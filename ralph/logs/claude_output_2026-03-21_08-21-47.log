{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01R2xHS56w4tvphhgyjGtuSW","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→import { Command } from 'commander';\n     3→\n     4→// Mock dependencies\n     5→vi.mock('../../lib/output.js', () => ({\n     6→  ok: vi.fn(),\n     7→  fail: vi.fn(),\n     8→  warn: vi.fn(),\n     9→  info: vi.fn(),\n    10→  jsonOutput: vi.fn(),\n    11→}));\n    12→\n    13→vi.mock('../../lib/onboard-checks.js', () => ({\n    14→  runPreconditions: vi.fn(),\n    15→}));\n    16→\n    17→vi.mock('../../modules/audit/index.js', () => ({\n    18→  runAudit: vi.fn(),\n    19→  generateFixStories: vi.fn(),\n    20→  addFixStoriesToState: vi.fn(),\n    21→}));\n    22→\n    23→vi.mock('../../modules/audit/report.js', () => ({\n    24→  formatAuditHuman: vi.fn(),\n    25→  formatAuditJson: vi.fn(),\n    26→}));\n    27→\n    28→import { ok as okOutput, fail as failOutput, info, jsonOutput } from '../../lib/output.js';\n    29→import { runPreconditions } from '../../lib/onboard-checks.js';\n    30→import { runAudit, generateFixStories, addFixStoriesToState } from '../../modules/audit/index.js';\n    31→import { formatAuditHuman, formatAuditJson } from '../../modules/audit/report.js';\n    32→import { registerAuditCommand } from '../audit.js';\n    33→\n    34→const mockRunPreconditions = vi.mocked(runPreconditions);\n    35→const mockRunAudit = vi.mocked(runAudit);\n    36→const mockFormatAuditHuman = vi.mocked(formatAuditHuman);\n    37→const mockFormatAuditJson = vi.mocked(formatAuditJson);\n    38→const mockFailOutput = vi.mocked(failOutput);\n    39→const mockOkOutput = vi.mocked(okOutput);\n    40→const mockInfoOutput = vi.mocked(info);\n    41→const mockJsonOutput = vi.mocked(jsonOutput);\n    42→const mockGenerateFixStories = vi.mocked(generateFixStories);\n    43→const mockAddFixStoriesToState = vi.mocked(addFixStoriesToState);\n    44→\n    45→beforeEac