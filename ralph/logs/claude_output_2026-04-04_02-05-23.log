{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RAoFqp4SHtQDJiAxCfrm3N","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach } from 'vitest';\n2\t\n3\t// Create controllable mocks — must use vi.hoisted so they're available in vi.mock factories\n4\tconst { mockExecAsync, mockAppendFileSync, mockMkdirSync } = vi.hoisted(() => ({\n5\t  mockExecAsync: vi.fn(),\n6\t  mockAppendFileSync: vi.fn(),\n7\t  mockMkdirSync: vi.fn(),\n8\t}));\n9\t\n10\t// Mock node:child_process\n11\tvi.mock('node:child_process', () => ({\n12\t  exec: vi.fn(),\n13\t}));\n14\t\n15\t// Mock node:util to return our controllable mockExecAsync\n16\tvi.mock('node:util', () => ({\n17\t  promisify: () => mockExecAsync,\n18\t}));\n19\t\n20\t// Mock node:fs\n21\tvi.mock('node:fs', () => ({\n22\t  appendFileSync: mockAppendFileSync,\n23\t  mkdirSync: mockMkdirSync,\n24\t}));\n25\t\n26\timport {\n27\t  validateMerge,\n28\t  parseTestOutput,\n29\t  writeMergeTelemetry,\n30\t  type ValidateMergeOptions,\n31\t  type ValidationResult,\n32\t} from '../cross-worktree-validator.js';\n33\t\n34\tdescribe('cross-worktree-validator', () => {\n35\t  beforeEach(() => {\n36\t    vi.clearAllMocks();\n37\t  });\n38\t\n39\t  // --- Interface Shape Tests (AC #7, #8) ---\n40\t\n41\t  describe('ValidateMergeOptions interface shape (AC #8)', () => {\n42\t    it('has all required fields', () => {\n43\t      const opts: ValidateMergeOptions = {\n44\t        testCommand: 'npm test',\n45\t        cwd: '/repo',\n46\t        epicId: '18',\n47\t        writeTelemetry: true,\n48\t      };\n49\t      expect(opts).toHaveProperty('testCommand');\n50\t      expect(opts).toHaveProperty('cwd');\n51\t      expect(opts).toHaveProperty('epicId');\n52\t      expect(opts).toHaveProperty('writeTelemetry');\n53\t    });\n54\t\n55\t    it('accepts optional storyKey', () => {\n56\t      const opts: ValidateMergeOptions = {\n57\t        testCommand: 'npm test',\n58\t        cwd: '/repo',\n59\t        epicId: '18',\n60\t        storyKey: 'merge-18-custom',\n61\t        writeTelemetry: false,\n62\t      };\n63\t      expect(opts.storyKey).toBe('merge-18-custom');\n64\t    });\n65\t  });\n66\t\n67\t  describe('ValidationResult interface shape (AC #7)', () => {\n68\t    it('has all required fields', () => {\n69\t      const result: ValidationResult = {\n70\t        valid: true,\n71\t        testResults: { passed: 10, failed: 0, coverage: 95.5 },\n72\t        output: '10 passed',\n73\t        durationMs: 1234,\n74\t      };\n75\t      expect(result).toHaveProperty('valid');\n76\t      expect(result).toHaveProperty('testResults');\n77\t      expect(result).toHaveProperty('output');\n78\t      expect(result).toHaveProperty('durationMs');\n79\t    });\n80\t\n81\t    it('testResults includes passed, failed, and optional coverage', () => {\n82\t      const withCov: ValidationResult = {\n83\t        valid: true,\n84\t        testResults: { passed: 5, failed: 0, coverage: 88.2 },\n85\t        output: '',\n86\t        durationMs: 100,\n87\t      };\n88\t      expect(withCov.testResults.passed).toBe(5);\n89\t      expect(withCov.testResults.failed).toBe(0);\n90\t      expect(withCov.testResults.coverage).toBe(88.2);\n91\t\n92\t      const withoutCov: ValidationResult = {\n93\t        valid: false,\n94\t        testResults: { passed: 3, failed: 2 },\n95\t        output: '',\n96\t        durationMs: 200,\n97\t      };\n98\t      expect(withoutCov.testResults.coverage).toBeUndefined();\n99\t    });\n100\t  });\n101\t\n102\t  // --- parseTestOutput Tests ---\n103\t\n104\t  describe('parseTestOutput (AC #1)', () => {\n105\t    it('parses passed and failed counts', () => {\n106\t      const result = parseTestOutput('10 passed\\n2 failed');\n107\t      expect(result.passed).toBe(10);\n108\t      expect(result.failed).toBe(2);\n109\t    });\n110\t\n111\t    it('parses passed only', () => {\n112\t      const result = parseTestOutput('5 passed');\n113\t      expect(result.passed).toBe(5);\n114\t      expect(result.failed).toBe(0);\n115\t    });\n116\t\n117\t    it('parses coverage from \"All files\" pattern', () => {\n118\t      const result = parseTestOutput('10 passed\\n0 failed\\nAll files | 95.5');\n119\t      expect(result.coverage).toBe(95.5);\n120\t    });\n121\t\n122\t    it('returns 0/0 for unparseable output', () => {\n123\t      const result = parseTestOutput('Build completed successfully.');\n124\t      expect(result.passed).toBe(0);\n125\t      expect(result.failed).toBe(0);\n126\t      expect(result.coverage).toBeUndefined();\n127\t    });\n128\t\n129\t    it('handles empty string', () => {\n130\t      const result = parseTestOutput('');\n131\t      expect(result.passed).toBe(0);\n132\t      expect(result.failed).toBe(0);\n133\t    });\n134\t  });\n135\t\n136\t  // --- validateMerge Tests ---\n137\t\n138\t  describe('validateMerge — success path (AC #1)', () => {\n139\t    it('returns valid: true when tests pass', async () => {\n140\t      mockExecAsync.mockResolvedValue({ stdout: '10 passed\\n0 failed' });\n141\t\n142\t      const result = await validateMerge({\n143\t        testCommand: 'npm test',\n144\t        cwd: '/repo',\n145\t        epicId: '18',\n146\t        writeTelemetry: false,\n147\t      });\n148\t\n149\t      expect(result.valid).toBe(true);\n150\t      expect(result.testResults).toEqual({ passed: 10, failed: 0 });\n151\t      expect(result.output).toBe('10 passed\\n0 failed');\n152\t      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n153\t    });\n154\t\n155\t    it('includes coverage in test results when available', async () => {\n156\t      mockExecAsync.mockResolvedValue({ stdout: '10 passed\\nAll files | 95.5' });\n157\t\n158\t      const result = await validateMerge({\n159\t        testCommand: 'npm test',\n160\t        cwd: '/repo',\n161\t        epicId: '18',\n162\t        writeTelemetry: false,\n163\t      });\n164\t\n165\t      expect(result.valid).toBe(true);\n166\t      expect(result.testResults.coverage).toBe(95.5);\n167\t    });\n168\t  });\n169\t\n170\t  describe('validateMerge — failure path (AC #2)', () => {\n171\t    it('returns valid: false when tests fail', async () => {\n172\t      mockExecAsync.mockResolvedValue({ stdout: '5 passed\\n3 failed' });\n173\t\n174\t      const result = await validateMerge({\n175\t        testCommand: 'npm test',\n176\t        cwd: '/repo',\n177\t        epicId: '18',\n178\t        writeTelemetry: false,\n179\t      });\n180\t\n181\t      expect(result.valid).toBe(false);\n182\t      expect(result.testResults).toEqual({ passed: 5, failed: 3 });\n183\t      expect(result.output).toBe('5 passed\\n3 failed');\n184\t    });\n185\t\n186\t    it('returns valid: false when test command exits non-zero with parseable output', async () => {\n187\t      const err = new Error('Command failed') as Error & { stdout: string };\n188\t      err.stdout = '3 passed\\n2 failed\\nError: some test error';\n189\t      mockExecAsync.mockRejectedValue(err);\n190\t\n191\t      const result = await validateMerge({\n192\t        testCommand: 'npm test',\n193\t        cwd: '/repo',\n194\t        epicId: '18',\n195\t        writeTelemetry: false,\n196\t      });\n197\t\n198\t      expect(result.valid).toBe(false);\n199\t      expect(result.testResults).toEqual({ passed: 3, failed: 2 });\n200\t      expect(result.output).toContain('3 passed');\n201\t    });\n202\t\n203\t    it('returns failed: 1 when test command exits with no parseable output', async () => {\n204\t      const err = new Error('Command failed') as Error & { stdout: string };\n205\t      err.stdout = '';\n206\t      mockExecAsync.mockRejectedValue(err);\n207\t\n208\t      const result = await validateMerge({\n209\t        testCommand: 'npm test',\n210\t        cwd: '/repo',\n211\t        epicId: '18',\n212\t        writeTelemetry: false,\n213\t      });\n214\t\n215\t      expect(result.valid).toBe(false);\n216\t      expect(result.testResults).toEqual({ passed: 0, failed: 1 });\n217\t      expect(result.output).toBe('Test command failed with no output');\n218\t    });\n219\t\n220\t    it('handles error with no stdout property', async () => {\n221\t      mockExecAsync.mockRejectedValue(new Error('SIGTERM'));\n222\t\n223\t      const result = await validateMerge({\n224\t        testCommand: 'npm test',\n225\t        cwd: '/repo',\n226\t        epicId: '18',\n227\t        writeTelemetry: false,\n228\t      });\n229\t\n230\t      expect(result.valid).toBe(false);\n231\t      expect(result.testResults).toEqual({ passed: 0, failed: 1 });\n232\t    });\n233\t\n234\t    it('treats 0 passed 0 failed as failure (edge case)', async () => {\n235\t      mockExecAsync.mockResolvedValue({ stdout: 'Build completed successfully.' });\n236\t\n237\t      const result = await validateMerge({\n238\t        testCommand: 'npm test',\n239\t        cwd: '/repo',\n240\t        epicId: '18',\n241\t        writeTelemetry: false,\n242\t      });\n243\t\n244\t      // 0 passed && 0 failed => valid = false (passed must be > 0)\n245\t      expect(result.valid).toBe(false);\n246\t    });\n247\t  });\n248\t\n249\t  describe('validateMerge — timeout (AC #5)', () => {\n250\t    it('respects 5-minute timeout', async () => {\n251\t      mockExecAsync.mockResolvedValue({ stdout: '5 passed' });\n252\t\n253\t      await validateMerge({\n254\t        testCommand: 'npm test',\n255\t        cwd: '/repo',\n256\t        epicId: '18',\n257\t        writeTelemetry: false,\n258\t      });\n259\t\n260\t      expect(mockExecAsync).toHaveBeenCalledWith('npm test', {\n261\t        cwd: '/repo',\n262\t        timeout: 300_000,\n263\t      });\n264\t    });\n265\t\n266\t    it('handles timeout error as failure', async () => {\n267\t      const err = new Error('Process timed out') as Error & { stdout: string };\n268\t      err.stdout = '';\n269\t      mockExecAsync.mockRejectedValue(err);\n270\t\n271\t      const result = await validateMerge({\n272\t        testCommand: 'npm test',\n273\t        cwd: '/repo',\n274\t        epicId: '18',\n275\t        writeTelemetry: false,\n276\t      });\n277\t\n278\t      expect(result.valid).toBe(false);\n279\t      expect(result.testResults).toEqual({ passed: 0, failed: 1 });\n280\t    });\n281\t  });\n282\t\n283\t  // --- Telemetry Tests (AC #4, #9) ---\n284\t\n285\t  describe('validateMerge — telemetry integration (AC #4, #9)', () => {\n286\t    it('writes telemetry when writeTelemetry is true', async () => {\n287\t      mockExecAsync.mockResolvedValue({ stdout: '10 passed\\n0 failed' });\n288\t\n289\t      await validateMerge({\n290\t        testCommand: 'npm test',\n291\t        cwd: '/repo',\n292\t        epicId: '18',\n293\t        writeTelemetry: true,\n294\t      });\n295\t\n296\t      expect(mockMkdirSync).toHaveBeenCalledWith('/repo/.codeharness', { recursive: true });\n297\t      expect(mockAppendFileSync).toHaveBeenCalledOnce();\n298\t      const written = mockAppendFileSync.mock.calls[0][1] as string;\n299\t      const entry = JSON.parse(written.trim());\n300\t      expect(entry.version).toBe(1);\n301\t      expect(entry.storyKey).toBe('merge-18');\n302\t      expect(entry.epicId).toBe('18');\n303\t      expect(entry.testResults.passed).toBe(10);\n304\t      expect(entry.testResults.failed).toBe(0);\n305\t      expect(entry.errors).toEqual([]);\n306\t    });\n307\t\n308\t    it('skips telemetry when writeTelemetry is false', async () => {\n309\t      mockExecAsync.mockResolvedValue({ stdout: '10 passed' });\n310\t\n311\t      await validateMerge({\n312\t        testCommand: 'npm test',\n313\t        cwd: '/repo',\n314\t        epicId: '18',\n315\t        writeTelemetry: false,\n316\t      });\n317\t\n318\t      expect(mockAppendFileSync).not.toHaveBeenCalled();\n319\t    });\n320\t\n321\t    it('writes telemetry on failure with error message', async () => {\n322\t      mockExecAsync.mockResolvedValue({ stdout: '5 passed\\n2 failed' });\n323\t\n324\t      await validateMerge({\n325\t        testCommand: 'npm test',\n326\t        cwd: '/repo',\n327\t        epicId: '18',\n328\t        writeTelemetry: true,\n329\t      });\n330\t\n331\t      expect(mockAppendFileSync).toHaveBeenCalledOnce();\n332\t      const written = mockAppendFileSync.mock.calls[0][1] as string;\n333\t      const entry = JSON.parse(written.trim());\n334\t      expect(entry.errors).toEqual(['Test suite failed after merge']);\n335\t      expect(entry.testResults.failed).toBe(2);\n336\t    });\n337\t\n338\t    it('telemetry entry has storyKey: merge-{epicId} format (AC #9)', async () => {\n339\t      mockExecAsync.mockResolvedValue({ stdout: '5 passed' });\n340\t\n341\t      await validateMerge({\n342\t        testCommand: 'npm test',\n343\t        cwd: '/repo',\n344\t        epicId: '42',\n345\t        writeTelemetry: true,\n346\t      });\n347\t\n348\t      const written = mockAppendFileSync.mock.calls[0][1] as string;\n349\t      const entry = JSON.parse(written.trim());\n350\t      expect(entry.storyKey).toBe('merge-42');\n351\t    });\n352\t\n353\t    it('uses custom storyKey when provided (AC #9)', async () => {\n354\t      mockExecAsync.mockResolvedValue({ stdout: '5 passed' });\n355\t\n356\t      await validateMerge({\n357\t        testCommand: 'npm test',\n358\t        cwd: '/repo',\n359\t        epicId: '42',\n360\t        storyKey: 'custom-key',\n361\t        writeTelemetry: true,\n362\t      });\n363\t\n364\t      const written = mockAppendFileSync.mock.calls[0][1] as string;\n365\t      const entry = JSON.parse(written.trim());\n366\t      expect(entry.storyKey).toBe('custom-key');\n367\t    });\n368\t\n369\t    it('telemetry entry includes duration_ms and timestamp', async () => {\n370\t      mockExecAsync.mockResolvedValue({ stdout: '5 passed' });\n371\t\n372\t      await validateMerge({\n373\t        testCommand: 'npm test',\n374\t        cwd: '/repo',\n375\t        epicId: '18',\n376\t        writeTelemetry: true,\n377\t      });\n378\t\n379\t      const written = mockAppendFileSync.mock.calls[0][1] as string;\n380\t      const entry = JSON.parse(written.trim());\n381\t      expect(typeof entry.duration_ms).toBe('number');\n382\t      expect(entry.duration_ms).toBeGreaterThanOrEqual(0);\n383\t      expect(typeof entry.timestamp).toBe('string');\n384\t      expect(entry.cost_usd).toBeNull();\n385\t      expect(entry.attempts).toBeNull();\n386\t      expect(entry.acResults).toBeNull();\n387\t      expect(entry.filesChanged).toEqual([]);\n388\t    });\n389\t\n390\t    it('telemetry write failure does not break validation', async () => {\n391\t      mockExecAsync.mockResolvedValue({ stdout: '10 passed\\n0 failed' });\n392\t      mockAppendFileSync.mockImplementation(() => {\n393\t        throw new Error('ENOSPC: no space left on device');\n394\t      });\n395\t\n396\t      const result = await validateMerge({\n397\t        testCommand: 'npm test',\n398\t        cwd: '/repo',\n399\t        epicId: '18',\n400\t        writeTelemetry: true,\n401\t      });\n402\t\n403\t      // Validation should still succeed despite telemetry failure\n404\t      expect(result.valid).toBe(true);\n405\t      expect(result.testResults).toEqual({ passed: 10, failed: 0 });\n406\t    });\n407\t\n408\t    it('writes telemetry on test command error when writeTelemetry is true', async () => {\n409\t      const err = new Error('Command failed') as Error & { stdout: string };\n410\t      err.stdout = '2 passed\\n3 failed';\n411\t      mockExecAsync.mockRejectedValue(err);\n412\t\n413\t      await validateMerge({\n414\t        testCommand: 'npm test',\n415\t        cwd: '/repo',\n416\t        epicId: '18',\n417\t        writeTelemetry: true,\n418\t      });\n419\t\n420\t      expect(mockAppendFileSync).toHaveBeenCalledOnce();\n421\t      const written = mockAppendFileSync.mock.calls[0][1] as string;\n422\t      const entry = JSON.parse(written.trim());\n423\t      expect(entry.testResults.passed).toBe(2);\n424\t      expect(entry.testResults.failed).toBe(3);\n425\t    });\n426\t\n427\t    it('writes telemetry on no-output error when writeTelemetry is true', async () => {\n428\t      const err = new Error('Command failed') as Error & { stdout: string };\n429\t      err.stdout = '';\n430\t      mockExecAsync.mockRejectedValue(err);\n431\t\n432\t      await validateMerge({\n433\t        testCommand: 'npm test',\n434\t        cwd: '/repo',\n435\t        epicId: '18',\n436\t        writeTelemetry: true,\n437\t      });\n438\t\n439\t      expect(mockAppendFileSync).toHaveBeenCalledOnce();\n440\t      const written = mockAppendFileSync.mock.calls[0][1] as string;\n441\t      const entry = JSON.parse(written.trim());\n442\t      expect(entry.testResults).toEqual({ passed: 0, failed: 1 });\n443\t      expect(entry.errors).toEqual(['Test suite failed after merge']);\n444\t    });\n445\t  });\n446\t\n447\t  // --- writeMergeTelemetry Tests ---\n448\t\n449\t  describe('writeMergeTelemetry (exported helper)', () => {\n450\t    it('writes NDJSON entry to .codeharness/telemetry.jsonl', () => {\n451\t      const opts: ValidateMergeOptions = {\n452\t        testCommand: 'npm test',\n453\t        cwd: '/repo',\n454\t        epicId: '18',\n455\t        writeTelemetry: true,\n456\t      };\n457\t      const result: ValidationResult = {\n458\t        valid: true,\n459\t        testResults: { passed: 10, failed: 0 },\n460\t        output: '10 passed',\n461\t        durationMs: 500,\n462\t      };\n463\t\n464\t      writeMergeTelemetry(opts, result);\n465\t\n466\t      expect(mockMkdirSync).toHaveBeenCalledWith('/repo/.codeharness', { recursive: true });\n467\t      expect(mockAppendFileSync).toHaveBeenCalledWith(\n468\t        '/repo/.codeharness/telemetry.jsonl',\n469\t        expect.stringContaining('\"storyKey\":\"merge-18\"'),\n470\t      );\n471\t    });\n472\t\n473\t    it('silently catches write failures', () => {\n474\t      mockAppendFileSync.mockImplementation(() => {\n475\t        throw new Error('Permission denied');\n476\t      });\n477\t\n478\t      const opts: ValidateMergeOptions = {\n479\t        testCommand: 'npm test',\n480\t        cwd: '/repo',\n481\t        epicId: '18',\n482\t        writeTelemetry: true,\n483\t      };\n484\t      const result: ValidationResult = {\n485\t        valid: true,\n486\t        testResults: { passed: 5, failed: 0 },\n487\t        output: '',\n488\t        durationMs: 100,\n489\t      };\n490\t\n491\t      // Should not throw\n492\t      expect(() => writeMergeTelemetry(opts, result)).not.toThrow();\n493\t    });\n494\t  });\n495\t\n496\t  // --- Uses configured test command (AC #5) ---\n497\t\n498\t  describe('validateMerge — test command configuration (AC #5)', () => {\n499\t    it('uses the configured test command', async () => {\n500\t      mockExecAsync.mockResolvedValue({ stdout: '5 passed' });\n501\t\n502\t      await validateMerge({\n503\t        testCommand: './node_modules/.bin/vitest run',\n504\t        cwd: '/my-project',\n505\t        epicId: '18',\n506\t        writeTelemetry: false,\n507\t      });\n508\t\n509\t      expect(mockExecAsync).toHaveBeenCalledWith('./node_modules/.bin/vitest run', {\n510\t        cwd: '/my-project',\n511\t        timeout: 300_000,\n512\t      });\n513\t    });\n514\t  });\n515\t\n516\t  // --- Regression: existing module tests still pass (AC #10) ---\n517\t\n518\t  describe('exports (AC #6)', () => {\n519\t    it('exports validateMerge function', () => {\n520\t      expect(typeof validateMerge).toBe('function');\n521\t    });\n522\t\n523\t    it('exports parseTestOutput function', () => {\n524\t      expect(typeof parseTestOutput).toBe('function');\n525\t    });\n526\t\n527\t    it('exports writeMergeTelemetry function', () => {\n528\t      expect(typeof writeMergeTelemetry).toBe('function');\n529\t    });\n530\t  });\n531\t});\n532\t"}]},"parent_tool_use_id":"toolu_01KN13KxQzTPDh38EUNUPmae","session_id":"22206bba-5847-41b1-b510-883e1dd8c0da","uuid":"5002d5a6-c09f-4188-872c-13b00051e4e1","timestamp":"2026-04-03T22:22:22.921Z"}
