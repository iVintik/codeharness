{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015W4S881WCGuykCByCCHDQm","type":"tool_result","content":"1\timport { Command } from 'commander';\n2\timport { existsSync, readFileSync } from 'node:fs';\n3\timport { join } from 'node:path';\n4\timport { ok, fail, info, warn, jsonOutput } from '../lib/output.js';\n5\timport { parseRetroActionItems, classifyFinding } from '../lib/retro-parser.js';\n6\timport { isGhAvailable, findExistingGhIssue, ghIssueCreate, ensureLabels, getRepoFromRemote } from '../lib/github.js';\n7\timport { readState, StateFileNotFoundError } from '../lib/state.js';\n8\timport type { Classification } from '../lib/retro-parser.js';\n9\timport type { RetroIssueTarget } from '../lib/github.js';\n10\t\n11\tconst STORY_DIR = '_bmad-output/implementation-artifacts';\n12\t\n13\t/** Maximum length for issue titles derived from action item descriptions. */\n14\tconst MAX_TITLE_LENGTH = 120;\n15\t\n16\tinterface ImportedIssue {\n17\t  number: string;\n18\t  title: string;\n19\t  gapId: string;\n20\t  classification: string;\n21\t  created: boolean;\n22\t  status: string;\n23\t  notes: string;\n24\t}\n25\t\n26\tinterface GitHubResult {\n27\t  created: number;\n28\t  skipped: number;\n29\t  errors: number;\n30\t}\n31\t\n32\tfunction classificationToString(c: Classification): string {\n33\t  if (c.type === 'tool') {\n34\t    return `tool:${c.name}`;\n35\t  }\n36\t  return c.type;\n37\t}\n38\t\n39\texport function registerRetroImportCommand(program: Command): void {\n40\t  program\n41\t    .command('retro-import')\n42\t    .description('Import retrospective action items as GitHub issues')\n43\t    .requiredOption('--epic <n>', 'Epic number to import action items from')\n44\t    .action((opts, cmd) => {\n45\t      const globalOpts = cmd.optsWithGlobals();\n46\t      const isJson = globalOpts.json === true;\n47\t      const root = process.cwd();\n48\t\n49\t      // Validate epic number\n50\t      const epicNum = parseInt(opts.epic, 10);\n51\t      if (isNaN(epicNum) || epicNum < 1) {\n52\t        fail(`Invalid epic number: ${opts.epic}`, { json: isJson });\n53\t        process.exitCode = 1;\n54\t        return;\n55\t      }\n56\t\n57\t      // Read retro file\n58\t      const retroFile = `epic-${epicNum}-retrospective.md`;\n59\t      const retroPath = join(root, STORY_DIR, retroFile);\n60\t\n61\t      if (!existsSync(retroPath)) {\n62\t        fail(`Retro file not found: ${retroFile}`, { json: isJson });\n63\t        process.exitCode = 1;\n64\t        return;\n65\t      }\n66\t\n67\t      let content: string;\n68\t      try {\n69\t        content = readFileSync(retroPath, 'utf-8');\n70\t      } catch (err: unknown) {\n71\t        const message = err instanceof Error ? err.message : String(err);\n72\t        fail(`Failed to read retro file: ${message}`, { json: isJson });\n73\t        process.exitCode = 1;\n74\t        return;\n75\t      }\n76\t\n77\t      // Parse action items\n78\t      const items = parseRetroActionItems(content);\n79\t\n80\t      if (items.length === 0) {\n81\t        if (isJson) {\n82\t          jsonOutput({ imported: 0, skipped: 0, issues: [] });\n83\t        } else {\n84\t          info('No action items found in retro file');\n85\t        }\n86\t        return;\n87\t      }\n88\t\n89\t      // TODO: v2 issue tracker (Epic 8) — beads import removed, items collected for GitHub only\n90\t      const imported = 0;\n91\t      const skipped = 0;\n92\t      const issues: ImportedIssue[] = [];\n93\t\n94\t      for (const item of items) {\n95\t        const classification = classifyFinding(item);\n96\t        const gapId = `[gap:retro:epic-${epicNum}-item-${item.number}]`;\n97\t\n98\t        // Truncate title to reasonable length\n99\t        const title =\n100\t          item.description.length > MAX_TITLE_LENGTH\n101\t            ? item.description.slice(0, MAX_TITLE_LENGTH - 3) + '...'\n102\t            : item.description;\n103\t\n104\t        const issueRecord: ImportedIssue = {\n105\t          number: item.number,\n106\t          title,\n107\t          gapId,\n108\t          classification: classificationToString(classification),\n109\t          created: false,\n110\t          status: item.status,\n111\t          notes: item.notes,\n112\t        };\n113\t\n114\t        issues.push(issueRecord);\n115\t\n116\t        if (!isJson) {\n117\t          info(`Parsed: ${title}`);\n118\t        }\n119\t      }\n120\t\n121\t      // ─── GitHub Issue Creation Phase ────────────────────────────────────\n122\t      const githubResult = createGitHubIssues(issues, epicNum, isJson);\n123\t\n124\t      if (isJson) {\n125\t        jsonOutput({\n126\t          imported,\n127\t          skipped,\n128\t          issues: issues as unknown as Record<string, unknown>[],\n129\t          github: githubResult as unknown as Record<string, unknown>,\n130\t        });\n131\t      }\n132\t    });\n133\t}\n134\t\n135\t/**\n136\t * Resolves the target repo for a classification based on retro_issue_targets config.\n137\t */\n138\tfunction resolveTargetRepo(\n139\t  classification: string,\n140\t  targets: RetroIssueTarget[],\n141\t): RetroIssueTarget | undefined {\n142\t  if (targets.length === 0) return undefined;\n143\t\n144\t  if (classification === 'harness') {\n145\t    // Prefer explicit codeharness repo, then first non-auto, then auto as fallback\n146\t    const explicit = targets.find(t => t.repo === 'iVintik/codeharness');\n147\t    if (explicit) return explicit;\n148\t    const nonAuto = targets.find(t => t.repo !== 'auto');\n149\t    if (nonAuto) return nonAuto;\n150\t    return targets[0];\n151\t  }\n152\t\n153\t  // project or tool:* → prefer auto, else first target\n154\t  const auto = targets.find(t => t.repo === 'auto');\n155\t  if (auto) return auto;\n156\t  return targets[0];\n157\t}\n158\t\n159\t/**\n160\t * Builds the GitHub issue body with retro context and gap-id for dedup.\n161\t */\n162\tfunction buildGitHubIssueBody(\n163\t  item: ImportedIssue,\n164\t  epicNum: number,\n165\t  projectName: string,\n166\t): string {\n167\t  return `## Retro Action Item ${item.number} — Epic ${epicNum}\n168\t\n169\t**Source project:** ${projectName}\n170\t**Classification:** ${item.classification}\n171\t**Original status:** ${item.status}\n172\t**Notes:** ${item.notes}\n173\t\n174\t${item.title}\n175\t\n176\t<!-- gap-id: ${item.gapId} -->`;\n177\t}\n178\t\n179\t/**\n180\t * GitHub issue creation phase.\n181\t */\n182\tfunction createGitHubIssues(\n183\t  issues: ImportedIssue[],\n184\t  epicNum: number,\n185\t  isJson: boolean,\n186\t): GitHubResult | undefined {\n187\t  // Read state to check for retro_issue_targets\n188\t  let targets: RetroIssueTarget[] | undefined;\n189\t  try {\n190\t    const state = readState();\n191\t    targets = state.retro_issue_targets;\n192\t  } catch (err: unknown) {\n193\t    if (err instanceof StateFileNotFoundError) {\n194\t      if (!isJson) {\n195\t        info('No state file found — skipping GitHub issues');\n196\t      }\n197\t      return undefined;\n198\t    }\n199\t    // Other state errors — skip GitHub phase gracefully\n200\t    if (!isJson) {\n201\t      info('Could not read state file — skipping GitHub issues');\n202\t    }\n203\t    return undefined;\n204\t  }\n205\t\n206\t  if (!targets || targets.length === 0) {\n207\t    if (!isJson) {\n208\t      info('No retro_issue_targets configured — skipping GitHub issues');\n209\t    }\n210\t    return undefined;\n211\t  }\n212\t\n213\t  // Check gh CLI availability\n214\t  if (!isGhAvailable()) {\n215\t    if (!isJson) {\n216\t      warn('gh CLI not available — skipping GitHub issue creation');\n217\t    }\n218\t    return undefined;\n219\t  }\n220\t\n221\t  // Resolve \"auto\" repos\n222\t  const resolvedAutoRepo = getRepoFromRemote();\n223\t\n224\t  const result: GitHubResult = { created: 0, skipped: 0, errors: 0 };\n225\t\n226\t  // Detect project name from git remote\n227\t  const projectName = resolvedAutoRepo ?? 'unknown';\n228\t\n229\t  for (const item of issues) {\n230\t    const target = resolveTargetRepo(item.classification, targets);\n231\t    if (!target) continue;\n232\t\n233\t    // Resolve actual repo name\n234\t    const repo = target.repo === 'auto' ? resolvedAutoRepo : target.repo;\n235\t    if (!repo) {\n236\t      if (!isJson) {\n237\t        warn(`Cannot resolve repo for ${item.number} — git remote not detected`);\n238\t      }\n239\t      result.errors++;\n240\t      continue;\n241\t    }\n242\t\n243\t    try {\n244\t      // Check for existing issue (dedup)\n245\t      const existing = findExistingGhIssue(repo, item.gapId);\n246\t      if (existing) {\n247\t        if (!isJson) {\n248\t          info(`GitHub issue exists: ${repo}#${existing.number}`);\n249\t        }\n250\t        result.skipped++;\n251\t        continue;\n252\t      }\n253\t\n254\t      // Ensure labels exist\n255\t      ensureLabels(repo, target.labels);\n256\t\n257\t      // Create the issue\n258\t      const body = buildGitHubIssueBody(item, epicNum, projectName);\n259\t      const created = ghIssueCreate(repo, item.title, body, target.labels);\n260\t      if (!isJson) {\n261\t        ok(`GitHub issue created: ${repo}#${created.number}`);\n262\t      }\n263\t      result.created++;\n264\t    } catch (err: unknown) {\n265\t      const message = err instanceof Error ? err.message : String(err);\n266\t      if (!isJson) {\n267\t        fail(`GitHub issue failed for ${item.number}: ${message}`);\n268\t      }\n269\t      result.errors++;\n270\t    }\n271\t  }\n272\t\n273\t  return result;\n274\t}\n275\t"}]},"parent_tool_use_id":"toolu_01RQfCFNpbMDVkdeQs35oAee","session_id":"3f15b50c-2c9b-40fa-9e63-9fad2199af43","uuid":"edd8801d-043a-4b7a-ab0f-7a780a4e0e36","timestamp":"2026-04-03T02:21:45.338Z"}
