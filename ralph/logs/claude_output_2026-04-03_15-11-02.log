  });\n116\t});\n117\t\n118\tdescribe('Separator component', () => {\n119\t  it('renders a line of heavy bar characters', () => {\n120\t    const { lastFrame } = render(<Separator />);\n121\t    const frame = lastFrame()!;\n122\t    expect(frame).toContain('━━━');\n123\t    // Verify it uses only ━ characters\n124\t    expect(frame.trim()).toMatch(/^━+$/);\n125\t  });\n126\t});\n127\t\n128\tdescribe('Header with elapsed time (AC #3)', () => {\n129\t  it('renders elapsed time when provided', () => {\n130\t    const info: SprintInfo = {\n131\t      storyKey: '3-2',\n132\t      phase: 'verify',\n133\t      done: 18,\n134\t      total: 65,\n135\t      elapsed: '47m',\n136\t      iterationCount: 3,\n137\t      totalCost: 12.30,\n138\t    };\n139\t    const { lastFrame } = render(<Header info={info} />);\n140\t    const frame = lastFrame()!;\n141\t    expect(frame).toContain('codeharness run');\n142\t    expect(frame).toContain('iteration 3');\n143\t    expect(frame).toContain('47m elapsed');\n144\t    expect(frame).toContain('$12.30 spent');\n145\t    expect(frame).toContain('Story: 3-2');\n146\t    expect(frame).toContain('Phase: verify');\n147\t  });\n148\t\n149\t  it('omits elapsed when not provided', () => {\n150\t    const info: SprintInfo = {\n151\t      storyKey: '1-1',\n152\t      phase: 'dev',\n153\t      done: 0,\n154\t      total: 5,\n155\t    };\n156\t    const { lastFrame } = render(<Header info={info} />);\n157\t    const frame = lastFrame()!;\n158\t    expect(frame).toContain('Story: 1-1');\n159\t    expect(frame).not.toContain('undefined');\n160\t  });\n161\t});\n162\t\n163\tdescribe('StoryBreakdown component (AC #4)', () => {\n164\t  it('renders labeled sections: Done, This, Next, Blocked', () => {\n165\t    const stories: StoryStatusEntry[] = [\n166\t      { key: '3-1-some-story', status: 'done' },\n167\t      { key: '4-1-another', status: 'done' },\n168\t      { key: '3-2-current', status: 'in-progress' },\n169\t      { key: '3-3-next-one', status: 'pending' },\n170\t      { key: '0-1-stuck', status: 'blocked', retryCount: 10, maxRetries: 10 },\n171\t    ];\n172\t    const { lastFrame } = render(<StoryBreakdown stories={stories} />);\n173\t    const frame = lastFrame()!;\n174\t    // Done: individual short keys with checkmarks\n175\t    expect(frame).toContain('Done:');\n176\t    expect(frame).toContain('3-1 ✓');\n177\t    expect(frame).toContain('4-1 ✓');\n178\t    // This: current story with diamond\n179\t    expect(frame).toContain('This:');\n180\t    expect(frame).toContain('3-2 ◆');\n181\t    // Next: next pending story\n182\t    expect(frame).toContain('Next:');\n183\t    expect(frame).toContain('3-3');\n184\t    // Blocked: with ✕ and retry counts\n185\t    expect(frame).toContain('Blocked:');\n186\t    expect(frame).toContain('0-1 ✕');\n187\t    expect(frame).toContain('(10/10)');\n188\t  });\n189\t\n190\t  it('renders nothing when stories array is empty', () => {\n191\t    const { lastFrame } = render(<StoryBreakdown stories={[]} />);\n192\t    expect(lastFrame()).toBe('');\n193\t  });\n194\t\n195\t  it('renders failed stories with ✗', () => {\n196\t    const stories: StoryStatusEntry[] = [\n197\t      { key: '2-3-broken', status: 'failed', retryCount: 5, maxRetries: 10 },\n198\t    ];\n199\t    const { lastFrame } = render(<StoryBreakdown stories={stories} />);\n200\t    const frame = lastFrame()!;\n201\t    expect(frame).toContain('Failed:');\n202\t    expect(frame).toContain('2-3 ✗');\n203\t    expect(frame).toContain('(5/10)');\n204\t  });\n205\t\n206\t  it('shows +N indicator for multiple pending stories', () => {\n207\t    const stories: StoryStatusEntry[] = [\n208\t      { key: '1-1-a', status: 'pending' },\n209\t      { key: '2-1-b', status: 'pending' },\n210\t      { key: '3-1-c', status: 'pending' },\n211\t      { key: '4-1-d', status: 'pending' },\n212\t      { key: '5-1-e', status: 'pending' },\n213\t    ];\n214\t    const { lastFrame } = render(<StoryBreakdown stories={stories} />);\n215\t    const frame = lastFrame()!;\n216\t    expect(frame).toContain('Next:');\n217\t    expect(frame).toContain('1-1');\n218\t    expect(frame).toContain('+4 more');\n219\t  });\n220\t\n221\t  it('includes AC progress for current story when sprintInfo provided', () => {\n222\t    const stories: StoryStatusEntry[] = [\n223\t      { key: '3-2-current', status: 'in-progress' },\n224\t    ];\n225\t    const sprintInfo: SprintInfo = {\n226\t      storyKey: '3-2-current',\n227\t      phase: 'verifying',\n228\t      done: 5,\n229\t      total: 10,\n230\t      acProgress: '8/12',\n231\t    };\n232\t    const { lastFrame } = render(<StoryBreakdown stories={stories} sprintInfo={sprintInfo} />);\n233\t    const frame = lastFrame()!;\n234\t    expect(frame).toContain('This:');\n235\t    expect(frame).toContain('3-2 ◆');\n236\t    expect(frame).toContain('verifying');\n237\t    expect(frame).toContain('(8/12 ACs)');\n238\t  });\n239\t\n240\t  it('renders blocked stories without retry counts when not provided', () => {\n241\t    const stories: StoryStatusEntry[] = [\n242\t      { key: '1-1-stuck', status: 'blocked' },\n243\t    ];\n244\t    const { lastFrame } = render(<StoryBreakdown stories={stories} />);\n245\t    const frame = lastFrame()!;\n246\t    expect(frame).toContain('Blocked:');\n247\t    expect(frame).toContain('1-1 ✕');\n248\t    expect(frame).not.toContain('(');\n249\t  });\n250\t\n251\t  it('does not match story 3-20 as current when sprint info says 3-2 (key prefix collision)', () => {\n252\t    const stories: StoryStatusEntry[] = [\n253\t      { key: '3-2-current', status: 'in-progress' },\n254\t      { key: '3-20-other', status: 'in-progress' },\n255\t    ];\n256\t    const sprintInfo: SprintInfo = {\n257\t      storyKey: '3-2-current',\n258\t      phase: 'verifying',\n259\t      done: 5,\n260\t      total: 10,\n261\t      acProgress: '8/12',\n262\t    };\n263\t    const { lastFrame } = render(<StoryBreakdown stories={stories} sprintInfo={sprintInfo} />);\n264\t    