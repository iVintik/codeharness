{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011o6zZnVQ4ynE7VZZ2YfUGz","type":"tool_result","content":"     1→/**\n     2→ * Timeout capture — captures diagnostic data when a ralph iteration times out.\n     3→ * All functions return Result<T>, never throw.\n     4→ */\n     5→\n     6→import { readFileSync, writeFileSync, existsSync, mkdirSync, readdirSync } from 'node:fs';\n     7→import { execSync } from 'node:child_process';\n     8→import { join, dirname } from 'node:path';\n     9→import { ok, fail } from '../../types/result.js';\n    10→import type { Result } from '../../types/result.js';\n    11→import type { TimeoutCapture, TimeoutReport, TimeoutSummary } from './types.js';\n    12→\n    13→/** Git command timeout in milliseconds */\n    14→const GIT_TIMEOUT_MS = 5000;\n    15→\n    16→/** Default max lines to capture from output log */\n    17→const DEFAULT_MAX_LINES = 100;\n    18→\n    19→/**\n    20→ * Capture git diff summary (staged + unstaged) using --stat format.\n    21→ * Uses execSync with a 5-second timeout to prevent hanging.\n    22→ */\n    23→export function captureGitDiff(): Result<string> {\n    24→  try {\n    25→    const unstaged = execSync('git diff --stat', {\n    26→      timeout: GIT_TIMEOUT_MS,\n    27→      encoding: 'utf-8',\n    28→      stdio: ['pipe', 'pipe', 'pipe'],\n    29→    }).trim();\n    30→\n    31→    const staged = execSync('git diff --cached --stat', {\n    32→      timeout: GIT_TIMEOUT_MS,\n    33→      encoding: 'utf-8',\n    34→      stdio: ['pipe', 'pipe', 'pipe'],\n    35→    }).trim();\n    36→\n    37→    const parts: string[] = [];\n    38→    if (unstaged) parts.push('Unstaged:\\n' + unstaged);\n    39→    if (staged) parts.push('Staged:\\n' + staged);\n    40→\n    41→    if (parts.length === 0) {\n    42→      return ok('No changes detected');\n    43→    }\n    44→\n    45→    return ok(parts.join('\\n\\n'));\n    46→  } catch (err: unknown) {\n    47→    const msg = err instanceof Error ? err.message : String(err);\n    48→    return fail(`Failed to capture git diff: ${msg}`);\n    49→  }\n    50→}\n    51→\n    52→/**\n    53→ * Compare two sprint-state.json snapshots and return a human-readable delta\n    54→ * of changed story statuses.\n    55→ */\n    56→export function captureStateDelta(\n    57→  beforePath: string,\n    58→  afterPath: string,\n    59→): Result<string> {\n    60→  try {\n    61→    if (!existsSync(beforePath)) {\n    62→      return fail(`State snapshot not found: ${beforePath}`);\n    63→    }\n    64→    if (!existsSync(afterPath)) {\n    65→      return fail(`Current state file not found: ${afterPath}`);\n    66→    }\n    67→\n    68→    const beforeRaw = readFileSync(beforePath, 'utf-8');\n    69→    const afterRaw = readFileSync(afterPath, 'utf-8');\n    70→\n    71→    const before = JSON.parse(beforeRaw) as { stories?: Record<string, { status?: string }> };\n    72→    const after = JSON.parse(afterRaw) as { stories?: Record<string, { status?: string }> };\n    73→\n    74→    const beforeStories = before.stories ?? {};\n    75→    const afterStories = after.stories ?? {};\n    76→\n    77→    const allKeys = new Set([...Object.keys(beforeStories), ...Object.keys(afterStories)]);\n    78→    const changes: string[] = [];\n    79→\n    80→    for (const key of allKeys) {\n    81→      const beforeStatus = beforeStories[key]?.status ?? '(absent)';\n    82→      const afterStatus = afterStories[key]?.status ?? '(absent)';\n    83→      if (beforeStatus !== afterStatus) {\n    84→        changes.push(`${key}: ${beforeStatus} → ${afterStatus}`);\n    85→      }\n    86→    }\n    87→\n    88→    if (changes.length === 0) {\n    89→      return ok('No state changes');\n    90→    }\n    91→\n    92→    return ok(changes.join('\\n'));\n    93→  } catch (err: unknown) {\n    94→    const msg = err instanceof Error ? err.message : String(err);\n    95→    return fail(`Failed to capture state delta: ${msg}`);\n    96→  }\n    97→}\n    98→\n    99→/**\n   100→ * Read the last N lines from the iteration output log.\n   101→ */\n   102→export function capturePartialStderr(\n   103→  outputFile: string,\n   104→  maxLines: number = DEFAULT_MAX_LINES,\n   105→): Result<string> {\n   106→  try {\n   107→    if (!existsSync(outputFile)) {\n   108→      return fail(`Output file not found: ${outputFile}`);\n   109→    }\n   110→\n   111→    const content = readFileSync(outputFile, 'utf-8');\n   112→    const lines = content.split('\\n');\n   113→    // Drop trailing empty element from files ending with newline\n   114→    if (lines.length > 0 && lines[lines.length - 1] === '') {\n   115→      lines.pop();\n   116→    }\n   117→    const lastLines = lines.slice(-maxLines).join('\\n');\n   118→\n   119→    return ok(lastLines);\n   120→  } catch (err: unknown) {\n   121→    const msg = err instanceof Error ? err.message : String(err);\n   122→    return fail(`Failed to capture partial stderr: ${msg}`);\n   123→  }\n   124→}\n   125→\n   126→/**\n   127→ * Format a TimeoutCapture as a markdown report string.\n   128→ */\n   129→function formatReport(capture: TimeoutCapture): string {\n   130→  const lines: string[] = [\n   131→    `# Timeout Report: Iteration ${capture.iteration}`,\n   132→    '',\n   133→    `- **Story:** ${capture.storyKey}`,\n   134→    `- **Duration:** ${capture.durationMinutes} minutes (timeout)`,\n   135→    `- **Timestamp:** ${capture.timestamp}`,\n   136→    '',\n   137→    '## Git Changes',\n   138→    '',\n   139→    capture.gitDiff,\n   140→    '',\n   141→    '## State Delta',\n   142→    '',\n   143→    capture.stateDelta,\n   144→    '',\n   145→    '## Partial Output (last 100 lines)',\n   146→    '',\n   147→    '```',\n   148→    capture.partialStderr,\n   149→    '```',\n   150→    '',\n   151→  ];\n   152→\n   153→  return lines.join('\\n');\n   154→}\n   155→\n   156→/**\n   157→ * Orchestrate all captures and write a markdown timeout report.\n   158→ * Handles partial failures gracefully — if git is unavailable, stderr is still captured.\n   159→ */\n   160→export function captureTimeoutReport(opts: {\n   161→  storyKey: string;\n   162→  iteration: number;\n   163→  durationMinutes: number;\n   164→  outputFile: string;\n   165→  stateSnapshotPath: string;\n   166→}): Result<TimeoutReport> {\n   167→  try {\n   168→    if (opts.iteration < 1 || !Number.isInteger(opts.iteration)) {\n   169→      return fail(`Invalid iteration number: ${opts.iteration}`);\n   170→    }\n   171→    if (opts.durationMinutes < 0) {\n   172→      return fail(`Invalid duration: ${opts.durationMinutes}`);\n   173→    }\n   174→\n   175→    const timestamp = new Date().toISOString();\n   176→\n   177→    // Capture git diff — graceful degradation\n   178→    const gitResult = captureGitDiff();\n   179→    const gitDiff = gitResult.success ? gitResult.data : `(unavailable: ${gitResult.error})`;\n   180→\n   181→    // Capture state delta — graceful degradation\n   182→    const statePath = join(process.cwd(), 'sprint-state.json');\n   183→    const deltaResult = captureStateDelta(opts.stateSnapshotPath, statePath);\n   184→    const stateDelta = deltaResult.success ? deltaResult.data : `(unavailable: ${deltaResult.error})`;\n   185→\n   186→    // Capture partial stderr — graceful degradation\n   187→    const stderrResult = capturePartialStderr(opts.outputFile);\n   188→    const partialStderr = stderrResult.success ? stderrResult.data : `(unavailable: ${stderrResult.error})`;\n   189→\n   190→    const capture: TimeoutCapture = {\n   191→      storyKey: opts.storyKey,\n   192→      iteration: opts.iteration,\n   193→      durationMinutes: opts.durationMinutes,\n   194→      gitDiff,\n   195→      stateDelta,\n   196→      partialStderr,\n   197→      timestamp,\n   198→    };\n   199→\n   200→    // Write report file — sanitize story key for safe filenames\n   201→    const reportDir = join(process.cwd(), 'ralph', 'logs');\n   202→    const safeStoryKey = opts.storyKey.replace(/[^a-zA-Z0-9._-]/g, '_');\n   203→    const reportFileName = `timeout-report-${opts.iteration}-${safeStoryKey}.md`;\n   204→    const reportPath = join(reportDir, reportFileName);\n   205→\n   206→    // Ensure directory exists\n   207→    if (!existsSync(reportDir)) {\n   208→      mkdirSync(reportDir, { recursive: true });\n   209→    }\n   210→\n   211→    const reportContent = formatReport(capture);\n   212→    writeFileSync(reportPath, reportContent, 'utf-8');\n   213→\n   214→    return ok({\n   215→      filePath: reportPath,\n   216→      capture,\n   217→    });\n   218→  } catch (err: unknown) {\n   219→    const msg = err instanceof Error ? err.message : String(err);\n   220→    return fail(`Failed to capture timeout report: ${msg}`);\n   221→  }\n   222→}\n   223→\n   224→/**\n   225→ * Find the latest timeout report for a given story key.\n   226→ * Scans ralph/logs/ for timeout-report-<N>-<storyKey>.md files,\n   227→ * parses the report to extract summary info.\n   228→ * Returns null if no timeout report exists.\n   229→ */\n   230→export function findLatestTimeoutReport(storyKey: string): Result<TimeoutSummary | null> {\n   231→  try {\n   232→    const reportDir = join(process.cwd(), 'ralph', 'logs');\n   233→    if (!existsSync(reportDir)) {\n   234→      return ok(null);\n   235→    }\n   236→\n   237→    const safeStoryKey = storyKey.replace(/[^a-zA-Z0-9._-]/g, '_');\n   238→    const prefix = `timeout-report-`;\n   239→    const suffix = `-${safeStoryKey}.md`;\n   240→\n   241→    const files = readdirSync(reportDir, { encoding: 'utf-8' });\n   242→    const matches: Array<{ fileName: string; iteration: number }> = [];\n   243→\n   244→    for (const f of files) {\n   245→      if (f.startsWith(prefix) && f.endsWith(suffix)) {\n   246→        const iterStr = f.slice(prefix.length, f.length - suffix.length);\n   247→        const iteration = parseInt(iterStr, 10);\n   248→        if (!isNaN(iteration) && iteration > 0) {\n   249→          matches.push({ fileName: f, iteration });\n   250→        }\n   251→      }\n   252→    }\n   253→\n   254→    if (matches.length === 0) {\n   255→      return ok(null);\n   256→    }\n   257→\n   258→    // Pick the highest iteration\n   259→    matches.sort((a, b) => b.iteration - a.iteration);\n   260→    const latest = matches[0];\n   261→    const reportPath = join(reportDir, latest.fileName);\n   262→\n   263→    // Parse the report to extract duration and files changed count\n   264→    const content = readFileSync(reportPath, 'utf-8');\n   265→    let durationMinutes = 0;\n   266→    let filesChanged = 0;\n   267→\n   268→    const durationMatch = content.match(/\\*\\*Duration:\\*\\*\\s*(\\d+)\\s*minutes/);\n   269→    if (durationMatch) {\n   270→      durationMinutes = parseInt(durationMatch[1], 10);\n   271→    }\n   272→\n   273→    // Count \"file changed\" or \"files changed\" lines in git diff stat\n   274→    const filesMatch = content.match(/(\\d+)\\s+files?\\s+changed/g);\n   275→    if (filesMatch) {\n   276→      for (const m of filesMatch) {\n   277→        const numMatch = m.match(/^(\\d+)/);\n   278→        if (numMatch) {\n   279→          filesChanged += parseInt(numMatch[1], 10);\n   280→        }\n   281→      }\n   282→    }\n   283→\n   284→    return ok({\n   285→      reportPath,\n   286→      iteration: latest.iteration,\n   287→      durationMinutes,\n   288→      filesChanged,\n   289→    });\n   290→  } catch (err: unknown) {\n   291→    const msg = err instanceof Error ? err.message : String(err);\n   292→    return fail(`Failed to find timeout report: ${msg}`);\n   293→  }\n   294→}\n   295→"}]},"parent_tool_use_id":"toolu_01KNQnUKBFtzFzrosUg6K7qd","session_id":"7d2c764f-deb1-4354-ad31-e0a846d19ae3","uuid":"fe705b64-6350-4965-b032-e0aea1022c6f","timestamp":"2026-03-25T00:17:25.222Z"}
