lse\n    },\n    {\n      \"id\": \"migrated-36\",\n      \"story\": \"15-5-lint-rule-bare-exception-swallowing\",\n      \"description\": \"HIGH: Hook grep pattern `except Exception.*pass` never matches multiline Python syntax (AC2 was non-functional). Fixed with awk-based multiline detection.\",\n      \"source\": \"retro\",\n      \"resolved\": false\n    },\n    {\n      \"id\": \"migrated-37\",\n      \"story\": \"15-5-lint-rule-bare-exception-swallowing\",\n      \"description\": \"HIGH: Semgrep `no-bare-except-ellipsis` rule was false positive generator — `...` is Semgrep wildcard, not Python Ellipsis. Fixed with `pattern-regex`.\",\n      \"source\": \"retro\",\n      \"resolved\": false\n    },\n    {\n      \"id\": \"migrated-38\",\n      \"story\": \"15-5-lint-rule-bare-exception-swallowing\",\n      \"description\": \"MEDIUM: Hook only detected `pass` but not Python `...` pattern. Fixed.\",\n      \"source\": \"retro\",\n      \"resolved\": false\n    },\n    {\n      \"id\": \"migrated-39\",\n      \"story\": \"15-5-lint-rule-bare-exception-swallowing\",\n      \"description\": \"MEDIUM: AGENTS.md stale after `additionalRulesDirs` addition. Fixed.\",\n      \"source\": \"retro\",\n      \"resolved\": false\n    },\n    {\n      \"id\": \"migrated-40\",\n      \"story\": \"15-5-lint-rule-bare-exception-swallowing\",\n      \"description\": \"Story lists `src/lib/scanner.ts` but change correctly went to `analyzer.ts` — story spec inaccuracy.\",\n      \"source\": \"retro\",\n      \"resolved\": false\n    }\n  ]\n}\n","structuredPatch":[{"oldStart":2,"oldLines":7,"newStart":2,"newLines":7,"lines":["   \"version\": 2,","   \"sprint\": {","     \"total\": 74,","-    \"done\": 63,","+    \"done\": 64,","     \"failed\": 0,","     \"blocked\": 0,","     \"inProgress\": null"]}],"userModified":false,"replaceAll":false}}
