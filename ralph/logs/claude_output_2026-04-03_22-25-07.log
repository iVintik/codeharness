{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LVESBH9MfhSmqVKwLRkP98","type":"tool_result","content":"580\t\n581\t  // 11. Record session ID (if dispatch returned one)\n582\t  let updatedState = state;\n583\t  if (resultSessionId) {\n584\t    updatedState = recordSessionId(sessionKey, resultSessionId, updatedState);\n585\t  } else {\n586\t    // Append checkpoint manually when no session ID is returned\n587\t    const checkpoint: TaskCheckpoint = {\n588\t      task_name: taskName,\n589\t      story_key: storyKey,\n590\t      completed_at: new Date().toISOString(),\n591\t    };\n592\t    updatedState = {\n593\t      ...updatedState,\n594\t      tasks_completed: [...updatedState.tasks_completed, checkpoint],\n595\t    };\n596\t  }\n597\t\n598\t  // 12. Record trace ID\n599\t  updatedState = recordTraceId(traceId, updatedState);\n600\t\n601\t  // 12b. Construct and write output contract (Task 1)\n602\t  const durationMs = Date.now() - startMs;\n603\t  let contract: OutputContract | null = null;\n604\t  try {\n605\t    contract = {\n606\t      version: 1,\n607\t      taskName,\n608\t      storyId: storyKey,\n609\t      driver: driverName,\n610\t      model,\n611\t      timestamp: new Date().toISOString(),\n612\t      cost_usd: cost > 0 ? cost : null,\n613\t      duration_ms: durationMs,\n614\t      changedFiles: [...new Set(changedFiles)],\n615\t      testResults: null,\n616\t      output,\n617\t      acceptanceCriteria: [],\n618\t    };\n619\t    writeOutputContract(contract, join(projectDir, '.codeharness', 'contracts'));\n620\t  } catch (err: unknown) {\n621\t    const message = err instanceof Error ? err.message : String(err);\n622\t    warn(`workflow-engine: failed to write output contract for ${taskName}/${storyKey}: ${message}`);\n623\t    contract = null;\n624\t  }\n625\t\n626\t  // 13. Write state to disk\n627\t  writeWorkflowState(updatedState, projectDir);\n628\t\n629\t  return { updatedState, output, contract };\n630\t}\n631\t\n632\t// --- Retry Prompt Construction (Task 3) ---\n633\t\n634\t/**\n635\t * Build a retry prompt with evaluator findings injected.\n636\t * Includes only failed/unknown findings.\n637\t */\n638\texport function buildRetryPrompt(storyKey: string, findings: EvaluatorVerdict['findings']): string {\n639\t  const failedFindings = findings.filter(\n640\t    (f) => f.status === 'fail' || f.status === 'unknown',\n641\t  );\n642\t\n643\t  if (failedFindings.length === 0) {\n644\t    return `Implement story ${storyKey}`;\n645\t  }\n646\t\n647\t  const formattedFindings = failedFindings\n648\t    .map((f) => {\n649\t      const status = f.status.toUpperCase();\n650\t      let entry = `AC #${f.ac} (${status}): ${f.description}`;\n651\t      if (f.evidence?.reasoning) {\n652\t        entry += `\\n  Evidence: ${f.evidence.reasoning}`;\n653\t      }\n654\t      return entry;\n655\t    })\n656\t    .join('\\n\\n');\n657\t\n658\t  return `Retry story ${storyKey}. Previous evaluator findings:\\n\\n${formattedFindings}\\n\\nFocus on fixing the failed criteria above.`;\n659\t}\n660\t\n661\t// --- All-UNKNOWN Verdict Builder ---\n662\t\n663\t/**\n664\t * Build an all-UNKNOWN EvaluatorVerdict as fallback when the evaluator\n665\t * fails to produce valid JSON after retry.\n666\t */\n667\texport function buildAllUnknownVerdict(\n668\t  workItems: WorkItem[],\n669\t  reasoning: string,\n670\t): EvaluatorVerdict {\n671\t  const findings = workItems.map((_, index) => ({\n672\t    ac: index + 1,\n673\t    description: `AC #${index + 1}`,\n674\t    status: 'unknown' as const,\n675\t    evidence: {\n676\t      commands_run: [] as string[],\n677\t      output_observed: '',\n678\t      reasoning,\n679\t    },\n680\t  }));\n681\t\n682\t  return {\n683\t    verdict: 'fail',\n684\t    score: {\n685\t      passed: 0,\n686\t      failed: 0,\n687\t      unknown: findings.length,\n688\t      total: findings.length,\n689\t    },\n690\t    findings,\n691\t  };\n692\t}\n693\t\n694\t// --- Failed Story Filtering (Task 4) ---\n695\t\n696\t/**\n697\t * Determine which work items failed based on evaluator findings.\n698\t * If verdict is null (parse failure), returns all items (conservative fallback).\n699\t */\n700\texport function getFailedItems(\n701\t  verdict: EvaluatorVerdict | null,\n702\t  allItems: WorkItem[],\n703\t): WorkItem[] {\n704\t  if (!verdict) return allItems;\n705\t\n706\t  // If verdict passed, no items need retry\n707\t  if (verdict.verdict === 'pass') return [];\n708\t\n709\t  // All items are retried on failure — per-story filtering based on individual\n710\t  // story results is not possible with the current verdict shape (verdict is per-run).\n711\t  // The findings track ACs, not stories. Conservative: retry all on failure.\n712\t  return allItems;\n713\t}\n714\t\n715\t// --- Loop Block Execution (Task 5) ---\n716\t\n717\t/**\n718\t * Result of loop block execution.\n719\t */\n720\tinterface LoopBlockResult {\n721\t  state: WorkflowState;\n722\t  errors: EngineError[];\n723\t  tasksCompleted: number;\n724\t  halted: boolean;\n725\t  lastContract: OutputContract | null;\n726\t}\n727\t\n728\t/**\n729\t * Execute a loop block: iterate tasks until pass, max iterations, or circuit breaker.\n730\t */\n731\texport async function executeLoopBlock(\n732\t  loopBlock: LoopBlock,\n733\t  state: WorkflowState,\n734\t  config: EngineConfig,\n735\t  workItems: WorkItem[],\n736\t  initialContract?: OutputContract | null,\n737\t): Promise<LoopBlockResult> {\n738\t  const projectDir = config.projectDir ?? process.cwd();\n739\t  const maxIterations = config.maxIterations ?? DEFAULT_MAX_ITERATIONS;\n740\t  const errors: EngineError[] = [];\n741\t  let tasksCompleted = 0;\n742\t  let currentState = state;\n743\t  let lastVerdict: EvaluatorVerdict | null = null;\n744\t  let lastOutputContract: OutputContract | null = initialContract ?? null;\n745\t  let accumulatedCostUsd = 0;\n746\t\n747\t  // Handle empty loop block\n748\t  if (loopBlock.loop.length === 0) {\n749\t    return { state: currentState, errors, tasksCompleted, halted: false, lastContract: lastOutputContract };\n750\t  }\n751\t\n752\t  while (true) {\n753\t    // 1. Determine whether to increment iteration or resume a partial one.\n754\t    //    On fresh start (iteration === 0), always increment.\n755\t    //    On resume (iteration > 0), check if the current iteration is fully done.\n756\t    const nextIteration = currentState.iteration + 1;\n757\t    const allCurrentIterationDone = currentState.iteration > 0 && loopBlock.loop.every((tn) => {\n758\t      const t = config.workflow.tasks[tn];\n759\t      if (!t) return true; // missing task = skip = \"done\"\n760\t      if (t.scope === 'per-story') {\n761\t        return workItems.every((item) =>\n762\t          isLoopTaskCompleted(currentState, tn, item.key, currentState.iteration));\n763\t      }\n764\t      return isLoopTaskCompleted(currentState, tn, PER_RUN_SENTINEL, currentState.iteration);\n765\t    });\n766\t\n767\t    if (currentState.iteration === 0 || allCurrentIterationDone) {\n768\t      // Fresh start or current iteration fully done — advance\n769\t      currentState = {\n770\t        ...currentState,\n771\t        iteration: nextIteration,\n772\t      };\n773\t      writeWorkflowState(currentState, projectDir);\n774\t    }\n775\t    // else: resuming a partially completed iteration — keep current iteration\n776\t\n777\t    let haltedInLoop = false;\n778\t\n779\t    // 2. Execute each task in the loop\n780\t    for (const taskName of loopBlock.loop) {\n781\t      const task = config.workflow.tasks[taskName];\n782\t      if (!task) {\n783\t        warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n784\t        continue;\n785\t      }\n786\t\n787\t      // --- Null task path in loop ---\n788\t      if (task.agent === null) {\n789\t        if (task.scope === 'per-story') {\n790\t          const itemsToProcess = lastVerdict ? getFailedItems(lastVerdict, workItems) : workItems;\n791\t          for (const item of itemsToProcess) {\n792\t            if (isLoopTaskCompleted(currentState, taskName, item.key, currentState.iteration)) {\n793\t              warn(`workflow-engine: skipping completed task ${taskName} for ${item.key}`);\n794\t              continue;\n795\t            }\n796\t            try {\n797\t              const nullResult = await executeNullTask(\n798\t                task, taskName, item.key, currentState, config, lastOutputContract ?? undefined, accumulatedCostUsd,\n799\t              );\n800\t              currentState = nullResult.updatedState;\n801\t              lastOutputContract = nullResult.contract;\n802\t              tasksCompleted++;\n803\t            } catch (err: unknown) {\n804\t              const engineError = isEngineError(err)\n805\t                ? err\n806\t                : handleDispatchError(err, taskName, item.key);\n807\t              errors.push(engineError);\n808\t              currentState = recordErrorInState(currentState, taskName, item.key, engineError);\n809\t              writeWorkflowState(currentState, projectDir);\n810\t            }\n811\t          }\n812\t        } else {\n813\t          if (isLoopTaskCompleted(currentState, taskName, PER_RUN_SENTINEL, currentState.iteration)) {\n814\t            warn(`workflow-engine: skipping completed task ${taskName} for ${PER_RUN_SENTINEL}`);\n815\t            continue;\n816\t          }\n817\t          try {\n818\t            const nullResult = await executeNullTask(\n819\t              task, taskName, PER_RUN_SENTINEL, currentState, config, lastOutputContract ?? undefined, accumulatedCostUsd,\n820\t            );\n821\t            currentState = nullResult.updatedState;\n822\t            lastOutputContract = nullResult.contract;\n823\t            tasksCompleted++;\n824\t          } catch (err: unknown) {\n825\t            const engineError = isEngineError(err)\n826\t              ? err\n827\t              : handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n828\t            errors.push(engineError);\n829\t            currentState = recordErrorInState(currentState, taskName, PER_RUN_SENTINEL, engineError);"}]},"parent_tool_use_id":"toolu_01Hody5ZigZ3cTLmGuBw8VE3","session_id":"b6bb3bfc-8778-4f16-a616-88028acc2431","uuid":"7b5140d5-fb2d-49b7-80f5-fd88339da957","timestamp":"2026-04-03T18:31:37.266Z"}
