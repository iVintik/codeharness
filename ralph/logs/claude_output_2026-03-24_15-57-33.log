rue,\n   753ŌåÆ      testsPassed: true,\n   754ŌåÆ      passCount: 10,\n   755ŌåÆ      failCount: 0,\n   756ŌåÆ      coveragePercent: 90,\n   757ŌåÆ      rawOutput: '',\n   758ŌåÆ    };\n   759ŌåÆ    const evaluation: CoverageEvaluation = {\n   760ŌåÆ      met: false,\n   761ŌåÆ      target: 100,\n   762ŌåÆ      actual: 90,\n   763ŌåÆ      delta: 40,\n   764ŌåÆ      baseline: 50,\n   765ŌåÆ    };\n   766ŌåÆ\n   767ŌåÆ    updateCoverageState(result, evaluation, testDir);\n   768ŌåÆ\n   769ŌåÆ    const { state: updated } = readStateWithBody(testDir);\n   770ŌåÆ    expect(updated.coverage.baseline).toBe(50);\n   771ŌåÆ  });\n   772ŌåÆ});\n   773ŌåÆ\n   774ŌåÆ// ŌöĆŌöĆŌöĆ formatCoverageOutput ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n   775ŌåÆ\n   776ŌåÆdescribe('formatCoverageOutput', () => {\n   777ŌåÆ  it('formats passing coverage', () => {\n   778ŌåÆ    const evaluation: CoverageEvaluation = {\n   779ŌåÆ      met: true,\n   780ŌåÆ      target: 100,\n   781ŌåÆ      actual: 100,\n   782ŌåÆ      delta: null,\n   783ŌåÆ      baseline: 100,\n   784ŌåÆ    };\n   785ŌåÆ\n   786ŌåÆ    const lines = formatCoverageOutput(evaluation);\n   787ŌåÆ    expect(lines).toEqual(['[OK] Coverage: 100%']);\n   788ŌåÆ  });\n   789ŌåÆ\n   790ŌåÆ  it('formats failing coverage', () => {\n   791ŌåÆ    const evaluation: CoverageEvaluation = {\n   792ŌåÆ      met: false,\n   793ŌåÆ      target: 100,\n   794ŌåÆ      actual: 87,\n   795ŌåÆ      delta: null,\n   796ŌåÆ      baseline: 87,\n   797ŌåÆ    };\n   798ŌåÆ\n   799ŌåÆ    const lines = formatCoverageOutput(evaluation);\n   800ŌåÆ    expect(lines).toEqual(['[FAIL] Coverage: 87% (target: 100%)']);\n   801ŌåÆ  });\n   802ŌåÆ\n   803ŌåÆ  it('includes delta when available', () => {\n   804ŌåÆ    const evaluation: CoverageEvaluation = {\n   805ŌåÆ      met: true,\n   806ŌåÆ      target: 100,\n   807ŌåÆ      actual: 100,\n   808ŌåÆ  