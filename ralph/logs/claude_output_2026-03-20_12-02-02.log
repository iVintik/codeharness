{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VcZ79Mwp8i5MxrXgczqy38","type":"tool_result","content":"     1→/**\n     2→ * Ink UI components for the terminal activity display.\n     3→ *\n     4→ * Each component renders one visual element of the Claude activity dashboard.\n     5→ * These are consumed by the root <App> component in ink-renderer.tsx.\n     6→ */\n     7→\n     8→import React from 'react';\n     9→import { Text, Box } from 'ink';\n    10→import { Spinner } from '@inkjs/ui';\n    11→\n    12→// --- Types ---\n    13→\n    14→export interface SprintInfo {\n    15→  storyKey: string;\n    16→  phase: string;\n    17→  done: number;\n    18→  total: number;\n    19→  elapsed?: string; // formatted elapsed time, e.g. \"47m\" or \"2h14m\"\n    20→}\n    21→\n    22→export interface CompletedToolEntry {\n    23→  name: string;\n    24→  args: string;\n    25→}\n    26→\n    27→export type StoryStatusValue = 'done' | 'in-progress' | 'pending' | 'failed' | 'blocked';\n    28→\n    29→export interface StoryStatusEntry {\n    30→  key: string;\n    31→  status: StoryStatusValue;\n    32→}\n    33→\n    34→export interface RetryInfo {\n    35→  attempt: number;\n    36→  delay: number;\n    37→}\n    38→\n    39→export interface StoryMessage {\n    40→  type: 'ok' | 'warn' | 'fail';\n    41→  key: string;\n    42→  message: string;\n    43→  details?: string[];\n    44→}\n    45→\n    46→export interface RendererState {\n    47→  sprintInfo: SprintInfo | null;\n    48→  stories: StoryStatusEntry[];\n    49→  messages: StoryMessage[];\n    50→  completedTools: CompletedToolEntry[];\n    51→  activeTool: { name: string } | null;\n    52→  activeToolArgs: string;\n    53→  lastThought: string | null;\n    54→  retryInfo: RetryInfo | null;\n    55→}\n    56→\n    57→// --- Components ---\n    58→\n    59→export function Header({ info }: { info: SprintInfo | null }) {\n    60→  if (!info) return null;\n    61→  return (\n    62→    <Text>\n    63→      {'◆ '}\n    64→      {info.storyKey}\n    65→      {' — '}\n    66→      {info.phase}\n    67→      {info.elapsed ? ` | ${info.elapsed}` : ''}\n    68→      {' | Sprint: '}\n    69→      {info.done}\n    70→      {'/'}\n    71→      {info.total}\n    72→    </Text>\n    73→  );\n    74→}\n    75→\n    76→export function CompletedTool({ entry }: { entry: CompletedToolEntry }) {\n    77→  const argsSummary = entry.args.length > 60\n    78→    ? entry.args.slice(0, 60) + '...'\n    79→    : entry.args;\n    80→  return (\n    81→    <Text>\n    82→      {'✓ ['}\n    83→      {entry.name}\n    84→      {'] '}\n    85→      {argsSummary}\n    86→    </Text>\n    87→  );\n    88→}\n    89→\n    90→export function CompletedTools({ tools }: { tools: CompletedToolEntry[] }) {\n    91→  return (\n    92→    <Box flexDirection=\"column\">\n    93→      {tools.map((entry, i) => (\n    94→        <CompletedTool key={i} entry={entry} />\n    95→      ))}\n    96→    </Box>\n    97→  );\n    98→}\n    99→\n   100→export function ActiveTool({ name }: { name: string }) {\n   101→  return (\n   102→    <Box>\n   103→      <Text>{'⚡ ['}{name}{'] '}</Text>\n   104→      <Spinner label=\"\" />\n   105→    </Box>\n   106→  );\n   107→}\n   108→\n   109→export function LastThought({ text }: { text: string }) {\n   110→  const maxWidth = (process.stdout.columns || 80) - 4;\n   111→  const truncated = truncateToWidth(text, maxWidth);\n   112→  return (\n   113→    <Text>\n   114→      {'💭 '}\n   115→      {truncated}\n   116→    </Text>\n   117→  );\n   118→}\n   119→\n   120→/**\n   121→ * Truncate a string to fit within a given terminal column width.\n   122→ * Iterates by codepoint (not UTF-16 index) to avoid splitting surrogate pairs.\n   123→ * Treats characters outside the Basic Latin range as 2 columns wide (CJK, emoji).\n   124→ */\n   125→function truncateToWidth(text: string, maxWidth: number): string {\n   126→  let width = 0;\n   127→  let result = '';\n   128→  for (const char of text) {\n   129→    const cp = char.codePointAt(0)!;\n   130→    // Rough heuristic: ASCII printable = 1 col, everything else = 2 cols\n   131→    const charWidth = cp <= 0x7e ? 1 : 2;\n   132→    if (width + charWidth > maxWidth) {\n   133→      return result;\n   134→    }\n   135→    width += charWidth;\n   136→    result += char;\n   137→  }\n   138→  return result;\n   139→}\n   140→\n   141→const STATUS_SYMBOLS: Record<StoryStatusValue, string> = {\n   142→  'done': '✓',\n   143→  'in-progress': '◆',\n   144→  'pending': '○',\n   145→  'failed': '✗',\n   146→  'blocked': '✕',\n   147→};\n   148→\n   149→export function StoryBreakdown({ stories }: { stories: StoryStatusEntry[] }) {\n   150→  if (stories.length === 0) return null;\n   151→\n   152→  const groups: Partial<Record<StoryStatusValue, string[]>> = {};\n   153→  for (const s of stories) {\n   154→    if (!groups[s.status]) groups[s.status] = [];\n   155→    groups[s.status]!.push(s.key);\n   156→  }\n   157→\n   158→  const fmt = (keys: string[], status: StoryStatusValue) =>\n   159→    keys.map(k => `${k} ${STATUS_SYMBOLS[status]}`).join('  ');\n   160→\n   161→  const parts: string[] = [];\n   162→  if (groups['done']?.length) {\n   163→    parts.push(`Done: ${fmt(groups['done'], 'done')}`);\n   164→  }\n   165→  if (groups['in-progress']?.length) {\n   166→    parts.push(`This: ${fmt(groups['in-progress'], 'in-progress')}`);\n   167→  }\n   168→  if (groups['pending']?.length) {\n   169→    parts.push(`Next: ${fmt(groups['pending'], 'pending')}`);\n   170→  }\n   171→  if (groups['failed']?.length) {\n   172→    parts.push(`Failed: ${fmt(groups['failed'], 'failed')}`);\n   173→  }\n   174→  if (groups['blocked']?.length) {\n   175→    parts.push(`Blocked: ${fmt(groups['blocked'], 'blocked')}`);\n   176→  }\n   177→\n   178→  return <Text>{parts.join(' | ')}</Text>;\n   179→}\n   180→\n   181→const MESSAGE_PREFIX: Record<StoryMessage['type'], string> = {\n   182→  ok: '[OK]',\n   183→  warn: '[WARN]',\n   184→  fail: '[FAIL]',\n   185→};\n   186→\n   187→export function StoryMessages({ messages }: { messages: StoryMessage[] }) {\n   188→  if (messages.length === 0) return null;\n   189→  return (\n   190→    <Box flexDirection=\"column\">\n   191→      {messages.map((msg, i) => (\n   192→        <Box key={i} flexDirection=\"column\">\n   193→          <Text>{`${MESSAGE_PREFIX[msg.type]} Story ${msg.key}: ${msg.message}`}</Text>\n   194→          {msg.details?.map((d, j) => (\n   195→            <Text key={j}>{`  └ ${d}`}</Text>\n   196→          ))}\n   197→        </Box>\n   198→      ))}\n   199→    </Box>\n   200→  );\n   201→}\n   202→\n   203→export function RetryNotice({ info }: { info: RetryInfo }) {\n   204→  return (\n   205→    <Text>\n   206→      {'⏳ API retry '}\n   207→      {info.attempt}\n   208→      {' (waiting '}\n   209→      {info.delay}\n   210→      {'ms)'}\n   211→    </Text>\n   212→  );\n   213→}\n   214→\n   215→export function App({\n   216→  state,\n   217→}: {\n   218→  state: RendererState;\n   219→}) {\n   220→  return (\n   221→    <Box flexDirection=\"column\">\n   222→      <Header info={state.sprintInfo} />\n   223→      <StoryBreakdown stories={state.stories} />\n   224→      <StoryMessages messages={state.messages} />\n   225→      <CompletedTools tools={state.completedTools} />\n   226→      {state.activeTool && <ActiveTool name={state.activeTool.name} />}\n   227→      {state.lastThought && <LastThought text={state.lastThought} />}\n   228→      {state.retryInfo && <RetryNotice info={state.retryInfo} />}\n   229→    </Box>\n   230→  );\n   231→}\n   232→"}]},"parent_tool_use_id":"toolu_01XRogrWXmkjb8B4r8U8sFo4","session_id":"64c1e9b9-a641-40be-ae67-07aee0c47965","uuid":"3f097392-2789-4e32-9ffa-ac6cc16b85c9","timestamp":"2026-03-20T08:14:40.626Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KWFa5JrHm1ekmCcQdhs1iw","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';\n     2→import { mkdtempSync, rmSync, writeFileSync, mkdirSync } from 'node:fs';\n     3→import { existsSync as origExistsSync, readFileSync as origReadFileSync } from 'node:fs';\n     4→import { tmpdir } from 'node:os';\n     5→import { join } from 'node:path';\n     6→import { EventEmitter } from 'node:events';\n     7→import { Command } from 'commander';\n     8→import { resolveRalphPath, resolvePluginDir, countStories, buildSpawnArgs } from '../run.js';\n     9→\n    10→// --- Hoisted mocks ---\n    11→// Capture the real existsSync before vi.mock replaces node:fs\n    12→const {\n    13→  spawnMock, getChildOnHandlers, existsSyncMock, readSprintStatusMock,\n    14→  realExistsSync, getStdoutEmitter, getStderrEmitter,\n    15→  startRendererMock, rendererUpdateMock, rendererUpdateSprintStateMock, rendererCleanupMock,\n    16→  rendererUpdateStoriesMock, rendererAddMessageMock,\n    17→  parseStreamLineMock, getSprintStateMock,\n    18→} = vi.hoisted(() => {\n    19→  // eslint-disable-next-line @typescript-eslint/no-require-imports\n    20→  const fs = require('node:fs');\n    21→  const realFn = fs.existsSync.bind(fs);\n    22→\n    23→  const handlers: Record<string, (...args: unknown[]) => void> = {};\n    24→  let stdoutEmitter: EventEmitter | null = null;\n    25→  let stderrEmitter: EventEmitter | null = null;\n    26→\n    27→  const rendererUpdateMock = vi.fn();\n    28→  const rendererUpdateSprintStateMock = vi.fn();\n    29→  const rendererCleanupMock = vi.fn();\n    30→  const rendererUpdateStoriesMock = vi.fn();\n    31→  const rendererAddMessageMock = vi.fn();\n    32→\n    33→  return {\n    34→    spawnMock: vi.fn(() => {\n    35→      stdoutEmitter = new EventEmitter();\n    36→      stderrEmitter = new EventEmitter();\n    37→      return {\n    38→        on: vi.fn((event: string, handler: (...args: unknown[]) => void) => {\n    39→          handlers[event] = handler;\n    40→        }),\n    41→        pid: 12345,\n    42→        stdin: null,\n    43→        stdout: stdoutEmitter,\n    44→        stderr: stderrEmitter,\n    45→      };\n    46→    }),\n    47→    getChildOnHandlers: () => handlers,\n    48→    existsSyncMock: vi.fn(realFn),\n    49→    readSprintStatusMock: vi.fn(() => ({}) as Record<string, string>),\n    50→    realExistsSync: realFn as (path: string) => boolean,\n    51→    getStdoutEmitter: () => stdoutEmitter,\n    52→    getStderrEmitter: () => stderrEmitter,\n    53→    startRendererMock: vi.fn(() => ({\n    54→      update: rendererUpdateMock,\n    55→      updateSprintState: rendererUpdateSprintStateMock,\n    56→      updateStories: rendererUpdateStoriesMock,\n    57→      addMessage: rendererAddMessageMock,\n    58→      cleanup: rendererCleanupMock,\n    59→    })),\n    60→    rendererUpdateMock,\n    61→    rendererUpdateSprintStateMock,\n    62→    rendererCleanupMock,\n    63→    rendererUpdateStoriesMock,\n    64→    rendererAddMessageMock,\n    65→    parseStreamLineMock: vi.fn(() => null),\n    66→    getSprintStateMock: vi.fn(() => ({ success: false, error: 'no state' })),\n    67→  };\n    68→});\n    69→\n    70→vi.mock('node:child_process', () => ({ spawn: spawnMock }));\n    71→\n    72→vi.mock('node:fs', async (importOriginal) => {\n    73→  const actual = await importOriginal<typeof import('node:fs')>();\n    74→  return { ...actual, existsSync: existsSyncMock };\n    75→});\n    76→\n    77→vi.mock('../../lib/beads-sync.js', () => ({\n    78→  readSprintStatus: (...args: unknown[]) => readSprintStatusMock(...args),\n    79→}));\n    80→\n    81→vi.mock('../../templates/ralph-prompt.js', () => ({\n    82→  generateRalphPrompt: vi.fn(() => 'mock prompt content'),\n    83→}));\n    84→\n    85→vi.mock('../../lib/stream-parser.js', () => ({\n    86→  parseStreamLine: (...args: unknown[]) => parseStreamLineMock(...args),\n    87→}));\n    88→\n    89→vi.mock('../../lib/ink-renderer.js', () => ({\n    90→  startRenderer: (...args: unknown[]) => startRendererMock(...args),\n    91→}));\n    92→\n    93→vi.mock('../../modules/sprint/index.js', () => ({\n    94→  getSprintState: (...args: unknown[]) => getSprintStateMock(...args),\n    95→}));\n    96→\n    97→describe('run command', () => {\n    98→  let tmpDir: string;\n    99→\n   100→  beforeEach(() => {\n   101→    tmpDir = mkdtempSync(join(tmpdir(), 'run-test-'));\n   102→    spawnMock.mockClear();\n   103→    existsSyncMock.mockReset();\n   104→    existsSyncMock.mockImplementation((p: unknown) => realExistsSync(String(p)));\n   105→    readSprintStatusMock.mockReset();\n   106→    readSprintStatusMock.mockReturnValue({});\n   107→    startRendererMock.mockClear();\n   108→    rendererUpdateMock.mockClear();\n   109→    rendererUpdateSprintStateMock.mockClear();\n   110→    rendererCleanupMock.mockClear();\n   111→    rendererUpdateStoriesMock.mockClear();\n   112→    rendererAddMessageMock.mockClear();\n   113→    parseStreamLineMock.mockClear();\n   114→    parseStreamLineMock.mockReturnValue(null);\n   115→    getSprintStateMock.mockClear();\n   116→    getSprintStateMock.mockReturnValue({ success: false, error: 'no state' });\n   117→    process.exitCode = undefined;\n   118→  });\n   119→\n   120→  afterEach(() => {\n   121→    rmSync(tmpDir, { recursive: true, force: true });\n   122→    vi.restoreAllMocks();\n   123→    process.exitCode = undefined;\n   124→  });\n   125→\n   126→  // Helper to control existsSync per path pattern\n   127→  function mockPaths(overrides: Record<string, boolean>) {\n   128→    existsSyncMock.mockImplementation((p: unknown) => {\n   129→      const path = String(p);\n   130→      for (const [pattern, value] of Object.entries(overrides)) {\n   131→        if (path.includes(pattern)) return value;\n   132→      }\n   133→      return realExistsSync(path);\n   134→    });\n   135→  }\n   136→\n   137→  // Helper to invoke the run command via Commander\n   138→  async function runCommand(args: string[] = []) {\n   139→    const { registerRunCommand } = await import('../run.js');\n   140→    const program = new Command();\n   141→    program.exitOverride();\n   142→    program.option('--json', 'JSON output');\n   143→    registerRunCommand(program);\n   144→    await program.parseAsync(['node', 'codeharness', 'run', ...args]);\n   145→  }\n   146→\n   147→  describe('resolveRalphPath', () => {\n   148→    it('returns a path ending with ralph/ralph.sh', () => {\n   149→      expect(resolveRalphPath()).toMatch(/ralph[/\\\\]ralph\\.sh$/);\n   150→    });\n   151→\n   152→    it('resolves to a path within the project', () => {\n   153→      expect(resolveRalphPath()).toContain('ralph');\n   154→    });\n   155→  });\n   156→\n   157→  describe('resolvePluginDir', () => {\n   158→    it('returns cwd/.claude', () => {\n   159→      expect(resolvePluginDir()).toBe(join(process.cwd(), '.claude'));\n   160→    });\n   161→  });\n   162→\n   163→  describe('countStories', () => {\n   164→    it('counts stories by status correctly', () => {\n   165→      const counts = countStories({\n   166→        'epic-5': 'in-progress',\n   167→        '5-1-ralph-loop': 'ready-for-dev',\n   168→        '5-2-verification': 'backlog',\n   169→        '5-3-tracking': 'done',\n   170→        '5-4-another': 'in-progress',\n   171→        'epic-5-retrospective': 'optional',\n   172→      });\n   173→      expect(counts).toEqual({ total: 4, ready: 2, done: 1, inProgress: 1, verified: 0 });\n   174→    });\n   175→\n   176→    it('ignores epic keys and retrospective keys', () => {\n   177→      const counts = countStories({\n   178→        'epic-1': 'done', 'epic-1-retrospective': 'done',\n   179→        '1-1-story-one': 'done', '1-2-story-two': 'done',\n   180→      });\n   181→      expect(counts.total).toBe(2);\n   182→      expect(counts.done).toBe(2);\n   183→    });\n   184→\n   185→    it('returns zeros for empty statuses', () => {\n   186→      expect(countStories({})).toEqual({ total: 0, ready: 0, done: 0, inProgress: 0, verified: 0 });\n   187→    });\n   188→\n   189→    it('counts review status as inProgress', () => {\n   190→      expect(countStories({ '1-1-story': 'review' }).inProgress).toBe(1);\n   191→    });\n   192→\n   193→    it('counts verifying status separately', () => {\n   194→      const counts = countStories({\n   195→        '1-1-story': 'verifying',\n   196→        '1-2-story': 'verifying',\n   197→        '1-3-story': 'done',\n   198→      });\n   199→      expect(counts).toEqual({ total: 3, ready: 0, done: 1, inProgress: 0, verified: 2 });\n   200→    });\n   201→  });\n   202→\n   203→  describe('buildSpawnArgs', () => {\n   204→    const baseOpts = {\n   205→      ralphPath: '/path/to/ralph.sh',\n   206→      pluginDir: '/path/to/.claude',\n   207→      promptFile: '/path/to/prompt.md',\n   208→      maxIterations: 50,\n   209→      timeout: 14400,\n   210→      iterationTimeout: 15,\n   211→      calls: 100,\n   212→      quiet: false,\n   213→    };\n   214→\n   215→    it('builds basic argument array', () => {\n   216→      const args = buildSpawnArgs(baseOpts);\n   217→      expect(args).toContain('/path/to/ralph.sh');\n   218→      expect(args).toContain('--plugin-dir');\n   219→      expect(args).toContain('50');\n   220→    });\n   221→\n   222→    it('never includes --live flag (removed)', () => {\n   223→      expect(buildSpawnArgs(baseOpts)).not.toContain('--live');\n   224→      expect(buildSpawnArgs({ ...baseOpts, quiet: true })).not.toContain('--live');\n   225→    });\n   226→\n   227→    it('includes --max-story-retries when provided', () => {\n   228→      const args = buildSpawnArgs({ ...baseOpts, maxStoryRetries: 5 });\n   229→      expect(args).toContain('--max-story-retries');\n   230→      expect(args).toContain('5');\n   231→    });\n   232→\n   233→    it('does not include --max-story-retries when undefined', () => {\n   234→      expect(buildSpawnArgs(baseOpts)).not.toContain('--max-story-retries');\n   235→    });\n   236→  });\n   237→\n   238→  describe('action handler', () => {\n   239→    it('fails when ralph script not found', async () => {\n   240→      mockPaths({ 'ralph.sh': false });\n   241→      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n   242→\n   243→      await runCommand();\n   244→\n   245→      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Ralph loop not found'));\n   246→      expect(process.exitCode).toBe(1);\n   247→    });\n   248→\n   249→    it('fails when plugin directory not found', async () => {\n   250→      mockPaths({ 'ralph.sh': true, '.claude': false });\n   251→      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n   252→\n   253→      await runCommand();\n   254→\n   255→      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Plugin directory not found'));\n   256→      expect(process.exitCode).toBe(1);\n   257→    });\n   258→\n   259→    it('fails when no stories in sprint-status.yaml', async () => {\n   260→      mockPaths({ 'ralph.sh': true, '.claude': true });\n   261→      readSprintStatusMock.mockReturnValue({});\n   262→      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n   263→\n   264→      await runCommand();\n   265→\n   266→      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('No stories found'));\n   267→      expect(process.exitCode).toBe(1);\n   268→    });\n   269→\n   270→    it('fails with invalid numeric options', async () => {\n   271→      mockPaths({ 'ralph.sh': true, '.claude': true });\n   272→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   273→      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n   274→\n   275→      await runCommand(['--max-iterations', 'abc']);\n   276→\n   277→      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Invalid numeric option'));\n   278→      expect(process.exitCode).toBe(1);\n   279→    });\n   280→\n   281→    it('spawns ralph and propagates exit code 0', async () => {\n   282→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   283→      mockPaths({ 'ralph.sh': true, '.claude': true, '.flagged_stories': false });\n   284→      readSprintStatusMock.mockReturnValue({ '1-1-do-stuff': 'backlog' });\n   285→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   286→\n   287→      const p = runCommand();\n   288→      await vi.waitFor(() => expect(spawnMock).toHaveBeenCalled());\n   289→      getChildOnHandlers()['close'](0);\n   290→      await p;\n   291→\n   292→      expect(spawnMock).toHaveBeenCalledWith('bash', expect.any(Array), expect.objectContaining({\n   293→        cwd: tmpDir,\n   294→      }));\n   295→      expect(process.exitCode).toBe(0);\n   296→    });\n   297→\n   298→    it('propagates non-zero exit code from ralph', async () => {\n   299→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   300→      mockPaths({ 'ralph.sh': true, '.claude': true, '.flagged_stories': false });\n   301→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   302→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   303→\n   304→      const p = runCommand();\n   305→      await vi.waitFor(() => expect(spawnMock).toHaveBeenCalled());\n   306→      getChildOnHandlers()['close'](42);\n   307→      await p;\n   308→\n   309→      expect(process.exitCode).toBe(42);\n   310→    });\n   311→\n   312→    it('handles spawn error gracefully', async () => {\n   313→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   314→      mockPaths({ 'ralph.sh': true, '.claude': true, '.flagged_stories': false });\n   315→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   316→      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n   317→\n   318→      const p = runCommand();\n   319→      await vi.waitFor(() => expect(spawnMock).toHaveBeenCalled());\n   320→      getChildOnHandlers()['error'](new Error('ENOENT: bash not found'));\n   321→      await p;\n   322→\n   323→      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Failed to start Ralph'));\n   324→      expect(process.exitCode).toBe(1);\n   325→    });\n   326→\n   327→    it('outputs JSON with status.json present', async () => {\n   328→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   329→      mkdirSync(join(tmpDir, 'ralph'), { recursive: true });\n   330→      writeFileSync(join(tmpDir, 'ralph', 'status.json'), JSON.stringify({\n   331→        status: 'completed', loop_count: 5, elapsed_seconds: 120,\n   332→        flagged_stories: [], exit_reason: 'all_done',\n   333→      }));\n   334→      mockPaths({ 'ralph.sh': true, '.claude': true, '.flagged_stories': false });\n   335→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'done' });\n   336→      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n   337→\n   338→      const p = runCommand(['--json']);\n   339→      await vi.waitFor(() => expect(spawnMock).toHaveBeenCalled());\n   340→      getChildOnHandlers()['close'](0);\n   341→      await p;\n   342→\n   343→      // Find the final JSON output (has storiesCompleted, not the info() call)\n   344→      const jsonCall = consoleSpy.mock.calls.find(\n   345→        call => typeof call[0] === 'string' && call[0].includes('\"storiesCompleted\"')\n   346→      );\n   347→      expect(jsonCall).toBeDefined();\n   348→      const output = JSON.parse(jsonCall![0] as string);\n   349→      expect(output.status).toBe('completed');\n   350→      expect(output.iterations).toBe(5);\n   351→      expect(output.storiesCompleted).toBe(1);\n   352→      expect(output.exitReason).toBe('all_done');\n   353→    });\n   354→\