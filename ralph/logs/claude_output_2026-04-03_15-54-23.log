{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JT7rmTCMoqEKP4sLVuwVuU","type":"tool_result","content":"1\timport { describe, it, expect, afterEach, vi } from 'vitest';\n2\timport { render } from 'ink-testing-library';\n3\timport React from 'react';\n4\timport { startRenderer } from '../ink-renderer.js';\n5\timport type { RendererHandle } from '../ink-renderer.js';\n6\timport type { StreamEvent } from '../agents/stream-parser.js';\n7\timport {\n8\t  App,\n9\t  Header,\n10\t  Separator,\n11\t  CompletedTool,\n12\t  ActiveTool,\n13\t  LastThought,\n14\t  RetryNotice,\n15\t  StoryBreakdown,\n16\t  StoryMessageLine,\n17\t  type RendererState,\n18\t  type SprintInfo,\n19\t  type CompletedToolEntry,\n20\t  type StoryStatusEntry,\n21\t  type StoryMessage,\n22\t} from '../ink-components.js';\n23\t\n24\t// --- Helpers ---\n25\t\n26\tfunction makeState(overrides?: Partial<RendererState>): RendererState {\n27\t  return {\n28\t    sprintInfo: null,\n29\t    stories: [],\n30\t    messages: [],\n31\t    completedTools: [],\n32\t    activeTool: null,\n33\t    activeToolArgs: '',\n34\t    lastThought: null,\n35\t    retryInfo: null,\n36\t    workflowFlow: [],\n37\t    currentTaskName: null,\n38\t    taskStates: {},\n39\t    taskMeta: {},\n40\t    activeDriverName: null,\n41\t    driverCosts: {},\n42\t    ...overrides,\n43\t  };\n44\t}\n45\t\n46\t// --- Component Tests (using ink-testing-library) ---\n47\t\n48\tdescribe('Header component', () => {\n49\t  it('renders plain text header line (no Box border, no diamond prefix)', () => {\n50\t    const info: SprintInfo = {\n51\t      storyKey: '0-5-3',\n52\t      phase: 'dev',\n53\t      done: 3,\n54\t      total: 10,\n55\t      iterationCount: 2,\n56\t      totalCost: 5.50,\n57\t    };\n58\t    const { lastFrame } = render(<Header info={info} />);\n59\t    const frame = lastFrame()!;\n60\t    // AC1: plain text header, NO Box border, NO diamond prefix\n61\t    expect(frame).toContain('codeharness run');\n62\t    expect(frame).toContain('iteration 2');\n63\t    expect(frame).toContain('$5.50 spent');\n64\t    expect(frame).not.toContain('◆');\n65\t    expect(frame).not.toContain('│'); // No Ink Box border character\n66\t    // AC3: Story and Phase on separate lines\n67\t    expect(frame).toContain('Story: 0-5-3');\n68\t    expect(frame).toContain('Phase: dev');\n69\t  });\n70\t\n71\t  it('renders separator line with heavy bars', () => {\n72\t    const info: SprintInfo = {\n73\t      storyKey: '1-1',\n74\t      phase: 'dev',\n75\t      done: 0,\n76\t      total: 5,\n77\t    };\n78\t    const { lastFrame } = render(<Header info={info} />);\n79\t    const frame = lastFrame()!;\n80\t    // AC2: separator line\n81\t    expect(frame).toContain('━━━');\n82\t  });\n83\t\n84\t  it('renders nothing when info is null', () => {\n85\t    const { lastFrame } = render(<Header info={null} />);\n86\t    expect(lastFrame()).toBe('');\n87\t  });\n88\t\n89\t  it('renders Phase with AC progress and current command', () => {\n90\t    const info: SprintInfo = {\n91\t      storyKey: '3-2',\n92\t      phase: 'verify',\n93\t      done: 18,\n94\t      total: 65,\n95\t      acProgress: '8/12',\n96\t      currentCommand: 'docker exec ... codeharness init --json',\n97\t    };\n98\t    const { lastFrame } = render(<Header info={info} />);\n99\t    const frame = lastFrame()!;\n100\t    expect(frame).toContain('Phase: verify');\n101\t    expect(frame).toContain('AC 8/12');\n102\t    expect(frame).toContain('(docker exec ... codeharness init --json)');\n103\t  });\n104\t\n105\t  it('omits iteration and cost when not provided', () => {\n106\t    const info: SprintInfo = {\n107\t      storyKey: '1-1',\n108\t      phase: 'dev',\n109\t      done: 0,\n110\t      total: 5,\n111\t    };\n112\t    const { lastFrame } = render(<Header info={info} />);\n113\t    const frame = lastFrame()!;\n114\t    expect(frame).toContain('codeharness run');\n115\t    expect(frame).not.toContain('iteration');\n116\t    expect(frame).not.toContain('spent');\n117\t    expect(frame).not.toContain('undefined');\n118\t  });\n119\t});\n120\t\n121\tdescribe('Separator component', () => {\n122\t  it('renders a line of heavy bar characters', () => {\n123\t    const { lastFrame } = render(<Separator />);\n124\t    const frame = lastFrame()!;\n125\t    expect(frame).toContain('━━━');\n126\t    // Verify it uses only ━ characters\n127\t    expect(frame.trim()).toMatch(/^━+$/);\n128\t  });\n129\t});\n130\t\n131\tdescribe('Header with elapsed time (AC #3)', () => {\n132\t  it('renders elapsed time when provided', () => {\n133\t    const info: SprintInfo = {\n134\t      storyKey: '3-2',\n135\t      phase: 'verify',\n136\t      done: 18,\n137\t      total: 65,\n138\t      elapsed: '47m',\n139\t      iterationCount: 3,\n140\t      totalCost: 12.30,\n141\t    };\n142\t    const { lastFrame } = render(<Header info={info} />);\n143\t    const frame = lastFrame()!;\n144\t    expect(frame).toContain('codeharness run');\n145\t    expect(frame).toContain('iteration 3');\n146\t    expect(frame).toContain('47m elapsed');\n147\t    expect(frame).toContain('$12.30 spent');\n148\t    expect(frame).toContain('Story: 3-2');\n149\t    expect(frame).toContain('Phase: verify');\n150\t  });\n151\t\n152\t  it('omits elapsed when not provided', () => {\n153\t    const info: SprintInfo = {\n154\t      storyKey: '1-1',\n155\t      phase: 'dev',\n156\t      done: 0,\n157\t      total: 5,\n158\t    };\n159\t    const { lastFrame } = render(<Header info={info} />);\n160\t    const frame = lastFrame()!;\n161\t    expect(frame).toContain('Story: 1-1');\n162\t    expect(frame).not.toContain('undefined');\n163\t  });\n164\t});\n165\t\n166\tdescribe('StoryBreakdown component (AC #4)', () => {\n167\t  it('renders labeled sections: Done, This, Next, Blocked', () => {\n168\t    const stories: StoryStatusEntry[] = [\n169\t      { key: '3-1-some-story', status: 'done' },\n170\t      { key: '4-1-another', status: 'done' },\n171\t      { key: '3-2-current', status: 'in-progress' },\n172\t      { key: '3-3-next-one', status: 'pending' },\n173\t      { key: '0-1-stuck', status: 'blocked', retryCount: 10, maxRetries: 10 },\n174\t    ];\n175\t    const { lastFrame } = render(<StoryBreakdown stories={stories} />);\n176\t    const frame = lastFrame()!;\n177\t    // Done: individual short keys with checkmarks\n178\t    expect(frame).toContain('Done:');\n179\t    expect(frame).toContain('3-1 ✓');\n180\t    expect(frame).toContain('4-1 ✓');\n181\t    // This: current story with diamond\n182\t    expect(frame).toContain('This:');\n183\t    expect(frame).toContain('3-2 ◆');\n184\t    // Next: next pending story\n185\t    expect(frame).toContain('Next:');\n186\t    expect(frame).toContain('3-3');\n187\t    // Blocked: with ✕ and retry counts\n188\t    expect(frame).toContain('Blocked:');\n189\t    expect(frame).toContain('0-1 ✕');\n190\t    expect(frame).toContain('(10/10)');\n191\t  });\n192\t\n193\t  it('renders nothing when stories array is empty', () => {\n194\t    const { lastFrame } = render(<StoryBreakdown stories={[]} />);\n195\t    expect(lastFrame()).toBe('');\n196\t  });\n197\t\n198\t  it('renders failed stories with ✗', () => {\n199\t    const stories: StoryStatusEntry[] = [\n200\t      { key: '2-3-broken', status: 'failed', retryCount: 5, maxRetries: 10 },"}]},"parent_tool_use_id":"toolu_0117vDhwD8YtdmVSBCbGt4wb","session_id":"a29ee53b-c2b0-4802-9455-7215112648b1","uuid":"bcd80984-a879-484d-a0ef-dcdfe7c5dcd9","timestamp":"2026-04-03T12:09:43.545Z"}
