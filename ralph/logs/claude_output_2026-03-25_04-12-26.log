{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FsL48AXYzKFnxEBAjmRP3w","type":"tool_result","content":"     1→/**\n     2→ * CLI command: codeharness timeout-report\n     3→ * Thin wrapper — parses args and delegates to captureTimeoutReport().\n     4→ */\n     5→\n     6→import { Command } from 'commander';\n     7→import { ok, fail, jsonOutput } from '../lib/output.js';\n     8→import { captureTimeoutReport } from '../modules/sprint/index.js';\n     9→\n    10→interface TimeoutReportOptions {\n    11→  story: string;\n    12→  iteration: string;\n    13→  duration: string;\n    14→  outputFile: string;\n    15→  stateSnapshot: string;\n    16→}\n    17→\n    18→export function registerTimeoutReportCommand(program: Command): void {\n    19→  program\n    20→    .command('timeout-report')\n    21→    .description('Capture diagnostic data from a timed-out iteration')\n    22→    .requiredOption('--story <key>', 'Story key')\n    23→    .requiredOption('--iteration <n>', 'Iteration number')\n    24→    .requiredOption('--duration <minutes>', 'Timeout duration in minutes')\n    25→    .requiredOption('--output-file <path>', 'Path to iteration output log')\n    26→    .requiredOption('--state-snapshot <path>', 'Path to pre-iteration state snapshot')\n    27→    .action((options: TimeoutReportOptions, cmd: Command) => {\n    28→      const opts = cmd.optsWithGlobals() as { json?: boolean };\n    29→      const isJson = opts.json === true;\n    30→\n    31→      const iteration = parseInt(options.iteration, 10);\n    32→      const duration = parseInt(options.duration, 10);\n    33→\n    34→      if (isNaN(iteration) || isNaN(duration)) {\n    35→        if (isJson) {\n    36→          jsonOutput({ status: 'fail', message: 'iteration and duration must be numbers' });\n    37→        } else {\n    38→          fail('iteration and duration must be numbers');\n    39→        }\n    40→        process.exitCode = 1;\n    41→        return;\n    42→      }\n    43→\n    44→      const result = captureTimeoutReport({\n    45→        storyKey: options.story,\n    46→        iteration,\n    47→        durationMinutes: duration,\n    48→        outputFile: options.outputFile,\n    49→        stateSnapshotPath: options.stateSnapshot,\n    50→      });\n    51→\n    52→      if (!result.success) {\n    53→        if (isJson) {\n    54→          jsonOutput({ status: 'fail', message: result.error });\n    55→        } else {\n    56→          fail(result.error);\n    57→        }\n    58→        process.exitCode = 1;\n    59→        return;\n    60→      }\n    61→\n    62→      if (isJson) {\n    63→        jsonOutput({\n    64→          status: 'ok',\n    65→          reportPath: result.data.filePath,\n    66→          storyKey: result.data.capture.storyKey,\n    67→          iteration: result.data.capture.iteration,\n    68→        });\n    69→      } else {\n    70→        ok(`Timeout report written: ${result.data.filePath}`);\n    71→      }\n    72→    });\n    73→}\n    74→"}]},"parent_tool_use_id":"toolu_01KNQnUKBFtzFzrosUg6K7qd","session_id":"7d2c764f-deb1-4354-ad31-e0a846d19ae3","uuid":"01bf9384-a19e-451b-8ae9-fe06f285c8b2","timestamp":"2026-03-25T00:16:58.591Z"}
