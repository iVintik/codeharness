{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FxXJUb9QCybgY4pS4DG9NN","type":"tool_result","content":"1\t/**\n2\t * Project initialization orchestrator.\n3\t * Composes sub-steps: stack detection, deps, Docker, BMAD, beads, state, docs, OTLP.\n4\t */\n5\t\n6\timport { existsSync } from 'node:fs';\n7\timport { basename, join } from 'node:path';\n8\timport { ok as okOutput, fail as failOutput, info, warn, jsonOutput } from '../../lib/output.js';\n9\timport { detectStacks, detectAppType } from '../../lib/stacks/index.js';\n10\timport { readState, writeState, getDefaultState, getStatePath } from '../../lib/state.js';\n11\timport type { HarnessState } from '../../lib/state.js';\n12\timport { instrumentProject } from '../../lib/observability/index.js';\n13\timport type { Result } from '../../types/result.js';\n14\timport { ok, fail, isOk } from '../../types/result.js';\n15\timport type { InitOptions, InitResult } from './types.js';\n16\timport { checkDocker, setupDocker } from './docker-setup.js';\n17\timport { installDeps, verifyDeps } from './deps-install.js';\n18\timport { setupBmad, verifyBmadOnRerun } from './bmad-setup.js';\n19\timport { scaffoldDocs, getCoverageTool, getStackLabel } from './docs-scaffold.js';\n20\timport { generateDockerfileTemplate } from './dockerfile-template.js';\n21\t\n22\tdeclare const __PKG_VERSION__: string;\n23\tconst HARNESS_VERSION = typeof __PKG_VERSION__ !== 'undefined' ? __PKG_VERSION__ : '0.0.0-dev';\n24\t\n25\t/** Helper: build a fail-status InitResult for early returns */\n26\tfunction failResult(opts: InitOptions, error: string): InitResult {\n27\t  return {\n28\t    status: 'fail', stack: null, stacks: [], error,\n29\t    enforcement: { frontend: opts.frontend, database: opts.database, api: opts.api },\n30\t    documentation: { agents_md: 'skipped', docs_scaffold: 'skipped', readme: 'skipped' },\n31\t  };\n32\t}\n33\t\n34\t/** Output error and set exit code for validation/critical failures */\n35\tfunction emitError(error: string, isJson: boolean): void {\n36\t  if (isJson) { jsonOutput({ status: 'fail', error }); } else { failOutput(error); }\n37\t  process.exitCode = 1;\n38\t}\n39\t\n40\t/** Main project initialization orchestrator. Never throws — returns fail() on unexpected errors. */\n41\texport async function initProject(opts: InitOptions): Promise<Result<InitResult>> {\n42\t  try {\n43\t    return await initProjectInner(opts);\n44\t  } catch (err) {\n45\t    const message = err instanceof Error ? err.message : String(err);\n46\t    return fail(`Unexpected init error: ${message}`);\n47\t  }\n48\t}\n49\t\n50\tasync function initProjectInner(opts: InitOptions): Promise<Result<InitResult>> {\n51\t  const { projectDir, json: isJson = false } = opts;\n52\t  const result: InitResult = {\n53\t    status: 'ok', stack: null, stacks: [],\n54\t    enforcement: { frontend: opts.frontend, database: opts.database, api: opts.api },\n55\t    documentation: { agents_md: 'skipped', docs_scaffold: 'skipped', readme: 'skipped' },\n56\t  };\n57\t\n58\t  // --- Idempotent re-run check ---\n59\t  const rerunResult = handleRerun(opts, result);\n60\t  if (rerunResult !== null) return rerunResult;\n61\t\n62\t  // --- Observability backend validation ---\n63\t  const validBackends = ['victoria', 'elk', 'none'] as const;\n64\t  if (opts.observabilityBackend !== undefined && !validBackends.includes(opts.observabilityBackend)) {\n65\t    const msg = `Invalid --observability-backend '${opts.observabilityBackend}'. Must be one of: ${validBackends.join(', ')}`;\n66\t    emitError(msg, isJson); return ok(failResult(opts, msg));\n67\t  }\n68\t\n69\t  // --- Remote endpoint URL validation ---\n70\t  const urlError = validateRemoteUrls(opts);\n71\t  if (urlError !== null) { emitError(urlError, isJson); return ok(failResult(opts, urlError)); }\n72\t\n73\t  // --- Stack detection ---\n74\t  // Call detectStacks() once; derive primary root stack from it to avoid double filesystem scan\n75\t  const allStacks = detectStacks(projectDir);\n76\t  const rootDetection = allStacks.find(s => s.dir === '.');\n77\t  const stack = rootDetection ? rootDetection.stack : null;\n78\t  if (!stack && !isJson) warn('No recognized stack detected');\n79\t  result.stack = stack;\n80\t  result.stacks = [...new Set(allStacks.map(s => s.stack))];\n81\t  const appType = detectAppType(projectDir, stack);\n82\t  result.app_type = appType;\n83\t  if (!isJson) {\n84\t    if (result.stacks.length > 0) {\n85\t      info(`Stack detected: ${getStackLabel(result.stacks)}`);\n86\t    } else if (stack) {\n87\t      info(`Stack detected: ${getStackLabel(stack)}`);\n88\t    }\n89\t    info(`App type: ${appType}`);\n90\t  }\n91\t\n92\t  // --- Dockerfile template generation ---\n93\t  const dfResult = generateDockerfileTemplate(projectDir, allStacks);\n94\t  if (isOk(dfResult)) {\n95\t    result.dockerfile = { generated: true, stack: dfResult.data.stack, stacks: dfResult.data.stacks };\n96\t    if (!isJson) info(`Generated Dockerfile for ${dfResult.data.stacks.join('+') || dfResult.data.stack} project.`);\n97\t  } else {\n98\t    if (!isJson) info('Dockerfile already exists -- skipping template generation.');\n99\t  }\n100\t\n101\t  // --- Docker check ---\n102\t  const dockerCheck = checkDocker({ observability: opts.observability, otelEndpoint: opts.otelEndpoint, logsUrl: opts.logsUrl, opensearchUrl: opts.opensearchUrl, isJson });\n103\t  if (!isOk(dockerCheck)) return fail(dockerCheck.error);\n104\t  const { available: dockerAvailable, criticalFailure, dockerResult: criticalDockerResult } = dockerCheck.data;\n105\t  if (criticalFailure) {\n106\t    result.status = 'fail'; result.error = 'Docker not installed'; result.docker = criticalDockerResult;\n107\t    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); }\n108\t    else { failOutput('Docker not installed'); info('\\u2192 Install Docker: https://docs.docker.com/engine/install/'); info('\\u2192 Or skip observability: codeharness init --no-observability'); }\n109\t    process.exitCode = 1;\n110\t    return ok(result);\n111\t  }\n112\t\n113\t  // --- Dependency install ---\n114\t  const depResult = installDeps({ isJson });\n115\t  if (!isOk(depResult)) {\n116\t    result.status = 'fail'; result.error = depResult.error;\n117\t    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); } else { info('Critical dependency failed — aborting init'); }\n118\t    process.exitCode = 1;\n119\t    return ok(result);\n120\t  }\n121\t  result.dependencies = depResult.data;\n122\t\n123\t  // --- Beads initialization — removed (Epic 8 replacement pending) ---\n124\t  // TODO: v2 issue tracker (Epic 8)\n125\t  result.beads = { status: 'skipped' as const, message: 'beads removed' };\n126\t\n127\t  // --- BMAD installation ---\n128\t  const bmadResult = setupBmad({ projectDir, isJson });\n129\t  if (isOk(bmadResult)) result.bmad = bmadResult.data;\n130\t\n131\t  // --- State file creation ---\n132\t  let state: HarnessState = getDefaultState(stack);\n133\t  state.harness_version = HARNESS_VERSION;\n134\t  state.initialized = true;\n135\t  state.app_type = appType;\n136\t  state.enforcement = { frontend: opts.frontend, database: opts.database, api: opts.api };\n137\t  // Per-stack coverage detection: build tools map keyed by stack name, primary stack's tool for backward compat\n138\t  const coverageTools: Record<string, string> = {};\n139\t  for (const detection of allStacks) {\n140\t    coverageTools[detection.stack] = getCoverageTool(detection.stack);\n141\t  }\n142\t  state.coverage.tool = getCoverageTool(stack);\n143\t  state.coverage.tools = coverageTools;\n144\t  // Persist all detected stacks (not just the primary root stack)\n145\t  state.stacks = result.stacks as import('../../lib/stacks/index.js').StackName[];\n146\t  writeState(state, projectDir);\n147\t  if (!isJson) okOutput('State file: .claude/codeharness.local.md created');\n148\t\n149\t  // --- Documentation scaffold ---\n150\t  const docsResult = await scaffoldDocs({ projectDir, stack, stacks: allStacks, isJson });\n151\t  if (isOk(docsResult)) result.documentation = docsResult.data;\n152\t\n153\t  // --- Store observability backend choice ---\n154\t  const obsBackend = opts.observabilityBackend ?? 'victoria';\n155\t  if (obsBackend === 'none') {\n156\t    // 'none' backend: disable OTLP and skip Docker, similar to --no-observability but persisted\n157\t    state.otlp = { enabled: false, endpoint: '', service_name: basename(projectDir), mode: 'local-shared', backend: 'none' };\n158\t    writeState(state, projectDir);\n159\t    result.otlp = { status: 'skipped', packages_installed: false, start_script_patched: false, env_vars_configured: false };\n160\t    if (!isJson) info('Observability: disabled (--observability-backend none)');\n161\t    // Skip enforcement summary for 'none' — jump to end\n162\t    if (!isJson) {\n163\t      const e = state.enforcement;\n164\t      const fmt = (v: boolean): string => v ? 'ON' : 'OFF';\n165\t      okOutput(`Enforcement: frontend:${fmt(e.frontend)} database:${fmt(e.database)} api:${fmt(e.api)} observability:OFF`);\n166\t      info('Harness initialized. Run: codeharness bridge --epics <path>');\n167\t    }\n168\t    if (isJson) jsonOutput(result as unknown as Record<string, unknown>);\n169\t    return ok(result);\n170\t  }\n171\t\n172\t  // --- OTLP instrumentation ---\n173\t  if (!opts.observability) {\n174\t    result.otlp = { status: 'skipped', packages_installed: false, start_script_patched: false, env_vars_configured: false };\n175\t    if (!isJson) info('OTLP: skipped (--no-observability)');\n176\t  } else {\n177\t    // Per-stack OTLP instrumentation: instrument each detected stack in its directory\n178\t    for (const detection of allStacks) {\n179\t      const stackDir = detection.dir === '.' ? projectDir : join(projectDir, detection.dir);\n180\t      const stackOtlp = instrumentProject(stackDir, detection.stack, { json: isJson, appType });\n181\t      // Primary (root) stack's result goes to result.otlp for backward compat\n182\t      if (detection.dir === '.' && detection.stack === stack) {\n183\t        result.otlp = stackOtlp;\n184\t      }\n185\t    }\n186\t    // Fallback: if primary stack wasn't in allStacks (shouldn't happen), use single-stack call\n187\t    if (!result.otlp) {\n188\t      result.otlp = instrumentProject(projectDir, stack, { json: isJson, appType });\n189\t    }\n190\t  }\n191\t\n192\t  // Re-read state to pick up otlp changes written by instrumentProject\n193\t  try { const u = readState(projectDir); if (u.otlp) state.otlp = u.otlp; } catch { /* IGNORE: state re-read may fail during init */ }\n194\t  if (!state.otlp) {\n195\t    state.otlp = { enabled: true, endpoint: 'http://localhost:4318', service_name: basename(projectDir), mode: 'local-shared' };\n196\t  }\n197\t  state.otlp.backend = obsBackend;\n198\t  writeState(state, projectDir);\n199\t\n200\t  // --- Docker stack setup ---\n201\t  const dockerSetup = setupDocker({\n202\t    observability: opts.observability, otelEndpoint: opts.otelEndpoint,\n203\t    opensearchUrl: opts.opensearchUrl,\n204\t    logsUrl: opts.logsUrl, metricsUrl: opts.metricsUrl, tracesUrl: opts.tracesUrl,\n205\t    isJson, dockerAvailable, appType, state, projectDir,\n206\t  });\n207\t  if (isOk(dockerSetup)) result.docker = dockerSetup.data.docker;\n208\t\n209\t  // --- Enforcement summary ---\n210\t  if (!isJson) {\n211\t    const e = state.enforcement;\n212\t    const fmt = (v: boolean): string => v ? 'ON' : 'OFF';\n213\t    okOutput(`Enforcement: frontend:${fmt(e.frontend)} database:${fmt(e.database)} api:${fmt(e.api)} observability:ON`);\n214\t    info('Harness initialized. Run: codeharness bridge --epics <path>');\n215\t  }\n216\t  if (isJson) jsonOutput(result as unknown as Record<string, unknown>);\n217\t\n218\t  return ok(result);\n219\t}\n220\t\n221\tfunction handleRerun(opts: InitOptions, result: InitResult): Result<InitResult> | null {\n222\t  const { projectDir, json: isJson = false } = opts;\n223\t  if (!existsSync(getStatePath(projectDir))) return null;\n224\t\n225\t  try {\n226\t    const existingState = readState(projectDir);\n227\t    const legacyObsDisabled = (existingState.enforcement as Record<string, unknown>).observability === false;\n228\t    if (!existingState.initialized || legacyObsDisabled) {\n229\t      if (legacyObsDisabled && !isJson) info('Observability upgraded from disabled to enabled');\n230\t      return null;\n231\t    }\n232\t    result.stack = existingState.stack;\n233\t    result.stacks = existingState.stacks ?? [];\n234\t    result.enforcement = existingState.enforcement;\n235\t    result.documentation = { agents_md: 'exists', docs_scaffold: 'exists', readme: 'exists' };\n236\t    result.dependencies = verifyDeps(isJson);\n237\t    result.docker = existingState.docker\n238\t      ? { compose_file: existingState.docker.compose_file, stack_running: existingState.docker.stack_running, services: [], ports: existingState.docker.ports }\n239\t      : null;\n240\t    const bmadResult = verifyBmadOnRerun(projectDir, isJson);\n241\t    if (bmadResult) result.bmad = bmadResult;\n242\t    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); }\n243\t    else { info('Harness already initialized — verifying configuration'); okOutput('Configuration verified'); }\n244\t    return ok(result);\n245\t  } catch {\n246\t    // IGNORE: re-init check may fail, non-fatal\n247\t    return null;\n248\t  }\n249\t}\n250\t\n251\t/** Returns error message string if validation fails, null if OK */\n252\tfunction validateRemoteUrls(opts: InitOptions): string | null {\n253\t  const remoteUrls = [opts.otelEndpoint, opts.opensearchUrl, opts.logsUrl, opts.metricsUrl, opts.tracesUrl].filter(Boolean) as string[];\n254\t  for (const url of remoteUrls) {\n255\t    if (!/^https?:\\/\\//i.test(url)) return `Invalid URL: '${url}' \\u2014 must start with http:// or https://`;\n256\t  }\n257\t  if (opts.otelEndpoint && (opts.logsUrl || opts.metricsUrl || opts.tracesUrl)) {\n258\t    return 'Cannot combine --otel-endpoint with --logs-url/--metrics-url/--traces-url';\n259\t  }\n260\t  const hasAny = opts.logsUrl || opts.metricsUrl || opts.tracesUrl;\n261\t  if (hasAny && !(opts.logsUrl && opts.metricsUrl && opts.tracesUrl)) {\n262\t    return 'When using remote backends, all three are required: --logs-url, --metrics-url, --traces-url';\n263\t  }\n264\t  return null;\n265\t}\n266\t"}]},"parent_tool_use_id":"toolu_01NHkhcMSk3T2Xeht2RXYVq5","session_id":"5e9a7eca-0e0b-47b2-8610-117311a6629c","uuid":"b92bc6a8-45d6-489f-aa25-fa4a9457d0d3","timestamp":"2026-04-02T14:31:25.496Z"}
