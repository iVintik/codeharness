{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FZxbdgBA9DVWkgFCxX5uSC","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';\n2\timport { mkdtempSync, rmSync } from 'node:fs';\n3\timport { existsSync as origExistsSync, readFileSync as origReadFileSync } from 'node:fs';\n4\timport { tmpdir } from 'node:os';\n5\timport { join } from 'node:path';\n6\timport { Command } from 'commander';\n7\timport { resolvePluginDir, countStories } from '../run.js';\n8\t\n9\t// --- Hoisted mocks ---\n10\tconst {\n11\t  getDriverMock, existsSyncMock, readSprintStatusMock,\n12\t  realExistsSync, startRendererMock, rendererCleanupMock,\n13\t  getSprintStateMock, reconcileStateMock,\n14\t  isDockerAvailableMock, cleanupContainersMock,\n15\t  parseWorkflowMock, resolveAgentMock, compileSubagentMock,\n16\t  executeWorkflowMock,\n17\t  readWorkflowStateMock, writeWorkflowStateMock,\n18\t} = vi.hoisted(() => {\n19\t  // eslint-disable-next-line @typescript-eslint/no-require-imports\n20\t  const fs = require('node:fs');\n21\t  const realFn = fs.existsSync.bind(fs);\n22\t\n23\t  const rendererCleanupMock = vi.fn();\n24\t\n25\t  return {\n26\t    getDriverMock: vi.fn(() => { throw new Error('No agent drivers available'); }),\n27\t    existsSyncMock: vi.fn(realFn),\n28\t    readSprintStatusMock: vi.fn(() => ({}) as Record<string, string>),\n29\t    realExistsSync: realFn as (path: string) => boolean,\n30\t    startRendererMock: vi.fn(() => ({\n31\t      update: vi.fn(),\n32\t      updateSprintState: vi.fn(),\n33\t      updateStories: vi.fn(),\n34\t      addMessage: vi.fn(),\n35\t      cleanup: rendererCleanupMock,\n36\t    })),\n37\t    rendererCleanupMock,\n38\t    getSprintStateMock: vi.fn((): { success: boolean; data?: Record<string, unknown>; error?: string } => ({ success: false, error: 'no state' })),\n39\t    reconcileStateMock: vi.fn(() => ({ success: true, data: { corrections: [], stateChanged: false } })),\n40\t    isDockerAvailableMock: vi.fn(() => true),\n41\t    cleanupContainersMock: vi.fn((): { success: boolean; data?: { containersRemoved: number; names: string[] }; error?: string } => ({ success: true, data: { containersRemoved: 0, names: [] } })),\n42\t    parseWorkflowMock: vi.fn(() => ({\n43\t      tasks: {\n44\t        implement: { agent: 'dev', scope: 'per-story', session: 'fresh', source_access: true },\n45\t      },\n46\t      flow: ['implement'],\n47\t    })),\n48\t    resolveAgentMock: vi.fn(() => ({\n49\t      name: 'dev',\n50\t      role: { title: 'Developer', purpose: 'Implement code' },\n51\t      persona: { identity: 'A developer', communication_style: 'direct', principles: [] },\n52\t    })),\n53\t    compileSubagentMock: vi.fn(() => ({\n54\t      name: 'dev',\n55\t      model: 'claude-sonnet-4-20250514',\n56\t      instructions: 'You are a developer',\n57\t      disallowedTools: [],\n58\t      bare: true,\n59\t    })),\n60\t    executeWorkflowMock: vi.fn(async () => ({\n61\t      success: true,\n62\t      tasksCompleted: 3,\n63\t      storiesProcessed: 1,\n64\t      errors: [],\n65\t      durationMs: 60000,\n66\t    })),\n67\t    readWorkflowStateMock: vi.fn(() => ({\n68\t      workflow_name: '',\n69\t      started: '',\n70\t      iteration: 0,\n71\t      phase: 'idle',\n72\t      tasks_completed: [],\n73\t      evaluator_scores: [],\n74\t      circuit_breaker: { triggered: false, reason: null, score_history: [] },\n75\t      trace_ids: [],\n76\t    })),\n77\t    writeWorkflowStateMock: vi.fn(),\n78\t  };\n79\t});\n80\t\n81\tvi.mock('../../lib/agents/index.js', () => ({\n82\t  getDriver: (...args: unknown[]) => getDriverMock(...(args as Parameters<typeof getDriverMock>)),\n83\t}));\n84\t\n85\tvi.mock('node:fs', async (importOriginal) => {\n86\t  const actual = await importOriginal<typeof import('node:fs')>();\n87\t  return { ...actual, existsSync: existsSyncMock };\n88\t});\n89\t\n90\tvi.mock('../../lib/ink-renderer.js', () => ({\n91\t  startRenderer: (...args: unknown[]) => startRendererMock(...(args as Parameters<typeof startRendererMock>)),\n92\t}));\n93\t\n94\tvi.mock('../../modules/sprint/index.js', () => ({\n95\t  getSprintState: (...args: unknown[]) => getSprintStateMock(...(args as Parameters<typeof getSprintStateMock>)),\n96\t  readSprintStatusFromState: (...args: unknown[]) => readSprintStatusMock(...(args as Parameters<typeof readSprintStatusMock>)),\n97\t  reconcileState: (...args: unknown[]) => reconcileStateMock(...(args as Parameters<typeof reconcileStateMock>)),\n98\t  updateStoryStatus: vi.fn(() => ({ success: true, data: undefined })),\n99\t  shouldDeferPhase: vi.fn(() => false),\n100\t  getPhaseEstimate: vi.fn(() => 15),\n101\t  computeRemainingMinutes: vi.fn(() => 60),\n102\t}));\n103\t\n104\tvi.mock('../../lib/docker/index.js', () => ({\n105\t  isDockerAvailable: (...args: unknown[]) => isDockerAvailableMock(...(args as Parameters<typeof isDockerAvailableMock>)),\n106\t}));\n107\t\n108\tvi.mock('../../modules/infra/index.js', () => ({\n109\t  cleanupContainers: (...args: unknown[]) => cleanupContainersMock(...(args as Parameters<typeof cleanupContainersMock>)),\n110\t}));\n111\t\n112\tvi.mock('../../lib/workflow-parser.js', () => ({\n113\t  parseWorkflow: (...args: unknown[]) => parseWorkflowMock(...(args as Parameters<typeof parseWorkflowMock>)),\n114\t}));\n115\t\n116\tvi.mock('../../lib/agent-resolver.js', () => ({\n117\t  resolveAgent: (...args: unknown[]) => resolveAgentMock(...(args as Parameters<typeof resolveAgentMock>)),\n118\t  compileSubagentDefinition: (...args: unknown[]) => compileSubagentMock(...(args as Parameters<typeof compileSubagentMock>)),\n119\t}));\n120\t\n121\tvi.mock('../../lib/workflow-engine.js', () => ({\n122\t  executeWorkflow: (...args: unknown[]) => executeWorkflowMock(...(args as Parameters<typeof executeWorkflowMock>)),\n123\t}));\n124\t\n125\tvi.mock('../../lib/workflow-state.js', () => ({\n126\t  readWorkflowState: (...args: unknown[]) => readWorkflowStateMock(...(args as Parameters<typeof readWorkflowStateMock>)),\n127\t  writeWorkflowState: (...args: unknown[]) => writeWorkflowStateMock(...(args as Parameters<typeof writeWorkflowStateMock>)),\n128\t}));\n129\t\n130\t\n131\tdescribe('run command', () => {\n132\t  let tmpDir: string;\n133\t\n134\t  beforeEach(() => {\n135\t    tmpDir = mkdtempSync(join(tmpdir(), 'run-test-'));\n136\t    getDriverMock.mockClear();\n137\t    existsSyncMock.mockReset();\n138\t    existsSyncMock.mockImplementation((p: unknown) => realExistsSync(String(p)));\n139\t    readSprintStatusMock.mockReset();\n140\t    readSprintStatusMock.mockReturnValue({});\n141\t    startRendererMock.mockClear();\n142\t    rendererCleanupMock.mockClear();\n143\t    getSprintStateMock.mockClear();\n144\t    getSprintStateMock.mockReturnValue({ success: false, error: 'no state' });\n145\t    reconcileStateMock.mockClear();\n146\t    reconcileStateMock.mockReturnValue({ success: true, data: { corrections: [], stateChanged: false } });\n147\t    isDockerAvailableMock.mockClear();\n148\t    isDockerAvailableMock.mockReturnValue(true);\n149\t    cleanupContainersMock.mockClear();\n150\t    cleanupContainersMock.mockReturnValue({ success: true, data: { containersRemoved: 0, names: [] } });\n151\t    parseWorkflowMock.mockReset();\n152\t    parseWorkflowMock.mockReturnValue({\n153\t      tasks: {\n154\t        implement: { agent: 'dev', scope: 'per-story', session: 'fresh', source_access: true },\n155\t      },\n156\t      flow: ['implement'],\n157\t    });\n158\t    resolveAgentMock.mockReset();\n159\t    resolveAgentMock.mockReturnValue({\n160\t      name: 'dev',\n161\t      role: { title: 'Developer', purpose: 'Implement code' },\n162\t      persona: { identity: 'A developer', communication_style: 'direct', principles: [] },\n163\t    });\n164\t    compileSubagentMock.mockReset();\n165\t    compileSubagentMock.mockReturnValue({\n166\t      name: 'dev',\n167\t      model: 'claude-sonnet-4-20250514',\n168\t      instructions: 'You are a developer',\n169\t      disallowedTools: [],\n170\t      bare: true,\n171\t    });\n172\t    executeWorkflowMock.mockReset();\n173\t    executeWorkflowMock.mockResolvedValue({\n174\t      success: true,\n175\t      tasksCompleted: 3,\n176\t      storiesProcessed: 1,\n177\t      errors: [],\n178\t      durationMs: 60000,\n179\t    });\n180\t    readWorkflowStateMock.mockReset();\n181\t    readWorkflowStateMock.mockReturnValue({\n182\t      workflow_name: '',\n183\t      started: '',\n184\t      iteration: 0,\n185\t      phase: 'idle',\n186\t      tasks_completed: [],\n187\t      evaluator_scores: [],\n188\t      circuit_breaker: { triggered: false, reason: null, score_history: [] },\n189\t      trace_ids: [],\n190\t    });\n191\t    writeWorkflowStateMock.mockReset();\n192\t    process.exitCode = undefined;\n193\t  });\n194\t\n195\t  afterEach(() => {\n196\t    rmSync(tmpDir, { recursive: true, force: true });\n197\t    vi.restoreAllMocks();\n198\t    process.exitCode = undefined;\n199\t  });\n200\t\n201\t  function mockPaths(overrides: Record<string, boolean>) {\n202\t    existsSyncMock.mockImplementation((p: unknown) => {\n203\t      const path = String(p);\n204\t      for (const [pattern, value] of Object.entries(overrides)) {\n205\t        if (path.includes(pattern)) return value;\n206\t      }\n207\t      return realExistsSync(path);\n208\t    });\n209\t  }\n210\t\n211\t  async function runCommand(args: string[] = []) {\n212\t    const { registerRunCommand } = await import('../run.js');\n213\t    const program = new Command();\n214\t    program.exitOverride();\n215\t    program.option('--json', 'JSON output');\n216\t    registerRunCommand(program);\n217\t    await program.parseAsync(['node', 'codeharness', 'run', ...args]);\n218\t  }\n219\t\n220\t  describe('resolvePluginDir', () => {\n221\t    it('returns cwd/.claude', () => {\n222\t      expect(resolvePluginDir()).toBe(join(process.cwd(), '.claude'));\n223\t    });\n224\t  });\n225\t