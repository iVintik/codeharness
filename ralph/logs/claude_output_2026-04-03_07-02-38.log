{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QNEPizngpk5viQADVd9XpE","type":"tool_result","content":"100\t\n101\t/** Validates proof quality. `passed` is true when `pending === 0 && verified > 0`. */\n102\texport function validateProofQuality(proofPath: string): ProofQuality {\n103\t  const emptyResult: ProofQuality = {\n104\t    verified: 0, pending: 0, escalated: 0, total: 0, passed: false,\n105\t    grepSrcCount: 0, dockerExecCount: 0, observabilityCount: 0, otherCount: 0,\n106\t    blackBoxPass: false,\n107\t  };\n108\t\n109\t  if (!existsSync(proofPath)) {\n110\t    return emptyResult;\n111\t  }\n112\t\n113\t  const content = readFileSync(proofPath, 'utf-8');\n114\t\n115\t  // Compute black-box enforcement metrics once\n116\t  // Build tier regex dynamically from canonical TIER_HIERARCHY + legacy names\n117\t  const allTierNames = [...TIER_HIERARCHY, ...Object.keys(LEGACY_TIER_MAP)];\n118\t  const uniqueTierNames = [...new Set(allTierNames)];\n119\t  const tierPattern = new RegExp(`\\\\*\\\\*Tier:\\\\*\\\\*\\\\s*(${uniqueTierNames.join('|')})`, 'i');\n120\t  const bbTierMatch = tierPattern.exec(content);\n121\t  const rawTierValue = bbTierMatch ? bbTierMatch[1].toLowerCase() : null;\n122\t  // Normalize legacy tier names to canonical VerificationTier values\n123\t  const normalizedTier: VerificationTier | null = rawTierValue\n124\t    ? (LEGACY_TIER_MAP[rawTierValue] as VerificationTier | undefined) ?? (TIER_HIERARCHY.includes(rawTierValue as VerificationTier) ? rawTierValue as VerificationTier : null)\n125\t    : null;\n126\t  // Only environment-provable requires Docker evidence; all others skip\n127\t  const skipDockerEnforcement = normalizedTier !== null && normalizedTier !== 'environment-provable';\n128\t  // Always compute metrics for diagnostics; override blackBoxPass when skipping\n129\t  const bbRawEnforcement = checkBlackBoxEnforcement(content);\n130\t  const bbEnforcement = skipDockerEnforcement\n131\t    ? { ...bbRawEnforcement, blackBoxPass: true }\n132\t    : bbRawEnforcement;\n133\t\n134\t  /** Helper: merge base counts with black-box metrics */\n135\t  function buildResult(base: {\n136\t    verified: number; pending: number; escalated: number; total: number;\n137\t  }): ProofQuality {\n138\t    const basePassed = base.pending === 0 && base.verified > 0;\n139\t    return {\n140\t      ...base,\n141\t      passed: basePassed && bbEnforcement.blackBoxPass,\n142\t      grepSrcCount: bbEnforcement.grepSrcCount,\n143\t      dockerExecCount: bbEnforcement.dockerExecCount,\n144\t      observabilityCount: bbEnforcement.observabilityCount,\n145\t      otherCount: bbEnforcement.otherCount,\n146\t      blackBoxPass: bbEnforcement.blackBoxPass,\n147\t    };\n148\t  }\n149\t\n150\t  // Format 1: ## AC N: section headers\n151\t  const acHeaderPattern = /^## AC ?(\\d+):/gm;\n152\t  const matches = [...content.matchAll(acHeaderPattern)];\n153\t\n154\t  // Find all ## headings that are NOT AC headers (e.g. ## Summary, ## Test Evidence)\n155\t  // These bound the last AC section so it doesn't bleed into trailing sections\n156\t  const nonAcHeadingPattern = /^## (?!AC ?\\d+:)/gm;\n157\t  const nonAcHeadings = [...content.matchAll(nonAcHeadingPattern)].map(m => m.index!);\n158\t\n159\t  let verified = 0;\n160\t  let pending = 0;\n161\t  let escalated = 0;\n162\t\n163\t  if (matches.length > 0) {\n164\t    for (let i = 0; i < matches.length; i++) {\n165\t      const start = matches[i].index!;\n166\t      // End at the next ## AC header or any non-AC ## heading (e.g. ## Summary), whichever comes first\n167\t      const nextAcEnd = i + 1 < matches.length ? matches[i + 1].index! : content.length;\n168\t      const nextNonAcHeading = nonAcHeadings.find(h => h > start);\n169\t      const end = nextNonAcHeading !== undefined && nextNonAcHeading < nextAcEnd\n170\t        ? nextNonAcHeading\n171\t        : nextAcEnd;\n172\t      const section = content.slice(start, end);\n173\t\n174\t      if (section.includes('[ESCALATE]')) {\n175\t        escalated++;\n176\t        continue;\n177\t      }\n178\t\n179\t      if (hasFailVerdict(section)) {"}]},"parent_tool_use_id":"toolu_01RP7o3BVkPNLNUsnWp84iwa","session_id":"c2800ecc-75a3-43b2-b3d8-396855aa3c3c","uuid":"c6afb561-137d-4b21-ad63-7156bbce661e","timestamp":"2026-04-03T03:17:17.146Z"}
