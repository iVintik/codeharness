{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XT2tGu1H8Sd4DdxNW3Fdqo","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { validateAgentSchema, validateWorkflowSchema } from '../schema-validate.js';\n3\t\n4\t// --- Helpers ---\n5\t\n6\tfunction minimalValidAgent() {\n7\t  return {\n8\t    name: 'evaluator',\n9\t    role: {\n10\t      title: 'Adversarial QA Evaluator',\n11\t      purpose: 'Exercise the built artifact and determine if it actually works',\n12\t    },\n13\t    persona: {\n14\t      identity: 'Senior QA who trusts nothing without evidence',\n15\t      communication_style: 'Blunt, evidence-first',\n16\t      principles: [\n17\t        'Never give the benefit of the doubt',\n18\t        'Every PASS requires evidence',\n19\t      ],\n20\t    },\n21\t  };\n22\t}\n23\t\n24\tfunction agentWithPersonality() {\n25\t  return {\n26\t    ...minimalValidAgent(),\n27\t    personality: {\n28\t      traits: {\n29\t        rigor: 0.98,\n30\t        directness: 0.95,\n31\t        warmth: 0.2,\n32\t      },\n33\t    },\n34\t  };\n35\t}\n36\t\n37\tfunction agentWithDisallowedTools() {\n38\t  return {\n39\t    ...minimalValidAgent(),\n40\t    disallowedTools: ['Edit', 'Write'],\n41\t  };\n42\t}\n43\t\n44\t// --- Tests ---\n45\t\n46\tdescribe('validateAgentSchema', () => {\n47\t  describe('valid agents', () => {\n48\t    it('accepts a minimal valid agent with all required fields (AC #1, #2)', () => {\n49\t      const result = validateAgentSchema(minimalValidAgent());\n50\t      expect(result.valid).toBe(true);\n51\t      expect(result.errors).toEqual([]);\n52\t    });\n53\t\n54\t    it('accepts agent with optional personality.traits in 0-1 range (AC #5)', () => {\n55\t      const result = validateAgentSchema(agentWithPersonality());\n56\t      expect(result.valid).toBe(true);\n57\t      expect(result.errors).toEqual([]);\n58\t    });\n59\t\n60\t    it('accepts agent with valid disallowedTools array', () => {\n61\t      const result = validateAgentSchema(agentWithDisallowedTools());\n62\t      expect(result.valid).toBe(true);\n63\t      expect(result.errors).toEqual([]);\n64\t    });\n65\t\n66\t    it('accepts agent with all optional fields present', () => {\n67\t      const agent = {\n68\t        ...minimalValidAgent(),\n69\t        personality: {\n70\t          traits: {\n71\t            rigor: 0.98,\n72\t            warmth: 0.2,\n73\t          },\n74\t        },\n75\t        disallowedTools: ['Edit', 'Write'],\n76\t      };\n77\t      const result = validateAgentSchema(agent);\n78\t      expect(result.valid).toBe(true);\n79\t      expect(result.errors).toEqual([]);\n80\t    });\n81\t\n82\t    it('accepts personality with empty traits object', () => {\n83\t      const agent = {\n84\t        ...minimalValidAgent(),\n85\t        personality: { traits: {} },\n86\t      };\n87\t      const result = validateAgentSchema(agent);\n88\t      expect(result.valid).toBe(true);\n89\t    });\n90\t\n91\t    it('accepts trait values at boundaries (0 and 1)', () => {\n92\t      const agent = {\n93\t        ...minimalValidAgent(),\n94\t        personality: {\n95\t          traits: {\n96\t            minimum: 0,\n97\t            maximum: 1,\n98\t          },\n99\t        },\n100\t      };\n101\t      const result = validateAgentSchema(agent);\n102\t      expect(result.valid).toBe(true);\n103\t    });\n104\t  });\n105\t\n106\t  describe('missing required fields', () => {\n107\t    it('rejects missing name field (AC #3)', () => {\n108\t      const { name: _, ...agent } = minimalValidAgent();\n109\t      const result = validateAgentSchema(agent);\n110\t      expect(result.valid).toBe(false);\n111\t      expect(result.errors.some((e) => e.keyword === 'required' && e.message.includes('name'))).toBe(true);\n112\t    });\n113\t\n114\t    it('rejects missing role field (AC #3)', () => {\n115\t      const { role: _, ...agent } = minimalValidAgent();\n116\t      const result = validateAgentSchema(agent);\n117\t      expect(result.valid).toBe(false);\n118\t      expect(result.errors.some((e) => e.keyword === 'required' && e.message.includes('role'))).toBe(true);\n119\t    });\n120\t\n121\t    it('rejects missing persona field (AC #3)', () => {\n122\t      const { persona: _, ...agent } = minimalValidAgent();\n123\t      const result = validateAgentSchema(agent);\n124\t      expect(result.valid).toBe(false);\n125\t      expect(result.errors.some((e) => e.keyword === 'required' && e.message.includes('persona'))).toBe(true);\n126\t    });\n127\t\n128\t    it('rejects missing role.title', () => {\n129\t      const agent = minimalValidAgent();\n130\t      delete (agent.role as Record<string, unknown>).title;\n131\t      const result = validateAgentSchema(agent);\n132\t      expect(result.valid).toBe(false);\n133\t      expect(result.errors.some((e) => e.keyword === 'required' && e.path === '/role')).toBe(true);\n134\t    });\n135\t\n136\t    it('rejects missing role.purpose', () => {\n137\t      const agent = minimalValidAgent();\n138\t      delete (agent.role as Record<string, unknown>).purpose;\n139\t      const result = validateAgentSchema(agent);\n140\t      expect(result.valid).toBe(false);\n141\t      expect(result.errors.some((e) => e.keyword === 'required' && e.path === '/role')).toBe(true);\n142\t    });\n143\t\n144\t    it('rejects missing persona.identity', () => {\n145\t      const agent = minimalValidAgent();\n146\t      delete (agent.persona as Record<string, unknown>).identity;\n147\t      const result = validateAgentSchema(agent);\n148\t      expect(result.valid).toBe(false);\n149\t      expect(result.errors.some((e) => e.keyword === 'required' && e.path === '/persona')).toBe(true);\n150\t    });\n151\t\n152\t    it('rejects missing persona.communication_style', () => {\n153\t      const agent = minimalValidAgent();\n154\t      delete (agent.persona as Record<string, unknown>).communication_style;\n155\t      const result = validateAgentSchema(agent);\n156\t      expect(result.valid).toBe(false);\n157\t      expect(result.errors.some((e) => e.keyword === 'required' && e.path === '/persona')).toBe(true);\n158\t    });\n159\t\n160\t    it('rejects missing persona.principles', () => {\n161\t      const agent = minimalValidAgent();\n162\t      delete (agent.persona as Record<string, unknown>).principles;\n163\t      const result = validateAgentSchema(agent);\n164\t      expect(result.valid).toBe(false);\n165\t      expect(result.errors.some((e) => e.keyword === 'required' && e.path === '/persona')).toBe(true);\n166\t    });\n167\t  });\n168\t\n169\t  describe('personality trait validation', () => {\n170\t    it('rejects trait value above 1 (AC #4)', () => {\n171\t      const agent = {\n172\t        ...minimalValidAgent(),\n173\t        personality: {\n174\t          traits: {\n175\t            rigor: 1.5,\n176\t          },\n177\t        },\n178\t      };\n179\t      const result = validateAgentSchema(agent);\n180\t      expect(result.valid).toBe(false);\n181\t      expect(result.errors.some((e) => e.keyword === 'maximum' && e.path.includes('rigor'))).toBe(true);\n182\t    });\n183\t\n184\t    it('rejects trait value below 0 (AC #4)', () => {\n185\t      const agent = {\n186\t        ...minimalValidAgent(),\n187\t        personality: {\n188\t          traits: {\n189\t            warmth: -0.1,\n190\t          },\n191\t        },\n192\t      };\n193\t      const result = validateAgentSchema(agent);\n194\t      expect(result.valid).toBe(false);\n195\t      expect(result.errors.some((e) => e.keyword === 'minimum' && e.path.includes('warmth'))).toBe(true);\n196\t    });\n197\t\n198\t    it('rejects non-number trait value', () => {\n199\t      const agent = {\n200\t        ...minimalValidAgent(),\n201\t        personality: {\n202\t          traits: {\n203\t            rigor: 'high',\n204\t          },\n205\t        },\n206\t      };\n207\t      const result = validateAgentSchema(agent);\n208\t      expect(result.valid).toBe(false);\n209\t      expect(result.errors.some((e) => e.keyword === 'type')).toBe(true);\n210\t    });\n211\t  });\n212\t\n213\t  describe('additional properties', () => {\n214\t    it('rejects unknown top-level property', () => {\n215\t      const agent = {\n216\t        ...minimalValidAgent(),\n217\t        unknownField: 'unexpected',\n218\t      };\n219\t      const result = validateAgentSchema(agent);\n220\t      expect(result.valid).toBe(false);\n221\t      expect(result.errors.some((e) => e.keyword === 'additionalProperties')).toBe(true);\n222\t    });\n223\t\n224\t    it('rejects unknown property in role', () => {\n225\t      const agent = minimalValidAgent();\n226\t      (agent.role as Record<string, unknown>).extra = 'nope';\n227\t      const result = validateAgentSchema(agent);\n228\t      expect(result.valid).toBe(false);\n229\t      expect(result.errors.some((e) => e.keyword === 'additionalProperties')).toBe(true);\n230\t    });\n231\t\n232\t    it('rejects unknown property in persona', () => {\n233\t      const agent = minimalValidAgent();\n234\t      (agent.persona as Record<string, unknown>).extra = 'nope';\n235\t      const result = validateAgentSchema(agent);\n236\t      expect(result.valid).toBe(false);\n237\t      expect(result.errors.some((e) => e.keyword === 'additionalProperties')).toBe(true);\n238\t    });\n239\t\n240\t    it('rejects unknown property in personality', () => {\n241\t      const agent = {\n242\t        ...minimalValidAgent(),\n243\t        personality: {\n244\t          traits: { rigor: 0.9 },\n245\t          extra: 'nope',\n246\t        },\n247\t      };\n248\t      const result = validateAgentSchema(agent);\n249\t      expect(result.valid).toBe(false);\n250\t      expect(result.errors.some((e) => e.keyword === 'additionalProperties')).toBe(true);\n251\t    });\n252\t  });\n253\t\n254\t  describe('edge cases', () => {\n255\t    it('rejects null input', () => {\n256\t      const result = validateAgentSchema(null);\n257\t      expect(result.valid).toBe(false);\n258\t    });\n259\t\n260\t    it('rejects non-object input', () => {\n261\t      const result = validateAgentSchema('not an object');\n262\t      expect(result.valid).toBe(false);\n263\t    });\n264\t\n265\t    it('rejects array input', () => {\n266\t      const result = validateAgentSchema([]);\n267\t      expect(result.valid).toBe(false);\n268\t    });\n269\t\n270\t    it('rejects empty object', () => {\n271\t      const result = validateAgentSchema({});\n272\t      expect(result.valid).toBe(false);\n273\t    });\n274\t  });\n275\t\n276\t  describe('error structure', () => {\n277\t    it('returns errors with path, message, and keyword', () => {\n278\t      const result = validateAgentSchema({});\n279\t      expect(result.valid).toBe(false);\n280\t      expect(result.errors.length).toBeGreaterThan(0);\n281\t      for (const err of result.errors) {\n282\t        expect(err).toHaveProperty('path');\n283\t        expect(err).toHaveProperty('message');\n284\t        expect(err).toHaveProperty('keyword');\n285\t        expect(typeof err.path).toBe('string');\n286\t        expect(typeof err.message).toBe('string');\n287\t        expect(typeof err.keyword).toBe('string');\n288\t      }\n289\t    });\n290\t\n291\t    it('returns ValidationResult with valid: true and errors: [] for valid input (AC #6)', () => {\n292\t      const result = validateAgentSchema(minimalValidAgent());\n293\t      expect(result).toEqual({ valid: true, errors: [] });\n294\t    });\n295\t  });\n296\t\n297\t  describe('no regressions', () => {\n298\t    it('existing workflow schema validation still works (AC #8)', () => {\n299\t      const validWorkflow = {\n300\t        tasks: { implement: { agent: 'dev' } },\n301\t        flow: ['implement'],\n302\t      };\n303\t      const result = validateWorkflowSchema(validWorkflow);\n304\t      expect(result.valid).toBe(true);\n305\t      expect(result.errors).toEqual([]);\n306\t    });\n307\t\n308\t    it('existing workflow schema still rejects invalid input', () => {\n309\t      const result = validateWorkflowSchema({});\n310\t      expect(result.valid).toBe(false);\n311\t      expect(result.errors.length).toBeGreaterThan(0);\n312\t    });\n313\t  });\n314\t});\n315\t"}]},"parent_tool_use_id":"toolu_01MZT1wf6WvCyJ5fZdoG3o3g","session_id":"fb9c1538-17c2-48c5-8d63-6a9f60fb8dd3","uuid":"9437dfa2-ac9c-4379-be01-d18cdb0a68d7","timestamp":"2026-04-02T15:18:37.267Z"}
