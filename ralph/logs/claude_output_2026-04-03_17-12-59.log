{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VRFZViU7cCwXaFWzkXzqbw","type":"tool_result","content":"1\t/**\n2\t * Driver Factory & Registry.\n3\t *\n4\t * Module-singleton registry for AgentDriver instances.\n5\t * Drivers are registered explicitly via registerDriver() — no auto-discovery,\n6\t * no filesystem scanning, no dynamic imports.\n7\t *\n8\t * @see architecture-multi-framework.md — \"Register in factory.ts — never auto-discover\"\n9\t */\n10\t\n11\timport type { AgentDriver, DriverCapabilities } from '../types.js';\n12\t\n13\tconst registry = new Map<string, AgentDriver>();\n14\t\n15\t/**\n16\t * Register an AgentDriver by its `name` property.\n17\t * Throws if a driver with the same name is already registered.\n18\t */\n19\texport function registerDriver(driver: AgentDriver): void {\n20\t  if (!driver || typeof driver.name !== 'string') {\n21\t    throw new Error('registerDriver requires a valid AgentDriver with a string name property.');\n22\t  }\n23\t  if (!driver.name) {\n24\t    throw new Error('Driver name must be a non-empty string.');\n25\t  }\n26\t  if (registry.has(driver.name)) {\n27\t    throw new Error(\n28\t      `Driver '${driver.name}' is already registered. Each driver name must be unique.`,\n29\t    );\n30\t  }\n31\t  registry.set(driver.name, driver);\n32\t}\n33\t\n34\t/**\n35\t * Retrieve a registered AgentDriver by name.\n36\t * Throws with a helpful message listing all registered drivers if not found.\n37\t */\n38\texport function getDriver(name: string): AgentDriver {\n39\t  if (!name || typeof name !== 'string') {\n40\t    throw new Error('getDriver requires a non-empty string name.');\n41\t  }\n42\t  const driver = registry.get(name);\n43\t  if (!driver) {\n44\t    const registered = [...registry.keys()];\n45\t    const list =\n46\t      registered.length > 0 ? registered.join(', ') : '(none)';\n47\t    throw new Error(\n48\t      `Driver '${name}' not found. Registered drivers: ${list}`,\n49\t    );\n50\t  }\n51\t  return driver;\n52\t}\n53\t\n54\t/**\n55\t * List all registered driver names.\n56\t * Returns a copy — mutating the returned array does not affect the registry.\n57\t */\n58\texport function listDrivers(): string[] {\n59\t  return [...registry.keys()];\n60\t}\n61\t\n62\t/**\n63\t * Clear all registered drivers. Exported for test isolation.\n64\t */\n65\texport function resetDrivers(): void {\n66\t  registry.clear();\n67\t}\n68\t\n69\t/**\n70\t * Suggest a cheaper registered driver whose capabilities satisfy the required capabilities.\n71\t *\n72\t * Returns the name of the cheapest capable driver if it is cheaper than the current driver,\n73\t * or `null` if the current driver is already the cheapest capable option.\n74\t *\n75\t * @param driverName - The current driver name.\n76\t * @param requiredCaps - Partial capability flags the task requires (only boolean fields checked).\n77\t * @returns The cheaper driver name or null.\n78\t */\n79\texport function suggestCheaperDriver(\n80\t  driverName: string,\n81\t  requiredCaps: Partial<DriverCapabilities>,\n82\t): string | null {\n83\t  const current = registry.get(driverName);\n84\t  if (!current) return null;\n85\t\n86\t  let cheapestName: string | null = null;\n87\t  let cheapestTier = Infinity;\n88\t\n89\t  for (const [name, driver] of registry) {\n90\t    // Check that this driver satisfies all required boolean capabilities\n91\t    let satisfies = true;\n92\t    for (const [key, value] of Object.entries(requiredCaps)) {\n93\t      if (typeof value === 'boolean' && value === true) {\n94\t        if (!(driver.capabilities as Record<string, unknown>)[key]) {\n95\t          satisfies = false;\n96\t          break;\n97\t        }\n98\t      }\n99\t    }\n100\t    if (satisfies && driver.capabilities.costTier < cheapestTier) {\n101\t      cheapestTier = driver.capabilities.costTier;\n102\t      cheapestName = name;\n103\t    }\n104\t  }\n105\t\n106\t  if (cheapestName && cheapestTier < current.capabilities.costTier) {\n107\t    return cheapestName;\n108\t  }\n109\t  return null;\n110\t}\n111\t"}]},"parent_tool_use_id":"toolu_01WL7MCsNF3La2JHGCjnTeXK","session_id":"cf16e575-8267-4c58-a992-20b07458710f","uuid":"c02a6797-8223-447b-99c1-51985dc79ac8","timestamp":"2026-04-03T13:29:56.388Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018Yy6zMXgYUhzybEHRRmnKs","type":"tool_result","content":"1\t/**\n2\t * codeharness drivers — Query the driver capability matrix.\n3\t *\n4\t * Outputs a JSON object with each registered driver's default model,\n5\t * capabilities, and a human-readable description.\n6\t *\n7\t * @see architecture-multi-framework.md — FR37: queryable driver capabilities\n8\t */\n9\t\n10\timport { Command } from 'commander';\n11\timport { jsonOutput } from '../lib/output.js';\n12\timport { listDrivers, getDriver } from '../lib/agents/drivers/factory.js';\n13\timport { registerDriver } from '../lib/agents/drivers/factory.js';\n14\timport { ClaudeCodeDriver } from '../lib/agents/drivers/claude-code.js';\n15\timport { CodexDriver } from '../lib/agents/drivers/codex.js';\n16\timport { OpenCodeDriver } from '../lib/agents/drivers/opencode.js';\n17\t\n18\t/** Static description map — avoids changing the AgentDriver interface for display concerns. */\n19\tconst DRIVER_DESCRIPTIONS: Record<string, string> = {\n20\t  'claude-code': 'Anthropic Claude via Agent SDK (in-process)',\n21\t  codex: 'OpenAI Codex via CLI',\n22\t  opencode: 'OpenCode via CLI',\n23\t};\n24\t\n25\t/**\n26\t * Ensure all built-in drivers are registered.\n27\t * Safe to call multiple times — skips already-registered drivers.\n28\t */\n29\tfunction ensureDriversRegistered(): void {\n30\t  const registered = new Set(listDrivers());\n31\t  if (!registered.has('claude-code')) registerDriver(new ClaudeCodeDriver());\n32\t  if (!registered.has('codex')) registerDriver(new CodexDriver());\n33\t  if (!registered.has('opencode')) registerDriver(new OpenCodeDriver());\n34\t}\n35\t\n36\texport function registerDriversCommand(program: Command): void {\n37\t  program\n38\t    .command('drivers')\n39\t    .description('List registered drivers and their capabilities')\n40\t    .action((_options, cmd) => {\n41\t      const globalOpts = cmd.optsWithGlobals();\n42\t      const isJson = !!globalOpts.json;\n43\t\n44\t      ensureDriversRegistered();\n45\t\n46\t      const result: Record<string, unknown> = {};\n47\t      for (const name of listDrivers()) {\n48\t        const driver = getDriver(name);\n49\t        result[name] = {\n50\t          defaultModel: driver.defaultModel,\n51\t          capabilities: { ...driver.capabilities },\n52\t          description: DRIVER_DESCRIPTIONS[name] ?? name,\n53\t        };\n54\t      }\n55\t\n56\t      if (isJson) {\n57\t        jsonOutput(result);\n58\t      } else {\n59\t        console.log(JSON.stringify(result, null, 2));\n60\t      }\n61\t    });\n62\t}\n63\t"}]},"parent_tool_use_id":"toolu_01WL7MCsNF3La2JHGCjnTeXK","session_id":"cf16e575-8267-4c58-a992-20b07458710f","uuid":"ffc18f0b-d881-4bd4-904d-b6c5924cea61","timestamp":"2026-04-03T13:29:56.388Z"}
