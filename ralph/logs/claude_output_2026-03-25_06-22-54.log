{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011VaNkqdM6vJTGso5hPmmsi","type":"tool_result","content":"     1в†’# Review Story Workflow\n     2в†’name: code-review\n     3в†’description: \"Perform an ADVERSARIAL Senior Developer code review that finds 3-10 specific problems in every story. Challenges everything: code quality, test coverage, architecture compliance, security, performance. NEVER accepts `looks good` - must find minimum issues and can auto-fix with user approval.\"\n     4в†’author: \"BMad\"\n     5в†’\n     6в†’# Critical variables from config\n     7в†’config_source: \"{project-root}/_bmad/bmm/config.yaml\"\n     8в†’user_name: \"{config_source}:user_name\"\n     9в†’communication_language: \"{config_source}:communication_language\"\n    10в†’user_skill_level: \"{config_source}:user_skill_level\"\n    11в†’document_output_language: \"{config_source}:document_output_language\"\n    12в†’date: system-generated\n    13в†’planning_artifacts: \"{config_source}:planning_artifacts\"\n    14в†’implementation_artifacts: \"{config_source}:implementation_artifacts\"\n    15в†’sprint_status: \"{implementation_artifacts}/sprint-status.yaml\"\n    16в†’\n    17в†’# Workflow components\n    18в†’installed_path: \"{project-root}/_bmad/bmm/workflows/4-implementation/code-review\"\n    19в†’instructions: \"{installed_path}/instructions.xml\"\n    20в†’validation: \"{installed_path}/checklist.md\"\n    21в†’template: false\n    22в†’\n    23в†’project_context: \"**/project-context.md\"\n    24в†’\n    25в†’# Smart input file references - handles both whole docs and sharded docs\n    26в†’# Priority: Whole document first, then sharded version\n    27в†’# Strategy: SELECTIVE LOAD - only load the specific epic needed for this story review\n    28в†’input_file_patterns:\n    29в†’  architecture:\n    30в†’    description: \"System architecture for review context\"\n    31в†’    whole: \"{planning_artifacts}/*architecture*.md\"\n    32в†’    sharded: \"{planning_artifacts}/*architecture*/*.md\"\n    33в†’    load_strategy: \"FULL_LOAD\"\n    34в†’  ux_design:\n    35в†’    description: \"UX design specification (if UI review)\"\n    36в†’    whole: \"{planning_artifacts}/*ux*.md\"\n    37в†’    sharded: \"{planning_artifacts}/*ux*/*.md\"\n    38в†’    load_strategy: \"FULL_LOAD\"\n    39в†’  epics:\n    40в†’    description: \"Epic containing story being reviewed\"\n    41в†’    whole: \"{planning_artifacts}/*epic*.md\"\n    42в†’    sharded_index: \"{planning_artifacts}/*epic*/index.md\"\n    43в†’    sharded_single: \"{planning_artifacts}/*epic*/epic-{{epic_num}}.md\"\n    44в†’    load_strategy: \"SELECTIVE_LOAD\"\n    45в†’"}]},"parent_tool_use_id":"toolu_011Fip6m9FHVBszWegBeTJVL","session_id":"406ac605-1908-4bc8-82ff-6bd28578af4b","uuid":"32b14ee7-5dc8-40f3-b364-7f6fb82f18b1","timestamp":"2026-03-25T02:24:23.069Z"}
