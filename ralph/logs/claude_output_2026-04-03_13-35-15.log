{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KD2Zmoo3w3vcdv14po5b8y","type":"tool_result","content":"1\t/**\n2\t * Story file acceptance criteria parser.\n3\t * Reads story markdown files and extracts numbered ACs with type classification.\n4\t */\n5\t\n6\timport { existsSync, readFileSync } from 'node:fs';\n7\timport { warn } from '../../lib/output.js';\n8\timport type { ParsedAC, Verifiability, VerificationStrategy, VerificationTier, ObservabilityGapResult, ObservabilityGapEntry } from './types.js';\n9\timport { LEGACY_TIER_MAP, TIER_HIERARCHY } from './types.js';\n10\timport {\n11\t  UI_KEYWORDS, API_KEYWORDS, DB_KEYWORDS,\n12\t  INTEGRATION_KEYWORDS, ESCALATE_KEYWORDS,\n13\t  TEST_PROVABLE_KEYWORDS, RUNTIME_PROVABLE_KEYWORDS,\n14\t  ENVIRONMENT_PROVABLE_KEYWORDS, ESCALATE_TIER_KEYWORDS,\n15\t} from './parser-keywords.js';\n16\t\n17\t// Re-export for backward compat (INTEGRATION_KEYWORDS was previously exported from parser.ts)\n18\texport { INTEGRATION_KEYWORDS } from './parser-keywords.js';\n19\t\n20\t// ─── Verifiability Classification ───────────────────────────────────────────\n21\t\n22\t/**\n23\t * Classifies whether an AC can be verified in a CLI subprocess or requires\n24\t * integration testing. Checks description against integration keywords\n25\t * (case-insensitive). Falls back to 'cli-verifiable'.\n26\t *\n27\t * @deprecated Use `classifyTier()` instead. Will be removed in a future release.\n28\t */\n29\texport function classifyVerifiability(description: string): Verifiability {\n30\t  const lower = description.toLowerCase();\n31\t\n32\t  for (const kw of INTEGRATION_KEYWORDS) {\n33\t    if (lower.includes(kw)) return 'integration-required';\n34\t  }\n35\t\n36\t  return 'cli-verifiable';\n37\t}\n38\t\n39\t// ─── Verification Strategy ─────────────────────────────────────────────────\n40\t\n41\t/**\n42\t * Determines the best verification strategy for an AC.\n43\t *\n44\t * Docker is the DEFAULT — it's the safest approach because it runs in an\n45\t * isolated container that can't corrupt the host environment.\n46\t *\n47\t * cli-direct is the fallback when Docker is unavailable (checked at runtime).\n48\t * escalate is the last resort for things that truly can't be automated.\n49\t *\n50\t * @deprecated Use `classifyTier()` instead. Will be removed in a future release.\n51\t */\n52\texport function classifyStrategy(description: string): VerificationStrategy {\n53\t  const lower = description.toLowerCase();\n54\t\n55\t  // Check for true escalation first (very rare)\n56\t  for (const kw of ESCALATE_KEYWORDS) {\n57\t    if (lower.includes(kw)) return 'escalate';\n58\t  }\n59\t\n60\t  // Default: Docker for everything\n61\t  return 'docker';\n62\t}\n63\t\n64\t// ─── Tier Classification ─────────────────────────────────────────────────────\n65\t\n66\t/**\n67\t * Classifies an AC description into a VerificationTier based on keyword matching.\n68\t * Priority: escalate > environment-provable > runtime-provable > test-provable (default).\n69\t */\n70\texport function classifyTier(description: string): VerificationTier {\n71\t  const lower = description.toLowerCase();\n72\t  // Check highest priority first\n73\t  for (const kw of ESCALATE_TIER_KEYWORDS) {\n74\t    if (lower.includes(kw)) return 'escalate';\n75\t  }\n76\t  for (const kw of ENVIRONMENT_PROVABLE_KEYWORDS) {\n77\t    if (lower.includes(kw)) return 'environment-provable';\n78\t  }\n79\t  for (const kw of RUNTIME_PROVABLE_KEYWORDS) {\n80\t    if (lower.includes(kw)) return 'runtime-provable';\n81\t  }\n82\t  // Default: test-provable\n83\t  return 'test-provable';\n84\t}\n85\t\n86\t// ─── Verification Tag Parsing ───────────────────────────────────────────────\n87\t\n88\tconst VERIFICATION_TAG_PATTERN = /<!--\\s*verification:\\s*(cli-verifiable|integration-required|unit-testable|black-box|test-provable|runtime-provable|environment-provable|escalate)\\s*-->/;\n89\t\n90\t/**\n91\t * Parses a `<!-- verification: ... -->` HTML comment tag from a string.\n92\t * Accepts both legacy values (cli-verifiable, integration-required) and\n93\t * new VerificationTier values (test-provable, runtime-provable, etc.).\n94\t * Legacy values are mapped to VerificationTier via LEGACY_TIER_MAP.\n95\t * Returns a VerificationTier if found, or null.\n96\t */\n97\texport function parseVerificationTag(text: string): VerificationTier | null {\n98\t  const match = VERIFICATION_TAG_PATTERN.exec(text);\n99\t  if (!match) return null;\n100\t  const raw = match[1];\n101\t  // Map legacy values to new tiers; validate result is a known tier\n102\t  const mapped = LEGACY_TIER_MAP[raw] ?? raw;\n103\t  if (!TIER_HIERARCHY.includes(mapped as VerificationTier)) return null;\n104\t  return mapped as VerificationTier;\n105\t}\n106\t\n107\t// ─── Classification ─────────────────────────────────────────────────────────\n108\t\n109\t/**\n110\t * Classifies an AC description by keywords.\n111\t * Checks UI, API, DB keywords (case-insensitive). Falls back to 'general'.\n112\t */\n113\texport function classifyAC(description: string): 'ui' | 'api' | 'db' | 'general' {\n114\t  const lower = description.toLowerCase();\n115\t\n116\t  for (const kw of UI_KEYWORDS) {\n117\t    if (lower.includes(kw)) return 'ui';\n118\t  }\n119\t  for (const kw of API_KEYWORDS) {\n120\t    if (lower.includes(kw)) return 'api';\n121\t  }\n122\t  for (const kw of DB_KEYWORDS) {\n123\t    if (lower.includes(kw)) return 'db';\n124\t  }\n125\t\n126\t  return 'general';\n127\t}\n128\t\n129\t// ─── Parser ─────────────────────────────────────────────────────────────────\n130\t\n131\t/**\n132\t * Reads a story markdown file and extracts numbered acceptance criteria.\n133\t * Finds the `## Acceptance Criteria` section, then parses numbered items.\n134\t *\n135\t * @throws Error if file not found (with actionable message)\n136\t * @returns ParsedAC[] — empty array if no AC section found (with warning)\n137\t */\n138\texport function parseStoryACs(storyFilePath: string): ParsedAC[] {\n139\t  if (!existsSync(storyFilePath)) {\n140\t    throw new Error(\n141\t      `Story file not found: ${storyFilePath}. Ensure the story file exists at the expected path.`,\n142\t    );\n143\t  }\n144\t\n145\t  const content = readFileSync(storyFilePath, 'utf-8');\n146\t  const lines = content.split('\\n');\n147\t\n148\t  // Find the AC section\n149\t  let acSectionStart = -1;\n150\t  for (let i = 0; i < lines.length; i++) {\n151\t    if (/^##\\s+Acceptance\\s+Criteria/i.test(lines[i])) {\n152\t      acSectionStart = i + 1;\n153\t      break;\n154\t    }\n155\t  }\n156\t\n157\t  if (acSectionStart === -1) {\n158\t    warn('No \"## Acceptance Criteria\" section found in story file');\n159\t    return [];\n160\t  }\n161\t\n162\t  // Find section end (next ## heading or end of file)\n163\t  let acSectionEnd = lines.length;\n164\t  for (let i = acSectionStart; i < lines.length; i++) {\n165\t    if (/^##\\s+/.test(lines[i]) && i !== acSectionStart - 1) {\n166\t      acSectionEnd = i;\n167\t      break;\n168\t    }\n169\t  }\n170\t\n171\t  const acSection = lines.slice(acSectionStart, acSectionEnd).join('\\n');\n172\t\n173\t  // Parse numbered ACs\n174\t  const acPattern = /^\\s*(\\d+)\\.\\s+/;\n175\t  const acs: ParsedAC[] = [];\n176\t  const acLines = acSection.split('\\n');\n177\t\n178\t  let currentId: string | null = null;\n179\t  let currentDesc: string[] = [];\n180\t\n181\t  const flushCurrent = (): void => {\n182\t    if (currentId !== null && currentDesc.length > 0) {\n183\t      const description = currentDesc.join(' ').trim();\n184\t      if (description) {\n185\t        const tag = parseVerificationTag(description);\n186\t        const tier: VerificationTier = tag ?? classifyTier(description);\n187\t        const verifiability = classifyVerifiability(description); // deprecated, kept for compat\n188\t        const strategy = classifyStrategy(description); // deprecated, kept for compat\n189\t        acs.push({\n190\t          id: currentId,\n191\t          description,\n192\t          type: classifyAC(description),\n193\t          verifiability,\n194\t          strategy,\n195\t          tier,\n196\t        });\n197\t      } else {\n198\t        warn(`Skipping malformed AC #${currentId}: empty description`);\n199\t      }\n200\t    }\n201\t  };\n202\t\n203\t  for (const line of acLines) {\n204\t    const match = acPattern.exec(line);\n205\t    if (match) {\n206\t      flushCurrent();\n207\t      currentId = match[1];\n208\t      currentDesc = [line.replace(acPattern, '').trim()];\n209\t    } else if (currentId !== null && line.trim()) {\n210\t      currentDesc.push(line.trim());\n211\t    }\n212\t  }\n213\t\n214\t  // Flush last AC\n215\t  flushCurrent();\n216\t\n217\t  return acs;\n218\t}\n219\t\n220\t// ─── Observability Gap Parser ────────────────────────────────────────────\n221\t\n222\tconst AC_HEADING_PATTERN = /^##\\s+AC\\s+(\\d+)/i;\n223\tconst OBSERVABILITY_GAP_TAG = '[OBSERVABILITY GAP]';\n224\t\n225\t/**\n226\t * Parses proof content for `[OBSERVABILITY GAP]` tags.\n227\t * Scans each AC section (delimited by `## AC N:` headings) for the gap tag.\n228\t *\n229\t * @param proofContent - Raw markdown content of the proof document\n230\t * @returns Per-AC gap presence and aggregate counts\n231\t */\n232\texport function parseObservabilityGaps(proofContent: string): ObservabilityGapResult {\n233\t  const lines = proofContent.split('\\n');\n234\t  const entries: ObservabilityGapEntry[] = [];\n235\t\n236\t  let currentAcId: string | null = null;\n237\t  let currentSectionLines: string[] = [];\n238\t\n239\t  const flushSection = (): void => {\n240\t    if (currentAcId !== null) {\n241\t      const sectionText = currentSectionLines.join('\\n');\n242\t      const hasGap = sectionText.includes(OBSERVABILITY_GAP_TAG);\n243\t      const gapNote = hasGap\n244\t        ? 'No log events detected for this user interaction'\n245\t        : undefined;\n246\t      entries.push({ acId: currentAcId, hasGap, gapNote });\n247\t    }\n248\t  };\n249\t\n250\t  for (const line of lines) {\n251\t    const match = AC_HEADING_PATTERN.exec(line);\n252\t    if (match) {\n253\t      flushSection();\n254\t      currentAcId = match[1];\n255\t      currentSectionLines = [line];\n256\t    } else if (currentAcId !== null) {\n257\t      currentSectionLines.push(line);\n258\t    }\n259\t  }\n260\t\n261\t  // Flush last section\n262\t  flushSection();\n263\t\n264\t  const totalACs = entries.length;\n265\t  const gapCount = entries.filter(e => e.hasGap).length;\n266\t  const coveredCount = totalACs - gapCount;\n267\t\n268\t  return { entries, totalACs, gapCount, coveredCount };\n269\t}\n270\t"}]},"parent_tool_use_id":null,"session_id":"b101ea9e-2f9e-4377-9c5a-f109fa318b32","uuid":"21210f55-3b88-401f-9ff8-37d6ef7b8626","timestamp":"2026-04-03T09:55:13.500Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ivintik/dev/personal/codeharness/src/modules/verify/parser.ts","content":"/**\n * Story file acceptance criteria parser.\n * Reads story markdown files and extracts numbered ACs with type classification.\n */\n\nimport { existsSync, readFileSync } from 'node:fs';\nimport { warn } from '../../lib/output.js';\nimport type { ParsedAC, Verifiability, VerificationStrategy, VerificationTier, ObservabilityGapResult, ObservabilityGapEntry } from './types.js';\nimport { LEGACY_TIER_MAP, TIER_HIERARCHY } from './types.js';\nimport {\n  UI_KEYWORDS, API_KEYWORDS, DB_KEYWORDS,\n  INTEGRATION_KEYWORDS, ESCALATE_KEYWORDS,\n  TEST_PROVABLE_KEYWORDS, RUNTIME_PROVABLE_KEYWORDS,\n  ENVIRONMENT_PROVABLE_KEYWORDS, ESCALATE_TIER_KEYWORDS,\n} from './parser-keywords.js';\n\n// Re-export for backward compat (INTEGRATION_KEYWORDS was previously exported from parser.ts)\nexport { INTEGRATION_KEYWORDS } from './parser-keywords.js';\n\n// ─── Verifiability Classification ───────────────────────────────────────────\n\n/**\n * Classifies whether an AC can be verified in a CLI subprocess or requires\n * integration testing. Checks description against integration keywords\n * (case-insensitive). Falls back to 'cli-verifiable'.\n *\n * @deprecated Use `classifyTier()` instead. Will be removed in a future release.\n */\nexport function classifyVerifiability(description: string): Verifiability {\n  const lower = description.toLowerCase();\n\n  for (const kw of INTEGRATION_KEYWORDS) {\n    if (lower.includes(kw)) return 'integration-required';\n  }\n\n  return 'cli-verifiable';\n}\n\n// ─── Verification Strategy ─────────────────────────────────────────────────\n\n/**\n * Determines the best verification strategy for an AC.\n *\n * Docker is the DEFAULT — it's the safest approach because it runs in an\n * isolated container that can't corrupt the host environment.\n *\n * cli-direct is the fallback when Docker is unavailable (checked at runtime).\n * escalate is the last resort for things that truly can't be automated.\n *\n * @deprecated Use `classifyTier()` instead. Will be removed in a future release.\n */\nexport function classifyStrategy(description: string): VerificationStrategy {\n  const lower = description.toLowerCase();\n\n  // Check for true escalation first (very rare)\n  for (const kw of ESCALATE_KEYWORDS) {\n    if (lower.includes(kw)) return 'escalate';\n  }\n\n  // Default: Docker for everything\n  return 'docker';\n}\n\n// ─── Tier Classification ─────────────────────────────────────────────────────\n\n/**\n * Classifies an AC description into a VerificationTier based on keyword matching.\n * Priority: escalate > environment-provable > runtime-provable > test-provable (default).\n */\nexport function classifyTier(description: string): VerificationTier {\n  const lower = description.toLowerCase();\n  // Check highest priority first\n  for (const kw of ESCALATE_TIER_KEYWORDS) {\n    if (lower.includes(kw)) return 'escalate';\n  }\n  for (const kw of ENVIRONMENT_PROVABLE_KEYWORDS) {\n    if (lower.includes(kw)) return 'environment-provable';\n  }\n  for (const kw of RUNTIME_PROVABLE_KEYWORDS) {\n    if (lower.includes(kw)) return 'runtime-provable';\n  }\n  // Default: test-provable\n  return 'test-provable';\n}\n\n// ─── Verification Tag Parsing ───────────────────────────────────────────────\n\nconst VERIFICATION_TAG_PATTERN = /<!--\\s*verification:\\s*(cli-verifiable|integration-required|unit-testable|black-box|test-provable|runtime-provable|environment-provable|escalate)\\s*-->/;\n\n/**\n * Parses a `<!-- verification: ... -->` HTML comment tag from a string.\n * Accepts both legacy values (cli-verifiable, integration-required) and\n * new VerificationTier values (test-provable, runtime-provable, etc.).\n * Legacy values are mapped to VerificationTier via LEGACY_TIER_MAP.\n * Returns a VerificationTier if found, or null.\n */\nexport function parseVerificationTag(text: string): VerificationTier | null {\n  const match = VERIFICATION_TAG_PATTERN.exec(text);\n  if (!match) return null;\n  const raw = match[1];\n  // Map legacy values to new tiers; validate result is a known tier\n  const mapped = LEGACY_TIER_MAP[raw] ?? raw;\n  if (!TIER_HIERARCHY.includes(mapped as VerificationTier)) return null;\n  return mapped as VerificationTier;\n}\n\n// ─── Classification ─────────────────────────────────────────────────────────\n\n/**\n * Classifies an AC description by keywords.\n * Checks UI, API, DB keywords (case-insensitive). Falls back to 'general'.\n */\nexport function classifyAC(description: string): 'ui' | 'api' | 'db' | 'general' {\n  const lower = description.toLowerCase();\n\n  for (const kw of UI_KEYWORDS) {\n    if (lower.includes(kw)) return 'ui';\n  }\n  for (const kw of API_KEYWORDS) {\n    if (lower.includes(kw)) return 'api';\n  }\n  for (const kw of DB_KEYWORDS) {\n    if (lower.includes(kw)) return 'db';\n  }\n\n  return 'general';\n}\n\n// ─── Parser ─────────────────────────────────────────────────────────────────\n\n/**\n * Reads a story markdown file and extracts numbered acceptance criteria.\n * Finds the `## Acceptance Criteria` section, then parses numbered items.\n *\n * @throws Error if file not found (with actionable message)\n * @returns ParsedAC[] — empty array if no AC section found (with warning)\n */\nexport function parseStoryACs(storyFilePath: string): ParsedAC[] {\n  if (!existsSync(storyFilePath)) {\n    throw new Error(\n      `Story file not found: ${storyFilePath}. Ensure the story file exists at the expected path.`,\n    );\n  }\n\n  const content = readFileSync(storyFilePath, 'utf-8');\n  const lines = content.split('\\n');\n\n  // Find the AC section\n  let acSectionStart = -1;\n  for (let i = 0; i < lines.length; i++) {\n    if (/^##\\s+Acceptance\\s+Criteria/i.test(lines[i])) {\n      acSectionStart = i + 1;\n      break;\n    }\n  }\n\n  if (acSectionStart === -1) {\n    warn('No \"## Acceptance Criteria\" section found in story file');\n    return [];\n  }\n\n  // Find section end (next ## heading or end of file)\n  let acSectionEnd = lines.length;\n  for (let i = acSectionStart; i < lines.length; i++) {\n    if (/^##\\s+/.test(lines[i]) && i !== acSectionStart - 1) {\n      acSectionEnd = i;\n      break;\n    }\n  }\n\n  const acSection = lines.slice(acSectionStart, acSectionEnd).join('\\n');\n\n  // Parse numbered ACs\n  const acPattern = /^\\s*(\\d+)\\.\\s+/;\n  const acs: ParsedAC[] = [];\n  const acLines = acSection.split('\\n');\n\n  let currentId: string | null = null;\n  let currentDesc: string[] = [];\n\n  const flushCurrent = (): void => {\n    if (currentId !== null && currentDesc.length > 0) {\n      const description = currentDesc.join(' ').trim();\n      if (description) {\n        const tag = parseVerificationTag(description);\n        const tier: VerificationTier = tag ?? classifyTier(description);\n        const verifiability = classifyVerifiability(description); // deprecated, kept for compat\n        const strategy = classifyStrategy(description); // deprecated, kept for compat\n        acs.push({\n          id: currentId,\n          description,\n          type: classifyAC(description),\n          verifiability,\n          strategy,\n          tier,\n        });\n      } else {\n        warn(`Skipping malformed AC #${currentId}: empty description`);\n      }\n    }\n  };\n\n  for (const line of acLines) {\n    const match = acPattern.exec(line);\n    if (match) {\n      flushCurrent();\n      currentId = match[1];\n      currentDesc = [line.replace(acPattern, '').trim()];\n    } else if (currentId !== null && line.trim()) {\n      currentDesc.push(line.trim());\n    }\n  }\n\n  // Flush last AC\n  flushCurrent();\n\n  return acs;\n}\n\n// ─── Observability Gap Parser ────────────────────────────────────────────\n\nconst AC_HEADING_PATTERN = /^##\\s+AC\\s+(\\d+)/i;\nconst OBSERVABILITY_GAP_TAG = '[OBSERVABILITY GAP]';\n\n/**\n * Parses proof content for `[OBSERVABILITY GAP]` tags.\n * Scans each AC section (delimited by `## AC N:` headings) for the gap tag.\n *\n * @param proofContent - Raw markdown content of the proof document\n * @returns Per-AC gap presence and aggregate counts\n */\nexport function parseObservabilityGaps(proofContent: string): ObservabilityGapResult {\n  const lines = proofContent.split('\\n');\n  const entries: ObservabilityGapEntry[] = [];\n\n  let currentAcId: string | null = null;\n  let currentSectionLines: string[] = [];\n\n  const flushSection = (): void => {\n    if (currentAcId !== null) {\n      const sectionText = currentSectionLines.join('\\n');\n      const hasGap = sectionText.includes(OBSERVABILITY_GAP_TAG);\n      const gapNote = hasGap\n        ? 'No log events detected for this user interaction'\n        : undefined;\n      entries.push({ acId: currentAcId, hasGap, gapNote });\n    }\n  };\n\n  for (const line of lines) {\n    const match = AC_HEADING_PATTERN.exec(line);\n    if (match) {\n      flushSection();\n      currentAcId = match[1];\n      currentSectionLines = [line];\n    } else if (currentAcId !== null) {\n      currentSectionLines.push(line);\n    }\n  }\n\n  // Flush last section\n  flushSection();\n\n  const totalACs = entries.length;\n  const gapCount = entries.filter(e => e.hasGap).length;\n  const coveredCount = totalACs - gapCount;\n\n  return { entries, totalACs, gapCount, coveredCount };\n}\n","numLines":270,"startLine":1,"totalLines":270}}}
