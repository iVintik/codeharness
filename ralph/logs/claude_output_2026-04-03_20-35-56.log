{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VYZcDXeABkrSqXRmR45727","type":"tool_result","content":"1\timport type { ResolvedTask, FlowStep, LoopBlock } from './workflow-parser.js';\n2\t\n3\t// --- Interfaces ---\n4\t\n5\texport interface ExecutionConfig {\n6\t  max_parallel: number;\n7\t  isolation: 'worktree' | 'none';\n8\t  merge_strategy: 'rebase' | 'merge-commit';\n9\t  epic_strategy: 'parallel' | 'sequential';\n10\t  story_strategy: 'sequential' | 'parallel';\n11\t}\n12\t\n13\texport interface HierarchicalFlow {\n14\t  execution: ExecutionConfig;\n15\t  storyFlow: FlowStep[];\n16\t  epicFlow: FlowStep[];\n17\t  tasks: Record<string, ResolvedTask>;\n18\t}\n19\t\n20\t// --- Constants ---\n21\t\n22\t/** Built-in epic flow task names that do not need entries in `tasks:`. */\n23\texport const BUILTIN_EPIC_FLOW_TASKS = new Set(['merge', 'validate']);\n24\t\n25\t/** Default execution configuration values. */\n26\texport const EXECUTION_DEFAULTS: ExecutionConfig = {\n27\t  max_parallel: 1,\n28\t  isolation: 'none',\n29\t  merge_strategy: 'merge-commit',\n30\t  epic_strategy: 'sequential',\n31\t  story_strategy: 'sequential',\n32\t};\n33\t\n34\t// --- Resolution ---\n35\t\n36\t/**\n37\t * Resolve a parsed workflow YAML object into a HierarchicalFlow.\n38\t *\n39\t * Handles three cases:\n40\t * 1. Legacy: only `flow` present → normalized to `storyFlow`\n41\t * 2. Hierarchical: `story_flow` (and optionally `epic_flow`, `execution`) present\n42\t * 3. Conflict: both `flow` and `story_flow` → rejected with error\n43\t *\n44\t * This is a pure parsing/normalization function with no side effects.\n45\t */\n46\texport function resolveHierarchicalFlow(\n47\t  parsed: Record<string, unknown>,\n48\t  resolvedTasks: Record<string, ResolvedTask>,\n49\t): HierarchicalFlow {\n50\t  const hasFlow = 'flow' in parsed && parsed.flow !== undefined;\n51\t  const hasStoryFlow = 'story_flow' in parsed && parsed.story_flow !== undefined;\n52\t\n53\t  // Reject coexistence of flow and story_flow\n54\t  if (hasFlow && hasStoryFlow) {\n55\t    throw new HierarchicalFlowError(\n56\t      'Workflow cannot have both \"flow\" and \"story_flow\" — use \"story_flow\" for hierarchical workflows or \"flow\" for legacy mode',\n57\t    );\n58\t  }\n59\t\n60\t  // Resolve execution config with defaults\n61\t  const rawExecution = (parsed.execution ?? {}) as Record<string, unknown>;\n62\t  const execution: ExecutionConfig = {\n63\t    max_parallel: (rawExecution.max_parallel as number) ?? EXECUTION_DEFAULTS.max_parallel,\n64\t    isolation: (rawExecution.isolation as ExecutionConfig['isolation']) ?? EXECUTION_DEFAULTS.isolation,\n65\t    merge_strategy: (rawExecution.merge_strategy as ExecutionConfig['merge_strategy']) ?? EXECUTION_DEFAULTS.merge_strategy,\n66\t    epic_strategy: (rawExecution.epic_strategy as ExecutionConfig['epic_strategy']) ?? EXECUTION_DEFAULTS.epic_strategy,\n67\t    story_strategy: (rawExecution.story_strategy as ExecutionConfig['story_strategy']) ?? EXECUTION_DEFAULTS.story_strategy,\n68\t  };\n69\t\n70\t  // Resolve story flow\n71\t  const rawStoryFlow = (hasStoryFlow ? parsed.story_flow : parsed.flow) as unknown[] | undefined;\n72\t  const storyFlow: FlowStep[] = (rawStoryFlow ?? []).map((step) => {\n73\t    if (typeof step === 'string') return step;\n74\t    return step as LoopBlock;\n75\t  });\n76\t\n77\t  // Resolve epic flow\n78\t  const rawEpicFlow = (parsed.epic_flow ?? []) as unknown[];\n79\t  const epicFlow: FlowStep[] = rawEpicFlow.map((step) => {\n80\t    if (typeof step === 'string') return step;\n81\t    return step as LoopBlock;\n82\t  });\n83\t\n84\t  return {\n85\t    execution,\n86\t    storyFlow,\n87\t    epicFlow,\n88\t    tasks: resolvedTasks,\n89\t  };\n90\t}\n91\t\n92\t// --- Error Class ---\n93\t\n94\texport class HierarchicalFlowError extends Error {\n95\t  constructor(message: string) {\n96\t    super(message);\n97\t    this.name = 'HierarchicalFlowError';\n98\t  }\n99\t}\n100\t"}]},"parent_tool_use_id":"toolu_01EbWLuRzBfXxKEeXQE4hLnQ","session_id":"9c9fe147-c536-4d36-9f64-8249f0c68839","uuid":"ff01b6c2-1bb2-485c-ad58-9e0bd6e6ab9a","timestamp":"2026-04-03T16:50:48.915Z"}
