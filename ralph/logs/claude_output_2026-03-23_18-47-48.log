{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Fb5iNsxQ1gxJeab1oCxUMQ","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n     2→import { mkdtempSync, rmSync, existsSync, writeFileSync } from 'node:fs';\n     3→import { tmpdir } from 'node:os';\n     4→import { join } from 'node:path';\n     5→\n     6→vi.mock('../../../lib/templates.js', () => ({\n     7→  generateFile: vi.fn((_path: string, _content: string) => {\n     8→    // Simulate file creation for test assertions\n     9→    const { mkdirSync, writeFileSync } = require('node:fs');\n    10→    const { dirname } = require('node:path');\n    11→    mkdirSync(dirname(_path), { recursive: true });\n    12→    writeFileSync(_path, _content);\n    13→  }),\n    14→}));\n    15→\n    16→vi.mock('../../../templates/readme.js', () => ({\n    17→  readmeTemplate: vi.fn(() => '# Test README\\n'),\n    18→}));\n    19→\n    20→import {\n    21→  getProjectName,\n    22→  getStackLabel,\n    23→  getCoverageTool,\n    24→  generateAgentsMdContent,\n    25→  generateDocsIndexContent,\n    26→  scaffoldDocs,\n    27→} from '../docs-scaffold.js';\n    28→\n    29→let testDir: string;\n    30→\n    31→beforeEach(() => {\n    32→  testDir = mkdtempSync(join(tmpdir(), 'ch-docs-test-'));\n    33→  vi.restoreAllMocks();\n    34→  vi.spyOn(console, 'log').mockImplementation(() => {});\n    35→});\n    36→\n    37→afterEach(() => {\n    38→  rmSync(testDir, { recursive: true, force: true });\n    39→});\n    40→\n    41→\n    42→describe('getProjectName', () => {\n    43→  it('returns name from package.json', () => {\n    44→    writeFileSync(join(testDir, 'package.json'), JSON.stringify({ name: 'my-project' }));\n    45→    expect(getProjectName(testDir)).toBe('my-project');\n    46→  });\n    47→\n    48→  it('falls back to basename when no package.json', () => {\n    49→    const name = getProjectName(testDir);\n    50→    expect(typeof name).toBe('string');\n    51→    expect(name.length).toBeGreaterThan(0);\n    52→  });\n    53→\n    54→  it('falls back to basename when package.json has no name', () => {\n    55→    writeFileSync(join(testDir, 'package.json'), '{}');\n    56→    const name = getProjectName(testDir);\n    57→    expect(typeof name).toBe('string');\n    58→  });\n    59→\n    60→  it('returns name from Cargo.toml [package] section when no package.json', () => {\n    61→    writeFileSync(join(testDir, 'Cargo.toml'), '[package]\\nname = \"myapp\"\\nversion = \"0.1.0\"\\n');\n    62→    expect(getProjectName(testDir)).toBe('myapp');\n    63→  });\n    64→\n    65→  it('returns package.json name over Cargo.toml name (precedence)', () => {\n    66→    writeFileSync(join(testDir, 'package.json'), JSON.stringify({ name: 'npm-name' }));\n    67→    writeFileSync(join(testDir, 'Cargo.toml'), '[package]\\nname = \"rust-name\"\\nversion = \"0.1.0\"\\n');\n    68→    expect(getProjectName(testDir)).toBe('npm-name');\n    69→  });\n    70→\n    71→  it('falls back to basename when Cargo.toml has name only in [dependencies]', () => {\n    72→    writeFileSync(\n    73→      join(testDir, 'Cargo.toml'),\n    74→      '[dependencies]\\nname = \"dep-name\"\\nversion = \"0.1.0\"\\n',\n    75→    );\n    76→    const name = getProjectName(testDir);\n    77→    const { basename } = require('node:path');\n    78→    // Should NOT return 'dep-name' — no [package] section; should return basename\n    79→    expect(name).not.toBe('dep-name');\n    80→    expect(name).toBe(basename(testDir));\n    81→  });\n    82→\n    83→  it('falls back to basename when Cargo.toml is malformed', () => {\n    84→    writeFileSync(join(testDir, 'Cargo.toml'), 'this is not valid toml!!!');\n    85→    const name = getProjectName(testDir);\n    86→    const { basename } = require('node:path');\n    87→    expect(name).toBe(basename(testDir));\n    88→  });\n    89→\n    90→  it('falls back to basename when Cargo.toml [package] has no name field', () => {\n    91→    writeFileSync(join(testDir, 'Cargo.toml'), '[package]\\nversion = \"0.1.0\"\\nedition = \"2021\"\\n');\n    92→    const name = getProjectName(testDir);\n    93→    const { basename } = require('node:path');\n    94→    expect(name).toBe(basename(testDir));\n    95→  });\n    96→\n    97→  it('handles single-quoted name in Cargo.toml', () => {\n    98→    writeFileSync(join(testDir, 'Cargo.toml'), \"[package]\\nname = 'single-quoted'\\nversion = \\\"0.1.0\\\"\\n\");\n    99→    expect(getProjectName(testDir)).toBe('single-quoted');\n   100→  });\n   101→\n   102→  it('handles Cargo.toml with [package] name before [dependencies] section', () => {\n   103→    writeFileSync(\n   104→      join(testDir, 'Cargo.toml'),\n   105→      '[package]\\nname = \"real-name\"\\nversion = \"0.1.0\"\\n\\n[dependencies]\\nserde = \"1.0\"\\n',\n   106→    );\n   107→    expect(getProjectName(testDir)).toBe('real-name');\n   108→  });\n   109→});\n   110→\n   111→describe('getStackLabel', () => {\n   112→  it('returns Node.js label for nodejs stack', () => {\n   113→    expect(getStackLabel('nodejs')).toBe('Node.js (package.json)');\n   114→  });\n   115→\n   116→  it('returns Python label for python stack', () => {\n   117→    expect(getStackLabel('python')).toBe('Python');\n   118→  });\n   119→\n   120→  it('returns Unknown for null stack', () => {\n   121→    expect(getStackLabel(null)).toBe('Unknown');\n   122→  });\n   123→\n   124→  it('returns Rust label for rust stack', () => {\n   125→    expect(getStackLabel('rust')).toBe('Rust (Cargo.toml)');\n   126→  });\n   127→\n   128→  it('returns joined label for multi-stack array', () => {\n   129→    expect(getStackLabel(['nodejs', 'rust'])).toBe('Node.js (package.json) + Rust (Cargo.toml)');\n   130→  });\n   131→\n   132→  it('returns single label for single-element array', () => {\n   133→    expect(getStackLabel(['python'])).toBe('Python');\n   134→  });\n   135→\n   136→  it('returns Unknown for empty array', () => {\n   137→    expect(getStackLabel([])).toBe('Unknown');\n   138→  });\n   139→});\n   140→\n   141→describe('getCoverageTool', () => {\n   142→  it('returns c8 for nodejs', () => {\n   143→    expect(getCoverageTool('nodejs')).toBe('c8');\n   144→  });\n   145→\n   146→  it('returns coverage.py for python', () => {\n   147→    expect(getCoverageTool('python')).toBe('coverage.py');\n   148→  });\n   149→\n   150→  it('returns c8 for null', () => {\n   151→    expect(getCoverageTool(null)).toBe('c8');\n   152→  });\n   153→\n   154→  it('returns cargo-tarpaulin for rust', () => {\n   155→    expect(getCoverageTool('rust')).toBe('cargo-tarpaulin');\n   156→  });\n   157→});\n   158→\n   159→describe('generateAgentsMdContent', () => {\n   160→  it('includes project name', () => {\n   161→    const content = generateAgentsMdContent(testDir, 'nodejs');\n   162→    expect(content).toContain('# ');\n   163→  });\n   164→\n   165→  it('includes Node.js commands for nodejs stack', () => {\n   166→    const content = generateAgentsMdContent(testDir, 'nodejs');\n   167→    expect(content).toContain('npm install');\n   168→    expect(content).toContain('npm test');\n   169→  });\n   170→\n   171→  it('includes Python commands for python stack', () => {\n   172→    const content = generateAgentsMdContent(testDir, 'python');\n   173→    expect(content).toContain('pip install');\n   174→    expect(content).toContain('pytest');\n   175→  });\n   176→\n   177→  it('includes generic message for unknown stack', () => {\n   178→    const content = generateAgentsMdContent(testDir, null);\n   179→    expect(content).toContain('No recognized stack');\n   180→  });\n   181→\n   182→  it('includes Rust commands for rust stack', () => {\n   183→    const content = generateAgentsMdContent(testDir, 'rust');\n   184→    expect(content).toContain('cargo build');\n   185→    expect(content).toContain('cargo test');\n   186→    expect(content).toContain('cargo tarpaulin');\n   187→  });\n   188→\n   189→  it('labels Rust stack correctly', () => {\n   190→    const content = generateAgentsMdContent(testDir, 'rust');\n   191→    expect(content).toContain('Rust');\n   192→  });\n   193→});\n   194→\n   195→describe('generateDocsIndexContent', () => {\n   196→  it('includes documentation sections', () => {\n   197→    const content = generateDocsIndexContent();\n   198→    expect(content).toContain('Planning Artifacts');\n   199→    expect(content).toContain('Execution');\n   200→    expect(content).toContain('Quality');\n   201→  });\n   202→});\n   203→\n   204→describe('scaffoldDocs', () => {\n   205→  it('creates AGENTS.md when it does not exist', async () => {\n   206→    const result = await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: false });\n   207→    expect(result.success).toBe(true);\n   208→    if (result.success) {\n   209→      expect(result.data.agents_md).toBe('created');\n   210→    }\n   211→  });\n   212→\n   213→  it('reports exists when AGENTS.md already exists', async () => {\n   214→    writeFileSync(join(testDir, 'AGENTS.md'), '# existing');\n   215→    const result = await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: false });\n   216→    expect(result.success).toBe(true);\n   217→    if (result.success) {\n   218→      expect(result.data.agents_md).toBe('exists');\n   219→    }\n   220→  });\n   221→\n   222→  it('creates docs scaffold when docs/ does not exist', async () => {\n   223→    const result = await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: false });\n   224→    expect(result.success).toBe(true);\n   225→    if (result.success) {\n   226→      expect(result.data.docs_scaffold).toBe('created');\n   227→    }\n   228→  });\n   229→\n   230→  it('creates README.md when it does not exist', async () => {\n   231→    const result = await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: false });\n   232→    expect(result.success).toBe(true);\n   233→    if (result.success) {\n   234→      expect(result.data.readme).toBe('created');\n   235→    }\n   236→  });\n   237→\n   238→  it('reports exists when README.md already exists', async () => {\n   239→    writeFileSync(join(testDir, 'README.md'), '# existing');\n   240→    const result = await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: false });\n   241→    expect(result.success).toBe(true);\n   242→    if (result.success) {\n   243→      expect(result.data.readme).toBe('exists');\n   244→    }\n   245→  });\n   246→\n   247→  it('suppresses console output in json mode', async () => {\n   248→    const spy = vi.spyOn(console, 'log');\n   249→    await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: true });\n   250→    // In json mode, no [OK]/[INFO] messages should be printed\n   251→    const calls = spy.mock.calls.map(c => c[0] as string);\n   252→    const outputCalls = calls.filter(c => c && (c.startsWith('[OK]') || c.startsWith('[INFO]')));\n   253→    expect(outputCalls).toHaveLength(0);\n   254→  });\n   255→});\n   256→"}]},"parent_tool_use_id":"toolu_01RW3DvRwuMditE8CiVokyWA","session_id":"46c7b24e-5b3f-4eb1-bc5a-20f6a0336cfe","uuid":"fe741a3e-1fd2-4752-9be2-01c47a2b8830","timestamp":"2026-03-23T14:56:16.516Z"}
