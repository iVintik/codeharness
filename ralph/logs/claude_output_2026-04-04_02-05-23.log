{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SFAVkowmz96B1qULZphBj8","type":"tool_result","content":"1\t/**\n2\t * Worktree Manager.\n3\t *\n4\t * Handles git worktree lifecycle for parallel epic execution:\n5\t * create, cleanup, list, and orphan detection. Each epic gets\n6\t * its own git worktree on a dedicated branch under the\n7\t * `codeharness/` namespace.\n8\t *\n9\t * @see Story 17-1: Worktree Manager\n10\t * @see Story 18-2: Merge Agent for Conflict Resolution (onConflict callback)\n11\t */\n12\t\n13\timport { execSync } from 'node:child_process';\n14\timport { existsSync, readFileSync, statSync } from 'node:fs';\n15\timport { join } from 'node:path';\n16\t\n17\timport type { ConflictResolutionResult } from './merge-agent.js';\n18\timport { validateMerge } from './cross-worktree-validator.js';\n19\t\n20\t/**\n21\t * Partial conflict context that mergeWorktree can fill from its own state.\n22\t * The onConflict callback receives this and enriches it with driver/descriptions\n23\t * before calling the merge agent.\n24\t */\n25\texport interface MergeConflictInfo {\n26\t  readonly epicId: string;\n27\t  readonly branch: string;\n28\t  readonly conflicts: string[];\n29\t  readonly cwd: string;\n30\t  readonly testCommand: string;\n31\t}\n32\t\n33\t// --- Constants ---\n34\t\n35\t/** Branch prefix for all codeharness worktree branches. */\n36\texport const BRANCH_PREFIX = 'codeharness/epic-';\n37\t\n38\t/** Base path for worktree directories in /tmp. */\n39\texport const WORKTREE_BASE = '/tmp/codeharness-wt-epic-';\n40\t\n41\t// --- Interfaces ---\n42\t\n43\t/**\n44\t * Information about a codeharness worktree.\n45\t */\n46\texport interface WorktreeInfo {\n47\t  /** Epic identifier extracted from the branch name. */\n48\t  readonly epicId: string;\n49\t  /** Absolute path to the worktree directory. */\n50\t  readonly path: string;\n51\t  /** Full branch name (e.g., `codeharness/epic-17-worktree-manager`). */\n52\t  readonly branch: string;\n53\t  /** Timestamp when the worktree was created. */\n54\t  readonly createdAt: Date;\n55\t}\n56\t\n57\t// --- Error Class ---\n58\t\n59\t/**\n60\t * Error thrown by worktree operations. Includes stderr from git commands.\n61\t */\n62\texport class WorktreeError extends Error {\n63\t  /** Raw stderr output from the failed git command. */\n64\t  readonly stderr: string;\n65\t\n66\t  constructor(message: string, stderr: string) {\n67\t    super(message);\n68\t    this.name = 'WorktreeError';\n69\t    this.stderr = stderr;\n70\t  }\n71\t}\n72\t\n73\t// --- Merge Types ---\n74\t\n75\t/**\n76\t * Strategy used when merging an epic branch into main.\n77\t */\n78\texport type MergeStrategy = 'rebase' | 'merge-commit';\n79\t\n80\t/**\n81\t * Result of a merge operation.\n82\t */\n83\texport interface MergeResult {\n84\t  /** Whether the merge and post-merge validation succeeded. */\n85\t  success: boolean;\n86\t  /** Reason for failure, if any. */\n87\t  reason?: 'conflict' | 'tests-failed' | 'git-error';\n88\t  /** List of conflicting file paths, when reason is 'conflict'. */\n89\t  conflicts?: string[];\n90\t  /** Test suite results from post-merge validation. */\n91\t  testResults?: { passed: number; failed: number; coverage?: number };\n92\t  /** Total wall-clock duration of the merge operation in milliseconds. */\n93\t  durationMs: number;\n94\t}\n95\t\n96\t// --- Async Mutex ---\n97\t\n98\t/**\n99\t * Simple async mutex for serializing merge operations.\n100\t * No external dependencies — uses a promise-based wait queue.\n101\t */\n102\texport class AsyncMutex {\n103\t  private locked = false;\n104\t  private waitQueue: Array<() => void> = [];\n105\t\n106\t  async acquire(): Promise<() => void> {\n107\t    while (this.locked) {\n108\t      await new Promise<void>((resolve) => this.waitQueue.push(resolve));\n109\t    }\n110\t    this.locked = true;\n111\t    return () => {\n112\t      this.locked = false;\n113\t      const next = this.waitQueue.shift();\n114\t      if (next) next();\n115\t    };\n116\t  }\n117\t}\n118\t\n119\t/** Module-level singleton merge mutex shared across all WorktreeManager instances. */\n120\texport const mergeMutex = new AsyncMutex();\n121\t\n122\t/**\n123\t * Callback invoked when merge conflicts are detected.\n124\t * Receives partial conflict info (what mergeWorktree knows), returns resolution result.\n125\t * The caller enriches this with driver and descriptions before calling the merge agent.\n126\t */\n127\texport type OnConflictCallback = (info: MergeConflictInfo) => Promise<ConflictResolutionResult>;\n128\t\n129\t// --- WorktreeManager Class ---\n130\t\n131\t/**\n132\t * Manages git worktrees for parallel epic execution.\n133\t *\n134\t * Creates isolated working directories (worktrees) for each epic,\n135\t * each on its own branch under the `codeharness/` namespace.\n136\t */\n137\texport class WorktreeManager {\n138\t  private readonly mainBranch: string;\n139\t  private readonly cwd: string;\n140\t\n141\t  /**\n142\t   * @param mainBranch  The main branch to base new worktree branches on (default: `'main'`).\n143\t   * @param cwd  The git repository root directory (default: `process.cwd()`).\n144\t   */\n145\t  constructor(mainBranch: string = 'main', cwd?: string) {\n146\t    this.mainBranch = mainBranch;\n147\t    this.cwd = cwd ?? process.cwd();\n148\t  }\n149\t\n150\t  /**\n151\t   * Create a worktree for a parallel epic.\n152\t   *\n153\t   * Creates a branch `codeharness/epic-{epicId}-{slug}` from the main branch HEAD,\n154\t   * then creates a git worktree at `/tmp/codeharness-wt-epic-{epicId}`.\n155\t   *\n156\t   * If a stale branch or worktree exists from a previous crashed run,\n157\t   * it is cleaned up before re-creating (idempotent recovery).\n158\t   *\n159\t   * @param epicId  The epic identifier (numeric or string).\n160\t   * @param slug  A human-readable slug for the branch name (sanitized to `[a-z0-9-]`).\n161\t   * @returns The absolute path to the created worktree directory.\n162\t   * @throws {WorktreeError} If the git command fails.\n163\t   */\n164\t  createWorktree(epicId: string, slug: string): string {\n165\t    this.validateEpicId(epicId);\n166\t    const sanitizedSlug = this.sanitizeSlug(slug);\n167\t    const branchName = `${BRANCH_PREFIX}${epicId}-${sanitizedSlug}`;\n168\t    const worktreePath = `${WORKTREE_BASE}${epicId}`;\n169\t\n170\t    // Clean up stale state from previous crashed runs (AC #9)\n171\t    this.cleanupStale(epicId, branchName, worktreePath);\n172\t\n173\t    let branchCreated = false;\n174\t    try {\n175\t      // Create branch from main branch HEAD\n176\t      this.execGit(`git branch ${branchName} ${this.mainBranch}`);\n177\t      branchCreated = true;\n178\t\n179\t      // Create worktree\n180\t      this.execGit(`git worktree add ${worktreePath} ${branchName}`);\n181\t\n182\t      return worktreePath;\n183\t    } catch (err: unknown) {\n184\t      // Clean up partial state on failure (AC #10)\n185\t      this.cleanupPartial(branchCreated, branchName, worktreePath);\n186\t\n187\t      // execGit always wraps errors as WorktreeError; re-throw directly\n188\t      if (err instanceof WorktreeError) {\n189\t        throw err;\n190\t      }\n191\t\n192\t      // Defensive: handle unexpected non-WorktreeError (should not happen)\n193\t      const message = err instanceof Error ? err.message : String(err);\n194\t      throw new WorktreeError(\n195\t        `Failed to create worktree for epic ${epicId}: ${message}`,\n196\t        '',\n197\t      );\n198\t    }\n199\t  }\n200\t\n201\t  /**\n202\t   * Remove a worktree and its branch for an epic.\n203\t   *\n204\t   * Idempotent: completes without error if the worktree or branch\n205\t   * does not exist (AC #5).\n206\t   *\n207\t   * @param epicId  The epic identifier.\n208\t   */\n209\t  cleanupWorktree(epicId: string): void {\n210\t    this.validateEpicId(epicId);\n211\t    const worktreePath = `${WORKTREE_BASE}${epicId}`;\n212\t\n213\t    // Remove worktree (ignore errors if it doesn't exist)\n214\t    try {\n215\t      this.execGit(`git worktree remove ${worktreePath} --force`);\n216\t    } catch { // IGNORE: idempotent cleanup — worktree may not exist per AC #5\n217\t    }\n218\t\n219\t    // Find and delete the branch matching this epicId\n220\t    const branch = this.findBranchForEpic(epicId);\n221\t    if (branch) {\n222\t      try {\n223\t        this.execGit(`git branch -D ${branch}`);\n224\t      } catch { // IGNORE: idempotent cleanup — branch may not exist per AC #5\n225\t      }\n226\t    }\n227\t  }\n228\t\n229\t  /**\n230\t   * List all codeharness worktrees.\n231\t   *\n232\t   * @returns An array of `WorktreeInfo` objects sorted by epicId.\n233\t   *          Returns an empty array when no codeharness worktrees exist.\n234\t   */\n235\t  listWorktrees(): WorktreeInfo[] {\n236\t    let output: string;\n237\t    try {\n238\t      output = this.execGit('git worktree list --porcelain');\n239\t    } catch { // IGNORE: non-git-repo or corrupt state returns empty list safely\n240\t      return [];\n241\t    }\n242\t\n243\t    const entries = this.parsePorcelainOutput(output);\n244\t    return entries\n245\t      .filter((e) => e.branch.startsWith(`refs/heads/${BRANCH_PREFIX}`))\n246\t      .map((e) => {\n247\t        const branchName = e.branch.replace('refs/heads/', '');\n248\t        const epicId = this.extractEpicId(branchName);\n249\t        return {\n250\t          epicId,\n251\t          path: e.path,\n252\t          branch: branchName,\n253\t          createdAt: this.getWorktreeCreatedAt(e.path),\n254\t        };\n255\t      })\n256\t      .sort((a, b) => a.epicId.localeCompare(b.epicId, undefined, { numeric: true }));\n257\t  }\n258\t\n259\t  /**\n260\t   * Detect orphaned worktrees from previous crashed runs.\n261\t   *\n262\t   * A worktree is considered orphaned if its directory exists on disk\n263\t   * but has no `.codeharness/lane-state.json` file or the file has\n264\t   * no active PID.\n265\t   *\n266\t   * @returns An array of orphaned `WorktreeInfo` entries.\n267\t   */\n268\t  detectOrphans(): WorktreeInfo[] {\n269\t    const worktrees = this.listWorktrees();\n270\t    return worktrees.filter((wt) => this.isOrphaned(wt));\n271\t  }\n272\t\n273\t  /**\n274\t   * Merge an epic branch into the main branch with serialized access.\n275\t   *\n276\t   * Acquires a module-level mutex so only one merge runs at a time.\n277\t   * After a clean merge, runs the test suite. If tests fail, the merge\n278\t   * is reverted. On conflict or git error, the main branch is restored.\n279\t   *\n280\t   * @param epicId  The epic identifier whose branch should be merged.\n281\t   * @param strategy  Merge strategy: `'merge-commit'` (default) or `'rebase'`.\n282\t   * @param testCommand  Command to run for post-merge validation (default: `'npm test'`).\n283\t   * @returns A `MergeResult` describing the outcome.\n284\t   */\n285\t  async mergeWorktree(\n286\t    epicId: string,\n287\t    strategy: MergeStrategy = 'merge-commit',\n288\t    testCommand: string = 'npm test',\n289\t    onConflict?: OnConflictCallback,\n290\t  ): Promise<MergeResult> {\n291\t    const start = Date.now();\n292\t\n293\t    // Validate testCommand to prevent shell injection — only allow safe characters\n294\t    if (!/^[a-zA-Z0-9_./ -]+$/.test(testCommand)) {\n295\t      return {\n296\t        success: false,\n297\t        reason: 'git-error',\n298\t        durationMs: Date.now() - start,\n299\t      };\n300\t    }\n301\t\n302\t    // Find branch for this epicId\n303\t    const branch = this.findBranchForEpic(epicId);\n304\t    if (!branch) {\n305\t      return {\n306\t        success: false,\n307\t        reason: 'git-error',\n308\t        durationMs: Date.now() - start,\n309\t      };\n310\t    }\n311\t\n312\t    // Validate branch name to prevent command injection via malicious branch names\n313\t    if (!/^[a-zA-Z0-9_./-]+$/.test(branch)) {\n314\t      return {\n315\t        success: false,\n316\t        reason: 'git-error',\n317\t        durationMs: Date.now() - start,\n318\t      };\n319\t    }\n320\t\n321\t    const release = await mergeMutex.acquire();\n322\t    try {\n323\t      // Re-verify branch still exists after acquiring mutex (could be deleted while waiting)\n324\t      const branchCheck = this.findBranchForEpic(epicId);\n325\t      if (!branchCheck || branchCheck !== branch) {\n326\t        return {\n327\t          success: false,\n328\t          reason: 'git-error',\n329\t          durationMs: Date.now() - start,\n330\t        };\n331\t      }\n332\t\n333\t      // Verify main branch is clean before merge\n334\t      const status = this.execGit('git status --porcelain');\n335\t      if (status.length > 0) {\n336\t        return {\n337\t          success: false,\n338\t          reason: 'git-error',\n339\t          durationMs: Date.now() - start,\n340\t        };\n341\t      }\n342\t\n343\t      // Attempt merge or rebase\n344\t      try {\n345\t        if (strategy === 'rebase') {\n346\t          this.execGit(`git rebase ${branch}`);\n347\t        } else {\n348\t          this.execGit(`git merge --no-ff ${branch}`);\n349\t        }\n350\t      } catch { // IGNORE: merge/rebase failure is expected — detect conflict vs git-error below\n351\t        const conflicts = this.detectConflicts();\n352\t        if (conflicts.length > 0) {\n353\t          // If onConflict callback is provided, invoke the merge agent\n354\t          if (onConflict) {\n355\t            const result = await onConflict({\n356\t              epicId,\n357\t              branch,\n358\t              conflicts,\n359\t              cwd: this.cwd,\n360\t              testCommand,\n361\t            });\n362\t            if (result.resolved) {\n363\t              // Agent resolved and committed — cleanup worktree\n364\t              this.cleanupWorktree(epicId);\n365\t              return {\n366\t                success: true,\n367\t                testResults: result.testResults,\n368\t                durationMs: Date.now() - start,\n369\t              };\n370\t            }\n371\t            // Escalated — abort merge, preserve worktree\n372\t            this.abortMerge(strategy);\n373\t            return {\n374\t              success: false,\n375\t              reason: 'conflict',\n376\t              conflicts,\n377\t              durationMs: Date.now() - start,\n378\t            };\n379\t          }\n380\t          // No callback — existing behavior\n381\t          this.abortMerge(strategy);\n382\t          return {\n383\t            success: false,\n384\t            reason: 'conflict',\n385\t            conflicts,\n386\t            durationMs: Date.now() - start,\n387\t          };\n388\t        }\n389\t        // Not a conflict — unexpected git error\n390\t        this.abortMerge(strategy);\n391\t        return {\n392\t          success: false,\n393\t          reason: 'git-error',\n394\t          durationMs: Date.now() - start,\n395\t        };\n396\t      }\n397\t\n398\t      // Run test suite after successful merge via cross-worktree validator\n399\t      const validation = await validateMerge({\n400\t        testCommand,\n401\t        cwd: this.cwd,\n402\t        epicId,\n403\t        writeTelemetry: true,\n404\t      });\n405\t      if (!validation.valid) {\n406\t        // Revert merge on test failure\n407\t        try {\n408\t          this.execGit('git reset --hard HEAD~1');\n409\t        } catch { // IGNORE: reset failure indicates corrupted git state; still return tests-failed\n410\t        }\n411\t        return {\n412\t          success: false,\n413\t          reason: 'tests-failed',\n414\t          testResults: validation.testResults,\n415\t          durationMs: Date.now() - start,\n416\t        };\n417\t      }\n418\t\n419\t      // Success — cleanup worktree\n420\t      this.cleanupWorktree(epicId);\n421\t      return {\n422\t        success: true,\n423\t        testResults: validation.testResults,\n424\t        durationMs: Date.now() - start,\n425\t      };\n426\t    } finally {\n427\t      release();\n428\t    }\n429\t  }\n430\t\n431\t  // --- Private Helpers ---\n432\t\n433\t  /**\n434\t   * Get the creation time of a worktree directory.\n435\t   * Falls back to current time if the directory doesn't exist or stat fails.\n436\t   */\n437\t  private getWorktreeCreatedAt(worktreePath: string): Date {\n438\t    try {\n439\t      const stats = statSync(worktreePath);\n440\t      return stats.birthtime;\n441\t    } catch { // IGNORE: stat failure — worktree dir may not be accessible; fall back to now\n442\t      return new Date();\n443\t    }\n444\t  }\n445\t\n446\t  /**\n447\t   * Validate epicId contains only safe characters `[a-zA-Z0-9-]`.\n448\t   * Prevents command injection via crafted epicId values.\n449\t   */\n450\t  private validateEpicId(epicId: string): void {\n451\t    if (!epicId || !/^[a-zA-Z0-9-]+$/.test(epicId)) {\n452\t      throw new WorktreeError(\n453\t        `Invalid epicId: \"${epicId}\" — must be non-empty and contain only [a-zA-Z0-9-]`,\n454\t        '',\n455\t      );\n456\t    }\n457\t  }\n458\t\n459\t  /**\n460\t   * Sanitize a slug to contain only `[a-z0-9-]`.\n461\t   */\n462\t  private sanitizeSlug(slug: string): string {\n463\t    return slug\n464\t      .toLowerCase()\n465\t      .replace(/[^a-z0-9-]/g, '-')\n466\t      .replace(/-+/g, '-')\n467\t      .replace(/^-|-$/g, '');\n468\t  }\n469\t\n470\t  /**\n471\t   * Execute a git command and return its stdout.\n472\t   * Wraps errors in WorktreeError with captured stderr.\n473\t   */\n474\t  private execGit(cmd: string): string {\n475\t    try {\n476\t      const result = execSync(cmd, {\n477\t        cwd: this.cwd,\n478\t        stdio: ['pipe', 'pipe', 'pipe'],\n479\t        timeout: 30_000,\n480\t      });\n481\t      return result.toString().trim();\n482\t    } catch (err: unknown) {\n483\t      const stderr = (err as { stderr?: Buffer })?.stderr?.toString() ?? '';\n484\t      throw new WorktreeError(`Git command failed: ${cmd} — ${stderr}`, stderr);\n485\t    }\n486\t  }\n487\t\n488\t  /**\n489\t   * Clean up stale branch and worktree from a previous crash (AC #9).\n490\t   */\n491\t  private cleanupStale(epicId: string, branchName: string, worktreePath: string): void {\n492\t    // Check if worktree path exists on disk\n493\t    if (existsSync(worktreePath)) {\n494\t      try {\n495\t        this.execGit(`git worktree remove ${worktreePath} --force`);\n496\t      } catch { // IGNORE: stale worktree removal is best-effort before re-create per AC #9\n497\t        try {\n498\t          this.execGit('git worktree prune');\n499\t        } catch { // IGNORE: prune is best-effort fallback for stale worktree cleanup\n500\t        }\n501\t      }\n502\t    }\n503\t\n504\t    // Check if branch already exists\n505\t    const existingBranch = this.findBranchForEpic(epicId);\n506\t    if (existingBranch) {\n507\t      try {\n508\t        this.execGit(`git branch -D ${existingBranch}`);\n509\t      } catch { // IGNORE: stale branch deletion is best-effort before re-create per AC #9\n510\t      }\n511\t    }\n512\t  }\n513\t\n514\t  /**\n515\t   * Clean up partial state after a failed createWorktree (AC #10).\n516\t   */\n517\t  private cleanupPartial(branchCreated: boolean, branchName: string, worktreePath: string): void {\n518\t    // Try to remove worktree if it was partially created\n519\t    try {\n520\t      this.execGit(`git worktree remove ${worktreePath} --force`);\n521\t    } catch { // IGNORE: partial worktree may not exist during failure cleanup per AC #10\n522\t    }\n523\t\n524\t    // Delete branch if it was created\n525\t    if (branchCreated) {\n526\t      try {\n527\t        this.execGit(`git branch -D ${branchName}`);\n528\t      } catch { // IGNORE: partial branch may not exist during failure cleanup per AC #10\n529\t      }\n530\t    }\n531\t  }\n532\t\n533\t  /**\n534\t   * Find a branch matching `codeharness/epic-{epicId}-*`.\n535\t   */\n536\t  private findBranchForEpic(epicId: string): string | undefined {\n537\t    try {\n538\t      const output = this.execGit(`git branch --list ${BRANCH_PREFIX}${epicId}-*`);\n539\t      const branches = output\n540\t        .split('\\n')\n541\t        .map((b) => b.trim().replace(/^\\*\\s*/, ''))\n542\t        .filter((b) => b.length > 0);\n543\t      return branches[0];\n544\t    } catch { // IGNORE: branch listing failure means no branch exists — safe to return undefined\n545\t      return undefined;\n546\t    }\n547\t  }\n548\t\n549\t  /**\n550\t   * Parse `git worktree list --porcelain` output into structured entries.\n551\t   */\n552\t  private parsePorcelainOutput(output: string): Array<{ path: string; branch: string }> {\n553\t    if (!output.trim()) return [];\n554\t\n555\t    const blocks = output.split('\\n\\n').filter((b) => b.trim());\n556\t    const entries: Array<{ path: string; branch: string }> = [];\n557\t\n558\t    for (const block of blocks) {\n559\t      const lines = block.split('\\n');\n560\t      let path = '';\n561\t      let branch = '';\n562\t\n563\t      for (const line of lines) {\n564\t        if (line.startsWith('worktree ')) {\n565\t          path = line.slice('worktree '.length);\n566\t        } else if (line.startsWith('branch ')) {\n567\t          branch = line.slice('branch '.length);\n568\t        }\n569\t      }\n570\t\n571\t      if (path && branch) {\n572\t        entries.push({ path, branch });\n573\t      }\n574\t    }\n575\t\n576\t    return entries;\n577\t  }\n578\t\n579\t  /**\n580\t   * Extract epicId from a branch name like `codeharness/epic-17-slug`.\n581\t   */\n582\t  private extractEpicId(branchName: string): string {\n583\t    const withoutPrefix = branchName.slice(BRANCH_PREFIX.length);\n584\t    const dashIndex = withoutPrefix.indexOf('-');\n585\t    if (dashIndex === -1) return withoutPrefix;\n586\t    return withoutPrefix.slice(0, dashIndex);\n587\t  }\n588\t\n589\t  /**\n590\t   * Detect conflicting files after a failed merge/rebase.\n591\t   * Uses `git diff --name-only --diff-filter=U` to find unmerged paths.\n592\t   */\n593\t  private detectConflicts(): string[] {\n594\t    try {\n595\t      const output = this.execGit('git diff --name-only --diff-filter=U');\n596\t      return output\n597\t        .split('\\n')\n598\t        .map((f) => f.trim())\n599\t        .filter((f) => f.length > 0);\n600\t    } catch { // IGNORE: diff failure means no conflict info available\n601\t      return [];\n602\t    }\n603\t  }\n604\t\n605\t  /**\n606\t   * Abort an in-progress merge or rebase to restore main branch state.\n607\t   */\n608\t  private abortMerge(strategy: MergeStrategy): void {\n609\t    try {\n610\t      if (strategy === 'rebase') {\n611\t        this.execGit('git rebase --abort');\n612\t      } else {\n613\t        this.execGit('git merge --abort');\n614\t      }\n615\t    } catch { // IGNORE: abort may fail if merge already resolved; main state is preserved\n616\t    }\n617\t  }\n618\t\n619\t  /**\n620\t   * Check if a worktree is orphaned (no active codeharness process).\n621\t   */\n622\t  private isOrphaned(wt: WorktreeInfo): boolean {\n623\t    const laneStatePath = join(wt.path, '.codeharness', 'lane-state.json');\n624\t\n625\t    if (!existsSync(laneStatePath)) {\n626\t      return true;\n627\t    }\n628\t\n629\t    try {\n630\t      const content = readFileSync(laneStatePath, 'utf-8');\n631\t      const state = JSON.parse(content) as { pid?: number };\n632\t\n633\t      if (!state.pid) {\n634\t        return true;\n635\t      }\n636\t\n637\t      // Check if the PID is still running\n638\t      try {\n639\t        process.kill(state.pid, 0);\n640\t        return false; // Process is alive — not orphaned\n641\t      } catch { // IGNORE: ESRCH means process is dead — worktree is orphaned per AC #8\n642\t        return true;\n643\t      }\n644\t    } catch { // IGNORE: unreadable/corrupt lane-state.json means orphaned per AC #8\n645\t      return true;\n646\t    }\n647\t  }\n648\t}\n649\t"}]},"parent_tool_use_id":"toolu_01KN13KxQzTPDh38EUNUPmae","session_id":"22206bba-5847-41b1-b510-883e1dd8c0da","uuid":"15fc53e6-f72d-43f0-bb1b-634571249583","timestamp":"2026-04-03T22:22:23.585Z"}
