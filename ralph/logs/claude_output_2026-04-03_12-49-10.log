{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Gm8QVZ4x4yxMg7W965xEfv","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n2\timport { EventEmitter, Readable } from 'node:stream';\n3\t\n4\t// --- Mock child_process ---\n5\t\n6\tconst mockSpawn = vi.fn();\n7\tconst mockExecFile = vi.fn();\n8\t\n9\tvi.mock('node:child_process', () => ({\n10\t  spawn: (...args: unknown[]) => mockSpawn(...args),\n11\t  execFile: (...args: unknown[]) => mockExecFile(...args),\n12\t}));\n13\t\n14\timport { CodexDriver, parseLine, classifyError } from '../drivers/codex.js';\n15\timport type { DispatchOpts } from '../types.js';\n16\timport type { StreamEvent, ResultEvent } from '../stream-parser.js';\n17\t\n18\t// --- Helpers ---\n19\t\n20\tfunction makeOpts(overrides?: Partial<DispatchOpts>): DispatchOpts {\n21\t  return {\n22\t    prompt: 'Do the thing',\n23\t    model: 'codex-mini',\n24\t    cwd: '/tmp/test',\n25\t    sourceAccess: true,\n26\t    ...overrides,\n27\t  };\n28\t}\n29\t\n30\tasync function collectEvents(iterable: AsyncIterable<StreamEvent>): Promise<StreamEvent[]> {\n31\t  const events: StreamEvent[] = [];\n32\t  for await (const event of iterable) {\n33\t    events.push(event);\n34\t  }\n35\t  return events;\n36\t}\n37\t\n38\t/**\n39\t * Create a mock child process that emits given stdout lines and exits with given code.\n40\t */\n41\tfunction createMockProcess(stdoutLines: string[], exitCode = 0, stderrData = ''): {\n42\t  proc: EventEmitter & {\n43\t    stdout: Readable;\n44\t    stderr: EventEmitter & { on: ReturnType<typeof vi.fn> };\n45\t    kill: ReturnType<typeof vi.fn>;\n46\t  };\n47\t} {\n48\t  const stdout = new Readable({ read() {} });\n49\t  const stderr = new EventEmitter();\n50\t  const proc = new EventEmitter() as EventEmitter & {\n51\t    stdout: Readable;\n52\t    stderr: EventEmitter & { on: ReturnType<typeof vi.fn> };\n53\t    kill: ReturnType<typeof vi.fn>;\n54\t  };\n55\t  proc.stdout = stdout;\n56\t  proc.stderr = stderr as EventEmitter & { on: ReturnType<typeof vi.fn> };\n57\t  proc.kill = vi.fn(() => {\n58\t    // When killed, close the process\n59\t    setTimeout(() => {\n60\t      stdout.push(null);\n61\t      proc.emit('close', 1);\n62\t    }, 5);\n63\t  });\n64\t\n65\t  // Push stderr data\n66\t  if (stderrData) {\n67\t    setTimeout(() => {\n68\t      stderr.emit('data', Buffer.from(stderrData));\n69\t    }, 1);\n70\t  }\n71\t\n72\t  // Push lines to stdout, then close\n73\t  setTimeout(() => {\n74\t    for (const line of stdoutLines) {\n75\t      stdout.push(line + '\\n');\n76\t    }\n77\t    stdout.push(null);\n78\t\n79\t    // Emit close after stdout is consumed\n80\t    setTimeout(() => {\n81\t      proc.emit('close', exitCode);\n82\t    }, 10);\n83\t  }, 1);\n84\t\n85\t  return { proc };\n86\t}\n87\t\n88\t// --- Fixtures as inline data ---\n89\t\n90\tconst SUCCESS_LINES = [\n91\t  '{\"type\":\"tool_call\",\"name\":\"file_read\",\"call_id\":\"call_001\"}',\n92\t  '{\"type\":\"tool_input\",\"call_id\":\"call_001\",\"input\":\"{\\\\\"path\\\\\":\\\\\"/src/index.ts\\\\\"}\"}',\n93\t  '{\"type\":\"tool_result\",\"call_id\":\"call_001\",\"output\":\"file contents here\"}',\n94\t  '{\"type\":\"message\",\"content\":\"I\\'ve read the file and will now make changes.\"}',\n95\t  '{\"type\":\"tool_call\",\"name\":\"file_write\",\"call_id\":\"call_002\"}',\n96\t  '{\"type\":\"tool_input\",\"call_id\":\"call_002\",\"input\":\"{\\\\\"path\\\\\":\\\\\"/src/index.ts\\\\\",\\\\\"content\\\\\":\\\\\"updated\\\\\"}\"}',\n97\t  '{\"type\":\"tool_result\",\"call_id\":\"call_002\",\"output\":\"File written successfully.\"}',\n98\t  '{\"type\":\"message\",\"content\":\"Done. I updated the file.\"}',\n99\t  '{\"type\":\"result\",\"status\":\"completed\",\"cost_usd\":0.0034,\"session_id\":\"codex-sess-abc123\"}',\n100\t];\n101\t\n102\tconst UNPARSEABLE_LINES = [\n103\t  'Loading codex v0.1.2...',\n104\t  'Connecting to OpenAI API...',\n105\t  '[spinner] Working...',\n106\t  'not json at all {{{',\n107\t];\n108\t\n109\t// --- Tests ---\n110\t\n111\tdescribe('CodexDriver', () => {\n112\t  let driver: CodexDriver;\n113\t\n114\t  beforeEach(() => {\n115\t    vi.clearAllMocks();\n116\t    driver = new CodexDriver();\n117\t  });\n118\t\n119\t  afterEach(() => {\n120\t    vi.restoreAllMocks();\n121\t  });\n122\t\n123\t  describe('class properties (AC #1)', () => {\n124\t    it('has name \"codex\"', () => {\n125\t      expect(driver.name).toBe('codex');\n126\t    });\n127\t\n128\t    it('has defaultModel \"codex-mini\"', () => {\n129\t      expect(driver.defaultModel).toBe('codex-mini');\n130\t    });\n131\t\n132\t    it('has correct capabilities', () => {\n133\t      expect(driver.capabilities).toEqual({\n134\t        supportsPlugins: false,\n135\t        supportsStreaming: true,\n136\t        costReporting: true,\n137\t      });\n138\t    });\n139\t  });\n140\t\n141\t  describe('parseLine (AC #2)', () => {\n142\t    it('parses tool_call to tool-start event', () => {\n143\t      const event = parseLine('{\"type\":\"tool_call\",\"name\":\"file_read\",\"call_id\":\"call_001\"}');\n144\t      expect(event).toEqual({ type: 'tool-start', name: 'file_read', id: 'call_001' });\n145\t    });\n146\t\n147\t    it('parses tool_input to tool-input event', () => {\n148\t      const event = parseLine('{\"type\":\"tool_input\",\"call_id\":\"c1\",\"input\":\"{\\\\\"path\\\\\":\\\\\"/a\\\\\"}\"}');\n149\t      expect(event).toEqual({ type: 'tool-input', partial: '{\"path\":\"/a\"}' });\n150\t    });\n151\t\n152\t    it('parses tool_result to tool-complete event', () => {\n153\t      const event = parseLine('{\"type\":\"tool_result\",\"call_id\":\"c1\",\"output\":\"ok\"}');\n154\t      expect(event).toEqual({ type: 'tool-complete' });\n155\t    });\n156\t\n157\t    it('parses message to text event', () => {\n158\t      const event = parseLine('{\"type\":\"message\",\"content\":\"Hello\"}');\n159\t      expect(event).toEqual({ type: 'text', text: 'Hello' });\n160\t    });\n161\t\n162\t    it('parses retry to retry event', () => {\n163\t      const event = parseLine('{\"type\":\"retry\",\"attempt\":2,\"delay_ms\":5000}');\n164\t      expect(event).toEqual({ type: 'retry', attempt: 2, delay: 5000 });\n165\t    });\n166\t\n167\t    it('parses result with cost', () => {\n168\t      const event = parseLine('{\"type\":\"result\",\"cost_usd\":0.0034,\"session_id\":\"sess-123\"}');\n169\t      expect(event).toEqual({\n170\t        type: 'result',\n171\t        cost: 0.0034,\n172\t        sessionId: 'sess-123',\n173\t        cost_usd: 0.0034,\n174\t      });\n175\t    });\n176\t\n177\t    it('parses result without cost (cost_usd is null)', () => {\n178\t      const event = parseLine('{\"type\":\"result\",\"status\":\"completed\",\"session_id\":\"sess-123\"}');\n179\t      expect(event).toEqual({\n180\t        type: 'result',\n181\t        cost: 0,\n182\t        sessionId: 'sess-123',\n183\t        cost_usd: null,\n184\t      });\n185\t    });\n186\t\n187\t    it('returns null for empty lines', () => {\n188\t      expect(parseLine('')).toBeNull();\n189\t      expect(parseLine('   ')).toBeNull();\n190\t    });\n191\t\n192\t    it('returns null for invalid JSON', () => {\n193\t      expect(parseLine('not json at all {{{')).toBeNull();\n194\t    });\n195\t\n196\t    it('returns null for unrecognized type', () => {\n197\t      expect(parseLine('{\"type\":\"unknown_event\",\"data\":\"foo\"}')).toBeNull();\n198\t    });\n199\t\n200\t    it('returns null for arrays', () => {\n201\t      expect(parseLine('[1,2,3]')).toBeNull();\n202\t    });\n203\t\n204\t    it('returns null for primitives', () => {\n205\t      expect(parseLine('\"hello\"')).toBeNull();\n206\t      expect(parseLine('42')).toBeNull();\n207\t    });\n208\t  });\n209\t\n210\t  describe('classifyError (AC #4)', () => {\n211\t    it('classifies 429 status as RATE_LIMIT', () => {\n212\t      const err = Object.assign(new Error('Rate limit'), { status: 429 });\n213\t      expect(classifyError(err)).toBe('RATE_LIMIT');\n214\t    });\n215\t\n216\t    it('classifies \"rate limit\" in message as RATE_LIMIT', () => {\n217\t      expect(classifyError('You have exceeded your rate limit')).toBe('RATE_LIMIT');\n218\t    });\n219\t\n220\t    it('classifies ECONNREFUSED code as NETWORK', () => {\n221\t      const err = Object.assign(new Error('connect failed'), { code: 'ECONNREFUSED' });\n222\t      expect(classifyError(err)).toBe('NETWORK');\n223\t    });\n224\t\n225\t    it('classifies ECONNREFUSED in message string as NETWORK', () => {\n226\t      expect(classifyError('fetch failed: connect ECONNREFUSED 127.0.0.1:443')).toBe('NETWORK');\n227\t    });\n228\t\n229\t    it('classifies ETIMEDOUT code as NETWORK', () => {\n230\t      const err = Object.assign(new Error('request timed out'), { code: 'ETIMEDOUT' });\n231\t      expect(classifyError(err)).toBe('NETWORK');\n232\t    });\n233\t\n234\t    it('classifies fetch failure message as NETWORK', () => {\n235\t      expect(classifyError('fetch failed: DNS resolution error')).toBe('NETWORK');\n236\t    });\n237\t\n238\t    it('classifies 401 status as AUTH', () => {\n239\t      const err = Object.assign(new Error('Unauthorized'), { status: 401 });\n240\t      expect(classifyError(err)).toBe('AUTH');\n241\t    });\n242\t\n243\t    it('classifies 403 status as AUTH', () => {\n244\t      const err = Object.assign(new Error('Forbidden'), { status: 403 });\n245\t      expect(classifyError(err)).toBe('AUTH');\n246\t    });\n247\t\n248\t    it('classifies \"unauthorized\" in message as AUTH', () => {\n249\t      expect(classifyError('Unauthorized. Please check your API key')).toBe('AUTH');\n250\t    });\n251\t\n252\t    it('classifies timeout in message as TIMEOUT', () => {\n253\t      expect(classifyError('operation timed out')).toBe('TIMEOUT');\n254\t    });\n255\t\n256\t    it('classifies unknown errors as UNKNOWN', () => {\n257\t      expect(classifyError('Something unexpected happened')).toBe('UNKNOWN');\n258\t    });\n259\t\n260\t    it('follows priority order: rate limit before network', () => {\n261\t      // An error with both rate limit message and network code\n262\t      const err = Object.assign(new Error('rate limit reached'), { code: 'ECONNRESET' });\n263\t      expect(classifyError(err)).toBe('RATE_LIMIT');\n264\t    });\n265\t\n266\t    it('follows priority order: network before auth', () => {\n267\t      const err = Object.assign(new Error('forbidden'), { code: 'ECONNREFUSED' });\n268\t      expect(classifyError(err)).toBe('NETWORK');\n269\t    });\n270\t  });\n271\t\n272\t  describe('dispatch — successful flow (AC #2, #3, #8)', () => {\n273\t    it('produces correct StreamEvent sequence from fixture lines', async () => {\n274\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n275\t      mockSpawn.mockReturnValue(proc);\n276\t\n277\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n278\t      const types = events.map((e) => e.type);\n279\t\n280\t      expect(types).toEqual([\n281\t        'tool-start',\n282\t        'tool-input',\n283\t        'tool-complete',\n284\t        'text',\n285\t        'tool-start',\n286\t        'tool-input',\n287\t        'tool-complete',\n288\t        'text',\n289\t        'result',\n290\t      ]);\n291\t    });\n292\t\n293\t    it('result event is always the last event', async () => {\n294\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n295\t      mockSpawn.mockReturnValue(proc);\n296\t\n297\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n298\t      expect(events[events.length - 1].type).toBe('result');\n299\t    });\n300\t\n301\t    it('captures cost from CLI output', async () => {\n302\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n303\t      mockSpawn.mockReturnValue(proc);\n304\t\n305\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n306\t      const resultEvent = events.find((e) => e.type === 'result') as ResultEvent;\n307\t      expect(resultEvent.cost_usd).toBe(0.0034);\n308\t      expect(resultEvent.cost).toBe(0.0034);\n309\t    });\n310\t\n311\t    it('getLastCost returns cost after dispatch', async () => {\n312\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n313\t      mockSpawn.mockReturnValue(proc);\n314\t\n315\t      await collectEvents(driver.dispatch(makeOpts()));\n316\t      expect(driver.getLastCost()).toBe(0.0034);\n317\t    });\n318\t  });\n319\t\n320\t  describe('dispatch — cost handling (AC #3)', () => {\n321\t    it('cost_usd is null when CLI does not report cost', async () => {\n322\t      const lines = [\n323\t        '{\"type\":\"message\",\"content\":\"Done.\"}',\n324\t        '{\"type\":\"result\",\"status\":\"completed\",\"session_id\":\"sess-no-cost\"}',\n325\t      ];\n326\t      const { proc } = createMockProcess(lines, 0);\n327\t      mockSpawn.mockReturnValue(proc);\n328\t\n329\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n330\t      const resultEvent = events.find((e) => e.type === 'result') as ResultEvent;\n331\t      expect(resultEvent.cost_usd).toBeNull();\n332\t    });\n333\t\n334\t    it('getLastCost returns null before any dispatch', () => {\n335\t      expect(driver.getLastCost()).toBeNull();\n336\t    });\n337\t\n338\t    it('getLastCost resets on new dispatch', async () => {\n339\t      // First dispatch with cost\n340\t      const { proc: proc1 } = createMockProcess(SUCCESS_LINES, 0);\n341\t      mockSpawn.mockReturnValue(proc1);\n342\t      await collectEvents(driver.dispatch(makeOpts()));\n343\t      expect(driver.getLastCost()).toBe(0.0034);\n344\t\n345\t      // Second dispatch without cost\n346\t      const lines = ['{\"type\":\"result\",\"status\":\"completed\",\"session_id\":\"s\"}'];\n347\t      const { proc: proc2 } = createMockProcess(lines, 0);\n348\t      mockSpawn.mockReturnValue(proc2);\n349\t      await collectEvents(driver.dispatch(makeOpts()));\n350\t      expect(driver.getLastCost()).toBeNull();\n351\t    });\n352\t  });\n353\t\n354\t  describe('dispatch — error handling (AC #4)', () => {\n355\t    it('yields result with RATE_LIMIT on rate limit stderr', async () => {\n356\t      const { proc } = createMockProcess(\n357\t        [],\n358\t        1,\n359\t        'Error: Request failed with status 429: You have exceeded your rate limit.',\n360\t      );\n361\t      mockSpawn.mockReturnValue(proc);\n362\t\n363\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n364\t      const resultEvent = events.find((e) => e.type === 'result') as ResultEvent;\n365\t      expect(resultEvent.errorCategory).toBe('RATE_LIMIT');\n366\t    });\n367\t\n368\t    it('yields result with AUTH on auth failure stderr', async () => {\n369\t      const { proc } = createMockProcess(\n370\t        [],\n371\t        1,\n372\t        'Error: Request failed with status 401: Unauthorized.',\n373\t      );\n374\t      mockSpawn.mockReturnValue(proc);\n375\t\n376\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n377\t      const resultEvent = events.find((e) => e.type === 'result') as ResultEvent;\n378\t      expect(resultEvent.errorCategory).toBe('AUTH');\n379\t    });\n380\t\n381\t    it('yields result with NETWORK on network failure stderr', async () => {\n382\t      const { proc } = createMockProcess(\n383\t        [],\n384\t        1,\n385\t        'Error: fetch failed: connect ECONNREFUSED 127.0.0.1:443',\n386\t      );\n387\t      mockSpawn.mockReturnValue(proc);\n388\t\n389\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n390\t      const resultEvent = events.find((e) => e.type === 'result') as ResultEvent;\n391\t      expect(resultEvent.errorCategory).toBe('NETWORK');\n392\t    });\n393\t\n394\t    it('yields result with UNKNOWN on unrecognized error', async () => {\n395\t      const { proc } = createMockProcess([], 1, 'Something went wrong');\n396\t      mockSpawn.mockReturnValue(proc);\n397\t\n398\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n399\t      const resultEvent = events.find((e) => e.type === 'result') as ResultEvent;\n400\t      expect(resultEvent.errorCategory).toBe('UNKNOWN');\n401\t    });\n402\t\n403\t    it('always yields exactly one result event on error', async () => {\n404\t      const { proc } = createMockProcess([], 1, 'kaboom');\n405\t      mockSpawn.mockReturnValue(proc);\n406\t\n407\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n408\t      const resultEvents = events.filter((e) => e.type === 'result');\n409\t      expect(resultEvents).toHaveLength(1);\n410\t    });\n411\t  });\n412\t\n413\t  describe('dispatch — result guarantee (AC #2)', () => {\n414\t    it('yields result even when stdout is empty and exit code is 0', async () => {\n415\t      const { proc } = createMockProcess([], 0);\n416\t      mockSpawn.mockReturnValue(proc);\n417\t\n418\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n419\t      const resultEvents = events.filter((e) => e.type === 'result');\n420\t      expect(resultEvents).toHaveLength(1);\n421\t    });\n422\t\n423\t    it('yields exactly one result from normal flow', async () => {\n424\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n425\t      mockSpawn.mockReturnValue(proc);\n426\t\n427\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n428\t      const resultEvents = events.filter((e) => e.type === 'result');\n429\t      expect(resultEvents).toHaveLength(1);\n430\t    });\n431\t  });\n432\t\n433\t  describe('dispatch — timeout (AC #6)', () => {\n434\t    it('kills process on timeout and yields TIMEOUT result', async () => {\n435\t      // Create a process that never completes on its own\n436\t      const stdout = new Readable({ read() {} });\n437\t      const stderr = new EventEmitter();\n438\t      const proc = new EventEmitter() as EventEmitter & {\n439\t        stdout: Readable;\n440\t        stderr: EventEmitter;\n441\t        kill: ReturnType<typeof vi.fn>;\n442\t      };\n443\t      proc.stdout = stdout;\n444\t      proc.stderr = stderr;\n445\t      proc.kill = vi.fn(() => {\n446\t        // When killed, end the streams and emit close\n447\t        setTimeout(() => {\n448\t          stdout.push(null);\n449\t          proc.emit('close', 1);\n450\t        }, 5);\n451\t      });\n452\t\n453\t      mockSpawn.mockReturnValue(proc);\n454\t\n455\t      const events = await collectEvents(driver.dispatch(makeOpts({ timeout: 50 })));\n456\t      const resultEvent = events.find((e) => e.type === 'result') as ResultEvent;\n457\t\n458\t      expect(proc.kill).toHaveBeenCalled();\n459\t      expect(resultEvent).toBeDefined();\n460\t      expect(resultEvent.errorCategory).toBe('TIMEOUT');\n461\t    });\n462\t  });\n463\t\n464\t  describe('dispatch — plugins warning (AC #7)', () => {\n465\t    it('logs warning when plugins are provided', async () => {\n466\t      const warnSpy = vi.spyOn(console, 'warn').mockImplementation(() => {});\n467\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n468\t      mockSpawn.mockReturnValue(proc);\n469\t\n470\t      await collectEvents(driver.dispatch(makeOpts({ plugins: ['some-plugin'] })));\n471\t\n472\t      expect(warnSpy).toHaveBeenCalledWith(\n473\t        '[CodexDriver] Codex does not support plugins. Ignoring plugins:',\n474\t        ['some-plugin'],\n475\t      );\n476\t      warnSpy.mockRestore();\n477\t    });\n478\t\n479\t    it('proceeds normally despite plugins', async () => {\n480\t      vi.spyOn(console, 'warn').mockImplementation(() => {});\n481\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n482\t      mockSpawn.mockReturnValue(proc);\n483\t\n484\t      const events = await collectEvents(driver.dispatch(makeOpts({ plugins: ['p1'] })));\n485\t      expect(events.length).toBeGreaterThan(0);\n486\t      expect(events[events.length - 1].type).toBe('result');\n487\t    });\n488\t\n489\t    it('does not warn when plugins is empty', async () => {\n490\t      const warnSpy = vi.spyOn(console, 'warn').mockImplementation(() => {});\n491\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n492\t      mockSpawn.mockReturnValue(proc);\n493\t\n494\t      await collectEvents(driver.dispatch(makeOpts({ plugins: [] })));\n495\t\n496\t      expect(warnSpy).not.toHaveBeenCalled();\n497\t      warnSpy.mockRestore();\n498\t    });\n499\t  });\n500\t\n501\t  describe('dispatch — unparseable lines (AC #2)', () => {\n502\t    it('skips unparseable lines and logs them at debug level', async () => {\n503\t      const debugSpy = vi.spyOn(console, 'debug').mockImplementation(() => {});\n504\t      const lines = [\n505\t        ...UNPARSEABLE_LINES,\n506\t        '{\"type\":\"result\",\"cost_usd\":0.01,\"session_id\":\"s1\"}',\n507\t      ];\n508\t      const { proc } = createMockProcess(lines, 0);\n509\t      mockSpawn.mockReturnValue(proc);\n510\t\n511\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n512\t\n513\t      // Only the result event should be yielded\n514\t      expect(events).toHaveLength(1);\n515\t      expect(events[0].type).toBe('result');\n516\t\n517\t      // All 4 unparseable lines should be debug-logged\n518\t      expect(debugSpy).toHaveBeenCalledTimes(4);\n519\t      debugSpy.mockRestore();\n520\t    });\n521\t  });\n522\t\n523\t  describe('dispatch — event ordering (AC #8)', () => {\n524\t    it('events follow tool-start -> tool-input -> tool-complete, text, result ordering', async () => {\n525\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n526\t      mockSpawn.mockReturnValue(proc);\n527\t\n528\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n529\t      const types = events.map((e) => e.type);\n530\t\n531\t      // Verify no result event before the end\n532\t      const resultIndex = types.indexOf('result');\n533\t      expect(resultIndex).toBe(types.length - 1);\n534\t\n535\t      // Verify tool sequences are ordered correctly\n536\t      // First tool use: tool-start, tool-input, tool-complete\n537\t      expect(types[0]).toBe('tool-start');\n538\t      expect(types[1]).toBe('tool-input');\n539\t      expect(types[2]).toBe('tool-complete');\n540\t      // Then text\n541\t      expect(types[3]).toBe('text');\n542\t    });\n543\t  });\n544\t\n545\t  describe('healthCheck (AC #5)', () => {\n546\t    it('returns available: true when binary is found', async () => {\n547\t      mockExecFile.mockImplementation(\n548\t        (cmd: string, args: string[], cb: (err: Error | null, result: { stdout: string }) => void) => {\n549\t          if (cmd === 'which') {\n550\t            cb(null, { stdout: '/usr/local/bin/codex\\n' });\n551\t          } else if (args[0] === '--version') {\n552\t            cb(null, { stdout: '0.1.2\\n' });\n553\t          } else if (args[0] === 'auth') {\n554\t            cb(null, { stdout: 'authenticated\\n' });\n555\t          }\n556\t        },\n557\t      );\n558\t\n559\t      const health = await driver.healthCheck();\n560\t      expect(health.available).toBe(true);\n561\t      expect(health.version).toBe('0.1.2');\n562\t      expect(health.authenticated).toBe(true);\n563\t    });\n564\t\n565\t    it('returns available: false when binary is not found', async () => {\n566\t      mockExecFile.mockImplementation(\n567\t        (_cmd: string, _args: string[], cb: (err: Error | null) => void) => {\n568\t          cb(new Error('not found'));\n569\t        },\n570\t      );\n571\t\n572\t      const health = await driver.healthCheck();\n573\t      expect(health.available).toBe(false);\n574\t      expect(health.authenticated).toBe(false);\n575\t      expect(health.version).toBeNull();\n576\t      expect(health.error).toBe('codex CLI not found. Install: npm install -g @openai/codex');\n577\t    });\n578\t\n579\t    it('returns authenticated: false when auth check fails', async () => {\n580\t      let callCount = 0;\n581\t      mockExecFile.mockImplementation(\n582\t        (cmd: string, args: string[], cb: (err: Error | null, result?: { stdout: string }) => void) => {\n583\t          callCount++;\n584\t          if (cmd === 'which') {\n585\t            cb(null, { stdout: '/usr/local/bin/codex\\n' });\n586\t          } else if (args[0] === '--version') {\n587\t            cb(null, { stdout: '0.1.2\\n' });\n588\t          } else if (args[0] === 'auth') {\n589\t            cb(new Error('not authenticated'));\n590\t          }\n591\t        },\n592\t      );\n593\t\n594\t      const health = await driver.healthCheck();\n595\t      expect(health.available).toBe(true);\n596\t      expect(health.authenticated).toBe(false);\n597\t    });\n598\t  });\n599\t\n600\t  describe('dispatch — CLI args', () => {\n601\t    it('passes model and cwd to spawn', async () => {\n602\t      const { proc } = createMockProcess(\n603\t        ['{\"type\":\"result\",\"cost_usd\":0.01,\"session_id\":\"s\"}'],\n604\t        0,\n605\t      );\n606\t      mockSpawn.mockReturnValue(proc);\n607\t\n608\t      await collectEvents(\n609\t        driver.dispatch(makeOpts({ model: 'codex-mini', cwd: '/my/project', prompt: 'hello' })),\n610\t      );\n611\t\n612\t      expect(mockSpawn).toHaveBeenCalledWith(\n613\t        'codex',\n614\t        ['--model', 'codex-mini', '--cwd', '/my/project', 'hello'],\n615\t        { stdio: ['ignore', 'pipe', 'pipe'] },\n616\t      );\n617\t    });\n618\t  });\n619\t\n620\t  describe('barrel export (AC #9)', () => {\n621\t    it('CodexDriver is re-exported from drivers/index.ts', async () => {\n622\t      const mod = await import('../drivers/index.js');\n623\t      expect(mod.CodexDriver).toBe(CodexDriver);\n624\t    });\n625\t  });\n626\t});\n627\t"}]},"parent_tool_use_id":"toolu_01JbXzRAzkG8BRgjQTeRY35M","session_id":"576f74f4-0d7f-4316-a569-4c3ab5c122fd","uuid":"2a71aebf-cb06-4355-b1e5-4d12ed0207c6","timestamp":"2026-04-03T09:03:17.596Z"}
