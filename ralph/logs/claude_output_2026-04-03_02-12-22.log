: [],\n61\t    circuit_breaker: { triggered: false, reason: null, score_history: [] },\n62\t    trace_ids: [],\n63\t  }),\n64\t}));\n65\t\n66\tvi.mock('../source-isolation.js', () => ({\n67\t  createIsolatedWorkspace: mockCreateIsolatedWorkspace,\n68\t}));\n69\t\n70\tvi.mock('../trace-id.js', () => ({\n71\t  generateTraceId: mockGenerateTraceId,\n72\t  formatTracePrompt: mockFormatTracePrompt,\n73\t  recordTraceId: mockRecordTraceId,\n74\t}));\n75\t\n76\tvi.mock('../session-manager.js', () => ({\n77\t  resolveSessionId: mockResolveSessionId,\n78\t  recordSessionId: mockRecordSessionId,\n79\t}));\n80\t\n81\tvi.mock('../output.js', () => ({\n82\t  warn: mockWarn,\n83\t}));\n84\t\n85\tvi.mock('node:fs', () => ({\n86\t  readFileSync: mockReadFileSync,\n87\t  existsSync: mockExistsSync,\n88\t}));\n89\t\n90\tvi.mock('yaml', () => ({\n91\t  parse: mockParse,\n92\t}));\n93\t\n94\timport {\n95\t  executeWorkflow,\n96\t  loadWorkItems,\n97\t  dispatchTask,\n98\t  parseVerdict,\n99\t  buildRetryPrompt,\n100\t  getFailedItems,\n101\t  executeLoopBlock,\n102\t} from '../workflow-engine.js';\n103\timport type {\n104\t  EngineConfig,\n105\t  EngineError,\n106\t  WorkItem,\n107\t  EvaluatorVerdict,\n108\t} from '../workflow-engine.js';\n109\timport type { WorkflowState } from '../workflow-state.js';\n110\timport type { ResolvedWorkflow, ResolvedTask } from '../workflow-parser.js';\n111\timport type { SubagentDefinition } from '../agent-resolver.js';\n112\t\n113\t// --- Helpers ---\n114\t\n115\tfunction makeDefaultState(overrides?: Partial<WorkflowState>): WorkflowState {\n116\t  return {\n117\t    workflow_name: '',\n118\t    started: '',\n119\t    iteration: 0,\n120\t    phase: 'idle',\n121\t    tasks_completed: [],\n122\t    evaluator_scores: [],\n123\t    circuit_breaker: { triggered: false, reason: null, score_history: [] },\n124\t    trace_ids: [],\n125\t    ...overrides,\n126\t  };\n127\t}\n128\t\n129\tfunction makeDefinition(overrides?: Partial<SubagentDefinition>): SubagentDefinition {\n130\t  return {\n131\t    name: 'test-agent',\n132\t    model: 'claude-sonnet-4-20250514',\n133\t    instructions: 'You are a test agent.',\n134\t    disallowedTools: [],\n135\t    bare: true,\n136\t    ...overrides,\n137\t  };\n138\t}\n139\t\n140\tfunction makeTask(overrides?: Partial<ResolvedTask>): ResolvedTask {\n141\t  return {\n142\t    agent: 'dev',\n143\t    scope: 'per-story',\n144\t    session: 'fresh',\n145\t    source_access: true,\n146\t    ...overrides,\n147\t  };\n148\t}\n149\t\n150\tfunction makeConfig(overrides?: Partial<EngineConfig>): EngineConfig {\n151\t  return {\n152\t    workflow: {\n153\t      tasks: {\n154\t        implement: makeTask(),\n155\t        verify: makeTask({ scope: 'per-run', source_access: false }),\n156\t      },\n157\t      flow: ['implement', 'verify'],\n158\t    },\n159\t    agents: {\n160\t      dev: makeDefinition(),\n161\t    },\n162\t    sprintStatusPath: '/project/sprint-status.yaml',\n163\t    runId: 'run-001',\n164\t    projectDir: '/project',\n165\t    ...overrides,\n166\t  };\n167\t}\n168\t\n169\tfunction setupDefaultMocks() {\n170\t  mockReadWorkflowState.mockReturnValue(makeDefaultState());\n171\t  mockWriteWorkflowState.mockImplementation(() => {});\n172\t\n173\t  mockGenerateTraceId.mockReturnValue('ch-run-001-0-implement');\n174\t  mockFormatTracePrompt.mockReturnValue('[TRACE] trace_id=ch-run-001-0-implement');\n175\t  mockRecordTraceId.mockImplementation((traceId: string, state: WorkflowState) => ({\n176\t    ...state,\n177\t    trace_ids: [...(state.trace_ids ?? []), traceId],\n178\t  }));\n179\t\n180\t  mockResolveSessionId.mockReturnValue(undefined);\n181\t  mockRecordSessionId.mockImplementation(\n182\t    (key: { taskName: string; storyKey: string }, sessionId: string, state: WorkflowState) => ({\n183\t      ...state,\n184\t      tasks_completed: [\n185\t        ...state.tasks_completed,\n186\t        {\n187\t          task_name: key.taskName,\n188\t          story_key: key.storyKey,\n189\t          completed_at: '2026-04-03T00:00:00.000Z',\n190\t          session_id: sessionId,\n191\t        },\n192\t      ],\n193\t    }),\n194\t  );\n195\t\n196\t  mockDispatchAgent.mockResolvedValue({\n197\t    sessionId: 'sess-abc-123',\n198\t    success: true,\n199\t    durationMs: 1000,\n200\t    output: 'Done',"}]},"parent_tool_use_id":"toolu_01V1x6e3c7XZ7fi9gyeDWjD6","session_id":"7447df8e-50f4-441a-b8fe-e85605fee72e","uuid":"5e72cc5b-10b2-4a38-8fdd-ad5d9d796bd1","timestamp":"2026-04-02T22:25:09.991Z"}
