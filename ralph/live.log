{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012XQEDgPk3Fz4oVYrA39zrk","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n     2→import { mkdtempSync, rmSync, writeFileSync, mkdirSync } from 'node:fs';\n     3→import { tmpdir } from 'node:os';\n     4→import { join } from 'node:path';\n     5→import { parseStoryACs, classifyAC, classifyVerifiability, classifyStrategy, parseVerificationTag, INTEGRATION_KEYWORDS } from '../parser.js';\n     6→\n     7→// Mock output.ts to suppress warnings during tests\n     8→vi.mock('../../../lib/output.js', () => ({\n     9→  ok: vi.fn(),\n    10→  fail: vi.fn(),\n    11→  warn: vi.fn(),\n    12→  info: vi.fn(),\n    13→  jsonOutput: vi.fn(),\n    14→}));\n    15→\n    16→let testDir: string;\n    17→\n    18→beforeEach(() => {\n    19→  vi.restoreAllMocks();\n    20→  testDir = mkdtempSync(join(tmpdir(), 'ch-verify-parser-test-'));\n    21→});\n    22→\n    23→afterEach(() => {\n    24→  rmSync(testDir, { recursive: true, force: true });\n    25→});\n    26→\n    27→function writeStoryFile(filename: string, content: string): string {\n    28→  const filePath = join(testDir, filename);\n    29→  writeFileSync(filePath, content, 'utf-8');\n    30→  return filePath;\n    31→}\n    32→\n    33→// ─── classifyAC ─────────────────────────────────────────────────────────────\n    34→\n    35→describe('classifyAC', () => {\n    36→  it('classifies UI keywords', () => {\n    37→    expect(classifyAC('use agent-browser to navigate')).toBe('ui');\n    38→    expect(classifyAC('take a screenshot of the page')).toBe('ui');\n    39→    expect(classifyAC('click on the submit button')).toBe('ui');\n    40→    expect(classifyAC('fill the form with data')).toBe('ui');\n    41→    expect(classifyAC('navigate to the home page')).toBe('ui');\n    42→  });\n    43→\n    44→  it('classifies API keywords', () => {\n    45→    expect(classifyAC('make HTTP calls to the endpoint')).toBe('api');\n    46→    expect(classifyAC('use curl to test the API')).toBe('api');\n    47→    expect(classifyAC('verify REST response body')).toBe('api');\n    48→    expect(classifyAC('check the API endpoint status')).toBe('api');\n    49→  });\n    50→\n    51→  it('classifies DB keywords', () => {\n    52→    expect(classifyAC('check database state after insert')).toBe('db');\n    53→    expect(classifyAC('verify DB state via query')).toBe('db');\n    54→    expect(classifyAC('use Database MCP to query')).toBe('db');\n    55→    expect(classifyAC('run SQL to verify')).toBe('db');\n    56→    expect(classifyAC('check the table contents')).toBe('db');\n    57→  });\n    58→\n    59→  it('classifies general when no keywords match', () => {\n    60→    expect(classifyAC('verify the output is correct')).toBe('general');\n    61→    expect(classifyAC('check that the file exists')).toBe('general');\n    62→    expect(classifyAC('ensure the config is valid')).toBe('general');\n    63→  });\n    64→\n    65→  it('is case insensitive', () => {\n    66→    expect(classifyAC('Use AGENT-BROWSER to test')).toBe('ui');\n    67→    expect(classifyAC('Make HTTP calls')).toBe('api');\n    68→    expect(classifyAC('Check DATABASE state')).toBe('db');\n    69→  });\n    70→\n    71→  it('returns first matching type when multiple keywords present', () => {\n    72→    // UI keywords are checked first\n    73→    expect(classifyAC('use agent-browser to call API endpoint')).toBe('ui');\n    74→  });\n    75→});\n    76→\n    77→// ─── parseStoryACs ──────────────────────────────────────────────────────────\n    78→\n    79→describe('parseStoryACs', () => {\n    80→  it('extracts numbered ACs from a standard story file', () => {\n    81→    const filePath = writeStoryFile('story.md', `# Story 4.1: Test Story\n    82→\n    83→Status: ready-for-dev\n    84→\n    85→## Story\n    86→\n    87→As a developer...\n    88→\n    89→## Acceptance Criteria\n    90→\n    91→1. **Given** a developer runs the command, **When** tests pass, **Then** output is shown.\n    92→\n    93→2. **Given** a user opens the app, **When** they click submit, **Then** the form is saved.\n    94→\n    95→## Tasks / Subtasks\n    96→\n    97→- [ ] Task 1: Do something\n    98→`);\n    99→\n   100→    const acs = parseStoryACs(filePath);\n   101→    expect(acs).toHaveLength(2);\n   102→    expect(acs[0].id).toBe('1');\n   103→    expect(acs[0].description).toContain('developer runs the command');\n   104→    expect(acs[0].type).toBe('general');\n   105→    expect(acs[0].verifiability).toBe('cli-verifiable');\n   106→    expect(acs[1].id).toBe('2');\n   107→    expect(acs[1].description).toContain('click submit');\n   108→    expect(acs[1].type).toBe('ui');\n   109→    expect(acs[1].verifiability).toBe('cli-verifiable');\n   110→  });\n   111→\n   112→  it('handles multi-line ACs', () => {\n   113→    const filePath = writeStoryFile('story.md', `# Story 1.1: Multi\n   114→\n   115→## Acceptance Criteria\n   116→\n   117→1. **Given** a developer runs the verify command,\n   118→   **When** the verification pipeline starts,\n   119→   **Then** preconditions are checked.\n   120→\n   121→## Tasks\n   122→`);\n   123→\n   124→    const acs = parseStoryACs(filePath);\n   125→    expect(acs).toHaveLength(1);\n   126→    expect(acs[0].description).toContain('developer runs the verify command');\n   127→    expect(acs[0].description).toContain('preconditions are checked');\n   128→  });\n   129→\n   130→  it('classifies ACs by type from content', () => {\n   131→    const filePath = writeStoryFile('story.md', `# Story 1.1: Types\n   132→\n   133→## Acceptance Criteria\n   134→\n   135→1. **Given** agent-browser is used, **Then** screenshots are captured.\n   136→\n   137→2. **Given** HTTP calls are made to the API endpoint, **Then** response bodies are inspected.\n   138→\n   139→3. **Given** Database MCP is used for read-only queries, **Then** results are captured.\n   140→\n   141→4. **Given** verification steps complete, **Then** a proof document is created.\n   142→\n   143→## Tasks\n   144→`);\n   145→\n   146→    const acs = parseStoryACs(filePath);\n   147→    expect(acs).toHaveLength(4);\n   148→    expect(acs[0].type).toBe('ui');\n   149→    expect(acs[1].type).toBe('api');\n   150→    expect(acs[2].type).toBe('db');\n   151→    expect(acs[3].type).toBe('general');\n   152→  });\n   153→\n   154→  it('throws with actionable message when file not found', () => {\n   155→    expect(() => parseStoryACs('/nonexistent/path/story.md')).toThrow(\n   156→      'Story file not found: /nonexistent/path/story.md',\n   157→    );\n   158→  });\n   159→\n   160→  it('returns empty array when no AC section exists', () => {\n   161→    const filePath = writeStoryFile('story.md', `# Story 1.1: No ACs\n   162→\n   163→## Story\n   164→\n   165→As a developer...\n   166→\n   167→## Tasks\n   168→\n   169→- [ ] Do something\n   170→`);\n   171→\n   172→    const acs = parseStoryACs(filePath);\n   173→    expect(acs).toEqual([]);\n   174→  });\n   175→\n   176→  it('handles malformed ACs — skips empty descriptions', () => {\n   177→    const filePath = writeStoryFile('story.md', `# Story 1.1: Malformed\n   178→\n   179→## Acceptance Criteria\n   180→\n   181→1. **Given** a valid AC, **Then** it works.\n   182→\n   183→2.\n   184→\n   185→3. **Given** another valid AC, **Then** it also works.\n   186→\n   187→## Tasks\n   188→`);\n   189→\n   190→    const acs = parseStoryACs(filePath);\n   191→    // AC #2 has empty description and should be skipped\n   192→    expect(acs).toHaveLength(2);\n   193→    expect(acs[0].id).toBe('1');\n   194→    expect(acs[1].id).toBe('3');\n   195→  });\n   196→\n   197→  it('handles AC section at end of file (no following section)', () => {\n   198→    const filePath = writeStoryFile('story.md', `# Story 1.1: EOF\n   199→\n   200→## Acceptance Criteria\n   201→\n   202→1. **Given** it is the last section, **Then** it should still parse.\n   203→`);\n   204→\n   205→    const acs = parseStoryACs(filePath);\n   206→    expect(acs).toHaveLength(1);\n   207→    expect(acs[0].description).toContain('last section');\n   208→    expect(acs[0].verifiability).toBe('cli-verifiable');\n   209→  });\n   210→\n   211→  it('reads verification tag from AC line and sets verifiability accordingly', () => {\n   212→    const filePath = writeStoryFile('story.md', `# Story 12.3: Tags\n   213→\n   214→## Acceptance Criteria\n   215→\n   216→1. **Given** a CLI command, **Then** output is shown. <!-- verification: cli-verifiable -->\n   217→\n   218→2. **Given** sprint planning surfaces retro items, **Then** items appear. <!-- verification: integration-required -->\n   219→\n   220→## Tasks\n   221→`);\n   222→\n   223→    const acs = parseStoryACs(filePath);\n   224→    expect(acs).toHaveLength(2);\n   225→    expect(acs[0].verifiability).toBe('cli-verifiable');\n   226→    expect(acs[1].verifiability).toBe('integration-required');\n   227→  });\n   228→\n   229→  it('falls back to heuristic classification when no verification tag is present', () => {\n   230→    const filePath = writeStoryFile('story.md', `# Story 12.3: Heuristic\n   231→\n   232→## Acceptance Criteria\n   233→\n   234→1. **Given** a CLI command, **Then** output is correct.\n   235→\n   236→2. **Given** an external system connection, **Then** data syncs.\n   237→\n   238→3. **Given** manual verification is needed, **Then** flag for human review.\n   239→\n   240→## Tasks\n   241→`);\n   242→\n   243→    const acs = parseStoryACs(filePath);\n   244→    expect(acs).toHaveLength(3);\n   245→    expect(acs[0].verifiability).toBe('cli-verifiable');\n   246→    expect(acs[1].verifiability).toBe('integration-required');\n   247→    expect(acs[2].verifiability).toBe('integration-required');\n   248→  });\n   249→\n   250→  it('verification tag overrides heuristic classification', () => {\n   251→    const filePath = writeStoryFile('story.md', `# Story 12.3: Override\n   252→\n   253→## Acceptance Criteria\n   254→\n   255→1. **Given** an external system is connected, **Then** output is correct. <!-- verification: cli-verifiable -->\n   256→\n   257→## Tasks\n   258→`);\n   259→\n   260→    const acs = parseStoryACs(filePath);\n   261→    expect(acs).toHaveLength(1);\n   262→    // \"external system\" would heuristically classify as integration-required,\n   263→    // but the explicit tag overrides it to cli-verifiable\n   264→    expect(acs[0].verifiability).toBe('cli-verifiable');\n   265→  });\n   266→});\n   267→\n   268→// ─── classifyVerifiability ───────────────────────────────────────────────────\n   269→\n   270→describe('classifyVerifiability', () => {\n   271→  it('returns integration-required for descriptions mentioning integration keywords', () => {\n   272→    expect(classifyVerifiability('connects to external system')).toBe('integration-required');\n   273→    expect(classifyVerifiability('uses real infrastructure for testing')).toBe('integration-required');\n   274→    expect(classifyVerifiability('requires manual verification')).toBe('integration-required');\n   275→  });\n   276→\n   277→  it('returns cli-verifiable for descriptions that were previously over-classified', () => {\n   278→    expect(classifyVerifiability('sprint planning surfaces retro action items')).toBe('cli-verifiable');\n   279→    expect(classifyVerifiability('the workflow executes correctly')).toBe('cli-verifiable');\n   280→    expect(classifyVerifiability('run /command to start the process')).toBe('cli-verifiable');\n   281→    expect(classifyVerifiability('user session is active and preserved')).toBe('cli-verifiable');\n   282→    expect(classifyVerifiability('requires multi-step verification')).toBe('cli-verifiable');\n   283→  });\n   284→\n   285→  it('returns cli-verifiable for descriptions without integration keywords', () => {\n   286→    expect(classifyVerifiability('CLI output contains expected text')).toBe('cli-verifiable');\n   287→    expect(classifyVerifiability('file exists at the expected path')).toBe('cli-verifiable');\n   288→    expect(classifyVerifiability('command returns exit code 0')).toBe('cli-verifiable');\n   289→    expect(classifyVerifiability('JSON contains the expected field')).toBe('cli-verifiable');\n   290→    expect(classifyVerifiability('verify the output is correct')).toBe('cli-verifiable');\n   291→  });\n   292→\n   293→  it('is case insensitive', () => {\n   294→    expect(classifyVerifiability('EXTERNAL SYSTEM connection')).toBe('integration-required');\n   295→    expect(classifyVerifiability('Manual Verification required')).toBe('integration-required');\n   296→  });\n   297→});\n   298→\n   299→// ─── parseVerificationTag ────────────────────────────────────────────────────\n   300→\n   301→describe('parseVerificationTag', () => {\n   302→  it('parses cli-verifiable tag', () => {\n   303→    expect(parseVerificationTag('some text <!-- verification: cli-verifiable -->')).toBe('cli-verifiable');\n   304→  });\n   305→\n   306→  it('parses integration-required tag', () => {\n   307→    expect(parseVerificationTag('some text <!-- verification: integration-required -->')).toBe('integration-required');\n   308→  });\n   309→\n   310→  it('returns null when no tag is present', () => {\n   311→    expect(parseVerificationTag('some text without a tag')).toBeNull();\n   312→  });\n   313→\n   314→  it('handles extra whitespace in tag', () => {\n   315→    expect(parseVerificationTag('text <!--  verification:  cli-verifiable  -->')).toBe('cli-verifiable');\n   316→  });\n   317→});\n   318→\n   319→// ─── classifyStrategy ──────────────────────────────────────────────────────\n   320→\n   321→describe('classifyStrategy', () => {\n   322→  it('returns docker as the default for all normal ACs', () => {\n   323→    expect(classifyStrategy('Given the user runs codeharness status, Then output shows version')).toBe('docker');\n   324→  });\n   325→\n   326→  it('returns docker for Agent tool ACs', () => {\n   327→    expect(classifyStrategy('invokes /create-story via Agent tool')).toBe('docker');\n   328→  });\n   329→\n   330→  it('returns docker for workflow ACs', () => {\n   331→    expect(classifyStrategy('runs the sprint planning workflow')).toBe('docker');\n   332→  });\n   333→\n   334→  it('returns docker for integration keywords', () => {\n   335→    expect(classifyStrategy('requires integration test with external system')).toBe('docker');\n   336→  });\n   337→\n   338→  it('returns docker for CLI ACs (safer than cli-direct)', () => {\n   339→    expect(classifyStrategy('runs npm test and checks coverage')).toBe('docker');\n   340→  });\n   341→\n   342→  it('returns escalate for physical hardware ACs', () => {\n   343→    expect(classifyStrategy('requires physical hardware testing on device')).toBe('escalate');\n   344→  });\n   345→\n   346→  it('returns escalate for manual human review ACs', () => {\n   347→    expect(classifyStrategy('needs manual human visual inspection')).toBe('escalate');\n   348→  });\n   349→\n   350→  it('includes strategy in parsed ACs', () => {\n   351→    const storyPath = writeStoryFile('strategy-test.md', [\n   352→      '# Story',\n   353→      '',\n   354→      '## Acceptance Criteria',\n   355→      '',\n   356→      '1. Given the CLI is built, Then codeharness --version shows the version',\n   357→      '2. Given a sprint, Then it invokes /create-story via Agent tool for backlog stories',\n   358→    ].join('\\n'));\n   359→\n   360→    const acs = parseStoryACs(storyPath);\n   361→    expect(acs).toHaveLength(2);\n   362→    expect(acs[0].strategy).toBe('docker');\n   363→    expect(acs[1].strategy).toBe('docker');\n   364→  });\n   365→\n   366→  // ─── AC #6: classifyStrategy never refuses based on project type ──────\n   367→\n   368→  it('returns docker for empty description', () => {\n   369→    expect(classifyStrategy('')).toBe('docker');\n   370→  });\n   371→\n   372→  it('returns docker for unusual project keywords', () => {\n   373→    expect(classifyStrategy('Rust cargo build and run tests')).toBe('docker');\n   374→    expect(classifyStrategy('Go binary compilation with modules')).toBe('docker');\n   375→    expect(classifyStrategy('Java Maven Spring Boot application')).toBe('docker');\n   376→    expect(classifyStrategy('Ruby on Rails web server')).toBe('docker');\n   377→  });\n   378→\n   379→  it('never returns escalate for project-type descriptions', () => {\n   380→    const projectDescriptions = [\n   381→      'CLI project with Node.js',\n   382→      'Python library with pip install',\n   383→      'Claude Code plugin with slash commands',\n   384→      'Unknown project with no package.json',\n   385→      'Generic container with basic tools',\n   386→      'Web application with React frontend',\n   387→      'API server with Express',\n   388→      'Library published on npm',\n   389→    ];\n   390→    for (const desc of projectDescriptions) {\n   391→      expect(classifyStrategy(desc)).toBe('docker');\n   392→    }\n   393→  });\n   394→\n   395→  it('only escalates for genuine escalation keywords', () => {\n   396→    expect(classifyStrategy('requires physical hardware testing')).toBe('escalate');\n   397→    expect(classifyStrategy('manual human review required')).toBe('escalate');\n   398→    expect(classifyStrategy('visual inspection by human needed')).toBe('escalate');\n   399→    expect(classifyStrategy('paid external service integration')).toBe('escalate');\n   400→  });\n   401→});\n   402→\n   403→"}]},"parent_tool_use_id":"toolu_01MFawaZjU2m6JcEgsVAbzsc","session_id":"7513e7c5-481d-406c-8e26-d0526a0df74d","uuid":"e9da0d77-a06e-4430-a6bb-7bfe1eef52b4","timestamp":"2026-03-27T06:46:55.394Z"}
