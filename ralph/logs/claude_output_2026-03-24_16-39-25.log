TS.md' && d.grade === 'stale');\n   627→    expect(agentsResult).toBeDefined();\n   628→    expect(agentsResult!.reason).toContain('missing:');\n   629→  });\n   630→});\n   631→\n   632→// ─── Exec-Plan Lifecycle ─────────────────────────────────────────────────────\n   633→\n   634→describe('createExecPlan', () => {\n   635→  it('creates exec-plan in active directory', () => {\n   636→    const path = createExecPlan('test-story', testDir);\n   637→    expect(existsSync(path)).toBe(true);\n   638→    expect(path).toContain('docs/exec-plans/active/test-story.md');\n   639→  });\n   640→\n   641→  it('includes DO NOT EDIT header', () => {\n   642→    const path = createExecPlan('test-story', testDir);\n   643→    const content = readFileSync(path, 'utf-8');\n   644→    expect(content).toContain('DO NOT EDIT MANUALLY');\n   645→  });\n   646→\n   647→  it('includes Status: active', () => {\n   648→    const path = createExecPlan('test-story', testDir);\n   649→    const content = readFileSync(path, 'utf-8');\n   650→    expect(content).toContain('Status: active');\n   651→  });\n   652→\n   653→  it('includes Created timestamp', () => {\n   654→    const path = createExecPlan('test-story', testDir);\n   655→    const content = readFileSync(path, 'utf-8');\n   656→    expect(content).toMatch(/Created: \\d{4}-\\d{2}-\\d{2}/);\n   657→  });\n   658→\n   659→  it('extracts content from story file if available', () => {\n   660→    // Create a story file\n   661→    const storyContent = [\n   662→      '# Story: Test Story',\n   663→      '',\n   664→      '## Acceptance Criteria',\n   665→      '',\n   666→      '1. Given X, When Y, Then Z',\n   667→      '',\n   668→      '## Tasks / Subtasks',\n   669→      '',\n   670→      '- [ ] Task 1: Do something',\n   671→      '- [ ] Task 2: Do something else',\n   672→      '',\n   673→    ].join('\\n');\n   674→\n   675→    mkdirSync(join(testDir, '_bmad-output', 'implementation-artifacts'), { recursive: true });\n   676→    writeFileSync(join(testDir, '_bmad-output', 'implementation-artifacts', 'test-story.md'), storyContent);\n   677→\n   678→    const path = createExecPlan('test-story', testDir);\n   679→    const content = readFileSync(path, 'utf-8');\n   680→    expect(content).toContain('Given X, When Y, Then Z');\n   681→    expect(content).toContain('Task 1: Do something');\n   682→  });\n   683→});\n   684→\n   685→describe('completeExecPlan', () => {\n   686→  it('moves exec-plan from active to completed', () => {\n   687→    createExecPlan('test-story', testDir);\n   688→    const completedPath = completeExecPlan('test-story', testDir);\n   689→\n   690→    expect(completedPath).not.toBeNull();\n   691→    expect(completedPath!).toContain('docs/exec-plans/completed/test-story.md');\n   692→    expect(existsSync(completedPath!)).toBe(true);\n   693→    expect(existsSync(join(testDir, 'docs/exec-plans/active/test-story.md'))).toBe(false);\n   694→  });\n   695→\n   696→  it('updates status to completed', () => {\n   697→    createExecPlan('test-story', testDir);\n   698→    const completedPath = completeExecPlan('test-story', testDir)!;\n   699→    const content = readFileSync(completedPath, 'utf-8');\n   700→    expect(content).toContain('Status: completed');\n   701→    expect(content).not.toContain('Status: active');\n   702→  });\n   703→\n   704→  it('adds Completed timestamp', () => {\n   705→    createExecPlan('test-story', testDir);\n   706→    const completedPath = completeExecPlan('test-story', testDir)!;\n   707→    const content = readFileSync(completedPath, 'utf-8');\n   708→    expect(content).toMatch(/Completed: \\d{4}-\\d{2}-\\d{2}/);\n   709→  });\n   710→\n   711→  it('returns null when no active exec-plan exists', () => {\n   712→    const result = completeExecPlan('nonexistent', testDir);\n   713→    expect(result).toBeNull();\n   714→  });\n   715→});\n   716→\n   717→describe('getExecPlanStatus', () => {\n   718→  it('returns active when exec-plan is in active directory', () => {\n   719→    createExecPlan('test-story', testDir);\n   720→    expect(getExecPlanStatus('test-story', testDir)).toBe('active');\n   721→  });\n   722→\n   723→  it('returns completed when exec-plan is in completed directory', () => {\n   724→    createExecPlan('test-story', testDir);\n   725→    completeExecPlan('test-story', testDir);\n   726→    expect(getExecPlanStatus('test-story', testDir)).toBe('completed');\n   727→  });\n   728→\n   729→  it('returns missing when no exec-plan exists', () => {\n   730→    expect(getExecPlanStatus('nonexistent', testDir)).toBe('missing');\n   731→  });\n   732→});\n   733→\n   734→// ─── formatDocHealthOutput ───────────────────────────────────────────────────\n   735→\n   736→describe('formatDocHealthOutput', () => {\n   737→  it('formats healthy report correctly', () => {\n   738→    const report: DocHealthReport = {\n   739→      documents: [\n   740→        { path: 'AGENTS.md', grade: 'fresh', lastModified: new Date(), codeLastModified: new Date(), reason: 'Up to date' },\n   741→      ],\n   742→      summary: { fresh: 1, stale: 0, missing: 0, total: 1 },\n   743→      passed: true,\n   744→      scanDurationMs: 10,\n   745→    };\n   746→\n   747→    const lines = formatDocHealthOutput(report);\n   748→    expect(lines).toContain('[OK] AGENTS.md: fresh');\n   749→    expect(lines.some(l => l.includes('1 fresh, 0 stale, 0 missing'))).toBe(true);\n   750→  });\n   751→\n   752→  it('formats stale report correctly', () => {\n   753→    const report: DocHealthReport = {\n   754→      documents: [\n   755→        { path: 'AGENTS.md', grade: 'stale', lastModified: new Date(), codeLastModified: new Date(), reason: 'AGENTS.md stale for module: src' },\n   756→      ],\n   757→      summary: { fresh: 0, stale: 1, missing: 0, total: 1 },\n   758→      passed: false,\n   759→      scanDurationMs: 10,\n   760→    };\n   761→\n   762→    const lines = formatDocHealthOutput(report);\n   763→    expect(lines).toContain('[FAIL] AGENTS.md stale for module: src');\n   764→  });\n   765→\n   766→  it('formats missing doc correctly', () => {\n   767→    const report: DocHealthReport = {\n   768→      documents: [\n   769→        { path: 'AGENTS.md', grade: 'missing', lastModified: null, codeLastModified: null, reason: 'Root AGENTS.md not found' },\n   770→      ],\n   771→      summary: { fresh: 0, stale: 0, missing: 1, total: 1 },\n   772→      passed: false,\n   773→      scanDurationMs: 5,\n   774→    };\n   775→\n   776→    const lines = formatDocHealthOutput(report);\n   777→    expect(lines).toContain('[FAIL] Root AGENTS.md not found');\n   778→  });\n   779→});\n   780→\n   781→// ─── checkStoryDocFreshness with git ──────────────────────────────────────────\n   782→\n   783→describe('checkStoryDocFreshness with git repo', () => {\n   784→  let gitDir: string;\n   785→\n   786→  beforeEach(() => {\n   787→    gitDir = mkdtempSync(join(tmpdir(), 'ch-doc-health-git-'));\n   788→    // Initialize a git repo with some files\n   789→    const { execSync } = require('node:child_process') as typeof import('node:child_process');\n   790→    execSync('git init -q', { cwd: gitDir });\n   791→    execSync('git config user.email \"test@test.com\"', { cwd: gitDir });\n   792→    execSync('git config user.name \"Test\"', { cwd: gitDir });\n   793→\n   794→    // Create initial files and commit\n   795→    mkdirSync(join(gitDir, 'src'), { recursive: true });\n   796→    writeFileSync(join(gitDir, 'src', 'a.ts'), 'code a');\n   797→    writeFileSync(join(gitDir, 'src', 'b.ts'), 'code b');\n   798→    writeFileSync(join(gitDir, 'src', 'c.ts'), 'code c');\n   799→    writeFileSync(join(gitDir, 'AGENTS.md'), '# Agents');\n   800→    execSync('git add -A && git commit -q -m \"init\"', { cwd: gitDir });\n   801→\n   802→    // Make a change and commit\n   803→    writeFileSync(join(gitDir, 'src', 'a.ts'), 'code a modified');\n   804→    execSync('git add -A && git commit -q -m \"modify a\"', { cwd: gitDir });\n   805→  });\n   806→\n   807→  afterEach(() => {\n   808→    rmSync(gitDir, { recursive: true, force: true });\n   809→  });\n   810→\n   811→  it('uses git to detect changed modules', () => {\n   812→    const report = checkStoryDocFreshness('test-story', gitDir);\n   813→    // Should detect src as a changed module via git\n   814→    expect(report.documents.length).toBeGreaterThanOrEqual(1);\n   815→  });\n   816→\n   817→  it('detects stale AGENTS.md when source files are not mentioned', () => {\n   818→    // AGENTS.md has content '# Agents' which doesn't mention a.ts, b.ts, c.ts\n   819→    const report = checkStoryDocFreshness('test-story', gitDir);\n   820→    expect(report.passed).toBe(false);\n   821→  });\n   822→});\n   823→\n   824→// ─── printDocHealthOutput ────────────────────────────────────────────────────\n   825→\n   826→describe('printDocHealthOutput', () => {\n   827→  it('calls output functions without error', () => {\n   828→    const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n   829→\n   830→    const report: DocHealthReport = {\n   831→      documents: [\n   832→        { path: 'AGENTS.md', grade: 'fresh', lastModified: new Date(), codeLastModified: new Date(), reason: 'Up to date' },\n   833→        { path: 'docs/quality/bad.md', grade: 'stale', lastModified: new Date(), codeLastModified: null, reason: 'Missing header' },\n   834→        { path: 'AGENTS.md', grade: 'missing', lastModified: null, codeLastModified: null, reason: 'Not found' },\n   835→      ],\n   836→      summary: { fresh: 1, stale: 1, missing: 1, total: 3 },\n   837→      passed: false,\n   838→      scanDurationMs: 10,\n   839→    };\n   840→\n   841→    printDocHealthOutput(report);\n   842→    expect(consoleSpy).toHaveBeenCalled();\n   843→\n   844→    consoleSpy.mockRestore();\n   845→  });\n   846→});\n   847→"}]},"parent_tool_use_id":"toolu_01JdxXvgowBNhnosQk7Q9BkR","session_id":"849556cc-0fdf-4120-9ec0-a67b358cdbd5","u