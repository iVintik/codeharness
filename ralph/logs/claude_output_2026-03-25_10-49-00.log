{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AhxaGygkW2JGvZjiY1hZUc","type":"tool_result","content":"     1→#!/bin/bash\n     2→# codeharness: PostToolUse hook for Write and Edit tools\n     3→# Prompts agent to verify OTLP instrumentation after code changes.\n     4→# Must complete within 500ms (NFR1).\n     5→# Canonical pattern: valid JSON output always, fail open on errors.\n     6→\n     7→# Error trap: fail open on script errors\n     8→trap 'exit 0' ERR\n     9→\n    10→STATE_FILE=\".claude/codeharness.local.md\"\n    11→\n    12→# If harness not initialized, skip (fail open)\n    13→if [ ! -f \"$STATE_FILE\" ]; then\n    14→  echo \"[WARN] State file not found — skipping post-write check\" >&2\n    15→  exit 0\n    16→fi\n    17→\n    18→# Read hook input to check what file was written\n    19→HOOK_INPUT=$(cat)\n    20→FILE_PATH=$(echo \"$HOOK_INPUT\" | grep -o '\"file_path\"[[:space:]]*:[[:space:]]*\"[^\"]*\"' | head -1 | sed 's/.*\"file_path\"[[:space:]]*:[[:space:]]*\"//' | sed 's/\"$//' || true)\n    21→\n    22→# Only prompt for source code files, not config/docs\n    23→case \"$FILE_PATH\" in\n    24→  *.ts|*.js|*.tsx|*.jsx|*.py|*.go|*.rs)\n    25→    ;;\n    26→  *)\n    27→    # Non-source file, skip\n    28→    exit 0\n    29→    ;;\n    30→esac\n    31→\n    32→# Python-specific: check for bare exception swallowing\n    33→# grep -P with lookahead isn't portable; instead use awk to detect\n    34→# \"except Exception:\" followed by a line containing only \"pass\" or \"...\"\n    35→BARE_EXCEPT_WARNING=\"\"\n    36→if [[ \"$FILE_PATH\" == *.py ]]; then\n    37→  BARE_EXCEPT_MATCHES=$(awk '/except[[:space:]]+Exception[[:space:]]*:/{found=NR; next} found && NR==found+1 && /^[[:space:]]*(pass|\\.\\.\\.)([[:space:]]*#.*)?$/{print found\": except Exception swallowed\"; found=0; next} {found=0}' \"$FILE_PATH\" 2>/dev/null || true)\n    38→  if [ -n \"$BARE_EXCEPT_MATCHES\" ]; then\n    39→    BARE_EXCEPT_WARNING=\"\\\\n[WARN] Bare 'except Exception: pass/...' detected in $FILE_PATH\\\\n       Handle the error or add a # IGNORE: comment\"\n    40→  fi\n    41→fi\n    42→\n    43→# Build message\n    44→MSG=\"New code written. Verify OTLP instrumentation is present.\\\\n-> Check that new endpoints emit traces and structured logs.\"\n    45→if [ -n \"$BARE_EXCEPT_WARNING\" ]; then\n    46→  MSG=\"${MSG}${BARE_EXCEPT_WARNING}\"\n    47→fi\n    48→\n    49→echo \"{\\\"message\\\": \\\"${MSG}\\\"}\"\n    50→"}]},"parent_tool_use_id":null,"session_id":"3fcb2b1c-e710-401b-91ab-b64a3e9a3996","uuid":"42165320-03fa-4e5e-96aa-74cfa49e8882","timestamp":"2026-03-25T07:09:33.255Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ivintik/dev/personal/codeharness/hooks/post-write-check.sh","content":"#!/bin/bash\n# codeharness: PostToolUse hook for Write and Edit tools\n# Prompts agent to verify OTLP instrumentation after code changes.\n# Must complete within 500ms (NFR1).\n# Canonical pattern: valid JSON output always, fail open on errors.\n\n# Error trap: fail open on script errors\ntrap 'exit 0' ERR\n\nSTATE_FILE=\".claude/codeharness.local.md\"\n\n# If harness not initialized, skip (fail open)\nif [ ! -f \"$STATE_FILE\" ]; then\n  echo \"[WARN] State file not found — skipping post-write check\" >&2\n  exit 0\nfi\n\n# Read hook input to check what file was written\nHOOK_INPUT=$(cat)\nFILE_PATH=$(echo \"$HOOK_INPUT\" | grep -o '\"file_path\"[[:space:]]*:[[:space:]]*\"[^\"]*\"' | head -1 | sed 's/.*\"file_path\"[[:space:]]*:[[:space:]]*\"//' | sed 's/\"$//' || true)\n\n# Only prompt for source code files, not config/docs\ncase \"$FILE_PATH\" in\n  *.ts|*.js|*.tsx|*.jsx|*.py|*.go|*.rs)\n    ;;\n  *)\n    # Non-source file, skip\n    exit 0\n    ;;\nesac\n\n# Python-specific: check for bare exception swallowing\n# grep -P with lookahead isn't portable; instead use awk to detect\n# \"except Exception:\" followed by a line containing only \"pass\" or \"...\"\nBARE_EXCEPT_WARNING=\"\"\nif [[ \"$FILE_PATH\" == *.py ]]; then\n  BARE_EXCEPT_MATCHES=$(awk '/except[[:space:]]+Exception[[:space:]]*:/{found=NR; next} found && NR==found+1 && /^[[:space:]]*(pass|\\.\\.\\.)([[:space:]]*#.*)?$/{print found\": except Exception swallowed\"; found=0; next} {found=0}' \"$FILE_PATH\" 2>/dev/null || true)\n  if [ -n \"$BARE_EXCEPT_MATCHES\" ]; then\n    BARE_EXCEPT_WARNING=\"\\\\n[WARN] Bare 'except Exception: pass/...' detected in $FILE_PATH\\\\n       Handle the error or add a # IGNORE: comment\"\n  fi\nfi\n\n# Build message\nMSG=\"New code written. Verify OTLP instrumentation is present.\\\\n-> Check that new endpoints emit traces and structured logs.\"\nif [ -n \"$BARE_EXCEPT_WARNING\" ]; then\n  MSG=\"${MSG}${BARE_EXCEPT_WARNING}\"\nfi\n\necho \"{\\\"message\\\": \\\"${MSG}\\\"}\"\n","numLines":50,"startLine":1,"totalLines":50}}}
