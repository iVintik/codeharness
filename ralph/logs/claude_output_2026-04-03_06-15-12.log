{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015yLhcwjKshRP2mKS17CVyF","type":"tool_result","content":"1\t/**\n2\t * Retro-to-Sprint pipeline: processes retro action items into TD stories\n3\t * and manages the persistent epic-TD in sprint state.\n4\t */\n5\t\n6\timport { writeFileSync, readFileSync, existsSync } from 'node:fs';\n7\timport { join } from 'node:path';\n8\timport { parseRetroSections, isDuplicate } from './retro-parser.js';\n9\timport type { RetroSectionItem } from './retro-parser.js';\n10\timport type { SprintState, EpicState, StoryState } from '../types/state.js';\n11\t\n12\t/** Result of processing retro action items */\n13\texport interface ProcessRetroResult {\n14\t  readonly updatedState: SprintState;\n15\t  readonly created: string[];\n16\t  readonly skipped: string[];\n17\t  readonly backlogAppended: string[];\n18\t}\n19\t\n20\t/**\n21\t * Generate a slug from item text.\n22\t * Lowercase, replace non-alphanumeric with hyphens, truncate to 40 chars, trim trailing hyphens.\n23\t */\n24\texport function generateSlug(text: string): string {\n25\t  const slug = text\n26\t    .toLowerCase()\n27\t    .replace(/[^a-z0-9]+/g, '-')\n28\t    .replace(/^-+|-+$/g, '')\n29\t    .slice(0, 40)\n30\t    .replace(/-+$/, '');\n31\t  return slug || 'untitled';\n32\t}\n33\t\n34\t/**\n35\t * Scan existing TD-* story keys and return the next story number.\n36\t * Returns max existing N + 1, or 1 if none exist.\n37\t */\n38\texport function nextTdStoryNumber(state: SprintState): number {\n39\t  let max = 0;\n40\t  for (const key of Object.keys(state.stories)) {\n41\t    const match = key.match(/^TD-(\\d+)-/);\n42\t    if (match) {\n43\t      const n = parseInt(match[1], 10);\n44\t      if (n > max) max = n;\n45\t    }\n46\t  }\n47\t  return max + 1;\n48\t}\n49\t\n50\t/**\n51\t * Ensure epic-TD exists in state. Creates it if absent.\n52\t * Returns updated state (immutable — returns new object).\n53\t */\n54\texport function ensureEpicTd(state: SprintState): SprintState {\n55\t  if (state.epics['epic-TD']) return state;\n56\t  const epicTd: EpicState = {\n57\t    status: 'in-progress',\n58\t    storiesTotal: 0,\n59\t    storiesDone: 0,\n60\t  };\n61\t  return {\n62\t    ...state,\n63\t    epics: { ...state.epics, 'epic-TD': epicTd },\n64\t  };\n65\t}\n66\t\n67\t/**\n68\t * Add a TD story to sprint state. Increments epic-TD.storiesTotal.\n69\t * Returns updated state.\n70\t */\n71\texport function createTdStory(state: SprintState, slug: string): SprintState {\n72\t  const num = nextTdStoryNumber(state);\n73\t  const key = `TD-${num}-${slug}`;\n74\t  const story: StoryState = {\n75\t    status: 'backlog',\n76\t    attempts: 0,\n77\t    lastAttempt: null,\n78\t    lastError: null,\n79\t    proofPath: null,\n80\t    acResults: null,\n81\t  };\n82\t  const currentEpic = state.epics['epic-TD'];\n83\t  const updatedEpic: EpicState = {\n84\t    status: 'in-progress',\n85\t    storiesTotal: (currentEpic?.storiesTotal ?? 0) + 1,\n86\t    storiesDone: currentEpic?.storiesDone ?? 0,\n87\t  };\n88\t  return {\n89\t    ...state,\n90\t    stories: { ...state.stories, [key]: story },\n91\t    epics: { ...state.epics, 'epic-TD': updatedEpic },\n92\t  };\n93\t}\n94\t\n95\t/**\n96\t * Append backlog items to tech-debt-backlog.md at project root.\n97\t * Creates the file with a header if it doesn't exist.\n98\t */\n99\tfunction appendToBacklogFile(items: string[], projectRoot: string): void {\n100\t  const filePath = join(projectRoot, 'tech-debt-backlog.md');\n101\t  const date = new Date().toISOString().slice(0, 10);\n102\t\n103\t  let content = '';\n104\t  if (existsSync(filePath)) {\n105\t    content = readFileSync(filePath, 'utf-8');\n106\t  } else {\n107\t    content = '## Backlog Items (auto-appended from retros)\\n\\n';\n108\t  }\n109\t\n110\t  for (const item of items) {\n111\t    content += `- [${date}] ${item}\\n`;\n112\t  }\n113\t\n114\t  writeFileSync(filePath, content, 'utf-8');\n115\t}\n116\t\n117\t/**\n118\t * Get existing TD story titles from state for deduplication.\n119\t */\n120\tfunction getExistingTdTitles(state: SprintState): string[] {\n121\t  return Object.keys(state.stories)\n122\t    .filter(k => k.startsWith('TD-'))\n123\t    .map(k => k.replace(/^TD-\\d+-/, '').replace(/-/g, ' '));\n124\t}\n125\t\n126\t/**\n127\t * Process retro action items into TD stories and backlog entries.\n128\t *\n129\t * - fix-now and fix-soon items: create TD-N-slug stories (with dedup check)\n130\t * - backlog items: append to tech-debt-backlog.md (no sprint-state stories)\n131\t */\n132\texport function processRetroActionItems(\n133\t  retroContent: string,\n134\t  state: SprintState,\n135\t  projectRoot?: string,\n136\t): ProcessRetroResult {\n137\t  const sectionItems = parseRetroSections(retroContent);\n138\t  const created: string[] = [];\n139\t  const skipped: string[] = [];\n140\t  const backlogAppended: string[] = [];\n141\t\n142\t  let current = ensureEpicTd(state);\n143\t\n144\t  const backlogItems: string[] = [];\n145\t\n146\t  for (const item of sectionItems) {\n147\t    if (item.section === 'backlog') {\n148\t      backlogItems.push(item.text);\n149\t      backlogAppended.push(item.text);\n150\t      continue;\n151\t    }\n152\t\n153\t    // fix-now or fix-soon: create TD story\n154\t    const existingTitles = getExistingTdTitles(current);\n155\t    const dedupResult = isDuplicate(item.text, existingTitles);\n156\t    if (dedupResult.duplicate) {\n157\t      console.log(`[INFO] Skipping duplicate: \"${item.text}\" (matches: \"${dedupResult.matchedTitle}\")`);\n158\t      skipped.push(item.text);\n159\t      continue;\n160\t    }\n161\t\n162\t    const slug = generateSlug(item.text);\n163\t    current = createTdStory(current, slug);\n164\t    created.push(item.text);\n165\t  }\n166\t\n167\t  // Append backlog items to file (only report as appended if actually written)\n168\t  if (backlogItems.length > 0 && projectRoot) {\n169\t    appendToBacklogFile(backlogItems, projectRoot);\n170\t  } else if (backlogItems.length > 0 && !projectRoot) {\n171\t    // No projectRoot — items were parsed but not persisted; clear appended list\n172\t    backlogAppended.length = 0;\n173\t  }\n174\t\n175\t  return { updatedState: current, created, skipped, backlogAppended };\n176\t}\n177\t"}]},"parent_tool_use_id":"toolu_01XpaP1HRJV63HnT5Mxey4dk","session_id":"3f15b50c-2c9b-40fa-9e63-9fad2199af43","uuid":"2dc6926d-fc23-4bd5-ad0d-4c6a7d752f1b","timestamp":"2026-04-03T02:17:41.999Z"}
