{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0144Ny3yK3BQGQ8xh8C6TXDk","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n     2→import { mkdtempSync, rmSync, writeFileSync, existsSync } from 'node:fs';\n     3→import { tmpdir } from 'node:os';\n     4→import { join } from 'node:path';\n     5→\n     6→// Mock all lib modules\n     7→vi.mock('../../../lib/stack-detect.js', async (importOriginal) => {\n     8→  const orig = await importOriginal<typeof import('../../../lib/stack-detect.js')>();\n     9→  return { ...orig, detectStack: vi.fn(orig.detectStack), detectStacks: vi.fn(orig.detectStacks), detectAppType: vi.fn(orig.detectAppType) };\n    10→});\n    11→\n    12→vi.mock('../docs-scaffold.js', async (importOriginal) => {\n    13→  const orig = await importOriginal<typeof import('../docs-scaffold.js')>();\n    14→  return { ...orig, getCoverageTool: vi.fn(orig.getCoverageTool), getStackLabel: vi.fn(orig.getStackLabel) };\n    15→});\n    16→\n    17→vi.mock('../../../lib/stack-path.js', () => ({\n    18→  getComposeFilePath: vi.fn(() => '/mock/.codeharness/stack/docker-compose.harness.yml'),\n    19→  ensureStackDir: vi.fn(),\n    20→}));\n    21→\n    22→vi.mock('../../../lib/docker.js', () => ({\n    23→  isDockerAvailable: vi.fn(() => true),\n    24→  isSharedStackRunning: vi.fn(() => false),\n    25→  startSharedStack: vi.fn(() => ({\n    26→    started: true,\n    27→    services: [{ name: 'otel-collector', status: 'running', port: '4317,4318' }],\n    28→  })),\n    29→  startCollectorOnly: vi.fn(() => ({\n    30→    started: true,\n    31→    services: [{ name: 'otel-collector', status: 'running', port: '4317,4318' }],\n    32→  })),\n    33→}));\n    34→\n    35→vi.mock('../../../lib/deps.js', () => ({\n    36→  installAllDependencies: vi.fn(() => [\n    37→    { name: 'showboat', displayName: 'Showboat', status: 'already-installed', version: '0.6.1' },\n    38→  ]),\n    39→  checkInstalled: vi.fn(() => ({ installed: true, version: '1.0.0' })),\n    40→  DEPENDENCY_REGISTRY: [\n    41→    {\n    42→      name: 'showboat',\n    43→      displayName: 'Showboat',\n    44→      installCommands: [{ cmd: 'pip', args: ['install', 'showboat'] }],\n    45→      checkCommand: { cmd: 'showboat', args: ['--version'] },\n    46→      critical: false,\n    47→    },\n    48→  ],\n    49→  CriticalDependencyError: class extends Error {\n    50→    constructor(d: string, r: string) { super(`Critical dependency '${d}' failed: ${r}`); this.name = 'CriticalDependencyError'; }\n    51→  },\n    52→}));\n    53→\n    54→vi.mock('../../../lib/beads.js', () => ({\n    55→  isBeadsInitialized: vi.fn(() => false),\n    56→  initBeads: vi.fn(),\n    57→  detectBeadsHooks: vi.fn(() => ({ hasHooks: false, hookTypes: [] })),\n    58→  configureHookCoexistence: vi.fn(),\n    59→  BeadsError: class extends Error {\n    60→    constructor(c: string, m: string) { super(`Beads failed: ${m}`); this.name = 'BeadsError'; }\n    61→  },\n    62→}));\n    63→\n    64→vi.mock('../../../lib/bmad.js', () => ({\n    65→  isBmadInstalled: vi.fn(() => false),\n    66→  installBmad: vi.fn(() => ({ status: 'installed', version: '6.0.0', patches_applied: [] })),\n    67→  applyAllPatches: vi.fn(() => []),\n    68→  detectBmadVersion: vi.fn(() => '6.0.0'),\n    69→  detectBmalph: vi.fn(() => ({ detected: false, files: [] })),\n    70→  BmadError: class extends Error {\n    71→    constructor(c: string, m: string) { super(`BMAD failed: ${m}`); this.name = 'BmadError'; }\n    72→  },\n    73→}));\n    74→\n    75→vi.mock('../../../lib/otlp.js', () => ({\n    76→  instrumentProject: vi.fn(() => ({\n    77→    status: 'configured',\n    78→    packages_installed: true,\n    79→    start_script_patched: true,\n    80→    env_vars_configured: true,\n    81→  })),\n    82→  configureOtlpEnvVars: vi.fn(),\n    83→}));\n    84→\n    85→vi.mock('../../../lib/templates.js', () => ({\n    86→  generateFile: vi.fn(),\n    87→}));\n    88→\n    89→vi.mock('../../../templates/readme.js', () => ({\n    90→  readmeTemplate: vi.fn(() => '# README'),\n    91→}));\n    92→\n    93→import { isDockerAvailable } from '../../../lib/docker.js';\n    94→import { installAllDependencies, CriticalDependencyError } from '../../../lib/deps.js';\n    95→import { isBeadsInitialized, BeadsError } from '../../../lib/beads.js';\n    96→import { readState, writeState, getDefaultState } from '../../../lib/state.js';\n    97→import { detectStack, detectStacks, detectAppType } from '../../../lib/stack-detect.js';\n    98→import { instrumentProject } from '../../../lib/otlp.js';\n    99→import { getCoverageTool } from '../docs-scaffold.js';\n   100→import { initProject } from '../init-project.js';\n   101→\n   102→const mockIsDockerAvailable = vi.mocked(isDockerAvailable);\n   103→const mockInstallAll = vi.mocked(installAllDependencies);\n   104→const mockIsBeadsInitialized = vi.mocked(isBeadsInitialized);\n   105→const mockDetectStack = vi.mocked(detectStack);\n   106→const mockDetectStacks = vi.mocked(detectStacks);\n   107→const mockInstrumentProject = vi.mocked(instrumentProject);\n   108→const mockGetCoverageTool = vi.mocked(getCoverageTool);\n   109→\n   110→let testDir: string;\n   111→let originalCwd: string;\n   112→\n   113→beforeEach(() => {\n   114→  testDir = mkdtempSync(join(tmpdir(), 'ch-init-project-test-'));\n   115→  originalCwd = process.cwd();\n   116→  process.chdir(testDir);\n   117→  vi.spyOn(console, 'log').mockImplementation(() => {});\n   118→  process.exitCode = undefined;\n   119→  // Reset mocks to default implementations\n   120→  mockIsDockerAvailable.mockReturnValue(true);\n   121→  mockInstallAll.mockReturnValue([\n   122→    { name: 'showboat', displayName: 'Showboat', status: 'already-installed', version: '0.6.1' },\n   123→  ]);\n   124→  mockIsBeadsInitialized.mockReturnValue(false);\n   125→});\n   126→\n   127→afterEach(() => {\n   128→  process.chdir(originalCwd);\n   129→  rmSync(testDir, { recursive: true, force: true });\n   130→  vi.restoreAllMocks();\n   131→  process.exitCode = undefined;\n   132→});\n   133→\n   134→describe('initProject — fresh init', () => {\n   135→  it('returns ok result with correct structure', async () => {\n   136→    writeFileSync(join(testDir, 'package.json'), '{}');\n   137→    const result = await initProject({\n   138→      projectDir: testDir,\n   139→      frontend: true,\n   140→      database: true,\n   141→      api: true,\n   142→      observability: false,\n   143→    });\n   144→    expect(result.success).toBe(true);\n   145→    if (result.success) {\n   146→      expect(result.data.status).toBe('ok');\n   147→      expect(result.data.stack).toBe('nodejs');\n   148→      expect(result.data.enforcement).toEqual({ frontend: true, database: true, api: true });\n   149→    }\n   150→  });\n   151→\n   152→  it('creates state file', async () => {\n   153→    writeFileSync(join(testDir, 'package.json'), '{}');\n   154→    await initProject({\n   155→      projectDir: testDir,\n   156→      frontend: true,\n   157→      database: true,\n   158→      api: true,\n   159→      observability: false,\n   160→    });\n   161→    const state = readState(testDir);\n   162→    expect(state.initialized).toBe(true);\n   163→    expect(state.stack).toBe('nodejs');\n   164→  });\n   165→\n   166→  it('includes beads result', async () => {\n   167→    writeFileSync(join(testDir, 'package.json'), '{}');\n   168→    const result = await initProject({\n   169→      projectDir: testDir,\n   170→      frontend: true,\n   171→      database: true,\n   172→      api: true,\n   173→      observability: false,\n   174→    });\n   175→    if (result.success) {\n   176→      expect(result.data.beads).toBeDefined();\n   177→      expect(result.data.beads!.status).toBe('initialized');\n   178→    }\n   179→  });\n   180→\n   181→  it('includes bmad result', async () => {\n   182→    writeFileSync(join(testDir, 'package.json'), '{}');\n   183→    const result = await initProject({\n   184→      projectDir: testDir,\n   185→      frontend: true,\n   186→      database: true,\n   187→      api: true,\n   188→      observability: false,\n   189→    });\n   190→    if (result.success) {\n   191→      expect(result.data.bmad).toBeDefined();\n   192→      expect(result.data.bmad!.status).toBe('installed');\n   193→    }\n   194→  });\n   195→\n   196→  it('includes dependencies result', async () => {\n   197→    writeFileSync(join(testDir, 'package.json'), '{}');\n   198→    const result = await initProject({\n   199→      projectDir: testDir,\n   200→      frontend: true,\n   201→      database: true,\n   202→      api: true,\n   203→      observability: false,\n   204→    });\n   205→    if (result.success) {\n   206→      expect(result.data.dependencies).toBeDefined();\n   207→      expect(result.data.dependencies!.length).toBeGreaterThan(0);\n   208→    }\n   209→  });\n   210→});\n   211→\n   212→describe('initProject — idempotent re-run', () => {\n   213→  it('detects already initialized and returns early', async () => {\n   214→    writeFileSync(join(testDir, 'package.json'), '{}');\n   215→    // First init\n   216→    await initProject({\n   217→      projectDir: testDir,\n   218→      frontend: true,\n   219→      database: true,\n   220→      api: true,\n   221→      observability: false,\n   222→    });\n   223→    // Second init (re-run)\n   224→    const result = await initProject({\n   225→      projectDir: testDir,\n   226→      frontend: true,\n   227→      database: true,\n   228→      api: true,\n   229→      observability: false,\n   230→    });\n   231→    expect(result.success).toBe(true);\n   232→    if (result.success) {\n   233→      expect(result.data.documentation.agents_md).toBe('exists');\n   234→    }\n   235→  });\n   236→});\n   237→\n   238→describe('initProject — critical failures', () => {\n   239→  it('returns ok with