{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QiS58mqwdY2gQqdpjBKtYF","type":"tool_result","content":"     1→import { spawn } from 'node:child_process';\n     2→import { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n     3→import { join, dirname } from 'node:path';\n     4→import { fileURLToPath } from 'node:url';\n     5→import { StringDecoder } from 'node:string_decoder';\n     6→import { Command } from 'commander';\n     7→import { fail, info, jsonOutput } from '../lib/output.js';\n     8→import { readSprintStatus } from '../lib/beads-sync.js';\n     9→import { generateRalphPrompt } from '../templates/ralph-prompt.js';\n    10→import { parseStreamLine } from '../lib/stream-parser.js';\n    11→import { startRenderer } from '../lib/ink-renderer.js';\n    12→import type { SprintInfo } from '../lib/ink-renderer.js';\n    13→import { getSprintState } from '../modules/sprint/index.js';\n    14→\n    15→const SPRINT_STATUS_REL = '_bmad-output/implementation-artifacts/sprint-status.yaml';\n    16→const STORY_KEY_PATTERN = /^\\d+-\\d+-/;\n    17→\n    18→/**\n    19→ * Resolves the path to ralph/ralph.sh relative to the package root.\n    20→ * In the built CLI, __dirname is dist/, so we go up one level.\n    21→ */\n    22→export function resolveRalphPath(): string {\n    23→  // Use import.meta.url to find the package root\n    24→  const currentFile = fileURLToPath(import.meta.url);\n    25→  const currentDir = dirname(currentFile);\n    26→  // From dist/ or src/commands/, go up to package root\n    27→  // In built mode: dist/index.js -> dist/ -> package root\n    28→  // In dev mode: src/commands/run.ts -> src/commands/ -> src/ -> package root\n    29→  let root = dirname(currentDir); // up from commands/ or dist/\n    30→  if (root.endsWith('/src') || root.endsWith('\\\\src')) {\n    31→    root = dirname(root); // up from src/ to package root\n    32→  }\n    33→  return join(root, 'ralph', 'ralph.sh');\n    34→}\n    35→\n    36→/**\n    37→ * Resolves the plugin directory path.\n    38→ * The plugin is scaffolded to .claude/ during init.\n    39→ */\n    40→export function resolvePluginDir(): string {\n    41→  return join(process.cwd(), '.claude');\n    42→}\n    43→\n    44→/**\n    45→ * Counts stories by status from sprint-status.yaml.\n    46→ */\n    47→export function countStories(statuses: Record<string, string>): {\n    48→  total: number;\n    49→  ready: number;\n    50→  done: number;\n    51→  inProgress: number;\n    52→  // eslint-disable-next-line @typescript-eslint/naming-convention\n    53→  verified: number;\n    54→} {\n    55→  let total = 0;\n    56→  let ready = 0;\n    57→  let done = 0;\n    58→  let inProgress = 0;\n    59→  // eslint-disable-next-line @typescript-eslint/naming-convention\n    60→  let verified = 0;\n    61→\n    62→  for (const [key, status] of Object.entries(statuses)) {\n    63→    if (!STORY_KEY_PATTERN.test(key)) continue;\n    64→    total++;\n    65→    if (status === 'backlog' || status === 'ready-for-dev') ready++;\n    66→    else if (status === 'done') done++;\n    67→    else if (status === 'in-progress' || status === 'review') inProgress++;\n    68→    else if (status === 'verifying') verified++;\n    69→  }\n    70→\n    71→  return { total, ready, done, inProgress, verified };\n    72→}\n    73→\n    74→/**\n    75→ * Builds the argument array for spawning Ralph.\n    76→ */\n    77→export function buildSpawnArgs(opts: {\n    78→  ralphPath: string;\n    79→  pluginDir: string;\n    80→  promptFile: string;\n    81→  maxIterations: number;\n    82→  timeout: number;\n    83→  iterationTimeout: number;\n    84→  calls: number;\n    85→  quiet: boolean;\n    86→  maxStoryRetries?: number;\n    87→  reset?: boolean;\n    88→}): string[] {\n    89→  const args = [\n    90→    opts.ralphPath,\n    91→    '--plugin-dir', opts.pluginDir,\n    92→    '--max-iterations', String(opts.maxIterations),\n    93→    '--timeout', String(opts.timeout),\n    94→    '--iteration-timeout', String(opts.iterationTimeout),\n    95→    '--calls', String(opts.calls),\n    96→    '--prompt', opts.promptFile,\n    97→  ];\n    98→\n    99→  if (opts.maxStoryRetries !== undefined) {\n   100→    args.push('--max-story-retries', String(opts.maxStoryRetries));\n   101→  }\n   102→\n   103→  if (opts.reset) {\n   104→    args.push('--reset');\n   105→  }\n   106→\n   107→  return args;\n   108→}\n   109→\n   110→export function registerRunCommand(program: Command): void {\n   111→  program\n   112→    .command('run')\n   113→    .description('Execute the autonomous coding loop')\n   114→    .option('--max-iterations <n>', 'Maximum loop iterations', '50')\n   115→    .option('--timeout <seconds>', 'Total loop timeout in seconds', '43200')\n   116→    .option('--iteration-timeout <minutes>', 'Per-iteration timeout in minutes', '30')\n   117→    .option('--quiet', 'Suppress terminal output (background mode)', false)\n   118→    .option('--calls <n>', 'Max API calls per hour', '100')\n   119→    .option('--max-story-retries <n>', 'Max retries per story before flagging', '10')\n   120→    .option('--reset', 'Clear retry counters, flagged stories, and circuit breaker before starting', false)\n   121→    .action(async (options, cmd) => {\n   122→      const globalOpts = cmd.optsWithGlobals();\n   123→      const isJson = !!globalOpts.json;\n   124→      const outputOpts = { json: isJson };\n   125→\n   126→      // 1. Resolve Ralph script path\n   127→      const ralphPath = resolveRalphPath();\n   128→      if (!existsSync(ralphPath)) {\n   129→        fail('Ralph loop not found — reinstall codeharness', outputOpts);\n   130→        process.exitCode = 1;\n   131→        return;\n   132→      }\n   133→\n   134→      // 2. Resolve plugin directory\n   135→      const pluginDir = resolvePluginDir();\n   136→      if (!existsSync(pluginDir)) {\n   137→        fail('Plugin directory not found — run codeharness init first', outputOpts);\n   138→        process.exitCode = 1;\n   139→        return;\n   140→      }\n   141→\n   142→      // 3. Read sprint status for story count\n   143→      const projectDir = process.cwd();\n   144→      const sprintStatusPath = join(projectDir, SPRINT_STATUS_REL);\n   145→      const statuses = readSprintStatus(projectDir);\n   146→      const counts = countStories(statuses);\n   147→\n   148→      if (counts.total === 0) {\n   149→        fail('No stories found in sprint-status.yaml — nothing to execute', outputOpts);\n   150→        process.exitCode = 1;\n   151→        return;\n   152→      }\n   153→\n   154→      info(`Starting autonomous execution — ${counts.ready} ready, ${counts.inProgress} in progress, ${counts.verified} verified, ${counts.done}/${counts.total} done`, outputOpts);\n   155→\n   156→      // 4. Parse and validate numeric options\n   157→      const maxIterations = parseInt(options.maxIterations, 10);\n   158→      const timeout = parseInt(options.timeout, 10);\n   159→      const iterationTimeout = parseInt(options.iterationTimeout, 10);\n   160→      const calls = parseInt(options.calls, 10);\n   161→      const maxStoryRetries = parseInt(options.maxStoryRetries, 10);\n   162→\n   163→      if (isNaN(maxIterations) || isNaN(timeout) || isNaN(iterationTimeout) || isNaN(calls) || isNaN(maxStoryRetries)) {\n   164→        fail('Invalid numeric option — --max-iterations, --timeout, --iteration-timeout, --calls, and --max-story-retries must be numbers', outputOpts);\n   165→        process.exitCode = 1;\n   166→        return;\n   167→      }\n   168→\n   169→      // 5. Generate prompt file (with flagged stories context if available)\n   170→      const promptFile = join(projectDir, 'ralph', '.harness-prompt.md');\n   171→\n   172→      // Read flagged stories file if it exists (retry counts are managed by ralph.sh)\n   173→      const flaggedFilePath = join(projectDir, 'ralph', '.flagged_stories');\n   174→\n   175→      let flaggedStories: string[] | undefined;\n   176→\n   177→      if (existsSync(flaggedFilePath)) {\n   178→        try {\n   179→          const flaggedContent = readFileSync(flaggedFilePath, 'utf-8');\n   180→          flaggedStories = flaggedContent.split('\\n').filter(s => s.trim().length > 0);\n   181→        } catch {\n   182→          // Ignore read errors\n   183→        }\n   184→      }\n   185→\n   186→      const promptContent = generateRalphPrompt({\n   187→        projectDir,\n   188→        sprintStatusPath,\n   189→        flaggedStories,\n   190→      });\n   191→      try {\n   192→        mkdirSync(dirname(promptFile), { recursive: true });\n   193→        writeFileSync(promptFile, promptContent, 'utf-8');\n   194→      } catch (err) {\n   195→        const message = err instanceof Error ? err.message : String(err);\n   196→        fail(`Failed to write prompt file: ${message}`, outputOpts);\n   197→        process.exitCode = 1;\n   198→        return;\n   199→      }\n   200→\n   201→      // 6. Build spawn arguments\n   202→      const args = buildSpawnArgs({\n   203→        ralphPath,\n   204→        pluginDir,\n   205→        promptFile,\n   206→        maxIterations,\n   207→        timeout,\n   208→        iterationTimeout,\n   209→        calls,\n   210→        quiet: options.quiet,\n   211→        maxStoryRetries,\n   212→        reset: options.reset,\n   213→      });\n   214→\n   215→      // 7. Set environment — stream-json is always the output format\n   216→      const env = { ...process.env };\n   217→      if (isJson) {\n   218→        env.CLAUDE_OUTPUT_FORMAT = 'stream-json';\n   219→      }\n   220→\n   221→      // 8. Spawn Ralph — pipe stdout/stderr through stream parser → Ink renderer\n   222→      // Declare renderer handle outside try so cleanup is always reachable\n   223→      const quiet = options.quiet;\n   224→      const rendererHandle = startRenderer({ quiet });\n   225→      let sprintStateInterval: ReturnType<typeof setInterval> | null = null;\n   226→\n   227→      try {\n   228→        // Read initial sprint state for the renderer header\n   229→        const initialState = getSprintState();\n   230→        if (initialState.success) {\n   231→          const s = initialState.data;\n   232→          const sprintInfo: SprintInfo = {\n   233→            storyKey: s.run.currentStory ?? '',\n   234→            phase: s.run.currentPhase ?? '',\n   235→            done: s.sprint.done,\n   236→            total: s.sprint.total,\n   237→          };\n   238→          rendererHandle.updateSprintState(sprintInfo);\n   239→        }\n   240→\n   241→        const child = spawn('bash', args, {\n   242→          stdio: quiet ? 'ignore' : ['inherit', 'pipe', 'pipe'],\n   243→          cwd: projectDir,\n   244→          env,\n   245→        });\n   246→\n   247→        if (!quiet && child.stdout && child.stderr) {\n   248→          // Buffer partial lines and feed through stream parser → Ink renderer.\n   249→          // StringDecoder handles multi-byte UTF-8 chars split across Buffer boundaries.\n   250→          const makeLineHandler = (): ((data: Buffer) => void) => {\n   251→            let partial = '';\n   252→            const decoder = new StringDecoder('utf8');\n   253→            return (data: Buffer): void => {\n   254→              const text = partial + decoder.write(data);\n   255→              const parts = text.split('\\n');\n   256→              partial = parts.pop() ?? '';\n   257→              for (const line of parts) {\n   258→                if (line.trim().length === 0) continue;\n   259→                const event = parseStreamLine(line);\n   260→                if (event) {\n   261→                  rendererHandle.update(event);\n   262→                }\n   263→              }\n   264→            };\n   265→          };\n   266→          child.stdout.on('data', makeLineHandler());\n   267→          child.stderr.on('data', makeLineHandler());\n   268→\n   269→          // Periodically refresh sprint state for the header display\n   270→          sprintStateInterval = setInterval(() => {\n   271→            try {\n   272→              const stateResult = getSprintState();\n   273→              if (stateResult.success) {\n   274→                const s = stateResult.data;\n   275→                const sprintInfo: SprintInfo = {\n   276→                  storyKey: s.run.currentStory ?? '',\n   277→                  phase: s.run.currentPhase ?? '',\n   278→                  done: s.sprint.done,\n   279→                  total: s.sprint.total,\n   280→                };\n   281→                rendererHandle.updateSprintState(sprintInfo);\n   282→              }\n   283→            } catch {\n   284→              // Ignore read errors during polling\n   285→            }\n   286→          }, 5_000);\n   287→        }\n   288→\n   289→        const exitCode = await new Promise<number>((resolve, reject) => {\n   290→          child.on('error', (err) => {\n   291→            if (sprintStateInterval) clearInterval(sprintStateInterval);\n   292→            rendererHandle.cleanup();\n   293→            reject(err);\n   294→          });\n   295→          child.on('close', (code) => {\n   296→            if (sprintStateInterval) clearInterval(sprintStateInterval);\n   297→            rendererHandle.cleanup();\n   298→            resolve(code ?? 1);\n   299→          });\n   300→        });\n   301→\n   302→        // 9. Handle JSON output on exit\n   303→        if (isJson) {\n   304→          const statusFile = join(projectDir, 'ralph', 'status.json');\n   305→          if (existsSync(statusFile)) {\n   306→            try {\n   307→              const statusData = JSON.parse(readFileSync(statusFile, 'utf-8'));\n   308→              const finalStatuses = readSprintStatus(projectDir);\n   309→              const finalCounts = countStories(finalStatuses);\n   310→              jsonOutput({\n   311→                status: statusData.status ?? (exitCode === 0 ? 'completed' : 'stopped'),\n   312→                iterations: statusData.loop_count ?? 0,\n   313→                storiesCompleted: finalCounts.done,\n   314→                storiesTotal: finalCounts.total,\n   315→                storiesRemaining: finalCounts.total - finalCounts.done,\n   316→                elapsedSeconds: statusData.elapsed_seconds ?? 0,\n   317→                flaggedStories: statusData.flagged_stories ?? [],\n   318→                exitReason: statusData.exit_reason ?? '',\n   319→              });\n   320→            } catch {\n   321→              jsonOutput({\n   322→                status: exitCode === 0 ? 'completed' : 'stopped',\n   323→                iterations: 0,\n   324→                storiesCompleted: 0,\n   325→                storiesTotal: counts.total,\n   326→                storiesRemaining: counts.total,\n   327→                elapsedSeconds: 0,\n   328→                flaggedStories: [],\n   329→                exitReason: 'status_file_unreadable',\n   330→              });\n   331→            }\n   332→          } else {\n   333→            // status.json not created (Ralph crashed early or never started)\n   334→            const finalStatuses = readSprintStatus(projectDir);\n   335→            const finalCounts = countStories(finalStatuses);\n   336→            jsonOutput({\n   337→              status: exitCode === 0 ? 'completed' : 'stopped',\n   338→              iterations: 0,\n   339→              storiesCompleted: finalCounts.done,\n   340→              storiesTotal: finalCounts.total,\n   341→              storiesRemaining: finalCounts.total - finalCounts.done,\n   342→              elapsedSeconds: 0,\n   343→              flaggedStories: [],\n   344→              exitReason: 'status_file_missing',\n   345→            });\n   346→          }\n   347→        }\n   348→\n   349→        process.exitCode = exitCode;\n   350→      } catch (err) {\n   351→        if (sprintStateInterval) clearInterval(sprintStateInterval);\n   352→        rendererHandle.cleanup();\n   353→        const message = err instanceof Error ? err.message : String(err);\n   354→        fail(`Failed to start Ralph: ${message}`, outputOpts);\n   355→        process.exitCode = 1;\n   356→      }\n   357→    });\n   358→}\n   359→"}]},"parent_tool_use_id":"toolu_01SSYRLyPH5AH8B6tXVc5VLG","session_id":"1eada203-6dd0-4cf1-909a-4daaca264b98","uuid":"a2344c1d-aa2d-4621-a108-f2a9f6942d56","timestamp":"2026-03-20T07:23:36.565Z"}
