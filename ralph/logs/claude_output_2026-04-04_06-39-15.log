{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Vurf5ervDSbXnJ3WTmSuht","type":"tool_result","content":"1\t/**\n2\t * SummaryBar — Ink component showing sprint-level summary.\n3\t *\n4\t * Displays done stories, active merge status, and pending epics\n5\t * in a single-line overview. Also renders lane completion lines.\n6\t * Pure presentational component — receives all data via props.\n7\t *\n8\t * @see Story 20.2: Summary Bar & Merge Status\n9\t */\n10\t\n11\timport React from 'react';\n12\timport { Text, Box } from 'ink';\n13\t\n14\t// --- Types ---\n15\t\n16\texport interface MergingEpicInfo {\n17\t  epicId: string;\n18\t  status: 'in-progress' | 'resolving' | 'complete';\n19\t  conflictCount?: number;\n20\t}\n21\t\n22\texport interface CompletedLaneInfo {\n23\t  laneIndex: number;\n24\t  epicId: string;\n25\t  storyCount: number;\n26\t  cost: number;\n27\t  elapsed: string;\n28\t}\n29\t\n30\texport interface SummaryBarProps {\n31\t  doneStories: string[];\n32\t  mergingEpic: MergingEpicInfo | null;\n33\t  pendingEpics: string[];\n34\t  completedLanes?: CompletedLaneInfo[];\n35\t}\n36\t\n37\t// --- Helpers ---\n38\t\n39\tfunction formatConflictText(count: number): string {\n40\t  return count === 1 ? '1 conflict' : `${count} conflicts`;\n41\t}\n42\t\n43\tfunction formatCost(cost: number): string {\n44\t  return `$${cost.toFixed(2)}`;\n45\t}\n46\t\n47\t// --- Component ---\n48\t\n49\texport function SummaryBar({ doneStories, mergingEpic, pendingEpics, completedLanes }: SummaryBarProps) {\n50\t  // Done section\n51\t  const doneSection = doneStories.length > 0\n52\t    ? doneStories.map(s => `${s} \\u2713`).join('  ')\n53\t    : '\\u2014';\n54\t\n55\t  // Merging section\n56\t  let mergingNode: React.ReactNode;\n57\t  if (!mergingEpic) {\n58\t    mergingNode = <Text dimColor>{'\\u2014'}</Text>;\n59\t  } else if (mergingEpic.status === 'resolving') {\n60\t    const conflictText = mergingEpic.conflictCount != null\n61\t      ? ` (resolving ${formatConflictText(mergingEpic.conflictCount)})`\n62\t      : '';\n63\t    mergingNode = <Text color=\"yellow\">{`${mergingEpic.epicId} \\u2192 main${conflictText} \\u25CC`}</Text>;\n64\t  } else if (mergingEpic.status === 'in-progress') {\n65\t    mergingNode = <Text>{`${mergingEpic.epicId} \\u2192 main \\u25CC`}</Text>;\n66\t  } else {\n67\t    // complete\n68\t    mergingNode = <Text color=\"green\">{`${mergingEpic.epicId} \\u2192 main \\u2713`}</Text>;\n69\t  }\n70\t\n71\t  // Pending section\n72\t  const pendingSection = pendingEpics.length > 0\n73\t    ? pendingEpics.join(', ')\n74\t    : '\\u2014';\n75\t\n76\t  return (\n77\t    <Box flexDirection=\"column\">\n78\t      <Text>\n79\t        <Text color=\"green\">{`Done: ${doneSection}`}</Text>\n80\t        <Text>{' \\u2502 '}</Text>\n81\t        <Text>{'Merging: '}</Text>\n82\t        {mergingNode}\n83\t        <Text>{' \\u2502 '}</Text>\n84\t        <Text dimColor>{`Pending: ${pendingSection}`}</Text>\n85\t      </Text>\n86\t      {completedLanes && completedLanes.length > 0 && completedLanes.map(lane => (\n87\t        <Text key={`lane-complete-${lane.laneIndex}`} color=\"green\">\n88\t          {`[OK] Lane ${lane.laneIndex}: Epic ${lane.epicId} complete (${lane.storyCount} stories, ${formatCost(lane.cost)}, ${lane.elapsed})`}\n89\t        </Text>\n90\t      ))}\n91\t    </Box>\n92\t  );\n93\t}\n94\t"}]},"parent_tool_use_id":"toolu_01TzQwpEV7uekTzzh7pB5DWd","session_id":"7e3ded59-6184-4f8b-8f55-ba5e63dae51f","uuid":"6a6ab793-1847-4a8b-8f94-fef738d7e92f","timestamp":"2026-04-04T02:49:34.677Z"}
