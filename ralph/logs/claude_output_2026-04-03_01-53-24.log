{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EiaSSm7rQ1nAp2ZAzbqG7v","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { parse } from 'yaml';\n3\timport { warn } from './output.js';\n4\timport { dispatchAgent, DispatchError } from './agent-dispatch.js';\n5\timport type { DispatchOptions, DispatchResult } from './agent-dispatch.js';\n6\timport type { SubagentDefinition } from './agent-resolver.js';\n7\timport type { ResolvedWorkflow, ResolvedTask, FlowStep, LoopBlock } from './workflow-parser.js';\n8\timport {\n9\t  readWorkflowState,\n10\t  writeWorkflowState,\n11\t} from './workflow-state.js';\n12\timport type { WorkflowState, TaskCheckpoint } from './workflow-state.js';\n13\timport { createIsolatedWorkspace } from './source-isolation.js';\n14\timport { generateTraceId, formatTracePrompt, recordTraceId } from './trace-id.js';\n15\timport { resolveSessionId, recordSessionId } from './session-manager.js';\n16\timport type { SessionLookupKey } from './session-manager.js';\n17\t\n18\t// --- Interfaces ---\n19\t\n20\t/**\n21\t * Configuration for the workflow engine.\n22\t */\n23\texport interface EngineConfig {\n24\t  /** The resolved workflow with tasks and flow steps. */\n25\t  workflow: ResolvedWorkflow;\n26\t  /** Pre-compiled agent definitions keyed by agent name. */\n27\t  agents: Record<string, SubagentDefinition>;\n28\t  /** Path to sprint-status.yaml for work item discovery. */\n29\t  sprintStatusPath: string;\n30\t  /** Optional path to issues.yaml for additional work items. */\n31\t  issuesPath?: string;\n32\t  /** Unique identifier for this engine run. */\n33\t  runId: string;\n34\t  /** Project root directory. Defaults to process.cwd(). */\n35\t  projectDir?: string;\n36\t}\n37\t\n38\t/**\n39\t * Result returned by executeWorkflow().\n40\t */\n41\texport interface EngineResult {\n42\t  /** Whether the workflow completed without errors. */\n43\t  success: boolean;\n44\t  /** Number of task dispatches completed. */\n45\t  tasksCompleted: number;\n46\t  /** Number of work items (stories/issues) processed. */\n47\t  storiesProcessed: number;\n48\t  /** Errors encountered during execution. */\n49\t  errors: EngineError[];\n50\t  /** Wall-clock duration of the entire workflow in milliseconds. */\n51\t  durationMs: number;\n52\t}\n53\t\n54\t/**\n55\t * Structured error recorded during workflow execution.\n56\t */\n57\texport interface EngineError {\n58\t  taskName: string;\n59\t  storyKey: string;\n60\t  code: string;\n61\t  message: string;\n62\t}\n63\t\n64\t/**\n65\t * A work item (story or issue) ready for execution.\n66\t */\n67\texport interface WorkItem {\n68\t  key: string;\n69\t  title?: string;\n70\t  source: 'sprint' | 'issues';\n71\t}\n72\t\n73\t// --- Constants ---\n74\t\n75\t/** Sentinel story key for per-run tasks. */\n76\tconst PER_RUN_SENTINEL = '__run__';\n77\t\n78\t/** DispatchError codes that should halt execution immediately. */\n79\tconst HALT_ERROR_CODES = new Set(['RATE_LIMIT', 'NETWORK', 'SDK_INIT']);\n80\t\n81\t// --- Work Item Loading ---\n82\t\n83\t/**\n84\t * Load work items from sprint-status.yaml and optionally issues.yaml.\n85\t *\n86\t * Stories are extracted from the `development_status` section of sprint-status.yaml.\n87\t * Issues are extracted from the `issues` array of issues.yaml.\n88\t *\n89\t * Only items with status `backlog` or `ready-for-dev` are included.\n90\t * Epic keys (`epic-*`) and retrospective keys (`*-retrospective`) are excluded.\n91\t *\n92\t * If issues.yaml does not exist, returns only stories (no error).\n93\t */\n94\texport function loadWorkItems(sprintStatusPath: string, issuesPath?: string): WorkItem[] {\n95\t  const items: WorkItem[] = [];\n96\t\n97\t  // --- Load stories from sprint-status.yaml ---\n98\t  if (existsSync(sprintStatusPath)) {\n99\t    let raw: string;\n100\t    try {\n101\t      raw = readFileSync(sprintStatusPath, 'utf-8');\n102\t    } catch { // IGNORE: unreadable file — warn and return empty\n103\t      warn(`workflow-engine: could not read sprint-status.yaml at ${sprintStatusPath}`);\n104\t      return items;\n105\t    }\n106\t\n107\t    let parsed: unknown;\n108\t    try {\n109\t      parsed = parse(raw);\n110\t    } catch { // IGNORE: malformed YAML — warn and return empty\n111\t      warn(`workflow-engine: invalid YAML in sprint-status.yaml at ${sprintStatusPath}`);\n112\t      return items;\n113\t    }\n114\t\n115\t    if (parsed && typeof parsed === 'object') {\n116\t      const data = parsed as Record<string, unknown>;\n117\t      const devStatus = data.development_status as Record<string, unknown> | undefined;\n118\t\n119\t      if (devStatus && typeof devStatus === 'object') {\n120\t        for (const [key, status] of Object.entries(devStatus)) {\n121\t          // Skip epic keys and retrospective keys\n122\t          if (key.startsWith('epic-')) continue;\n123\t          if (key.endsWith('-retrospective')) continue;\n124\t\n125\t          // Only include backlog or ready-for-dev\n126\t          if (status === 'backlog' || status === 'ready-for-dev') {\n127\t            items.push({ key, source: 'sprint' });\n128\t          }\n129\t        }\n130\t      }\n131\t    }\n132\t  }\n133\t\n134\t  // --- Load issues from issues.yaml ---\n135\t  if (issuesPath && existsSync(issuesPath)) {\n136\t    let raw: string;\n137\t    try {\n138\t      raw = readFileSync(issuesPath, 'utf-8');\n139\t    } catch { // IGNORE: unreadable issues file — warn and return what we have\n140\t      warn(`workflow-engine: could not read issues.yaml at ${issuesPath}`);\n141\t      return items;\n142\t    }\n143\t\n144\t    let parsed: unknown;\n145\t    try {\n146\t      parsed = parse(raw);\n147\t    } catch { // IGNORE: malformed issues YAML — warn and return what we have\n148\t      warn(`workflow-engine: invalid YAML in issues.yaml at ${issuesPath}`);\n149\t      return items;\n150\t    }\n151\t\n152\t    if (parsed && typeof parsed === 'object') {\n153\t      const data = parsed as Record<string, unknown>;\n154\t      const issuesList = data.issues as Array<Record<string, unknown>> | undefined;\n155\t\n156\t      if (Array.isArray(issuesList)) {\n157\t        for (const issue of issuesList) {\n158\t          if (issue && typeof issue === 'object') {\n159\t            const status = issue.status as string | undefined;\n160\t            if (status === 'backlog' || status === 'ready-for-dev') {\n161\t              items.push({\n162\t                key: issue.id as string,\n163\t                title: issue.title as string | undefined,\n164\t                source: 'issues',\n165\t              });\n166\t            }\n167\t          }\n168\t        }\n169\t      }\n170\t    }\n171\t  }\n172\t\n173\t  return items;\n174\t}\n175\t\n176\t// --- Single Task Dispatch ---\n177\t\n178\t/**\n179\t * Dispatch a single task for a specific work item (or per-run sentinel).\n180\t *\n181\t * Handles: trace ID generation, session resolution, source isolation,\n182\t * agent dispatch, state checkpointing, and cleanup.\n183\t *\n184\t * Returns the updated workflow state after recording the dispatch.\n185\t */\n186\texport async function dispatchTask(\n187\t  task: ResolvedTask,\n188\t  taskName: string,\n189\t  storyKey: string,\n190\t  definition: SubagentDefinition,\n191\t  state: WorkflowState,\n192\t  config: EngineConfig,\n193\t): Promise<WorkflowState> {\n194\t  const projectDir = config.projectDir ?? process.cwd();\n195\t\n196\t  // 1. Generate trace ID\n197\t  const traceId = generateTraceId(config.runId, state.iteration, taskName);\n198\t\n199\t  // 2. Format trace prompt\n200\t  const tracePrompt = formatTracePrompt(traceId);\n201\t\n202\t  // 3. Resolve session ID\n203\t  const sessionKey: SessionLookupKey = { taskName, storyKey };\n204\t  const sessionId = resolveSessionId(task.session, sessionKey, state);\n205\t\n206\t  // 4. Build dispatch options based on source_access\n207\t  let dispatchOptions: DispatchOptions;\n208\t  let workspace: Awaited<ReturnType<typeof createIsolatedWorkspace>> | null = null;\n209\t\n210\t  if (task.source_access === false) {\n211\t    workspace = await createIsolatedWorkspace({ runId: config.runId, storyFiles: [] });\n212\t    dispatchOptions = {\n213\t      ...workspace.toDispatchOptions(),\n214\t      sessionId,\n215\t      appendSystemPrompt: tracePrompt,\n216\t    };\n217\t  } else {\n218\t    dispatchOptions = {\n219\t      cwd: projectDir,\n220\t      sessionId,\n221\t      appendSystemPrompt: tracePrompt,\n222\t    };\n223\t  }\n224\t\n225\t  // 5. Construct prompt\n226\t  const prompt = storyKey === PER_RUN_SENTINEL\n227\t    ? `Execute task \"${taskName}\" for the current run.`\n228\t    : `Implement story ${storyKey}`;\n229\t\n230\t  // 6. Dispatch agent\n231\t  let result: DispatchResult;\n232\t  try {\n233\t    result = await dispatchAgent(definition, prompt, dispatchOptions);\n234\t  } finally {\n235\t    // Cleanup workspace regardless of dispatch success/failure\n236\t    if (workspace) {\n237\t      await workspace.cleanup();\n238\t    }\n239\t  }\n240\t\n241\t  // 7. Record session ID (if dispatch returned one)\n242\t  let updatedState = state;\n243\t  if (result.sessionId) {\n244\t    updatedState = recordSessionId(sessionKey, result.sessionId, updatedState);\n245\t  } else {\n246\t    // Append checkpoint manually when no session ID is returned\n247\t    const checkpoint: TaskCheckpoint = {\n248\t      task_name: taskName,\n249\t      story_key: storyKey,\n250\t      completed_at: new Date().toISOString(),\n251\t    };\n252\t    updatedState = {\n253\t      ...updatedState,\n254\t      tasks_completed: [...updatedState.tasks_completed, checkpoint],\n255\t    };\n256\t  }\n257\t\n258\t  // 8. Record trace ID\n259\t  updatedState = recordTraceId(traceId, updatedState);\n260\t\n261\t  // 9. Write state to disk\n262\t  writeWorkflowState(updatedState, projectDir);\n263\t\n264\t  return updatedState;\n265\t}\n266\t\n267\t// --- Flow Step Type Guard ---\n268\t\n269\tfunction isLoopBlock(step: FlowStep): step is LoopBlock {\n270\t  return typeof step === 'object' && step !== null && 'loop' in step;\n271\t}\n272\t\n273\t// --- Main Execution ---\n274\t\n275\t/**\n276\t * Execute a workflow sequentially: iterate through flow steps, dispatch tasks\n277\t * per-story or per-run, checkpoint state after each dispatch.\n278\t *\n279\t * Loop blocks are skipped with a warning (story 5-2).\n280\t *\n281\t * Returns an EngineResult summarizing the execution.\n282\t */\n283\texport async function executeWorkflow(config: EngineConfig): Promise<EngineResult> {\n284\t  const startMs = Date.now();\n285\t  const projectDir = config.projectDir ?? process.cwd();\n286\t  const errors: EngineError[] = [];\n287\t  let tasksCompleted = 0;\n288\t  const processedStories = new Set<string>();\n289\t\n290\t  // 1. Read or initialize workflow state\n291\t  let state = readWorkflowState(projectDir);\n292\t  state = {\n293\t    ...state,\n294\t    phase: 'executing',\n295\t    started: state.started || new Date().toISOString(),\n296\t    workflow_name: config.workflow.flow.filter((s) => typeof s === 'string').join(' -> '),\n297\t  };\n298\t  writeWorkflowState(state, projectDir);\n299\t\n300\t  // 2. Load work items\n301\t  const workItems = loadWorkItems(config.sprintStatusPath, config.issuesPath);\n302\t\n303\t  // 3. Iterate through flow steps\n304\t  let halted = false;\n305\t  for (const step of config.workflow.flow) {\n306\t    if (halted) break;\n307\t\n308\t    // Skip loop blocks (story 5-2)\n309\t    if (isLoopBlock(step)) {\n310\t      warn('workflow-engine: loop blocks are not yet implemented (story 5-2), skipping');\n311\t      continue;\n312\t    }\n313\t\n314\t    // step is a string task name\n315\t    const taskName = step;\n316\t    const task = config.workflow.tasks[taskName];\n317\t\n318\t    if (!task) {\n319\t      warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n320\t      continue;\n321\t    }\n322\t\n323\t    // Look up the agent definition\n324\t    const definition = config.agents[task.agent];\n325\t    if (!definition) {\n326\t      warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n327\t      continue;\n328\t    }\n329\t\n330\t    if (task.scope === 'per-run') {\n331\t      // Per-run: dispatch once with sentinel key\n332\t      try {\n333\t        state = await dispatchTask(task, taskName, PER_RUN_SENTINEL, definition, state, config);\n334\t        tasksCompleted++;\n335\t      } catch (err: unknown) {\n336\t        const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n337\t        errors.push(engineError);\n338\t\n339\t        // Record error checkpoint in state (AC #13)\n340\t        state = recordErrorInState(state, taskName, PER_RUN_SENTINEL, engineError);\n341\t        writeWorkflowState(state, projectDir);\n342\t\n343\t        // Halt on critical errors\n344\t        if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n345\t          halted = true;\n346\t        }\n347\t      }\n348\t    } else {\n349\t      // Per-story: dispatch once per work item\n350\t      for (const item of workItems) {\n351\t        processedStories.add(item.key);\n352\t        try {\n353\t          state = await dispatchTask(task, taskName, item.key, definition, state, config);\n354\t          tasksCompleted++;\n355\t        } catch (err: unknown) {\n356\t          const engineError = handleDispatchError(err, taskName, item.key);\n357\t          errors.push(engineError);\n358\t\n359\t          // Record error checkpoint in state (AC #13)\n360\t          state = recordErrorInState(state, taskName, item.key, engineError);\n361\t          writeWorkflowState(state, projectDir);\n362\t\n363\t          // Halt on critical errors, continue on UNKNOWN\n364\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n365\t            halted = true;\n366\t            break;\n367\t          }\n368\t          // UNKNOWN errors: record and continue to next story\n369\t          continue;\n370\t        }\n371\t      }\n372\t    }\n373\t  }\n374\t\n375\t  // 4. Set final phase if no errors\n376\t  if (errors.length === 0) {\n377\t    state = { ...state, phase: 'completed' };\n378\t    writeWorkflowState(state, projectDir);\n379\t  }\n380\t\n381\t  // 5. Return result\n382\t  return {\n383\t    success: errors.length === 0,\n384\t    tasksCompleted,\n385\t    storiesProcessed: processedStories.size,\n386\t    errors,\n387\t    durationMs: Date.now() - startMs,\n388\t  };\n389\t}\n390\t\n391\t// --- Error Handling ---\n392\t\n393\t/**\n394\t * Record a dispatch error in workflow state: set phase to \"error\" and append\n395\t * a TaskCheckpoint with the error details (AC #13).\n396\t */\n397\tfunction recordErrorInState(\n398\t  state: WorkflowState,\n399\t  taskName: string,\n400\t  storyKey: string,\n401\t  error: EngineError,\n402\t): WorkflowState {\n403\t  const errorCheckpoint: TaskCheckpoint = {\n404\t    task_name: taskName,\n405\t    story_key: storyKey,\n406\t    completed_at: new Date().toISOString(),\n407\t  };\n408\t  return {\n409\t    ...state,\n410\t    phase: 'error',\n411\t    tasks_completed: [...state.tasks_completed, errorCheckpoint],\n412\t  };\n413\t}\n414\t\n415\tfunction handleDispatchError(err: unknown, taskName: string, storyKey: string): EngineError {\n416\t  if (err instanceof DispatchError) {\n417\t    return {\n418\t      taskName,\n419\t      storyKey,\n420\t      code: err.code,\n421\t      message: err.message,\n422\t    };\n423\t  }\n424\t\n425\t  const message = err instanceof Error ? err.message : String(err);\n426\t  return {\n427\t    taskName,\n428\t    storyKey,\n429\t    code: 'UNKNOWN',\n430\t    message,\n431\t  };\n432\t}\n433\t"}]},"parent_tool_use_id":"toolu_01CvZPYtXoZGoSJBzrD2Q4bs","session_id":"7bb08296-a865-42eb-9710-ebdb6ccedbda","uuid":"c8d1b8a4-0656-4dd3-a9bc-041007464403","timestamp":"2026-04-02T22:04:40.877Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BKK28yJsz4vN3Ffcr2QX74","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach } from 'vitest';\n2\t\n3\t// --- Hoisted Mocks ---\n4\t\n5\tconst {\n6\t  mockDispatchAgent,\n7\t  mockReadWorkflowState,\n8\t  mockWriteWorkflowState,\n9\t  mockCreateIsolatedWorkspace,\n10\t  mockGenerateTraceId,\n11\t  mockFormatTracePrompt,\n12\t  mockRecordTraceId,\n13\t  mockResolveSessionId,\n14\t  mockRecordSessionId,\n15\t  mockWarn,\n16\t  mockReadFileSync,\n17\t  mockExistsSync,\n18\t  mockParse,\n19\t} = vi.hoisted(() => ({\n20\t  mockDispatchAgent: vi.fn(),\n21\t  mockReadWorkflowState: vi.fn(),\n22\t  mockWriteWorkflowState: vi.fn(),\n23\t  mockCreateIsolatedWorkspace: vi.fn(),\n24\t  mockGenerateTraceId: vi.fn(),\n25\t  mockFormatTracePrompt: vi.fn(),\n26\t  mockRecordTraceId: vi.fn(),\n27\t  mockResolveSessionId: vi.fn(),\n28\t  mockRecordSessionId: vi.fn(),\n29\t  mockWarn: vi.fn(),\n30\t  mockReadFileSync: vi.fn(),\n31\t  mockExistsSync: vi.fn(),\n32\t  mockParse: vi.fn(),\n33\t}));\n34\t\n35\tvi.mock('../agent-dispatch.js', () => ({\n36\t  dispatchAgent: mockDispatchAgent,\n37\t  DispatchError: class DispatchError extends Error {\n38\t    public readonly code: string;\n39\t    public readonly agentName: string;\n40\t    public readonly cause: unknown;\n41\t    constructor(message: string, code: string, agentName: string, cause: unknown) {\n42\t      super(message);\n43\t      this.name = 'DispatchError';\n44\t      this.code = code;\n45\t      this.agentName = agentName;\n46\t      this.cause = cause;\n47\t    }\n48\t  },\n49\t}));\n50\t\n51\tvi.mock('../workflow-state.js', () => ({\n52\t  readWorkflowState: mockReadWorkflowState,\n53\t  writeWorkflowState: mockWriteWorkflowState,\n54\t  getDefaultWorkflowState: () => ({\n55\t    workflow_name: '',\n56\t    started: '',\n57\t    iteration: 0,\n58\t    phase: 'idle',\n59\t    tasks_completed: [],\n60\t    evaluator_scores: [],\n61\t    circuit_breaker: { triggered: false, reason: null, score_history: [] },\n62\t    trace_ids: [],\n63\t  }),\n64\t}));\n65\t\n66\tvi.mock('../source-isolation.js', () => ({\n67\t  createIsolatedWorkspace: mockCreateIsolatedWorkspace,\n68\t}));\n69\t\n70\tvi.mock('../trace-id.js', () => ({\n71\t  generateTraceId: mockGenerateTraceId,\n72\t  formatTracePrompt: mockFormatTracePrompt,\n73\t  recordTraceId: mockRecordTraceId,\n74\t}));\n75\t\n76\tvi.mock('../session-manager.js', () => ({\n77\t  resolveSessionId: mockResolveSessionId,\n78\t  recordSessionId: mockRecordSessionId,\n79\t}));\n80\t\n81\tvi.mock('../output.js', () => ({\n82\t  warn: mockWarn,\n83\t}));\n84\t\n85\tvi.mock('node:fs', () => ({\n86\t  readFileSync: mockReadFileSync,\n87\t  existsSync: mockExistsSync,\n88\t}));\n89\t\n90\tvi.mock('yaml', () => ({\n91\t  parse: mockParse,\n92\t}));\n93\t\n94\timport {\n95\t  executeWorkflow,\n96\t  loadWorkItems,\n97\t  dispatchTask,\n98\t} from '../workflow-engine.js';\n99\timport type {\n100\t  EngineConfig,\n101\t  WorkItem,\n102\t} from '../workflow-engine.js';\n103\timport type { WorkflowState } from '../workflow-state.js';\n104\timport type { ResolvedWorkflow, ResolvedTask } from '../workflow-parser.js';\n105\timport type { SubagentDefinition } from '../agent-resolver.js';\n106\t\n107\t// --- Helpers ---\n108\t\n109\tfunction makeDefaultState(overrides?: Partial<WorkflowState>): WorkflowState {\n110\t  return {\n111\t    workflow_name: '',\n112\t    started: '',\n113\t    iteration: 0,\n114\t    phase: 'idle',\n115\t    tasks_completed: [],\n116\t    evaluator_scores: [],\n117\t    circuit_breaker: { triggered: false, reason: null, score_history: [] },\n118\t    trace_ids: [],\n119\t    ...overrides,\n120\t  };\n121\t}\n122\t\n123\tfunction makeDefinition(overrides?: Partial<SubagentDefinition>): SubagentDefinition {\n124\t  return {\n125\t    name: 'test-agent',\n126\t    model: 'claude-sonnet-4-20250514',\n127\t    instructions: 'You are a test agent.',\n128\t    disallowedTools: [],\n129\t    bare: true,\n130\t    ...overrides,\n131\t  };\n132\t}\n133\t\n134\tfunction makeTask(overrides?: Partial<ResolvedTask>): ResolvedTask {\n135\t  return {\n136\t    agent: 'dev',\n137\t    scope: 'per-story',\n138\t    session: 'fresh',\n139\t    source_access: true,\n140\t    ...overrides,\n141\t  };\n142\t}\n143\t\n144\tfunction makeConfig(overrides?: Partial<EngineConfig>): EngineConfig {\n145\t  return {\n146\t    workflow: {\n147\t      tasks: {\n148\t        implement: makeTask(),\n149\t        verify: makeTask({ scope: 'per-run', source_access: false }),\n150\t      },\n151\t      flow: ['implement', 'verify'],\n152\t    },\n153\t    agents: {\n154\t      dev: makeDefinition(),\n155\t    },\n156\t    sprintStatusPath: '/project/sprint-status.yaml',\n157\t    runId: 'run-001',\n158\t    projectDir: '/project',\n159\t    ...overrides,\n160\t  };\n161\t}\n162\t\n163\tfunction setupDefaultMocks() {\n164\t  mockReadWorkflowState.mockReturnValue(makeDefaultState());\n165\t  mockWriteWorkflowState.mockImplementation(() => {});\n166\t\n167\t  mockGenerateTraceId.mockReturnValue('ch-run-001-0-implement');\n168\t  mockFormatTracePrompt.mockReturnValue('[TRACE] trace_id=ch-run-001-0-implement');\n169\t  mockRecordTraceId.mockImplementation((traceId: string, state: WorkflowState) => ({\n170\t    ...state,\n171\t    trace_ids: [...(state.trace_ids ?? []), traceId],\n172\t  }));\n173\t\n174\t  mockResolveSessionId.mockReturnValue(undefined);\n175\t  mockRecordSessionId.mockImplementation(\n176\t    (key: { taskName: string; storyKey: string }, sessionId: string, state: WorkflowState) => ({\n177\t      ...state,\n178\t      tasks_completed: [\n179\t        ...state.tasks_completed,\n180\t        {\n181\t          task_name: key.taskName,\n182\t          story_key: key.storyKey,\n183\t          completed_at: '2026-04-03T00:00:00.000Z',\n184\t          session_id: sessionId,\n185\t        },\n186\t      ],\n187\t    }),\n188\t  );\n189\t\n190\t  mockDispatchAgent.mockResolvedValue({\n191\t    sessionId: 'sess-abc-123',\n192\t    success: true,\n193\t    durationMs: 1000,\n194\t    output: 'Done',\n195\t  });\n196\t\n197\t  // Default: sprint-status.yaml exists with two stories\n198\t  mockExistsSync.mockImplementation((path: string) => {\n199\t    if (path === '/project/sprint-status.yaml') return true;\n200\t    return false;\n201\t  });\n202\t\n203\t  mockReadFileSync.mockReturnValue('dummy yaml');\n204\t  mockParse.mockReturnValue({\n205\t    development_status: {\n206\t      'epic-5': 'backlog',\n207\t      '5-1-foo': 'ready-for-dev',\n208\t      '5-2-bar': 'backlog',\n209\t    },\n210\t  });\n211\t}\n212\t\n213\t// --- Tests ---\n214\t\n215\tdescribe('loadWorkItems', () => {\n216\t  beforeEach(() => {\n217\t    vi.clearAllMocks();\n218\t  });\n219\t\n220\t  it('loads stories from sprint-status.yaml excluding epics and retrospectives', () => {\n221\t    mockExistsSync.mockReturnValue(true);\n222\t    mockReadFileSync.mockReturnValue('yaml content');\n223\t    mockParse.mockReturnValue({\n224\t      development_status: {\n225\t        'epic-5': 'backlog',\n226\t        '5-1-foo': 'ready-for-dev',\n227\t        '5-2-bar': 'backlog',\n228\t        '5-3-baz': 'done',\n229\t        'epic-5-retrospective': 'backlog',\n230\t      },\n231\t    });\n232\t\n233\t    const items = loadWorkItems('/path/sprint-status.yaml');\n234\t\n235\t    expect(items).toEqual([\n236\t      { key: '5-1-foo', source: 'sprint' },\n237\t      { key: '5-2-bar', source: 'sprint' },\n238\t    ]);\n239\t  });\n240\t\n241\t  it('returns empty array when sprint-status.yaml does not exist and no issues.yaml', () => {\n242\t    mockExistsSync.mockReturnValue(false);\n243\t\n244\t    const items = loadWorkItems('/nonexistent/sprint-status.yaml');\n245\t    expect(items).toEqual([]);\n246\t  });\n247\t\n248\t  it('returns stories only when issues.yaml does not exist (AC #6)', () => {\n249\t    mockExistsSync.mockImplementation((path: string) => {\n250\t      if (path === '/path/sprint-status.yaml') return true;\n251\t      return false;\n252\t    });\n253\t    mockReadFileSync.mockReturnValue('yaml');\n254\t    mockParse.mockReturnValue({\n255\t      development_status: {\n256\t        '3-1-foo': 'ready-for-dev',\n257\t      },\n258\t    });\n259\t\n260\t    const items = loadWorkItems('/path/sprint-status.yaml', '/path/issues.yaml');\n261\t\n262\t    expect(items).toEqual([{ key: '3-1-foo', source: 'sprint' }]);\n263\t  });\n264\t\n265\t  it('loads both stories and issues when issues.yaml exists (AC #5)', () => {\n266\t    mockExistsSync.mockReturnValue(true);\n267\t    mockReadFileSync.mockReturnValue('yaml');\n268\t    mockParse\n269\t      .mockReturnValueOnce({\n270\t        development_status: {\n271\t          '3-1-foo': 'ready-for-dev',\n272\t        },\n273\t      })\n274\t      .mockReturnValueOnce({\n275\t        issues: [\n276\t          { id: 'issue-001', title: 'Fix docker timeout', status: 'ready-for-dev' },\n277\t          { id: 'issue-002', title: 'Already done', status: 'done' },\n278\t        ],\n279\t      });\n280\t\n281\t    const items = loadWorkItems('/path/sprint-status.yaml', '/path/issues.yaml');\n282\t\n283\t    expect(items).toEqual([\n284\t      { key: '3-1-foo', source: 'sprint' },\n285\t      { key: 'issue-001', title: 'Fix docker timeout', source: 'issues' },\n286\t    ]);\n287\t  });\n288\t\n289\t  it('handles invalid YAML in sprint-status.yaml gracefully', () => {\n290\t    mockExistsSync.mockReturnValue(true);\n291\t    mockReadFileSync.mockReturnValue('yaml');\n292\t    mockParse.mockImplementation(() => {\n293\t      throw new Error('bad yaml');\n294\t    });\n295\t\n296\t    const items = loadWorkItems('/path/sprint-status.yaml');\n297\t    expect(items).toEqual([]);\n298\t    expect(mockWarn).toHaveBeenCalled();\n299\t  });\n300\t\n301\t  it('handles unreadable sprint-status.yaml file gracefully', () => {\n302\t    mockExistsSync.mockReturnValue(true);\n303\t    mockReadFileSync.mockImplementation(() => {\n304\t      throw new Error('EACCES: permission denied');\n305\t    });\n306\t\n307\t    const items = loadWorkItems('/path/sprint-status.yaml');\n308\t    expect(items).toEqual([]);\n309\t    expect(mockWarn).toHaveBeenCalledWith(\n310\t      expect.stringContaining('could not read sprint-status.yaml'),\n311\t    );\n312\t  });\n313\t\n314\t  it('handles unreadable issues.yaml file gracefully', () => {\n315\t    // sprint-status.yaml is fine\n316\t    mockExistsSync.mockReturnValue(true);\n317\t    let readCount = 0;\n318\t    mockReadFileSync.mockImplementation(() => {\n319\t      readCount++;\n320\t      if (readCount === 1) return 'sprint yaml';\n321\t      throw new Error('EACCES: permission denied');\n322\t    });\n323\t    mockParse.mockReturnValue({\n324\t      development_status: { '3-1-foo': 'ready-for-dev' },\n325\t    });\n326\t\n327\t    const items = loadWorkItems('/path/sprint-status.yaml', '/path/issues.yaml');\n328\t    // Should still have the sprint story\n329\t    expect(items).toEqual([{ key: '3-1-foo', source: 'sprint' }]);\n330\t    expect(mockWarn).toHaveBeenCalledWith(\n331\t      expect.stringContaining('could not read issues.yaml'),\n332\t    );\n333\t  });\n334\t\n335\t  it('handles invalid YAML in issues.yaml gracefully', () => {\n336\t    mockExistsSync.mockReturnValue(true);\n337\t    mockReadFileSync.mockReturnValue('yaml');\n338\t    let parseCount = 0;\n339\t    mockParse.mockImplementation(() => {\n340\t      parseCount++;\n341\t      if (parseCount === 1) {\n342\t        return { development_status: { '3-1-foo': 'ready-for-dev' } };\n343\t      }\n344\t      throw new Error('bad issues yaml');\n345\t    });\n346\t\n347\t    const items = loadWorkItems('/path/sprint-status.yaml', '/path/issues.yaml');\n348\t    expect(items).toEqual([{ key: '3-1-foo', source: 'sprint' }]);\n349\t    expect(mockWarn).toHaveBeenCalledWith(\n350\t      expect.stringContaining('invalid YAML in issues.yaml'),\n351\t    );\n352\t  });\n353\t});\n354\t\n355\tdescribe('dispatchTask', () => {\n356\t  beforeEach(() => {\n357\t    vi.clearAllMocks();\n358\t    setupDefaultMocks();\n359\t  });\n360\t\n361\t  it('generates trace ID and injects trace prompt per dispatch (AC #11)', async () => {\n362\t    const task = makeTask();\n363\t    const definition = makeDefinition();\n364\t    const state = makeDefaultState();\n365\t    const config = makeConfig();\n366\t\n367\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n368\t\n369\t    expect(mockGenerateTraceId).toHaveBeenCalledWith('run-001', 0, 'implement');\n370\t    expect(mockFormatTracePrompt).toHaveBeenCalledWith('ch-run-001-0-implement');\n371\t    expect(mockDispatchAgent).toHaveBeenCalledWith(\n372\t      definition,\n373\t      'Implement story 5-1-foo',\n374\t      expect.objectContaining({\n375\t        appendSystemPrompt: '[TRACE] trace_id=ch-run-001-0-implement',\n376\t      }),\n377\t    );\n378\t  });\n379\t\n380\t  it('resolves session ID for continue boundary (AC #12)', async () => {\n381\t    const task = makeTask({ session: 'continue' });\n382\t    const definition = makeDefinition();\n383\t    const state = makeDefaultState();\n384\t    const config = makeConfig();\n385\t\n386\t    mockResolveSessionId.mockReturnValue('prev-sess-id');\n387\t\n388\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n389\t\n390\t    expect(mockResolveSessionId).toHaveBeenCalledWith(\n391\t      'continue',\n392\t      { taskName: 'implement', storyKey: '5-1-foo' },\n393\t      state,\n394\t    );\n395\t    expect(mockDispatchAgent).toHaveBeenCalledWith(\n396\t      definition,\n397\t      expect.any(String),\n398\t      expect.objectContaining({ sessionId: 'prev-sess-id' }),\n399\t    );\n400\t  });\n401\t\n402\t  it('dispatches with cwd when source_access is true (default) (AC #10)', async () => {\n403\t    const task = makeTask({ source_access: true });\n404\t    const definition = makeDefinition();\n405\t    const state = makeDefaultState();\n406\t    const config = makeConfig({ projectDir: '/my-project' });\n407\t\n408\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n409\t\n410\t    expect(mockCreateIsolatedWorkspace).not.toHaveBeenCalled();\n411\t    expect(mockDispatchAgent).toHaveBeenCalledWith(\n412\t      definition,\n413\t      expect.any(String),\n414\t      expect.objectContaining({ cwd: '/my-project' }),\n415\t    );\n416\t  });\n417\t\n418\t  it('creates isolated workspace when source_access is false (AC #9)', async () => {\n419\t    const mockWorkspace = {\n420\t      dir: '/tmp/codeharness-verify-run-001',\n421\t      storyFilesDir: '/tmp/codeharness-verify-run-001/story-files',\n422\t      verdictDir: '/tmp/codeharness-verify-run-001/verdict',\n423\t      toDispatchOptions: () => ({ cwd: '/tmp/codeharness-verify-run-001' }),\n424\t      cleanup: vi.fn().mockResolvedValue(undefined),\n425\t    };\n426\t    mockCreateIsolatedWorkspace.mockResolvedValue(mockWorkspace);\n427\t\n428\t    const task = makeTask({ source_access: false });\n429\t    const definition = makeDefinition();\n430\t    const state = makeDefaultState();\n431\t    const config = makeConfig();\n432\t\n433\t    await dispatchTask(task, 'verify', '__run__', definition, state, config);\n434\t\n435\t    expect(mockCreateIsolatedWorkspace).toHaveBeenCalledWith({\n436\t      runId: 'run-001',\n437\t      storyFiles: [],\n438\t    });\n439\t    expect(mockDispatchAgent).toHaveBeenCalledWith(\n440\t      definition,\n441\t      expect.any(String),\n442\t      expect.objectContaining({ cwd: '/tmp/codeharness-verify-run-001' }),\n443\t    );\n444\t    expect(mockWorkspace.cleanup).toHaveBeenCalled();\n445\t  });\n446\t\n447\t  it('writes state to disk after each dispatch (AC #4)', async () => {\n448\t    const task = makeTask();\n449\t    const definition = makeDefinition();\n450\t    const state = makeDefaultState();\n451\t    const config = makeConfig();\n452\t\n453\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n454\t\n455\t    expect(mockWriteWorkflowState).toHaveBeenCalled();\n456\t    // State should have the new checkpoint\n457\t    const writtenState = mockWriteWorkflowState.mock.calls[0][0] as WorkflowState;\n458\t    expect(writtenState.trace_ids).toContain('ch-run-001-0-implement');\n459\t  });\n460\t\n461\t  it('records trace ID in workflow state (AC #11)', async () => {\n462\t    const task = makeTask();\n463\t    const definition = makeDefinition();\n464\t    const state = makeDefaultState();\n465\t    const config = makeConfig();\n466\t\n467\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n468\t\n469\t    expect(mockRecordTraceId).toHaveBeenCalledWith('ch-run-001-0-implement', expect.any(Object));\n470\t  });\n471\t\n472\t  it('records session ID after successful dispatch', async () => {\n473\t    const task = makeTask();\n474\t    const definition = makeDefinition();\n475\t    const state = makeDefaultState();\n476\t    const config = makeConfig();\n477\t\n478\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n479\t\n480\t    expect(mockRecordSessionId).toHaveBeenCalledWith(\n481\t      { taskName: 'implement', storyKey: '5-1-foo' },\n482\t      'sess-abc-123',\n483\t      expect.any(Object),\n484\t    );\n485\t  });\n486\t\n487\t  it('appends checkpoint manually when dispatch returns no sessionId', async () => {\n488\t    mockDispatchAgent.mockResolvedValue({\n489\t      sessionId: '',\n490\t      success: true,\n491\t      durationMs: 100,\n492\t      output: 'ok',\n493\t    });\n494\t\n495\t    const task = makeTask();\n496\t    const definition = makeDefinition();\n497\t    const state = makeDefaultState();\n498\t    const config = makeConfig();\n499\t\n500\t    const result = await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n501\t\n502\t    // recordSessionId should NOT be called (empty string is falsy)\n503\t    expect(mockRecordSessionId).not.toHaveBeenCalled();\n504\t    // State should have a manually-created checkpoint\n505\t    const writtenState = mockWriteWorkflowState.mock.calls[0][0] as WorkflowState;\n506\t    expect(writtenState.tasks_completed).toHaveLength(1);\n507\t    expect(writtenState.tasks_completed[0].task_name).toBe('implement');\n508\t    expect(writtenState.tasks_completed[0].story_key).toBe('5-1-foo');\n509\t  });\n510\t\n511\t  it('cleans up workspace on dispatch error when source_access is false', async () => {\n512\t    const mockWorkspace = {\n513\t      dir: '/tmp/test',\n514\t      storyFilesDir: '/tmp/test/story-files',\n515\t      verdictDir: '/tmp/test/verdict',\n516\t      toDispatchOptions: () => ({ cwd: '/tmp/test' }),\n517\t      cleanup: vi.fn().mockResolvedValue(undefined),\n518\t    };\n519\t    mockCreateIsolatedWorkspace.mockResolvedValue(mockWorkspace);\n520\t    mockDispatchAgent.mockRejectedValue(new Error('dispatch failed'));\n521\t\n522\t    const task = makeTask({ source_access: false });\n523\t    const definition = makeDefinition();\n524\t    const state = makeDefaultState();\n525\t    const config = makeConfig();\n526\t\n527\t    await expect(\n528\t      dispatchTask(task, 'verify', '__run__', definition, state, config),\n529\t    ).rejects.toThrow('dispatch failed');\n530\t\n531\t    // Cleanup should still be called\n532\t    expect(mockWorkspace.cleanup).toHaveBeenCalled();\n533\t  });\n534\t\n535\t  it('constructs per-run prompt for sentinel key', async () => {\n536\t    const task = makeTask({ scope: 'per-run' });\n537\t    const definition = makeDefinition();\n538\t    const state = makeDefaultState();\n539\t    const config = makeConfig();\n540\t\n541\t    await dispatchTask(task, 'verify', '__run__', definition, state, config);\n542\t\n543\t    expect(mockDispatchAgent).toHaveBeenCalledWith(\n544\t      definition,\n545\t      'Execute task \"verify\" for the current run.',\n546\t      expect.any(Object),\n547\t    );\n548\t  });\n549\t});\n550\t\n551\tdescribe('executeWorkflow', () => {\n552\t  beforeEach(() => {\n553\t    vi.clearAllMocks();\n554\t    setupDefaultMocks();\n555\t  });\n556\t\n557\t  it('executes flow steps sequentially in order (AC #2)', async () => {\n558\t    const callOrder: string[] = [];\n559\t    mockDispatchAgent.mockImplementation(\n560\t      async (_def: SubagentDefinition, prompt: string) => {\n561\t        callOrder.push(prompt);\n562\t        return { sessionId: 'sess-1', success: true, durationMs: 100, output: 'ok' };\n563\t      },\n564\t    );\n565\t\n566\t    // Two stories, flow: [implement, verify]\n567\t    mockParse.mockReturnValue({\n568\t      development_status: {\n569\t        '3-1-foo': 'ready-for-dev',\n570\t        '3-2-bar': 'backlog',\n571\t      },\n572\t    });\n573\t\n574\t    const config = makeConfig();\n575\t    const result = await executeWorkflow(config);\n576\t\n577\t    expect(result.success).toBe(true);\n578\t    // implement dispatched for each story, then verify once\n579\t    expect(callOrder).toEqual([\n580\t      'Implement story 3-1-foo',\n581\t      'Implement story 3-2-bar',\n582\t      'Execute task \"verify\" for the current run.',\n583\t    ]);\n584\t  });\n585\t\n586\t  it('dispatches per-story task once per story (AC #3)', async () => {\n587\t    mockParse.mockReturnValue({\n588\t      development_status: {\n589\t        '3-1-foo': 'ready-for-dev',\n590\t        '3-2-bar': 'backlog',\n591\t      },\n592\t    });\n593\t\n594\t    const config = makeConfig({\n595\t      workflow: {\n596\t        tasks: { implement: makeTask() },\n597\t        flow: ['implement'],\n598\t      },\n599\t    });\n600\t\n601\t    const result = await executeWorkflow(config);\n602\t\n603\t    expect(mockDispatchAgent).toHaveBeenCalledTimes(2);\n604\t    expect(result.tasksCompleted).toBe(2);\n605\t    expect(result.storiesProcessed).toBe(2);\n606\t  });\n607\t\n608\t  it('dispatches per-run task exactly once with sentinel key (AC #7)', async () => {\n609\t    mockParse.mockReturnValue({\n610\t      development_status: {\n611\t        '3-1-foo': 'ready-for-dev',\n612\t        '3-2-bar': 'backlog',\n613\t      },\n614\t    });\n615\t\n616\t    const config = makeConfig({\n617\t      workflow: {\n618\t        tasks: { verify: makeTask({ scope: 'per-run' }) },\n619\t        flow: ['verify'],\n620\t      },\n621\t    });\n622\t\n623\t    const result = await executeWorkflow(config);\n624\t\n625\t    expect(mockDispatchAgent).toHaveBeenCalledTimes(1);\n626\t    expect(result.tasksCompleted).toBe(1);\n627\t  });\n628\t\n629\t  it('writes state after each task completion (AC #4)', async () => {\n630\t    mockParse.mockReturnValue({\n631\t      development_status: {\n632\t        '3-1-foo': 'ready-for-dev',\n633\t      },\n634\t    });\n635\t\n636\t    const config = makeConfig({\n637\t      workflow: {\n638\t        tasks: { implement: makeTask() },\n639\t        flow: ['implement'],\n640\t      },\n641\t    });\n642\t\n643\t    await executeWorkflow(config);\n644\t\n645\t    // writeWorkflowState called: initial state + after dispatch + final completed state\n646\t    expect(mockWriteWorkflowState).toHaveBeenCalledTimes(3);\n647\t  });\n648\t\n649\t  it('skips loop blocks with warning (AC #8)', async () => {\n650\t    const config = makeConfig({\n651\t      workflow: {\n652\t        tasks: { implement: makeTask() },\n653\t        flow: ['implement', { loop: ['implement'] }],\n654\t      },\n655\t    });\n656\t\n657\t    mockParse.mockReturnValue({\n658\t      development_status: { '3-1-foo': 'ready-for-dev' },\n659\t    });\n660\t\n661\t    const result = await executeWorkflow(config);\n662\t\n663\t    expect(mockWarn).toHaveBeenCalledWith(\n664\t      expect.stringContaining('loop blocks are not yet implemented'),\n665\t    );\n666\t    // Only the string task should have dispatched\n667\t    expect(mockDispatchAgent).toHaveBeenCalledTimes(1);\n668\t    expect(result.success).toBe(true);\n669\t  });\n670\t\n671\t  it('handles DispatchError and records in result (AC #13)', async () => {\n672\t    const { DispatchError } = await import('../agent-dispatch.js');\n673\t    mockDispatchAgent.mockRejectedValue(\n674\t      new DispatchError('rate limited', 'UNKNOWN', 'dev', new Error('inner')),\n675\t    );\n676\t\n677\t    mockParse.mockReturnValue({\n678\t      development_status: { '3-1-foo': 'ready-for-dev' },\n679\t    });\n680\t\n681\t    const config = makeConfig({\n682\t      workflow: {\n683\t        tasks: { implement: makeTask() },\n684\t        flow: ['implement'],\n685\t      },\n686\t    });\n687\t\n688\t    const result = await executeWorkflow(config);\n689\t\n690\t    expect(result.success).toBe(false);\n691\t    expect(result.errors).toHaveLength(1);\n692\t    expect(result.errors[0].code).toBe('UNKNOWN');\n693\t    expect(result.errors[0].taskName).toBe('implement');\n694\t    expect(result.errors[0].storyKey).toBe('3-1-foo');\n695\t  });\n696\t\n697\t  it('halts on RATE_LIMIT dispatch errors (AC #13)', async () => {\n698\t    const { DispatchError } = await import('../agent-dispatch.js');\n699\t    mockDispatchAgent.mockRejectedValue(\n700\t      new DispatchError('rate limited', 'RATE_LIMIT', 'dev', new Error('inner')),\n701\t    );\n702\t\n703\t    mockParse.mockReturnValue({\n704\t      development_status: {\n705\t        '3-1-foo': 'ready-for-dev',\n706\t        '3-2-bar': 'backlog',\n707\t      },\n708\t    });\n709\t\n710\t    const config = makeConfig({\n711\t      workflow: {\n712\t        tasks: { implement: makeTask() },\n713\t        flow: ['implement'],\n714\t      },\n715\t    });\n716\t\n717\t    const result = await executeWorkflow(config);\n718\t\n719\t    expect(result.success).toBe(false);\n720\t    // Should halt after first error — only one dispatch attempted\n721\t    expect(mockDispatchAgent).toHaveBeenCalledTimes(1);\n722\t    