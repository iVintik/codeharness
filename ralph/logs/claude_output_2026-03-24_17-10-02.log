{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01V57xqLcnMz29XxGbp3ivm4","type":"tool_result","content":"     1→import { existsSync, readFileSync, writeFileSync } from 'node:fs';\n     2→import { join } from 'node:path';\n     3→import { parse } from 'yaml';\n     4→import { warn } from '../output.js';\n     5→\n     6→const SPRINT_STATUS_PATH = '_bmad-output/implementation-artifacts/sprint-status.yaml';\n     7→\n     8→/**\n     9→ * Reads sprint-status.yaml and returns the development_status map.\n    10→ */\n    11→export function readSprintStatus(dir?: string): Record<string, string> {\n    12→  const root = dir ?? process.cwd();\n    13→  const filePath = join(root, SPRINT_STATUS_PATH);\n    14→  if (!existsSync(filePath)) {\n    15→    return {};\n    16→  }\n    17→  try {\n    18→    const content = readFileSync(filePath, 'utf-8');\n    19→    const parsed = parse(content) as Record<string, unknown> | null;\n    20→    if (!parsed || typeof parsed !== 'object') {\n    21→      return {};\n    22→    }\n    23→    const devStatus = parsed.development_status;\n    24→    if (!devStatus || typeof devStatus !== 'object') {\n    25→      return {};\n    26→    }\n    27→    return devStatus as Record<string, string>;\n    28→  } catch {\n    29→    return {};\n    30→  }\n    31→}\n    32→\n    33→/**\n    34→ * Updates a single story's status in sprint-status.yaml while preserving structure and comments.\n    35→ * Uses line-level text replacement to preserve YAML comments.\n    36→ */\n    37→export function updateSprintStatus(storyKey: string, newStatus: string, dir?: string): void {\n    38→  const root = dir ?? process.cwd();\n    39→  const filePath = join(root, SPRINT_STATUS_PATH);\n    40→  if (!existsSync(filePath)) {\n    41→    warn(`sprint-status.yaml not found at ${filePath}, skipping update`);\n    42→    return;\n    43→  }\n    44→\n    45→  const content = readFileSync(filePath, 'utf-8');\n    46→\n    47→  const keyPattern = new RegExp(`^(\\\\s*${escapeRegExp(storyKey)}:\\\\s*)\\\\S+(.*)$`, 'm');\n    48→  if (!keyPattern.test(content)) {\n    49→    return;\n    50→  }\n    51→\n    52→  const updated = content.replace(keyPattern, `$1${newStatus}$2`);\n    53→  writeFileSync(filePath, updated, 'utf-8');\n    54→}\n    55→\n    56→function escapeRegExp(s: string): string {\n    57→  return s.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n    58→}\n    59→\n    60→// ─── Onboarding Epic → Sprint Status ────────────────────────────────────────\n    61→\n    62→function nextEpicNumber(statuses: Record<string, string>): number {\n    63→  let max = -1;\n    64→  for (const key of Object.keys(statuses)) {\n    65→    const match = key.match(/^epic-(\\d+)$/);\n    66→    if (match) {\n    67→      const n = parseInt(match[1], 10);\n    68→      if (n > max) max = n;\n    69→    }\n    70→  }\n    71→  return max + 1;\n    72→}\n    73→\n    74→function slugify(title: string): string {\n    75→  return title\n    76→    .toLowerCase()\n    77→    .replace(/[^a-z0-9]+/g, '-')\n    78→    .replace(/^-+|-+$/g, '')\n    79→    .slice(0, 60);\n    80→}\n    81→\n    82→export interface OnboardingStoryEntry {\n    83→  title: string;\n    84→  key?: string;\n    85→}\n    86→\n    87→/**\n    88→ * Appends an onboarding epic with stories to sprint-status.yaml.\n    89→ */\n    90→export function appendOnboardingEpicToSprint(\n    91→  stories: OnboardingStoryEntry[],\n    92→  dir?: string,\n    93→): { epicNumber: number; storyKeys: string[] } {\n    94→  const root = dir ?? process.cwd();\n    95→  const filePath = join(root, SPRINT_STATUS_PATH);\n    96→\n    97→  if (!existsSync(filePath)) {\n    98→    warn(`sprint-status.yaml not found at ${filePath}, cannot append onboarding epic`);\n    99→    return { epicNumber: -1, storyKeys: [] };\n   100→  }\n   101→\n   102→  const statuses = readSprintStatus(dir);\n   103→  const epicNum = nextEpicNumber(statuses);\n   104→  const storyKeys: string[] = [];\n   105→\n   106→  const lines: string[] = [''];\n   107→  lines.push(`  epic-${epicNum}: backlog`);\n   108→\n   109→  for (let i = 0; i < stories.length; i++) {\n   110→    const slug = slugify(stories[i].title);\n   111→    const storyKey = `${epicNum}-${i + 1}-${slug}`;\n   112→    storyKeys.push(storyKey);\n   113→    lines.push(`  ${storyKey}: backlog`);\n   114→  }\n   115→\n   116→  lines.push(`  epic-${epicNum}-retrospective: optional`);\n   117→  lines.push('');\n   118→\n   119→  const content = readFileSync(filePath, 'utf-8');\n   120→  const updated = content.trimEnd() + '\\n' + lines.join('\\n');\n   121→  writeFileSync(filePath, updated, 'utf-8');\n   122→\n   123→  return { epicNumber: epicNum, storyKeys };\n   124→}\n   125→"}]},"parent_tool_use_id":"toolu_01WxJciqSN2EMLLyK1wQ7yug","session_id":"6831c0a8-772d-4704-bc72-4469c7d7a986","uuid":"751e9bce-b932-40c8-8ecf-f19b7b1bf14a","timestamp":"2026-03-24T13:14:00.687Z"}
