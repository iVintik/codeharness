{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XVC4UQDvEeckynEPP7fDaS","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n2\timport { mkdtempSync, rmSync, writeFileSync, mkdirSync, existsSync } from 'node:fs';\n3\timport { tmpdir } from 'node:os';\n4\timport { join } from 'node:path';\n5\timport { Command } from 'commander';\n6\timport { runSchemaValidation } from '../validate-schema.js';\n7\timport { registerValidateCommand } from '../validate.js';\n8\t\n9\t// ─── Mocks ───────────────────────────────────────────────────────────────────\n10\t\n11\t// Mock validate-self to avoid pulling in modules/verify\n12\tvi.mock('../validate-self.js', () => ({\n13\t  registerValidateSelfCommand: vi.fn(),\n14\t}));\n15\t\n16\tlet testDir: string;\n17\t\n18\tbeforeEach(() => {\n19\t  testDir = mkdtempSync(join(tmpdir(), 'ch-validate-schema-test-'));\n20\t  process.exitCode = undefined;\n21\t});\n22\t\n23\tafterEach(() => {\n24\t  rmSync(testDir, { recursive: true, force: true });\n25\t  vi.restoreAllMocks();\n26\t  process.exitCode = undefined;\n27\t});\n28\t\n29\t// ─── Valid YAML content ──────────────────────────────────────────────────────\n30\t\n31\tconst validWorkflowYaml = `\n32\ttasks:\n33\t  implement:\n34\t    agent: dev\n35\t    scope: per-story\n36\t    session: fresh\n37\t    source_access: true\n38\t  verify:\n39\t    agent: evaluator\n40\t    scope: per-run\n41\t    session: fresh\n42\t    source_access: false\n43\t\n44\tflow:\n45\t  - implement\n46\t  - verify\n47\t`;\n48\t\n49\tconst invalidWorkflowMissingTasks = `\n50\tflow:\n51\t  - implement\n52\t`;\n53\t\n54\tconst danglingRefYaml = `\n55\ttasks:\n56\t  implement:\n57\t    agent: dev\n58\t\n59\tflow:\n60\t  - implement\n61\t  - nonexistent_task\n62\t`;\n63\t\n64\t// ─── Helpers ─────────────────────────────────────────────────────────────────\n65\t\n66\tfunction setupWorkflowsDir(files: Record<string, string>): void {\n67\t  const wfDir = join(testDir, '.codeharness', 'workflows');\n68\t  mkdirSync(wfDir, { recursive: true });\n69\t  for (const [name, content] of Object.entries(files)) {\n70\t    writeFileSync(join(wfDir, name), content, 'utf-8');\n71\t  }\n72\t}\n73\t\n74\tfunction createCli(): Command {\n75\t  const program = new Command();\n76\t  program.exitOverride();\n77\t  program.option('--json', 'JSON output');\n78\t  registerValidateCommand(program);\n79\t  return program;\n80\t}\n81\t\n82\tasync function runCli(args: string[]): Promise<{ stdout: string }> {\n83\t  const logs: string[] = [];\n84\t  const consoleSpy = vi.spyOn(console, 'log').mockImplementation((...a: unknown[]) => {\n85\t    logs.push(a.map(String).join(' '));\n86\t  });\n87\t  const origCwd = process.cwd();\n88\t  process.chdir(testDir);\n89\t  try {\n90\t    const program = createCli();\n91\t    await program.parseAsync(['node', 'codeharness', ...args]);\n92\t  } finally {\n93\t    process.chdir(origCwd);\n94\t  }\n95\t  consoleSpy.mockRestore();\n96\t  return { stdout: logs.join('\\n') };\n97\t}\n98\t\n99\t// ─── Unit tests for runSchemaValidation ──────────────────────────────────────\n100\t\n101\tdescribe('runSchemaValidation', () => {\n102\t  it('returns pass when all workflow files are valid (AC #1)', () => {\n103\t    setupWorkflowsDir({ 'default.yaml': validWorkflowYaml });\n104\t    const result = runSchemaValidation(testDir);\n105\t    expect(result.status).toBe('pass');\n106\t    expect(result.files).toHaveLength(1);\n107\t    expect(result.files[0].valid).toBe(true);\n108\t    expect(result.files[0].errors).toEqual([]);\n109\t  });\n110\t\n111\t  it('returns fail with errors when workflow has missing required keys (AC #2)', () => {\n112\t    setupWorkflowsDir({ 'bad.yaml': invalidWorkflowMissingTasks });\n113\t    const result = runSchemaValidation(testDir);\n114\t    expect(result.status).toBe('fail');\n115\t    expect(result.files).toHaveLength(1);\n116\t    expect(result.files[0].valid).toBe(false);\n117\t    expect(result.files[0].errors.length).toBeGreaterThan(0);\n118\t    // Error should mention path and message\n119\t    expect(result.files[0].errors[0].message).toBeTruthy();\n120\t    expect(result.files[0].errors[0].path).toBeTruthy();\n121\t  });\n122\t\n123\t  it('catches dangling task references (AC #3)', () => {\n124\t    setupWorkflowsDir({ 'dangling.yaml': danglingRefYaml });\n125\t    const result = runSchemaValidation(testDir);\n126\t    expect(result.status).toBe('fail');\n127\t    expect(result.files[0].valid).toBe(false);\n128\t    const danglingError = result.files[0].errors.find(e =>\n129\t      e.message.includes('nonexistent_task'),\n130\t    );\n131\t    expect(danglingError).toBeDefined();\n132\t    expect(danglingError!.path).toContain('/flow/');\n133\t  });\n134\t\n135\t  it('returns fail when .codeharness/workflows/ directory does not exist (AC #4)', () => {\n136\t    // testDir has no .codeharness/ directory\n137\t    const result = runSchemaValidation(testDir);\n138\t    expect(result.status).toBe('fail');\n139\t    expect(result.files).toHaveLength(1);\n140\t    expect(result.files[0].valid).toBe(false);\n141\t    expect(result.files[0].errors[0].message).toBe('No workflow files found');\n142\t  });\n143\t\n144\t  it('returns fail when workflows directory exists but is empty (AC #4)', () => {\n145\t    mkdirSync(join(testDir, '.codeharness', 'workflows'), { recursive: true });\n146\t    const result = runSchemaValidation(testDir);\n147\t    expect(result.status).toBe('fail');\n148\t    expect(result.files[0].errors[0].message).toBe('No workflow files found');\n149\t  });\n150\t\n151\t  it('handles mixed valid and invalid files (AC #5)', () => {\n152\t    setupWorkflowsDir({\n153\t      'good.yaml': validWorkflowYaml,\n154\t      'bad.yaml': invalidWorkflowMissingTasks,\n155\t    });\n156\t    const result = runSchemaValidation(testDir);\n157\t    expect(result.status).toBe('fail');\n158\t    expect(result.files).toHaveLength(2);\n159\t    const goodFile = result.files.find(f => f.path.includes('good.yaml'));\n160\t    const badFile = result.files.find(f => f.path.includes('bad.yaml'));\n161\t    expect(goodFile!.valid).toBe(true);\n162\t    expect(badFile!.valid).toBe(false);\n163\t    expect(badFile!.errors.length).toBeGreaterThan(0);\n164\t  });\n165\t\n166\t  it('discovers .yml files too', () => {\n167\t    setupWorkflowsDir({ 'custom.yml': validWorkflowYaml });\n168\t    const result = runSchemaValidation(testDir);\n169\t    expect(result.status).toBe('pass');\n170\t    expect(result.files).toHaveLength(1);\n171\t    expect(result.files[0].path).toContain('custom.yml');\n172\t  });\n173\t});\n174\t\n175\t// ─── CLI integration tests ──────────────────────────────────────────────────\n176\t\n177\tdescribe('validate schema CLI', () => {\n178\t  it('exits 0 and prints [OK] for valid workflow (AC #1)', async () => {\n179\t    setupWorkflowsDir({ 'default.yaml': validWorkflowYaml });\n180\t    const { stdout } = await runCli(['validate', 'schema']);\n181\t    expect(stdout).toContain('[OK]');\n182\t    expect(stdout).toContain('default.yaml');\n183\t    expect(process.exitCode).toBe(0);\n184\t  });\n185\t\n186\t  it('exits 1 and prints [FAIL] with error details for invalid workflow (AC #2)', async () => {\n187\t    setupWorkflowsDir({ 'bad.yaml': invalidWorkflowMissingTasks });\n188\t    const { stdout } = await runCli(['validate', 'schema']);\n189\t    expect(stdout).toContain('[FAIL]');\n190\t    expect(stdout).toContain('bad.yaml');\n191\t    expect(process.exitCode).toBe(1);\n192\t  });\n193\t\n194\t  it('exits 1 and reports dangling reference (AC #3)', async () => {\n195\t    setupWorkflowsDir({ 'dangling.yaml': danglingRefYaml });\n196\t    const { stdout } = await runCli(['validate', 'schema']);\n197\t    expect(stdout).toContain('[FAIL]');\n198\t    expect(stdout).toContain('nonexistent_task');\n199\t    expect(process.exitCode).toBe(1);\n200\t  });\n201\t\n202\t  it('exits 1 with \"No workflow files found\" when dir missing (AC #4)', async () => {\n203\t    const { stdout } = await runCli(['validate', 'schema']);\n204\t    expect(stdout).toContain('[FAIL]');\n205\t    expect(stdout).toContain('No workflow files found');\n206\t    expect(process.exitCode).toBe(1);\n207\t  });\n208\t\n209\t  it('--json outputs correct shape (AC #5)', async () => {\n210\t    setupWorkflowsDir({\n211\t      'good.yaml': validWorkflowYaml,\n212\t      'bad.yaml': invalidWorkflowMissingTasks,\n213\t    });\n214\t    const { stdout } = await runCli(['--json', 'validate', 'schema']);\n215\t    const parsed = JSON.parse(stdout);\n216\t    expect(parsed.status).toBe('fail');\n217\t    expect(Array.isArray(parsed.files)).toBe(true);\n218\t    expect(parsed.files.length).toBe(2);\n219\t    for (const f of parsed.files) {\n220\t      expect(f).toHaveProperty('path');\n221\t      expect(f).toHaveProperty('valid');\n222\t      expect(f).toHaveProperty('errors');\n223\t      expect(Array.isArray(f.errors)).toBe(true);\n224\t      for (const e of f.errors) {\n225\t        expect(e).toHaveProperty('path');\n226\t        expect(e).toHaveProperty('message');\n227\t      }\n228\t    }\n229\t  });\n230\t\n231\t  it('default \"validate\" (no subcommand) runs schema validation (AC #6)', async () => {\n232\t    setupWorkflowsDir({ 'default.yaml': validWorkflowYaml });\n233\t    const { stdout } = await runCli(['validate']);\n234\t    expect(stdout).toContain('[OK]');\n235\t    expect(stdout).toContain('default.yaml');\n236\t    expect(process.exitCode).toBe(0);\n237\t  });\n238\t\n239\t  it('default \"validate\" with no workflows reports fail (AC #6)', async () => {\n240\t    const { stdout } = await runCli(['validate']);\n241\t    expect(stdout).toContain('[FAIL]');\n242\t    expect(stdout).toContain('No workflow files found');\n243\t    expect(process.exitCode).toBe(1);\n244\t  });\n245\t\n246\t  it('--json on default validate outputs correct shape (AC #5, #6)', async () => {\n247\t    setupWorkflowsDir({ 'default.yaml': validWorkflowYaml });\n248\t    const { stdout } = await runCli(['--json', 'validate']);\n249\t    const parsed = JSON.parse(stdout);\n250\t    expect(parsed.status).toBe('pass');\n251\t    expect(parsed.files).toHaveLength(1);\n252\t    expect(parsed.files[0].valid).toBe(true);\n253\t  });\n254\t});\n255\t"}]},"parent_tool_use_id":"toolu_01DuVFpc4kAp6TjMAncLaYvJ","session_id":"5fca15c0-771e-463c-9e4f-c528b230e359","uuid":"83f258ff-5797-4383-b47c-14a28fb39eef","timestamp":"2026-04-02T14:57:41.928Z"}
