{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LUnPJH2GcmxTZNSxf8SPSW","type":"tool_result","content":"     1→/**\n     2→ * Shared audit action handler.\n     3→ *\n     4→ * Used by both `codeharness audit` and `codeharness onboard` (alias)\n     5→ * to ensure identical behavior (FR16).\n     6→ */\n     7→\n     8→import { ok as okOutput, fail as failOutput, info, jsonOutput } from '../lib/output.js';\n     9→import { runPreconditions } from '../lib/onboard-checks.js';\n    10→import { runAudit, generateFixStories, addFixStoriesToState } from '../modules/audit/index.js';\n    11→import { formatAuditHuman, formatAuditJson } from '../modules/audit/report.js';\n    12→import type { Result } from '../types/result.js';\n    13→import type { FixGenerationResult } from '../modules/audit/index.js';\n    14→\n    15→/**\n    16→ * Execute the audit action — shared between audit and onboard commands.\n    17→ * Handles precondition checks, audit execution, --fix, and output formatting.\n    18→ */\n    19→export async function executeAudit(opts: { isJson: boolean; isFix: boolean }): Promise<void> {\n    20→  const { isJson, isFix } = opts;\n    21→\n    22→  // Precondition: harness must be initialized\n    23→  const preconditions = runPreconditions();\n    24→  if (!preconditions.canProceed) {\n    25→    if (isJson) {\n    26→      jsonOutput({\n    27→        status: 'fail',\n    28→        message: 'Harness not initialized -- run codeharness init first',\n    29→      });\n    30→    } else {\n    31→      failOutput('Harness not initialized -- run codeharness init first');\n    32→    }\n    33→    process.exitCode = 1;\n    34→    return;\n    35→  }\n    36→\n    37→  // Run audit\n    38→  const result = await runAudit(process.cwd());\n    39→\n    40→  if (!result.success) {\n    41→    if (isJson) {\n    42→      jsonOutput({ status: 'fail', message: result.error });\n    43→    } else {\n    44→      failOutput(result.error);\n    45→    }\n    46→    process.exitCode = 1;\n    47→    return;\n    48→  }\n    49→\n    50→  // Handle --fix flag\n    51→  let fixStories: Result<FixGenerationResult> | undefined;\n    52→  let fixStateError: string | undefined;\n    53→\n    54→  if (isFix) {\n    55→    // No gaps found\n    56→    if (result.data.gapCount === 0) {\n    57→      if (!isJson) {\n    58→        okOutput('No gaps found -- nothing to fix');\n    59→      }\n    60→    } else {\n    61→      // Generate fix stories\n    62→      const fixResult = generateFixStories(result.data);\n    63→      fixStories = fixResult;\n    64→\n    65→      if (fixResult.success) {\n    66→        // Add to sprint state\n    67→        const stateResult = addFixStoriesToState(fixResult.data.stories);\n    68→        if (!stateResult.success) {\n    69→          fixStateError = stateResult.error;\n    70→          if (!isJson) {\n    71→            failOutput(`Failed to update sprint state: ${stateResult.error}`);\n    72→          }\n    73→        }\n    74→\n    75→        if (!isJson) {\n    76→          info(`Generated ${fixResult.data.created} fix stories (${fixResult.data.skipped} skipped)`);\n    77→        }\n    78→      } else if (!isJson) {\n    79→        failOutput(fixResult.error);\n    80→      }\n    81→    }\n    82→  }\n    83→\n    84→  // Format output\n    85→  if (isJson) {\n    86→    const jsonData: Record<string, unknown> = formatAuditJson(result.data) as unknown as Record<string, unknown>;\n    87→    // Include fixStories in JSON when --fix\n    88→    if (isFix) {\n    89→      if (result.data.gapCount === 0) {\n    90→        jsonData.fixStories = [];\n    91→      } else if (fixStories && fixStories.success) {\n    92→        jsonData.fixStories = fixStories.data.stories.map(s => ({\n    93→          key: s.key,\n    94→          filePath: s.filePath,\n    95→          gap: s.gap,\n    96→          ...(s.skipped ? { skipped: true } : {}),\n    97→        }));\n    98→        if (fixStateError) {\n    99→          jsonData.fixStateError = fixStateError;\n   100→        }\n   101→      } else if (fixStories && !fixStories.success) {\n   102→        jsonData.fixStories = [];\n   103→        jsonData.fixError = fixStories.error;\n   104→      }\n   105→    }\n   106→    jsonOutput(jsonData);\n   107→  } else if (!isFix || result.data.gapCount > 0) {\n   108→    // Print human audit output (skip if --fix with no gaps, already printed OK)\n   109→    const lines = formatAuditHuman(result.data);\n   110→    for (const line of lines) {\n   111→      console.log(line);\n   112→    }\n   113→  }\n   114→\n   115→  // Set exit code based on overall status\n   116→  if (result.data.overallStatus === 'fail') {\n   117→    process.exitCode = 1;\n   118→  }\n   119→}\n   120→"}]},"parent_tool_use_id":"toolu_01SeykkPhi15u7dNZcgkedBH","session_id":"1c9a200e-72ec-477b-8ec4-6d2e01a30422","uuid":"0bcec8b1-838b-493e-8fb8-888be101f8a0","timestamp":"2026-03-21T04:32:46.630Z"}
