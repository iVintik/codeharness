    54→  originalCwd = process.cwd();\n    55→  process.chdir(testDir);\n    56→  process.exitCode = undefined;\n    57→\n    58→  // Create default story file\n    59→  const storyDir = join(testDir, '_bmad-output', 'implementation-artifacts');\n    60→  mkdirSync(storyDir, { recursive: true });\n    61→  writeFileSync(\n    62→    join(storyDir, '4-1-test.md'),\n    63→    '# Story 4.1: Test Story\\n\\nStatus: ready-for-dev\\n\\n## Acceptance Criteria\\n\\n1. **Given** test, **Then** pass.\\n',\n    64→  );\n    65→\n    66→  // Create README.md (required by documentation gate)\n    67→  writeFileSync(join(testDir, 'README.md'), '# Test Project\\n');\n    68→});\n    69→\n    70→afterEach(() => {\n    71→  process.chdir(originalCwd);\n    72→  process.exitCode = undefined;\n    73→  rmSync(testDir, { recursive: true, force: true });\n    74→});\n    75→\n    76→async function runVerify(args: string[]): Promise<void> {\n    77→  const program = new Command();\n    78→  program.exitOverride();\n    79→  program.option('--json', 'JSON output');\n    80→  registerVerifyCommand(program);\n    81→  try {\n    82→    await program.parseAsync(['node', 'test', 'verify', ...args]);\n    83→  } catch {\n    84→    // Commander throws on exitOverride — ignore\n    85→  }\n    86→}\n    87→\n    88→// ─── README Gate Tests ──────────────────────────────────────────────────────\n    89→\n    90→describe('verify command — README gate', () => {\n    91→  it('fails with correct error when README.md is missing', async () => {\n    92→    // Remove the README.md created in beforeEach\n    93→    rmSync(join(testDir, 'README.md'), { force: true });\n    94→\n    95→    await runVerify(['--story', '4-1-test']);\n    96→\n    97→    expect(fail).toHaveBeenCalledWith('No README.md found — verification requires user documentation');\n    98→    expect(process.exitCode).toBe(1);\n    99→    // Should NOT reach preconditions\n   100→    expect(checkPreconditions).not.toHaveBeenCalled();\n   101→  });\n   102→\n   103→  it('outputs JSON error when README.md is missing and --json is set', async () => {\n   104→    rmSync(join(testDir, 'README.md'), { force: true });\n   105→\n   106→    await runVerify(['--story', '4-1-test', '--json']);\n   107→\n   108→    expect(jsonOutput).toHaveBeenCalledWith({\n   109→      status: 'fail',\n   110→      message: 'No README.md found — verification requires user documentation',\n   111→    });\n   112→    expect(process.exitCode).toBe(1);\n   113→  });\n   114→\n   115→  it('proceeds past README check when README.md exists', async () => {\n   116→    // README.md exists (created in beforeEach)\n   117→    vi.mocked(checkPreconditions).mockReturnValue({ passed: true, failures: [] });\n   118→    vi.mocked(parseStoryACs).mockReturnValue([\n   119→      { id: '1', description: 'Test AC', type: 'general', verifiability: 'cli-verifiable' as const, strategy: 'docker' as const, tier: 'test-provable' as const },\n   120→    ]);\n   121→    vi.mocked(createProofDocument).mockReturnValue(join(testDir, 'verification', '4-1-test-proof.md'));\n   122→    vi.mocked(validateProofQuality).mockReturnValue({ verified: 1, pending: 0, escalated: 0, total: 1, passed: true, grepSrcCount: 0, dockerExecCount: 1, observabilityCount: 0, otherCount: 0, blackBoxPass: true });\n   123→    vi.mocked(runShowboatVerify).mockReturnValue({ passed: false, output: 'showboat not available' });\n   124→    vi.mocked(updateVerificationState).mockImplementation(() => {});\n   125→    vi.mocked(closeBeadsIssue).mockImplementation(() => {});\n   126→\n   127→    await runVerify(['--story', '4-1-test']);\n   128→\n   129→    // Should reach preconditions (README gate passed)\n   130→    expect(checkPreconditions).toHaveBeenCalled();\n   131→    expect(ok).toHaveBeenCalled();\n   132→  });\n   133→});\n   134→\n   135→// ─── Story Verification Tests ────────────────────────────────────────────────\n   136→\n   137→describe('verify command — story mode', () =