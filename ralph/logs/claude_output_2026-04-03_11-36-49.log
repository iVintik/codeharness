tsPlugins: true, supportsStreaming: true, costReporting: true },\n252\t    healthCheck: vi.fn(),\n253\t    dispatch: mockDriverDispatch,\n254\t    getLastCost: vi.fn().mockReturnValue(null),\n255\t  });\n256\t\n257\t  mockResolveModel.mockReturnValue('claude-sonnet-4-20250514');\n258\t\n259\t  // Keep legacy mock for backward compat in any test that still references it\n260\t  mockDispatchAgent.mockResolvedValue({\n261\t    sessionId: 'sess-abc-123',\n262\t    success: true,\n263\t    durationMs: 1000,\n264\t    output: 'Done',\n265\t  });\n266\t\n267\t  // Default: sprint-status.yaml exists with two stories\n268\t  mockExistsSync.mockImplementation((path: string) => {\n269\t    if (path === '/project/sprint-status.yaml') return true;\n270\t    return false;\n271\t  });\n272\t\n273\t  mockReadFileSync.mockReturnValue('dummy yaml');\n274\t  mockParse.mockReturnValue({\n275\t    development_status: {\n276\t      'epic-5': 'backlog',\n277\t      '5-1-foo': 'ready-for-dev',\n278\t      '5-2-bar': 'backlog',\n279\t    },\n280\t  });\n281\t}\n282\t\n283\t// --- Tests ---\n284\t\n285\tdescribe('loadWorkItems', () => {\n286\t  beforeEach(() => {\n287\t    vi.clearAllMocks();\n288\t  });\n289\t\n290\t  it('loads stories from sprint-status.yaml excluding epics and retrospectives', () => {\n291\t    mockExistsSync.mockReturnValue(true);\n292\t    mockReadFileSync.mockReturnValue('yaml content');\n293\t    mockParse.mockReturnValue({\n294\t      development_status: {\n295\t        'epic-5': 'backlog',\n296\t        '5-1-foo': 'ready-for-dev',\n297\t        '5-2-bar': 'backlog',\n298\t        '5-3-baz': 'done',\n299\t        'epic-5-retrospective': 'backlog',\n300\t      },\n301\t    });\n302\t\n303\t    const items = loadWorkItems('/path/sprint-status.yaml');\n304\t\n305\t    expect(items).toEqual([\n306\t      { key: '5-1-foo', source: 'sprint' },\n307\t      { key: '5-2-bar', source: 'sprint' },\n308\t    ]);\n309\t  });\n310\t\n311\t  it('returns empty array when sprint-status.yaml does not exist and no issues.yaml', () => {\n312\t    mockExistsSync.mockReturnValue(false);\n313\t\n314\t    const items = loadWorkItems('/nonexistent/sprint-status.yaml');\n315\t    expect(items).toEqual([]);\n316\t  });\n317\t\n318\t  it('returns stories only when issues.yaml does not exist (AC #6)', () => {\n319\t    mockExistsSync.mockImplementation((path: string) => {\n320\t      if (path === '/path/sprint-status.yaml') return true;\n321\t      return false;\n322\t    });\n323\t    mockReadFileSync.mockReturnValue('yaml');\n324\t    mockParse.mockReturnValue({\n325\t      development_status: {\n326\t        '3-1-foo': 'ready-for-dev',\n327\t      },\n328\t    });\n329\t\n330\t    const items = loadWorkItems('/path/sprint-status.yaml', '/path/issues.yaml');\n331\t\n332\t    expect(items).toEqual([{ key: '3-1-foo', source: 'sprint' }]);\n333\t  });\n334\t\n335\t  it('loads both stories and issues when issues.yaml exists (AC #5)', () => {\n336\t    mockExistsSync.mockReturnValue(true);\n337\t    mockReadFileSync.mockReturnValue('yaml');\n338\t    mockParse\n339\t      .mockReturnValueOnce({\n340\t        development_status: {\n341\t          '3-1-foo': 'ready-for-dev',\n342\t        },\n343\t      })\n344\t      .mockReturnValueOnce({\n345\t        issues: [\n346\t          { id: 'issue-001', title: 'Fix docker timeout', status: 'ready-for-dev' },\n347\t          { id: 'issue-002', title: 'Already done', status: 'done' },\n348\t        ],\n349\t      });\n350\t\n351\t    const items = loadWorkItems('/path/sprint-status.yaml', '/path/issues.yaml');\n352\t\n353\t    expect(items).toEqual([\n354\t      { key: '3-1-foo', source: 'sprint' },\n355\t      { key: 'issue-001', title: 'Fix docker timeout', source: 'issues' },\n356\t    ]);\n357\t  });\n358\t\n359\t  it('handles invalid YAML in sprint-status.yaml gracefully', () => {\n360\t    mockExistsSync.mockReturnValue(true);\n361\t    mockReadFileSync.mockReturnValue('yaml');\n362\t    mockParse.mockImplementation(() => {\n363\t      throw new Error('bad yaml');\n364\t    });\n365\t\n366\t    const items = loadWorkItems('/path/sprint-status.yaml');\n367\t    expect(items).toEqual([]);\n368\t    expect(mockWarn).toHaveBeenCalled();\n369\t  });\n370\t\n371\t  it('handles unreadable sprint-status.yaml file gracefully', () => {\n372\t    mockExistsSync.mockReturnValue(true);\n373\t    mockReadFileSync.mockImplementation(() => {\n374\t      throw new Error('EACCES: permission denied');\n375\t    });\n376\t\n377\t    const items = loadWorkItems('/path/sprint-status.yaml');\n378\t    expect(items).toEqual([]);\n379\t    expect(mockWarn).toHaveBeenCalledWith(\n380\t      expect.stringContaining('could not read sprint-status.yaml'),\n381\t    );\n382\t  });\n383\t\n384\t  it('handles unreadable issues.yaml file gracefully', () => {\n385\t    // sprint-status.yaml is fine\n386\t    mockExistsSync.mockReturnValue(true);\n387\t    let readCount = 0;\n388\t    mockReadFileSync.mockImplementation(() => {\n389\t      readCount++;\n390\t      if (readCount === 1) return 'sprint yaml';\n391\t      throw new Error('EACCES: permission denied');\n392\t    });\n393\t    mockParse.mockReturnValue({\n394\t      development_status: { '3-1-foo': 'ready-for-dev' },\n395\t    });\n396\t\n397\t    const items = loadWorkItems('/path/sprint-status.yaml', '/path/issues.yaml');\n398\t    // Should still have the sprint story\n399\t    expect(items).toEqual([{ key: '3-1-foo', source: 'sprint' }]);"}]},"parent_tool_use_id":"toolu_01WzzY2TpSn4HBX8Gw2yuQNF","session_id":"f83470b7-c271-483e-ae93-7fe9bce4b683","uuid":"0b650395-d3f7-4aaf-8aaf-9631e3e8e49d","timestamp":"2026-04-03T07:55:06.494Z"}
