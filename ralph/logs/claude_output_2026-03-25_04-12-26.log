{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AU9Cj6fYvEiBPM6z5tCcoQ","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n     2→import { mkdtempSync, rmSync, mkdirSync, writeFileSync, readFileSync } from 'node:fs';\n     3→import { tmpdir } from 'node:os';\n     4→import { join } from 'node:path';\n     5→\n     6→import {\n     7→  resolveStoryFilePath,\n     8→  readStoryFileStatus,\n     9→  updateStoryFileStatus,\n    10→  beadsStatusToStoryStatus,\n    11→  storyStatusToBeadsStatus,\n    12→  syncBeadsToStoryFile,\n    13→  syncStoryFileToBeads,\n    14→  syncClose,\n    15→  syncAll,\n    16→  readSprintStatus,\n    17→  updateSprintStatus,\n    18→  appendOnboardingEpicToSprint,\n    19→} from '../index.js';\n    20→import type { BeadsIssue } from '../../beads.js';\n    21→\n    22→// Mock output.ts to suppress warnings during tests\n    23→vi.mock('../../output.js', () => ({\n    24→  ok: vi.fn(),\n    25→  fail: vi.fn(),\n    26→  warn: vi.fn(),\n    27→  info: vi.fn(),\n    28→  jsonOutput: vi.fn(),\n    29→}));\n    30→\n    31→let testDir: string;\n    32→\n    33→beforeEach(() => {\n    34→  vi.restoreAllMocks();\n    35→  testDir = mkdtempSync(join(tmpdir(), 'ch-beads-sync-test-'));\n    36→});\n    37→\n    38→afterEach(() => {\n    39→  rmSync(testDir, { recursive: true, force: true });\n    40→});\n    41→\n    42→function makeIssue(overrides: Partial<BeadsIssue> = {}): BeadsIssue {\n    43→  return {\n    44→    id: '1',\n    45→    title: 'Test Story',\n    46→    status: 'open',\n    47→    type: 'story',\n    48→    priority: 1,\n    49→    description: '_bmad-output/implementation-artifacts/3-1-test-story.md',\n    50→    ...overrides,\n    51→  };\n    52→}\n    53→\n    54→function createStoryFile(storyKey: string, status: string): string {\n    55→  const dir = join(testDir, '_bmad-output', 'implementation-artifacts');\n    56→  mkdirSync(dir, { recursive: true });\n    57→  const filePath = join(dir, `${storyKey}.md`);\n    58→  writeFileSync(filePath, `# Story 3.1: Test Story\\n\\nStatus: ${status}\\n\\n## Story\\n\\nAs a developer...\\n`);\n    59→  return filePath;\n    60→}\n    61→\n    62→function createSprintStatusFile(content: string): void {\n    63→  const dir = join(testDir, '_bmad-output', 'implementation-artifacts');\n    64→  mkdirSync(dir, { recursive: true });\n    65→  writeFileSync(join(dir, 'sprint-status.yaml'), content);\n    66→}\n    67→\n    68→// ─── resolveStoryFilePath ───────────────────────────────────────────────────\n    69→\n    70→describe('resolveStoryFilePath', () => {\n    71→  it('extracts path from beads issue description', () => {\n    72→    const issue = makeIssue({\n    73→      description: '_bmad-output/implementation-artifacts/3-1-beads-installation-cli-wrapper.md',\n    74→    });\n    75→    expect(resolveStoryFilePath(issue)).toBe(\n    76→      '_bmad-output/implementation-artifacts/3-1-beads-installation-cli-wrapper.md',\n    77→    );\n    78→  });\n    79→\n    80→  it('returns null for empty description', () => {\n    81→    const issue = makeIssue({ description: '' });\n    82→    expect(resolveStoryFilePath(issue)).toBeNull();\n    83→  });\n    84→\n    85→  it('returns null for undefined description', () => {\n    86→    const issue = makeIssue({ description: undefined });\n    87→    expect(resolveStoryFilePath(issue)).toBeNull();\n    88→  });\n    89→\n    90→  it('returns null for description not ending in .md', () => {\n    91→    const issue = makeIssue({ description: 'some random text' });\n    92→    expect(resolveStoryFilePath(issue)).toBeNull();\n    93→  });\n    94→\n    95→  it('trims whitespace from description', () => {\n    96→    const issue = makeIssue({\n    97→      description: '  _bmad-output/implementation-artifacts/3-1-test.md  ',\n    98→    });\n    99→    expect(resolveStoryFilePath(issue)).toBe(\n   100→      '_bmad-output/implementation-artifacts/3-1-test.md',\n   101→    );\n   102→  });\n   103→});\n   104→\n   105→// ─── readStoryFileStatus ────────────────────────────────────────────────────\n   106→\n   107→describe('readStoryFileStatus', () => {\n   108→  it('reads Status line from markdown file', () => {\n   109→    const filePath = createStoryFile('3-1-test-story', 'ready-for-dev');\n   110→    expect(readStoryFileStatus(filePath)).toBe('ready-for-dev');\n   111→  });\n   112→\n   113→  it('returns null for missing file', () => {\n   114→    expect(readStoryFileStatus('/nonexistent/file.md')).toBeNull();\n   115→  });\n   116→\n   117→  it('returns null for file without Status line', () => {\n   118→    const dir = join(testDir, '_bmad-output', 'implementation-artifacts');\n   119→    mkdirSync(dir, { recursive: true });\n   120→    const filePath = join(dir, 'no-status.md');\n   121→    writeFileSync(filePath, '# Story\\n\\nSome content.\\n');\n   122→    expect(readStoryFileStatus(filePath)).toBeNull();\n   123→  });\n   124→\n   125→  it('handles Status line with extra whitespace', () => {\n   126→    const dir = join(testDir, '_bmad-output', 'implementation-artifacts');\n   127→    mkdirSync(dir, { recursive: true });\n   128→    const filePath = join(dir, 'spaced.md');\n   129→    writeFileSync(filePath, '# Story\\n\\nStatus:   in-progress  \\n');\n   130→    expect(readStoryFileStatus(filePath)).toBe('in-progress');\n   131→  });\n   132→});\n   133→\n   134→// ─── updateStoryFileStatus ──────────────────────────────────────────────────\n   135→\n   136→describe('updateStoryFileStatus', () => {\n   137→  it('updates existing Status line', () => {\n   138→    const filePath = createStoryFile('3-1-update-test', 'ready-for-dev');\n   139→    updateStoryFileStatus(filePath, 'done');\n   140→    const content = readFileSync(filePath, 'utf-8');\n   141→    expect(content).toContain('Status: done');\n   142→    expect(content).not.toContain('Status: ready-for-dev');\n   143→  });\n   144→\n   145→  it('preserves rest of file content', () => {\n   146→    const filePath = createStoryFile('3-1-preserve-test', 'in-progress');\n   147→    updateStoryFileStatus(filePath, 'done');\n   148→    const content = readFileSync(filePath, 'utf-8');\n   149→    expect(content).toContain('# Story 3.1: Test Story');\n   150→    expect(content).toContain('## Story');\n   151→    expect(content).toContain('As a developer...');\n   152→  });\n   153→\n   154→  it('inserts Status line if missing', () => {\n   155→    const dir = join(testDir, '_bmad-output', 'implementation-artifacts');\n   156→    mkdirSync(dir, { recursive: true });\n   157→    const filePath = join(dir, 'no-status.md');\n   158→    writeFileSync(filePath, '# Story 3.1: Test\\n\\n## Story\\n\\nContent here.\\n');\n   159→\n   160→    updateStoryFileStatus(filePath, 'in-progress');\n   161→    const content = readFileSync(filePath, 'utf-8');\n   162→    expect(content).toContain('Status: in-progress');\n   163→    // The Status line should appear after the title\n   164→    const lines = content.split('\\n');\n   165→    const titleIdx = lines.findIndex(l => l.startsWith('# Story'));\n   166→    const statusIdx = lines.findIndex(l => l.startsWith('Status:'));\n   167→    expect(statusIdx).toBeGreaterThan(titleIdx);\n   168→  });\n   169→\n   170→  it('handles file with no title by prepending Status', () => {\n   171→    const dir = join(testDir, '_bmad-output', 'implementation-artifacts');\n   172→    mkdirSync(dir, { recursive: true });\n   173→    const filePath = join(dir, 'no-title.md');\n   174→    writeFileSync(filePath, 'Just some content\\nwithout a title.\\n');\n   175→\n   176→    updateStoryFileStatus(filePath, 'done');\n   177→    const content = readFileSync(filePath, 'utf-8');\n   178→    expect(content).toContain('Status: done');\n   179→  });\n   180→});\n   181→\n   182→// ─── Status Mapping ─────────────────────────────────────────────────────────\n   183→\n   184→describe('status mapping', () => {\n   185→  it('maps beads \"open\" to story \"in-progress\"', () => {\n   186→    expect(beadsStatusToStoryStatus('open')).toBe('in-progress');\n   187→  });\n   188→\n   189→  it('maps beads \"closed\" to story \"done\"', () => {\n   190→    expect(beadsStatusToStoryStatus('closed')).toBe('done');\n   191→  });\n   192→\n   193→  it('returns null for unknown beads status', () => {\n   194→    expect(beadsStatusToStoryStatus('unknown')).toBeNull();\n   195→  });\n   196→\n   197→  it('maps story \"backlog\" to beads \"open\"', () => {\n   198→    expect(storyStatusToBeadsStatus('backlog')).toBe('open');\n   199→  });\n   200→\n   201→  it('maps story \"ready-for-dev\" to beads \"open\"', () => {\n   202→    expect(storyStatusToBeadsStatus('ready-for-dev')).toBe('open');\n   203→  });\n   204→\n   205→  it('maps story \"in-progress\" to beads \"open\"', () => {\n   206→    expect(storyStatusToBeadsStatus('in-progress')).toBe('open');\n   207→  });\n   208→\n   209→  it('maps story \"review\" to beads \"open\"', () => {\n   210→    expect(storyStatusToBeadsStatus('review')).toBe('open');\n   211→  });\n   212→\n   213→  it('maps story \"done\" to beads \"closed\"', () => {\n   214→    expect(storyStatusToBeadsStatus('done')).toBe('closed');\n   215→  });\n   216→\n   217→  it('returns null for unknown story status', () => {\n   218→    expect(storyStatusToBeadsStatus('unknown')).toBeNull();\n   219→  });\n   220→});\n   221→\n   222→// ─── syncBeadsToStoryFile ───────────────────────────────────────────────────\n   223→\n   224→describe('syncBeadsToStoryFile', () => {\n   225→  it('updates story file when statuses differ', () => {\n   226→    const issue = makeIssue({ id: '1', status: 'closed' });\n   227→    createStoryFile('3-1-test-story', 'in-progress');\n   228→\n   229→    const result = syncBeadsToStoryFile('1', { listIssues: () => [issue] }, testDir);\n   230→\n   231→    expect(result.synced).toBe(true);\n   232→    expect(result.previousStatus).toBe('in-progress');\n   233→    expect(result.newStatus).toBe('done');\n   234→    expect(result.storyKey).toBe('3-1-test-story');\n   235→  });\n   236→\n   237→  it('skips when already in sync', () => {\n   238→    const issue = makeIssue({ id: '1', status: 'open' });\n   239→    createStoryFile('3-1-test-story', 'in-progress');\n   240→\n   241→    const result = syncBeadsToStoryFile('1', { listIssues: () => [issue] }, testDir);\n   242→\n   243→    expect(result.synced).toBe(false);\n   244→    expect(result.error).toBeUndefined();\n   245→    expect(result.previousStatus).toBe('in-progress');\n   246→  });\n   247→\n   248→  it('returns error for missing beads issue', () => {\n   249→    const result = syncBeadsToStoryFile('999', { listIssues: () => [] }, testDir);\n   250→    expect(result.synced).toBe(false);\n   251→    expect(result.error).toContain('Beads issue not found');\n   252→  });\n   253→\n   254→  it('returns error when story file not found', () => {\n   255→    const issue = makeIssue({ id: '1', description: '_bmad-output/implementation-artifacts/nonexistent.md' });\n   256→    const result = syncBeadsToStoryFile('1', { listIssues: () => [issue] }, testDir);\n   257→    expect(result.synced).toBe(false);\n   258→    expect(result.error).toContain('Story file not found');\n   259→  });\n   260→\n   261→  it('returns error when description has no valid path', () => {\n   262→    const issue = makeIssue({ id: '1', description: 'not a path' });\n   263→    const result = syncBeadsToStoryFile('1', { listIssues: () => [issue] }, testDir);\n   264→    expect(result.synced).toBe(false);\n   265→    expect(result.error).toContain('No story file path');\n   266→  });\n   267→\n   268→  it('returns error for unknown beads status', () => {\n   269→    const issue = makeIssue({ id: '1', status: 'weird-status' });\n   270→    createStoryFile('3-1-test-story', 'in-progress');\n   271→\n   272→    const result = syncBeadsToStoryFile('1', { listIssues: () => [issue] }, testDir);\n   273→    expect(result.synced).toBe(false);\n   274→    expect(result.error).toContain('Unknown beads status');\n   275→  });\n   276→});\n   277→\n   278→// ─── syncStoryFileToBeads ───────────────────────────────────────────────────\n   279→\n   280→describe('syncStoryFileToBeads', () => {\n   281→  it('updates beads when story status is \"done\" and beads is \"open\"', () => {\n   282→    const issue = makeIssue({ id: '1', status: 'open' });\n   283→    createStoryFile('3-1-test-story', 'done');\n   284→\n   285→    const mockCloseIssue = vi.fn();\n   286→    const mockUpdateIssue = vi.fn();\n   287→\n   288→    const result = syncStoryFileToBeads('3-1-test-story', {\n   289→      listIssues: () => [issue],\n   290→      updateIssue: mockUpdateIssue,\n   291→      closeIssue: mockCloseIssue,\n   292→    }, testDir);\n   293→\n   294→    expect(result.synced).toBe(true);\n   295→    expect(mockCloseIssue).toHaveBeenCalledWith('1');\n   296→    expect(mockUpdateIssue).not.toHaveBeenCalled();\n   297→  });\n   298→\n   299→  it('updates beads when story status is \"in-progress\" and beads is \"closed\"', () => {\n   300→    const issue = makeIssue({ id: '1', status: 'closed' });\n   301→    createStoryFile('3-1-test-story', 'in-progress');\n   302→\n   303→    const mockCloseIssue = vi.fn();\n   304→    const mockUpdateIssue = vi.fn();\n   305→\n   306→    const result = syncStoryFileToBeads('3-1-test-story', {\n   307→      listIssues: () => [issue],\n   308→      updateIssue: mockUpdateIssue,\n   309→      closeIssue: mockCloseIssue,\n   310→    }, testDir);\n   311→\n   312→    expect(result.synced).toBe(true);\n   313→    expect(result.newStatus).toBe('open');\n   314→    expect(mockUpdateIssue).toHaveBeenCalledWith('1', { status: 'open' });\n   315→  });\n   316→\n   317→  it('skips when already in sync', () => {\n   318→    const issue = makeIssue({ id: '1', status: 'open' });\n   319→    createStoryFile('3-1-test-story', 'in-progress');\n   320→\n   321→    const result = syncStoryFileToBeads('3-1-test-story', {\n   322→      listIssues: () => [issue],\n   323→      updateIssue: vi.fn(),\n   324→      closeIssue: vi.fn(),\n   325→    }, testDir);\n   326→\n   327→    expect(result.synced).toBe(false);\n   328→    expect(result.error).toBeUndefined();\n   329→  });\n   330→\n   331→  it('returns error when story file not found', () => {\n   332→    const result = syncStoryFileToBeads('nonexistent', {\n   333→      listIssues: () => [],\n   334→      updateIssue: vi.fn(),\n   335→      closeIssue: vi.fn(),\n   336→    }, testDir);\n   337→\n   338→    expect(result.synced).toBe(false);\n   339→    expect(result.error).toContain('Story file not found');\n   340→  });\n   341→\n   342→  it('returns error when no beads issue matches story key', () => {\n   343→    createStoryFile('3-1-orphan-story', 'in-progress');\n   344→\n   345→    const result = syncStoryFileToBeads('3-1-orphan-story', {\n   346→      listIssues: () => [],\n   347→      updateIssue: vi.fn(),\n   348→      closeIssue: vi.fn(),\n   349→    }, testDir);\n   350→\n   351→    expect(result.synced).toBe(false);\n   352→    expect(result.error).toContain('No beads issue found');\n   353→  });\n   354→\n   355→  it('returns error for unknown story status', () => {\n   356→    const issue = makeIssue({ id: '1', status: 'open' });\n   357→    // Create a file with a non-standard status\n   358→    const dir = join(testDir, '_bmad-output', 'implementation-artifacts');\n   359→    mkdirSync(dir, { recursive: true });\n   360→    writeFileSync(join(dir, '3-1-test-story.md'), '# Story\\n\\nStatus: weird-status\\n');\n   361→\n   362→    const result = syncStoryFileToBeads('3-1-test-story', {\n   363→      listIssues: () => [issue],\n   364→      updateIssue: vi.fn(),\n   365→      closeIssue: vi.fn(),\n   366→    }, testDir);\n   367→\n   368→    expect(result.synced).toBe(false);\n   369→    expect(result.error).toContain('Unknown story status');\n   370→  });\n   371→});\n   372→\n   373→// ─── syncClose ──────────────────────────────────────────────────────────────\n   374→\n   375→describe('syncClose', () => {\n   376→  it('closes beads issue and updates story file to done', () => {\n   377→    const issue = makeIssue({ id: '1', status: 'closed' });\n   378→    createStoryFile('3-1-test-story', 'in-progress');\n   379→\n   380→    const mockCloseIssue = vi.fn();\n   381→\n   382→    const result = syncClose('1', {\n   383→      closeIssue: mockCloseIssue,\n   384→      listIssues: () => [issue],\n   385→    }, testDir);\n   386→\n   387→    expect(result.synced).toBe(true);\n   388→    expect(result.newStatus).toBe('done');\n   389→    expect(result.previousStatus).toBe('in-progress');\n   390→    expect(mockCloseIssue).toHaveBeenCalledWith('1');\n   391→\n   392→    // Verify file was updated\n   393→    const fullPath = join(testDir, '_bmad-output', 'implementation-artifacts', '3-1-test-story.md');\n   394→    expect(readFileSync(fullPath, 'utf-8')).toContain('Status: done');\n   395→  });\n   396→\n   397→  it('handles missing story file gracefully', () => {\n   398→    const issue = makeIssue({ id: '1', status: 'closed', description: '_bmad-output/implementation-artifacts/nonexistent.md' });\n   399→    const mockCloseIssue = vi.fn();\n   400→\n   401→    const result = syncClose('1', {\n   402→      closeIssue: mockCloseIssue,\n   403→      listIssues: () => [issue],\n   404→    }, testDir);\n   405→\n   406→    expect(result.synced).toBe(false);\n   407→    expect(result.error).toContain('Story file not found');\n   408→    expect(mockCloseIssue).toHaveBeenCalledWith('1');\n   409→  });\n   410→\n   411→  it('handles already-closed issue — still updates story file to done (idempotent)', () => {\n   412→    const issue = makeIssue({ id: '1', status: 'closed' });\n   413→    createStoryFile('3-1-test-story', 'done');\n   414→\n   415→    const mockCloseIssue = vi.fn();\n   416→\n   417→    const result = syncClose('1', {\n   418→      closeIssue: mockCloseIssue,\n   419→      listIssues: () => [issue],\n   420→    }, testDir);\n   421→\n   422→    // closeIssue is still called (idempotent)\n   423→    expect(mockCloseIssue).toHaveBeenCalledWith('1');\n   424→    expect(result.synced).toBe(true);\n   425→    expect(result.newStatus).toBe('done');\n   426→  });\n   427→\n   428→  it('handles issue with no description', () => {\n   429→    const issue = makeIssue({ id: '1', description: undefined });\n   430→    const mockCloseIssue = vi.fn();\n   431→\n   432→    const result = syncClose('1', {\n   433→      closeIssue: mockCloseIssue,\n   434→      listIssues: () => [issue],\n   435→    }, testDir);\n   436→\n   437→    expect(result.synced).toBe(false);\n   438→    expect(result.error).toContain('No story file path');\n   439→  });\n   440→\n   441→  it('calls listIssues before closeIssue to capture issue data', () => {\n   442→    const callOrder: string[] = [];\n   443→    const issue = makeIssue({ id: '1', status: 'open' });\n   444→    createStoryFile('3-1-test-story', 'in-progress');\n   445→\n   446→    const result = syncClose('1', {\n   447→      closeIssue: () => { callOrder.push('close'); },\n   448→      listIssues: () => { callOrder.push('list'); return [issue]; },\n   449→    }, testDir);\n   450→\n   451→    expect(callOrder).toEqual(['list', 'close']);\n   452→    expect(result.synced).toBe(true);\n   453→  });\n   454→\n   455→  it('handles issue not found', () => {\n   456→    const mockCloseIssue = vi.fn();\n   457→\n   458→    const result = syncClose('999', {\n   459→      closeIssue: mockCloseIssue,\n   460→      listIssues: () => [],\n   461→    }, testDir);\n   462→\n   463→    expect(result.synced).toBe(false);\n   464→    expect(result.error).toContain('Beads issue not found');\n   465→    // closeIssue is still called even if issue not in list\n   466→    expect(mockCloseIssue).toHaveBeenCalledWith('999');\n   467→  });\n   468→});\n   469→\n   470→// ─── syncAll ────────────────────────────────────────────────────────────────\n   471→\n   472→describe('syncAll', () => {\n   473→  it('syncs multiple issues in beads-to-files direction', () => {\n   474→    const issues = [\n   475→      makeIssue({ id: '1', status: 'closed', description: '_bmad-output/implementation-artifacts/3-1-story-a.md' }),\n   476→      makeIssue({ id: '2', status: 'open', description: '_bmad-output/implementation-artifacts/3-2-story-b.md' }),\n   477→    ];\n   478→\n   479→    createStoryFile('3-1-story-a', 'in-progress');\n   480→    createStoryFile('3-2-story-b', 'in-progress');\n   481→\n   482→    const results = syncAll('beads-to-files', {\n   483→      listIssues: () => issues,\n   484→      updateIssue: vi.fn(),\n   485→      closeIssue: vi.fn(),\n   486→    }, testDir);\n   487→\n   488→    expect(results).toHaveLength(2);\n   489→    // Story A: closed -> done (synced)\n   490→    expect(results[0].synced).toBe(true);\n   491→    expect(results[0].newStatus).toBe('done');\n   492→    // Story B: open -> in-progress (already in sync)\n   493→    expect(results[1].synced).toBe(false);\n   494→    expect(results[1].error).toBeUndefined();\n   495→  });\n   496→\n   497→  it('syncs in files-to-beads direction', () => {\n   498→    const issue = makeIssue({ id: '1', status: 'open' });\n   499→    createStoryFile('3-1-test-story', 'done');\n   500→\n   501→    const mockCloseIssue = vi.fn();\n   502→\n   503→    const results = syncAll('files-to-beads', {\n   504→      listIssues: () => [issue],\n   505→      updateIssue: vi.fn(),\n   506→      closeIssue: mockCloseIssue,\n   507→    }, testDir);\n   508→\n   509→    expect(results).toHaveLength(1);\n   510→    expect(results[0].synced).toBe(true);\n   511→    expect(mockCloseIssue).toHaveBeenCalledWith('1');\n   512→  });\n   513→\n   514→  it('returns correct counts', () => {\n   515→    const issues = [\n   516→      makeIssue({ id: '1', status: 'closed', description: '_bmad-output/implementation-artifacts/3-1-synced.md' }),\n   517→      makeIssue({ id: '2', status: 'open', description: '_bmad-output/implementation-artifacts/3-2-in-sync.md' }),\n   518→      makeIssue({ id: '3', status: 'open', description: '_bmad-output/implementation-artifacts/3-3-missing.md' }),\n   519→    ];\n   520→\n   521→    createStoryFile('3-1-synced', 'in-progress');\n   522→    createStoryFile('3-2-in-sync', 'in-progress');\n   523→    // 3-3-missing.md doesn't exist\n   524→\n   525→    const results = syncAll('beads-to-files', {\n   526→      listIssues: () => issues,\n   527→      updateIssue: vi.fn(),\n   528→      closeIssue: vi.fn(),\n   529→    }, testDir);\n   530→\n   531→    const syncedCount = results.filter(r => r.synced).length;\n   532→    const alreadyInSync = results.filter(r => !r.synced && !r.error).length;\n   533→    const errorCount = results.filter(r => !!r.error).length;\n   534→\n   535→    expect(syncedCount).toBe(1); // 3-1 was synced\n   536→    expect(alreadyInSync).toBe(1); // 3-2 was already in sync\n   537→    expect(errorCount).toBe(1); // 3-3 had an error\n   538→  });\n   539→\n   540→  it('handles errors per-issue without aborting', () => {\n   541→    const issues = [\n   542→      makeIssue({ id: '1', status: 'open', description: '_bmad-output/implementation-artifacts/3-1-missing.md' }),\n   543→      makeIssue({ id: '2', status: 'closed', description: '_bmad-output/implementation-artifacts/3-2-exists.md' }),\n   544→    ];\n   545→\n   546→    // Only create the second story file\n   547→    createStoryFile('3-2-exists', 'in-progress');\n   548→\n   549→    const results = syncAll('beads-to-files', {\n   550→      listIssues: () => issues,\n   551→      updateIssue: vi.fn(),\n   552→      closeIssue: vi.fn(),\n   553→    }, testDir);\n   554→\n   555→    expect(results).toHaveLength(2);\n   556→    expect(results[0].error).toBeTruthy();\n   557→    expect(results[1].synced).toBe(true);\n   558→  });\n   559→\n   560→  it('skips issues without story file paths', () => {\n   561→    const issues = [\n   562→      makeIssue({ id: '1', status: 'open', description: undefined }),\n   563→      makeIssue({ id: '2', status: 'open', description: 'not-a-path' }),\n   564→      makeIssue({ id: '3', status: 'closed', description: '_bmad-output/implementation-artifacts/3-1-valid.md' }),\n   565→    ];\n   566→\n   567→    createStoryFile('3-1-valid', 'in-progress');\n   568→\n   569→    const results = syncAll('beads-to-files', {\n   570→      listIssues: () => issues,\n   571→      updateIssue: vi.fn(),\n   572→      closeIssue: vi.fn(),\n   573→    }, testDir);\n   574→\n   575→    // Only the valid issue should be processed\n   576→    expect(results).toHaveLength(1);\n   577→    expect(results[0].storyKey).toBe('3-1-valid');\n   578→  });\n   579→\n   580→  it('handles listIssues failure gracefully', () => {\n   581→    const results = syncAll('beads-to-files', {\n   582→      listIssues: () => { throw new Error('bd not available'); },\n   583→      updateIssue: vi.fn(),\n   584→      closeIssue: vi.fn(),\n   585→    }, testDir);\n   586→\n   587→    expect(results).toHaveLength(1);\n   588→    expect(results[0].error).toContain('Failed to list beads issues');\n   589→  });\n   590→});\n   591→\n   592→// ─── readSprintStatus ───────────────────────────────────────────────────────\n   593→\n   594→describe('readSprintStatus', () => {\n   595→  it('reads development_status map from sprint-status.yaml', () => {\n   596→    createSprintStatusFile(`generated: 2026-03-15\n   597→project: codeharness\n   598→development_status:\n   599→  epic-1: done\n   600→  1-1-test-story: in-progress\n   601→`);\n   602→\n   603→    const status = readSprintStatus(testDir);\n   604→    expect(status['epic-1']).toBe('done');\n   605→    expect(status['1-1-test-story']).toBe('in-progress');\n   606→  });\n   607→\n   608→  it('returns empty object when file does not exist', () => {\n   609→