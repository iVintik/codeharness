hing');\n797\t    expect(frame).toContain('Phase: verify');\n798\t    expect(frame).toContain('AC 8/12');\n799\t    expect(frame).toContain('(docker exec ... codeharness init --json)');\n800\t\n801\t    // Labeled story sections\n802\t    expect(frame).toContain('Done:');\n803\t    expect(frame).toContain('3-1 ✓');\n804\t    expect(frame).toContain('4-1 ✓');\n805\t    expect(frame).toContain('4-2 ✓');\n806\t    expect(frame).toContain('This:');\n807\t    expect(frame).toContain('3-2 ◆');\n808\t    expect(frame).toContain('Next:');\n809\t    expect(frame).toContain('3-3');\n810\t    expect(frame).toContain('Blocked:');\n811\t    expect(frame).toContain('0-1 ✕ (10/10)');\n812\t    expect(frame).toContain('13-3 ✕ (10/10)');\n813\t\n814\t    // No Ink Box border artifacts\n815\t    expect(frame).not.toContain('╭');\n816\t    expect(frame).not.toContain('╮');\n817\t    expect(frame).not.toContain('╰');\n818\t    expect(frame).not.toContain('╯');\n819\t    expect(frame).not.toMatch(/│/);\n820\t  });\n821\t\n822\t  it('renders story completion in spec format', () => {\n823\t    const msg: StoryMessage = {\n824\t      type: 'ok',\n825\t      key: '3-2',\n826\t      message: 'DONE — 12/12 ACs verified',\n827\t      details: [\n828\t        'Proof: verification/3-2-proof.md',\n829\t        'Duration: 18m | Cost: $4.20',\n830\t      ],\n831\t    };\n832\t    const { lastFrame } = render(<StoryMessageLine msg={msg} />);\n833\t    const frame = lastFrame()!;\n834\t    expect(frame).toContain('[OK] Story 3-2: DONE — 12/12 ACs verified');\n835\t    expect(frame).toContain('└ Proof: verification/3-2-proof.md');\n836\t    expect(frame).toContain('└ Duration: 18m | Cost: $4.20');\n837\t  });\n838\t\n839\t  it('renders story warning in spec format', () => {\n840\t    const msg: StoryMessage = {\n841\t      type: 'warn',\n842\t      key: '3-3',\n843\t      message: 'verification found 2 failing ACs → returning to dev',\n844\t      details: [\n845\t        'AC 3: bridge --dry-run output