{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018ACiZ5pTMbed4R3oTs1Ae9","type":"tool_result","content":"     1→/**\n     2→ * OpenSearchBackend — ObservabilityBackend implementation for OpenSearch.\n     3→ * Queries logs, metrics, and traces via the OpenSearch/Elasticsearch _search API.\n     4→ * Uses Node.js built-in fetch (no external HTTP dependencies).\n     5→ */\n     6→import type {\n     7→  ObservabilityBackend, LogQuery, LogResult, LogEntry,\n     8→  MetricQuery, MetricResult, MetricSeries, MetricDataPoint,\n     9→  TraceQuery, TraceResult, TraceSpan, HealthStatus,\n    10→} from '../../types/observability.js';\n    11→import type { Result } from '../../types/result.js';\n    12→import { ok, fail } from '../../types/result.js';\n    13→\n    14→/** Configuration for OpenSearchBackend */\n    15→export interface OpenSearchConfig {\n    16→  url: string;\n    17→  logsIndex?: string;\n    18→  metricsIndex?: string;\n    19→  tracesIndex?: string;\n    20→}\n    21→\n    22→const QUERY_TIMEOUT_MS = 30_000;\n    23→const HEALTH_TIMEOUT_MS = 5_000;\n    24→\n    25→export class OpenSearchBackend implements ObservabilityBackend {\n    26→  readonly type = 'opensearch' as const;\n    27→  private readonly url: string;\n    28→  private readonly logsIndex: string;\n    29→  private readonly metricsIndex: string;\n    30→  private readonly tracesIndex: string;\n    31→\n    32→  constructor(config: OpenSearchConfig) {\n    33→    this.url = config.url.replace(/\\/+$/, '');\n    34→    this.logsIndex = config.logsIndex ?? 'otel-logs-*';\n    35→    this.metricsIndex = config.metricsIndex ?? 'otel-metrics-*';\n    36→    this.tracesIndex = config.tracesIndex ?? 'otel-traces-*';\n    37→  }\n    38→\n    39→  async queryLogs(params: LogQuery): Promise<Result<LogResult>> {\n    40→    const endpoint = `${this.url}/${this.logsIndex}/_search`;\n    41→    const body = {\n    42→      query: { bool: { must: [\n    43→        { query_string: { query: params.query } },\n    44→        rangeFilter(params.timeRange.start, params.timeRange.end),\n    45→      ] } },\n    46→      size: params.limit ?? 100,\n    47→    };\n    48→    return this.post(endpoint, body, (data: OpenSearchResponse) => {\n    49→      const entries = parseLogHits(data);\n    50→      return ok({ entries, total: entries.length });\n    51→    });\n    52→  }\n    53→\n    54→  async queryMetrics(params: MetricQuery): Promise<Result<MetricResult>> {\n    55→    const endpoint = `${this.url}/${this.metricsIndex}/_search`;\n    56→    const body = {\n    57→      query: { bool: { must: [\n    58→        { query_string: { query: params.query } },\n    59→        rangeFilter(params.timeRange.start, params.timeRange.end),\n    60→      ] } },\n    61→      size: 0,\n    62→      aggs: {\n    63→        over_time: {\n    64→          date_histogram: { field: '@timestamp', fixed_interval: params.step ?? '60s' },\n    65→          aggs: { avg_value: { avg: { field: 'value' } } },\n    66→        },\n    67→      },\n    68→    };\n    69→    return this.post(endpoint, body, (data: OpenSearchAggResponse) => {\n    70→      const buckets = data.aggregations?.over_time?.buckets ?? [];\n    71→      if (buckets.length === 0) return ok({ series: [] });\n    72→      const dataPoints: MetricDataPoint[] = buckets.map((b) => ({\n    73→        timestamp: b.key_as_string ?? String(b.key ?? ''),\n    74→        value: b.avg_value?.value ?? 0,\n    75→      }));\n    76→      return ok({ series: [{ labels: {}, dataPoints }] as MetricSeries[] });\n    77→    });\n    78→  }\n    79→\n    80→  async queryTraces(params: TraceQuery): Promise<Result<TraceResult>> {\n    81→    const endpoint = `${this.url}/${this.tracesIndex}/_search`;\n    82→    const must: Record<string, unknown>[] = [];\n    83→    if (params.serviceName) must.push({ term: { 'resource.service.name': params.serviceName } });\n    84→    if (params.operationName) must.push({ term: { name: params.operationName } });\n    85→    must.push(rangeFilter(params.timeRange.start, params.timeRange.end));\n    86→    const body = { query: { bool: { must } }, size: params.limit ?? 100 };\n    87→    return this.post(endpoint, body, (data: OpenSearchResponse) => {\n    88→      const spans = parseTraceHits(data);\n    89→      return ok({ spans });\n    90→    });\n    91→  }\n    92→\n    93→  async healthCheck(): Promise<Result<HealthStatus>> {\n    94→    const endpoint = `${this.url}/_cluster/health`;\n    95→    const start = Date.now();\n    96→    try {\n    97→      const response = await fetch(endpoint, { signal: AbortSignal.timeout(HEALTH_TIMEOUT_MS) });\n    98→      const latencyMs = Date.now() - start;\n    99→      if (!response.ok) return ok({ healthy: false, message: `OpenSearch returned HTTP ${response.status}`, latencyMs });\n   100→      const body = (await response.json()) as { status?: string };\n   101→      const status = body.status ?? 'unknown';\n   102→      const healthy = status === 'green' || status === 'yellow';\n   103→      return ok({ healthy, message: `Cluster status: ${status}`, latencyMs });\n   104→    } catch (err) {\n   105→      return ok({ healthy: false, message: errMsg(err), latencyMs: Date.now() - start });\n   106→    }\n   107→  }\n   108→\n   109→  /** Shared POST helper — sends JSON body, parses response with provided parser */\n   110→  private async post<T, R>(endpoint: string, body: unknown, parse: (data: T) => Result<R>): Promise<Result<R>> {\n   111→    try {\n   112→      const response = await fetch(endpoint, {\n   113→        method: 'POST',\n   114→        headers: { 'Content-Type': 'application/json' },\n   115→        body: JSON.stringify(body),\n   116→        signal: AbortSignal.timeout(QUERY_TIMEOUT_MS),\n   117→      });\n   118→      if (!response.ok) return fail(`OpenSearch returned ${response.status}`, { endpoint, statusCode: response.status });\n   119→      return parse((await response.json()) as T);\n   120→    } catch (err) {\n   121→      return fail(errMsg(err), { endpoint });\n   122→    }\n   123→  }\n   124→}\n   125→\n   126→// --- Helpers & response types ---\n   127→\n   128→function errMsg(err: unknown): string {\n   129→  return err instanceof Error ? err.message : String(err);\n   130→}\n   131→\n   132→function rangeFilter(gte: string, lte: string): Record<string, unknown> {\n   133→  return { range: { '@timestamp': { gte, lte } } };\n   134→}\n   135→\n   136→interface OpenSearchHit { _source?: Record<string, unknown> }\n   137→interface OpenSearchResponse { hits?: { hits?: OpenSearchHit[] } }\n   138→interface OpenSearchAggBucket { key_as_string?: string; key?: number; avg_value?: { value?: number | null } }\n   139→interface OpenSearchAggResponse { aggregations?: { over_time?: { buckets?: OpenSearchAggBucket[] } } }\n   140→\n   141→const LOG_SKIP_FIELDS = new Set(['@timestamp', 'timestamp', 'body', 'message', 'severity', 'level', 'severityText']);\n   142→\n   143→function parseLogHits(data: OpenSearchResponse): LogEntry[] {\n   144→  return (data.hits?.hits ?? []).map((hit) => {\n   145→    const src = hit._source ?? {};\n   146→    const labels: Record<string, string> = {};\n   147→    for (const [k, v] of Object.entries(src)) {\n   148→      if (!LOG_SKIP_FIELDS.has(k) && v != null && typeof v !== 'object') labels[k] = String(v);\n   149→    }\n   150→    return {\n   151→      timestamp: String(src['@timestamp'] ?? src['timestamp'] ?? ''),\n   152→      message: String(src['body'] ?? src['message'] ?? ''),\n   153→      level: String(src['severityText'] ?? src['severity'] ?? src['level'] ?? 'unknown'),\n   154→      labels,\n   155→    };\n   156→  });\n   157→}\n   158→\n   159→function parseTraceHits(data: OpenSearchResponse): TraceSpan[] {\n   160→  return (data.hits?.hits ?? []).map((hit) => {\n   161→    const src = hit._source ?? {};\n   162→    const tags: Record<string, string> = {};\n   163→    const attrs = src['attributes'] as Record<string, unknown> | undefined;\n   164→    if (attrs && typeof attrs === 'object') {\n   165→      for (const [k, v] of Object.entries(attrs)) { if (v != null) tags[k] = String(v); }\n   166→    }\n   167→    const resource = src['resource'] as Record<string, unknown> | undefined;\n   168→    const serviceName = resource\n   169→      ? String((resource['service.name'] ?? (resource['service'] as Record<string, unknown> | undefined)?.['name']) ?? '')\n   170→      : '';\n   171→    return {\n   172→      traceId: String(src['traceId'] ?? src['trace_id'] ?? ''),\n   173→      spanId: String(src['spanId'] ?? src['span_id'] ?? ''),\n   174→      parentSpanId: (src['parentSpanId'] ?? src['parent_span_id'] ?? null) as string | null,\n   175→      operationName: String(src['name'] ?? ''),\n   176→      serviceName,\n   177→      startTime: String(src['startTime'] ?? src['@timestamp'] ?? ''),\n   178→      duration: Number(src['duration'] ?? 0),\n   179→      tags,\n   180→    };\n   181→  });\n   182→}\n   183→"}]},"parent_tool_use_id":"toolu_011GhyUaMpB5RRP9ifchfuED","session_id":"790cd04c-5c91-45bb-998d-78a56b65af9a","uuid":"32945211-ea8a-4e69-934b-111a9d94eaab","timestamp":"2026-03-24T23:02:42.787Z"}
