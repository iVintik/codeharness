→    writeFileSync(join(testDir, 'AGENTS.md'), '# existing');\n   154→    const result = await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: false });\n   155→    expect(result.success).toBe(true);\n   156→    if (result.success) {\n   157→      expect(result.data.agents_md).toBe('exists');\n   158→    }\n   159→  });\n   160→\n   161→  it('creates docs scaffold when docs/ does not exist', async () => {\n   162→    const result = await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: false });\n   163→    expect(result.success).toBe(true);\n   164→    if (result.success) {\n   165→      expect(result.data.docs_scaffold).toBe('created');\n   166→    }\n   167→  });\n   168→\n   169→  it('creates README.md when it does not exist', async () => {\n   170→    const result = await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: false });\n   171→    expect(result.success).toBe(true);\n   172→    if (result.success) {\n   173→      expect(result.data.readme).toBe('created');\n   174→    }\n   175→  });\n   176→\n   177→  it('reports exists when README.md already exists', async () => {\n   178→    writeFileSync(join(testDir, 'README.md'), '# existing');\n   179→    const result = await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: false });\n   180→    expect(result.success).toBe(true);\n   181→    if (result.success) {\n   182→      expect(result.data.readme).toBe('exists');\n   183→    }\n   184→  });\n   185→\n   186→  it('suppresses console output in json mode', async () => {\n   187→    const spy = vi.spyOn(console, 'log');\n   188→    await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: true });\n   189→    // In json mode, no [OK]/[INFO] messages should be printed\n   190→    const calls = spy.mock.calls.map(c => c[0] as string);\n   191→    const outputCalls = calls.filter(c => c && (c.startsWith('[OK]') || c.startsWith('[INFO]')));\n   192→    expect(outputCalls).toHaveLength(0);\n   193→  });\n  