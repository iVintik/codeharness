e,\n613\t              evaluator_scores: [...currentState.evaluator_scores, score],\n614\t            };\n615\t          }\n616\t          writeWorkflowState(currentState, projectDir);\n617\t        } catch (err: unknown) {\n618\t          const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n619\t          errors.push(engineError);\n620\t          currentState = recordErrorInState(currentState, taskName, PER_RUN_SENTINEL, engineError);\n621\t          writeWorkflowState(currentState, projectDir);\n622\t\n623\t          // Clear stale verdict so next iteration retries all items\n624\t          lastVerdict = null;\n625\t\n626\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n627\t            haltedInLoop = true;\n628\t            break;\n629\t          }\n630\t          continue;\n631\t        }\n632\t      }\n633\t    }\n634\t\n635\t    if (haltedInLoop) {\n636\t      return { state: currentState, errors, tasksCompleted, halted: true };\n637\t    }\n638\t\n639\t    // 3. Check termination conditions\n640\t    if (lastVerdict?.verdict === 'pass') {\n641\t      // Success: loop passes\n642\t      return { state: currentState, errors, tasksCompleted, halted: false };\n643\t    }\n644\t\n645\t    if (currentState.iteration >= maxIterations) {\n646\t      currentState = { ...currentState, phase: 'max-iterations' };\n647\t      writeWorkflowState(currentState, projectDir);\n648\t      return { state: currentState, errors, tasksCompleted, halted: false };\n649\t    }\n650\t\n651\t    if (currentState.circuit_breaker.triggered) {\n652\t      currentState = { ...currentState, phase: 'circuit-breaker' };\n653\t      writeWorkflowState(currentState, projectDir);\n654\t      return { state: currentState, errors, tasksCompleted, halted: false };\n655\t    }\n656\t  }\n657\t}\n658\t\n659\t\n660\t// --- Main Execution ---\n661\t\n662\t/**\n663\t * Execute a workflow sequentially: iterate through flow steps, dispatch tasks\n664\t