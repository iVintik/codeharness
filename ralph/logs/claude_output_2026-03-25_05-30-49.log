{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015AQw8bqt1QdDYrhztghGig","type":"tool_result","content":"     1→/**\n     2→ * Boundary tests — enforces NFR3 (no bare catch) and NFR6 (module imports through index.ts).\n     3→ *\n     4→ * Scans all .ts files in src/ for:\n     5→ * 1. Catch blocks without // IGNORE: comments (NFR3)\n     6→ * 2. Cross-module internal imports bypassing barrel files (NFR6)\n     7→ */\n     8→\n     9→import { describe, it, expect } from 'vitest';\n    10→import { readdirSync, readFileSync, statSync } from 'node:fs';\n    11→import { join, relative } from 'node:path';\n    12→\n    13→const SRC_DIR = join(__dirname, '..');\n    14→\n    15→// ─── Shared file walker ─────────────────────────────────────────────────────\n    16→\n    17→/** Recursively collect all .ts files under a directory (excluding common skip dirs). */\n    18→function collectTsFiles(dir: string): string[] {\n    19→  const results: string[] = [];\n    20→  let entries: string[];\n    21→  try {\n    22→    entries = readdirSync(dir);\n    23→  } catch {\n    24→    // IGNORE: directory may not be readable\n    25→    return results;\n    26→  }\n    27→  for (const name of entries) {\n    28→    const fullPath = join(dir, name);\n    29→    try {\n    30→      const stat = statSync(fullPath);\n    31→      if (stat.isDirectory()) {\n    32→        if (['node_modules', 'coverage', 'dist'].includes(name)) continue;\n    33→        results.push(...collectTsFiles(fullPath));\n    34→      } else if (stat.isFile() && name.endsWith('.ts')) {\n    35→        results.push(fullPath);\n    36→      }\n    37→    } catch {\n    38→      // IGNORE: stat may fail, skip entry\n    39→      continue;\n    40→    }\n    41→  }\n    42→  return results;\n    43→}\n    44→\n    45→// ─── NFR3: No bare catch {} without // IGNORE: comment ──────────────────────\n    46→\n    47→describe('catch block enforcement (NFR3)', () => {\n    48→  const allFiles = collectTsFiles(SRC_DIR);\n    49→  // Exclude test files — they are covered separately\n    50→  const sourceFiles = allFiles.filter(\n    51→    (f) => !f.includes('__tests__') && !f.endsWith('.test.ts'),\n    52→  );\n    53→\n    54→  it('all catch blocks have // IGNORE: comment, rethrow, or Result.fail()', () => {\n    55→    const violations: Array<{ file: string; line: number; content: string }> = [];\n    56→\n    57→    for (const filePath of sourceFiles) {\n    58→      const content = readFileSync(filePath, 'utf-8');\n    59→      const lines = content.split('\\n');\n    60→\n    61→      for (let i = 0; i < lines.length; i++) {\n    62→        const line = lines[i];\n    63→        // Match lines that contain `catch {` or `catch{`\n    64→        if (!/catch\\s*\\{/.test(line)) continue;\n    65→\n    66→        // Check if the catch block itself has an inline comment with IGNORE:\n    67→        if (/IGNORE:/.test(line)) continue;\n    68→\n    69→        // Check the next few lines (up to 3) for an IGNORE: comment\n    70→        let hasIgnore = false;\n    71→        for (let j = i + 1; j < Math.min(i + 4, lines.length); j++) {\n    72→          const nextLine = lines[j].trim();\n    73→          if (/\\/\\/\\s*IGNORE:/.test(nextLine)) {\n    74→            hasIgnore = true;\n    75→            break;\n    76→          }\n    77→          // If we hit a non-comment, non-empty line that isn't the closing brace, stop looking\n    78→          if (nextLine && !nextLine.startsWith('//') && !nextLine.startsWith('/*') && !nextLine.startsWith('*') && nextLine !== '}') {\n    79→            break;\n    80→          }\n    81→        }\n    82→\n    83→        if (!hasIgnore) {\n    84→          violations.push({\n    85→            file: relative(SRC_DIR, filePath),\n    86→            line: i + 1,\n    87→            content: line.trim(),\n    88→          });\n    89→        }\n    90→      }\n    91→    }\n    92→\n    93→    if (violations.length > 0) {\n    94→      const report = violations\n    95→        .map((v) => `  ${v.file}:${v.line} — ${v.content}`)\n    96→        .join('\\n');\n    97→      expect.fail(\n    98→        `Found ${violations.length} catch block(s) without // IGNORE: comment:\\n${report}`,\n    99→      );\n   100→    }\n   101→\n   102→    expect(violations).toHaveLength(0);\n   103→  });\n   104→});\n   105→\n   106→// ─── NFR6: Module imports only through index.ts ─────────────────────────────\n   107→\n   108→describe('module import boundary (NFR6)', () => {\n   109→  const allFiles = collectTsFiles(SRC_DIR);\n   110→\n   111→  /**\n   112→   * Modules under src/modules/ and domain directories under src/lib/\n   113→   * that enforce barrel-only imports from external consumers.\n   114→   */\n   115→  const PROTECTED_DIRS = [\n   116→    'modules/infra',\n   117→    'modules/verify',\n   118→    'modules/observability',\n   119→    'modules/audit',\n   120→    'modules/review',\n   121→    'modules/dev',\n   122→    'modules/status',\n   123→    'modules/sprint',\n   124→    'lib/coverage',\n   125→    'lib/docker',\n   126→    'lib/stacks',\n   127→    'lib/sync',\n   128→    'lib/observability',\n   129→  ];\n   130→\n   131→  /**\n   132→   * Pattern: import from '.../<protected-dir>/<internal-file>'\n   133→   * where <internal-file> is NOT index, index.js, or index.ts.\n   134→   *\n   135→   * This catches direct imports into module internals like:\n   136→   *   import { foo } from '../../modules/infra/container-cleanup.js'\n   137→   * but allows:\n   138→   *   import { foo } from '../../modules/infra/index.js'\n   139→   */\n   140→  function isInternalImport(importPath: string): { protected: boolean; dir: string } {\n   141→    for (const dir of PROTECTED_DIRS) {\n   142→      // Match import paths that reference a protected directory with a file after it\n   143→      // Allow: .../modules/infra/index.js, .../modules/infra/index\n   144→      // Reject: .../modules/infra/container-cleanup.js, .../modules/infra/types.js\n   145→      const regex = new RegExp(`/${dir}/([^'\"]+)$`);\n   146→      const match = regex.exec(importPath);\n   147→      if (match) {\n   148→        const fileName = match[1];\n   149→        // Allow index imports (index, index.js, index.ts)\n   150→        if (/^index(\\.(js|ts))?$/.test(fileName)) continue;\n   151→        return { protected: true, dir };\n   152→      }\n   153→    }\n   154→    return { protected: false, dir: '' };\n   155→  }\n   156→\n   157→  it('no cross-module imports bypass barrel files (index.ts)', () => {\n   158→    const violations: Array<{ file: string; line: number; content: string; dir: string }> = [];\n   159→\n   160→    for (const filePath of allFiles) {\n   161→      const relPath = relative(SRC_DIR, filePath);\n   162→\n   163→      // Files INSIDE a protected directory can import their own siblings\n   164→      const isInsideProtected = PROTECTED_DIRS.some(\n   165→        (dir) => relPath.startsWith(dir + '/') || relPath.startsWith(dir + '\\\\'),\n   166→      );\n   167→      if (isInsideProtected) continue;\n   168→\n   169→      const content = readFileSync(filePath, 'utf-8');\n   170→      const lines = content.split('\\n');\n   171→\n   172→      for (let i = 0; i < lines.length; i++) {\n   173→        const line = lines[i];\n   174→        // Skip comments\n   175→        if (line.trimStart().startsWith('//') || line.trimStart().startsWith('*')) continue;\n   176→\n   177→        // Match import/export from statements\n   178→        const importMatch = /(?:import|export)\\s+.*from\\s+['\"]([^'\"]+)['\"]/g;\n   179→        let match;\n   180→        while ((match = importMatch.exec(line)) !== null) {\n   181→          const importPath = match[1];\n   182→          const result = isInternalImport(importPath);\n   183→          if (result.protected) {\n   184→            violations.push({\n   185→              file: relPath,\n   186→              line: i + 1,\n   187→              content: line.trim(),\n   188→              dir: result.dir,\n   189→            });\n   190→          }\n   191→        }\n   192→      }\n   193→    }\n   194→\n   195→    if (violations.length > 0) {\n   196→      const report = violations\n   197→        .map((v) => `  ${v.file}:${v.line} [${v.dir}] — ${v.content}`)\n   198→        .join('\\n');\n   199→      expect.fail(\n   200→        `Found ${violations.length} cross-module internal import(s) bypassing barrel files:\\n${report}`,\n   201→      );\n   202→    }\n   203→\n   204→    expect(violations).toHaveLength(0);\n   205→  });\n   206→});\n   207→"}]},"parent_tool_use_id":"toolu_01Qh7UqPVGdNKsnDBAZKFd6g","session_id":"bab18149-7022-4086-8939-7adb2ed0216c","uuid":"71b6e2a4-5d0a-4b6e-a719-3b9a54fa59ed","timestamp":"2026-03-25T01:33:29.849Z"}
