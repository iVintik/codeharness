{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013nAwQsRvtfsd6hBEU33pCH","type":"tool_result","content":"     1→/**\n     2→ * Story drill-down — builds detailed view of a single story.\n     3→ * Pure function over in-memory state; no filesystem or network access.\n     4→ */\n     5→\n     6→import { ok, fail } from '../../types/result.js';\n     7→import type { Result } from '../../types/result.js';\n     8→import type { SprintState, StoryState } from '../../types/state.js';\n     9→import type {\n    10→  StoryDrillDown,\n    11→  AcDetail,\n    12→  AttemptRecord,\n    13→  ProofSummary,\n    14→  TimeoutSummary,\n    15→} from './types.js';\n    16→import { MAX_STORY_ATTEMPTS } from './selector.js';\n    17→\n    18→/** Max attempts constant used for display */\n    19→const MAX_ATTEMPTS = MAX_STORY_ATTEMPTS;\n    20→\n    21→/**\n    22→ * Extract the epic prefix from a story key.\n    23→ * E.g. \"2-3-status-report...\" -> \"2\", \"10-1-validation...\" -> \"10\"\n    24→ */\n    25→export function epicPrefix(key: string): string {\n    26→  const dashIdx = key.indexOf('-');\n    27→  if (dashIdx === -1) return key;\n    28→  return key.slice(0, dashIdx);\n    29→}\n    30→\n    31→/**\n    32→ * Build AC details from a story's acResults.\n    33→ * Returns enriched AcDetail array, or empty array if acResults is null.\n    34→ */\n    35→function buildAcDetails(story: StoryState): AcDetail[] {\n    36→  if (!story.acResults) return [];\n    37→  return story.acResults.map((ac) => {\n    38→    const detail: AcDetail = { id: ac.id, verdict: ac.verdict };\n    39→    if (ac.verdict === 'fail' && story.lastError) {\n    40→      return { ...detail, reason: story.lastError };\n    41→    }\n    42→    return detail;\n    43→  });\n    44→}\n    45→\n    46→/** Build synthetic attempt history from available story data */\n    47→function buildAttemptHistory(story: StoryState): AttemptRecord[] {\n    48→  const records: AttemptRecord[] = [];\n    49→  if (story.attempts === 0) return records;\n    50→\n    51→  // For attempts before the last one, we only have the count\n    52→  for (let i = 1; i < story.attempts; i++) {\n    53→    records.push({\n    54→      number: i,\n    55→      outcome: 'details unavailable',\n    56→    });\n    57→  }\n    58→\n    59→  // Last attempt has data\n    60→  const lastOutcome = story.status === 'done' ? 'passed' :\n    61→    story.status === 'failed' ? 'verify failed' :\n    62→    story.status === 'blocked' ? 'blocked' : story.status;\n    63→\n    64→  const lastRecord: AttemptRecord = {\n    65→    number: story.attempts,\n    66→    outcome: lastOutcome,\n    67→    ...(story.lastAttempt ? { timestamp: story.lastAttempt } : {}),\n    68→  };\n    69→\n    70→  // If there's a failing AC, add it\n    71→  if (story.acResults) {\n    72→    const failingAc = story.acResults.find((ac) => ac.verdict === 'fail');\n    73→    if (failingAc) {\n    74→      records.push({ ...lastRecord, failingAc: failingAc.id });\n    75→      return records;\n    76→    }\n    77→  }\n    78→\n    79→  records.push(lastRecord);\n    80→  return records;\n    81→}\n    82→\n    83→/** Build proof summary from story data */\n    84→function buildProofSummary(story: StoryState): ProofSummary | null {\n    85→  if (!story.proofPath) return null;\n    86→\n    87→  let passCount = 0;\n    88→  let failCount = 0;\n    89→  let escalateCount = 0;\n    90→  let pendingCount = 0;\n    91→\n    92→  if (story.acResults) {\n    93→    for (const ac of story.acResults) {\n    94→      if (ac.verdict === 'pass') passCount++;\n    95→      else if (ac.verdict === 'fail') failCount++;\n    96→      else if (ac.verdict === 'escalate') escalateCount++;\n    97→      else if (ac.verdict === 'pending') pendingCount++;\n    98→    }\n    99→  }\n   100→\n   101→  return { path: story.proofPath, passCount, failCount, escalateCount, pendingCount };\n   102→}\n   103→\n   104→/**\n   105→ * Get detailed drill-down for a single story.\n   106→ * Pure function — never throws, returns Result<StoryDrillDown>.\n   107→ */\n   108→export function getStoryDrillDown(\n   109→  state: SprintState,\n   110→  key: string,\n   111→  opts?: { timeoutSummary?: TimeoutSummary | null },\n   112→): Result<StoryDrillDown> {\n   113→  try {\n   114→    const story = state.stories[key];\n   115→    if (!story) {\n   116→      return fail(`Story '${key}' not found in sprint state`);\n   117→    }\n   118→\n   119→    const epic = epicPrefix(key);\n   120→    const acDetails = buildAcDetails(story);\n   121→    const attemptHistory = buildAttemptHistory(story);\n   122→    const proofSummary = buildProofSummary(story);\n   123→\n   124→    return ok({\n   125→      key,\n   126→      status: story.status,\n   127→      epic,\n   128→      attempts: story.attempts,\n   129→      maxAttempts: MAX_ATTEMPTS,\n   130→      lastAttempt: story.lastAttempt,\n   131→      acDetails,\n   132→      attemptHistory,\n   133→      proofSummary,\n   134→      timeoutSummary: opts?.timeoutSummary ?? null,\n   135→    });\n   136→  } catch (err: unknown) {\n   137→    const msg = err instanceof Error ? err.message : String(err);\n   138→    return fail(`Failed to get story drill-down: ${msg}`);\n   139→  }\n   140→}\n   141→"}]},"parent_tool_use_id":"toolu_01LFLA8oQXWrijK9MtY4zgZk","session_id":"a74f233b-d75f-4731-af98-d5f8de661326","uuid":"66f2cf3b-2526-4e5d-8290-9d4b6da85662","timestamp":"2026-03-24T13:34:59.333Z"}
