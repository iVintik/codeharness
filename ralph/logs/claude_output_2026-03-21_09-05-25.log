{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01NtEj7yHfnQfjPS8LUX8wVM","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01FwL6nQWG6N4XiDur4VLWpE","name":"Write","input":{"file_path":"/Users/ivintik/dev/personal/codeharness/src/modules/infra/__tests__/dockerfile-validator.test.ts","content":"import { describe, it, expect, vi, beforeEach } from 'vitest';\n\nvi.mock('node:fs', () => ({\n  existsSync: vi.fn(),\n  readFileSync: vi.fn(),\n}));\n\nimport { existsSync, readFileSync } from 'node:fs';\nimport { validateDockerfile, loadRules } from '../dockerfile-validator.js';\n\nconst mockExistsSync = vi.mocked(existsSync);\nconst mockReadFileSync = vi.mocked(readFileSync);\n\nbeforeEach(() => {\n  vi.clearAllMocks();\n});\n\n// Helper: build a Dockerfile string from lines\nfunction dockerfile(...lines: string[]): string {\n  return lines.join('\\n');\n}\n\n// A Dockerfile that passes all 6 rules\nconst PASSING_DOCKERFILE = dockerfile(\n  'FROM node:22-slim',\n  'RUN apt-get update && apt-get install -y curl jq && rm -rf /var/lib/apt/lists/*',\n  'RUN npm install -g codeharness',\n  'COPY dist/ /app/dist/',\n  'USER node',\n  'CMD [\"codeharness\"]',\n);\n\nfunction mockDockerfile(content: string, hasRulesFile = true): void {\n  mockExistsSync.mockImplementation((p: unknown) => {\n    const path = String(p);\n    if (path.endsWith('Dockerfile')) return true;\n    if (path.includes('dockerfile-rules.md')) return hasRulesFile;\n    return false;\n  });\n  mockReadFileSync.mockReturnValue(content);\n}\n\n// ─── validateDockerfile ─────────────────────────────────────────────────────\n\ndescribe('validateDockerfile', () => {\n  it('returns fail when no Dockerfile exists', () => {\n    mockExistsSync.mockReturnValue(false);\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(false);\n    if (!result.success) {\n      expect(result.error).toBe('No Dockerfile found');\n    }\n  });\n\n  it('returns fail when Dockerfile is unreadable', () => {\n    mockExistsSync.mockReturnValue(true);\n    mockReadFileSync.mockImplementation(() => { throw new Error('EACCES'); });\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(false);\n    if (!result.success) {\n      expect(result.error).toContain('could not be read');\n    }\n  });\n\n  it('returns fail when Dockerfile has no FROM instruction', () => {\n    mockExistsSync.mockReturnValue(true);\n    mockReadFileSync.mockReturnValue('RUN echo hello\\n');\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(false);\n    if (!result.success) {\n      expect(result.error).toContain('no FROM instruction');\n    }\n  });\n\n  it('returns passed: true for a fully compliant Dockerfile', () => {\n    mockDockerfile(PASSING_DOCKERFILE);\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.passed).toBe(true);\n      expect(result.data.gaps).toHaveLength(0);\n      expect(result.data.warnings).toHaveLength(0);\n    }\n  });\n\n  // ─── Pinned FROM (AC #3) ───────────────────────────────────────────────\n\n  it('passes for pinned tag: node:22-slim', () => {\n    mockDockerfile(dockerfile(\n      'FROM node:22-slim',\n      'RUN npm install -g pkg && apt-get update && apt-get install -y curl jq && rm -rf /var/lib/apt/lists/*',\n      'USER node',\n    ));\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(true);\n    if (result.success) {\n      const pinnedGaps = result.data.gaps.filter(g => g.rule === 'pinned-from');\n      expect(pinnedGaps).toHaveLength(0);\n    }\n  });\n\n  it('fails for FROM node:latest', () => {\n    mockDockerfile(dockerfile(\n      'FROM node:latest',\n      'RUN npm install -g pkg && apt-get update && apt-get install -y curl jq && rm -rf /var/lib/apt/lists/*',\n      'USER node',\n    ));\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(true);\n    if (result.success) {\n      const pinnedGaps = result.data.gaps.filter(g => g.rule === 'pinned-from');\n      expect(pinnedGaps.length).toBeGreaterThan(0);\n      expect(pinnedGaps[0].description).toContain('unpinned base image');\n    }\n  });\n\n  it('fails for FROM node (no tag)', () => {\n    mockDockerfile(dockerfile(\n      'FROM node',\n      'RUN npm install -g pkg && apt-get update && apt-get install -y curl jq && rm -rf /var/lib/apt/lists/*',\n      'USER node',\n    ));\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(true);\n    if (result.success) {\n      const pinnedGaps = result.data.gaps.filter(g => g.rule === 'pinned-from');\n      expect(pinnedGaps.length).toBeGreaterThan(0);\n      expect(pinnedGaps[0].description).toContain('unpinned base image');\n    }\n  });\n\n  // ─── Binary on PATH (AC #2) ────────────────────────────────────────────\n\n  it('detects npm install -g as binary install', () => {\n    mockDockerfile(dockerfile(\n      'FROM node:22-slim',\n      'RUN npm install -g codeharness',\n      'RUN apt-get update && apt-get install -y curl jq && rm -rf /var/lib/apt/lists/*',\n      'USER node',\n    ));\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.gaps.filter(g => g.rule === 'binary-on-path')).toHaveLength(0);\n    }\n  });\n\n  it('detects pip install as binary install', () => {\n    mockDockerfile(dockerfile(\n      'FROM python:3.12-slim',\n      'RUN pip install mypackage',\n      'RUN apt-get update && apt-get install -y curl jq && rm -rf /var/lib/apt/lists/*',\n      'USER appuser',\n    ));\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.gaps.filter(g => g.rule === 'binary-on-path')).toHaveLength(0);\n    }\n  });\n\n  it('detects COPY --from as binary install', () => {\n    mockDockerfile(dockerfile(\n      'FROM node:22-slim',\n      'COPY --from=builder /app/bin /usr/local/bin',\n      'RUN apt-get update && apt-get install -y curl jq && rm -rf /var/lib/apt/lists/*',\n      'USER node',\n    ));\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.gaps.filter(g => g.rule === 'binary-on-path')).toHaveLength(0);\n    }\n  });\n\n  it('reports gap when no binary install found', () => {\n    mockDockerfile(dockerfile(\n      'FROM node:22-slim',\n      'RUN apt-get update && apt-get install -y curl jq && rm -rf /var/lib/apt/lists/*',\n      'USER node',\n    ));\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(true);\n    if (result.success) {\n      const binaryGaps = result.data.gaps.filter(g => g.rule === 'binary-on-path');\n      expect(binaryGaps).toHaveLength(1);\n      expect(binaryGaps[0].description).toContain('project binary not installed');\n    }\n  });\n\n  // ─── Verification tools (AC #5) ───────────────────────────────────────\n\n  it('passes when curl and jq are installed via apt-get', () => {\n    mockDockerfile(dockerfile(\n      'FROM node:22-slim',\n      'RUN apt-get update && apt-get install -y curl jq && rm -rf /var/lib/apt/lists/*',\n      'RUN npm install -g codeharness',\n      'USER node',\n    ));\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.gaps.filter(g => g.rule === 'verification-tools')).toHaveLength(0);\n    }\n  });\n\n  it('reports missing curl when only jq installed', () => {\n    mockDockerfile(dockerfile(\n      'FROM node:22-slim',\n      'RUN apt-get update && apt-get install -y jq && rm -rf /var/lib/apt/lists/*',\n      'RUN npm install -g codeharness',\n      'USER node',\n    ));\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(true);\n    if (result.success) {\n      const toolGaps = result.data.gaps.filter(g => g.rule === 'verification-tools');\n      expect(toolGaps.some(g => g.description.includes('curl'))).toBe(true);\n    }\n  });\n\n  it('reports missing jq when only curl installed', () => {\n    mockDockerfile(dockerfile(\n      'FROM node:22-slim',\n      'RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*',\n      'RUN npm install -g codeharness',\n      'USER node',\n    ));\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(true);\n    if (result.success) {\n      const toolGaps = result.data.gaps.filter(g => g.rule === 'verification-tools');\n      expect(toolGaps.some(g => g.description.includes('jq'))).toBe(true);\n    }\n  });\n\n  it('passes when tools installed via apk add', () => {\n    mockDockerfile(dockerfile(\n      'FROM node:22-alpine',\n      'RUN apk add --no-cache curl jq',\n      'RUN npm install -g codeharness',\n      'USER node',\n    ));\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.gaps.filter(g => g.rule === 'verification-tools')).toHaveLength(0);\n    }\n  });\n\n  // ─── No source code COPY (AC #6) ──────────────────────────────────────\n\n  it('reports gap for COPY src/', () => {\n    mockDockerfile(dockerfile(\n      'FROM node:22-slim',\n      'COPY src/ /app/src/',\n      'RUN npm install -g codeharness && apt-get update && apt-get install -y curl jq && rm -rf /var/lib/apt/lists/*',\n      'USER node',\n    ));\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(true);\n    if (result.success) {\n      const copyGaps = result.data.gaps.filter(g => g.rule === 'no-source-copy');\n      expect(copyGaps.length).toBeGreaterThan(0);\n      expect(copyGaps[0].description).toContain('source code copied into container');\n    }\n  });\n\n  it('reports gap for COPY lib/', () => {\n    mockDockerfile(dockerfile(\n      'FROM node:22-slim',\n      'COPY lib/ /app/lib/',\n      'RUN npm install -g codeharness && apt-get update && apt-get install -y curl jq && rm -rf /var/lib/apt/lists/*',\n      'USER node',\n    ));\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.gaps.filter(g => g.rule === 'no-source-copy').length).toBeGreaterThan(0);\n    }\n  });\n\n  it('does not flag COPY dist/', () => {\n    mockDockerfile(PASSING_DOCKERFILE);\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.gaps.filter(g => g.rule === 'no-source-copy')).toHaveLength(0);\n    }\n  });\n\n  // ─── Non-root USER (AC #7) ────────────────────────────────────────────\n\n  it('passes when USER node is present', () => {\n    mockDockerfile(PASSING_DOCKERFILE);\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.gaps.filter(g => g.rule === 'non-root-user')).toHaveLength(0);\n    }\n  });\n\n  it('reports gap when no USER instruction', () => {\n    mockDockerfile(dockerfile(\n      'FROM node:22-slim',\n      'RUN npm install -g codeharness && apt-get update && apt-get install -y curl jq && rm -rf /var/lib/apt/lists/*',\n    ));\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(true);\n    if (result.success) {\n      const userGaps = result.data.gaps.filter(g => g.rule === 'non-root-user');\n      expect(userGaps).toHaveLength(1);\n      expect(userGaps[0].description).toContain('no non-root USER instruction found');\n    }\n  });\n\n  it('reports gap when only USER root', () => {\n    mockDockerfile(dockerfile(\n      'FROM node:22-slim',\n      'USER root',\n      'RUN npm install -g codeharness && apt-get update && apt-get install -y curl jq && rm -rf /var/lib/apt/lists/*',\n    ));\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(true);\n    if (result.success) {\n      const userGaps = result.data.gaps.filter(g => g.rule === 'non-root-user');\n      expect(userGaps).toHaveLength(1);\n    }\n  });\n\n  // ─── Cache cleanup (AC #8) ────────────────────────────────────────────\n\n  it('passes with apt cache cleanup', () => {\n    mockDockerfile(PASSING_DOCKERFILE);\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.gaps.filter(g => g.rule === 'cache-cleanup')).toHaveLength(0);\n    }\n  });\n\n  it('passes with npm cache clean', () => {\n    mockDockerfile(dockerfile(\n      'FROM node:22-slim',\n      'RUN npm install -g codeharness && npm cache clean --force',\n      'RUN apt-get update && apt-get install -y curl jq',\n      'USER node',\n    ));\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.gaps.filter(g => g.rule === 'cache-cleanup')).toHaveLength(0);\n    }\n  });\n\n  it('passes with pip cache purge', () => {\n    mockDockerfile(dockerfile(\n      'FROM python:3.12-slim',\n      'RUN pip install mypackage && pip cache purge',\n      'RUN apt-get update && apt-get install -y curl jq',\n      'USER appuser',\n    ));\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.gaps.filter(g => g.rule === 'cache-cleanup')).toHaveLength(0);\n    }\n  });\n\n  it('reports gap when no cache cleanup', () => {\n    mockDockerfile(dockerfile(\n      'FROM node:22-slim',\n      'RUN apt-get update && apt-get install -y curl jq',\n      'RUN npm install -g codeharness',\n      'USER node',\n    ));\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(true);\n    if (result.success) {\n      const cacheGaps = result.data.gaps.filter(g => g.rule === 'cache-cleanup');\n      expect(cacheGaps).toHaveLength(1);\n      expect(cacheGaps[0].description).toContain('no cache cleanup detected');\n    }\n  });\n\n  // ─── Missing rules file (AC #10) ──────────────────────────────────────\n\n  it('uses defaults with warning when rules file missing', () => {\n    mockDockerfile(PASSING_DOCKERFILE, false);\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.warnings).toHaveLength(1);\n      expect(result.data.warnings[0]).toContain('dockerfile-rules.md not found');\n      expect(result.data.warnings[0]).toContain('using defaults');\n      // Still validates correctly\n      expect(result.data.passed).toBe(true);\n    }\n  });\n\n  it('no warning when rules file exists', () => {\n    mockDockerfile(PASSING_DOCKERFILE, true);\n    const result = validateDockerfile('/project');\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.warnings).toHaveLength(0);\n    }\n  });\n});\n\n// ─── loadRules ──────────────────────────────────────────────────────────────\n\ndescribe('loadRules', () => {\n  it('returns defaults with warning when file missing', () => {\n    mockExistsSync.mockReturnValue(false);\n    const { rules, warnings } = loadRules('/project');\n    expect(rules.verificationTools).toEqual(['curl', 'jq']);\n    expect(warnings).toHaveLength(1);\n    expect(warnings[0]).toContain('dockerfile-rules.md not found');\n  });\n\n  it('returns defaults with no warning when file exists', () => {\n    mockExistsSync.mockReturnValue(true);\n    const { rules, warnings } = loadRules('/project');\n    expect(rules.verificationTools).toEqual(['curl', 'jq']);\n    expect(warnings).toHaveLength(0);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_toke