{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SCWMLfQDE2cgqT7kuwYTj7","type":"tool_result","content":"725\t}\n726\t\n727\t\n728\t// --- Driver Health Check ---\n729\t\n730\t/** Default timeout for the health check phase (NFR6). */\n731\tconst HEALTH_CHECK_TIMEOUT_MS = 5000;\n732\t\n733\t/**\n734\t * Run health checks on all unique drivers referenced in a workflow.\n735\t *\n736\t * Collects unique driver names from `workflow.tasks`, resolves each via\n737\t * `getDriver()`, and runs all `healthCheck()` calls concurrently with a\n738\t * 5-second timeout (NFR6).\n739\t *\n740\t * Throws if any driver is unavailable or if the timeout fires.\n741\t */\n742\texport async function checkDriverHealth(workflow: ResolvedWorkflow, timeoutMs?: number): Promise<void> {\n743\t  // 1. Collect unique driver names from all tasks\n744\t  const driverNames = new Set<string>();\n745\t  for (const task of Object.values(workflow.tasks)) {\n746\t    driverNames.add(task.driver ?? 'claude-code');\n747\t  }\n748\t\n749\t  // 2. Resolve drivers\n750\t  const drivers = new Map<string, ReturnType<typeof getDriver>>();\n751\t  for (const name of driverNames) {\n752\t    drivers.set(name, getDriver(name));\n753\t  }\n754\t\n755\t  // 3. Run health checks concurrently, tracking which drivers responded\n756\t  interface HealthResult { name: string; health: DriverHealth }\n757\t  const responded = new Set<string>();\n758\t  const healthChecks = Promise.all(\n759\t    [...drivers.entries()].map(async ([name, driver]): Promise<HealthResult> => {\n760\t      const health = await driver.healthCheck();\n761\t      responded.add(name);\n762\t      return { name, health };\n763\t    }),\n764\t  );\n765\t\n766\t  // 4. Race against timeout (NFR6) — clear timer on success to prevent leaks\n767\t  const effectiveTimeout = timeoutMs ?? HEALTH_CHECK_TIMEOUT_MS;\n768\t  let timer: ReturnType<typeof setTimeout>;\n769\t  const timeoutPromise = new Promise<'timeout'>((resolve) => {\n770\t    timer = setTimeout(() => resolve('timeout'), effectiveTimeout);\n771\t  });\n772\t\n773\t  const result = await Promise.race([healthChecks, timeoutPromise]);\n774\t\n775\t  if (result === 'timeout') {\n776\t    // Report only the drivers that did NOT respond (AC #6)\n777\t    const pending = [...driverNames].filter((n) => !responded.has(n));\n778\t    const names = pending.length > 0 ? pending.join(', ') : [...driverNames].join(', ');\n779\t    throw new Error(\n780\t      `Driver health check timed out after ${effectiveTimeout}ms. Drivers that did not respond: ${names}`,\n781\t    );\n782\t  }\n783\t\n784\t  // Health checks completed before timeout — clear the timer\n785\t  clearTimeout(timer!);\n786\t\n787\t  // 5. Check for failures\n788\t  const failures = result.filter((r) => !r.health.available);\n789\t  if (failures.length > 0) {\n790\t    const details = failures\n791\t      .map((f) => `${f.name}: ${f.health.error ?? 'unavailable'}`)\n792\t      .join('; ');\n793\t    throw new Error(`Driver health check failed: ${details}`);\n794\t  }\n795\t}\n796\t\n797\t// --- Main Execution ---\n798\t\n799\t/**\n800\t * Execute a workflow sequentially: iterate through flow steps, dispatch tasks\n801\t * per-story or per-run, checkpoint state after each dispatch.\n802\t *\n803\t * Loop blocks execute iteratively until pass, max-iterations, or circuit-breaker.\n804\t *\n805\t * Returns an EngineResult summarizing the execution.\n806\t */\n807\texport async function executeWorkflow(config: EngineConfig): Promise<EngineResult> {\n808\t  const startMs = Date.now();\n809\t  const projectDir = config.projectDir ?? process.cwd();\n810\t  const errors: EngineError[] = [];\n811\t  let tasksCompleted = 0;\n812\t  const processedStories = new Set<string>();\n813\t\n814\t  // 1. Read or initialize workflow state\n815\t  let state = readWorkflowState(projectDir);\n816\t\n817\t  // Early exit: workflow already completed (AC #6)\n818\t  if (state.phase === 'completed') {\n819\t    return {\n820\t      success: true,\n821\t      tasksCompleted: 0,\n822\t      storiesProcessed: 0,\n823\t      errors: [],\n824\t      durationMs: 0,\n825\t    };\n826\t  }\n827\t\n828\t  state = {\n829\t    ...state,\n830\t    phase: 'executing',\n831\t    started: state.started || new Date().toISOString(),\n832\t    workflow_name: config.workflow.flow.filter((s) => typeof s === 'string').join(' -> '),\n833\t  };\n834\t  writeWorkflowState(state, projectDir);\n835\t\n836\t  // 1b. Pre-flight driver health check\n837\t  try {\n838\t    await checkDriverHealth(config.workflow);\n839\t  } catch (err: unknown) { // IGNORE: health check failure — record and abort\n840\t    const message = err instanceof Error ? err.message : String(err);\n841\t    state = { ...state, phase: 'failed' };\n842\t    const engineError: EngineError = {\n843\t      taskName: '__health_check__',\n844\t      storyKey: '__health_check__',\n845\t      code: 'HEALTH_CHECK',\n846\t      message,\n847\t    };\n848\t    errors.push(engineError);\n849\t    writeWorkflowState(state, projectDir);\n850\t    return {\n851\t      success: false,\n852\t      tasksCompleted: 0,\n853\t      storiesProcessed: 0,\n854\t      errors,"}]},"parent_tool_use_id":"toolu_01Q7LeFxMNp3taZsLic9hNBs","session_id":"b101ea9e-2f9e-4377-9c5a-f109fa318b32","uuid":"330274b1-707a-4c70-8448-e8b822b1af5d","timestamp":"2026-04-03T09:51:30.008Z"}
