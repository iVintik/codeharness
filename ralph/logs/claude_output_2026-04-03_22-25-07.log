{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01728R3iMeazHKbRXL1NqeyH","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01HoeFi6sqwYUi1QH42J7osF","name":"Read","input":{"file_path":"/Users/ivintik/dev/personal/codeharness/src/lib/workflow-engine.ts","offset":280,"limit":300},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":11025,"cache_read_input_tokens":36015,"cache_creation":{"ephemeral_5m_input_tokens":11025,"ephemeral_1h_input_tokens":0},"output_tokens":72,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01Hody5ZigZ3cTLmGuBw8VE3","session_id":"b6bb3bfc-8778-4f16-a616-88028acc2431","uuid":"5367d8cd-da55-41e7-9e8d-124b6fdae63d"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HoeFi6sqwYUi1QH42J7osF","type":"tool_result","content":"280\t      }\n281\t    }\n282\t  }\n283\t\n284\t  return items;\n285\t}\n286\t\n287\t// --- Single Task Dispatch ---\n288\t\n289\t/**\n290\t * Dispatch a single task for a specific work item (or per-run sentinel).\n291\t *\n292\t * Handles: trace ID generation, session resolution, source isolation,\n293\t * agent dispatch, state checkpointing, and cleanup.\n294\t *\n295\t * Returns the updated workflow state after recording the dispatch.\n296\t */\n297\texport async function dispatchTask(\n298\t  task: ResolvedTask,\n299\t  taskName: string,\n300\t  storyKey: string,\n301\t  definition: SubagentDefinition,\n302\t  state: WorkflowState,\n303\t  config: EngineConfig,\n304\t  customPrompt?: string,\n305\t  previousOutputContract?: OutputContract,\n306\t): Promise<WorkflowState> {\n307\t  const { updatedState, contract } = await dispatchTaskWithResult(\n308\t    task, taskName, storyKey, definition, state, config, customPrompt, previousOutputContract,\n309\t  );\n310\t  const projectDir = config.projectDir ?? process.cwd();\n311\t  propagateVerifyFlags(taskName, contract, projectDir);\n312\t  return updatedState;\n313\t}\n314\t\n315\t/** Tool names that indicate file write/edit operations across different drivers. */\n316\tconst FILE_WRITE_TOOL_NAMES = new Set([\n317\t  'Write', 'Edit', 'write_to_file', 'edit_file',\n318\t  'write', 'edit', 'WriteFile', 'EditFile',\n319\t]);\n320\t\n321\t// --- Flow Step Type Guard ---\n322\t\n323\tfunction isLoopBlock(step: FlowStep): step is LoopBlock {\n324\t  return typeof step === 'object' && step !== null && 'loop' in step;\n325\t}\n326\t\n327\t// --- Null Task Execution ---\n328\t\n329\t/**\n330\t * Execute a null task (agent: null) directly in the engine.\n331\t *\n332\t * Looks up the handler via the null task registry, builds a TaskContext,\n333\t * calls the handler, writes a TaskCheckpoint, and returns the same shape\n334\t * as dispatchTaskWithResult so callers don't need branching.\n335\t *\n336\t * @throws EngineError with code NULL_TASK_NOT_FOUND if no handler is registered.\n337\t */\n338\tasync function executeNullTask(\n339\t  task: ResolvedTask,\n340\t  taskName: string,\n341\t  storyKey: string,\n342\t  state: WorkflowState,\n343\t  config: EngineConfig,\n344\t  previousOutputContract?: OutputContract,\n345\t  accumulatedCostUsd?: number,\n346\t): Promise<{ updatedState: WorkflowState; output: string; contract: OutputContract | null }> {\n347\t  const projectDir = config.projectDir ?? process.cwd();\n348\t\n349\t  // 1. Look up handler\n350\t  const handler = getNullTask(taskName);\n351\t  if (!handler) {\n352\t    const registered = listNullTasks();\n353\t    const registeredList = registered.length > 0 ? registered.join(', ') : '(none)';\n354\t    const error: EngineError = {\n355\t      taskName,\n356\t      storyKey,\n357\t      code: 'NULL_TASK_NOT_FOUND',\n358\t      message: `No null task handler registered for \"${taskName}\". Registered handlers: ${registeredList}`,\n359\t    };\n360\t    throw error;\n361\t  }\n362\t\n363\t  // 2. Build TaskContext\n364\t  const startMs = Date.now();\n365\t  const workflowStartMs = state.started ? new Date(state.started).getTime() : startMs;\n366\t  const ctx: TaskContext = {\n367\t    storyKey,\n368\t    taskName,\n369\t    cost: accumulatedCostUsd ?? 0,\n370\t    durationMs: startMs - workflowStartMs,\n371\t    outputContract: previousOutputContract ?? null,\n372\t    projectDir,\n373\t  };\n374\t\n375\t  // 3. Call handler (wrap in try/catch for structured error reporting)\n376\t  let result: NullTaskResult;\n377\t  try {\n378\t    result = await handler(ctx);\n379\t  } catch (handlerErr: unknown) {\n380\t    const error: EngineError = {\n381\t      taskName,\n382\t      storyKey,\n383\t      code: 'NULL_TASK_HANDLER_ERROR',\n384\t      message: `Null task handler \"${taskName}\" threw: ${handlerErr instanceof Error ? handlerErr.message : String(handlerErr)}`,\n385\t    };\n386\t    throw error;\n387\t  }\n388\t  const durationMs = Date.now() - startMs;\n389\t\n390\t  // 4. Check handler result — if success is false, throw an EngineError\n391\t  if (!result.success) {\n392\t    const error: EngineError = {\n393\t      taskName,\n394\t      storyKey,\n395\t      code: 'NULL_TASK_FAILED',\n396\t      message: `Null task handler \"${taskName}\" returned success=false${result.output ? `: ${result.output}` : ''}`,\n397\t    };\n398\t    throw error;\n399\t  }\n400\t\n401\t  // 5. Write TaskCheckpoint\n402\t  const checkpoint: TaskCheckpoint = {\n403\t    task_name: taskName,\n404\t    story_key: storyKey,\n405\t    completed_at: new Date().toISOString(),\n406\t  };\n407\t  let updatedState: WorkflowState = {\n408\t    ...state,\n409\t    tasks_completed: [...state.tasks_completed, checkpoint],\n410\t  };\n411\t\n412\t  // 6. Build OutputContract (driver: \"engine\", model: \"null\", cost_usd: 0)\n413\t  const contract: OutputContract = {\n414\t    version: 1,\n415\t    taskName,\n416\t    storyId: storyKey,\n417\t    driver: 'engine',\n418\t    model: 'null',\n419\t    timestamp: new Date().toISOString(),\n420\t    cost_usd: 0,\n421\t    duration_ms: durationMs,\n422\t    changedFiles: [],\n423\t    testResults: null,\n424\t    output: result.output ?? '',\n425\t    acceptanceCriteria: [],\n426\t  };\n427\t\n428\t  // 7. Write state to disk\n429\t  writeWorkflowState(updatedState, projectDir);\n430\t\n431\t  return { updatedState, output: result.output ?? '', contract };\n432\t}\n433\t\n434\t// --- Core Dispatch (shared by dispatchTask and loop block execution) ---\n435\t\n436\t/**\n437\t * Dispatch a task and return both the updated state and the raw dispatch output.\n438\t * This is the single implementation of task dispatch logic. Both `dispatchTask()`\n439\t * and loop block execution delegate here.\n440\t */\n441\tasync function dispatchTaskWithResult(\n442\t  task: ResolvedTask,\n443\t  taskName: string,\n444\t  storyKey: string,\n445\t  definition: SubagentDefinition,\n446\t  state: WorkflowState,\n447\t  config: EngineConfig,\n448\t  customPrompt?: string,\n449\t  previousOutputContract?: OutputContract,\n450\t): Promise<{ updatedState: WorkflowState; output: string; contract: OutputContract | null }> {\n451\t  const projectDir = config.projectDir ?? process.cwd();\n452\t\n453\t  // 1. Generate trace ID\n454\t  const traceId = generateTraceId(config.runId, state.iteration, taskName);\n455\t\n456\t  // 2. Format trace prompt — injected into driver via DispatchOpts.appendSystemPrompt\n457\t  const tracePrompt = formatTracePrompt(traceId);\n458\t\n459\t  // 3. Resolve session ID\n460\t  const sessionKey: SessionLookupKey = { taskName, storyKey };\n461\t  const sessionId = resolveSessionId(task.session, sessionKey, state);\n462\t\n463\t  // 4. Resolve driver\n464\t  const driverName = task.driver ?? 'claude-code';\n465\t  const driver = getDriver(driverName);\n466\t\n467\t  // 5. Resolve model via cascade: task → agent → driver\n468\t  const agentAsModelSource = { model: definition.model };\n469\t  const model = resolveModel(task, agentAsModelSource, driver);\n470\t\n471\t  // 6. Determine cwd based on source_access\n472\t  let cwd: string;\n473\t  let workspace: Awaited<ReturnType<typeof createIsolatedWorkspace>> | null = null;\n474\t\n475\t  if (task.source_access === false) {\n476\t    workspace = await createIsolatedWorkspace({ runId: config.runId, storyFiles: [] });\n477\t    cwd = workspace.toDispatchOptions().cwd ?? projectDir;\n478\t  } else {\n479\t    cwd = projectDir;\n480\t  }\n481\t\n482\t  // 7. Construct prompt\n483\t  const basePrompt = customPrompt\n484\t    ?? (storyKey === PER_RUN_SENTINEL\n485\t      ? `Execute task \"${taskName}\" for the current run.`\n486\t      : `Implement story ${storyKey}`);\n487\t\n488\t  // 7b. Inject previous task's output contract context into the prompt (story 13-2)\n489\t  const prompt = buildPromptWithContractContext(basePrompt, previousOutputContract ?? null);\n490\t\n491\t  // 8. Build DispatchOpts for the driver\n492\t  const dispatchOpts: DispatchOpts = {\n493\t    prompt,\n494\t    model,\n495\t    cwd,\n496\t    sourceAccess: task.source_access !== false,\n497\t    ...(sessionId ? { sessionId } : {}),\n498\t    ...(tracePrompt ? { appendSystemPrompt: tracePrompt } : {}),\n499\t    ...((task.plugins ?? definition.plugins) ? { plugins: task.plugins ?? definition.plugins } : {}),\n500\t    ...(task.max_budget_usd != null ? { timeout: task.max_budget_usd } : {}),\n501\t  };\n502\t\n503\t  // 9. Dispatch through the driver and consume AsyncIterable<StreamEvent>\n504\t  let output = '';\n505\t  let resultSessionId = '';\n506\t  let cost = 0;\n507\t  let errorEvent: { error: string; errorCategory?: string } | null = null;\n508\t\n509\t  // Track changed files from tool-start/tool-input/tool-complete events (Task 2)\n510\t  const changedFiles: string[] = [];\n511\t  let activeToolName: string | null = null;\n512\t  let activeToolInput = '';\n513\t\n514\t  // Timing measurement (Task 6)\n515\t  const startMs = Date.now();\n516\t\n517\t  try {\n518\t    for await (const event of driver.dispatch(dispatchOpts)) {\n519\t      if (event.type === 'text') {\n520\t        output += event.text;\n521\t      }\n522\t      if (event.type === 'tool-start') {\n523\t        const toolStart = event as ToolStartEvent;\n524\t        activeToolName = toolStart.name;\n525\t        activeToolInput = '';\n526\t      }\n527\t      if (event.type === 'tool-input') {\n528\t        activeToolInput += event.partial;\n529\t      }\n530\t      if (event.type === 'tool-complete') {\n531\t        // Extract file path from Write/Edit tool completions\n532\t        if (activeToolName && FILE_WRITE_TOOL_NAMES.has(activeToolName)) {\n533\t          try {\n534\t            const parsed = JSON.parse(activeToolInput) as Record<string, unknown>;\n535\t            const filePath = (parsed.file_path ?? parsed.path ?? parsed.filePath) as string | undefined;\n536\t            if (filePath && typeof filePath === 'string') {\n537\t              changedFiles.push(filePath);\n538\t            }\n539\t          } catch { // IGNORE: best-effort — tool input may not be valid JSON (partial accumulation)\n540\t          }\n541\t        }\n542\t        activeToolName = null;\n543\t        activeToolInput = '';\n544\t      }\n545\t      if (event.type === 'result') {\n546\t        const resultEvt = event as ResultEvent;\n547\t        resultSessionId = resultEvt.sessionId;\n548\t        cost = resultEvt.cost;\n549\t        if (resultEvt.error) {\n550\t          errorEvent = { error: resultEvt.error, errorCategory: resultEvt.errorCategory };\n551\t        }\n552\t      }\n553\t    }\n554\t  } finally {\n555\t    // Cleanup workspace regardless of dispatch success/failure\n556\t    if (workspace) {\n557\t      await workspace.cleanup();\n558\t    }\n559\t  }\n560\t\n561\t  // 10. If the driver reported an error in the result event, throw DispatchError\n562\t  if (errorEvent) {\n563\t    // Map ErrorCategory to DispatchErrorCode\n564\t    const categoryToCode: Record<string, string> = {\n565\t      RATE_LIMIT: 'RATE_LIMIT',\n566\t      NETWORK: 'NETWORK',\n567\t      SDK_INIT: 'SDK_INIT',\n568\t      AUTH: 'UNKNOWN',\n569\t      TIMEOUT: 'UNKNOWN',\n570\t      UNKNOWN: 'UNKNOWN',\n571\t    };\n572\t    const code = categoryToCode[errorEvent.errorCategory ?? 'UNKNOWN'] ?? 'UNKNOWN';\n573\t    throw new DispatchError(\n574\t      errorEvent.error,\n575\t      code as DispatchErrorCode,\n576\t      definition.name,\n577\t      errorEvent,\n578\t    );\n579\t  }"}]},"parent_tool_use_id":"toolu_01Hody5ZigZ3cTLmGuBw8VE3","session_id":"b6bb3bfc-8778-4f16-a616-88028acc2431","uuid":"cc28b0ea-6eca-488d-a0a8-b5591e25fe3a","timestamp":"2026-04-03T18:31:33.965Z"}
