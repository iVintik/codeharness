{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018atLxmySDX8uU1CjfZW9Qu","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→\n     3→vi.mock('node:child_process', () => ({\n     4→  execFileSync: vi.fn(),\n     5→}));\n     6→\n     7→import { execFileSync } from 'node:child_process';\n     8→import {\n     9→  checkInstalled,\n    10→  installDependency,\n    11→  installAllDependencies,\n    12→  parseVersion,\n    13→  CriticalDependencyError,\n    14→  DEPENDENCY_REGISTRY,\n    15→} from '../deps.js';\n    16→import type { DependencySpec } from '../deps.js';\n    17→\n    18→const mockExecFileSync = vi.mocked(execFileSync);\n    19→\n    20→beforeEach(() => {\n    21→  vi.restoreAllMocks();\n    22→  // Suppress console output during tests\n    23→  vi.spyOn(console, 'log').mockImplementation(() => {});\n    24→});\n    25→\n    26→describe('parseVersion', () => {\n    27→  it('extracts version from simple output', () => {\n    28→    expect(parseVersion('1.2.3')).toBe('1.2.3');\n    29→  });\n    30→\n    31→  it('extracts version from \"tool v1.2.3\" format', () => {\n    32→    expect(parseVersion('showboat v0.6.1')).toBe('0.6.1');\n    33→  });\n    34→\n    35→  it('extracts version from \"tool version 1.2.3\" format', () => {\n    36→    expect(parseVersion('bd version 2.0.0-beta.1')).toBe('2.0.0-beta.1');\n    37→  });\n    38→\n    39→  it('returns null when no version found', () => {\n    40→    expect(parseVersion('no version here')).toBeNull();\n    41→  });\n    42→\n    43→  it('returns null for empty string', () => {\n    44→    expect(parseVersion('')).toBeNull();\n    45→  });\n    46→});\n    47→\n    48→describe('checkInstalled', () => {\n    49→  const spec: DependencySpec = {\n    50→    name: 'test-tool',\n    51→    displayName: 'TestTool',\n    52→    installCommands: [{ cmd: 'pip', args: ['install', 'test-tool'] }],\n    53→    checkCommand: { cmd: 'test-tool', args: ['--version'] },\n    54→    critical: false,\n    55→  };\n    56→\n    57→  it('returns installed=true with version when command succeeds', () => {\n    58→    mockExecFileSync.mockReturnValue(Buffer.from('test-tool 1.0.0'));\n    59→    const result = checkInstalled(spec);\n    60→    expect(result.installed).toBe(true);\n    61→    expect(result.version).toBe('1.0.0');\n    62→    expect(mockExecFileSync).toHaveBeenCalledWith('test-tool', ['--version'], { stdio: 'pipe', timeout: 15_000 });\n    63→  });\n    64→\n    65→  it('returns installed=false when command fails', () => {\n    66→    mockExecFileSync.mockImplementation(() => {\n    67→      throw new Error('command not found');\n    68→    });\n    69→    const result = checkInstalled(spec);\n    70→    expect(result.installed).toBe(false);\n    71→    expect(result.version).toBeNull();\n    72→  });\n    73→\n    74→  it('returns installed=true with null version when output has no version', () => {\n    75→    mockExecFileSync.mockReturnValue(Buffer.from('some output without version'));\n    76→    const result = checkInstalled(spec);\n    77→    expect(result.installed).toBe(true);\n    78→    expect(result.version).toBeNull();\n    79→  });\n    80→});\n    81→\n    82→describe('installDependency', () => {\n    83→  const nonCriticalSpec: DependencySpec = {\n    84→    name: 'showboat',\n    85→    displayName: 'Showboat',\n    86→    installCommands: [\n    87→      { cmd: 'pip', args: ['install', 'showboat'] },\n    88→      { cmd: 'pipx', args: ['install', 'showboat'] },\n    89→    ],\n    90→    checkCommand: { cmd: 'showboat', args: ['--version'] },\n    91→    critical: false,\n    92→  };\n    93→\n    94→  it('returns already-installed when tool is already present', () => {\n    95→    mockExecFileSync.mockReturnValue(Buffer.from('showboat 0.6.1'));\n    96→    const result = installDependency(nonCriticalSpec);\n    97→    expect(result.status).toBe('already-installed');\n    98→    expect(result.version).toBe('0.6.1');\n    99→  });\n   100→\n   101→  it('installs via primary command and returns installed', () => {\n   102→    let checkCount = 0;\n   103→    mockExecFileSync.mockImplementation((cmd) => {\n   104→      const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   105→      // Version check: first fails, then succeeds\n   106→      if (cmdStr === 'showboat') {\n   107→        checkCount++;\n   108→        if (checkCount === 1) throw new Error('not found');\n   109→        return Buffer.from('showboat 0.6.1');\n   110→      }\n   111→      // Install command succeeds\n   112→      return Buffer.from('');\n   113→    });\n   114→\n   115→    const result = installDependency(nonCriticalSpec);\n   116→    expect(result.status).toBe('installed');\n   117→    expect(result.version).toBe('0.6.1');\n   118→  });\n   119→\n   120→  it('falls back to secondary command when primary fails', () => {\n   121→    let checkCount = 0;\n   122→    mockExecFileSync.mockImplementation((cmd) => {\n   123→      const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   124→      if (cmdStr === 'showboat') {\n   125→        checkCount++;\n   126→        if (checkCount === 1) throw new Error('not found');\n   127→        return Buffer.from('showboat 0.6.1');\n   128→      }\n   129→      if (cmdStr === 'pip') throw new Error('pip not found');\n   130→      // pipx install succeeds\n   131→      return Buffer.from('');\n   132→    });\n   133→\n   134→    const result = installDependency(nonCriticalSpec);\n   135→    expect(result.status).toBe('installed');\n   136→    expect(result.version).toBe('0.6.1');\n   137→  });\n   138→\n   139→  it('returns failed when all install commands fail', () => {\n   140→    mockExecFileSync.mockImplementation(() => {\n   141→      throw new Error('command failed');\n   142→    });\n   143→\n   144→    const result = installDependency(nonCriticalSpec);\n   145→    expect(result.status).toBe('failed');\n   146→    expect(result.version).toBeNull();\n   147→    expect(result.error).toContain('Install failed');\n   148→    expect(result.error).toContain('pip install showboat');\n   149→    expect(result.error).toContain('pipx install showboat');\n   150→  });\n   151→\n   152→  it('returns failed when install succeeds but post-check fails', () => {\n   153→    mockExecFileSync.mockImplementation((cmd) => {\n   154→      const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   155→      if (cmdStr === 'showboat') throw new Error('not found');\n   156→      // Install commands succeed but version check always fails\n   157→      return Buffer.from('');\n   158→    });\n   159→\n   160→    const result = installDependency(nonCriticalSpec);\n   161→    expect(result.status).toBe('failed');\n   162→  });\n   163→\n   164→  describe('semgrep entry', () => {\n   165→    const semgrepSpec: DependencySpec = {\n   166→      name: 'semgrep',\n   167→      displayName: 'Semgrep',\n   168→      installCommands: [\n   169→        { cmd: 'pipx', args: ['install', 'semgrep'] },\n   170→        { cmd: 'pip', args: ['install', 'semgrep'] },\n   171→      ],\n   172→      checkCommand: { cmd: 'semgrep', args: ['--version'] },\n   173→      critical: false,\n   174→    };\n   175→\n   176→    it('returns already-installed when semgrep is present', () => {\n   177→      mockExecFileSync.mockReturnValue(Buffer.from('1.56.0'));\n   178→      const result = installDependency(semgrepSpec);\n   179→      expect(result.status).toBe('already-installed');\n   180→      expect(result.version).toBe('1.56.0');\n   181→    });\n   182→\n   183→    it('installs semgrep via pipx (primary) and returns installed', () => {\n   184→      let checkCount = 0;\n   185→      mockExecFileSync.mockImplementation((cmd) => {\n   186→        const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   187→        if (cmdStr === 'semgrep') {\n   188→          checkCount++;\n   189→          if (checkCount === 1) throw new Error('not found');\n   190→          return Buffer.from('1.56.0');\n   191→        }\n   192→        return Buffer.from('');\n   193→      });\n   194→\n   195→      const result = installDependency(semgrepSpec);\n   196→      expect(result.status).toBe('installed');\n   197→      expect(result.version).toBe('1.56.0');\n   198→    });\n   199→\n   200→    it('falls back to pip when pipx fails', () => {\n   201→      let checkCount = 0;\n   202→      mockExecFileSync.mockImplementation((cmd) => {\n   203→        const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   204→        if (cmdStr === 'semgrep') {\n   205→          checkCount++;\n   206→          if (checkCount === 1) throw new Error('not found');\n   207→          return Buffer.from('1.56.0');\n   208→        }\n   209→        if (cmdStr === 'pipx') throw new Error('pipx not found');\n   210→        return Buffer.from('');\n   211→      });\n   212→\n   213→      const result = installDependency(semgrepSpec);\n   214→      expect(result.status).toBe('installed');\n   215→      expect(result.version).toBe('1.56.0');\n   216→    });\n   217→\n   218→    it('returns failed when both pipx and pip fail', () => {\n   219→      mockExecFileSync.mockImplementation(() => {\n   220→        throw new Error('command failed');\n   221→      });\n   222→\n   223→      const result = installDependency(semgrepSpec);\n   224→      expect(result.status).toBe('failed');\n   225→      expect(result.error).toContain('pipx install semgrep');\n   226→      expect(result.error).toContain('pip install semgrep');\n   227→    });\n   228→  });\n   229→});\n   230→\n   231→describe('installAllDependencies', () => {\n   232→  it('installs all dependencies and returns results', () => {\n   233→    // All tools already installed\n   234→    mockExecFileSync.mockReturnValue(Buffer.from('tool 1.0.0'));\n   235→\n   236→    const results = installAllDependencies({});\n   237→    expect(results).toHaveLength(DEPENDENCY_REGISTRY.length);\n   238→    expect(results.every(r => r.status === 'already-installed')).toBe(true);\n   239→  });\n   240→\n   241→  it('does not throw when all deps fail (none are critical)', () => {\n   242→    mockExecFileSync.mockImplementation(() => {\n   243→      throw new Error('command failed');\n   244→    });\n   245→\n   246→    const results = installAllDependencies({});\n   247→    expect(results.every(r => r.status === 'failed')).toBe(true);\n   248→  });\n   249→\n   250→  it('continues when non-critical dep fails', () => {\n   251→    mockExecFileSync.mockImplementation((cmd, args) => {\n   252→      const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   253→      const argsArr = Array.isArray(args) ? args.map(String) : [];\n   254→\n   255→      // showboat check and install both fail\n   256→      if (cmdStr === 'showboat') throw new Error('not found');\n   257→      // agent-browser check and install both fail\n   258→      if (cmdStr === 'agent-browser') throw new Error('not found');\n   259→      if (cmdStr === 'npm') throw new Error('not found');\n   260→      // semgrep check and install both fail\n   261→      if (cmdStr === 'semgrep') throw new Error('not found');\n   262→      // pip/pipx for showboat/semgrep fail, for beads we don't reach (already installed)\n   263→      if ((cmdStr === 'pip' || cmdStr === 'pipx') && argsArr.some(a => a.includes('showboat') || a.includes('semgrep'))) {\n   264→        throw new Error('not found');\n   265→      }\n   266→      // beads check succeeds\n   267→      if (cmdStr === 'bd') {\n   268→        return Buffer.from('bd 1.0.0');\n   269→      }\n   270→      throw new Error('unexpected');\n   271→    });\n   272→\n   273→    // Should not throw because showboat, agent-browser, and semgrep are non-critical,\n   274→    // and beads is already installed\n   275→    const results = installAllDependencies({});\n   276→    const failed = results.filter(r => r.status === 'failed');\n   277→    expect(failed.length).toBeGreaterThanOrEqual(1);\n   278→    const beadsResult = results.find(r => r.name === 'beads');\n   279→    expect(beadsResult?.status).toBe('already-installed');\n   280→  });\n   281→\n   282→  it('prints OK messages for installed dependencies (non-json mode)', () => {\n   283→    const logSpy = vi.spyOn(console, 'log');\n   284→    mockExecFileSync.mockReturnValue(Buffer.from('tool 1.0.0'));\n   285→\n   286→    installAllDependencies({ json: false });\n   287→\n   288→    const calls = logSpy.mock.calls.map(c => c[0]);\n   289→    expect(calls.some(c => typeof c === 'string' && c.includes('[OK]'))).toBe(true);\n   290→  });\n   291→\n   292→  it('prints installed (not already-installed) message for freshly installed deps', () => {\n   293→    const logSpy = vi.spyOn(console, 'log');\n   294→    let showboatCheckCount = 0;\n   295→    mockExecFileSync.mockImplementation((cmd) => {\n   296→      const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   297→      // For showboat: first version check fails, install succeeds, post-check succeeds\n   298→      if (cmdStr === 'showboat') {\n   299→        showboatCheckCount++;\n   300→        if (showboatCheckCount === 1) throw new Error('not found');\n   301→        return Buffer.from('showboat 0.6.1');\n   302→      }\n   303→      if (cmdStr === 'pip') return Buffer.from('');\n   304→      // Everything else: already installed\n   305→      return Buffer.from('tool 1.0.0');\n   306→    });\n   307→\n   308→    const results = installAllDependencies({ json: false });\n   309→    const showboat = results.find(r => r.name === 'showboat');\n   310→    expect(showboat?.status).toBe('installed');\n   311→    expect(showboat?.version).toBe('0.6.1');\n   312→\n   313→    const calls = logSpy.mock.calls.map(c => String(c[0]));\n   314→    expect(calls.some(c => c.includes('Showboat: installed (v0.6.1)'))).toBe(true);\n   315→  });\n   316→\n   317→  it('does not print messages in json mode', () => {\n   318→    const logSpy = vi.spyOn(console, 'log');\n   319→    mockExecFileSync.mockReturnValue(Buffer.from('tool 1.0.0'));\n   320→\n   321→    installAllDependencies({ json: true });\n   322→\n   323→    const calls = logSpy.mock.calls.map(c => c[0]);\n   324→    expect(calls.some(c => typeof c === 'string' && c.includes('[OK]'))).toBe(false);\n   325→  });\n   326→\n   327→  it('prints FAIL and info messages for non-critical failures', () => {\n   328→    const logSpy = vi.spyOn(console, 'log');\n   329→\n   330→    mockExecFileSync.mockImplementation((cmd, args) => {\n   331→      const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   332→      const argsArr = Array.isArray(args) ? args.map(String) : [];\n   333→      // showboat fails\n   334→      if (cmdStr === 'showboat') throw new Error('not found');\n   335→      if ((cmdStr === 'pip' || cmdStr === 'pipx') && argsArr.some(a => a.includes('showboat'))) throw new Error('not found');\n   336→      // agent-browser fails\n   337→      if (cmdStr === 'agent-browser' || cmdStr === 'npm') throw new Error('not found');\n   338→      // semgrep fails\n   339→      if (cmdStr === 'semgrep') throw new Error('not found');\n   340→      if ((cmdStr === 'pip' || cmdStr === 'pipx') && argsArr.some(a => a.includes('semgrep'))) throw new Error('not found');\n   341→      // beads succeeds\n   342→      if (cmdStr === 'bd') return Buffer.from('bd 1.0.0');\n   343→      throw new Error('unexpected');\n   344→    });\n   345→\n   346→    installAllDependencies({});\n   347→\n   348→    const calls = logSpy.mock.calls.map(c => String(c[0]));\n   349→    expect(calls.some(c => c.includes('[FAIL]'))).toBe(true);\n   350→    expect(calls.some(c => c.includes('optional'))).toBe(true);\n   351→  });\n   352→});\n   353→\n   354→describe('DEPENDENCY_REGISTRY', () => {\n   355→  it('contains showboat, agent-browser, beads, and semgrep', () => {\n   356→    const names = DEPENDENCY_REGISTRY.map(d => d.name);\n   357→    expect(names).toContain('showboat');\n   358→    expect(names).toContain('agent-browser');\n   359→    expect(names).toContain('beads');\n   360→    expect(names).toContain('semgrep');\n   361→  });\n   362→\n   363→  it('has exactly 4 entries', () => {\n   364→    expect(DEPENDENCY_REGISTRY).toHaveLength(4);\n   365→  });\n   366→\n   367→  it('beads is not critical', () => {\n   368→    const beads = DEPENDENCY_REGISTRY.find(d => d.name === 'beads');\n   369→    expect(beads?.critical).toBe(false);\n   370→  });\n   371→\n   372→  it('showboat and agent-browser are not critical', () => {\n   373→    const showboat = DEPENDENCY_REGISTRY.find(d => d.name === 'showboat');\n   374→    const agentBrowser = DEPENDENCY_REGISTRY.find(d => d.name === 'agent-browser');\n   375→    expect(showboat?.critical).toBe(false);\n   376→    expect(agentBrowser?.critical).toBe(false);\n   377→  });\n   378→\n   379→  it('showboat has pip and pipx fallback', () => {\n   380→    const showboat = DEPENDENCY_REGISTRY.find(d => d.name === 'showboat');\n   381→    expect(showboat?.installCommands).toHaveLength(2);\n   382→    expect(showboat?.installCommands[0].cmd).toBe('pip');\n   383→    expect(showboat?.installCommands[1].cmd).toBe('pipx');\n   384→  });\n   385→\n   386→  it('agent-browser has single npm install command', () => {\n   387→    const ab = DEPENDENCY_REGISTRY.find(d => d.name === 'agent-browser');\n   388→    expect(ab?.installCommands).toHaveLength(1);\n   389→    expect(ab?.installCommands[0].cmd).toBe('npm');\n   390→  });\n   391→\n   392→  it('beads has pip and pipx fallback', () => {\n   393→    const beads = DEPENDENCY_REGISTRY.find(d => d.name === 'beads');\n   394→    expect(beads?.installCommands).toHaveLength(2);\n   395→    expect(beads?.installCommands[0].cmd).toBe('pip');\n   396→    expect(beads?.installCommands[1].cmd).toBe('pipx');\n   397→  });\n   398→\n   399→  it('semgrep is not critical', () => {\n   400→    const semgrep = DEPENDENCY_REGISTRY.find(d => d.name === 'semgrep');\n   401→    expect(semgrep?.critical).toBe(false);\n   402→  });\n   403→\n   404→  it('semgrep has pipx as primary and pip as fallback', () => {\n   405→    const semgrep = DEPENDENCY_REGISTRY.find(d => d.name === 'semgrep');\n   406→    expect(semgrep?.installCommands).toHaveLength(2);\n   407→    expect(semgrep?.installCommands[0].cmd).toBe('pipx');\n   408→    expect(semgrep?.installCommands[1].cmd).toBe('pip');\n   409→  });\n   410→\n   411→  it('semgrep checks version via semgrep --version', () => {\n   412→    const semgrep = DEPENDENCY_REGISTRY.find(d => d.name === 'semgrep');\n   413→    expect(semgrep?.checkCommand.cmd).toBe('semgrep');\n   414→    expect(semgrep?.checkCommand.args).toEqual(['--version']);\n   415→  });\n   416→});\n   417→\n   418→describe('CriticalDependencyError', () => {\n   419→  it('contains dependency name and reason', () => {\n   420→    const err = new CriticalDependencyError('beads', 'not found');\n   421→    expect(err.dependencyName).toBe('beads');\n   422→    expect(err.reason).toBe('not found');\n   423→    expect(err.name).toBe('CriticalDependencyError');\n   424→    expect(err.message).toContain('beads');\n   425→  });\n   426→});\n   427→"}]},"parent_tool_use_id":"toolu_01GwwRGHx2aGkVK7JeqGtRMs","session_id":"02b06ad8-9233-430d-bd8e-764032ea190c","uuid":"5a367757-e9af-412b-9eab-40b47f9813aa","timestamp":"2026-03-21T11:51:10.196Z"}
