{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Wp337NHry8iuZCfH8Vw6hv","type":"tool_result","content":"1\t/**\n2\t * Merge Agent — conflict resolution via driver dispatch with retry loop.\n3\t *\n4\t * Receives a MergeConflictContext with conflicting files, epic descriptions,\n5\t * and an AgentDriver instance. Dispatches the driver to resolve conflicts,\n6\t * validates with the test suite, and retries up to 3 times before escalating.\n7\t *\n8\t * @see Story 18-2: Merge Agent for Conflict Resolution\n9\t */\n10\t\n11\timport { execSync } from 'node:child_process';\n12\timport { readFileSync } from 'node:fs';\n13\timport { join } from 'node:path';\n14\t\n15\timport type { AgentDriver } from './agents/types.js';\n16\timport { validateMerge, writeMergeTelemetry } from './cross-worktree-validator.js';\n17\t\n18\t// --- Interfaces ---\n19\t\n20\t/**\n21\t * Context provided to the merge agent for conflict resolution.\n22\t */\n23\texport interface MergeConflictContext {\n24\t  /** Epic identifier. */\n25\t  readonly epicId: string;\n26\t  /** Branch being merged. */\n27\t  readonly branch: string;\n28\t  /** List of conflicting file paths (relative to cwd). */\n29\t  readonly conflicts: string[];\n30\t  /** Description of what the main branch contains. */\n31\t  readonly mainDescription: string;\n32\t  /** Description of what the feature branch was building. */\n33\t  readonly branchDescription: string;\n34\t  /** Working directory (main repo root where merge is in progress). */\n35\t  readonly cwd: string;\n36\t  /** Command to run for test validation. */\n37\t  readonly testCommand: string;\n38\t  /** Driver instance to dispatch for conflict resolution. */\n39\t  readonly driver: AgentDriver;\n40\t}\n41\t\n42\t/**\n43\t * Result of a conflict resolution attempt.\n44\t */\n45\texport interface ConflictResolutionResult {\n46\t  /** Whether all conflicts were resolved and tests pass. */\n47\t  resolved: boolean;\n48\t  /** Number of resolution attempts made. */\n49\t  attempts: number;\n50\t  /** Whether the conflict was escalated for manual resolution. */\n51\t  escalated: boolean;\n52\t  /** Human-readable escalation message with details for manual resolution. */\n53\t  escalationMessage?: string;\n54\t  /** Test suite results from the last successful validation. */\n55\t  testResults?: { passed: number; failed: number; coverage: number | null };\n56\t  /** List of files that were resolved. */\n57\t  resolvedFiles?: string[];\n58\t}\n59\t\n60\t// --- Constants ---\n61\t\n62\tconst MAX_ATTEMPTS = 3;\n63\t\n64\t// --- Prompt Construction ---\n65\t\n66\t/**\n67\t * Build the conflict resolution prompt for the driver.\n68\t *\n69\t * Includes file paths with full conflict-marker content, descriptions\n70\t * of both branches, and instructions to resolve preserving both changes.\n71\t */\n72\texport function buildConflictPrompt(ctx: MergeConflictContext, testFailure?: string): string {\n73\t  const conflictSections = ctx.conflicts.map((file) => {\n74\t    try {\n75\t      const content = readFileSync(join(ctx.cwd, file), 'utf-8');\n76\t      return `### ${file}\\n\\`\\`\\`\\n${content}\\n\\`\\`\\``;\n77\t    } catch { // IGNORE: file may be deleted on one side or unreadable — degrade gracefully in prompt\n78\t      return `### ${file}\\n*(File deleted on one side or unreadable)*`;\n79\t    }\n80\t  }).join('\\n\\n');"}]},"parent_tool_use_id":"toolu_016EMr5poT3LRabJonL53yHn","session_id":"d383a9e0-3bc4-4a94-aaff-6965a5cc223b","uuid":"f051dd55-20d1-4503-8ee1-174d4d78b99e","timestamp":"2026-04-03T23:14:36.246Z"}
