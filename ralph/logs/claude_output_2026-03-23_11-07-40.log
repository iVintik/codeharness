.not.toBe(hash2);\n   141в†’  });\n   142в†’\n   143в†’  it('produces same hash for same content', () => {\n   144в†’    const distDir = join(testDir, 'dist');\n   145в†’    mkdirSync(distDir);\n   146в†’    writeFileSync(join(distDir, 'index.js'), 'stable content');\n   147в†’\n   148в†’    const hash1 = computeDistHash(testDir);\n   149в†’    const hash2 = computeDistHash(testDir);\n   150в†’\n   151в†’    expect(hash1).toBe(hash2);\n   152в†’  });\n   153в†’\n   154в†’  it('includes nested files in hash', () => {\n   155в†’    const distDir = join(testDir, 'dist');\n   156в†’    mkdirSync(join(distDir, 'sub'), { recursive: true });\n   157в†’    writeFileSync(join(distDir, 'index.js'), 'main');\n   158в†’\n   159в†’    const hash1 = computeDistHash(testDir);\n   160в†’\n   161в†’    writeFileSync(join(distDir, 'sub', 'nested.js'), 'nested');\n   162в†’    const hash2 = computeDistHash(testDir);\n   163в†’\n   164в†’    expect(hash1).not.toBe(hash2);\n   165в†’  });\n   166в†’});\n   167в†’\n   168в†’// в”Ђв”Ђв”Ђ buildVerifyImage в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n   169в†’\n   170в†’describe('buildVerifyImage', () => {\n   171в†’  it('throws when Docker is not available', () => {\n   172в†’    mockIsDockerAvailable.mockReturnValue(false);\n   173в†’    expect(() => buildVerifyImage({ projectDir: testDir })).toThrow('Docker is not available');\n   174в†’  });\n   175в†’\n   176в†’  it('builds generic image when stack is not detected (AC #4, #8)', () => {\n   177в†’    mockDetectStack.mockReturnValue(null);\n   178в†’\n   179в†’    mockExecFileSync\n   180в†’      .mockReturnValueOnce(Buffer.from('')) // docker build\n   181в†’      .mockReturnValueOnce(Buffer.from('50000000')); // docker image inspect (size)\n   182в†’\n   183в†’    const result = buildVerifyImage({ projectDir: testDir });\n   184в†’    expect(result.cached).toBe(false);\n   185в†’    expect(result.imageTag).toBe('codeharness-verify');\n   186в†’\n   187в†’    // Verify docker build was called (no --build-arg for generic)\n   188в†’    const buildCall = mockExecFileSync.mock.calls.find(\n   189в†’      c => (c[1] as string[]).includes('build'),\n   190в†’    );\n   191в†’    expect(buildCall).toBeDefined();\n   192в†’  });\n   193в†’\n   194в†’  it('throws when dist/ does not exist', () => {\n   195в†’    expect(() => buildVerifyImage({ projectDir: testDir })).toThrow('No dist/ directory found');\n   196в†’  });\n   197в†’\n   198в†’  it('returns cached result when hash matches and image exists', () => {\n   199в†’    // Setup dist/\n   200в†’    const distDir = join(testDir, 'dist');\n   201в†’    mkdirSync(distDir);\n   202в†’    writeFileSync(join(distDir, 'index.js'), 'content');\n   203в†’\n   204в†’    const hash = computeDistHash(testDir)!;\n   205в†’    mockReadStateWithBody.mockReturnValue({\n   206в†’      state: { verify_env_dist_hash: hash } as ReturnType<typeof readStateWithBody>['state'],\n   207в†’      body: '',\n   208в†’    });\n   209в†’\n   210в†’    // Image exists\n   211в†’    mockExecFileSync.mockReturnValue(Buffer.from('[{\"Id\":\"abc\"}]'));\n   212в†’\n   213в†’    const result = buildVerifyImage({ projectDir: testDir });\n   214в†’    expect(result.cached).toBe(true);\n   215в†’    expect(result.buildTimeMs).toBe(0);\n   216в†’  });\n   217в†’\n   218в†’  it('builds when hash differs', () => {\n   219в†’    const distDir = join(testDir, 'dist');\n   220в†’    mkdirSync(distDir);\n   221в†’    writeFileSync(join(distDir, 'index.js'), 'content');\n   222в†’\n   223в†’    // Create fake tarball that npm pack would produce\n   224в†’    writeFileSync('/tmp/codeharness-0.13.2.tgz', 'fake-tarball');\n   225в†’\n   226в†’    // Return a different hash from state\n   227в†’    mockReadStateWithBody.mockReturnValue({\n   228в†’      state: { verify_env_dist_hash: 'oldhash' } as ReturnType<typeof readStateWithBody>['state'],\n   229в†’      body: '',\n   230в†’    });\n   231в†’\n   232в†’    // npm pack returns tarball name\n   233в†’    mockExecFileSync\n   234в†’      .mockReturnValueOnce(Buffer.from('codeharness-0.13.2.tgz')) // npm pack\n   235в†’      .mockReturnValueOnce(Buffer.from('')) // docker build\n   236в†’      .mockReturnValueOnce(Buffer.from('250000000')); // docker image inspect (size)\n   237в†’\n   238в†’    const result = buildVerifyImage({ projectDir: testDir });\n   239в†’    expect(result.cached).toBe(false);\n   240в†’    expect(result.imageTag).toBe('codeharness-verify');\n   241в†’    expect(result.buildTimeMs).toBeGreaterThanOrEqual(0);\n   242в†’\n   243в†’    // Cleanup\n   244в†’    try { rmSync('/tmp/codeharness-0.13.2.tgz', { force: true }); } catch {}\n   245в†’  });\n   246в†’\n   247в†’  it('returns cached result regardless of caller context', () => {\n   248в†’    const distDir = join(testDir, 'dist');\n   249в†’    mkdirSync(distDir);\n   250в†’    writeFileSync(join(distDir, 'index.js'), 'content');\n   251в†’\n   252в†’    const hash = computeDistHash(testDir)!;\n   253в†’    mockReadStateWithBody.mockReturnValue({\n   254в†’      state: { verify_env_dist_hash: hash } as ReturnType<typeof readStateWithBody>['state'],\n   255в†’      body: '',\n   256в†’    });\n   257в†’\n   258в†’    mockExecFileSync.mockReturnValue(Buffer.from('[{\"Id\":\"abc\"}]'));\n   259в†’\n   260в†’    const result = buildVerifyImage({ projectDir: testDir });\n   261в†’    expect(result.cached).toBe(true);\n   262в†’    expect(result.imageTag).toBe('codeharness-verify');\n   263в†’  });\n   264в†’\n   265в†’  it('selects correct install strategy for Python stack', () => {\n   266в†’    const distDir = join(testDir, 'dist');\n   267в†’    mkdirSync(distDir);\n   268в†’    writeFileSync(join(distDir, 'mypackage-0.1.0.tar.gz'), 'fake-tarball');\n   269в†’\n   270в†’    mockDetectStack.mockReturnValue('python');\n   271в†’    mockReadStateWithBody.mockReturnValu