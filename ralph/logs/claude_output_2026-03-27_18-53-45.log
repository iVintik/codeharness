{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018uTHhZu33FKgyEftEedYPo","type":"tool_result","content":"     1→import { existsSync, readFileSync, writeFileSync } from 'node:fs';\n     2→import { join } from 'node:path';\n     3→import { parse } from 'yaml';\n     4→import { warn } from '../output.js';\n     5→\n     6→const SPRINT_STATUS_PATH = '_bmad-output/implementation-artifacts/sprint-status.yaml';\n     7→\n     8→/**\n     9→ * Reads sprint-status.yaml and returns the development_status map.\n    10→ */\n    11→export function readSprintStatus(dir?: string): Record<string, string> {\n    12→  const root = dir ?? process.cwd();\n    13→  const filePath = join(root, SPRINT_STATUS_PATH);\n    14→  if (!existsSync(filePath)) {\n    15→    return {};\n    16→  }\n    17→  try {\n    18→    const content = readFileSync(filePath, 'utf-8');\n    19→    const parsed = parse(content) as Record<string, unknown> | null;\n    20→    if (!parsed || typeof parsed !== 'object') {\n    21→      return {};\n    22→    }\n    23→    const devStatus = parsed.development_status;\n    24→    if (!devStatus || typeof devStatus !== 'object') {\n    25→      return {};\n    26→    }\n    27→    return devStatus as Record<string, string>;\n    28→  } catch {\n    29→    // IGNORE: sprint-status.yaml may not exist or be malformed\n    30→    return {};\n    31→  }\n    32→}\n    33→\n    34→/**\n    35→ * Updates a single story's status in sprint-status.yaml while preserving structure and comments.\n    36→ * Uses line-level text replacement to preserve YAML comments.\n    37→ */\n    38→export function updateSprintStatus(storyKey: string, newStatus: string, dir?: string): void {\n    39→  const root = dir ?? process.cwd();\n    40→  const filePath = join(root, SPRINT_STATUS_PATH);\n    41→  if (!existsSync(filePath)) {\n    42→    warn(`sprint-status.yaml not found at ${filePath}, skipping update`);\n    43→    return;\n    44→  }\n    45→\n    46→  const content = readFileSync(filePath, 'utf-8');\n    47→\n    48→  const keyPattern = new RegExp(`^(\\\\s*${escapeRegExp(storyKey)}:\\\\s*)\\\\S+(.*)$`, 'm');\n    49→  if (!keyPattern.test(content)) {\n    50→    return;\n    51→  }\n    52→\n    53→  const updated = content.replace(keyPattern, `$1${newStatus}$2`);\n    54→  writeFileSync(filePath, updated, 'utf-8');\n    55→}\n    56→\n    57→function escapeRegExp(s: string): string {\n    58→  return s.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n    59→}\n    60→\n    61→// ─── Onboarding Epic → Sprint Status ────────────────────────────────────────\n    62→\n    63→function nextEpicNumber(statuses: Record<string, string>): number {\n    64→  let max = -1;\n    65→  for (const key of Object.keys(statuses)) {\n    66→    const match = key.match(/^epic-(\\d+)$/);\n    67→    if (match) {\n    68→      const n = parseInt(match[1], 10);\n    69→      if (n > max) max = n;\n    70→    }\n    71→  }\n    72→  return max + 1;\n    73→}\n    74→\n    75→function slugify(title: string): string {\n    76→  return title\n    77→    .toLowerCase()\n    78→    .replace(/[^a-z0-9]+/g, '-')\n    79→    .replace(/^-+|-+$/g, '')\n    80→    .slice(0, 60);\n    81→}\n    82→\n    83→export interface OnboardingStoryEntry {\n    84→  title: string;\n    85→  key?: string;\n    86→}\n    87→\n    88→/**\n    89→ * Appends an onboarding epic with stories to sprint-status.yaml.\n    90→ */\n    91→export function appendOnboardingEpicToSprint(\n    92→  stories: OnboardingStoryEntry[],\n    93→  dir?: string,\n    94→): { epicNumber: number; storyKeys: string[] } {\n    95→  const root = dir ?? process.cwd();\n    96→  const filePath = join(root, SPRINT_STATUS_PATH);\n    97→\n    98→  if (!existsSync(filePath)) {\n    99→    warn(`sprint-status.yaml not found at ${filePath}, cannot append onboarding epic`);\n   100→    return { epicNumber: -1, storyKeys: [] };\n   101→  }\n   102→\n   103→  const statuses = readSprintStatus(dir);\n   104→  const epicNum = nextEpicNumber(statuses);\n   105→  const storyKeys: string[] = [];\n   106→\n   107→  const lines: string[] = [''];\n   108→  lines.push(`  epic-${epicNum}: backlog`);\n   109→\n   110→  for (let i = 0; i < stories.length; i++) {\n   111→    const slug = slugify(stories[i].title);\n   112→    const storyKey = `${epicNum}-${i + 1}-${slug}`;\n   113→    storyKeys.push(storyKey);\n   114→    lines.push(`  ${storyKey}: backlog`);\n   115→  }\n   116→\n   117→  lines.push(`  epic-${epicNum}-retrospective: optional`);\n   118→  lines.push('');\n   119→\n   120→  const content = readFileSync(filePath, 'utf-8');\n   121→  const updated = content.trimEnd() + '\\n' + lines.join('\\n');\n   122→  writeFileSync(filePath, updated, 'utf-8');\n   123→\n   124→  return { epicNumber: epicNum, storyKeys };\n   125→}\n   126→"}]},"parent_tool_use_id":"toolu_01GTepbYbnTDehnMhc3XqM2y","session_id":"2610e689-589b-4ec2-8784-d06d07275472","uuid":"0b3539db-5895-4c46-8a07-a1830ee0add5","timestamp":"2026-03-27T14:54:56.797Z"}
