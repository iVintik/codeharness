{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LtLdamo3iirSUv7DeUtLwG","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach, afterEach } from 'vitest';\n2\timport { mkdtempSync, rmSync, writeFileSync, readFileSync, mkdirSync } from 'node:fs';\n3\timport { tmpdir, homedir } from 'node:os';\n4\timport os from 'node:os';\n5\timport { join } from 'node:path';\n6\timport {\n7\t  parseWorkflow,\n8\t  resolveWorkflow,\n9\t  loadWorkflowPatch,\n10\t  mergeWorkflowPatch,\n11\t  WorkflowParseError,\n12\t  type ResolvedWorkflow,\n13\t  type ResolvedTask,\n14\t  type LoopBlock,\n15\t  type FlowStep,\n16\t  type WorkflowPatch,\n17\t} from '../workflow-parser.js';\n18\t\n19\tlet testDir: string;\n20\t\n21\tbeforeEach(() => {\n22\t  testDir = mkdtempSync(join(tmpdir(), 'ch-wfparser-test-'));\n23\t});\n24\t\n25\tafterEach(() => {\n26\t  rmSync(testDir, { recursive: true, force: true });\n27\t});\n28\t\n29\tfunction writeYaml(filename: string, content: string): string {\n30\t  const filePath = join(testDir, filename);\n31\t  writeFileSync(filePath, content, 'utf-8');\n32\t  return filePath;\n33\t}\n34\t\n35\t// --- Helpers: YAML content ---\n36\t\n37\tconst minimalYaml = `\n38\ttasks:\n39\t  implement:\n40\t    agent: dev\n41\tflow:\n42\t  - implement\n43\t`;\n44\t\n45\tconst fullYaml = `\n46\ttasks:\n47\t  implement:\n48\t    agent: dev\n49\t    scope: per-story\n50\t    session: fresh\n51\t    source_access: true\n52\t    prompt_template: \"Implement story {{story_key}}\"\n53\t    input_contract:\n54\t      type: object\n55\t    output_contract:\n56\t      type: object\n57\t    max_budget_usd: 5.0\n58\t  verify:\n59\t    agent: evaluator\n60\t    scope: per-run\n61\t    session: continue\n62\t    source_access: false\n63\tflow:\n64\t  - implement\n65\t  - verify\n66\t`;\n67\t\n68\tconst loopYaml = `\n69\ttasks:\n70\t  implement:\n71\t    agent: dev\n72\t  verify:\n73\t    agent: evaluator\n74\t  retry:\n75\t    agent: dev\n76\tflow:\n77\t  - implement\n78\t  - verify\n79\t  - loop:\n80\t      - retry\n81\t      - verify\n82\t`;\n83\t\n84\tconst emptyYaml = `\n85\ttasks: {}\n86\tflow: []\n87\t`;\n88\t\n89\t// --- Tests ---\n90\t\n91\tdescribe('parseWorkflow', () => {\n92\t  describe('valid workflows (AC #1)', () => {\n93\t    it('parses a minimal valid workflow and returns ResolvedWorkflow', () => {\n94\t      const filePath = writeYaml('minimal.yaml', minimalYaml);\n95\t      const result = parseWorkflow(filePath);\n96\t\n97\t      expect(result.tasks).toBeDefined();\n98\t      expect(result.flow).toBeDefined();\n99\t      expect(result.tasks.implement).toBeDefined();\n100\t      expect(result.tasks.implement.agent).toBe('dev');\n101\t      expect(result.flow).toEqual(['implement']);\n102\t    });\n103\t\n104\t    it('parses a full workflow with all optional fields (AC #1)', () => {\n105\t      const filePath = writeYaml('full.yaml', fullYaml);\n106\t      const result = parseWorkflow(filePath);\n107\t\n108\t      expect(result.tasks.implement.agent).toBe('dev');\n109\t      expect(result.tasks.implement.scope).toBe('per-story');\n110\t      expect(result.tasks.implement.session).toBe('fresh');\n111\t      expect(result.tasks.implement.source_access).toBe(true);\n112\t      expect(result.tasks.implement.prompt_template).toBe('Implement story {{story_key}}');\n113\t      expect(result.tasks.implement.input_contract).toEqual({ type: 'object' });\n114\t      expect(result.tasks.implement.output_contract).toEqual({ type: 'object' });\n115\t      expect(result.tasks.implement.max_budget_usd).toBe(5.0);\n116\t\n117\t      expect(result.tasks.verify.agent).toBe('evaluator');\n118\t      expect(result.tasks.verify.scope).toBe('per-run');\n119\t      expect(result.tasks.verify.session).toBe('continue');\n120\t      expect(result.tasks.verify.source_access).toBe(false);\n121\t    });\n122\t\n123\t    it('applies defaults when optional fields are omitted (AC #1)', () => {\n124\t      const filePath = writeYaml('defaults.yaml', minimalYaml);\n125\t      const result = parseWorkflow(filePath);\n126\t      const task = result.tasks.implement;\n127\t\n128\t      expect(task.scope).toBe('per-story');\n129\t      expect(task.session).toBe('fresh');\n130\t      expect(task.source_access).toBe(true);\n131\t      expect(task.prompt_template).toBeUndefined();\n132\t      expect(task.input_contract).toBeUndefined();\n133\t      expect(task.output_contract).toBeUndefined();\n134\t      expect(task.max_budget_usd).toBeUndefined();\n135\t    });\n136\t\n137\t    it('parses empty tasks and flow as valid degenerate case', () => {\n138\t      const filePath = writeYaml('empty.yaml', emptyYaml);\n139\t      const result = parseWorkflow(filePath);\n140\t\n141\t      expect(result.tasks).toEqual({});\n142\t      expect(result.flow).toEqual([]);\n143\t    });\n144\t  });\n145\t\n146\t  describe('invalid YAML syntax (AC #2)', () => {\n147\t    it('throws WorkflowParseError for bad YAML', () => {\n148\t      const filePath = writeYaml('bad.yaml', '{{{{not yaml at all');\n149\t\n150\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n151\t      try {\n152\t        parseWorkflow(filePath);\n153\t      } catch (err) {\n154\t        expect(err).toBeInstanceOf(WorkflowParseError);\n155\t        const pe = err as WorkflowParseError;\n156\t        expect(pe.message).toContain('Invalid YAML syntax');\n157\t        expect(pe.errors.length).toBeGreaterThan(0);\n158\t      }\n159\t    });\n160\t\n161\t    it('throws WorkflowParseError for unclosed quotes in YAML', () => {\n162\t      const badYaml = `\n163\ttasks:\n164\t  implement:\n165\t    agent: \"dev\n166\tflow:\n167\t  - implement\n168\t`;\n169\t      const filePath = writeYaml('unclosed.yaml', badYaml);\n170\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n171\t    });\n172\t  });\n173\t\n174\t  describe('schema validation failures (AC #3)', () => {\n175\t    it('throws WorkflowParseError when tasks is missing', () => {\n176\t      const yaml = 'flow:\\n  - implement\\n';\n177\t      const filePath = writeYaml('no-tasks.yaml', yaml);\n178\t\n179\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n180\t      try {\n181\t        parseWorkflow(filePath);\n182\t      } catch (err) {\n183\t        const pe = err as WorkflowParseError;\n184\t        expect(pe.message).toContain('Schema validation failed');\n185\t        expect(pe.errors.length).toBeGreaterThan(0);\n186\t        expect(pe.errors.some((e) => e.message.includes('tasks'))).toBe(true);\n187\t      }\n188\t    });\n189\t\n190\t    it('throws WorkflowParseError for empty file (null YAML)', () => {\n191\t      const filePath = writeYaml('empty-file.yaml', '');\n192\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n193\t      try {\n194\t        parseWorkflow(filePath);\n195\t      } catch (err) {\n196\t        const pe = err as WorkflowParseError;\n197\t        expect(pe.message).toContain('Schema validation failed');\n198\t      }\n199\t    });\n200\t\n201\t    it('throws WorkflowParseError for scalar YAML content', () => {\n202\t      const filePath = writeYaml('scalar.yaml', '42');\n203\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n204\t      try {\n205\t        parseWorkflow(filePath);\n206\t      } catch (err) {\n207\t        const pe = err as WorkflowParseError;\n208\t        expect(pe.message).toContain('Schema validation failed');\n209\t      }\n210\t    });\n211\t\n212\t    it('throws WorkflowParseError for invalid scope enum value', () => {\n213\t      const yaml = `\n214\ttasks:\n215\t  implement:\n216\t    agent: dev\n217\t    scope: invalid-scope\n218\tflow:\n219\t  - implement\n220\t`;\n221\t      const filePath = writeYaml('bad-scope.yaml', yaml);\n222\t\n223\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n224\t      try {\n225\t        parseWorkflow(filePath);\n226\t      } catch (err) {\n227\t        const pe = err as WorkflowParseError;\n228\t        expect(pe.message).toContain('Schema validation failed');\n229\t        expect(pe.errors.some((e) => e.path.includes('scope'))).toBe(true);\n230\t      }\n231\t    });\n232\t  });\n233\t\n234\t  describe('dangling task references (AC #4)', () => {\n235\t    it('throws WorkflowParseError when flow references non-existent task', () => {\n236\t      const yaml = `\n237\ttasks:\n238\t  implement:\n239\t    agent: dev\n240\tflow:\n241\t  - implement\n242\t  - nonexistent\n243\t`;\n244\t      const filePath = writeYaml('dangling.yaml', yaml);\n245\t\n246\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n247\t      try {\n248\t        parseWorkflow(filePath);\n249\t      } catch (err) {\n250\t        const pe = err as WorkflowParseError;\n251\t        expect(pe.message).toContain('Dangling task references');\n252\t        expect(pe.errors.some((e) => e.message.includes('nonexistent'))).toBe(true);\n253\t      }\n254\t    });\n255\t\n256\t    it('throws WorkflowParseError when loop references non-existent task', () => {\n257\t      const yaml = `\n258\ttasks:\n259\t  implement:\n260\t    agent: dev\n261\tflow:\n262\t  - implement\n263\t  - loop:\n264\t      - ghost_task\n265\t`;\n266\t      const filePath = writeYaml('dangling-loop.yaml', yaml);\n267\t\n268\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n269\t      try {\n270\t        parseWorkflow(filePath);\n271\t      } catch (err) {\n272\t        const pe = err as WorkflowParseError;\n273\t        expect(pe.message).toContain('Dangling task references');\n274\t        expect(pe.errors.some((e) => e.message.includes('ghost_task'))).toBe(true);\n275\t        expect(pe.errors.some((e) => e.path.includes('loop'))).toBe(true);\n276\t      }\n277\t    });\n278\t  });\n279\t\n280\t  describe('loop blocks (AC #5)', () => {\n281\t    it('resolves loop block with valid task references', () => {\n282\t      const filePath = writeYaml('loop.yaml', loopYaml);\n283\t      const result = parseWorkflow(filePath);\n284\t\n285\t      expect(result.flow).toHaveLength(3);\n286\t      expect(result.flow[0]).toBe('implement');\n287\t      expect(result.flow[1]).toBe('verify');\n288\t\n289\t      const loopStep = result.flow[2] as LoopBlock;\n290\t      expect(loopStep).toHaveProperty('loop');\n291\t      expect(loopStep.loop).toEqual(['retry', 'verify']);\n292\t    });\n293\t  });\n294\t\n295\t  describe('performance (AC #6)', () => {\n296\t    it('parses a typical workflow in under 500ms', () => {\n297\t      const filePath = writeYaml('perf.yaml', fullYaml);\n298\t\n299\t      const start = performance.now();\n300\t      parseWorkflow(filePath);\n301\t      const elapsed = performance.now() - start;\n302\t\n303\t      expect(elapsed).toBeLessThan(500);\n304\t    });\n305\t  });\n306\t\n307\t  describe('file not found (AC #7)', () => {\n308\t    it('throws WorkflowParseError for non-existent file', () => {\n309\t      const fakePath = join(testDir, 'does-not-exist.yaml');\n310\t\n311\t      expect(() => parseWorkflow(fakePath)).toThrow(WorkflowParseError);\n312\t      try {\n313\t        parseWorkflow(fakePath);\n314\t      } catch (err) {\n315\t        const pe = err as WorkflowParseError;\n316\t        expect(pe.message).toContain('File not found');\n317\t        expect(pe.errors.length).toBeGreaterThan(0);\n318\t      }\n319\t    });\n320\t\n321\t    it('throws WorkflowParseError when path is a directory', () => {\n322\t      const dirPath = join(testDir, 'subdir');\n323\t      mkdirSync(dirPath);\n324\t\n325\t      expect(() => parseWorkflow(dirPath)).toThrow(WorkflowParseError);\n326\t      try {\n327\t        parseWorkflow(dirPath);\n328\t      } catch (err) {\n329\t        const pe = err as WorkflowParseError;\n330\t        expect(pe.message).toContain('Path is a directory');\n331\t      }\n332\t    });\n333\t  });\n334\t\n335\t  describe('typed interfaces (AC #8)', () => {\n336\t    it('ResolvedWorkflow has correct structure', () => {\n337\t      const filePath = writeYaml('typed.yaml', fullYaml);\n338\t      const result: ResolvedWorkflow = parseWorkflow(filePath);\n339\t\n340\t      // tasks is Record<string, ResolvedTask>\n341\t      const taskKeys = Object.keys(result.tasks);\n342\t      expect(taskKeys).toContain('implement');\n343\t      expect(taskKeys).toContain('verify');\n344\t\n345\t      // flow is FlowStep[]\n346\t      expect(Array.isArray(result.flow)).toBe(true);\n347\t\n348\t      // Each task has ResolvedTask properties\n349\t      const task: ResolvedTask = result.tasks.implement;\n350\t      expect(typeof task.agent).toBe('string');\n351\t      expect(typeof task.scope).toBe('string');\n352\t      expect(typeof task.session).toBe('string');\n353\t      expect(typeof task.source_access).toBe('boolean');\n354\t    });\n355\t\n356\t    it('FlowStep is a union of string | LoopBlock', () => {\n357\t      const filePath = writeYaml('flow-types.yaml', loopYaml);\n358\t      const result = parseWorkflow(filePath);\n359\t\n360\t      // String flow step\n361\t      const stringStep: FlowStep = result.flow[0];\n362\t      expect(typeof stringStep).toBe('string');\n363\t\n364\t      // LoopBlock flow step\n365\t      const loopStep: FlowStep = result.flow[2];\n366\t      expect(typeof loopStep).toBe('object');\n367\t      expect((loopStep as LoopBlock).loop).toBeDefined();\n368\t    });\n369\t  });\n370\t\n371\t  describe('WorkflowParseError structure (AC #8)', () => {\n372\t    it('extends Error and has name and errors array', () => {\n373\t      const err = new WorkflowParseError('test error', [\n374\t        { path: '/tasks', message: 'missing' },\n375\t      ]);\n376\t\n377\t      expect(err).toBeInstanceOf(Error);\n378\t      expect(err.name).toBe('WorkflowParseError');\n379\t      expect(err.message).toBe('test error');\n380\t      expect(err.errors).toHaveLength(1);\n381\t      expect(err.errors[0]).toEqual({ path: '/tasks', message: 'missing' });\n382\t    });\n383\t\n384\t    it('defaults errors to empty array when not provided', () => {\n385\t      const err = new WorkflowParseError('test error');\n386\t      expect(err.errors).toEqual([]);\n387\t    });\n388\t  });\n389\t});\n390\t\n391\t// --- Patch Resolution Tests ---\n392\t\n393\tdescribe('loadWorkflowPatch', () => {\n394\t  it('returns null for non-existent file', () => {\n395\t    const result = loadWorkflowPatch(join(testDir, 'does-not-exist.patch.yaml'));\n396\t    expect(result).toBeNull();\n397\t  });\n398\t\n399\t  it('throws WorkflowParseError for invalid YAML', () => {\n400\t    const filePath = writeYaml('bad.patch.yaml', '{{{{not yaml');\n401\t    expect(() => loadWorkflowPatch(filePath)).toThrow(WorkflowParseError);\n402\t    try {\n403\t      loadWorkflowPatch(filePath);\n404\t    } catch (err) {\n405\t      const pe = err as WorkflowParseError;\n406\t      expect(pe.message).toContain('Invalid YAML in patch file');\n407\t      expect(pe.message).toContain(filePath);\n408\t    }\n409\t  });\n410\t\n411\t  it('throws WorkflowParseError for non-object YAML (scalar)', () => {\n412\t    const filePath = writeYaml('scalar.patch.yaml', '42');\n413\t    expect(() => loadWorkflowPatch(filePath)).toThrow(WorkflowParseError);\n414\t    try {\n415\t      loadWorkflowPatch(filePath);\n416\t    } catch (err) {\n417\t      const pe = err as WorkflowParseError;\n418\t      expect(pe.message).toContain('not a valid object');\n419\t    }\n420\t  });\n421\t\n422\t  it('loads a valid patch file', () => {\n423\t    const patchContent = `\n424\textends: embedded://default\n425\toverrides:\n426\t  tasks:\n427\t    implement:\n428\t      session: continue\n429\t`;\n430\t    const filePath = writeYaml('valid.patch.yaml', patchContent);\n431\t    const result = loadWorkflowPatch(filePath);\n432\t    expect(result).not.toBeNull();\n433\t    expect(result!.extends).toBe('embedded://default');\n434\t    expect(result!.overrides).toBeDefined();\n435\t    expect((result!.overrides!.tasks as Record<string, unknown>).implement).toBeDefined();\n436\t  });\n437\t});\n438\t\n439\tdescribe('mergeWorkflowPatch', () => {\n440\t  const base: Record<string, unknown> = {\n441\t    tasks: {\n442\t      implement: { agent: 'dev', scope: 'per-story', session: 'fresh', source_access: true },\n443\t      verify: { agent: 'evaluator', scope: 'per-run', session: 'fresh', source_access: false },\n444\t    },\n445\t    flow: ['implement', 'verify'],\n446\t  };\n447\t\n448\t  it('handles overrides-only patch (deep merge)', () => {\n449\t    const patch: WorkflowPatch = {\n450\t      overrides: {\n451\t        tasks: {\n452\t          implement: { session: 'continue', max_budget_usd: 5.0 },\n453\t        },\n454\t      },\n455\t    };\n456\t    const result = mergeWorkflowPatch(base, patch);\n457\t    const tasks = result.tasks as Record<string, Record<string, unknown>>;\n458\t\n459\t    // Deep-merged: implement gets new session and max_budget_usd, keeps agent/scope/source_access\n460\t    expect(tasks.implement.agent).toBe('dev');\n461\t    expect(tasks.implement.scope).toBe('per-story');\n462\t    expect(tasks.implement.session).toBe('continue');\n463\t    expect(tasks.implement.max_budget_usd).toBe(5.0);\n464\t    expect(tasks.implement.source_access).toBe(true);\n465\t\n466\t    // verify unchanged\n467\t    expect(tasks.verify.agent).toBe('evaluator');\n468\t\n469\t    // flow unchanged\n470\t    expect(result.flow).toEqual(['implement', 'verify']);\n471\t  });\n472\t\n473\t  it('handles replace-only patch (full replacement)', () => {\n474\t    const patch: WorkflowPatch = {\n475\t      replace: {\n476\t        flow: ['implement'],\n477\t      },\n478\t    };\n479\t    const result = mergeWorkflowPatch(base, patch);\n480\t\n481\t    // flow fully replaced\n482\t    expect(result.flow).toEqual(['implement']);\n483\t\n484\t    // tasks unchanged\n485\t    const tasks = result.tasks as Record<string, Record<string, unknown>>;\n486\t    expect(tasks.implement.agent).toBe('dev');\n487\t    expect(tasks.verify.agent).toBe('evaluator');\n488\t  });\n489\t\n490\t  it('handles patch with both overrides and replace', () => {\n491\t    const patch: WorkflowPatch = {\n492\t      overrides: {\n493\t        tasks: {\n494\t          implement: { session: 'continue' },\n495\t        },\n496\t      },\n497\t      replace: {\n498\t        flow: ['implement'],\n499\t      },\n500\t    };\n501\t    const result = mergeWorkflowPatch(base, patch);\n502\t    const tasks = result.tasks as Record<string, Record<string, unknown>>;\n503\t\n504\t    // overrides applied\n505\t    expect(tasks.implement.session).toBe('continue');\n506\t    expect(tasks.implement.agent).toBe('dev');\n507\t\n508\t    // replace applied after overrides\n509\t    expect(result.flow).toEqual(['implement']);\n510\t  });\n511\t\n512\t  it('replace overwrites even if overrides also touched the same key', () => {\n513\t    const patch: WorkflowPatch = {\n514\t      overrides: {\n515\t        flow: ['implement', 'verify', 'extra'],\n516\t      },\n517\t      replace: {\n518\t        flow: ['only-this'],\n519\t      },\n520\t    };\n521\t    const result = mergeWorkflowPatch(base, patch);\n522\t    // replace wins because it runs after overrides\n523\t    expect(result.flow).toEqual(['only-this']);\n524\t  });\n525\t});\n526\t\n527\tdescribe('resolveWorkflow', () => {\n528\t  it('returns embedded workflow when no patches exist', () => {\n529\t    // Use a cwd with no .codeharness directory\n530\t    const result = resolveWorkflow({ cwd: testDir });\n531\t\n532\t    // Should return the embedded default workflow\n533\t    expect(result.tasks).toBeDefined();\n534\t    expect(result.tasks.implement).toBeDefined();\n535\t    expect(result.tasks.implement.agent).toBe('dev');\n536\t    expect(result.tasks.verify).toBeDefined();\n537\t    expect(result.tasks.verify.agent).toBe('evaluator');\n538\t    expect(result.flow.length).toBeGreaterThan(0);\n539\t  });\n540\t\n541\t  it('deep-merges overrides from project patch onto embedded base', () => {\n542\t    // Create project patch directory\n543\t    const patchDir = join(testDir, '.codeharness', 'workflows');\n544\t    mkdirSync(patchDir, { recursive: true });\n545\t\n546\t    const patchContent = `\n547\textends: embedded://default\n548\toverrides:\n549\t  tasks:\n550\t    implement:\n551\t      session: continue\n552\t      max_budget_usd: 10.0\n553\t`;\n554\t    writeFileSync(join(patchDir, 'default.patch.yaml'), patchContent, 'utf-8');\n555\t\n556\t    const result = resolveWorkflow({ cwd: testDir });\n557\t\n558\t    expect(result.tasks.implement.session).toBe('continue');\n559\t    expect(result.tasks.implement.max_budget_usd).toBe(10.0);\n560\t    // Preserved from base\n561\t    expect(result.tasks.implement.agent).toBe('dev');\n562\t    expect(result.tasks.implement.scope).toBe('per-story');\n563\t    expect(result.tasks.implement.source_access).toBe(true);\n564\t  });\n565\t\n566\t  it('applies replace sections as full replacement (not deep merge)', () => {\n567\t    const patchDir = join(testDir, '.codeharness', 'workflows');\n568\t    mkdirSync(patchDir, { recursive: true });\n569\t\n570\t    const patchContent = `\n571\textends: embedded://default\n572\treplace:\n573\t  flow:\n574\t    - implement\n575\t    - verify\n576\t`;\n577\t    writeFileSync(join(patchDir, 'default.patch.yaml'), patchContent, 'utf-8');\n578\t\n579\t    const result = resolveWorkflow({ cwd: testDir });\n580\t\n581\t    // flow fully replaced — no loop block from embedded default\n582\t    expect(result.flow).toEqual(['implement', 'verify']);\n583\t  });\n584\t\n585\t  it('applies user patch before project patch (ordering)', () => {\n586\t    // Create user-level patch\n587\t    const userPatchDir = join(os.homedir(), '.codeharness', 'workflows');\n588\t    const userPatchPath = join(userPatchDir, 'default.patch.yaml');\n589\t    let userPatchExisted = false;\n590\t    let originalUserPatch: string | undefined;\n591\t\n592\t    try {\n593\t      originalUserPatch = readFileSync(userPatchPath, 'utf-8');\n594\t      userPatchExisted = true;\n595\t    } catch { /* no existing patch */ }\n596\t\n597\t    try {\n598\t      mkdirSync(userPatchDir, { recursive: true });\n599\t      writeFileSync(userPatchPath, `\n600\textends: embedded://default\n601\toverrides:\n602\t  tasks:\n603\t    implement:\n604\t      session: continue\n605\t      max_budget_usd: 3.0\n606\t`, 'utf-8');\n607\t\n608\t      // Create project-level patch that overrides the user patch\n609\t      const projectPatchDir = join(testDir, '.codeharness', 'workflows');\n610\t      mkdirSync(projectPatchDir, { recursive: true });\n611\t      writeFileSync(join(projectPatchDir, 'default.patch.yaml'), `\n612\textends: embedded://default\n613\toverrides:\n614\t  tasks:\n615\t    implement:\n616\t      max_budget_usd: 7.0\n617\t`, 'utf-8');\n618\t\n619\t      const result = resolveWorkflow({ cwd: testDir });\n620\t\n621\t      // User patch: session=continue, max_budget_usd=3.0\n622\t      // Project patch overrides: max_budget_usd=7.0\n623\t      expect(result.tasks.implement.session).toBe('continue');\n624\t      expect(result.tasks.implement.max_budget_usd).toBe(7.0);\n625\t    } finally {\n626\t      // Cleanup user patch\n627\t      if (userPatchExisted && originalUserPatch !== undefined) {\n628\t        writeFileSync(userPatchPath, originalUserPatch, 'utf-8');\n629\t      } else {\n630\t        try { rmSync(userPatchPath); } catch { /* ignore */ }\n631\t      }\n632\t    }\n633\t  });\n634\t\n635\t  it('throws WorkflowParseError for malformed YAML patch', () => {\n636\t    const patchDir = join(testDir, '.codeharness', 'workflows');\n637\t    mkdirSync(patchDir, { recursive: true });\n638\t    writeFileSync(join(patchDir, 'default.patch.yaml'), '{{{{not yaml', 'utf-8');\n639\t\n640\t    expect(() => resolveWorkflow({ cwd: testDir })).toThrow(WorkflowParseError);\n641\t    try {\n642\t      resolveWorkflow({ cwd: testDir });\n643\t    } catch (err) {\n644\t      const pe = err as WorkflowParseError;\n645\t      expect(pe.message).toContain('Invalid YAML');\n646\t    }\n647\t  });\n648\t\n649\t  it('throws WorkflowParseError when merged result fails schema validation', () => {\n650\t    const patchDir = join(testDir, '.codeharness', 'workflows');\n651\t    mkdirSync(patchDir, { recursive: true });\n652\t\n653\t    // Replace tasks with invalid structure (agent missing)\n654\t    const patchContent = `\n655\textends: embedded://default\n656\treplace:\n657\t  tasks:\n658\t    broken:\n659\t      scope: per-story\n660\t`;\n661\t    writeFileSync(join(patchDir, 'default.patch.yaml'), patchContent, 'utf-8');\n662\t\n663\t    expect(() => resolveWorkflow({ cwd: testDir })).toThrow(WorkflowParseError);\n664\t    try {\n665\t      resolveWorkflow({ cwd: testDir });\n666\t    } catch (err) {\n667\t      const pe = err as WorkflowParseError;\n668\t      expect(pe.message).toContain('Schema validation failed');\n669\t    }\n670\t  });\n671\t\n672\t  it('throws WorkflowParseError when merged result has dangling task refs in flow', () => {\n673\t    const patchDir = join(testDir, '.codeharness', 'workflows');\n674\t    mkdirSync(patchDir, { recursive: true });\n675\t\n676\t    // Replace flow with ref to non-existent task, but keep tasks valid\n677\t    const patchContent = `\n678\textends: embedded://default\n679\treplace:\n680\t  flow:\n681\t    - implement\n682\t    - nonexistent_task\n683\t`;\n684\t    writeFileSync(join(patchDir, 'default.patch.yaml'), patchContent, 'utf-8');\n685\t\n686\t    expect(() => resolveWorkflow({ cwd: testDir })).toThrow(WorkflowParseError);\n687\t    try {\n688\t      resolveWorkflow({ cwd: testDir });\n689\t    } catch (err) {\n690\t      const pe = err as WorkflowParseError;\n691\t      expect(pe.message).toContain('Dangling task references');\n692\t      expect(pe.errors.some((e) => e.message.includes('nonexistent_task'))).toBe(true);\n693\t    }\n694\t  });\n695\t\n696\t  it('silently skips missing patch files', () => {\n697\t    // testDir has no .codeharness directory\n698\t    const result = resolveWorkflow({ cwd: testDir });\n699\t    // Should not throw, should return embedded workflow\n700\t    expect(result.tasks.implement).toBeDefined();\n701\t  });\n702\t\n703\t  it('uses cwd option to find project patches', () => {\n704\t    const projectA = join(testDir, 'project-a');\n705\t    const patchDir = join(projectA, '.codeharness', 'workflows');\n706\t    mkdirSync(patchDir, { recursive: true });\n707\t\n708\t    writeFileSync(join(patchDir, 'default.patch.yaml'), `\n709\textends: embedded://default\n710\toverrides:\n711\t  tasks:\n712\t    implement:\n713\t      max_budget_usd: 99.0\n714\t`, 'utf-8');\n715\t\n716\t    const result = resolveWorkflow({ cwd: projectA });\n717\t    expect(result.tasks.implement.max_budget_usd).toBe(99.0);\n718\t  });\n719\t\n720\t  it('throws WorkflowParseError for non-existent embedded workflow name', () => {\n721\t    expect(() => resolveWorkflow({ cwd: testDir, name: 'nonexistent-workflow' })).toThrow(WorkflowParseError);\n722\t    try {\n723\t      resolveWorkflow({ cwd: testDir, name: 'nonexistent-workflow' });\n724\t    } catch (err) {\n725\t      const pe = err as WorkflowParseError;\n726\t      expect(pe.message).toContain('Embedded workflow not found: nonexistent-workflow');\n727\t    }\n728\t  });\n729\t\n730\t  it('loads full custom workflow at project level when no extends', () => {\n731\t    const customDir = join(testDir, '.codeharness', 'workflows');\n732\t    mkdirSync(customDir, { recursive: true });\n733\t\n734\t    // Full custom workflow (not a patch)\n735\t    writeFileSync(join(customDir, 'default.yaml'), `\n736\ttasks:\n737\t  custom-task:\n738\t    agent: custom-agent\n739\tflow:\n740\t  - custom-task\n741\t`, 'utf-8');\n742\t\n743\t    const result = resolveWorkflow({ cwd: testDir });\n744\t    expect(result.tasks['custom-task']).toBeDefined();\n745\t    expect(result.tasks['custom-task'].agent).toBe('custom-agent');\n746\t  });\n747\t\n748\t  // --- Story 9.2: Custom Workflow Creation ---\n749\t\n750\t  describe('custom workflow by name (Story 9.2)', () => {\n751\t    it('loads a custom workflow from .codeharness/workflows/{name}.yaml by name', () => {\n752\t      const customDir = join(testDir, '.codeharness', 'workflows');\n753\t      mkdirSync(customDir, { recursive: true });\n754\t\n755\t      writeFileSync(join(customDir, 'my-workflow.yaml'), `\n756\ttasks:\n757\t  deploy:\n758\t    agent: deployer\n759\tflow:\n760\t  - deploy\n761\t`, 'utf-8');\n762\t\n763\t      const result = resolveWorkflow({ cwd: testDir, name: 'my-workflow' });\n764\t      expect(result.tasks.deploy).toBeDefined();\n765\t      expect(result.tasks.deploy.agent).toBe('deployer');\n766\t      expect(result.flow).toEqual(['deploy']);\n767\t    });\n768\t\n769\t    it('custom workflow fails schema validation — throws WorkflowParseError', () => {\n770\t      const customDir = join(testDir, '.codeharness', 'workflows');\n771\t      mkdirSync(customDir, { recursive: true });\n772\t\n773\t      // Missing tasks key entirely\n774\t      writeFileSync(join(customDir, 'bad-schema.yaml'), `\n775\tflow:\n776\t  - deploy\n777\t`, 'utf-8');\n778\t\n779\t      expect(() => resolveWorkflow({ cwd: testDir, name: 'bad-schema' })).toThrow(WorkflowParseError);\n780\t      try {\n781\t        resolveWorkflow({ cwd: testDir, name: 'bad-schema' });\n782\t      } catch (err) {\n783\t        const pe = err as WorkflowParseError;\n784\t        expect(pe.message).toContain('Schema validation failed');\n785\t        expect(pe.errors.length).toBeGreaterThan(0);\n786\t      }\n787\t    });\n788\t\n789\t    it('custom workflow passes schema but has dangling flow refs — throws WorkflowParseError', () => {\n790\t      const customDir = join(testDir, '.codeharness', 'workflows');\n791\t      mkdirSync(customDir, { recursive: true });\n792\t\n793\t      writeFileSync(join(customDir, 'dangling.yaml'), `\n794\ttasks:\n795\t  deploy:\n796\t    agent: deployer\n797\tflow:\n798\t  - deploy\n799\t  - nonexistent\n800\t`, 'utf-8');\n801\t\n802\t      expect(() => resolveWorkflow({ cwd: testDir, name: 'dangling' })).toThrow(WorkflowParseError);\n803\t      try {\n804\t        resolveWorkflow({ cwd: testDir, name: 'dangling' });\n805\t      } catch (err) {\n806\t        const pe = err as WorkflowParseError;\n807\t        expect(pe.message).toContain('Dangling task references');\n808\t        expect(pe.errors.some((e) => e.message.includes('nonexistent'))).toBe(true);\n809\t      }\n810\t    });\n811\t\n812\t    it('resolveWorkflow({ name: \"nonexistent\" }) with no matching file throws clear error', () => {\n813\t      expect(() => resolveWorkflow({ cwd: testDir, name: 'nonexistent' })).toThrow(WorkflowParseError);\n814\t      try {\n815\t        resolveWorkflow({ cwd: testDir, name: 'nonexistent' });\n816\t      } catch (err) {\n817\t        const pe = err as WorkflowParseError;\n818\t        expect(pe.message).toContain('Embedded workflow not found: nonexistent');\n819\t      }\n820\t    });\n821\t\n822\t    it('resolveWorkflow() with no name defaults to \"default\" — backward-compatible', () => {\n823\t      const result = resolveWorkflow({ cwd: testDir });\n824\t      // Should load embedded default without error\n825\t      expect(result.tasks).toBeDefined();\n826\t      expect(result.tasks.implement).toBeDefined();\n827\t      expect(result.flow.length).toBeGreaterThan(0);\n828\t    });\n829\t\n830\t    it('custom workflow with extends key is NOT treated as full custom (falls to patch resolution)', () => {\n831\t      const customDir = join(testDir, '.codeharness', 'workflows');\n832\t      mkdirSync(customDir, { recursive: true });\n833\t\n834\t      // This has extends, so it should be treated as a patch-like file, not a full custom workflow\n835\t      // Since the name is 'ci' and there is no embedded 'ci' template, this should throw\n836\t      writeFileSync(join(customDir, 'ci.yaml'), `\n837\textends: embedded://default\n838\toverrides:\n839\t  tasks:\n840\t    implement:\n841\t      session: continue\n842\t`, 'utf-8');\n843\t\n844\t      // With extends, it's not treated as a full custom workflow.\n845\t      // It tries to load embedded 'ci' template which doesn't exist => error\n846\t      expect(() => resolveWorkflow({ cwd: testDir, name: 'ci' })).toThrow(WorkflowParseError);\n847\t      try {\n848\t        resolveWorkflow({ cwd: testDir, name: 'ci' });\n849\t      } catch (err) {\n850\t        const pe = err as WorkflowParseError;\n851\t        expect(pe.message).toContain('Embedded workflow not found: ci');\n852\t      }\n853\t    });\n854\t\n855\t    it('custom workflow alongside patch file: patch is ignored for full custom workflows', () => {\n856\t      const customDir = join(testDir, '.codeharness', 'workflows');\n857\t      mkdirSync(customDir, { recursive: true });\n858\t\n859\t      // Full custom workflow (no extends)\n860\t      writeFileSync(join(customDir, 'ci.yaml'), `\n861\ttasks:\n862\t  build:\n863\t    agent: builder\n864\tflow:\n865\t  - build\n866\t`, 'utf-8');\n867\t\n868\t      // Patch file that would change agent — should be ignored\n869\t      writeFileSync(join(customDir, 'ci.patch.yaml'), `\n870\textends: embedded://default\n871\toverrides:\n872\t  tasks:\n873\t    build:\n874\t      agent: patched-builder\n875\t`, 'utf-8');\n876\t\n877\t      const result = resolveWorkflow({ cwd: testDir, name: 'ci' });\n878\t      expect(result.tasks.build.agent).toBe('builder'); // Not patched\n879\t    });\n880\t\n881\t    it('custom workflow with custom agent names resolves agent field correctly', () => {\n882\t      const customDir = join(testDir, '.codeharness', 'workflows');\n883\t      mkdirSync(customDir, { recursive: true });\n884\t\n885\t      writeFileSync(join(customDir, 'multi-agent.yaml'), `\n886\ttasks:\n887\t  build:\n888\t    agent: my-custom-builder\n889\t  test:\n890\t    agent: my-custom-tester\n891\t  deploy:\n892\t    agent: my-custom-deployer\n893\tflow:\n894\t  - build\n895\t  - test\n896\t  - deploy\n897\t`, 'utf-8');\n898\t\n899\t      const result = resolveWorkflow({ cwd: testDir, name: 'multi-agent' });\n900\t      expect(result.tasks.build.agent).toBe('my-custom-builder');\n901\t      expect(result.tasks.test.agent).toBe('my-custom-tester');\n902\t      expect(result.tasks.deploy.agent).toBe('my-custom-deployer');\n903\t    });\n904\t  });\n905\t});\n906\t"}]},"parent_tool_use_id":"toolu_019kDU2rXQxKhW35XzJYDDnv","session_id":"90f775a4-0bf0-4884-b410-4d7f1f50684d","uuid":"6e1d704a-ee9f-4a24-a877-7b5646e65ff8","timestamp":"2026-04-03T08:11:39.187Z"}
