cargo-tarpaulin');\n   150→  });\n   151→\n   152→  it('detects cargo-tarpaulin for rust project with Cargo.toml when tarpaulin installed (AC1)', () => {\n   153→    writeFileSync(join(testDir, 'Cargo.toml'), '[package]\\nname = \"my-crate\"\\nversion = \"0.1.0\"\\n');\n   154→\n   155→    mockedExecSync.mockImplementation((cmd: unknown) => {\n   156→      if (typeof cmd === 'string' && cmd.includes('cargo tarpaulin --version')) {\n   157→        return Buffer.from('cargo-tarpaulin 0.27.0');\n   158→      }\n   159→      return Buffer.from('');\n   160→    });\n   161→\n   162→    const result = detectCoverageTool(testDir);\n   163→    expect(result.tool).toBe('cargo-tarpaulin');\n   164→    expect(result.runCommand).toBe('cargo tarpaulin --out json --output-dir coverage/');\n   165→    expect(result.reportFormat).toBe('tarpaulin-json');\n   166→  });\n   167→\n   168→  it('returns unknown for rust project when tarpaulin not installed (AC5)', () => {\n   169→    writeFileSync(join(testDir, 'Cargo.toml'), '[package]\\nname = \"my-crate\"\\nversion = \"0.1.0\"\\n');\n   170→\n   171→    mockedExecSync.mockImplementation((cmd: unknown) => {\n   172→      if (typeof cmd === 'string' && cmd.includes('cargo tarpaulin --version')) {\n   173→        throw new Error('command not found: cargo-tarpaulin');\n   174→      }\n   175→      return Buffer.from('');\n   176→    });\n   177→\n   178→    const result = detectCoverageTool(testDir);\n   179→    expect(result.tool).toBe('unknown');\n   180→    expect(result.runCommand).toBe('');\n   181→  });\n   182→\n   183→  it('includes --workspace flag for rust workspace projects (AC2)', () => {\n   184→    writeFileSync(join(testDir, 'Cargo.toml'), '[workspace]\\nmembers = [\"crate-a\", \"crate-b\"]\\n');\n   185→\n   186→    mockedExecSync.mockImplementation((cmd: unknown) => {\n   187→      if (typeof cmd === 'string' && cmd.includes('cargo tarpaulin --version')) {\n   188→        return Buffer.from('cargo-tarpaulin 0.27.0');\n   