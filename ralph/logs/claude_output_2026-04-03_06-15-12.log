{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014ofxu5KXZyXHUoayQofJej","type":"tool_result","content":"1\t/**\n2\t * Issue tracker module — CRUD operations for `.codeharness/issues.yaml`.\n3\t *\n4\t * This is the write side of the issue tracker. The read side lives in\n5\t * `workflow-engine.ts` → `loadWorkItems()`.\n6\t */\n7\t\n8\timport { existsSync, readFileSync, writeFileSync, mkdirSync } from 'node:fs';\n9\timport { join } from 'node:path';\n10\timport { parse, stringify } from 'yaml';\n11\t\n12\t// ---------------------------------------------------------------------------\n13\t// Types\n14\t// ---------------------------------------------------------------------------\n15\t\n16\texport interface Issue {\n17\t  id: string;\n18\t  title: string;\n19\t  source: string;\n20\t  priority: string;\n21\t  status: string;\n22\t  created_at: string;\n23\t}\n24\t\n25\texport interface IssuesFile {\n26\t  issues: Issue[];\n27\t}\n28\t\n29\t// ---------------------------------------------------------------------------\n30\t// Constants\n31\t// ---------------------------------------------------------------------------\n32\t\n33\texport const VALID_STATUSES: ReadonlySet<string> = new Set([\n34\t  'backlog',\n35\t  'ready',\n36\t  'in-progress',\n37\t  'review',\n38\t  'verifying',\n39\t  'done',\n40\t  'failed',\n41\t  'blocked',\n42\t]);\n43\t\n44\texport const VALID_PRIORITIES: ReadonlySet<string> = new Set([\n45\t  'low',\n46\t  'medium',\n47\t  'high',\n48\t  'critical',\n49\t]);\n50\t\n51\t// ---------------------------------------------------------------------------\n52\t// Helpers\n53\t// ---------------------------------------------------------------------------\n54\t\n55\tconst ISSUES_REL_PATH = join('.codeharness', 'issues.yaml');\n56\t\n57\tfunction issuesPath(dir: string): string {\n58\t  return join(dir, ISSUES_REL_PATH);\n59\t}\n60\t\n61\t// ---------------------------------------------------------------------------\n62\t// Core functions\n63\t// ---------------------------------------------------------------------------\n64\t\n65\t/**\n66\t * Read issues from `.codeharness/issues.yaml`.\n67\t * Returns `{ issues: [] }` if the file does not exist.\n68\t */\n69\texport function readIssues(dir: string = process.cwd()): IssuesFile {\n70\t  const filePath = issuesPath(dir);\n71\t  if (!existsSync(filePath)) {\n72\t    return { issues: [] };\n73\t  }\n74\t\n75\t  const raw = readFileSync(filePath, 'utf-8');\n76\t  const parsed = parse(raw) as Record<string, unknown> | null;\n77\t\n78\t  if (!parsed || !Array.isArray(parsed.issues)) {\n79\t    return { issues: [] };\n80\t  }\n81\t\n82\t  return { issues: parsed.issues as Issue[] };\n83\t}\n84\t\n85\t/**\n86\t * Write issues to `.codeharness/issues.yaml`.\n87\t * Creates the `.codeharness/` directory if it does not exist.\n88\t */\n89\texport function writeIssues(data: IssuesFile, dir: string = process.cwd()): void {\n90\t  const filePath = issuesPath(dir);\n91\t  const dirPath = join(dir, '.codeharness');\n92\t\n93\t  if (!existsSync(dirPath)) {\n94\t    mkdirSync(dirPath, { recursive: true });\n95\t  }\n96\t\n97\t  writeFileSync(filePath, stringify(data, { nullStr: '' }), 'utf-8');\n98\t}\n99\t\n100\t/**\n101\t * Generate the next sequential issue ID from existing issues.\n102\t * Format: `issue-NNN` (zero-padded 3 digits). Starts at `issue-001`.\n103\t */\n104\texport function nextIssueId(existing: Issue[]): string {\n105\t  let max = 0;\n106\t  for (const issue of existing) {\n107\t    const match = issue.id.match(/^issue-(\\d+)$/);\n108\t    if (match) {\n109\t      const num = parseInt(match[1], 10);\n110\t      if (num > max) max = num;\n111\t    }\n112\t  }\n113\t  return `issue-${String(max + 1).padStart(3, '0')}`;\n114\t}\n115\t\n116\t/**\n117\t * Create a new issue and persist it to `.codeharness/issues.yaml`.\n118\t */\n119\t/**\n120\t * Create a new issue and persist it to `.codeharness/issues.yaml`.\n121\t * Throws if `priority` is not in VALID_PRIORITIES.\n122\t */\n123\texport function createIssue(\n124\t  title: string,\n125\t  options?: { priority?: string; source?: string },\n126\t  dir?: string,\n127\t): Issue {\n128\t  const baseDir = dir ?? process.cwd();\n129\t  const priority = options?.priority ?? 'medium';\n130\t\n131\t  if (!VALID_PRIORITIES.has(priority)) {\n132\t    throw new Error(`Invalid priority '${priority}'. Valid values: ${[...VALID_PRIORITIES].join(', ')}`);\n133\t  }\n134\t\n135\t  const data = readIssues(baseDir);\n136\t\n137\t  const issue: Issue = {\n138\t    id: nextIssueId(data.issues),\n139\t    title,\n140\t    source: options?.source ?? 'manual',\n141\t    priority,\n142\t    status: 'backlog',\n143\t    created_at: new Date().toISOString(),\n144\t  };\n145\t\n146\t  data.issues.push(issue);\n147\t  writeIssues(data, baseDir);\n148\t\n149\t  return issue;\n150\t}\n151\t\n152\t/**\n153\t * Close an issue by setting its status to `done`.\n154\t * Throws if the issue ID is not found.\n155\t */\n156\texport function closeIssue(id: string, dir?: string): Issue {\n157\t  const baseDir = dir ?? process.cwd();\n158\t  const data = readIssues(baseDir);\n159\t\n160\t  const issue = data.issues.find((i) => i.id === id);\n161\t  if (!issue) {\n162\t    throw new Error(`Issue '${id}' not found`);\n163\t  }\n164\t\n165\t  issue.status = 'done';\n166\t  writeIssues(data, baseDir);\n167\t\n168\t  return issue;\n169\t}\n170\t"}]},"parent_tool_use_id":"toolu_01RQfCFNpbMDVkdeQs35oAee","session_id":"3f15b50c-2c9b-40fa-9e63-9fad2199af43","uuid":"3899e88a-2fad-486c-b113-8a0afbff7de2","timestamp":"2026-04-03T02:21:46.013Z"}
