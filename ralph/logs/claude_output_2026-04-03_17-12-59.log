{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018TRzGUQ3AH4nckxB92498P","type":"tool_result","content":"1\t/**\n2\t * Pre-flight capability conflict detection and routing hints.\n3\t *\n4\t * Pure query functions — no side effects, no thrown errors.\n5\t * Called during workflow startup to warn about misconfigurations\n6\t * and suggest cheaper driver alternatives.\n7\t *\n8\t * @see architecture-multi-framework.md — FR36, FR37, FR38\n9\t */\n10\t\n11\timport type { ResolvedWorkflow } from '../workflow-parser.js';\n12\timport type { CapabilityWarning } from './types.js';\n13\timport { getDriver } from './drivers/factory.js';\n14\timport { suggestCheaperDriver } from './drivers/factory.js';\n15\t\n16\t/**\n17\t * Check all tasks in a workflow for capability conflicts and cost routing hints.\n18\t *\n19\t * Returns an array of CapabilityWarning objects. Each warning is advisory —\n20\t * the caller decides whether to log, display, or ignore them.\n21\t *\n22\t * Conflict detection:\n23\t * - task.plugins.length > 0 && !driver.capabilities.supportsPlugins → warning\n24\t *\n25\t * Cost routing:\n26\t * - If driver.costTier > 2 * cheapestCapable.costTier → advisory\n27\t *\n28\t * @param workflow - The resolved workflow to check.\n29\t * @returns Array of capability warnings (empty if no issues found).\n30\t */\n31\texport function checkCapabilityConflicts(workflow: ResolvedWorkflow): CapabilityWarning[] {\n32\t  const warnings: CapabilityWarning[] = [];\n33\t\n34\t  for (const [taskName, task] of Object.entries(workflow.tasks)) {\n35\t    const driverName = task.driver ?? 'claude-code';\n36\t\n37\t    let driver;\n38\t    try {\n39\t      driver = getDriver(driverName);\n40\t    } catch { // IGNORE: driver not found — skip (health check catches this separately)\n41\t      continue;\n42\t    }\n43\t\n44\t    // Check: plugins required but driver doesn't support them\n45\t    const hasPlugins = task.plugins && task.plugins.length > 0;\n46\t    if (hasPlugins && !driver.capabilities.supportsPlugins) {\n47\t      warnings.push({\n48\t        taskName,\n49\t        driverName,\n50\t        capability: 'supportsPlugins',\n51\t        message: `Task \"${taskName}\" requires plugins but driver \"${driverName}\" does not support plugins (supportsPlugins: false)`,\n52\t      });\n53\t    }\n54\t\n55\t    // Determine required capabilities from task configuration\n56\t    const requiredCaps: Record<string, boolean> = {};\n57\t    if (hasPlugins) {\n58\t      requiredCaps.supportsPlugins = true;\n59\t    }\n60\t\n61\t    // Cost routing hint\n62\t    const cheaper = suggestCheaperDriver(driverName, requiredCaps);\n63\t    if (cheaper) {\n64\t      const cheaperDriver = getDriver(cheaper);\n65\t      // Only emit advisory if current driver costs >2x the cheapest capable\n66\t      if (driver.capabilities.costTier > 2 * cheaperDriver.capabilities.costTier) {\n67\t        warnings.push({\n68\t          taskName,\n69\t          driverName,\n70\t          capability: 'costTier',\n71\t          message: `Advisory: task \"${taskName}\" uses ${driverName} — ${cheaper} could handle this task at lower cost`,\n72\t        });\n73\t      }\n74\t    }\n75\t  }\n76\t\n77\t  return warnings;\n78\t}\n79\t"}]},"parent_tool_use_id":"toolu_01WL7MCsNF3La2JHGCjnTeXK","session_id":"cf16e575-8267-4c58-a992-20b07458710f","uuid":"270ea576-4b48-4646-aa5b-ada2751413c9","timestamp":"2026-04-03T13:29:55.886Z"}
