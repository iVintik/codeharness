{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UGVQr571yPzsGAQPQTiYrC","type":"tool_result","content":"     1→/**\n     2→ * Documentation scaffolding for project initialization.\n     3→ * Generates AGENTS.md, docs/ directory structure, and README.md.\n     4→ */\n     5→\n     6→import { existsSync, readFileSync } from 'node:fs';\n     7→import { join, basename } from 'node:path';\n     8→import { ok as okOutput } from '../../lib/output.js';\n     9→import { generateFile } from '../../lib/templates.js';\n    10→import { readmeTemplate } from '../../templates/readme.js';\n    11→import type { Result } from '../../types/result.js';\n    12→import { ok, fail } from '../../types/result.js';\n    13→import type { InitDocumentationResult } from './types.js';\n    14→\n    15→const DO_NOT_EDIT_HEADER = '<!-- DO NOT EDIT MANUALLY -->\\n';\n    16→\n    17→export function getProjectName(projectDir: string): string {\n    18→  try {\n    19→    const pkgPath = join(projectDir, 'package.json');\n    20→    if (existsSync(pkgPath)) {\n    21→      const pkg = JSON.parse(readFileSync(pkgPath, 'utf-8')) as Record<string, unknown>;\n    22→      if (pkg.name && typeof pkg.name === 'string') {\n    23→        return pkg.name;\n    24→      }\n    25→    }\n    26→  } catch {\n    27→    // Fall through to Cargo.toml check\n    28→  }\n    29→\n    30→  // Cargo.toml fallback for Rust projects\n    31→  try {\n    32→    const cargoPath = join(projectDir, 'Cargo.toml');\n    33→    if (existsSync(cargoPath)) {\n    34→      const content = readFileSync(cargoPath, 'utf-8');\n    35→      const packageMatch = content.match(/\\[package\\]([^[]*)/s);\n    36→      if (packageMatch) {\n    37→        const nameMatch = packageMatch[1].match(/^\\s*name\\s*=\\s*\"([^\"]+)\"/m);\n    38→        if (nameMatch) {\n    39→          return nameMatch[1];\n    40→        }\n    41→      }\n    42→    }\n    43→  } catch {\n    44→    // Fall through to basename\n    45→  }\n    46→\n    47→  return basename(projectDir);\n    48→}\n    49→\n    50→export function getStackLabel(stack: string | null): string {\n    51→  if (stack === 'nodejs') return 'Node.js (package.json)';\n    52→  if (stack === 'python') return 'Python';\n    53→  if (stack === 'rust') return 'Rust (Cargo.toml)';\n    54→  return 'Unknown';\n    55→}\n    56→\n    57→export function getCoverageTool(stack: string | null): 'c8' | 'coverage.py' | 'cargo-tarpaulin' | 'unknown' {\n    58→  if (stack === 'python') return 'coverage.py';\n    59→  if (stack === 'rust') return 'cargo-tarpaulin';\n    60→  return 'c8';\n    61→}\n    62→\n    63→export function generateAgentsMdContent(projectDir: string, stack: string | null): string {\n    64→  const projectName = basename(projectDir);\n    65→  const stackLabel = stack === 'nodejs' ? 'Node.js' : stack === 'python' ? 'Python' : stack === 'rust' ? 'Rust' : 'Unknown';\n    66→\n    67→  const lines = [\n    68→    `# ${projectName}`,\n    69→    '',\n    70→    '## Stack',\n    71→    '',\n    72→    `- **Language/Runtime:** ${stackLabel}`,\n    73→    '',\n    74→    '## Build & Test Commands',\n    75→    '',\n    76→  ];\n    77→\n    78→  if (stack === 'nodejs') {\n    79→    lines.push(\n    80→      '```bash',\n    81→      'npm install    # Install dependencies',\n    82→      'npm run build  # Build the project',\n    83→      'npm test       # Run tests',\n    84→      '```',\n    85→    );\n    86→  } else if (stack === 'python') {\n    87→    lines.push(\n    88→      '```bash',\n    89→      'pip install -r requirements.txt  # Install dependencies',\n    90→      'python -m pytest                 # Run tests',\n    91→      '```',\n    92→    );\n    93→  } else if (stack === 'rust') {\n    94→    lines.push(\n    95→      '```bash',\n    96→      'cargo build    # Build the project',\n    97→      'cargo test     # Run tests',\n    98→      'cargo tarpaulin --out json  # Run coverage',\n    99→      '```',\n   100→    );\n   101→  } else {\n   102→    lines.push('```bash', '# No recognized stack — add build/test commands here', '```');\n   103→  }\n   104→\n   105→  lines.push(\n   106→    '',\n   107→    '## Project Structure',\n   108→    '',\n   109→    '```',\n   110→    `${projectName}/`,\n   111→    '├── src/           # Source code',\n   112→    '├── tests/         # Test files',\n   113→    '├── docs/          # Documentation',\n   114→    '└── .claude/       # Codeharness state',\n   115→    '```',\n   116→    '',\n   117→    '## Conventions',\n   118→    '',\n   119→    '- All changes must pass tests before commit',\n   120→    '- Maintain test coverage targets',\n   121→    '- Follow existing code style and patterns',\n   122→    '',\n   123→  );\n   124→\n   125→  return lines.join('\\n');\n   126→}\n   127→\n   128→export function generateDocsIndexContent(): string {\n   129→  return [\n   130→    '# Project Documentation',\n   131→    '',\n   132→    '## Planning Artifacts',\n   133→    '- [Product Requirements](../_bmad-output/planning-artifacts/prd.md)',\n   134→    '- [Architecture](../_bmad-output/planning-artifacts/architecture.md)',\n   135→    '- [Epics & Stories](../_bmad-output/planning-artifacts/epics.md)',\n   136→    '',\n   137→    '## Execution',\n   138→    '- [Active Exec Plans](exec-plans/active/)',\n   139→    '- [Completed Exec Plans](exec-plans/completed/)',\n   140→    '',\n   141→    '## Quality',\n   142→    '- [Quality Reports](quality/)',\n   143→    '- [Generated Reports](generated/)',\n   144→    '',\n   145→  ].join('\\n');\n   146→}\n   147→\n   148→interface ScaffoldDocsOptions {\n   149→  readonly projectDir: string;\n   150→  readonly stack: string | null;\n   151→  readonly isJson: boolean;\n   152→}\n   153→\n   154→export async function scaffoldDocs(opts: ScaffoldDocsOptions): Promise<Result<InitDocumentationResult>> {\n   155→  try {\n   156→    let agentsMd: 'created' | 'exists' | 'skipped' = 'skipped';\n   157→    let docsScaffold: 'created' | 'exists' | 'skipped' = 'skipped';\n   158→    let readme: 'created' | 'exists' | 'skipped' = 'skipped';\n   159→\n   160→    // AGENTS.md\n   161→    const agentsMdPath = join(opts.projectDir, 'AGENTS.md');\n   162→    if (!existsSync(agentsMdPath)) {\n   163→      const content = generateAgentsMdContent(opts.projectDir, opts.stack);\n   164→      generateFile(agentsMdPath, content);\n   165→      agentsMd = 'created';\n   166→    } else {\n   167→      agentsMd = 'exists';\n   168→    }\n   169→\n   170→    // docs/ scaffold\n   171→    const docsDir = join(opts.projectDir, 'docs');\n   172→    if (!existsSync(docsDir)) {\n   173→      generateFile(join(docsDir, 'index.md'), generateDocsIndexContent());\n   174→      generateFile(join(docsDir, 'exec-plans', 'active', '.gitkeep'), '');\n   175→      generateFile(join(docsDir, 'exec-plans', 'completed', '.gitkeep'), '');\n   176→      generateFile(join(docsDir, 'quality', '.gitkeep'), DO_NOT_EDIT_HEADER);\n   177→      generateFile(join(docsDir, 'generated', '.gitkeep'), DO_NOT_EDIT_HEADER);\n   178→      docsScaffold = 'created';\n   179→    } else {\n   180→      docsScaffold = 'exists';\n   181→    }\n   182→\n   183→    // README.md\n   184→    const readmePath = join(opts.projectDir, 'README.md');\n   185→    if (!existsSync(readmePath)) {\n   186→      let cliHelpOutput = '';\n   187→      try {\n   188→        const { execFileSync } = await import('node:child_process');\n   189→        cliHelpOutput = execFileSync(process.execPath, [process.argv[1], '--help'], {\n   190→          stdio: 'pipe',\n   191→          timeout: 10_000,\n   192→        }).toString();\n   193→      } catch {\n   194→        cliHelpOutput = 'Run: codeharness --help';\n   195→      }\n   196→\n   197→      const readmeContent = readmeTemplate({\n   198→        projectName: getProjectName(opts.projectDir),\n   199→        stack: opts.stack,\n   200→        cliHelpOutput,\n   201→      });\n   202→      generateFile(readmePath, readmeContent);\n   203→      readme = 'created';\n   204→    } else {\n   205→      readme = 'exists';\n   206→    }\n   207→\n   208→    const result: InitDocumentationResult = { agents_md: agentsMd, docs_scaffold: docsScaffold, readme };\n   209→\n   210→    if (!opts.isJson) {\n   211→      if (result.agents_md === 'created' || result.docs_scaffold === 'created') {\n   212→        okOutput('Documentation: AGENTS.md + docs/ scaffold created');\n   213→      }\n   214→      if (result.readme === 'created') {\n   215→        okOutput('Documentation: README.md created');\n   216→      }\n   217→    }\n   218→\n   219→    return ok(result);\n   220→  } catch (err) {\n   221→    const message = err instanceof Error ? err.message : String(err);\n   222→    return fail(`Documentation scaffold failed: ${message}`);\n   223→  }\n   224→}\n   225→"}]},"parent_tool_use_id":"toolu_01Pjqm6RwzFUa1tNdjiqKz4j","session_id":"9c50fb69-0476-4a5d-8998-78fcdfa47c24","uuid":"a692ac4c-c2c3-41c6-970d-e54afcfc201e","timestamp":"2026-03-23T08:18:17.457Z"}
