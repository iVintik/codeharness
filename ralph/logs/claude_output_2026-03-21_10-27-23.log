{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SeNgT1WqvFTrRou3WEsqwH","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→\n     3→// Mock all module internals\n     4→vi.mock('../orchestrator.js', () => ({\n     5→  checkPreconditions: vi.fn(),\n     6→  createProofDocument: vi.fn(),\n     7→  runShowboatVerify: vi.fn(),\n     8→  updateVerificationState: vi.fn(),\n     9→  closeBeadsIssue: vi.fn(),\n    10→}));\n    11→\n    12→vi.mock('../proof.js', () => ({\n    13→  validateProofQuality: vi.fn(),\n    14→  proofHasContent: vi.fn(),\n    15→  classifyEvidenceCommands: vi.fn(),\n    16→  checkBlackBoxEnforcement: vi.fn(),\n    17→}));\n    18→\n    19→vi.mock('../parser.js', () => ({\n    20→  parseStoryACs: vi.fn(),\n    21→  classifyAC: vi.fn(),\n    22→  classifyVerifiability: vi.fn(),\n    23→  classifyStrategy: vi.fn(),\n    24→  parseVerificationTag: vi.fn(),\n    25→  INTEGRATION_KEYWORDS: [],\n    26→}));\n    27→\n    28→vi.mock('../env.js', () => ({\n    29→  buildVerifyImage: vi.fn(),\n    30→  prepareVerifyWorkspace: vi.fn(),\n    31→  checkVerifyEnv: vi.fn(),\n    32→  cleanupVerifyEnv: vi.fn(),\n    33→  isValidStoryKey: vi.fn(),\n    34→  computeDistHash: vi.fn(),\n    35→}));\n    36→\n    37→// Mock output to suppress warnings\n    38→vi.mock('../../../lib/output.js', () => ({\n    39→  ok: vi.fn(),\n    40→  fail: vi.fn(),\n    41→  warn: vi.fn(),\n    42→  info: vi.fn(),\n    43→  jsonOutput: vi.fn(),\n    44→}));\n    45→\n    46→import { verifyStory, parseProof } from '../index.js';\n    47→import { checkPreconditions } from '../orchestrator.js';\n    48→import { validateProofQuality } from '../proof.js';\n    49→import { parseStoryACs } from '../parser.js';\n    50→import { runShowboatVerify, updateVerificationState, closeBeadsIssue } from '../orchestrator.js';\n    51→\n    52→beforeEach(() => {\n    53→  vi.clearAllMocks();\n    54→});\n    55→\n    56→describe('verifyStory', () => {\n    57→  it('returns fail when preconditions not met', () => {\n    58→    vi.mocked(checkPreconditions).mockReturnValue({\n    59→      passed: false,\n    60→      failures: ['tests_passed is false'],\n    61→    });\n    62→\n    63→    const result = verifyStory('4-1-test');\n    64→    expect(result.success).toBe(false);\n    65→    if (!result.success) {\n    66→      expect(result.error).toContain('Preconditions not met');\n    67→    }\n    68→  });\n    69→\n    70→  it('returns fail when proof quality check fails', () => {\n    71→    vi.mocked(checkPreconditions).mockReturnValue({ passed: true, failures: [] });\n    72→    vi.mocked(parseStoryACs).mockReturnValue([]);\n    73→    vi.mocked(validateProofQuality).mockReturnValue({\n    74→      verified: 0, pending: 1, escalated: 0, total: 1, passed: false,\n    75→      grepSrcCount: 0, dockerExecCount: 0, observabilityCount: 0, otherCount: 0, blackBoxPass: false,\n    76→    });\n    77→\n    78→    const result = verifyStory('4-1-test');\n    79→    expect(result.success).toBe(false);\n    80→    if (!result.success) {\n    81→      expect(result.error).toContain('Proof quality check failed');\n    82→    }\n    83→  });\n    84→\n    85→  it('returns ok with VerifyResult on success', () => {\n    86→    vi.mocked(checkPreconditions).mockReturnValue({ passed: true, failures: [] });\n    87→    vi.mocked(parseStoryACs).mockReturnValue([\n    88→      { id: '1', description: 'Test AC', type: 'general', verifiability: 'cli-verifiable', strategy: 'docker' },\n    89→    ]);\n    90→    vi.mocked(validateProofQuality).mockReturnValue({\n    91→      verified: 1, pending: 0, escalated: 0, total: 1, passed: true,\n    92→      grepSrcCount: 0, dockerExecCount: 1, observabilityCount: 0, otherCount: 0, blackBoxPass: true,\n    93→    });\n    94→    vi.mocked(runShowboatVerify).mockReturnValue({ passed: false, output: 'showboat not available' });\n    95→    vi.mocked(updateVerificationState).mockImplementation(() => {});\n    96→    vi.mocked(closeBeadsIssue).mockImplementation(() => {});\n    97→\n    98→    const result = verifyStory('4-1-test');\n    99→    expect(result.success).toBe(true);\n   100→    if (result.success) {\n   101→      expect(result.data.storyId).toBe('4-1-test');\n   102→      expect(result.data.success).toBe(true);\n   103→      expect(result.data.totalACs).toBe(1);\n   104→      expect(result.data.verifiedCount).toBe(1);\n   105→      expect(result.data.proofPath).toContain('4-1-test');\n   106→      expect(result.data.perAC).toHaveLength(1);\n   107→    }\n   108→  });\n   109→\n   110→  it('returns fail when an unexpected error is thrown', () => {\n   111→    vi.mocked(checkPreconditions).mockImplementation(() => {\n   112→      throw new Error('unexpected crash');\n   113→    });\n   114→\n   115→    const result = verifyStory('4-1-test');\n   116→    expect(result.success).toBe(false);\n   117→    if (!result.success) {\n   118→      expect(result.error).toBe('unexpected crash');\n   119→    }\n   120→  });\n   121→});\n   122→\n   123→describe('parseProof', () => {\n   124→  it('returns ok with ProofQuality on success', () => {\n   125→    vi.mocked(validateProofQuality).mockReturnValue({\n   126→      verified: 2, pending: 0, escalated: 1, total: 3, passed: true,\n   127→      grepSrcCount: 0, dockerExecCount: 2, observabilityCount: 0, otherCount: 0, blackBoxPass: true,\n   128→    });\n   129→\n   130→    const result = parseProof('/path/to/proof.md');\n   131→    expect(result.success).toBe(true);\n   132→    if (result.success) {\n   133→      expect(result.data.verified).toBe(2);\n   134→      expect(result.data.pending).toBe(0);\n   135→      expect(result.data.escalated).toBe(1);\n   136→      expect(result.data.total).toBe(3);\n   137→      expect(result.data.passed).toBe(true);\n   138→    }\n   139→  });\n   140→\n   141→  it('returns fail when validateProofQuality throws', () => {\n   142→    vi.mocked(validateProofQuality).mockImplementation(() => {\n   143→      throw new Error('file read error');\n   144→    });\n   145→\n   146→    const result = parseProof('/bad/path');\n   147→    expect(result.success).toBe(false);\n   148→    if (!result.success) {\n   149→      expect(result.error).toBe('file read error');\n   150→    }\n   151→  });\n   152→\n   153→  it('returns ok with FAIL detection metrics', () => {\n   154→    vi.mocked(validateProofQuality).mockReturnValue({\n   155→      verified: 1, pending: 2, escalated: 0, total: 3, passed: false,\n   156→      grepSrcCount: 0, dockerExecCount: 1, observabilityCount: 0, otherCount: 0, blackBoxPass: true,\n   157→    });\n   158→\n   159→    const result = parseProof('/path/to/proof.md');\n   160→    expect(result.success).toBe(true);\n   161→    if (result.success) {\n   162→      expect(result.data.pending).toBe(2);\n   163→      expect(result.data.passed).toBe(false);\n   164→    }\n   165→  });\n   166→\n   167→  it('returns ok with ESCALATE detection metrics', () => {\n   168→    vi.mocked(validateProofQuality).mockReturnValue({\n   169→      verified: 1, pending: 0, escalated: 2, total: 3, passed: true,\n   170→      grepSrcCount: 0, dockerExecCount: 1, observabilityCount: 0, otherCount: 0, blackBoxPass: true,\n   171→    });\n   172→\n   173→    const result = parseProof('/path/to/proof.md');\n   174→    expect(result.success).toBe(true);\n   175→    if (result.success) {\n   176→      expect(result.data.escalated).toBe(2);\n   177→    }\n   178→  });\n   179→\n   180→  it('returns ok with black-box enforcement metrics', () => {\n   181→    vi.mocked(validateProofQuality).mockReturnValue({\n   182→      verified: 1, pending: 0, escalated: 0, total: 1, passed: false,\n   183→      grepSrcCount: 3, dockerExecCount: 0, observabilityCount: 0, otherCount: 0, blackBoxPass: false,\n   184→    });\n   185→\n   186→    const result = parseProof('/path/to/proof.md');\n   187→    expect(result.success).toBe(true);\n   188→    if (result.success) {\n   189→      expect(result.data.blackBoxPass).toBe(false);\n   190→      expect(result.data.grepSrcCount).toBe(3);\n   191→    }\n   192→  });\n   193→});\n   194→"}]},"parent_tool_use_id":"toolu_01XPwSJXFDAHM6Py9mHqpeeW","session_id":"63766b2b-ee05-46af-a819-a3f0370845d2","uuid":"0143bd67-7648-44b6-bd4c-73ef7e3a53d7","timestamp":"2026-03-21T06:33:08.802Z"}
