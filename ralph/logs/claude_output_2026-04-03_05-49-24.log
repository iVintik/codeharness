{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KbZkJrVzXwrFWhDY89TrA3","type":"tool_result","content":"130\t  return count >= iteration;\n131\t}\n132\t\n133\t// --- Work Item Loading ---\n134\t\n135\t/**\n136\t * Load work items from sprint-status.yaml and optionally issues.yaml.\n137\t *\n138\t * Stories are extracted from the `development_status` section of sprint-status.yaml.\n139\t * Issues are extracted from the `issues` array of issues.yaml.\n140\t *\n141\t * Only items with status `backlog` or `ready-for-dev` are included.\n142\t * Epic keys (`epic-*`) and retrospective keys (`*-retrospective`) are excluded.\n143\t *\n144\t * If issues.yaml does not exist, returns only stories (no error).\n145\t */\n146\texport function loadWorkItems(sprintStatusPath: string, issuesPath?: string): WorkItem[] {\n147\t  const items: WorkItem[] = [];\n148\t\n149\t  // --- Load stories from sprint-status.yaml ---\n150\t  if (existsSync(sprintStatusPath)) {\n151\t    let raw: string;\n152\t    try {\n153\t      raw = readFileSync(sprintStatusPath, 'utf-8');\n154\t    } catch { // IGNORE: unreadable file — warn and return empty\n155\t      warn(`workflow-engine: could not read sprint-status.yaml at ${sprintStatusPath}`);\n156\t      return items;\n157\t    }\n158\t\n159\t    let parsed: unknown;\n160\t    try {\n161\t      parsed = parse(raw);\n162\t    } catch { // IGNORE: malformed YAML — warn and return empty\n163\t      warn(`workflow-engine: invalid YAML in sprint-status.yaml at ${sprintStatusPath}`);\n164\t      return items;\n165\t    }\n166\t\n167\t    if (parsed && typeof parsed === 'object') {\n168\t      const data = parsed as Record<string, unknown>;\n169\t      const devStatus = data.development_status as Record<string, unknown> | undefined;\n170\t\n171\t      if (devStatus && typeof devStatus === 'object') {\n172\t        for (const [key, status] of Object.entries(devStatus)) {\n173\t          // Skip epic keys and retrospective keys\n174\t          if (key.startsWith('epic-')) continue;\n175\t          if (key.endsWith('-retrospective')) continue;\n176\t\n177\t          // Only include backlog or ready-for-dev\n178\t          if (status === 'backlog' || status === 'ready-for-dev') {\n179\t            items.push({ key, source: 'sprint' });\n180\t          }\n181\t        }\n182\t      }\n183\t    }\n184\t  }\n185\t\n186\t  // --- Load issues from issues.yaml ---\n187\t  if (issuesPath && existsSync(issuesPath)) {\n188\t    let raw: string;\n189\t    try {\n190\t      raw = readFileSync(issuesPath, 'utf-8');\n191\t    } catch { // IGNORE: unreadable issues file — warn and return what we have\n192\t      warn(`workflow-engine: could not read issues.yaml at ${issuesPath}`);\n193\t      return items;\n194\t    }\n195\t\n196\t    let parsed: unknown;\n197\t    try {\n198\t      parsed = parse(raw);\n199\t    } catch { // IGNORE: malformed issues YAML — warn and return what we have\n200\t      warn(`workflow-engine: invalid YAML in issues.yaml at ${issuesPath}`);\n201\t      return items;\n202\t    }\n203\t\n204\t    if (parsed && typeof parsed === 'object') {\n205\t      const data = parsed as Record<string, unknown>;\n206\t      const issuesList = data.issues as Array<Record<string, unknown>> | undefined;\n207\t\n208\t      if (Array.isArray(issuesList)) {\n209\t        for (const issue of issuesList) {\n210\t          if (issue && typeof issue === 'object') {\n211\t            const status = issue.status as string | undefined;\n212\t            if (status === 'backlog' || status === 'ready-for-dev') {\n213\t              items.push({\n214\t                key: issue.id as string,\n215\t                title: issue.title as string | undefined,\n216\t                source: 'issues',\n217\t              });\n218\t            }\n219\t          }\n220\t        }\n221\t      }\n222\t    }\n223\t  }\n224\t\n225\t  return items;\n226\t}\n227\t\n228\t// --- Single Task Dispatch ---\n229\t"}]},"parent_tool_use_id":"toolu_01CMZbq8RrvXCKSwd18t2Hto","session_id":"2800a04b-8151-4215-bf66-1f43973b9365","uuid":"2511a89c-853a-4323-8c1e-df242392c5bb","timestamp":"2026-04-03T02:02:38.153Z"}
