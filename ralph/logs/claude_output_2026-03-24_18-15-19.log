{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016oLKHGYpssfCypESYtQrkn","type":"tool_result","content":"     1→/**\n     2→ * Named Cargo.toml string constants for test fixtures.\n     3→ *\n     4→ * Extracted from inline literals in rust.test.ts and other stack tests.\n     5→ * Each constant represents a distinct Cargo.toml configuration variant.\n     6→ */\n     7→\n     8→/** Minimal Cargo.toml with only [package] and a single dependency */\n     9→export const CARGO_TOML_MINIMAL = `[package]\n    10→name = \"myapp\"\n    11→version = \"0.1.0\"\n    12→\n    13→[dependencies]\n    14→serde = \"1\"\n    15→`;\n    16→\n    17→/** Cargo.toml with actix-web server framework */\n    18→export const CARGO_TOML_ACTIX_WEB = `[package]\n    19→name = \"myapp\"\n    20→\n    21→[dependencies]\n    22→actix-web = \"4\"\n    23→`;\n    24→\n    25→/** Cargo.toml with axum server framework */\n    26→export const CARGO_TOML_AXUM = `[package]\n    27→name = \"myapp\"\n    28→\n    29→[dependencies]\n    30→axum = \"0.7\"\n    31→`;\n    32→\n    33→/** Cargo.toml with async-openai AI/agent dependency */\n    34→export const CARGO_TOML_ASYNC_OPENAI = `[package]\n    35→name = \"myapp\"\n    36→version = \"0.1.0\"\n    37→\n    38→[dependencies]\n    39→async-openai = \"0.18\"\n    40→`;\n    41→\n    42→/** Cargo.toml workspace with multiple members */\n    43→export const CARGO_TOML_WORKSPACE = `[workspace]\n    44→members = [\"crate-a\", \"crate-b\"]\n    45→`;\n    46→\n    47→/** Cargo.toml with [[bin]] section (CLI binary) */\n    48→export const CARGO_TOML_BINARY = `[package]\n    49→name = \"myapp\"\n    50→\n    51→[[bin]]\n    52→name = \"myapp\"\n    53→path = \"src/main.rs\"\n    54→\n    55→[dependencies]\n    56→clap = \"4\"\n    57→`;\n    58→\n    59→/** Cargo.toml with [lib] section (library crate) */\n    60→export const CARGO_TOML_LIBRARY = `[package]\n    61→name = \"mylib\"\n    62→\n    63→[lib]\n    64→name = \"mylib\"\n    65→\n    66→[dependencies]\n    67→serde = \"1\"\n    68→`;\n    69→\n    70→/** Generic Cargo.toml with only a package name and version */\n    71→export const CARGO_TOML_GENERIC = `[package]\n    72→name = \"myapp\"\n    73→version = \"0.1.0\"\n    74→`;\n    75→"}]},"parent_tool_use_id":"toolu_01E4d2UoNxdYuxQTG5Dezgge","session_id":"8c35c2f7-0e10-4994-a438-2b5cecce3396","uuid":"ec6208ca-404a-48cf-80f9-aa007040be7f","timestamp":"2026-03-24T14:16:18.020Z"}
