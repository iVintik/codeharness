{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014u8ZEEwYMHi4GEVnhvpy9H","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { render } from 'ink-testing-library';\n3\timport React from 'react';\n4\timport { WorkflowGraph } from '../ink-workflow.js';\n5\timport type { TaskNodeState } from '../ink-components.js';\n6\timport type { FlowStep } from '../workflow-parser.js';\n7\t\n8\tdescribe('WorkflowGraph component', () => {\n9\t  it('renders sequential flow as task1 ã task2 ã task3', () => {\n10\t    const flow: FlowStep[] = ['create-story', 'implement', 'verify'];\n11\t    const taskStates: Record<string, TaskNodeState> = {\n12\t      'create-story': 'done',\n13\t      'implement': 'active',\n14\t      'verify': 'pending',\n15\t    };\n16\t    const { lastFrame } = render(\n17\t      <WorkflowGraph flow={flow} currentTask=\"implement\" taskStates={taskStates} />\n18\t    );\n19\t    const frame = lastFrame()!;\n20\t    expect(frame).toContain('create-story');\n21\t    expect(frame).toContain('ã');\n22\t    expect(frame).toContain('implement');\n23\t    expect(frame).toContain('verify');\n24\t  });\n25\t\n26\t  it('renders loop block as loop(N)[ task1 ã task2 ]', () => {\n27\t    const flow: FlowStep[] = ['create-story', { loop: ['implement', 'verify'] }];\n28\t    const taskStates: Record<string, TaskNodeState> = {\n29\t      'create-story': 'done',\n30\t      'implement': 'active',\n31\t      'verify': 'pending',\n32\t    };\n33\t    const { lastFrame } = render(\n34\t      <WorkflowGraph flow={flow} currentTask=\"implement\" taskStates={taskStates} />\n35\t    );\n36\t    const frame = lastFrame()!;\n37\t    expect(frame).toContain('loop(');\n38\t    expect(frame).toContain('[ ');\n39\t    expect(frame).toContain('implement');\n40\t    expect(frame).toContain('verify');\n41\t    expect(frame).toContain(' ]');\n42\t  });\n43\t\n44\t  it('renders pending tasks with dim text', () => {\n45\t    const flow: FlowStep[] = ['task1'];\n46\t    const taskStates: Record<string, TaskNodeState> = { 'task1': 'pending' };\n47\t    const { lastFrame } = render(\n48\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} />\n49\t    );\n50\t    const frame = lastFrame()!;\n51\t    // Dim text in Ink renders the text without color markers\n52\t    expect(frame).toContain('task1');\n53\t    // Pending should NOT have status symbols\n54\t    expect(frame).not.toContain('ã');\n55\t    expect(frame).not.toContain('ã');\n56\t    expect(frame).not.toContain('ã');\n57\t  });\n58\t\n59\t  it('renders active task with ã marker', () => {\n60\t    const flow: FlowStep[] = ['task1'];\n61\t    const taskStates: Record<string, TaskNodeState> = { 'task1': 'active' };\n62\t    const { lastFrame } = render(\n63\t      <WorkflowGraph flow={flow} currentTask=\"task1\" taskStates={taskStates} />\n64\t    );\n65\t    const frame = lastFrame()!;\n66\t    expect(frame).toContain('ã');\n67\t    expect(frame).toContain('task1');\n68\t  });\n69\t\n70\t  it('renders completed task with ã', () => {\n71\t    const flow: FlowStep[] = ['task1'];\n72\t    const taskStates: Record<string, TaskNodeState> = { 'task1': 'done' };\n73\t    const { lastFrame } = render(\n74\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} />\n75\t    );\n76\t    const frame = lastFrame()!;\n77\t    expect(frame).toContain('ã');\n78\t    expect(frame).toContain('task1');\n79\t  });\n80\t\n81\t  it('renders failed task with ã', () => {\n82\t    const flow: FlowStep[] = ['task1'];\n83\t    const taskStates: Record<string, TaskNodeState> = { 'task1': 'failed' };\n84\t    const { lastFrame } = render(\n85\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} />\n86\t    );\n87\t    const frame = lastFrame()!;\n88\t    expect(frame).toContain('ã');\n89\t    expect(frame).toContain('task1');\n90\t  });\n91\t\n92\t  it('returns null for empty flow', () => {\n93\t    const { lastFrame } = render(\n94\t      <WorkflowGraph flow={[]} currentTask={null} taskStates={{ task1: 'pending' }} />\n95\t    );\n96\t    expect(lastFrame()).toBe('');\n97\t  });\n98\t\n99\t  it('returns null for empty taskStates', () => {\n100\t    const { lastFrame } = render(\n101\t      <WorkflowGraph flow={['task1']} currentTask={null} taskStates={{}} />\n102\t    );\n103\t    expect(lastFrame()).toBe('');\n104\t  });\n105\t\n106\t  it('renders loop block with iteration 0 when all tasks are pending', () => {\n107\t    const flow: FlowStep[] = [{ loop: ['implement', 'verify'] }];\n108\t    const taskStates: Record<string, TaskNodeState> = {\n109\t      'implement': 'pending',\n110\t      'verify': 'pending',\n111\t    };\n112\t    const { lastFrame } = render(\n113\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} />\n114\t    );\n115\t    const frame = lastFrame()!;\n116\t    expect(frame).toContain('loop(0)');\n117\t    expect(frame).toContain('implement');\n118\t    expect(frame).toContain('verify');\n119\t  });\n120\t\n121\t  it('renders loop block with iteration 1 when a task is done', () => {\n122\t    const flow: FlowStep[] = [{ loop: ['implement', 'verify'] }];\n123\t    const taskStates: Record<string, TaskNodeState> = {\n124\t      'implement': 'done',\n125\t      'verify': 'pending',\n126\t    };\n127\t    const { lastFrame } = render(\n128\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} />\n129\t    );\n130\t    const frame = lastFrame()!;\n131\t    expect(frame).toContain('loop(1)');\n132\t  });\n133\t\n134\t  it('renders loop block with iteration 1 when a task has failed', () => {\n135\t    const flow: FlowStep[] = [{ loop: ['implement', 'verify'] }];\n136\t    const taskStates: Record<string, TaskNodeState> = {\n137\t      'implement': 'failed',\n138\t      'verify': 'pending',\n139\t    };\n140\t    const { lastFrame } = render(\n141\t      <WorkflowGraph flow={fl