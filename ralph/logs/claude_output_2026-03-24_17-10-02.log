{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0162pmYTT98SDwzBMhJpS9E8","type":"tool_result","content":"     1→/**\n     2→ * Documentation health report formatting and exec-plan lifecycle.\n     3→ */\n     4→\n     5→import {\n     6→  existsSync,\n     7→  mkdirSync,\n     8→  readFileSync,\n     9→  unlinkSync,\n    10→  writeFileSync,\n    11→} from 'node:fs';\n    12→import { join } from 'node:path';\n    13→import { ok, fail as failFmt, info as infoFmt } from '../output.js';\n    14→import type { DocHealthReport } from './types.js';\n    15→\n    16→// ─── Output Formatting ──────────────────────────────────────────────────────\n    17→\n    18→export function formatDocHealthOutput(report: DocHealthReport): string[] {\n    19→  const lines: string[] = [];\n    20→\n    21→  for (const doc of report.documents) {\n    22→    switch (doc.grade) {\n    23→      case 'fresh':\n    24→        lines.push(`[OK] ${doc.path}: fresh`);\n    25→        break;\n    26→      case 'stale':\n    27→        lines.push(`[FAIL] ${doc.reason}`);\n    28→        break;\n    29→      case 'missing':\n    30→        lines.push(`[FAIL] ${doc.reason}`);\n    31→        break;\n    32→    }\n    33→  }\n    34→\n    35→  lines.push(\n    36→    `[INFO] Doc health: ${report.summary.fresh} fresh, ${report.summary.stale} stale, ${report.summary.missing} missing`,\n    37→  );\n    38→\n    39→  return lines;\n    40→}\n    41→\n    42→export function printDocHealthOutput(report: DocHealthReport): void {\n    43→  for (const doc of report.documents) {\n    44→    switch (doc.grade) {\n    45→      case 'fresh':\n    46→        ok(`${doc.path}: fresh`);\n    47→        break;\n    48→      case 'stale':\n    49→        failFmt(doc.reason);\n    50→        break;\n    51→      case 'missing':\n    52→        failFmt(doc.reason);\n    53→        break;\n    54→    }\n    55→  }\n    56→\n    57→  infoFmt(\n    58→    `Doc health: ${report.summary.fresh} fresh, ${report.summary.stale} stale, ${report.summary.missing} missing`,\n    59→  );\n    60→}\n    61→\n    62→// ─── Exec-Plan Lifecycle ────────────────────────────────────────────────────\n    63→\n    64→export function createExecPlan(storyId: string, dir?: string): string {\n    65→  const root = dir ?? process.cwd();\n    66→  const activeDir = join(root, 'docs', 'exec-plans', 'active');\n    67→  mkdirSync(activeDir, { recursive: true });\n    68→\n    69→  const execPlanPath = join(activeDir, `${storyId}.md`);\n    70→\n    71→  const storyDir = join(root, '_bmad-output', 'implementation-artifacts');\n    72→  const storyPath = join(storyDir, `${storyId}.md`);\n    73→\n    74→  let storyTitle = storyId;\n    75→  let acSection = '';\n    76→  let taskSection = '';\n    77→\n    78→  if (existsSync(storyPath)) {\n    79→    const content = readFileSync(storyPath, 'utf-8');\n    80→\n    81→    const titleMatch = /^#\\s+(.+)$/m.exec(content);\n    82→    if (titleMatch) {\n    83→      storyTitle = titleMatch[1];\n    84→    }\n    85→\n    86→    const acMatch = /## Acceptance Criteria\\n([\\s\\S]*?)(?=\\n## |\\n<!-- |$)/i.exec(content);\n    87→    if (acMatch) {\n    88→      acSection = acMatch[1].trim();\n    89→    }\n    90→\n    91→    const taskMatch = /## Tasks \\/ Subtasks\\n([\\s\\S]*?)(?=\\n## |\\n<!-- |$)/i.exec(content);\n    92→    if (taskMatch) {\n    93→      taskSection = taskMatch[1].trim();\n    94→    }\n    95→  }\n    96→\n    97→  const timestamp = new Date().toISOString();\n    98→  const execPlanContent = [\n    99→    '<!-- DO NOT EDIT MANUALLY — managed by codeharness -->',\n   100→    `# Exec Plan: ${storyId}`,\n   101→    '',\n   102→    'Status: active',\n   103→    `Created: ${timestamp}`,\n   104→    '',\n   105→    '## Acceptance Criteria',\n   106→    '',\n   107→    acSection || '_No acceptance criteria extracted_',\n   108→    '',\n   109→    '## Task Checklist',\n   110→    '',\n   111→    taskSection || '_No tasks extracted_',\n   112→    '',\n   113→  ].join('\\n');\n   114→\n   115→  writeFileSync(execPlanPath, execPlanContent, 'utf-8');\n   116→  return execPlanPath;\n   117→}\n   118→\n   119→export function completeExecPlan(storyId: string, dir?: string): string | null {\n   120→  const root = dir ?? process.cwd();\n   121→  const activePath = join(root, 'docs', 'exec-plans', 'active', `${storyId}.md`);\n   122→\n   123→  if (!existsSync(activePath)) {\n   124→    return null;\n   125→  }\n   126→\n   127→  let content = readFileSync(activePath, 'utf-8');\n   128→\n   129→  content = content.replace(/^Status:\\s*active$/m, 'Status: completed');\n   130→\n   131→  const timestamp = new Date().toISOString();\n   132→  content = content.replace(\n   133→    /^(Created:\\s*.+)$/m,\n   134→    `$1\\nCompleted: ${timestamp}`,\n   135→  );\n   136→\n   137→  const completedDir = join(root, 'docs', 'exec-plans', 'completed');\n   138→  mkdirSync(completedDir, { recursive: true });\n   139→\n   140→  const completedPath = join(completedDir, `${storyId}.md`);\n   141→  writeFileSync(completedPath, content, 'utf-8');\n   142→\n   143→  try {\n   144→    unlinkSync(activePath);\n   145→  } catch {\n   146→    // Best-effort removal\n   147→  }\n   148→\n   149→  return completedPath;\n   150→}\n   151→\n   152→export function getExecPlanStatus(\n   153→  storyId: string,\n   154→  dir?: string,\n   155→): 'active' | 'completed' | 'missing' {\n   156→  const root = dir ?? process.cwd();\n   157→\n   158→  if (existsSync(join(root, 'docs', 'exec-plans', 'active', `${storyId}.md`))) {\n   159→    return 'active';\n   160→  }\n   161→  if (existsSync(join(root, 'docs', 'exec-plans', 'completed', `${storyId}.md`))) {\n   162→    return 'completed';\n   163→  }\n   164→  return 'missing';\n   165→}\n   166→"}]},"parent_tool_use_id":"toolu_01WxJciqSN2EMLLyK1wQ7yug","session_id":"6831c0a8-772d-4704-bc72-4469c7d7a986","uuid":"a33dc620-d0e2-45b3-954b-4046bd598391","timestamp":"2026-03-24T13:14:02.910Z"}
