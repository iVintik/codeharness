{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UKaSGb7bfrLbo9AFUMpGkw","type":"tool_result","content":"     1→/**\n     2→ * Types for the validation AC registry.\n     3→ * Shared across all AC data files.\n     4→ */\n     5→\n     6→/**\n     7→ * Verification method classification.\n     8→ *\n     9→ * Correspondence to {@link VerificationTier} (from `types.ts`):\n    10→ * - `'cli'` maps to the `test-provable` tier — verifiable via CLI commands.\n    11→ * - `'integration'` maps to the `environment-provable` tier — requires a running integration environment.\n    12→ */\n    13→export type VerificationMethod = 'cli' | 'integration';\n    14→\n    15→/** AC category for grouping */\n    16→export type AcCategory = 'FR' | 'NFR' | 'UX' | 'Regression' | 'ActionItem';\n    17→\n    18→/** A single validation AC entry */\n    19→export interface ValidationAC {\n    20→  /** Unique AC number (1-79) */\n    21→  readonly id: number;\n    22→  /** Reference to the requirement (e.g. \"FR1\", \"NFR2\", \"Regression: 1-1\") */\n    23→  readonly frRef: string;\n    24→  /** Human-readable description of the acceptance criterion */\n    25→  readonly description: string;\n    26→  /** How this AC can be verified */\n    27→  readonly verificationMethod: VerificationMethod;\n    28→  /** Optional CLI command or file check that can verify this AC */\n    29→  readonly command?: string;\n    30→  /** Category for grouping and filtering */\n    31→  readonly category: AcCategory;\n    32→}\n    33→"}]},"parent_tool_use_id":"toolu_01WsJumCEeohz8aetMGbH1m9","session_id":"15a05376-1038-4ca0-9130-3347fd423c16","uuid":"f793733e-a9f9-4971-8c30-d0549f898176","timestamp":"2026-03-27T11:42:57.433Z"}
