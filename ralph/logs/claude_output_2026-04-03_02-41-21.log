enCalledTimes(10);\n1651\t  });\n1652\t\n1653\t  it('records multiple evaluator scores across iterations', async () => {\n1654\t    let callCount = 0;\n1655\t    mockDispatchAgent.mockImplementation(\n1656\t      async (_def: SubagentDefinition, prompt: string) => {\n1657\t        callCount++;\n1658\t        if (prompt.includes('Execute task')) {\n1659\t          // Fail first, pass second\n1660\t          if (callCount <= 2) {\n1661\t            return { sessionId: 'sess-v', success: true, durationMs: 100, output: makeFailVerdict() };\n1662\t          }\n1663\t          return { sessionId: 'sess-v', success: true, durationMs: 100, output: makePassVerdict() };\n1664\t        }\n1665\t        return { sessionId: 'sess-r', success: true, durationMs: 100, output: 'ok' };\n1666\t      },\n1667\t    );\n1668\t\n1669\t    mockParse.mockReturnValue({\n1670\t      development_status: { '3-1-foo': 'ready-for-dev' },\n1671\t    });\n1672\t\n1673\t    const config = makeConfig({\n1674\t      workflow: {\n1675\t        tasks: {\n1676\t          retry: makeTask({ scope: 'per-story' }),\n1677\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n1678\t        },\n1679\t        flow: [{ loop: ['retry', 'verify'] }],\n1680\t      },\n1681\t    });\n1682\t\n1683\t    await executeWorkflow(config);\n1684\t\n1685\t    // Find final state with evaluator scores\n1686\t    const allWrites = mockWriteWorkflowState.mock.calls.map((c: unknown[]) => c[0] as WorkflowState);\n1687\t    const statesWithScores = allWrites.filter((s) => s.evaluator_scores.length >= 2);\n1688\t    expect(statesWithScores.length).toBeGreaterThan(0);\n1689\t\n1690\t    const finalScored = statesWithScores[statesWithScores.length - 1];\n1691\t    expect(finalScored.evaluator_scores).toHaveLength(2);\n1692\t    expect(finalScored.evaluator_scores[0].failed).toBe(1); // first: fail\n1693\t    expect(finalScored.evaluator_scores[1].passed).toBe(2); // second: pass\n1694\t  });\n1695\t\n1696\t  it('halt error in per-run verify task terminates loop', async () => {\n1697\t    const { DispatchError } = await import('../agent-dispatch.js');\n1698\t\n1699\t    let callCount = 0;"}]},"parent_tool_use_id":"toolu_01RL1K8ArV7Pe3b3p8vDkEdF","session_id":"8b4a1da7-9e18-4302-ad13-ce7f0aff0314","uuid":"e7118750-13ed-4526-a642-aa8e48c19f69","timestamp":"2026-04-02T22:48:40.564Z"}
