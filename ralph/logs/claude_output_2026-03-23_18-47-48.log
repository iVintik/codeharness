result.data.enforcement).toEqual({ frontend: true, database: true, api: true });\n   137→    }\n   138→  });\n   139→\n   140→  it('creates state file', async () => {\n   141→    writeFileSync(join(testDir, 'package.json'), '{}');\n   142→    await initProject({\n   143→      projectDir: testDir,\n   144→      frontend: true,\n   145→      database: true,\n   146→      api: true,\n   147→      observability: false,\n   148→    });\n   149→    const state = readState(testDir);\n   150→    expect(state.initialized).toBe(true);\n   151→    expect(state.stack).toBe('nodejs');\n   152→  });\n   153→\n   154→  it('includes beads result', async () => {\n   155→    writeFileSync(join(testDir, 'package.json'), '{}');\n   156→    const result = await initProject({\n   157→      projectDir: testDir,\n   158→      frontend: true,\n   159→      database: true,\n   160→      api: true,\n   161→      observability: false,\n   162→    });\n   163→    if (result.success) {\n   164→      expect(result.data.beads).toBeDefined();\n   165→      expect(result.data.beads!.status).toBe('initialized');\n   166→    }\n   167→  });\n   168→\n   169→  it('includes bmad result', async () => {\n   170→    writeFileSync(join(testDir, 'package.json'), '{}');\n   171→    const result = await initProject({\n   172→      projectDir: testDir,\n   173→      frontend: true,\n   174→      database: true,\n   175→      api: true,\n   176→      observability: false,\n   177→    });\n   178→    if (result.success) {\n   179→      expect(result.data.bmad).toBeDefined();\n   180→      expect(result.data.bmad!.status).toBe('installed');\n   181→    }\n   182→  });\n   183→\n   184→  it('includes dependencies result', async () => {\n   185→    writeFileSync(join(testDir, 'package.json'), '{}');\n   186→    const result = await initProject({\n   187→      projectDir: testDir,\n   188→      frontend: true,\n   189→      database: true,\n   190→      api: true,\n   191→      observability: false,\n   192→    });\n   193→    if (result.success) {\n   194→      expect(result.data.dependencies).toBeDefined();\n   195→      expect(result.data.dependencies!.length).toBeGreaterThan(0);\n   196→    }\n   197→  });\n   198→});\n   199→\n   200→describe('initProject — idempotent re-run', () => {\n   201→  it('detects already initialized and returns early', async () => {\n   202→    writeFileSync(join(testDir, 'package.json'), '{}');\n   203→    // First init\n   204→    await initProject({\n   205→      projectDir: testDir,\n   206→      frontend: true,\n   207→      database: true,\n   208→      api: true,\n   209→      observability: false,\n   210→    });\n   211→    // Second init (re-run)\n   212→    const result = await initProject({\n   213→      projectDir: testDir,\n   214→      frontend: true,\n   215→      database: true,\n   216→      api: true,\n   217→      observability: false,\n   218→    });\n   219→    expect(result.success).toBe(true);\n   220→    if (result.success) {\n   221→      expect(result.data.documentation.agents_md).toBe('exists');\n   222→    }\n   223→  });\n   224→});\n   225→\n   226→describe('initProject — critical failures', () => {\n   227→  it('returns ok with fail status when Docker missing and observability on', async () => {\n   228→    writeFileSync(join(testDir, 'package.json'), '{}');\n   229→    mockIsDockerAvailable.mockReturnValue(false);\n   230→    const result = await initProject({\n   231→      projectDir: testDir,\n   232→      frontend: true,\n   233→      database: true,\n   234→      api: true,\n   235→      observability: true,\n   236→    });\n   237→    expect(result.success).toBe(true);\n   238→    if (result.success) {\n   239→      expect(result.data.status).toBe('fail');\n   240→      expect(result.data.error).toBe('Docker not installed');\n   241→    }\n   242→    expect(process.exitCode).toBe(1);\n   243→  });\n   244→\n   245→  it('returns ok with fail status on critical dep failure', async () => {\n   246→    writeFileS