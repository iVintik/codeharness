e,\n   264→      data: {\n   265→        entries: [],\n   266→        totalModules: 5,\n   267→        modulesWithTelemetry: 5,\n   268→        coveragePercent: 100,\n   269→        skipped: false,\n   270→      },\n   271→    });\n   272→\n   273→    const result = await checkObservability('/project');\n   274→    expect(result.success).toBe(true);\n   275→    if (result.success) {\n   276→      expect(result.data.status).toBe('warn');\n   277→      expect(result.data.gaps.length).toBeGreaterThan(0);\n   278→      expect(result.data.metric).toContain('1 gap');\n   279→    }\n   280→  });\n   281→});\n   282→\n   283→// ─── checkTesting ───────────────────────────────────────────────────────────\n   284→\n   285→describe('checkTesting', () => {\n   286→  it('returns pass with high coverage', () => {\n   287→    mockCheckOnlyCoverage.mockReturnValue({\n   288→      success: true,\n   289→      testsPassed: true,\n   290→      passCount: 50,\n   291→      failCount: 0,\n   292→      coveragePercent: 95,\n   293→      rawOutput: 'Check-only mode',\n   294→    });\n   295→\n   296→    const result = checkTesting('/project');\n   297→    expect(result.success).toBe(true);\n   298→    if (result.success) {\n   299→      expect(result.data.status).toBe('pass');\n   300→      expect(result.data.metric).toBe('95%');\n   301→      expect(result.data.gaps).toHaveLength(0);\n   302→    }\n   303→  });\n   304→\n   305→  it('returns fail with critically low coverage', () => {\n   306→    mockCheckOnlyCoverage.mockReturnValue({\n   307→      success: true,\n   308→      testsPassed: true,\n   309→      passCount: 5,\n   310→      failCount: 0,\n   311→      coveragePercent: 30,\n   312→      rawOutput: '',\n   313→    });\n   314→\n   315→    const result = checkTesting('/project');\n   316→    expect(result.success).toBe(true);\n   317→    if (result.success) {\n   318→      expect(result.data.status).toBe('fail');\n   319→      expect(result.data.metric).toBe('30%');\n   320→  