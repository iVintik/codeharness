{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VRBxnyEutpZ9UeZXT8CGKm","type":"tool_result","content":"1\t/**\n2\t * Worktree Manager.\n3\t *\n4\t * Handles git worktree lifecycle for parallel epic execution:\n5\t * create, cleanup, list, and orphan detection. Each epic gets\n6\t * its own git worktree on a dedicated branch under the\n7\t * `codeharness/` namespace.\n8\t *\n9\t * @see Story 17-1: Worktree Manager\n10\t */\n11\t\n12\timport { exec, execSync } from 'node:child_process';\n13\timport { existsSync, readFileSync, statSync } from 'node:fs';\n14\timport { join } from 'node:path';\n15\timport { promisify } from 'node:util';\n16\t\n17\tconst execAsync = promisify(exec);\n18\t\n19\t// --- Constants ---\n20\t\n21\t/** Branch prefix for all codeharness worktree branches. */\n22\texport const BRANCH_PREFIX = 'codeharness/epic-';\n23\t\n24\t/** Base path for worktree directories in /tmp. */\n25\texport const WORKTREE_BASE = '/tmp/codeharness-wt-epic-';\n26\t\n27\t// --- Interfaces ---\n28\t\n29\t/**\n30\t * Information about a codeharness worktree.\n31\t */\n32\texport interface WorktreeInfo {\n33\t  /** Epic identifier extracted from the branch name. */\n34\t  readonly epicId: string;\n35\t  /** Absolute path to the worktree directory. */\n36\t  readonly path: string;\n37\t  /** Full branch name (e.g., `codeharness/epic-17-worktree-manager`). */\n38\t  readonly branch: string;\n39\t  /** Timestamp when the worktree was created. */\n40\t  readonly createdAt: Date;\n41\t}\n42\t\n43\t// --- Error Class ---\n44\t\n45\t/**\n46\t * Error thrown by worktree operations. Includes stderr from git commands.\n47\t */\n48\texport class WorktreeError extends Error {\n49\t  /** Raw stderr output from the failed git command. */\n50\t  readonly stderr: string;\n51\t\n52\t  constructor(message: string, stderr: string) {\n53\t    super(message);\n54\t    this.name = 'WorktreeError';\n55\t    this.stderr = stderr;\n56\t  }\n57\t}\n58\t\n59\t// --- Merge Types ---\n60\t\n61\t/**\n62\t * Strategy used when merging an epic branch into main.\n63\t */\n64\texport type MergeStrategy = 'rebase' | 'merge-commit';\n65\t\n66\t/**\n67\t * Result of a merge operation.\n68\t */\n69\texport interface MergeResult {\n70\t  /** Whether the merge and post-merge validation succeeded. */\n71\t  success: boolean;\n72\t  /** Reason for failure, if any. */\n73\t  reason?: 'conflict' | 'tests-failed' | 'git-error';\n74\t  /** List of conflicting file paths, when reason is 'conflict'. */\n75\t  conflicts?: string[];\n76\t  /** Test suite results from post-merge validation. */\n77\t  testResults?: { passed: number; failed: number; coverage?: number };\n78\t  /** Total wall-clock duration of the merge operation in milliseconds. */\n79\t  durationMs: number;\n80\t}\n81\t\n82\t// --- Async Mutex ---\n83\t\n84\t/**\n85\t * Simple async mutex for serializing merge operations.\n86\t * No external dependencies — uses a promise-based wait queue.\n87\t */\n88\texport class AsyncMutex {\n89\t  private locked = false;\n90\t  private waitQueue: Array<() => void> = [];\n91\t\n92\t  async acquire(): Promise<() => void> {\n93\t    while (this.locked) {\n94\t      await new Promise<void>((resolve) => this.waitQueue.push(resolve));\n95\t    }\n96\t    this.locked = true;\n97\t    return () => {\n98\t      this.locked = false;\n99\t      const next = this.waitQueue.shift();\n100\t      if (next) next();\n101\t    };\n102\t  }\n103\t}\n104\t\n105\t/** Module-level singleton merge mutex shared across all WorktreeManager instances. */\n106\texport const mergeMutex = new AsyncMutex();\n107\t\n108\t// --- WorktreeManager Class ---\n109\t\n110\t/**\n111\t * Manages git worktrees for parallel epic execution.\n112\t *\n113\t * Creates isolated working directories (worktrees) for each epic,\n114\t * each on its own branch under the `codeharness/` namespace.\n115\t */\n116\texport class WorktreeManager {\n117\t  private readonly mainBranch: string;\n118\t  private readonly cwd: string;\n119\t\n120\t  /**\n121\t   * @param mainBranch  The main branch to base new worktree branches on (default: `'main'`).\n122\t   * @param cwd  The git repository root directory (default: `process.cwd()`).\n123\t   */\n124\t  constructor(mainBranch: string = 'main', cwd?: string) {\n125\t    this.mainBranch = mainBranch;\n126\t    this.cwd = cwd ?? process.cwd();\n127\t  }\n128\t\n129\t  /**\n130\t   * Create a worktree for a parallel epic.\n131\t   *\n132\t   * Creates a branch `codeharness/epic-{epicId}-{slug}` from the main branch HEAD,\n133\t   * then creates a git worktree at `/tmp/codeharness-wt-epic-{epicId}`.\n134\t   *\n135\t   * If a stale branch or worktree exists from a previous crashed run,\n136\t   * it is cleaned up before re-creating (idempotent recovery).\n137\t   *\n138\t   * @param epicId  The epic identifier (numeric or string).\n139\t   * @param slug  A human-readable slug for the branch name (sanitized to `[a-z0-9-]`).\n140\t   * @returns The absolute path to the created worktree directory.\n141\t   * @throws {WorktreeError} If the git command fails.\n142\t   */\n143\t  createWorktree(epicId: string, slug: string): string {\n144\t    this.validateEpicId(epicId);\n145\t    const sanitizedSlug = this.sanitizeSlug(slug);\n146\t    const branchName = `${BRANCH_PREFIX}${epicId}-${sanitizedSlug}`;\n147\t    const worktreePath = `${WORKTREE_BASE}${epicId}`;\n148\t\n149\t    // Clean up stale state from previous crashed runs (AC #9)\n150\t    this.cleanupStale(epicId, branchName, worktreePath);\n151\t\n152\t    let branchCreated = false;\n153\t    try {\n154\t      // Create branch from main branch HEAD\n155\t      this.execGit(`git branch ${branchName} ${this.mainBranch}`);\n156\t      branchCreated = true;\n157\t\n158\t      // Create worktree\n159\t      this.execGit(`git worktree add ${worktreePath} ${branchName}`);\n160\t\n161\t      return worktreePath;\n162\t    } catch (err: unknown) {\n163\t      // Clean up partial state on failure (AC #10)\n164\t      this.cleanupPartial(branchCreated, branchName, worktreePath);\n165\t\n166\t      // execGit always wraps errors as WorktreeError; re-throw directly\n167\t      if (err instanceof WorktreeError) {\n168\t        throw err;\n169\t      }\n170\t\n171\t      // Defensive: handle unexpected non-WorktreeError (should not happen)\n172\t      const message = err instanceof Error ? err.message : String(err);\n173\t      throw new WorktreeError(\n174\t        `Failed to create worktree for epic ${epicId}: ${message}`,\n175\t        '',\n176\t      );\n177\t    }\n178\t  }\n179\t\n180\t  /**\n181\t   * Remove a worktree and its branch for an epic.\n182\t   *\n183\t   * Idempotent: completes without error if the worktree or branch\n184\t   * does not exist (AC #5).\n185\t   *\n186\t   * @param epicId  The epic identifier.\n187\t   */\n188\t  cleanupWorktree(epicId: string): void {\n189\t    this.validateEpicId(epicId);\n190\t    const worktreePath = `${WORKTREE_BASE}${epicId}`;\n191\t\n192\t    // Remove worktree (ignore errors if it doesn't exist)\n193\t    try {\n194\t      this.execGit(`git worktree remove ${worktreePath} --force`);\n195\t    } catch { // IGNORE: idempotent cleanup — worktree may not exist per AC #5\n196\t    }\n197\t\n198\t    // Find and delete the branch matching this epicId\n199\t    const branch = this.findBranchForEpic(epicId);\n200\t    if (branch) {\n201\t      try {\n202\t        this.execGit(`git branch -D ${branch}`);\n203\t      } catch { // IGNORE: idempotent cleanup — branch may not exist per AC #5\n204\t      }\n205\t    }\n206\t  }\n207\t\n208\t  /**\n209\t   * List all codeharness worktrees.\n210\t   *\n211\t   * @returns An array of `WorktreeInfo` objects sorted by epicId.\n212\t   *          Returns an empty array when no codeharness worktrees exist.\n213\t   */\n214\t  listWorktrees(): WorktreeInfo[] {\n215\t    let output: string;\n216\t    try {\n217\t      output = this.execGit('git worktree list --porcelain');\n218\t    } catch { // IGNORE: non-git-repo or corrupt state returns empty list safely\n219\t      return [];\n220\t    }\n221\t\n222\t    const entries = this.parsePorcelainOutput(output);\n223\t    return entries\n224\t      .filter((e) => e.branch.startsWith(`refs/heads/${BRANCH_PREFIX}`))\n225\t      .map((e) => {\n226\t        const branchName = e.branch.replace('refs/heads/', '');\n227\t        const epicId = this.extractEpicId(branchName);\n228\t        return {\n229\t          epicId,\n230\t          path: e.path,\n231\t          branch: branchName,\n232\t          createdAt: this.getWorktreeCreatedAt(e.path),\n233\t        };\n234\t      })\n235\t      .sort((a, b) => a.epicId.localeCompare(b.epicId, undefined, { numeric: true }));\n236\t  }\n237\t\n238\t  /**\n239\t   * Detect orphaned worktrees from previous crashed runs.\n240\t   *\n241\t   * A worktree is considered orphaned if its directory exists on disk\n242\t   * but has no `.codeharness/lane-state.json` file or the file has\n243\t   * no active PID.\n244\t   *\n245\t   * @returns An array of orphaned `WorktreeInfo` entries.\n246\t   */\n247\t  detectOrphans(): WorktreeInfo[] {\n248\t    const worktrees = this.listWorktrees();\n249\t    return worktrees.filter((wt) => this.isOrphaned(wt));\n250\t  }\n251\t\n252\t  /**\n253\t   * Merge an epic branch into the main branch with serialized access.\n254\t   *\n255\t   * Acquires a module-level mutex so only one merge runs at a time.\n256\t   * After a clean merge, runs the test suite. If tests fail, the merge\n257\t   * is reverted. On conflict or git error, the main branch is restored.\n258\t   *\n259\t   * @param epicId  The epic identifier whose branch should be merged.\n260\t   * @param strategy  Merge strategy: `'merge-commit'` (default) or `'rebase'`.\n261\t   * @param testCommand  Command to run for post-merge validation (default: `'npm test'`).\n262\t   * @returns A `MergeResult` describing the outcome.\n263\t   */\n264\t  async mergeWorktree(\n265\t    epicId: string,\n266\t    strategy: MergeStrategy = 'merge-commit',\n267\t    testCommand: string = 'npm test',\n268\t  ): Promise<MergeResult> {\n269\t    const start = Date.now();\n270\t\n271\t    // Find branch for this epicId\n272\t    const branch = this.findBranchForEpic(epicId);\n273\t    if (!branch) {\n274\t      return {\n275\t        success: false,\n276\t        reason: 'git-error',\n277\t        durationMs: Date.now() - start,\n278\t      };\n279\t    }\n280\t\n281\t    const release = await mergeMutex.acquire();\n282\t    try {\n283\t      // Verify main branch is clean before merge\n284\t      const status = this.execGit('git status --porcelain');\n285\t      if (status.length > 0) {\n286\t        return {\n287\t          success: false,\n288\t          reason: 'git-error',\n289\t          durationMs: Date.now() - start,\n290\t        };\n291\t      }\n292\t\n293\t      // Attempt merge or rebase\n294\t      try {\n295\t        if (strategy === 'rebase') {\n296\t          this.execGit(`git rebase ${branch}`);\n297\t        } else {\n298\t          this.execGit(`git merge --no-ff ${branch}`);\n299\t        }\n300\t      } catch {\n301\t        // Detect conflict vs other error\n302\t        const conflicts = this.detectConflicts();\n303\t        if (conflicts.length > 0) {\n304\t          this.abortMerge(strategy);\n305\t          return {\n306\t            success: false,\n307\t            reason: 'conflict',\n308\t            conflicts,\n309\t            durationMs: Date.now() - start,\n310\t          };\n311\t        }\n312\t        // Not a conflict — unexpected git error\n313\t        this.abortMerge(strategy);\n314\t        return {\n315\t          success: false,\n316\t          reason: 'git-error',\n317\t          durationMs: Date.now() - start,\n318\t        };\n319\t      }\n320\t\n321\t      // Run test suite after successful merge\n322\t      const testResults = await this.runTestSuite(testCommand);\n323\t      if (testResults.failed > 0) {\n324\t        // Revert merge on test failure\n325\t        try {\n326\t          this.execGit('git reset --hard HEAD~1');\n327\t        } catch { // IGNORE: reset failure indicates corrupted git state; still return tests-failed\n328\t        }\n329\t        return {\n330\t          success: false,\n331\t          reason: 'tests-failed',\n332\t          testResults,\n333\t          durationMs: Date.now() - start,\n334\t        };\n335\t      }\n336\t\n337\t      // Success — cleanup worktree\n338\t      this.cleanupWorktree(epicId);\n339\t      return {\n340\t        success: true,\n341\t        testResults,\n342\t        durationMs: Date.now() - start,\n343\t      };\n344\t    } finally {\n345\t      release();\n346\t    }\n347\t  }\n348\t\n349\t  // --- Private Helpers ---\n350\t\n351\t  /**\n352\t   * Get the creation time of a worktree directory.\n353\t   * Falls back to current time if the directory doesn't exist or stat fails.\n354\t   */\n355\t  private getWorktreeCreatedAt(worktreePath: string): Date {\n356\t    try {\n357\t      const stats = statSync(worktreePath);\n358\t      return stats.birthtime;\n359\t    } catch { // IGNORE: stat failure — worktree dir may not be accessible; fall back to now\n360\t      return new Date();\n361\t    }\n362\t  }\n363\t\n364\t  /**\n365\t   * Validate epicId contains only safe characters `[a-zA-Z0-9-]`.\n366\t   * Prevents command injection via crafted epicId values.\n367\t   */\n368\t  private validateEpicId(epicId: string): void {\n369\t    if (!epicId || !/^[a-zA-Z0-9-]+$/.test(epicId)) {\n370\t      throw new WorktreeError(\n371\t        `Invalid epicId: \"${epicId}\" — must be non-empty and contain only [a-zA-Z0-9-]`,\n372\t        '',\n373\t      );\n374\t    }\n375\t  }\n376\t\n377\t  /**\n378\t   * Sanitize a slug to contain only `[a-z0-9-]`.\n379\t   */\n380\t  private sanitizeSlug(slug: string): string {\n381\t    return slug\n382\t      .toLowerCase()\n383\t      .replace(/[^a-z0-9-]/g, '-')\n384\t      .replace(/-+/g, '-')\n385\t      .replace(/^-|-$/g, '');\n386\t  }\n387\t\n388\t  /**\n389\t   * Execute a git command and return its stdout.\n390\t   * Wraps errors in WorktreeError with captured stderr.\n391\t   */\n392\t  private execGit(cmd: string): string {\n393\t    try {\n394\t      const result = execSync(cmd, {\n395\t        cwd: this.cwd,\n396\t        stdio: ['pipe', 'pipe', 'pipe'],\n397\t        timeout: 30_000,\n398\t      });\n399\t      return result.toString().trim();\n400\t    } catch (err: unknown) {\n401\t      const stderr = (err as { stderr?: Buffer })?.stderr?.toString() ?? '';\n402\t      throw new WorktreeError(`Git command failed: ${cmd} — ${stderr}`, stderr);\n403\t    }\n404\t  }\n405\t\n406\t  /**\n407\t   * Clean up stale branch and worktree from a previous crash (AC #9).\n408\t   */\n409\t  private cleanupStale(epicId: string, branchName: string, worktreePath: string): void {\n410\t    // Check if worktree path exists on disk\n411\t    if (existsSync(worktreePath)) {\n412\t      try {\n413\t        this.execGit(`git worktree remove ${worktreePath} --force`);\n414\t      } catch { // IGNORE: stale worktree removal is best-effort before re-create per AC #9\n415\t        try {\n416\t          this.execGit('git worktree prune');\n417\t        } catch { // IGNORE: prune is best-effort fallback for stale worktree cleanup\n418\t        }\n419\t      }\n420\t    }\n421\t\n422\t    // Check if branch already exists\n423\t    const existingBranch = this.findBranchForEpic(epicId);\n424\t    if (existingBranch) {\n425\t      try {\n426\t        this.execGit(`git branch -D ${existingBranch}`);\n427\t      } catch { // IGNORE: stale branch deletion is best-effort before re-create per AC #9\n428\t      }\n429\t    }\n430\t  }\n431\t\n432\t  /**\n433\t   * Clean up partial state after a failed createWorktree (AC #10).\n434\t   */\n435\t  private cleanupPartial(branchCreated: boolean, branchName: string, worktreePath: string): void {\n436\t    // Try to remove worktree if it was partially created\n437\t    try {\n438\t      this.execGit(`git worktree remove ${worktreePath} --force`);\n439\t    } catch { // IGNORE: partial worktree may not exist during failure cleanup per AC #10\n440\t    }\n441\t\n442\t    // Delete branch if it was created\n443\t    if (branchCreated) {\n444\t      try {\n445\t        this.execGit(`git branch -D ${branchName}`);\n446\t      } catch { // IGNORE: partial branch may not exist during failure cleanup per AC #10\n447\t      }\n448\t    }\n449\t  }\n450\t\n451\t  /**\n452\t   * Find a branch matching `codeharness/epic-{epicId}-*`.\n453\t   */\n454\t  private findBranchForEpic(epicId: string): string | undefined {\n455\t    try {\n456\t      const output = this.execGit(`git branch --list ${BRANCH_PREFIX}${epicId}-*`);\n457\t      const branches = output\n458\t        .split('\\n')\n459\t        .map((b) => b.trim().replace(/^\\*\\s*/, ''))\n460\t        .filter((b) => b.length > 0);\n461\t      return branches[0];\n462\t    } catch { // IGNORE: branch listing failure means no branch exists — safe to return undefined\n463\t      return undefined;\n464\t    }\n465\t  }\n466\t\n467\t  /**\n468\t   * Parse `git worktree list --porcelain` output into structured entries.\n469\t   */\n470\t  private parsePorcelainOutput(output: string): Array<{ path: string; branch: string }> {\n471\t    if (!output.trim()) return [];\n472\t\n473\t    const blocks = output.split('\\n\\n').filter((b) => b.trim());\n474\t    const entries: Array<{ path: string; branch: string }> = [];\n475\t\n476\t    for (const block of blocks) {\n477\t      const lines = block.split('\\n');\n478\t      let path = '';\n479\t      let branch = '';\n480\t\n481\t      for (const line of lines) {\n482\t        if (line.startsWith('worktree ')) {\n483\t          path = line.slice('worktree '.length);\n484\t        } else if (line.startsWith('branch ')) {\n485\t          branch = line.slice('branch '.length);\n486\t        }\n487\t      }\n488\t\n489\t      if (path && branch) {\n490\t        entries.push({ path, branch });\n491\t      }\n492\t    }\n493\t\n494\t    return entries;\n495\t  }\n496\t\n497\t  /**\n498\t   * Extract epicId from a branch name like `codeharness/epic-17-slug`.\n499\t   */\n500\t  private extractEpicId(branchName: string): string {\n501\t    const withoutPrefix = branchName.slice(BRANCH_PREFIX.length);\n502\t    const dashIndex = withoutPrefix.indexOf('-');\n503\t    if (dashIndex === -1) return withoutPrefix;\n504\t    return withoutPrefix.slice(0, dashIndex);\n505\t  }\n506\t\n507\t  /**\n508\t   * Detect conflicting files after a failed merge/rebase.\n509\t   * Uses `git diff --name-only --diff-filter=U` to find unmerged paths.\n510\t   */\n511\t  private detectConflicts(): string[] {\n512\t    try {\n513\t      const output = this.execGit('git diff --name-only --diff-filter=U');\n514\t      return output\n515\t        .split('\\n')\n516\t        .map((f) => f.trim())\n517\t        .filter((f) => f.length > 0);\n518\t    } catch { // IGNORE: diff failure means no conflict info available\n519\t      return [];\n520\t    }\n521\t  }\n522\t\n523\t  /**\n524\t   * Abort an in-progress merge or rebase to restore main branch state.\n525\t   */\n526\t  private abortMerge(strategy: MergeStrategy): void {\n527\t    try {\n528\t      if (strategy === 'rebase') {\n529\t        this.execGit('git rebase --abort');\n530\t      } else {\n531\t        this.execGit('git merge --abort');\n532\t      }\n533\t    } catch { // IGNORE: abort may fail if merge already resolved; main state is preserved\n534\t    }\n535\t  }\n536\t\n537\t  /**\n538\t   * Run the test suite and parse results from stdout.\n539\t   * Uses async exec with a 5-minute timeout.\n540\t   */\n541\t  private async runTestSuite(\n542\t    testCommand: string = 'npm test',\n543\t  ): Promise<{ passed: number; failed: number; coverage?: number }> {\n544\t    try {\n545\t      const { stdout } = await execAsync(testCommand, {\n546\t        cwd: this.cwd,\n547\t        timeout: 300_000, // 5 minutes\n548\t      });\n549\t\n550\t      return this.parseTestOutput(stdout);\n551\t    } catch (err: unknown) {\n552\t      // Test command failed (non-zero exit) — parse whatever output we got\n553\t      const stdout = (err as { stdout?: string })?.stdout ?? '';\n554\t      const result = this.parseTestOutput(stdout);\n555\t      // If we couldn't parse anything, report 1 failure\n556\t      if (result.passed === 0 && result.failed === 0) {\n557\t        return { passed: 0, failed: 1 };\n558\t      }\n559\t      return result;\n560\t    }\n561\t  }\n562\t\n563\t  /**\n564\t   * Parse test output to extract pass/fail counts and optional coverage.\n565\t   * Supports common vitest/jest output patterns.\n566\t   */\n567\t  private parseTestOutput(stdout: string): { passed: number; failed: number; coverage?: number } {\n568\t    let passed = 0;\n569\t    let failed = 0;\n570\t    let coverage: number | undefined;\n571\t\n572\t    // Match vitest/jest \"Tests: X passed, Y failed\" or \"X passed\" patterns\n573\t    const passMatch = stdout.match(/(\\d+)\\s+passed/);\n574\t    const failMatch = stdout.match(/(\\d+)\\s+failed/);\n575\t    if (passMatch) passed = parseInt(passMatch[1], 10);\n576\t    if (failMatch) failed = parseInt(failMatch[1], 10);\n577\t\n578\t    // Match coverage percentage patterns like \"All files | 85.5\"\n579\t    const covMatch = stdout.match(/All files[^|]*\\|\\s*([\\d.]+)/);\n580\t    if (covMatch) coverage = parseFloat(covMatch[1]);\n581\t\n582\t    return { passed, failed, ...(coverage !== undefined && { coverage }) };\n583\t  }\n584\t\n585\t  /**\n586\t   * Check if a worktree is orphaned (no active codeharness process).\n587\t   */\n588\t  private isOrphaned(wt: WorktreeInfo): boolean {\n589\t    const laneStatePath = join(wt.path, '.codeharness', 'lane-state.json');\n590\t\n591\t    if (!existsSync(laneStatePath)) {\n592\t      return true;\n593\t    }\n594\t\n595\t    try {\n596\t      const content = readFileSync(laneStatePath, 'utf-8');\n597\t      const state = JSON.parse(content) as { pid?: number };\n598\t\n599\t      if (!state.pid) {\n600\t        return true;\n601\t      }\n602\t\n603\t      // Check if the PID is still running\n604\t      try {\n605\t        process.kill(state.pid, 0);\n606\t        return false; // Process is alive — not orphaned\n607\t      } catch { // IGNORE: ESRCH means process is dead — worktree is orphaned per AC #8\n608\t        return true;\n609\t      }\n610\t    } catch { // IGNORE: unreadable/corrupt lane-state.json means orphaned per AC #8\n611\t      return true;\n612\t    }\n613\t  }\n614\t}\n615\t"}]},"parent_tool_use_id":"toolu_01C74KKbCgdZj2LDCG8nDBR2","session_id":"80ecde4e-3ccc-44de-925d-a2036bf845d1","uuid":"4bb471da-d595-4e2a-87d6-57faa18e9ac3","timestamp":"2026-04-03T21:23:08.343Z"}
