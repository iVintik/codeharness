{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HxQ8yNnpNteVcN3QfPnWzW","type":"tool_result","content":"1\timport { Command } from 'commander';\n2\timport { existsSync, readFileSync } from 'node:fs';\n3\timport { join } from 'node:path';\n4\timport { ok, fail, warn, info, jsonOutput } from '../lib/output.js';\n5\timport {\n6\t  parseStoryACs,\n7\t  checkPreconditions,\n8\t  createProofDocument,\n9\t  runShowboatVerify,\n10\t  validateProofQuality,\n11\t  updateVerificationState,\n12\t  closeBeadsIssue,\n13\t  parseObservabilityGaps,\n14\t} from '../modules/verify/index.js';\n15\timport { completeExecPlan } from '../lib/doc-health/index.js';\n16\timport { updateSprintStatus } from '../lib/sync/index.js';\n17\timport type { VerifyResult, ProofQuality } from '../modules/verify/index.js';\n18\t\n19\tconst STORY_DIR = '_bmad-output/implementation-artifacts';\n20\t\n21\t/** Validates that a story ID is safe for file paths (no traversal or special chars). */\n22\tfunction isValidStoryId(storyId: string): boolean {\n23\t  if (!storyId || storyId.includes('..') || storyId.includes('/') || storyId.includes('\\\\')) return false;\n24\t  return /^[a-zA-Z0-9_-]+$/.test(storyId);\n25\t}\n26\t\n27\texport function registerVerifyCommand(program: Command): void {\n28\t  program\n29\t    .command('verify')\n30\t    .description('Run verification pipeline on completed work')\n31\t    .option('--story <id>', 'Story ID to verify')\n32\t    .option('--retro', 'Verify retrospective completion for an epic')\n33\t    .option('--epic <n>', 'Epic number (required with --retro)')\n34\t    .action((opts, cmd) => {\n35\t      const globalOpts = cmd.optsWithGlobals();\n36\t      const isJson = globalOpts.json === true;\n37\t      const root = process.cwd();\n38\t\n39\t      // Route to retro verification if --retro flag is set\n40\t      if (opts.retro) {\n41\t        verifyRetro(opts, isJson, root);\n42\t        return;\n43\t      }\n44\t\n45\t      // For story verification, --story is required\n46\t      if (!opts.story) {\n47\t        fail('--story is required when --retro is not set', { json: isJson });\n48\t        process.exitCode = 1;\n49\t        return;\n50\t      }\n51\t\n52\t      verifyStory(opts.story, isJson, root);\n53\t    });\n54\t}\n55\t\n56\t/**\n57\t * Verifies retrospective completion for an epic.\n58\t * Checks that epic-N-retrospective.md exists, then updates sprint-status.yaml.\n59\t */\n60\tfunction verifyRetro(opts: { epic?: string }, isJson: boolean, root: string): void {\n61\t  if (!opts.epic) {\n62\t    fail('--epic is required with --retro', { json: isJson });\n63\t    process.exitCode = 1;\n64\t    return;\n65\t  }\n66\t\n67\t  const epicNum = parseInt(opts.epic, 10);\n68\t  if (isNaN(epicNum) || epicNum < 1) {\n69\t    fail(`Invalid epic number: ${opts.epic}`, { json: isJson });\n70\t    process.exitCode = 1;\n71\t    return;\n72\t  }\n73\t\n74\t  const retroFile = `epic-${epicNum}-retrospective.md`;\n75\t  const retroPath = join(root, STORY_DIR, retroFile);\n76\t\n77\t  if (!existsSync(retroPath)) {\n78\t    if (isJson) {\n79\t      jsonOutput({ status: 'fail', epic: epicNum, retroFile, message: `${retroFile} not found` });\n80\t    } else {\n81\t      fail(`${retroFile} not found`);\n82\t    }\n83\t    process.exitCode = 1;\n84\t    return;\n85\t  }\n86\t\n87\t  // Update sprint-status.yaml\n88\t  const retroKey = `epic-${epicNum}-retrospective`;\n89\t  try {\n90\t    updateSprintStatus(retroKey, 'done', root);\n91\t  } catch (err: unknown) {\n92\t    const message = err instanceof Error ? err.message : String(err);\n93\t    warn(`Failed to update sprint status: ${message}`);\n94\t  }\n95\t\n96\t  if (isJson) {\n97\t    jsonOutput({ status: 'ok', epic: epicNum, retroFile: join(STORY_DIR, retroFile) });\n98\t  } else {\n99\t    ok(`Epic ${epicNum} retrospective: marked done`);\n100\t  }\n101\t}\n102\t\n103\t/**\n104\t * Verifies a story via the full verification pipeline (existing behavior).\n105\t */\n106\tfunction verifyStory(storyId: string, isJson: boolean, root: string): void {\n107\t  // 0. Validate story ID to prevent path traversal\n108\t  if (!isValidStoryId(storyId)) {\n109\t    fail(`Invalid story ID: ${storyId}. Story IDs must contain only alphanumeric characters, hyphens, and underscores.`, { json: isJson });\n110\t    process.exitCode = 1;\n111\t    return;\n112\t  }\n113\t\n114\t  // 0b. README.md gate — without docs, verification is meaningless\n115\t  const readmePath = join(root, 'README.md');\n116\t  if (!existsSync(readmePath)) {\n117\t    if (isJson) {\n118\t      jsonOutput({ status: 'fail', message: 'No README.md found — verification requires user documentation' });\n119\t    } else {\n120\t      fail('No README.md found — verification requires user documentation');\n121\t    }\n122\t    process.exitCode = 1;\n123\t    return;\n124\t  }\n125\t\n126\t  // 1. Resolve story file path\n127\t  const storyFilePath = join(root, STORY_DIR, `${storyId}.md`);\n128\t  if (!existsSync(storyFilePath)) {\n129\t    fail(`Story file not found: ${storyFilePath}`, { json: isJson });\n130\t    process.exitCode = 1;\n131\t    return;\n132\t  }\n133\t\n134\t  // 2. Check preconditions\n135\t  let preconditions;\n136\t  try {\n137\t    preconditions = checkPreconditions(root, storyId);\n138\t  } catch (err: unknown) {\n139\t    const message = err instanceof Error ? err.message : String(err);\n140\t    fail(`Precondition check failed: ${message}`, { json: isJson });\n141\t    process.exitCode = 1;\n142\t    return;\n143\t  }\n144\t\n145\t  if (!preconditions.passed) {\n146\t    if (isJson) {\n147\t      jsonOutput({\n148\t        status: 'fail',\n149\t        message: 'Preconditions not met',\n150\t        failures: preconditions.failures,\n151\t      });\n152\t    } else {\n153\t      fail('Preconditions not met:');\n154\t      for (const f of preconditions.failures) {\n155\t        info(`  - ${f}`);\n156\t      }\n157\t    }\n158\t    process.exitCode = 1;\n159\t    return;\n160\t  }\n161\t\n162\t  // 3. Parse story ACs\n163\t  let acs;\n164\t  try {\n165\t    acs = parseStoryACs(storyFilePath);\n166\t  } catch (err: unknown) {\n167\t    const message = err instanceof Error ? err.message : String(err);\n168\t    fail(`Failed to parse story file: ${message}`, { json: isJson });\n169\t    process.exitCode = 1;\n170\t    return;\n171\t  }\n172\t\n173\t  // 4. Extract story title from file\n174\t  const storyTitle = extractStoryTitle(storyFilePath);\n175\t\n176\t  // 5. Create proof document skeleton (only if one doesn't already exist)\n177\t  const expectedProofPath = join(root, 'verification', `${storyId}-proof.md`);\n178\t  const proofPath = existsSync(expectedProofPath)\n179\t    ? expectedProofPath\n180\t    : createProofDocument(storyId, storyTitle, acs, root);\n181\t\n182\t  // 6. Check proof quality — reject if any ACs are PENDING\n183\t  const proofQuality = validateProofQuality(proofPath);\n184\t  if (!proofQuality.passed) {\n185\t    if (isJson) {\n186\t      jsonOutput({\n187\t        status: 'fail',\n188\t        message: `Proof quality check failed: ${proofQuality.verified}/${proofQuality.total} ACs verified`,\n189\t        proofQuality: { verified: proofQuality.verified, pending: proofQuality.pending, escalated: proofQuality.escalated, total: proofQuality.total },\n190\t      });\n191\t    } else {\n192\t      fail(`Proof quality check failed: ${proofQuality.verified}/${proofQuality.total} ACs verified`);\n193\t    }\n194\t    process.exitCode = 1;\n195\t    return;\n196\t  }\n197\t\n198\t  // 6b. Warn about escalated ACs (passed but some ACs are integration-required)\n199\t  if (proofQuality.escalated > 0) {\n200\t    warn(`Story ${storyId} has ${proofQuality.escalated} ACs requiring integration verification`);\n201\t    info('Run these ACs manually or in a dedicated verification session');\n202\t  }\n203\t\n204\t  // 7. Run showboat verify — proof quality passed so we know there's real content\n205\t  let showboatStatus: 'pass' | 'fail' | 'skipped' = 'skipped';\n206\t  const showboatResult = runShowboatVerify(proofPath);\n207\t  if (showboatResult.output === 'showboat not available') {\n208\t    showboatStatus = 'skipped';\n209\t    warn('Showboat not installed — skipping re-verification');\n210\t  } else {\n211\t    showboatStatus = showboatResult.passed ? 'pass' : 'fail';\n212\t    if (!showboatResult.passed) {\n213\t      if (isJson) {\n214\t        jsonOutput({\n215\t          status: 'fail',\n216\t          message: `Showboat verify failed: ${showboatResult.output}`,\n217\t          proofQuality: { verified: proofQuality.verified, pending: proofQuality.pending, escalated: proofQuality.escalated, total: proofQuality.total },\n218\t        });\n219\t      } else {\n220\t        fail(`Showboat verify failed: ${showboatResult.output}`);\n221\t      }\n222\t      process.exitCode = 1;\n223\t      return;\n224\t    }\n225\t  }\n226\t\n227\t  // 8. Parse observability gaps from proof (Story 2.1)\n228\t  let observabilityGapCount = 0;\n229\t  let runtimeCoveragePercent = 0;\n230\t  try {\n231\t    const proofContent = readFileSync(proofPath, 'utf-8');\n232\t    const gapResult = parseObservabilityGaps(proofContent);\n233\t    observabilityGapCount = gapResult.gapCount;\n234\t    runtimeCoveragePercent =\n235\t      gapResult.totalACs === 0\n236\t        ? 0\n237\t        : (gapResult.coveredCount / gapResult.totalACs) * 100;\n238\t  } catch {\n239\t    // IGNORE: proof file may not be readable, proceed with defaults\n240\t  }\n241\t\n242\t  // 9. Build result\n243\t  const result: VerifyResult = {\n244\t    storyId,\n245\t    success: true,\n246\t    totalACs: proofQuality.total,\n247\t    verifiedCount: proofQuality.verified,\n248\t    failedCount: proofQuality.pending,\n249\t    escalatedCount: proofQuality.escalated,\n250\t    proofPath: `verification/${storyId}-proof.md`,\n251\t    showboatVerifyStatus: showboatStatus,\n252\t    observabilityGapCount,\n253\t    runtimeCoveragePercent,\n254\t    perAC: acs.map(ac => ({\n255\t      id: ac.id,\n256\t      description: ac.description,\n257\t      verified: true,\n258\t      evidencePaths: [],\n259\t    })),\n260\t  };\n261\t\n262\t  // 10. Update state\n263\t  try {\n264\t    updateVerificationState(storyId, result, root);\n265\t  } catch (err: unknown) {\n266\t    const message = err instanceof Error ? err.message : String(err);\n267\t    warn(`Failed to update state: ${message}`);\n268\t  }\n269\t\n270\t  // 11. Close beads issue\n271\t  try {\n272\t    closeBeadsIssue(storyId, root);\n273\t  } catch (err: unknown) {\n274\t    const message = err instanceof Error ? err.message : String(err);\n275\t    warn(`Failed to close beads issue: ${message}`);\n276\t  }\n277\t\n278\t  // 12. Complete exec-plan\n279\t  try {\n280\t    const completedPath = completeExecPlan(storyId, root);\n281\t    if (completedPath) {\n282\t      if (!isJson) {\n283\t        ok(`Exec-plan moved to completed: ${completedPath}`);\n284\t      }\n285\t    } else {\n286\t      if (!isJson) {\n287\t        warn(`No exec-plan found for story: ${storyId}`);\n288\t      }\n289\t    }\n290\t  } catch (err: unknown) {\n291\t    const message = err instanceof Error ? err.message : String(err);\n292\t    warn(`Failed to complete exec-plan: ${message}`);\n293\t  }\n294\t\n295\t  // 13. Output result\n296\t  if (isJson) {\n297\t    jsonOutput({\n298\t      ...(result as unknown as Record<string, unknown>),\n299\t      proofQuality: { verified: proofQuality.verified, pending: proofQuality.pending, escalated: proofQuality.escalated, total: proofQuality.total },\n300\t    });\n301\t  } else {\n302\t    ok(`Story ${storyId}: verified — proof at verification/${storyId}-proof.md`);\n303\t  }\n304\t}\n305\t\n306\tfunction extractStoryTitle(filePath: string): string {\n307\t  try {\n308\t    const content = readFileSync(filePath, 'utf-8');\n309\t    const match = /^#\\s+(.+)$/m.exec(content);\n310\t    return match ? match[1] : 'Unknown Story';\n311\t  } catch {\n312\t    // IGNORE: story file may not be readable\n313\t    return 'Unknown Story';\n314\t  }\n315\t}\n316\t"}]},"parent_tool_use_id":"toolu_01LDu7UrRP4AbsbSXc1UMj3o","session_id":"cb820906-0735-4f53-a851-3960824caad6","uuid":"d407406a-4536-418a-b26c-62f0463792b5","timestamp":"2026-04-03T23:08:16.765Z"}
