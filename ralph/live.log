n   261→  });\n   262→\n   263→  it('gets nested value', () => {\n   264→    expect(getNestedValue({ a: { b: { c: 42 } } }, 'a.b.c')).toBe(42);\n   265→  });\n   266→\n   267→  it('returns undefined for missing key', () => {\n   268→    expect(getNestedValue({ a: 1 }, 'b')).toBeUndefined();\n   269→  });\n   270→\n   271→  it('returns undefined for path through non-object', () => {\n   272→    expect(getNestedValue({ a: 'string' }, 'a.b')).toBeUndefined();\n   273→  });\n   274→\n   275→  it('returns undefined for path through null', () => {\n   276→    expect(getNestedValue({ a: null }, 'a.b')).toBeUndefined();\n   277→  });\n   278→\n   279→  it('rejects __proto__ key path', () => {\n   280→    expect(() => getNestedValue({ a: 1 }, '__proto__.polluted')).toThrow('not allowed');\n   281→  });\n   282→\n   283→  it('rejects constructor key path', () => {\n   284→    expect(() => getNestedValue({ a: 1 }, 'constructor.prototype')).toThrow('not allowed');\n   285→  });\n   286→\n   287→  it('rejects prototype key path', () => {\n   288→    expect(() => getNestedValue({ a: 1 }, 'a.prototype')).toThrow('not allowed');\n   289→  });\n   290→});\n   291→\n   292→describe('setNestedValue', () => {\n   293→  it('sets top-level value', () => {\n   294→    const obj: Record<string, unknown> = { a: 1 };\n   295→    setNestedValue(obj, 'a', 2);\n   296→    expect(obj.a).toBe(2);\n   297→  });\n   298→\n   299→  it('sets nested value', () => {\n   300→    const obj: Record<string, unknown> = { a: { b: 1 } };\n   301→    setNestedValue(obj, 'a.b', 42);\n   302→    expect((obj.a as Record<string, unknown>).b).toBe(42);\n   303→  });\n   304→\n   305→  it('creates intermediate objects for missing path', () => {\n   306→    const obj: Record<string, unknown> = {};\n   307→    setNestedValue(obj, 'a.b.c', 'value');\n   308→    expect((((obj.a as Record<string, unknown>).b) as Record<string, unknown>).c).toBe('value');\n   309→  });\n   310→\n   311→  it('creates intermediate objects when path goes through null', () => {\n   312→    const obj: Record<string, unknown> = { a: null };\n   313→    setNestedValue(obj, 'a.b', 'value');\n   314→    expect((obj.a as Record<string, unknown>).b).toBe('value');\n   315→  });\n   316→\n   317→  it('rejects __proto__ key path', () => {\n   318→    const obj: Record<string, unknown> = {};\n   319→    expect(() => setNestedValue(obj, '__proto__.polluted', true)).toThrow('not allowed');\n   320→  });\n   321→\n   322→  it('rejects constructor key path', () => {\n   323→    const obj: Record<string, unknown> = {};\n   324→    expect(() => setNestedValue(obj, 'constructor.prototype', true)).toThrow('not allowed');\n   325→  });\n   326→});\n   327→\n   328→describe('parseValue', () => {\n   329→  it('parses \"true\" as boolean', () => {\n   330→    expect(parseValue('true')).toBe(true);\n   331→  });\n   332→\n   333→  it('parses \"false\" as boolean', () => {\n   334→    expect(parseValue('false')).toBe(false);\n   335→  });\n   336→\n   337→  it('parses \"null\" as null', () => {\n   338→    expect(parseValue('null')).toBeNull();\n   339→  });\n   340→\n   341→  it('parses numbers', () => {\n   342→    expect(parseValue('42')).toBe(42);\n   343→    expect(parseValue('3.14')).toBe(3.14);\n   344→  });\n   345→\n   346→  it('keeps strings as strings', () => {\n   347→    expect(parseValue('hello')).toBe('hello');\n   348→  });\n   349→});\n   350→"}]},"parent_tool_use_id":"toolu_01BsKgFqrbnadEhsJTw9WBFH","session_id":"6b184f1a-3a3f-4307-8da0-d8cf52066851","uuid":"113fcc5e-bffa-456b-907c-da2d61a34386","timestamp":"2026-03-23T05:19:46.716Z"}
