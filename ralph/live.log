ect(classifyTier('Given a simple check, Then it passes')).toBe('test-provable');\n   489→  });\n   490→\n   491→  it('returns test-provable for empty string', () => {\n   492→    expect(classifyTier('')).toBe('test-provable');\n   493→  });\n   494→\n   495→  it('is case insensitive', () => {\n   496→    expect(classifyTier('Given the DOCKER CONTAINER starts')).toBe('environment-provable');\n   497→    expect(classifyTier('Given HTTP server responds')).toBe('runtime-provable');\n   498→    expect(classifyTier('Given PHYSICAL HARDWARE is needed')).toBe('escalate');\n   499→  });\n   500→\n   501→  it('respects priority order: escalate > environment > runtime > test', () => {\n   502→    // Description with both escalate and environment keywords — escalate wins\n   503→    expect(classifyTier('physical hardware with Docker container')).toBe('escalate');\n   504→    // Description with both environment and runtime keywords — environment wins\n   505→    expect(classifyTier('Docker container with HTTP server')).toBe('environment-provable');\n   506→  });\n   507→\n   508→  it('matches multiple test-provable keywords', () => {\n   509→    expect(classifyTier('Given the interface is exported from config')).toBe('test-provable');\n   510→    expect(classifyTier('Given test passes with full coverage')).toBe('test-provable');\n   511→    expect(classifyTier('Given the refactor is complete and documentation updated')).toBe('test-provable');\n   512→  });\n   513→\n   514→  it('matches multiple runtime-provable keywords', () => {\n   515→    expect(classifyTier('Given the server output shows the exit code')).toBe('runtime-provable');\n   516→    expect(classifyTier('Given the binary runs and produces correct output')).toBe('runtime-provable');\n   517→  });\n   518→\n   519→  it('matches multiple environment-provable keywords', () => {\n   520→    expect(classifyTier('Given telemetry flows to the observability stack')).toBe('environment-provable');\n   521→    expect(classifyTier('Given the distributed queue processes messages end-to-end')).toBe('environment-provable');\n   522→  });\n   523→\n   524→  it('matches multiple escalate keywords', () => {\n   525→    expect(classifyTier('Given GPU rendering with human visual confirmation')).toBe('escalate');\n   526→    expect(classifyTier('Given manual inspection of paid service output')).toBe('escalate');\n   527→  });\n   528→});\n   529→\n   530→// ─── classifyStrategy ──────────────────────────────────────────────────────\n   531→\n   532→describe('classifyStrategy', () => {\n   533→  it('returns docker as the default for all normal ACs', () => {\n   534→    expect(classifyStrategy('Given the user runs codeharness status, Then output shows version')).toBe('docker');\n   535→  });\n   536→\n   537→  it('returns docker for Agent tool ACs', () => {\n   538→    expect(classifyStrategy('invokes /create-story via Agent tool')).toBe('docker');\n   539→  });\n   540→\n   541→  it('returns docker for workflow ACs', () => {\n   542→    expect(classifyStrategy('runs the sprint planning workflow')).toBe('docker');\n   543→  });\n   544→\n   545→  it('returns docker for integration keywords', () => {\n   546→    expect(classifyStrategy('requires integration test with external system')).toBe('docker');\n   547→  });\n   548→\n   549→  it('returns docker for CLI ACs (safer than cli-direct)', () => {\n   550→    expect(classifyStrategy('runs npm test and checks coverage')).toBe('docker');\n   551→  });\n   552→\n   553→  it('returns escalate for physical hardware ACs', () => {\n   554→    expect(classifyStrategy('requires physical hardware testing on device')).toBe('escalate');\n   555→  });\n   556→\n   557→  it('returns escalate for manual human review ACs', () => {\n   558→    expect(classifyStrategy('needs manual human visual inspection')).toBe('escalate');\n   559→  });\n   560→\n   561→  it('includes strategy in parsed ACs', () => {\n   562→    const storyPath = writeStoryFile('strategy-test.md', 