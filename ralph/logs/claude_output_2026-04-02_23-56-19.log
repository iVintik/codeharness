{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01FANmkjA4gtWDZ4pgv5XWoC","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_017MCkG1AWHU45NxqgCH1ftr","name":"Write","input":{"file_path":"/Users/ivintik/dev/personal/codeharness/src/lib/session-manager.ts","content":"import type { WorkflowState, TaskCheckpoint } from './workflow-state.js';\n\n// --- Types ---\n\n/** Session boundary mode as defined in workflow YAML schema. */\nexport type SessionBoundary = 'fresh' | 'continue';\n\n/** Key that uniquely identifies a task+story combination for session lookup. */\nexport interface SessionLookupKey {\n  taskName: string;\n  storyKey: string;\n}\n\n// --- Functions ---\n\n/**\n * Resolve the session ID to use for a dispatch call.\n *\n * - `fresh`: always returns undefined (new session).\n * - `continue`: returns the most recent session ID for the task+story pair,\n *    or undefined if none exists (first invocation falls back to fresh).\n *\n * Does NOT cache — always reads from the supplied WorkflowState for crash-recovery safety.\n */\nexport function resolveSessionId(\n  boundary: SessionBoundary,\n  key: SessionLookupKey,\n  state: WorkflowState,\n): string | undefined {\n  if (boundary === 'fresh') {\n    return undefined;\n  }\n\n  // boundary === 'continue'\n  return getLastSessionId(state, key.taskName, key.storyKey);\n}\n\n/**\n * Record a session ID on a new or existing TaskCheckpoint in the workflow state.\n *\n * Returns a **new** WorkflowState (does not mutate the input).\n *\n * Appends a new checkpoint entry with the given session ID. The workflow engine\n * is expected to populate `completed_at` and other fields; this function only\n * ensures `session_id`, `task_name`, and `story_key` are set.\n */\nexport function recordSessionId(\n  key: SessionLookupKey,\n  sessionId: string,\n  state: WorkflowState,\n): WorkflowState {\n  const checkpoint: TaskCheckpoint = {\n    task_name: key.taskName,\n    story_key: key.storyKey,\n    completed_at: new Date().toISOString(),\n    session_id: sessionId,\n  };\n\n  return {\n    ...state,\n    tasks_completed: [...state.tasks_completed, checkpoint],\n  };\n}\n\n/**\n * Find the most recent session ID for a given task+story pair.\n *\n * Searches `tasks_completed` in reverse order so the most recent checkpoint\n * (including from loop iterations) is found first.\n *\n * Returns undefined when no matching checkpoint exists.\n */\nexport function getLastSessionId(\n  state: WorkflowState,\n  taskName: string,\n  storyKey: string,\n): string | undefined {\n  const tasks = state.tasks_completed;\n\n  for (let i = tasks.length - 1; i >= 0; i--) {\n    const cp = tasks[i];\n    if (cp.task_name === taskName && cp.story_key === storyKey && cp.session_id) {\n      return cp.session_id;\n    }\n  }\n\n  return undefined;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":445,"cache_read_input_tokens":40081,"cache_creation":{"ephemeral_5m_input_tokens":445,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_012UMvMRUqWzymCN6PtzoXhM","session_id":"45fbbef5-e9ca-4512-91b9-2760b179ad44","uuid":"823a68bf-f43d-4eb3-a57a-88855b55693a"}
