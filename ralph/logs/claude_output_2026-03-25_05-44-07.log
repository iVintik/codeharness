{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AkrbNR2J8o5kwcYgstmdD4","type":"tool_result","content":"     1→/**\n     2→ * Template migration tests — verify that static template files produce\n     3→ * identical output to the old TypeScript string literals.\n     4→ *\n     5→ * Story 15-3: Template Migration — All Templates to Static Files.\n     6→ * AC3: renderTemplateFile() returns the same content as the former inline functions.\n     7→ */\n     8→\n     9→import { describe, it, expect } from 'vitest';\n    10→import { readFileSync } from 'node:fs';\n    11→import { resolve, dirname } from 'node:path';\n    12→import { fileURLToPath } from 'node:url';\n    13→import { renderTemplate, renderTemplateFile } from '../../lib/templates.js';\n    14→\n    15→const __dirname = dirname(fileURLToPath(import.meta.url));\n    16→const packageRoot = resolve(__dirname, '..', '..', '..');\n    17→\n    18→// ─── renderTemplate() ────────────────────────────────────────────────────────\n    19→\n    20→describe('renderTemplate', () => {\n    21→  it('interpolates simple {{VAR}} placeholders', () => {\n    22→    const result = renderTemplate('Hello {{NAME}}!', { NAME: 'World' });\n    23→    expect(result).toBe('Hello World!');\n    24→  });\n    25→\n    26→  it('leaves unmatched placeholders intact', () => {\n    27→    const result = renderTemplate('{{KNOWN}} and {{UNKNOWN}}', { KNOWN: 'yes' });\n    28→    expect(result).toBe('yes and {{UNKNOWN}}');\n    29→  });\n    30→\n    31→  it('replaces multiple occurrences of same var', () => {\n    32→    const result = renderTemplate('{{X}} + {{X}}', { X: '1' });\n    33→    expect(result).toBe('1 + 1');\n    34→  });\n    35→\n    36→  it('handles empty vars object', () => {\n    37→    const result = renderTemplate('no vars {{HERE}}', {});\n    38→    expect(result).toBe('no vars {{HERE}}');\n    39→  });\n    40→});\n    41→\n    42→// ─── renderTemplateFile() ────────────────────────────────────────────────────\n    43→\n    44→describe('renderTemplateFile', () => {\n    45→  it('reads and returns a template file without interpolation', () => {\n    46→    const content = renderTemplateFile('templates/dockerfiles/Dockerfile.nodejs');\n    47→    expect(content).toContain('FROM node:22-slim');\n    48→    expect(content).toContain('npm install -g');\n    49→  });\n    50→\n    51→  it('reads and interpolates {{VAR}} placeholders from file', () => {\n    52→    const content = renderTemplateFile('templates/compose/otel-collector-remote.yaml', {\n    53→      LOGS_URL: 'http://logs.example.com',\n    54→      METRICS_URL: 'http://metrics.example.com',\n    55→      TRACES_URL: 'http://traces.example.com',\n    56→    });\n    57→    expect(content).toContain('http://logs.example.com/insert/opentelemetry');\n    58→    expect(content).toContain('http://metrics.example.com/api/v1/write');\n    59→    expect(content).toContain('http://traces.example.com');\n    60→    expect(content).not.toContain('{{LOGS_URL}}');\n    61→    expect(content).not.toContain('{{METRICS_URL}}');\n    62→    expect(content).not.toContain('{{TRACES_URL}}');\n    63→  });\n    64→\n    65→  it('throws for non-existent template file', () => {\n    66→    expect(() => renderTemplateFile('templates/does-not-exist.txt')).toThrow();\n    67→  });\n    68→});\n    69→\n    70→// ─── Dockerfile template equivalence ─────────────────────────────────────────\n    71→\n    72→describe('Dockerfile static files match old inline templates', () => {\n    73→  it('Dockerfile.nodejs matches old nodejsTemplate() output', () => {\n    74→    const content = renderTemplateFile('templates/dockerfiles/Dockerfile.nodejs');\n    75→    expect(content).toContain('FROM node:22-slim');\n    76→    expect(content).toContain('ARG TARBALL=package.tgz');\n    77→    expect(content).toContain('npm install -g');\n    78→    expect(content).toContain('USER node');\n    79→    expect(content).toContain('WORKDIR /workspace');\n    80→  });\n    81→\n    82→  it('Dockerfile.python matches old pythonTemplate() output', () => {\n    83→    const content = renderTemplateFile('templates/dockerfiles/Dockerfile.python');\n    84→    expect(content).toContain('FROM python:3.12-slim');\n    85→    expect(content).toContain('pip install');\n    86→    expect(content).toContain('pip cache purge');\n    87→    expect(content).toContain('USER nobody');\n    88→  });\n    89→\n    90→  it('Dockerfile.rust matches old rustTemplate() output', () => {\n    91→    const content = renderTemplateFile('templates/dockerfiles/Dockerfile.rust');\n    92→    expect(content).toContain('FROM rust:1.82-slim AS builder');\n    93→    expect(content).toContain('cargo build --release');\n    94→    expect(content).toContain('FROM debian:bookworm-slim');\n    95→    expect(content).toContain('COPY --from=builder');\n    96→    expect(content).toContain('USER nobody');\n    97→  });\n    98→\n    99→  it('Dockerfile.generic matches old genericTemplate() output', () => {\n   100→    const content = renderTemplateFile('templates/dockerfiles/Dockerfile.generic');\n   101→    expect(content).toContain('FROM node:22-slim');\n   102→    expect(content).toContain('bash');\n   103→    expect(content).toContain('git');\n   104→    expect(content).toContain('placeholder');\n   105→    expect(content).toContain('USER node');\n   106→  });\n   107→\n   108→  it('Dockerfile.multi-stage.tmpl has {{BUILD_STAGES}} and {{COPY_DIRECTIVES}} placeholders', () => {\n   109→    const raw = readFileSync(resolve(packageRoot, 'templates/dockerfiles/Dockerfile.multi-stage.tmpl'), 'utf-8');\n   110→    expect(raw).toContain('{{BUILD_STAGES}}');\n   111→    expect(raw).toContain('{{COPY_DIRECTIVES}}');\n   112→  });\n   113→\n   114→  it('Dockerfile.multi-stage.tmpl renders with provided build stages and copy directives', () => {\n   115→    const content = renderTemplateFile('templates/dockerfiles/Dockerfile.multi-stage.tmpl', {\n   116→