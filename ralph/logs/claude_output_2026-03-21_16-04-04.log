{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XwdtFvQnQHJJeM9kTig2fb","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→\n     3→vi.mock('node:child_process', () => ({\n     4→  execFileSync: vi.fn(),\n     5→}));\n     6→\n     7→import { execFileSync } from 'node:child_process';\n     8→import {\n     9→  checkInstalled,\n    10→  installDependency,\n    11→  installAllDependencies,\n    12→  parseVersion,\n    13→  CriticalDependencyError,\n    14→  DEPENDENCY_REGISTRY,\n    15→} from '../deps.js';\n    16→import type { DependencySpec } from '../deps.js';\n    17→\n    18→const mockExecFileSync = vi.mocked(execFileSync);\n    19→\n    20→beforeEach(() => {\n    21→  vi.restoreAllMocks();\n    22→  // Suppress console output during tests\n    23→  vi.spyOn(console, 'log').mockImplementation(() => {});\n    24→});\n    25→\n    26→describe('parseVersion', () => {\n    27→  it('extracts version from simple output', () => {\n    28→    expect(parseVersion('1.2.3')).toBe('1.2.3');\n    29→  });\n    30→\n    31→  it('extracts version from \"tool v1.2.3\" format', () => {\n    32→    expect(parseVersion('showboat v0.6.1')).toBe('0.6.1');\n    33→  });\n    34→\n    35→  it('extracts version from \"tool version 1.2.3\" format', () => {\n    36→    expect(parseVersion('bd version 2.0.0-beta.1')).toBe('2.0.0-beta.1');\n    37→  });\n    38→\n    39→  it('returns null when no version found', () => {\n    40→    expect(parseVersion('no version here')).toBeNull();\n    41→  });\n    42→\n    43→  it('returns null for empty string', () => {\n    44→    expect(parseVersion('')).toBeNull();\n    45→  });\n    46→});\n    47→\n    48→describe('checkInstalled', () => {\n    49→  const spec: DependencySpec = {\n    50→    name: 'test-tool',\n    51→    displayName: 'TestTool',\n    52→    installCommands: [{ cmd: 'pip', args: ['install', 'test-tool'] }],\n    53→    checkCommand: { cmd: 'test-tool', args: ['--version'] },\n    54→    critical: false,\n    55→  };\n    56→\n    57→  it('returns installed=true with version when command succeeds', () => {\n    58→    mockExecFileSync.mockReturnValue(Buffer.from('test-tool 1.0.0'));\n    59→    const result = checkInstalled(spec);\n    60→    expect(result.installed).toBe(true);\n    61→    expect(result.version).toBe('1.0.0');\n    62→    expect(mockExecFileSync).toHaveBeenCalledWith('test-tool', ['--version'], { stdio: 'pipe', timeout: 15_000 });\n    63→  });\n    64→\n    65→  it('returns installed=false when command fails', () => {\n    66→    mockExecFileSync.mockImplementation(() => {\n    67→      throw new Error('command not found');\n    68→    });\n    69→    const result = checkInstalled(spec);\n    70→    expect(result.installed).toBe(false);\n    71→    expect(result.version).toBeNull();\n    72→  });\n    73→\n    74→  it('returns installed=true with null version when output has no version', () => {\n    75→    mockExecFileSync.mockReturnValue(Buffer.from('some output without version'));\n    76→    const result = checkInstalled(spec);\n    77→    expect(result.installed).toBe(true);\n    78→    expect(result.version).toBeNull();\n    79→  });\n    80→});\n    81→\n    82→describe('installDependency', () => {\n    83→  const nonCriticalSpec: DependencySpec = {\n    84→    name: 'showboat',\n    85→    displayName: 'Showboat',\n    86→    installCommands: [\n    87→      { cmd: 'pip', args: ['install', 'showboat'] },\n    88→      { cmd: 'pipx', args: ['install', 'showboat'] },\n    89→    ],\n    90→    checkCommand: { cmd: 'showboat', args: ['--version'] },\n    91→    critical: false,\n    92→  };\n    93→\n    94→  it('returns already-installed when tool is already present', () => {\n    95→    mockExecFileSync.mockReturnValue(Buffer.from('showboat 0.6.1'));\n    96→    const result = installDependency(nonCriticalSpec);\n    97→    expect(result.status).toBe('already-installed');\n    98→    expect(result.version).toBe('0.6.1');\n    99→  });\n   100→\n   101→  it('installs via primary command and returns installed', () => {\n   102→    let checkCount = 0;\n   103→    mockExecFileSync.mockImplementation((cmd) => {\n   104→      const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   105→      // Version check: first fails, then succeeds\n   106→      if (cmdStr === 'showboat') {\n   107→        checkCount++;\n   108→        if (checkCount === 1) throw new Error('not found');\n   109→        return Buffer.from('showboat 0.6.1');\n   110→      }\n   111→      // Install command succeeds\n   112→      return Buffer.from('');\n   113→    });\n   114→\n   115→    const result = installDependency(nonCriticalSpec);\n   116→    expect(result.status).toBe('installed');\n   117→    expect(result.version).toBe('0.6.1');\n   118→  });\n   119→\n   120→  it('falls back to secondary command when primary fails', () => {\n   121→    let checkCount = 0;\n   122→    mockExecFileSync.mockImplementation((cmd) => {\n   123→      const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   124→      if (cmdStr === 'showboat') {\n   125→        checkCount++;\n   126→        if (checkCount === 1) throw new Error('not found');\n   127→        return Buffer.from('showboat 0.6.1');\n   128→      }\n   129→      if (cmdStr === 'pip') throw new Error('pip not found');\n   130→      // pipx install succeeds\n   131→      return Buffer.from('');\n   132→    });\n   133→\n   134→    const result = installDependency(nonCriticalSpec);\n   135→    expect(result.status).toBe('installed');\n   136→    expect(result.version).toBe('0.6.1');\n   137→  });\n   138→\n   139→  it('returns failed when all install commands fail', () => {\n   140→    mockExecFileSync.mockImplementation(() => {\n   141→      throw new Error('command failed');\n   142→    });\n   143→\n   144→    const result = installDependency(nonCriticalSpec);\n   145→    expect(result.status).toBe('failed');\n   146→    expect(result.version).toBeNull();\n   147→    expect(result.error).toContain('Install failed');\n   148→    expect(result.error).toContain('pip install showboat');\n   149→    expect(result.error).toContain('pipx install showboat');\n   150→  });\n   151→\n   152→  it('returns failed when install succeeds but post-check fails', () => {\n   153→    mockExecFileSync.mockImplementation((cmd) => {\n   154→      const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   155→      if (cmdStr === 'showboat') throw new Error('not found');\n   156→      // Install commands succeed but version check always fails\n   157→      return Buffer.from('');\n   158→    });\n   159→\n   160→    const result = installDependency(nonCriticalSpec);\n   161→    expect(result.status).toBe('failed');\n   162→  });\n   163→\n   164→  describe('semgrep entry', () => {\n   165→    // Use actual registry entry to catch regressions if the registry changes\n   166→    const semgrepSpec = DEPENDENCY_REGISTRY.find(d => d.name === 'semgrep')!;\n   167→\n   168→    it('returns already-installed when semgrep is present', () => {\n   169→      mockExecFileSync.mockReturnValue(Buffer.from('1.56.0'));\n   170→      const result = installDependency(semgrepSpec);\n   171→      expect(result.status).toBe('already-installed');\n   172→      expect(result.version).toBe('1.56.0');\n   173→    });\n   174→\n   175→    it('installs semgrep via pipx (primary) and returns installed', () => {\n   176→      let checkCount = 0;\n   177→      mockExecFileSync.mockImplementation((cmd) => {\n   178→        const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   179→        if (cmdStr === 'semgrep') {\n   180→          checkCount++;\n   181→          if (checkCount === 1) throw new Error('not found');\n   182→          return Buffer.from('1.56.0');\n   183→        }\n   184→        return Buffer.from('');\n   185→      });\n   186→\n   187→      const result = installDependency(semgrepSpec);\n   188→      expect(result.status).toBe('installed');\n   189→      expect(result.version).toBe('1.56.0');\n   190→    });\n   191→\n   192→    it('falls back to pip when pipx fails', () => {\n   193→      let checkCount = 0;\n   194→      mockExecFileSync.mockImplementation((cmd) => {\n   195→        const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   196→        if (cmdStr === 'semgrep') {\n   197→          checkCount++;\n   198→          if (checkCount === 1) throw new Error('not found');\n   199→          return Buffer.from('1.56.0');\n   200→        }\n   201→        if (cmdStr === 'pipx') throw new Error('pipx not found');\n   202→        return Buffer.from('');\n   203→      });\n   204→\n   205→      const result = installDependency(semgrepSpec);\n   206→      expect(result.status).toBe('installed');\n   207→      expect(result.version).toBe('1.56.0');\n   208→    });\n   209→\n   210→    it('returns failed when both pipx and pip fail', () => {\n   211→      mockExecFileSync.mockImplementation(() => {\n   212→        throw new Error('command failed');\n   213→      });\n   214→\n   215→      const result = installDependency(semgrepSpec);\n   216→      expect(result.status).toBe('failed');\n   217→      expect(result.error).toContain('pipx install semgrep');\n   218→      expect(result.error).toContain('pip install semgrep');\n   219→    });\n   220→  });\n   221→});\n   222→\n   223→describe('installAllDependencies', () => {\n   224→  it('installs all dependencies and returns results', () => {\n   225→    // All tools already installed\n   226→    mockExecFileSync.mockReturnValue(Buffer.from('tool 1.0.0'));\n   227→\n   228→    const results = installAllDependencies({});\n   229→    expect(results).toHaveLength(DEPENDENCY_REGISTRY.length);\n   230→    expect(results.every(r => r.status === 'already-installed')).toBe(true);\n   231→  });\n   232→\n   233→  it('does not throw when all deps fail (none are critical)', () => {\n   234→    mockExecFileSync.mockImplementation(() => {\n   235→      throw new Error('command failed');\n   236→    });\n   237→\n   238→    const results = installAllDependencies({});\n   239→    expect(results.every(r => r.status === 'failed')).toBe(true);\n   240→  });\n   241→\n   242→  it('throws CriticalDependencyError when a critical dep fails to install', () => {\n   243→    // Temporarily mutate the first registry entry to be critical\n   244→    const registry = DEPENDENCY_REGISTRY as unknown as Array<{ critical: boolean }>;\n   245→    const originalCritical = registry[0].critical;\n   246→    registry[0].critical = true;\n   247→\n   248→    try {\n   249→      // All commands fail — first dep (showboat) is now critical\n   250→      mockExecFileSync.mockImplementation(() => {\n   251→        throw new Error('command failed');\n   252→      });\n   253→\n   254→      expect(() => installAllDependencies({})).toThrow(CriticalDependencyError);\n   255→      expect(() => installAllDependencies({})).toThrow(/Showboat/);\n   256→    } finally {\n   257→      // Restore original value\n   258→      registry[0].critical = originalCritical;\n   259→    }\n   260→  });\n   261→\n   262→  it('continues when non-critical dep fails', () => {\n   263→    mockExecFileSync.mockImplementation((cmd, args) => {\n   264→      const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   265→      const argsArr = Array.isArray(args) ? args.map(String) : [];\n   266→\n   267→      // showboat check and install both fail\n   268→      if (cmdStr === 'showboat') throw new Error('not found');\n   269→      // agent-browser check and install both fail\n   270→      if (cmdStr === 'agent-browser') throw new Error('not found');\n   271→      if (cmdStr === 'npm') throw new Error('not found');\n   272→      // semgrep check and install both fail\n   273→      if (cmdStr === 'semgrep') throw new Error('not found');\n   274→      // pip/pipx for showboat/semgrep fail, for beads we don't reach (already installed)\n   275→      if ((cmdStr === 'pip' || cmdStr === 'pipx') && argsArr.some(a => a.includes('showboat') || a.includes('semgrep'))) {\n   276→        throw new Error('not found');\n   277→      }\n   278→      // beads check succeeds\n   279→      if (cmdStr === 'bd') {\n   280→        return Buffer.from('bd 1.0.0');\n   281→      }\n   282→      throw new Error('unexpected');\n   283→    });\n   284→\n   285→    // Should not throw because showboat, agent-browser, and semgrep are non-critical,\n   286→    // and beads is already installed\n   287→    const results = installAllDependencies({});\n   288→    const failed = results.filter(r => r.status === 'failed');\n   289→    expect(failed.length).toBeGreaterThanOrEqual(1);\n   290→    const beadsResult = results.find(r => r.name === 'beads');\n   291→    expect(beadsResult?.status).toBe('already-installed');\n   292→  });\n   293→\n   294→  it('prints OK messages for installed dependencies (non-json mode)', () => {\n   295→    const logSpy = vi.spyOn(console, 'log');\n   296→    mockExecFileSync.mockReturnValue(Buffer.from('tool 1.0.0'));\n   297→\n   298→    installAllDependencies({ json: false });\n   299→\n   300→    const calls = logSpy.mock.calls.map(c => c[0]);\n   301→    expect(calls.some(c => typeof c === 'string' && c.includes('[OK]'))).toBe(true);\n   302→  });\n   303→\n   304→  it('prints installed (not already-installed) message for freshly installed deps', () => {\n   305→    const logSpy = vi.spyOn(console, 'log');\n   306→    let showboatCheckCount = 0;\n   307→    mockExecFileSync.mockImplementation((cmd) => {\n   308→      const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   309→      // For showboat: first version check fails, install succeeds, post-check succeeds\n   310→      if (cmdStr === 'showboat') {\n   311→        showboatCheckCount++;\n   312→        if (showboatCheckCount === 1) throw new Error('not found');\n   313→        return Buffer.from('showboat 0.6.1');\n   314→      }\n   315→      if (cmdStr === 'pip') return Buffer.from('');\n   316→      // Everything else: already installed\n   317→      return Buffer.from('tool 1.0.0');\n   318→    });\n   319→\n   320→    const results = installAllDependencies({ json: false });\n   321→    const showboat = results.find(r => r.name === 'showboat');\n   322→    expect(showboat?.status).toBe('installed');\n   323→    expect(showboat?.version).toBe('0.6.1');\n   324→\n   325→    const calls = logSpy.mock.calls.map(c => String(c[0]));\n   326→    expect(calls.some(c => c.includes('Showboat: installed (v0.6.1)'))).toBe(true);\n   327→  });\n   328→\n   329→  it('prints OK without version when version is null (already-installed)', () => {\n   330→    const logSpy = vi.spyOn(console, 'log');\n   331→    // Return output that has no parseable version\n   332→    mockExecFileSync.mockReturnValue(Buffer.from('some output without version'));\n   333→\n   334→    installAllDependencies({ json: false });\n   335→\n   336→    const calls = logSpy.mock.calls.map(c => String(c[0]));\n   337→    // Should print \"already installed\" without \"(vX.Y.Z)\" suffix\n   338→    expect(calls.some(c => c.includes('already installed') && !c.includes('(v'))).toBe(true);\n   339→  });\n   340→\n   341→  it('prints OK without version when version is null (freshly installed)', () => {\n   342→    const logSpy = vi.spyOn(console, 'log');\n   343→    let showboatCheckCount = 0;\n   344→    mockExecFileSync.mockImplementation((cmd) => {\n   345→      const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   346→      // showboat: first check fails, install succeeds, post-check returns no-version output\n   347→      if (cmdStr === 'showboat') {\n   348→        showboatCheckCount++;\n   349→        if (showboatCheckCount === 1) throw new Error('not found');\n   350→        return Buffer.from('ready');\n   351→      }\n   352→      if (cmdStr === 'pip') return Buffer.from('');\n   353→      // Everything else: already installed with version\n   354→      return Buffer.from('tool 1.0.0');\n   355→    });\n   356→\n   357→    const results = installAllDependencies({ json: false });\n   358→    const showboat = results.find(r => r.name === 'showboat');\n   359→    expect(showboat?.status).toBe('installed');\n   360→    expect(showboat?.version).toBeNull();\n   361→\n   362→    const calls = logSpy.mock.calls.map(c => String(c[0]));\n   363→    // Should have \"Showboat: installed\" without \"(vX.Y.Z)\"\n   364→    expect(calls.some(c => c.includes('Showboat: installed') && !c.includes('(v'))).toBe(true);\n   365→  });\n   366→\n   367→  it('does not print messages in json mode', () => {\n   368→    const logSpy = vi.spyOn(console, 'log');\n   369→    mockExecFileSync.mockReturnValue(Buffer.from('tool 1.0.0'));\n   370→\n   371→    installAllDependencies({ json: true });\n   372→\n   373→    const calls = logSpy.mock.calls.map(c => c[0]);\n   374→    expect(calls.some(c => typeof c === 'string' && c.includes('[OK]'))).toBe(false);\n   375→  });\n   376→\n   377→  it('prints FAIL and info messages for non-critical failures', () => {\n   378→    const logSpy = vi.spyOn(console, 'log');\n   379→\n   380→    mockExecFileSync.mockImplementation((cmd, args) => {\n   381→      const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   382→      const argsArr = Array.isArray(args) ? args.map(String) : [];\n   383→      // showboat fails\n   384→      if (cmdStr === 'showboat') throw new Error('not found');\n   385→      if ((cmdStr === 'pip' || cmdStr === 'pipx') && argsArr.some(a => a.includes('showboat'))) throw new Error('not found');\n   386→      // agent-browser fails\n   387→      if (cmdStr === 'agent-browser' || cmdStr === 'npm') throw new Error('not found');\n   388→      // semgrep fails\n   389→      if (cmdStr === 'semgrep') throw new Error('not found');\n   390→      if ((cmdStr === 'pip' || cmdStr === 'pipx') && argsArr.some(a => a.includes('semgrep'))) throw new Error('not found');\n   391→      // beads succeeds\n   392→      if (cmdStr === 'bd') return Buffer.from('bd 1.0.0');\n   393→      throw new Error('unexpected');\n   394→    });\n   395→\n   396→    installAllDependencies({});\n   397→\n   398→    const calls = logSpy.mock.calls.map(c => String(c[0]));\n   399→    expect(calls.some(c => c.includes('[FAIL]'))).toBe(true);\n   400→    expect(calls.some(c => c.includes('optional'))).toBe(true);\n   401→  });\n   402→});\n   403→\n   404→describe('DEPENDENCY_REGISTRY', () => {\n   405→  it('contains showboat, agent-browser, beads, and semgrep', () => {\n   406→    const names = DEPENDENCY_REGISTRY.map(d => d.name);\n   407→    expect(names).toContain('showboat');\n   408→    expect(names).toContain('agent-browser');\n   409→    expect(names).toContain('beads');\n   410→    expect(names).toContain('semgrep');\n   411→  });\n   412→\n   413→  it('has exactly 4 entries', () => {\n   414→    expect(DEPENDENCY_REGISTRY).toHaveLength(4);\n   415→  });\n   416→\n   417→  it('beads is not critical', () => {\n   418→    const beads = DEPENDENCY_REGISTRY.find(d => d.name === 'beads');\n   419→    expect(beads?.critical).toBe(false);\n   420→  });\n   421→\n   422→  it('showboat and agent-browser are not critical', () => {\n   423→    const showboat = DEPENDENCY_REGISTRY.find(d => d.name === 'showboat');\n   424→    const agentBrowser = DEPENDENCY_REGISTRY.find(d => d.name === 'agent-browser');\n   425→    expect(showboat?.critical).toBe(false);\n   426→    expect(agentBrowser?.critical).toBe(false);\n   427→  });\n   428→\n   429→  it('showboat has pip and pipx fallback', () => {\n   430→    const showboat = DEPENDENCY_REGISTRY.find(d => d.name === 'showboat');\n   431→    expect(showboat?.installCommands).toHaveLength(2);\n   432→    expect(showboat?.installCommands[0].cmd).toBe('pip');\n   433→    expect(showboat?.installCommands[1].cmd).toBe('pipx');\n   434→  });\n   435→\n   436→  it('agent-browser has single npm install command', () => {\n   437→    const ab = DEPENDENCY_REGISTRY.find(d => d.name === 'agent-browser');\n   438→    expect(ab?.installCommands).toHaveLength(1);\n   439→    expect(ab?.installCommands[0].cmd).toBe('npm');\n   440→  });\n   441→\n   442→  it('beads has pip and pipx fallback', () => {\n   443→    const beads = DEPENDENCY_REGISTRY.find(d => d.name === 'beads');\n   444→    expect(beads?.installCommands).toHaveLength(2);\n   445→    expect(beads?.installCommands[0].cmd).toBe('pip');\n   446→    expect(beads?.installCommands[1].cmd).toBe('pipx');\n   447→  });\n   448→\n   449→  it('semgrep is not critical', () => {\n   450→    const semgrep = DEPENDENCY_REGISTRY.find(d => d.name === 'semgrep');\n   451→    expect(semgrep?.critical).toBe(false);\n   452→  });\n   453→\n   454→  it('semgrep has pipx as primary and pip as fallback', () => {\n   455→    const semgrep = DEPENDENCY_REGISTRY.find(d => d.name === 'semgrep');\n   456→    expect(semgrep?.installCommands).toHaveLength(2);\n   457→    expect(semgrep?.installCommands[0].cmd).toBe('pipx');\n   458→    expect(semgrep?.installCommands[1].cmd).toBe('pip');\n   459→  });\n   460→\n   461→  it('semgrep checks version via semgrep --version', () => {\n   462→    const semgrep = DEPENDENCY_REGISTRY.find(d => d.name === 'semgrep');\n   463→    expect(semgrep?.checkCommand.cmd).toBe('semgrep');\n   464→    expect(semgrep?.checkCommand.args).toEqual(['--version']);\n   465→  });\n   466→});\n   467→\n   468→describe('CriticalDependencyError', () => {\n   469→  it('contains dependency name and reason', () => {\n   470→    const err = new CriticalDependencyError('beads', 'not found');\n   471→    expect(err.dependencyName).toBe('beads');\n   472→    expect(err.reason).toBe('not found');\n   473→    expect(err.name).toBe('CriticalDependencyError');\n   474→    expect(err.message).toContain('beads');\n   475→  });\n   476→});\n   477→"}]},"parent_tool_use_id":"toolu_0139VAm2DeWA6MUvt71tK69y","session_id":"