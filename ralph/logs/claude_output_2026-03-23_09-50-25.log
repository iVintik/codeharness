al: 100,\n   834→      delta: null,\n   835→      baseline: 100,\n   836→    };\n   837→\n   838→    printCoverageOutput(result, evaluation);\n   839→\n   840→    expect(consoleSpy).toHaveBeenCalledWith('[OK] Tests passed: 10 passed');\n   841→    expect(consoleSpy).toHaveBeenCalledWith('[OK] Coverage: 100%');\n   842→    consoleSpy.mockRestore();\n   843→  });\n   844→\n   845→  it('calls console.log with failure output for failing tests', () => {\n   846→    const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n   847→\n   848→    const result: CoverageResult = {\n   849→      success: true,\n   850→      testsPassed: false,\n   851→      passCount: 8,\n   852→      failCount: 2,\n   853→      coveragePercent: 85,\n   854→      rawOutput: '',\n   855→    };\n   856→    const evaluation: CoverageEvaluation = {\n   857→      met: false,\n   858→      target: 100,\n   859→      actual: 85,\n   860→      delta: -5,\n   861→      baseline: 90,\n   862→    };\n   863→\n   864→    printCoverageOutput(result, evaluation);\n   865→\n   866→    expect(consoleSpy).toHaveBeenCalledWith('[FAIL] Tests failed: 8 passed, 2 failed');\n   867→    expect(consoleSpy).toHaveBeenCalledWith('[FAIL] Coverage: 85% (target: 100%)');\n   868→    expect(consoleSpy).toHaveBeenCalledWith('[INFO] Coverage delta: -5% (90% -> 85%)');\n   869→    consoleSpy.mockRestore();\n   870→  });\n   871→});\n   872→\n   873→// ─── checkPerFileCoverage ───────────────────────────────────────────────────\n   874→\n   875→describe('checkPerFileCoverage', () => {\n   876→  it('returns no violations when all files above floor', () => {\n   877→    const coverageDir = join(testDir, 'coverage');\n   878→    mkdirSync(coverageDir, { recursive: true });\n   879→    writeFileSync(join(coverageDir, 'coverage-summary.json'), JSON.stringify({\n   880→      total: { statements: { pct: 95 } },\n   881→      '/project/src/good.ts': { statements: { pct: 95 }, branches: { pct: 90 }, functions: { pct: 100 }, lines: { pct: 95 } },\n   882→      '/project/src/also-good.ts': { statements: { pct: 88 }, branches: { pct: 82 }, functions: { pct: 100 }, lines: { pct: 88 } },\n   883→    }));\n   884→\n   885→    const result = checkPerFileCoverage(80, testDir);\n   886→    expect(result.violations).toHaveLength(0);\n   887→    expect(result.totalFiles).toBe(2);\n   888→    expect(result.floor).toBe(80);\n   889→  });\n   890→\n   891→  it('returns violations for files below floor', () => {\n   892→    const coverageDir = join(testDir, 'coverage');\n   893→    mkdirSync(coverageDir, { recursive: true });\n   894→    writeFileSync(join(coverageDir, 'coverage-summary.json'), JSON.stringify({\n   895→      total: { statements: { pct: 85 } },\n   896→      [join(testDir, 'src', 'good.ts')]: { statements: { pct: 100 }, branches: { pct: 100 }, functions: { pct: 100 }, lines: { pct: 100 } },\n   897→      [join(testDir, 'src', 'bad.ts')]: { statements: { pct: 30 }, branches: { pct: 20 }, functions: { pct: 50 }, lines: { pct: 30 } },\n   898→      [join(testDir, 'src', 'also-bad.ts')]: { statements: { pct: 60 }, branches: { pct: 55 }, functions: { pct: 75 }, lines: { pct: 60 } },\n   899→    }));\n   900→\n   901→    const result = checkPerFileCoverage(80, testDir);\n   902→    expect(result.violations).toHaveLength(2);\n   903→    expect(result.totalFiles).toBe(3);\n   904→    // Sorted worst first\n   905→    expect(result.violations[0].statements).toBe(30);\n   906→    expect(result.violations[0].file).toBe(join('src', 'bad.ts'));\n   907→    expect(result.violations[1].statements).toBe(60);\n   908→  });\n   909→\n   910→  it('returns empty when no coverage report found', () => {\n   911→    const result = checkPerFileCoverage(80, testDir);\n   912→    expect(result.violations).toHaveLength(0);\n   913→    expect(result.totalFiles).toBe(0);\n   914→  });\n   915→\n   916→  it('finds coverage-summary.json in src/coverage/ fallback', () => {\n   917→    const coverageDir = join(testDir, 'src', 'coverage');\n   918→    mkdirSync(coverageDir, { recursive: true });\n   919→    writeFileSync(join(coverageDir, 'coverage-summary.json'), JSON.stringify({\n   920→      total: { statements: { pct: 90 } },\n   921→      '/project/src/file.ts': { statements: { pct: 70 }, branches: { pct: 60 }, functions: { pct: 80 }, lines: { pct: 70 } },\n   922→    }));\n   923→\n   924→    const result = checkPerFileCoverage(80, testDir);\n   925→    expect(result.violations).toHaveLength(1);\n   926→    expect(result.violations[0].statements).toBe(70);\n   927→  });\n   928→\n   929→  it('handles malformed coverage-summary.json gracefully', () => {\n   930→    const coverageDir = join(testDir, 'coverage');\n   931→    mkdirSync(coverageDir, { recursive: true });\n   932→    writeFileSync(join(coverageDir, 'coverage-summary.json'), 'not json');\n   933→\n   934→    const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n   935→    const result = checkPerFileCoverage(80, testDir);\n   936→    expect(result.violations).toHaveLength(0);\n   937→    expect(result.totalFiles).toBe(0);\n   938→    consoleSpy.mockRestore();\n   939→  });\n   940→\n   941→  it('excludes total key from file count', () => {\n   942→    const coverageDir = join(testDir, 'coverage');\n   943→    mkdirSync(coverageDir, { recursive: true });\n   944→    writeFileSync(join(coverageDir, 'coverage-summary.json'), JSON.stringify({\n   945→      total: { statements: { pct: 100 } },\n   946→      '/project/src/only.ts': { statements: { pct: 100 }, branches: { pct: 100 }, functions: { pct: 100 }, lines: { pct: 100 } },\n   947→    }));\n   948→\n   949→    const result = checkPerFileCoverage(80, testDir);\n   950→    expect(result.totalFiles).toBe(1);\n   951→  });\n   952→});\n   953→"}]},"parent_tool_use_id":"toolu_01FMDkUeUKeSEdVYnaeX8sCM","session_id":"900ad046-8ed4-4678-b2b2-9fd66fbde286","uuid":"caff73d9-8ed5-4b50-8a36-964829033b0d","timestamp":"2026-03-23T06:02:23.391Z"}
