{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ct7UPxLtNKNkMFs4MotHT3","type":"tool_result","content":"1\timport { existsSync } from 'node:fs';\n2\timport { join } from 'node:path';\n3\timport { Command } from 'commander';\n4\timport { fail, info, ok } from '../lib/output.js';\n5\timport { isDockerAvailable } from '../lib/docker/index.js';\n6\timport { cleanupContainers } from '../modules/infra/index.js';\n7\timport { readSprintStatusFromState, reconcileState } from '../modules/sprint/index.js';\n8\timport { countStories, formatElapsed } from '../lib/run-helpers.js';\n9\timport { parseWorkflow } from '../lib/workflow-parser.js';\n10\timport { resolveAgent, compileSubagentDefinition } from '../lib/agent-resolver.js';\n11\timport { executeWorkflow } from '../lib/workflow-engine.js';\n12\timport type { EngineConfig } from '../lib/workflow-engine.js';\n13\timport type { SubagentDefinition } from '../lib/agent-resolver.js';\n14\t\n15\t/** Resolves the plugin directory path (.claude/ in project root). */\n16\texport function resolvePluginDir(): string {\n17\t  return join(process.cwd(), '.claude');\n18\t}\n19\t\n20\t// Re-export helpers that tests import from run.ts\n21\texport { countStories } from '../lib/run-helpers.js';\n22\t\n23\texport function registerRunCommand(program: Command): void {\n24\t  program\n25\t    .command('run')\n26\t    .description('Execute the autonomous coding loop')\n27\t    .option('--max-iterations <n>', 'Maximum loop iterations', '50')\n28\t    .option('--timeout <seconds>', 'Total loop timeout in seconds', '43200')\n29\t    .option('--iteration-timeout <minutes>', 'Per-iteration timeout in minutes', '30')\n30\t    .option('--quiet', 'Suppress terminal output (background mode)', false)\n31\t    .option('--calls <n>', 'Max API calls per hour', '100')\n32\t    .option('--max-story-retries <n>', 'Max retries per story before flagging', '10')\n33\t    .option('--reset', 'Clear retry counters, flagged stories, and circuit breaker before starting', false)\n34\t    .option('--resume', 'Resume from last checkpoint (engine resumes by default)', false)\n35\t    .action(async (options, cmd) => {\n36\t      const globalOpts = cmd.optsWithGlobals();\n37\t      const isJson = !!globalOpts.json;\n38\t      const outputOpts = { json: isJson };\n39\t\n40\t      // 1. Resolve plugin directory\n41\t      const pluginDir = resolvePluginDir();\n42\t      if (!existsSync(pluginDir)) {\n43\t        fail('Plugin directory not found — run codeharness init first', outputOpts);\n44\t        process.exitCode = 1;\n45\t        return;\n46\t      }\n47\t\n48\t      // 1b. Reconcile state (best-effort — failures warn but don't abort)\n49\t      const reconciliation = reconcileState();\n50\t      if (reconciliation.success && reconciliation.data.corrections.length > 0) {\n51\t        for (const correction of reconciliation.data.corrections) {\n52\t          info(`[INFO] Reconciled: ${correction}`, outputOpts);\n53\t        }\n54\t      } else if (!reconciliation.success) {\n55\t        info(`[WARN] State reconciliation failed: ${reconciliation.error}`, outputOpts);\n56\t      }\n57\t\n58\t      // 1c. Docker pre-flight: fail fast if Docker unavailable\n59\t      if (!isDockerAvailable()) {\n60\t        fail('[FAIL] Docker not available — install Docker or start the daemon', outputOpts);\n61\t        process.exitCode = 1;\n62\t        return;\n63\t      }\n64\t      // 1d. Orphan container cleanup (best-effort — failures warn but don't abort)\n65\t      const cleanup = cleanupContainers();\n66\t      if (cleanup.success && cleanup.data.containersRemoved > 0) {\n67\t        info(`[INFO] Cleaned up ${cleanup.data.containersRemoved} orphaned container(s): ${cleanup.data.names.join(', ')}`, outputOpts);\n68\t      } else if (!cleanup.success) {\n69\t        info(`[WARN] Container cleanup failed: ${cleanup.error}`, outputOpts);\n70\t      }\n71\t      // 2. Read sprint status for story count (from sprint-state.json)\n72\t      const statuses = readSprintStatusFromState();\n73\t      const counts = countStories(statuses);\n74\t\n75\t      if (counts.total === 0) {\n76\t        fail('No stories found in sprint-state.json — nothing to execute', outputOpts);\n77\t        process.exitCode = 1;\n78\t        return;\n79\t      }\n80\t\n81\t      if (counts.ready === 0) {\n82\t        fail('No stories ready for execution', outputOpts);\n83\t        process.exitCode = 1;\n84\t        return;\n85\t      }\n86\t\n87\t      info(`Starting autonomous execution — ${counts.ready} ready, ${counts.inProgress} in progress, ${counts.verified} verified, ${counts.done}/${counts.total} done`, outputOpts);\n88\t      // 3. Parse and validate numeric options\n89\t      const maxIterations = parseInt(options.maxIterations, 10);\n90\t      const timeout = parseInt(options.timeout, 10);\n91\t      const iterationTimeout = parseInt(options.iterationTimeout, 10);\n92\t      const calls = parseInt(options.calls, 10);\n93\t      const maxStoryRetries = parseInt(options.maxStoryRetries, 10);\n94\t      if (isNaN(maxIterations) || isNaN(timeout) || isNaN(iterationTimeout) || isNaN(calls) || isNaN(maxStoryRetries)) {\n95\t        fail('Invalid numeric option — --max-iterations, --timeout, --iteration-timeout, --calls, and --max-story-retries must be numbers', outputOpts);\n96\t        process.exitCode = 1;\n97\t        return;\n98\t      }\n99\t\n100\t      // 4. Parse workflow YAML\n101\t      const projectDir = process.cwd();\n102\t      const projectWorkflowPath = join(projectDir, '.codeharness', 'workflows', 'default.yaml');\n103\t      const templateWorkflowPath = join(projectDir, 'templates', 'workflows', 'default.yaml');\n104\t      const workflowPath = existsSync(projectWorkflowPath) ? projectWorkflowPath : templateWorkflowPath;\n105\t\n106\t      let parsedWorkflow;\n107\t      try {\n108\t        parsedWorkflow = parseWorkflow(workflowPath);\n109\t      } catch (err: unknown) {\n110\t        const msg = err instanceof Error ? err.message : String(err);\n111\t        fail(`Failed to parse workflow: ${msg}`, outputOpts);\n112\t        process.exitCode = 1;\n113\t        return;\n114\t      }\n115\t\n116\t      // 5. Resolve agents referenced in workflow\n117\t      const agents: Record<string, SubagentDefinition> = {};\n118\t      try {\n119\t        for (const [, task] of Object.entries(parsedWorkflow.tasks)) {\n120\t          if (!agents[task.agent]) {\n121\t            const resolved = resolveAgent(task.agent, { cwd: projectDir });\n122\t            agents[task.agent] = compileSubagentDefinition(resolved);\n123\t          }\n124\t        }\n125\t      } catch (err: unknown) {\n126\t        const msg = err instanceof Error ? err.message : String(err);\n127\t        fail(`Failed to resolve agents: ${msg}`, outputOpts);\n128\t        process.exitCode = 1;\n129\t        return;\n130\t      }\n131\t\n132\t      // 6. Build EngineConfig and execute\n133\t      const config: EngineConfig = {\n134\t        workflow: parsedWorkflow,\n135\t        agents,\n136\t        sprintStatusPath: join(projectDir, '_bmad-output', 'implementation-artifacts', 'sprint-status.yaml'),\n137\t        issuesPath: join(projectDir, '.codeharness', 'issues.yaml'),\n138\t        runId: `run-${Date.now()}`,\n139\t        projectDir,\n140\t        maxIterations,\n141\t      };\n142\t\n143\t      try {\n144\t        const result = await executeWorkflow(config);\n145\t\n146\t        if (result.success) {\n147\t          ok(`Workflow completed — ${result.storiesProcessed} stories processed, ${result.tasksCompleted} tasks completed in ${formatElapsed(result.durationMs)}`, outputOpts);\n148\t        } else {\n149\t          fail(`Workflow failed — ${result.storiesProcessed} stories processed, ${result.tasksCompleted} tasks completed, ${result.errors.length} error(s) in ${formatElapsed(result.durationMs)}`, outputOpts);\n150\t          for (const err of result.errors) {\n151\t            info(`  ${err.taskName}/${err.storyKey}: [${err.code}] ${err.message}`, outputOpts);\n152\t          }\n153\t          process.exitCode = 1;\n154\t        }\n155\t      } catch (err: unknown) {\n156\t        const msg = err instanceof Error ? err.message : String(err);\n157\t        fail(`Workflow engine error: ${msg}`, outputOpts);\n158\t        process.exitCode = 1;\n159\t      }\n160\t    });\n161\t}\n162\t"}]},"parent_tool_use_id":"toolu_01FkgyC9DWuTXJxpDeAr6BwS","session_id":"452c48b4-eed2-4c96-83e9-8c71df0bbdac","uuid":"2d9f89d7-2c83-4210-ac6b-510b14b3ae3f","timestamp":"2026-04-02T23:24:27.242Z"}
