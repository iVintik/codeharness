{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AR5bk9Sug16J78MRJuAEca","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach } from 'vitest';\n2\timport {\n3\t  registerNullTask,\n4\t  getNullTask,\n5\t  listNullTasks,\n6\t} from '../null-task-registry.js';\n7\timport type { TaskContext, NullTaskResult } from '../null-task-registry.js';\n8\t\n9\tdescribe('null-task-registry', () => {\n10\t  // Note: 'telemetry' is registered at module load time as a built-in.\n11\t\n12\t  describe('registerNullTask / getNullTask', () => {\n13\t    it('returns undefined for an unregistered handler', () => {\n14\t      expect(getNullTask('nonexistent-handler-xyz')).toBeUndefined();\n15\t    });\n16\t\n17\t    it('returns the registered handler', () => {\n18\t      const handler = async (_ctx: TaskContext): Promise<NullTaskResult> => ({\n19\t        success: true,\n20\t        output: 'test',\n21\t      });\n22\t      registerNullTask('test-handler-unique', handler);\n23\t      expect(getNullTask('test-handler-unique')).toBe(handler);\n24\t    });\n25\t\n26\t    it('overwrites a previously registered handler', () => {\n27\t      const handler1 = async () => ({ success: true });\n28\t      const handler2 = async () => ({ success: false });\n29\t      registerNullTask('overwrite-test', handler1);\n30\t      registerNullTask('overwrite-test', handler2);\n31\t      expect(getNullTask('overwrite-test')).toBe(handler2);\n32\t    });\n33\t  });\n34\t\n35\t  describe('listNullTasks', () => {\n36\t    it('includes built-in telemetry handler', () => {\n37\t      const names = listNullTasks();\n38\t      expect(names).toContain('telemetry');\n39\t    });\n40\t\n41\t    it('includes dynamically registered handlers', () => {\n42\t      registerNullTask('list-test-handler', async () => ({ success: true }));\n43\t      const names = listNullTasks();\n44\t      expect(names).toContain('list-test-handler');\n45\t    });\n46\t  });\n47\t\n48\t  describe('built-in telemetry handler', () => {\n49\t    it('exists and returns success', async () => {\n50\t      const handler = getNullTask('telemetry');\n51\t      expect(handler).toBeDefined();\n52\t\n53\t      const ctx: TaskContext = {\n54\t        storyKey: 'test-story',\n55\t        taskName: 'telemetry',\n56\t        cost: 0.5,\n57\t        durationMs: 1000,\n58\t        outputContract: null,\n59\t        projectDir: '/tmp/test',\n60\t      };\n61\t      const result = await handler!(ctx);\n62\t      expect(result.success).toBe(true);\n63\t      expect(result.output).toBeDefined();\n64\t    });\n65\t\n66\t    it('completes in under 10ms (AC #6)', async () => {\n67\t      const handler = getNullTask('telemetry')!;\n68\t      const ctx: TaskContext = {\n69\t        storyKey: 'perf-test',\n70\t        taskName: 'telemetry',\n71\t        cost: 0,\n72\t        durationMs: 0,\n73\t        outputContract: null,\n74\t        projectDir: '/tmp/test',\n75\t      };\n76\t      const start = performance.now();\n77\t      await handler(ctx);\n78\t      const elapsed = performance.now() - start;\n79\t      expect(elapsed).toBeLessThan(10);\n80\t    });\n81\t  });\n82\t\n83\t  describe('TaskContext interface', () => {\n84\t    it('handler receives all expected fields', async () => {\n85\t      let receivedCtx: TaskContext | null = null;\n86\t      registerNullTask('ctx-capture', async (ctx) => {\n87\t        receivedCtx = ctx;\n88\t        return { success: true };\n89\t      });\n90\t\n91\t      const mockContract = {\n92\t        version: 1,\n93\t        taskName: 'implement',\n94\t        storyId: 'story-1',\n95\t        driver: 'claude-code',\n96\t        model: 'claude-sonnet-4-20250514',\n97\t        timestamp: '2026-04-03T00:00:00.000Z',\n98\t        cost_usd: 0.05,\n99\t        duration_ms: 5000,\n100\t        changedFiles: [],\n101\t        testResults: null,\n102\t        output: 'done',\n103\t        acceptanceCriteria: [],\n104\t      };\n105\t\n106\t      const ctx: TaskContext = {\n107\t        storyKey: '16-2-test',\n108\t        taskName: 'ctx-capture',\n109\t        cost: 0.05,\n110\t        durationMs: 5000,\n111\t        outputContract: mockContract,\n112\t        projectDir: '/project',\n113\t      };\n114\t\n115\t      await getNullTask('ctx-capture')!(ctx);\n116\t\n117\t      expect(receivedCtx).not.toBeNull();\n118\t      expect(receivedCtx!.storyKey).toBe('16-2-test');\n119\t      expect(receivedCtx!.taskName).toBe('ctx-capture');\n120\t      expect(receivedCtx!.cost).toBe(0.05);\n121\t      expect(receivedCtx!.durationMs).toBe(5000);\n122\t      expect(receivedCtx!.outputContract).toBe(mockContract);\n123\t      expect(receivedCtx!.projectDir).toBe('/project');\n124\t    });\n125\t  });\n126\t});\n127\t"}]},"parent_tool_use_id":"toolu_011ZTgKSKa4gwyUPFY6UYukh","session_id":"8a461711-53e2-475a-88dd-c7013f6080c5","uuid":"caeddef3-512c-4ce7-8ede-1a18d89465b3","timestamp":"2026-04-03T17:20:39.423Z"}
