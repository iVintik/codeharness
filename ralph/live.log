{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017wxBMUQ4JmBuuPm8rosomy","type":"tool_result","content":"     1→/**\n     2→ * E2E Integration Test — Stream-JSON Pipeline\n     3→ *\n     4→ * Story 6-2: Verify Stream-JSON Pipeline End-to-End\n     5→ *\n     6→ * Tests the full data flow: NDJSON lines → makeLineHandler (line splitting) →\n     7→ * parseStreamLine (event parsing) → renderer update (state accumulation).\n     8→ *\n     9→ * Uses a recorded NDJSON fixture (tests/fixtures/sample-stream.ndjson) that\n    10→ * represents a realistic Claude stream-json session.\n    11→ */\n    12→\n    13→import { describe, it, expect, vi, beforeEach } from 'vitest';\n    14→import { readFileSync } from 'node:fs';\n    15→import { join, dirname } from 'node:path';\n    16→import { StringDecoder } from 'node:string_decoder';\n    17→import { parseStreamLine } from '../lib/stream-parser.js';\n    18→import type { StreamEvent } from '../lib/stream-parser.js';\n    19→import { parseRalphMessage, parseIterationMessage } from '../lib/run-helpers.js';\n    20→import type { StoryMessage } from '../lib/ink-components.js';\n    21→\n    22→// --- Resolve fixture path (project root / tests / fixtures) ---\n    23→\n    24→function projectRoot(): string {\n    25→  // src/__tests__/run-pipeline.test.ts → up two levels to project root\n    26→  return join(dirname(new URL(import.meta.url).pathname), '..', '..');\n    27→}\n    28→\n    29→function readFixture(name: string): string {\n    30→  return readFileSync(join(projectRoot(), 'tests', 'fixtures', name), 'utf-8');\n    31→}\n    32→\n    33→// --- Recreate makeLineHandler from run.ts for direct testing ---\n    34→// This mirrors the exact logic in src/commands/run.ts lines 182-209.\n    35→// We reconstruct it here to test the pipeline without spawning a child process.\n    36→\n    37→interface LineHandlerOptions {\n    38→  parseRalph?: boolean;\n    39→}\n    40→\n    41→interface CollectedState {\n    42→  events: StreamEvent[];\n    43→  messages: StoryMessage[];\n    44→  iterationCount: number;\n    45→}\n    46→\n    47→function makeLineHandler(\n    48→  state: CollectedState,\n    49→  opts?: LineHandlerOptions,\n    50→): (data: Buffer) => void {\n    51→  let partial = '';\n    52→  const decoder = new StringDecoder('utf8');\n    53→  return (data: Buffer): void => {\n    54→    const text = partial + decoder.write(data);\n    55→    const parts = text.split('\\n');\n    56→    partial = parts.pop() ?? '';\n    57→    for (const line of parts) {\n    58→      if (line.trim().length === 0) continue;\n    59→      const event = parseStreamLine(line);\n    60→      if (event) {\n    61→        state.events.push(event);\n    62→      }\n    63→      if (opts?.parseRalph) {\n    64→        const msg = parseRalphMessage(line);\n    65→        if (msg) {\n    66→          state.messages.push(msg);\n    67→        }\n    68→        const iteration = parseIterationMessage(line);\n    69→        if (iteration !== null) {\n    70→          state.iterationCount = iteration;\n    71→        }\n    72→      }\n    73→    }\n    74→  };\n    75→}\n    76→\n    77→// --- AC1: Full pipeline integration test with recorded NDJSON fixture ---\n    78→\n    79→describe('AC1: Full pipeline — fixture through makeLineHandler → parseStreamLine → renderer', () => {\n    80→  let state: CollectedState;\n    81→\n    82→  beforeEach(() => {\n    83→    state = { events: [], messages: [], iterationCount: 0 };\n    84→  });\n    85→\n    86→  it('pipes the full sample-stream.ndjson fixture through the pipeline', () => {\n    87→    const fixture = readFixture('sample-stream.ndjson');\n    88→    const handler = makeLineHandler(state);\n    89→\n    90→    // Feed the fixture as a single Buffer (simulates reading from stdout)\n    91→    handler(Buffer.from(fixture));\n    92→    // Flush any remaining partial line\n    93→    handler(Buffer.from('\\n'));\n    94→\n    95→    // Verify events were collected\n    96→    expect(state.events.length).toBeGreaterThan(0);\n    97→\n    98→    // The fixture contains: text, tool-start (Read), tool-input, tool-complete,\n    99→    // tool-start (Bash), tool-input, tool-complete, text, result\n   100→    const types = state.events.map(e => e.type);\n   101→    expect(types).toContain('text');\n   102→    expect(types).toContain('tool-start');\n   103→    expect(types).toContain('tool-input');\n   104→    expect(types).toContain('tool-complete');\n   105→    expect(types).toContain('result');\n   106→  });\n   107→\n   108→  it('handles chunk boundaries — fixture split across multiple Buffers', () => {\n   109→    const fixture = readFixture('sample-stream.ndjson');\n   110→    const handler = makeLineHandler(state);\n   111→\n   112→    // Split into chunks of varying sizes to test partial-line buffering\n   113→    const chunkSizes = [17, 43, 7, 101, 29, 3, 200];\n   114→    let offset = 0;\n   115→    let sizeIndex = 0;\n   116→    while (offset < fixture.length) {\n   117→      const size = chunkSizes[sizeIndex % chunkSizes.length];\n   118→      const chunk = fixture.slice(offset, offset + size);\n   119→      handler(Buffer.from(chunk));\n   120→      offset += size;\n   121→      sizeIndex++;\n   122→    }\n   123→    // Flush trailing partial\n   124→    handler(Buffer.from('\\n'));\n   125→\n   126→    // Must produce the same events regardless of chunk boundaries\n   127→    const singleChunkState: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   128→    const singleHandler = makeLineHandler(singleChunkState);\n   129→    singleHandler(Buffer.from(fixture));\n   130→    singleHandler(Buffer.from('\\n'));\n   131→\n   132→    expect(state.events).toEqual(singleChunkState.events);\n   133→  });\n   134→});\n   135→\n   136→// --- AC2: Events reach renderer in correct order ---\n   137→\n   138→describe('AC2: Event ordering — tool-start, tool-input, tool-complete, text arrive in order', () => {\n   139→  it('events arrive in the correct sequence from the fixture', () => {\n   140→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   141→    const handler = makeLineHandler(state);\n   142→    const fixture = readFixture('sample-stream.ndjson');\n   143→    handler(Buffer.from(fixture));\n   144→    handler(Buffer.from('\\n'));\n   145→\n   146→    const types = state.events.map(e => e.type);\n   147→\n   148→    // Expected order from the fixture:\n   149→    // 1. text (\"I'll start by reading...\")\n   150→    // 2. tool-complete (text block stop — index 0)\n   151→    // 3. tool-start (Read, index 1)\n   152→    // 4. tool-input (Read args)\n   153→    // 5. tool-complete (Read block stop)\n   154→    // 6. tool-start (Bash, index 2)\n   155→    // 7. tool-input (Bash args)\n   156→    // 8. tool-complete (Bash block stop)\n   157→    // 9. text (\"All tests pass...\")\n   158→    // 10. tool-complete (text block stop — index 3)\n   159→    // 11. result\n   160→\n   161→    expect(types[0]).toBe('text');\n   162→    expect(types[1]).toBe('tool-complete'); // text block stop\n   163→\n   164→    // Find the Read tool-start\n   165→    const readStartIdx = types.indexOf('tool-start');\n   166→    expect(readStartIdx).toBeGreaterThan(0);\n   167→    expect((state.events[readStartIdx] as { name: string }).name).toBe('Read');\n   168→\n   169→    // tool-input(s) must follow tool-start (Read has 2 input deltas)\n   170→    expect(types[readStartIdx + 1]).toBe('tool-input');\n   171→    expect(types[readStartIdx + 2]).toBe('tool-input');\n   172→    // tool-complete must follow tool-inputs\n   173→    expect(types[readStartIdx + 3]).toBe('tool-complete');\n   174→\n   175→    // Bash tool-start comes after Read tool-complete\n   176→    const bashStartIdx = types.indexOf('tool-start', readStartIdx + 1);\n   177→    expect(bashStartIdx).toBeGreaterThan(readStartIdx + 3);\n   178→    expect((state.events[bashStartIdx] as { name: string }).name).toBe('Bash');\n   179→    expect(types[bashStartIdx + 1]).toBe('tool-input');\n   180→    expect(types[bashStartIdx + 2]).toBe('tool-complete');\n   181→\n   182→    // Second text event comes after Bash tool-complete\n   183→    const secondTextIdx = types.indexOf('text', bashStartIdx);\n   184→    expect(secondTextIdx).toBeGreaterThan(bashStartIdx + 2);\n   185→\n   186→    // Result is the last event\n   187→    expect(types[types.length - 1]).toBe('result');\n   188→  });\n   189→\n   190→  it('tool-start events contain correct tool names and IDs', () => {\n   191→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   192→    const handler = makeLineHandler(state);\n   193→    handler(Buffer.from(readFixture('sample-stream.ndjson')));\n   194→    handler(Buffer.from('\\n'));\n   195→\n   196→    const toolStarts = state.events.filter(e => e.type === 'tool-start') as Array<{\n   197→      type: 'tool-start'; name: string; id: string;\n   198→    }>;\n   199→    expect(toolStarts).toHaveLength(2);\n   200→    expect(toolStarts[0]).toEqual({ type: 'tool-start', name: 'Read', id: 'toolu_read_001' });\n   201→    expect(toolStarts[1]).toEqual({ type: 'tool-start', name: 'Bash', id: 'toolu_bash_002' });\n   202→  });\n   203→\n   204→  it('tool-input events contain correct partial JSON', () => {\n   205→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   206→    const handler = makeLineHandler(state);\n   207→    handler(Buffer.from(readFixture('sample-stream.ndjson')));\n   208→    handler(Buffer.from('\\n'));\n   209→\n   210→    const toolInputs = state.events.filter(e => e.type === 'tool-input') as Array<{\n   211→      type: 'tool-input'; partial: string;\n   212→    }>;\n   213→    expect(toolInputs.length).toBeGreaterThanOrEqual(2);\n   214→\n   215→    // Read tool input — split across two deltas\n   216→    expect(toolInputs[0].partial).toBe('{\"file_path\"');\n   217→    expect(toolInputs[1].partial).toBe(':\"/src/index.ts\"}');\n   218→\n   219→    // Bash tool input — single delta\n   220→    expect(toolInputs[2].partial).toBe('{\"command\":\"npm test\"}');\n   221→  });\n   222→\n   223→  it('text events contain correct text content', () => {\n   224→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   225→    const handler = makeLineHandler(state);\n   226→    handler(Buffer.from(readFixture('sample-stream.ndjson')));\n   227→    handler(Buffer.from('\\n'));\n   228→\n   229→    const textEvents = state.events.filter(e => e.type === 'text') as Array<{\n   230→      type: 'text'; text: string;\n   231→    }>;\n   232→    expect(textEvents.length).toBeGreaterThanOrEqual(2);\n   233→    expect(textEvents[0].text).toBe(\"I'll start by reading the project files.\");\n   234→    expect(textEvents[1].text).toBe('All tests pass. The implementation is complete.');\n   235→  });\n   236→\n   237→  it('result event contains cost and session ID', () => {\n   238→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   239→    const handler = makeLineHandler(state);\n   240→    handler(Buffer.from(readFixture('sample-stream.ndjson')));\n   241→    handler(Buffer.from('\\n'));\n   242→\n   243→    const results = state.events.filter(e => e.type === 'result') as Array<{\n   244→      type: 'result'; cost: number; sessionId: string;\n   245→    }>;\n   246→    expect(results).toHaveLength(1);\n   247→    expect(results[0]).toEqual({ type: 'result', cost: 0.42, sessionId: 'sess_e2e_test' });\n   248→  });\n   249→});\n   250→\n   251→// --- AC3: Silently ignored event types ---\n   252→\n   253→describe('AC3: Silently ignored events — thinking_delta, hook_started, hook_response, init', () => {\n   254→  it('thinking_delta events produce null (not errors)', () => {\n   255→    const thinkingLine = JSON.stringify({\n   256→      type: 'stream_event',\n   257→      event: {\n   258→        type: 'content_block_delta',\n   259→        index: 0,\n   260→        delta: { type: 'thinking_delta', thinking: 'Let me analyze the codebase structure first.' },\n   261→      },\n   262→    });\n   263→    expect(parseStreamLine(thinkingLine)).toBeNull();\n   264→  });\n   265→\n   266→  it('hook_started events produce null', () => {\n   267→    const hookStarted = JSON.stringify({\n   268→      type: 'system',\n   269→      subtype: 'hook_started',\n   270→      hook: 'pre-tool-use',\n   271→      tool: 'Bash',\n   272→    });\n   273→    expect(parseStreamLine(hookStarted)).toBeNull();\n   274→  });\n   275→\n   276→  it('hook_response events produce null', () => {\n   277→    const hookResponse = JSON.stringify({\n   278→      type: 'system',\n   279→      subtype: 'hook_response',\n   280→      hook: 'pre-tool-use',\n   281→      approved: true,\n   282→    });\n   283→    expect(parseStreamLine(hookResponse)).toBeNull();\n   284→  });\n   285→\n   286→  it('init events produce null', () => {\n   287→    const initLine = JSON.stringify({\n   288→      type: 'system',\n   289→      subtype: 'init',\n   290→      session_id: 'sess_abc',\n   291→      tools: ['Bash', 'Read'],\n   292→    });\n   293→    expect(parseStreamLine(initLine)).toBeNull();\n   294→  });\n   295→\n   296→  it('message_start, message_stop, message_delta produce null', () => {\n   297→    expect(parseStreamLine(JSON.stringify({\n   298→      type: 'stream_event',\n   299→      event: { type: 'message_start', message: { id: 'msg_001' } },\n   300→    }))).toBeNull();\n   301→\n   302→    expect(parseStreamLine(JSON.stringify({\n   303→      type: 'stream_event',\n   304→      event: { type: 'message_stop' },\n   305→    }))).toBeNull();\n   306→\n   307→    expect(parseStreamLine(JSON.stringify({\n   308→      type: 'stream_event',\n   309→      event: { type: 'message_delta', delta: { stop_reason: 'end_turn' } },\n   310→    }))).toBeNull();\n   311→  });\n   312→\n   313→  it('the full fixture produces zero errors despite containing ignored events', () => {\n   314→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   315→    const handler = makeLineHandler(state);\n   316→    handler(Buffer.from(readFixture('sample-stream.ndjson')));\n   317→    handler(Buffer.from('\\n'));\n   318→\n   319→    // The fixture has 21 lines. Only some produce events.\n   320→    // Ignored lines: init, message_start, content_block_start(text), thinking_delta,\n   321→    // hook_started, hook_response, message_delta, message_stop\n   322→    // All should be silently ignored — no throws, no error events.\n   323→    const eventTypes = new Set(state.events.map(e => e.type));\n   324→    expect(eventTypes).not.toContain('error');\n   325→\n   326→    // Count: the fixture should produce exactly these event types\n   327→    expect(eventTypes).toEqual(new Set(['text', 'tool-start', 'tool-input', 'tool-complete', 'result']));\n   328→  });\n   329→});\n   330→\n   331→// --- AC4: Ralph stderr messages parsed into StoryMessage objects ---\n   332→\n   333→describe('AC4: Ralph stderr — [SUCCESS], [WARN], [LOOP] parsed into StoryMessage objects', () => {\n   334→  it('[SUCCESS] Story key: DONE is parsed into an OK message', () => {\n   335→    const line = '[2026-03-16 10:23:42] [SUCCESS] Story 3-2-stream-parser: DONE — 12/12 ACs verified (18m, $4.20)';\n   336→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   337→    const handler = makeLineHandler(state, { parseRalph: true });\n   338→    handler(Buffer.from(line + '\\n'));\n   339→\n   340→    expect(state.messages).toHaveLength(1);\n   341→    expect(state.messages[0].type).toBe('ok');\n   342→    expect(state.messages[0].key).toBe('3-2-stream-parser');\n   343→    expect(state.messages[0].message).toContain('DONE');\n   344→  });\n   345→\n   346→  it('[WARN] Story key exceeded retry limit is parsed into a FAIL message', () => {\n   347→    const line = '[2026-03-16 11:00:00] [WARN] Story 4-1-broken-feature exceeded retry limit';\n   348→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   349→    const handler = makeLineHandler(state, { parseRalph: true });\n   350→    handler(Buffer.from(line + '\\n'));\n   351→\n   352→    expect(state.messages).toHaveLength(1);\n   353→    expect(state.messages[0].type).toBe('fail');\n   354→    expect(state.messages[0].key).toBe('4-1-broken-feature');\n   355→    expect(state.messages[0].message).toContain('exceeded retry limit');\n   356→  });\n   357→\n   358→  it('[WARN] Story key retry N/M is parsed into a WARN message', () => {\n   359→    const line = '[2026-03-16 11:00:00] [WARN] Story 4-1-broken — retry 3/10';\n   360→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   361→    const handler = makeLineHandler(state, { parseRalph: true });\n   362→    handler(Buffer.from(line + '\\n'));\n   363→\n   364→    expect(state.messages).toHaveLength(1);\n   365→    expect(state.messages[0].type).toBe('warn');\n   366→    expect(state.messages[0].key).toBe('4-1-broken');\n   367→    expect(state.messages[0].message).toBe('retry 3/10');\n   368→  });\n   369→\n   370→  it('[LOOP] iteration N is parsed into an iteration count', () => {\n   371→    const line = '[2026-03-16 11:00:00] [LOOP] iteration 7';\n   372→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   373→    const handler = makeLineHandler(state, { parseRalph: true });\n   374→    handler(Buffer.from(line + '\\n'));\n   375→\n   376→    expect(state.iterationCount).toBe(7);\n   377→    expect(state.messages).toHaveLength(0); // LOOP is not a StoryMessage\n   378→  });\n   379→\n   380→  it('ralph messages with ANSI color codes are cleaned before parsing', () => {\n   381→    const line = '\\x1b[32m[2026-03-16 10:23:42] [SUCCESS] Story 3-2-parser: DONE\\x1b[0m';\n   382→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   383→    const handler = makeLineHandler(state, { parseRalph: true });\n   384→    handler(Buffer.from(line + '\\n'));\n   385→\n   386→    expect(state.messages).toHaveLength(1);\n   387→    expect(state.messages[0].type).toBe('ok');\n   388→    expect(state.messages[0].key).toBe('3-2-parser');\n   389→  });\n   390→\n   391→  it('non-ralph lines produce no messages', () => {\n   392→    const line = 'Just some random output that is not a ralph message';\n   393→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   394→    const handler = makeLineHandler(state, { parseRalph: true });\n   395→    handler(Buffer.from(line + '\\n'));\n   396→\n   397→    expect(state.messages).toHaveLength(0);\n   398→  });\n   399→\n   400→  it('stderr handler parses both NDJSON events AND ralph messages', () => {\n   401→    // Stderr can contain both NDJSON (from tee) and ralph's own log lines\n   402→    const ndjsonLine = JSON.stringify({\n   403→      type: 'stream_event',\n   404→      event: { type: 'content_block_stop' },\n   405→    });\n   406→    const ralphLine = '[2026-03-16 10:23:42] [SUCCESS] Story 5-1-feature: DONE';\n   407→    const combined = ndjsonLine + '\\n' + ralphLine + '\\n';\n   408→\n   409→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   410→    const handler = makeLineHandler(state, { parseRalph: true });\n   411→    handler(Buffer.from(combined));\n   412→\n   413→    // NDJSON line produces a stream event\n   414→    expect(state.events).toHaveLength(1);\n   415→    expect(state.events[0].type).toBe('tool-complete');\n   416→\n   417→    // Ralph line produces a story message\n   418→    expect(state.messages).toHaveLength(1);\n   419→    expect(state.messages[0].key).toBe('5-1-feature');\n   420→  });\n   421→});\n   422→\n   423→// --- Renderer state accumulation integration ---\n   424→\n   425→describe('Renderer state accumulation — full pipeline to RendererHandle-compatible state', () => {\n   426→  it('accumulates state matching what RendererHandle.update() would produce', () => {\n   427→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   428→    const handler = makeLineHandler(state);\n   429→    handler(Buffer.from(readFixture('sample-stream.ndjson')));\n   430→    handler(Buffer.from('\\n'));\n   431→\n   432→    // Simulate what the renderer does: walk events and build renderer state\n   433→    let activeTool: { name: string } | null = null;\n   434→    let activeToolArgs = '';\n   435→    const completedTools: Array<{ name: string; args: string }> = [];\n   436→    let lastThought: string | null = null;\n   437→\n   438→    for (const event of state.events) {\n   439→      switch (event.type) {\n   440→        case 'tool-start':\n   441→          activeTool = { name: event.name };\n   442→          activeToolArgs = '';\n   443→          lastThought = null;\n   444→          break;\n   445→        case 'tool-input':\n   446→          activeToolArgs += event.partial;\n   447→          break;\n   448→        case 'tool-complete':\n   449→          if (activeTool) {\n   450→            completedTools.push({ name: activeTool.name, args: activeToolArgs });\n   451→            activeTool = null;\n   452→            activeToolArgs = '';\n   453→          }\n   454→          break;\n   455→        case 'text':\n   456→          lastThought = event.text;\n   457→          break;\n   458→      }\n   459→    }\n   460→\n   461→    // Verify accumulated state\n   462→    expect(completedTools).toHaveLength(2);\n   463→    expect(completedTools[0]).toEqual({ name: 'Read', args: '{\"file_path\":\"/src/index.ts\"}' });\n   464→    expect(completedTools[1]).toEqual({ name: 'Bash', args: '{\"command\":\"npm test\"}' });\n   465→    expect(activeTool).toBeNull(); // All tools completed\n   466→    expect(lastThought).toBe('All tests pass. The implementation is complete.');\n   467→  });\n   468→});\n   469→"}]},"parent_tool_use_id":"toolu_01FovCBiSYXRKp8ZFdrhG5VU","session_id":"eb26302c-c52a-41c7-9204-5eb8c12a854c","uuid":"7f532707-e5ef-4f05-81b4-a151b9a2cfd0","timestamp":"2026-03-21T11:22:34.697Z"}
