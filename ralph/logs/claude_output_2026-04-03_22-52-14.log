{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XthpHXnsmMpJY8EdaKMHX2","type":"tool_result","content":"1137\t// --- Main Execution ---\n1138\t\n1139\t/**\n1140\t * Execute a workflow sequentially: iterate through flow steps, dispatch tasks\n1141\t * per-story or per-run, checkpoint state after each dispatch.\n1142\t *\n1143\t * Loop blocks execute iteratively until pass, max-iterations, or circuit-breaker.\n1144\t *\n1145\t * Returns an EngineResult summarizing the execution.\n1146\t */\n1147\texport async function executeWorkflow(config: EngineConfig): Promise<EngineResult> {\n1148\t  const startMs = Date.now();\n1149\t  const projectDir = config.projectDir ?? process.cwd();\n1150\t  const errors: EngineError[] = [];\n1151\t  let tasksCompleted = 0;\n1152\t  const processedStories = new Set<string>();\n1153\t\n1154\t  // 1. Read or initialize workflow state\n1155\t  let state = readWorkflowState(projectDir);\n1156\t\n1157\t  // Early exit: workflow already completed (AC #6)\n1158\t  if (state.phase === 'completed') {\n1159\t    return {\n1160\t      success: true,\n1161\t      tasksCompleted: 0,\n1162\t      storiesProcessed: 0,\n1163\t      errors: [],\n1164\t      durationMs: 0,\n1165\t    };\n1166\t  }\n1167\t\n1168\t  state = {\n1169\t    ...state,\n1170\t    phase: 'executing',\n1171\t    started: state.started || new Date().toISOString(),\n1172\t    workflow_name: config.workflow.flow.filter((s) => typeof s === 'string').join(' -> '),\n1173\t  };\n1174\t  writeWorkflowState(state, projectDir);\n1175\t\n1176\t  // 1b. Pre-flight driver health check\n1177\t  try {\n1178\t    await checkDriverHealth(config.workflow);\n1179\t  } catch (err: unknown) { // IGNORE: health check failure — record and abort\n1180\t    const message = err instanceof Error ? err.message : String(err);\n1181\t    state = { ...state, phase: 'failed' };\n1182\t    const engineError: EngineError = {\n1183\t      taskName: '__health_check__',\n1184\t      storyKey: '__health_check__',\n1185\t      code: 'HEALTH_CHECK',\n1186\t      message,\n1187\t    };\n1188\t    errors.push(engineError);\n1189\t    writeWorkflowState(state, projectDir);\n1190\t    return {\n1191\t      success: false,\n1192\t      tasksCompleted: 0,\n1193\t      storiesProcessed: 0,\n1194\t      errors,\n1195\t      durationMs: Date.now() - startMs,\n1196\t    };\n1197\t  }\n1198\t\n1199\t  // 1c. Pre-flight capability conflict check (advisory only — never aborts)\n1200\t  const capWarnings = checkCapabilityConflicts(config.workflow);\n1201\t  for (const cw of capWarnings) {\n1202\t    warn(cw.message);\n1203\t  }\n1204\t\n1205\t  // 2. Load work items\n1206\t  const workItems = loadWorkItems(config.sprintStatusPath, config.issuesPath);\n1207\t\n1208\t  // 3. Iterate through flow steps\n1209\t  let halted = false;\n1210\t  let lastOutputContract: OutputContract | null = null;\n1211\t  let accumulatedCostUsd = 0;\n1212\t  for (const step of config.workflow.flow) {\n1213\t    if (halted) break;\n1214\t\n1215\t    // Execute loop blocks\n1216\t    if (isLoopBlock(step)) {\n1217\t      const loopResult = await executeLoopBlock(step, state, config, workItems, lastOutputContract);\n1218\t      state = loopResult.state;\n1219\t      errors.push(...loopResult.errors);\n1220\t      tasksCompleted += loopResult.tasksCompleted;\n1221\t      lastOutputContract = loopResult.lastContract;\n1222\t\n1223\t      // Track processed stories from loop\n1224\t      for (const item of workItems) {\n1225\t        processedStories.add(item.key);\n1226\t      }\n1227\t\n1228\t      if (loopResult.halted) {\n1229\t        halted = true;\n1230\t      }\n1231\t\n1232\t      // If loop ended with max-iterations or circuit-breaker, treat as failure\n1233\t      if (state.phase === 'max-iterations' || state.phase === 'circuit-breaker') {\n1234\t        halted = true;\n1235\t      }\n1236\t      continue;\n1237\t    }\n1238\t\n1239\t    // step is a string task name\n1240\t    const taskName = step;\n1241\t    const task = config.workflow.tasks[taskName];\n1242\t\n1243\t    if (!task) {\n1244\t      warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n1245\t      continue;\n1246\t    }\n1247\t\n1248\t    // --- Null task path (agent: null) ---\n1249\t    if (task.agent === null) {\n1250\t      if (task.scope === 'per-run') {\n1251\t        if (isTaskCompleted(state, taskName, PER_RUN_SENTINEL)) {\n1252\t          warn(`workflow-engine: skipping completed task ${taskName} for ${PER_RUN_SENTINEL}`);\n1253\t          continue;\n1254\t        }\n1255\t        try {\n1256\t          const nullResult = await executeNullTask(\n1257\t            task, taskName, PER_RUN_SENTINEL, state, config, lastOutputContract ?? undefined, accumulatedCostUsd,\n1258\t          );\n1259\t          state = nullResult.updatedState;\n1260\t          lastOutputContract = nullResult.contract;\n1261\t          tasksCompleted++;\n1262\t        } catch (err: unknown) {\n1263\t          const engineError = isEngineError(err)\n1264\t            ? err\n1265\t            : handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n1266\t          errors.push(engineError);\n1267\t          state = recordErrorInState(state, taskName, PER_RUN_SENTINEL, engineError);\n1268\t          writeWorkflowState(state, projectDir);\n1269\t        }\n1270\t      } else {\n1271\t        for (const item of workItems) {\n1272\t          processedStories.add(item.key);\n1273\t          if (isTaskCompleted(state, taskName, item.key)) {\n1274\t            warn(`workflow-engine: skipping completed task ${taskName} for ${item.key}`);\n1275\t            continue;\n1276\t          }\n1277\t          try {\n1278\t            const nullResult = await executeNullTask(\n1279\t              task, taskName, item.key, state, config, lastOutputContract ?? undefined, accumulatedCostUsd,\n1280\t            );\n1281\t            state = nullResult.updatedState;\n1282\t            lastOutputContract = nullResult.contract;\n1283\t            tasksCompleted++;\n1284\t          } catch (err: unknown) {\n1285\t            const engineError = isEngineError(err)\n1286\t              ? err"}]},"parent_tool_use_id":"toolu_01SZLK8Zhua7u6We7yVejosU","session_id":"e648a229-0e5b-4ea4-9861-593afdfcccd5","uuid":"a3fa32a1-0f9c-4552-9e9b-6a21afbee6e5","timestamp":"2026-04-03T18:54:10.616Z"}
