js';\n   118→\n   119→const mockIsDockerAvailable = vi.mocked(isDockerAvailable);\n   120→const mockInstallAll = vi.mocked(installAllDependencies);\n   121→const mockIsBeadsInitialized = vi.mocked(isBeadsInitialized);\n   122→const mockDetectStacks = vi.mocked(detectStacks);\n   123→const mockInstrumentProject = vi.mocked(instrumentProject);\n   124→const mockGetCoverageTool = vi.mocked(getCoverageTool);\n   125→\n   126→let testDir: string;\n   127→let originalCwd: string;\n   128→\n   129→beforeEach(() => {\n   130→  testDir = mkdtempSync(join(tmpdir(), 'ch-init-project-test-'));\n   131→  originalCwd = process.cwd();\n   132→  process.chdir(testDir);\n   133→  vi.spyOn(console, 'log').mockImplementation(() => {});\n   134→  process.exitCode = undefined;\n   135→  // Reset mocks to default implementations\n   136→  mockIsDockerAvailable.mockReturnValue(true);\n   137→  mockInstallAll.mockReturnValue([\n   138→    { name: 'showboat', displayName: 'Showboat', status: 'already-installed', version: '0.6.1' },\n   139→  ]);\n   140→  mockIsBeadsInitialized.mockReturnValue(false);\n   141→});\n   142→\n   143→afterEach(() => {\n   144→  process.chdir(originalCwd);\n   145→  rmSync(testDir, { recursive: true, force: true });\n   146→  vi.restoreAllMocks();\n   147→  process.exitCode = undefined;\n   148→});\n   149→\n   150→describe('initProject — fresh init', () => {\n   151→  it('returns ok result with correct structure', async () => {\n   152→    writeFileSync(join(testDir, 'package.json'), '{}');\n   153→    const result = await initProject({\n   154→      projectDir: testDir,\n   155→      frontend: true,\n   156→      database: true,\n   157→      api: true,\n   158→      observability: false,\n   159→    });\n   160→    expect(result.success).toBe(true);\n   161→    if (result.success) {\n   162→      expect(result.data.status).toBe('ok');\n   163→      expect(result.data.stack).toBe('nodejs');\n   164→      expect(result.data.enforcement).toEqual({ frontend: true