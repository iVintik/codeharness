se);\n   237→    if (result.success) return;\n   238→    expect(result.error).toContain('Failed to parse proof');\n   239→    expect(result.error).toContain('EACCES');\n   240→  });\n   241→});\n   242→\n   243→describe('writeVerificationFindings', () => {\n   244→  const STORY_CONTENT = `# Story 3.3\n   245→\n   246→## Acceptance Criteria\n   247→\n   248→1. Some AC\n   249→\n   250→## Tasks / Subtasks\n   251→\n   252→- [ ] Task 1\n   253→\n   254→## Dev Agent Record\n   255→\n   256→### Agent Model Used\n   257→`;\n   258→\n   259→  const STORY_WITH_FINDINGS = `# Story 3.3\n   260→\n   261→## Acceptance Criteria\n   262→\n   263→1. Some AC\n   264→\n   265→## Verification Findings\n   266→\n   267→_Last updated: 2026-01-01T00:00:00.000Z_\n   268→\n   269→The following ACs failed black-box verification:\n   270→\n   271→### AC 1: Old finding\n   272→**Verdict:** FAIL\n   273→**Error output:**\n   274→\\`\\`\\`\n   275→old error\n   276→\\`\\`\\`\n   277→\n   278→## Dev Agent Record\n   279→\n   280→### Agent Model Used\n   281→`;\n   282→\n   283→  it('appends findings section to story file before Dev Agent Record', () => {\n   284→    mockedExistsSync.mockReturnValue(true);\n   285→    mockedReadFileSync.mockReturnValue(STORY_CONTENT);\n   286→\n   287→    const failingAcs = [\n   288→      { acNumber: 2, description: 'Test fails', errorOutput: 'Error: boom', verdict: 'FAIL' },\n   289→    ];\n   290→\n   291→    const result = writeVerificationFindings('3-3-test', failingAcs);\n   292→    expect(result.success).toBe(true);\n   293→\n   294→    expect(mockedWriteFileSync).toHaveBeenCalledTimes(1);\n   295→    const written = mockedWriteFileSync.mock.calls[0][1] as string;\n   296→    expect(written).toContain('## Verification Findings');\n   297→    expect(written).toContain('### AC 2: Test fails');\n   298→    expect(written).toContain('**Verdict:** FAIL');\n   299→    expect(written).toContain('Error: boom');\n   300→    // Findings should appear before Dev Agent Record\n   301→    const findingsIdx = written.indexOf('## Verification Findings');\n   302→    const devAgentIdx = written.indexOf('## Dev Agent Record');\n   303→    expect(findingsIdx).toBeLessThan(devAgentIdx);\n   304→  });\n   305→\n   306→  it('replaces existing findings section', () => {\n   307→    mockedExistsSync.mockReturnValue(true);\n   308→    mockedReadFileSync.mockReturnValue(STORY_WITH_FINDINGS);\n   309→\n   310→    const failingAcs = [\n   311→      { acNumber: 5, description: 'New failure', errorOutput: 'new error', verdict: 'FAIL' },\n   312→    ];\n   313→\n   314→    const result = writeVerificationFindings('3-3-test', failingAcs);\n   315→    expect(result.success).toBe(true);\n   316→\n   317→    const written = mockedWriteFileSync.mock.calls[0][1] as string;\n   318→    expect(written).toContain('### AC 5: New failure');\n   319→    expect(written).not.toContain('Old finding');\n   320→    expect(written).not.toContain('old error');\n   321→    // Should still have Dev Agent Record\n   322→    expect(written).toContain('## Dev Agent Record');\n   323→  });\n   324→\n   325→  it('replaces existing findings section when it is the last section (no following heading)', () => {\n   326→    const storyFindingsAtEnd = `# Story 3.3\n   327→\n   328→## Acceptance Criteria\n   329→\n   330→1. Some AC\n   331→\n   332→## Verification Findings\n   333→\n   334→_Last updated: 2026-01-01T00:00:00.000Z_\n   335→\n   336→The following ACs failed black-box verification:\n   337→\n   338→### AC 1: Old finding\n   339→**Verdict:** FAIL\n   340→**Error output:**\n   341→\\`\\`\\`\n   342→old error\n   343→\\`\\`\\`\n   344→`;\n   345→    mockedExistsSync.mockReturnValue(true);\n   346→    mockedReadFileSync.mockReturnValue(storyFindingsAtEnd);\n   347→\n   348→    const failingAcs = [\n   349→      { acNumber: 3, description: 'New fail', errorOutput: 'new err', verdict: 'FAIL' },\n   350→    ];\n   351→\n   352→    const result = writeVerificationFindings(