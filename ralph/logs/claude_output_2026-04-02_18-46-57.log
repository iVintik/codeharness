{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GqtFvax8o9SLxVTa2ZHZdi","type":"tool_result","content":"1\t/**\n2\t * CLI subcommand: codeharness validate schema\n3\t * Validates workflow YAML files against JSON schemas using parseWorkflow().\n4\t * Story 2-5: Validate Command\n5\t */\n6\timport { readdirSync, existsSync } from 'node:fs';\n7\timport { join, resolve } from 'node:path';\n8\timport { Command } from 'commander';\n9\timport { ok, fail, jsonOutput } from '../lib/output.js';\n10\timport { parseWorkflow, WorkflowParseError } from '../lib/workflow-parser.js';\n11\t\n12\texport interface ValidateSchemaFileResult {\n13\t  path: string;\n14\t  valid: boolean;\n15\t  errors: Array<{ path: string; message: string }>;\n16\t}\n17\t\n18\texport interface ValidateSchemaResult {\n19\t  status: 'pass' | 'fail';\n20\t  files: ValidateSchemaFileResult[];\n21\t}\n22\t\n23\t/**\n24\t * Render schema validation result to console output or JSON.\n25\t * Shared between default `validate` action and explicit `validate schema`.\n26\t */\n27\texport function renderSchemaResult(result: ValidateSchemaResult, isJson: boolean): void {\n28\t  if (isJson) {\n29\t    jsonOutput(result as unknown as Record<string, unknown>);\n30\t    process.exitCode = result.status === 'pass' ? 0 : 1;\n31\t    return;\n32\t  }\n33\t\n34\t  for (const file of result.files) {\n35\t    if (file.valid) {\n36\t      ok(`Schema: ${file.path}`);\n37\t    } else {\n38\t      fail(`Schema: ${file.path}`);\n39\t      for (const error of file.errors) {\n40\t        console.log(`  ${error.path}: ${error.message}`);\n41\t      }\n42\t    }\n43\t  }\n44\t\n45\t  process.exitCode = result.status === 'pass' ? 0 : 1;\n46\t}\n47\t\n48\texport function runSchemaValidation(projectDir: string): ValidateSchemaResult {\n49\t  const workflowsDir = join(projectDir, '.codeharness', 'workflows');\n50\t\n51\t  if (!existsSync(workflowsDir)) {\n52\t    return {\n53\t      status: 'fail',\n54\t      files: [{\n55\t        path: workflowsDir,\n56\t        valid: false,\n57\t        errors: [{ path: workflowsDir, message: 'No workflow files found' }],\n58\t      }],\n59\t    };\n60\t  }\n61\t\n62\t  let entries: string[];\n63\t  try {\n64\t    entries = readdirSync(workflowsDir)\n65\t      .filter(f => f.endsWith('.yaml') || f.endsWith('.yml'));\n66\t  } catch { // IGNORE: graceful fallback — treat unreadable dir as empty\n67\t    entries = [];\n68\t  }\n69\t\n70\t  if (entries.length === 0) {\n71\t    return {\n72\t      status: 'fail',\n73\t      files: [{\n74\t        path: workflowsDir,\n75\t        valid: false,\n76\t        errors: [{ path: workflowsDir, message: 'No workflow files found' }],\n77\t      }],\n78\t    };\n79\t  }\n80\t\n81\t  const fileResults: ValidateSchemaFileResult[] = [];\n82\t  let allValid = true;\n83\t\n84\t  for (const entry of entries) {\n85\t    const filePath = resolve(workflowsDir, entry);\n86\t    try {\n87\t      parseWorkflow(filePath);\n88\t      fileResults.push({ path: filePath, valid: true, errors: [] });\n89\t    } catch (err: unknown) {\n90\t      allValid = false;\n91\t      if (err instanceof WorkflowParseError) {\n92\t        fileResults.push({ path: filePath, valid: false, errors: err.errors });\n93\t      } else {\n94\t        const msg = err instanceof Error ? err.message : String(err);\n95\t        fileResults.push({ path: filePath, valid: false, errors: [{ path: filePath, message: msg }] });\n96\t      }\n97\t    }\n98\t  }\n99\t\n100\t  return { status: allValid ? 'pass' : 'fail', files: fileResults };\n101\t}\n102\t\n103\texport function registerValidateSchemaCommand(parent: Command): void {\n104\t  parent\n105\t    .command('schema')\n106\t    .description('Validate workflow YAML files against JSON schemas')\n107\t    .action((_opts: Record<string, unknown>, cmd: Command) => {\n108\t      const isJson = (cmd.optsWithGlobals() as { json?: boolean }).json === true;\n109\t      const result = runSchemaValidation(process.cwd());\n110\t      renderSchemaResult(result, isJson);\n111\t    });\n112\t}\n113\t"}]},"parent_tool_use_id":"toolu_01DuVFpc4kAp6TjMAncLaYvJ","session_id":"5fca15c0-771e-463c-9e4f-c528b230e359","uuid":"301a3183-94a9-4e86-b8e6-bacfff47c58b","timestamp":"2026-04-02T15:02:42.443Z"}
