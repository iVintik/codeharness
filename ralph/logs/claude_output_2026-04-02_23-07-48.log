{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018aqz5kj8JkdadciLJZ75AS","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n2\timport fs from 'node:fs';\n3\timport path from 'node:path';\n4\timport os from 'node:os';\n5\timport YAML from 'yaml';\n6\timport {\n7\t  loadEmbeddedAgent,\n8\t  loadPatch,\n9\t  mergePatch,\n10\t  resolveAgent,\n11\t  compileSubagentDefinition,\n12\t  AgentResolveError,\n13\t} from '../agent-resolver.js';\n14\timport type { ResolvedAgent, AgentPatch } from '../agent-resolver.js';\n15\t\n16\tconst TEMPLATES_DIR = path.resolve(__dirname, '../../../templates/agents');\n17\t\n18\tconst EXPECTED_AGENTS = [\n19\t  'dev', 'qa', 'architect', 'pm', 'sm',\n20\t  'analyst', 'ux-designer', 'tech-writer', 'evaluator',\n21\t];\n22\t\n23\t// --- Helpers ---\n24\t\n25\tfunction makeMinimalAgent(overrides?: Partial<ResolvedAgent>): ResolvedAgent {\n26\t  return {\n27\t    name: 'test-agent',\n28\t    role: { title: 'Test Agent', purpose: 'Testing' },\n29\t    persona: {\n30\t      identity: 'A test agent for unit tests',\n31\t      communication_style: 'Direct and clear',\n32\t      principles: ['Be thorough', 'Be honest'],\n33\t    },\n34\t    ...overrides,\n35\t  };\n36\t}\n37\t\n38\tfunction writeTempYaml(dir: string, relativePath: string, content: unknown): string {\n39\t  const filePath = path.join(dir, relativePath);\n40\t  const dirPath = path.dirname(filePath);\n41\t  fs.mkdirSync(dirPath, { recursive: true });\n42\t  fs.writeFileSync(filePath, YAML.stringify(content), 'utf-8');\n43\t  return filePath;\n44\t}\n45\t\n46\t// --- Tests ---\n47\t\n48\tdescribe('agent-resolver', () => {\n49\t  describe('loadEmbeddedAgent', () => {\n50\t    it('loads dev.yaml and returns valid ResolvedAgent (AC #1)', () => {\n51\t      const agent = loadEmbeddedAgent('dev');\n52\t      expect(agent.name).toBe('dev');\n53\t      expect(agent.role.title).toBeDefined();\n54\t      expect(agent.persona.identity).toBeDefined();\n55\t      expect(agent.persona.communication_style).toBeDefined();\n56\t      expect(Array.isArray(agent.persona.principles)).toBe(true);\n57\t    });\n58\t\n59\t    it('loads evaluator.yaml with disallowedTools (AC #7)', () => {\n60\t      const agent = loadEmbeddedAgent('evaluator');\n61\t      expect(agent.name).toBe('evaluator');\n62\t      expect(agent.disallowedTools).toContain('Edit');\n63\t      expect(agent.disallowedTools).toContain('Write');\n64\t    });\n65\t\n66\t    it('throws AgentResolveError for non-existent embedded agent', () => {\n67\t      expect(() => loadEmbeddedAgent('nonexistent-agent')).toThrow(AgentResolveError);\n68\t      try {\n69\t        loadEmbeddedAgent('nonexistent-agent');\n70\t      } catch (err) {\n71\t        const e = err as AgentResolveError;\n72\t        expect(e.filePath).toContain('nonexistent-agent.yaml');\n73\t        expect(e.errors.length).toBeGreaterThan(0);\n74\t      }\n75\t    });\n76\t\n77\t    it.each(EXPECTED_AGENTS)('loads %s.yaml successfully', (name) => {\n78\t      const agent = loadEmbeddedAgent(name);\n79\t      expect(agent.name).toBe(name);\n80\t    });\n81\t\n82\t    it('throws AgentResolveError with details when schema validation would fail', () => {\n83\t      // Embedded agents in templates/ are always valid, so we test the error constructor\n84\t      // to ensure the schema validation error branch produces the right shape\n85\t      const err = new AgentResolveError(\n86\t        'Schema validation failed for embedded agent test: /name: must be string',\n87\t        '/tmp/test.yaml',\n88\t        [{ path: '/name', message: 'must be string' }],\n89\t      );\n90\t      expect(err.name).toBe('AgentResolveError');\n91\t      expect(err.filePath).toBe('/tmp/test.yaml');\n92\t      expect(err.errors).toHaveLength(1);\n93\t      expect(err.errors[0].path).toBe('/name');\n94\t    });\n95\t  });\n96\t\n97\t  describe('loadPatch', () => {\n98\t    it('returns null for non-existent file (silent skip, AC #4)', () => {\n99\t      const result = loadPatch('/tmp/nonexistent-patch-file-xyz.yaml');\n100\t      expect(result).toBeNull();\n101\t    });\n102\t\n103\t    it('loads a valid patch file', () => {\n104\t      const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'agent-resolver-'));\n105\t      try {\n106\t        const patchContent = {\n107\t          extends: 'embedded://dev',\n108\t          overrides: { personality: { traits: { rigor: 0.9 } } },\n109\t        };\n110\t        const patchPath = writeTempYaml(tmpDir, 'dev.patch.yaml', patchContent);\n111\t        const result = loadPatch(patchPath);\n112\t        expect(result).not.toBeNull();\n113\t        expect(result!.extends).toBe('embedded://dev');\n114\t        expect(result!.overrides).toEqual({ personality: { traits: { rigor: 0.9 } } });\n115\t      } finally {\n116\t        fs.rmSync(tmpDir, { recursive: true, force: true });\n117\t      }\n118\t    });\n119\t\n120\t    it('throws AgentResolveError on malformed YAML (AC #5)', () => {\n121\t      const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'agent-resolver-'));\n122\t      try {\n123\t        const patchPath = path.join(tmpDir, 'bad.patch.yaml');\n124\t        fs.writeFileSync(patchPath, '{ invalid yaml: [unterminated', 'utf-8');\n125\t        expect(() => loadPatch(patchPath)).toThrow(AgentResolveError);\n126\t        try {\n127\t          loadPatch(patchPath);\n128\t        } catch (err) {\n129\t          const e = err as AgentResolveError;\n130\t          expect(e.filePath).toBe(patchPath);\n131\t          expect(e.errors.length).toBeGreaterThan(0);\n132\t        }\n133\t      } finally {\n134\t        fs.rmSync(tmpDir, { recursive: true, force: true });\n135\t      }\n136\t    });\n137\t\n138\t    it('throws AgentResolveError when patch file is a scalar (not an object)', () => {\n139\t      const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'agent-resolver-'));\n140\t      try {\n141\t        const patchPath = path.join(tmpDir, 'scalar.patch.yaml');\n142\t        fs.writeFileSync(patchPath, 'just a string', 'utf-8');\n143\t        expect(() => loadPatch(patchPath)).toThrow(AgentResolveError);\n144\t        try {\n145\t          loadPatch(patchPath);\n146\t        } catch (err) {\n147\t          const e = err as AgentResolveError;\n148\t          expect(e.filePath).toBe(patchPath);\n149\t          expect(e.message).toContain('not a valid object');\n150\t        }\n151\t      } finally {\n152\t        fs.rmSync(tmpDir, { recursive: true, force: true });\n153\t      }\n154\t    });\n155\t\n156\t    it('returns null when file exists but is unreadable', () => {\n157\t      const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'agent-resolver-'));\n158\t      try {\n159\t        const patchPath = path.join(tmpDir, 'unreadable.patch.yaml');\n160\t        fs.writeFileSync(patchPath, 'name: test', 'utf-8');\n161\t        // Make file unreadable (mode 0o000)\n162\t        fs.chmodSync(patchPath, 0o000);\n163\t        // On some systems (macOS root), chmod doesn't prevent reading\n164\t        // so this test may not hit the branch; that's acceptable\n165\t        const result = loadPatch(patchPath);\n166\t        // Either null (unreadable) or a valid patch (if chmod didn't work)\n167\t        expect(result === null || (typeof result === 'object')).toBe(true);\n168\t      } finally {\n169\t        // Restore permissions for cleanup\n170\t        try {\n171\t          fs.chmodSync(path.join(tmpDir, 'unreadable.patch.yaml'), 0o644);\n172\t        } catch { /* ignore */ }\n173\t        fs.rmSync(tmpDir, { recursive: true, force: true });\n174\t      }\n175\t    });\n176\t  });\n177\t\n178\t  describe('mergePatch', () => {\n179\t    it('deep-merges overrides onto base (AC #2)', () => {\n180\t      const base: Record<string, unknown> = {\n181\t        name: 'dev',\n182\t        persona: {\n183\t          identity: 'A developer',\n184\t          communication_style: 'Direct',\n185\t          principles: ['Be thorough'],\n186\t        },\n187\t      };\n188\t      const patch: AgentPatch = {\n189\t        extends: 'embedded://dev',\n190\t        overrides: {\n191\t          personality: { traits: { rigor: 0.9 } },\n192\t        },\n193\t      };\n194\t      const result = mergePatch(base, patch);\n195\t      expect(result.name).toBe('dev');\n196\t      expect((result.personality as Record<string, unknown>)).toEqual({ traits: { rigor: 0.9 } });\n197\t      // Original fields preserved\n198\t      expect((result.persona as Record<string, unknown>)).toEqual(base.persona);\n199\t    });\n200\t\n201\t    it('arrays replace entirely (not concatenate)', () => {\n202\t      const base: Record<string, unknown> = {\n203\t        name: 'dev',\n204\t        persona: {\n205\t          identity: 'A developer',\n206\t          communication_style: 'Direct',\n207\t          principles: ['Original principle 1', 'Original principle 2'],\n208\t        },\n209\t      };\n210\t      const patch: AgentPatch = {\n211\t        overrides: {\n212\t          persona: {\n213\t            principles: ['New principle only'],\n214\t          },\n215\t        },\n216\t      };\n217\t      const result = mergePatch(base, patch);\n218\t      const persona = result.persona as Record<string, unknown>;\n219\t      expect(persona.principles).toEqual(['New principle only']);\n220\t    });\n221\t\n222\t    it('scalars replace', () => {\n223\t      const base: Record<string, unknown> = {\n224\t        name: 'dev',\n225\t        role: { title: 'Original', purpose: 'Original purpose' },\n226\t      };\n227\t      const patch: AgentPatch = {\n228\t        overrides: {\n229\t          role: { title: 'Patched' },\n230\t        },\n231\t      };\n232\t      const result = mergePatch(base, patch);\n233\t      const role = result.role as Record<string, unknown>;\n234\t      expect(role.title).toBe('Patched');\n235\t      expect(role.purpose).toBe('Original purpose');\n236\t    });\n237\t\n238\t    it('preserves prompt_patches separately (AC #3)', () => {\n239\t      const base: Record<string, unknown> = { name: 'dev' };\n240\t      const patch: AgentPatch = {\n241\t        prompt_patches: { append: 'Extra instructions here.' },\n242\t      };\n243\t      const result = mergePatch(base, patch);\n244\t      expect(result.prompt_patches).toEqual({ append: 'Extra instructions here.' });\n245\t    });\n246\t\n247\t    it('concatenates prompt_patches.append from multiple patches', () => {\n248\t      const base: Record<string, unknown> = {\n249\t        name: 'dev',\n250\t        prompt_patches: { append: 'First instruction.' },\n251\t      };\n252\t      const patch: AgentPatch = {\n253\t        prompt_patches: { append: 'Second instruction.' },\n254\t      };\n255\t      const result = mergePatch(base, patch);\n256\t      const pp = result.prompt_patches as { append: string };\n257\t      expect(pp.append).toContain('First instruction.');\n258\t      expect(pp.append).toContain('Second instruction.');\n259\t    });\n260\t  });\n261\t\n262\t  describe('resolveAgent', () => {\n263\t    let tmpDir: string;\n264\t\n265\t    beforeEach(() => {\n266\t      tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'agent-resolver-'));\n267\t    });\n268\t\n269\t    afterEach(() => {\n270\t      fs.rmSync(tmpDir, { recursive: true, force: true });\n271\t      vi.restoreAllMocks();\n272\t    });\n273\t\n274\t    it('loads embedded dev.yaml with no patches and returns unchanged (AC #1, #4)', () => {\n275\t      // Point to a cwd with no patches\n276\t      const agent = resolveAgent('dev', { cwd: tmpDir });\n277\t      expect(agent.name).toBe('dev');\n278\t      expect(agent.role.title).toBe('Developer Agent');\n279\t      expect(agent.persona.identity).toBeDefined();\n280\t    });\n281\t\n282\t    it('missing user and project patches are silently skipped (AC #4)', () => {\n283\t      // No patches exist in tmpDir or mocked homedir\n284\t      vi.spyOn(os, 'homedir').mockReturnValue(tmpDir);\n285\t      const agent = resolveAgent('dev', { cwd: tmpDir });\n286\t      expect(agent.name).toBe('dev');\n287\t    });\n288\t\n289\t    it('applies user patch with overrides (AC #2)', () => {\n290\t      const userHome = path.join(tmpDir, 'home');\n291\t      vi.spyOn(os, 'homedir').mockReturnValue(userHome);\n292\t\n293\t      writeTempYaml(userHome, '.codeharness/agents/dev.patch.yaml', {\n294\t        extends: 'embedded://dev',\n295\t        overrides: {\n296\t          personality: { traits: { rigor: 0.9 } },\n297\t        },\n298\t      });\n299\t\n300\t      const agent = resolveAgent('dev', { cwd: tmpDir });\n301\t      expect(agent.name).toBe('dev');\n302\t      expect(agent.personality?.traits.rigor).toBe(0.9);\n303\t    });\n304\t\n305\t    it('applies project patch on top of user patch (AC #3)', () => {\n306\t      const userHome = path.join(tmpDir, 'home');\n307\t      const projectDir = path.join(tmpDir, 'project');\n308\t      vi.spyOn(os, 'homedir').mockReturnValue(userHome);\n309\t\n310\t      writeTempYaml(userHome, '.codeharness/agents/dev.patch.yaml', {\n311\t        extends: 'embedded://dev',\n312\t        overrides: {\n313\t          personality: { traits: { rigor: 0.9 } },\n314\t        },\n315\t      });\n316\t\n317\t      writeTempYaml(projectDir, '.codeharness/agents/dev.patch.yaml', {\n318\t        extends: 'embedded://dev',\n319\t        prompt_patches: { append: 'Use React + Vite.' },\n320\t      });\n321\t\n322\t      const agent = resolveAgent('dev', { cwd: projectDir });\n323\t      expect(agent.name).toBe('dev');\n324\t      expect(agent.personality?.traits.rigor).toBe(0.9);\n325\t      expect(agent.prompt_patches?.append).toBe('Use React + Vite.');\n326\t    });\n327\t\n328\t    it('full 3-layer chain: embedded + user + project (AC #2, #3)', () => {\n329\t      const userHome = path.join(tmpDir, 'home');\n330\t      const projectDir = path.join(tmpDir, 'project');\n331\t      vi.spyOn(os, 'homedir').mockReturnValue(userHome);\n332\t\n333\t      writeTempYaml(userHome, '.codeharness/agents/dev.patch.yaml', {\n334\t        extends: 'embedded://dev',\n335\t        overrides: {\n336\t          personality: { traits: { rigor: 0.85 } },\n337\t        },\n338\t        prompt_patches: { append: 'User-level instruction.' },\n339\t      });\n340\t\n341\t      writeTempYaml(projectDir, '.codeharness/agents/dev.patch.yaml', {\n342\t        extends: 'embedded://dev',\n343\t        overrides: {\n344\t          personality: { traits: { directness: 0.7 } },\n345\t        },\n346\t        prompt_patches: { append: 'Project-level instruction.' },\n347\t      });\n348\t\n349\t      const agent = resolveAgent('dev', { cwd: projectDir });\n350\t      expect(agent.personality?.traits.rigor).toBe(0.85);\n351\t      expect(agent.personality?.traits.directness).toBe(0.7);\n352\t      expect(agent.prompt_patches?.append).toContain('User-level instruction.');\n353\t      expect(agent.prompt_patches?.append).toContain('Project-level instruction.');\n354\t    });\n355\t\n356\t    it('throws AgentResolveError for malformed patch (AC #5)', () => {\n357\t      const userHome = path.join(tmpDir, 'home');\n358\t      vi.spyOn(os, 'homedir').mockReturnValue(userHome);\n359\t\n360\t      const patchDir = path.join(userHome, '.codeharness', 'agents');\n361\t      fs.mkdirSync(patchDir, { recursive: true });\n362\t      fs.writeFileSync(path.join(patchDir, 'dev.patch.yaml'), '{ bad yaml [[[', 'utf-8');\n363\t\n364\t      expect(() => resolveAgent('dev', { cwd: tmpDir })).toThrow(AgentResolveError);\n365\t    });\n366\t\n367\t    it('throws AgentResolveError when patch produces schema-invalid result (AC #5)', () => {\n368\t      const userHome = path.join(tmpDir, 'home');\n369\t      vi.spyOn(os, 'homedir').mockReturnValue(userHome);\n370\t\n371\t      // Patch that adds an invalid field (additionalProperties: false in schema)\n372\t      writeTempYaml(userHome, '.codeharness/agents/dev.patch.yaml', {\n373\t        extends: 'embedded://dev',\n374\t        overrides: {\n375\t          unknownTopLevelField: 'this should fail validation',\n376\t        },\n377\t      });\n378\t\n379\t      expect(() => resolveAgent('dev', { cwd: tmpDir })).toThrow(AgentResolveError);\n380\t    });\n381\t\n382\t    it('loads custom agent directly without patch chain (AC #8)', () => {\n383\t      const projectDir = path.join(tmpDir, 'project');\n384\t      vi.spyOn(os, 'homedir').mockReturnValue(path.join(tmpDir, 'home'));\n385\t\n386\t      const customAgent = makeMinimalAgent({ name: 'my-agent' });\n387\t      writeTempYaml(projectDir, '.codeharness/agents/my-agent.yaml', customAgent);\n388\t\n389\t      const agent = resolveAgent('my-agent', { cwd: projectDir });\n390\t      expect(agent.name).toBe('my-agent');\n391\t      expect(agent.role.title).toBe('Test Agent');\n392\t    });\n393\t\n394\t    it('throws AgentResolveError for invalid custom agent (AC #8, #5)', () => {\n395\t      const projectDir = path.join(tmpDir, 'project');\n396\t      vi.spyOn(os, 'homedir').mockReturnValue(path.join(tmpDir, 'home'));\n397\t\n398\t      // Custom agent missing required fields\n399\t      writeTempYaml(projectDir, '.codeharness/agents/bad-agent.yaml', {\n400\t        name: 'bad-agent',\n401\t        // missing role and persona\n402\t      });\n403\t\n404\t      expect(() => resolveAgent('bad-agent', { cwd: projectDir })).toThrow(AgentResolveError);\n405\t    });\n406\t\n407\t    it('resolving all 9 embedded agents completes in <200ms (AC #9)', () => {\n408\t      vi.spyOn(os, 'homedir').mockReturnValue(path.join(tmpDir, 'home'));\n409\t\n410\t      const start = performance.now();\n411\t      for (const name of EXPECTED_AGENTS) {\n412\t        resolveAgent(name, { cwd: tmpDir });\n413\t      }\n414\t      const elapsed = performance.now() - start;\n415\t      expect(elapsed).toBeLessThan(200);\n416\t    });\n417\t  });\n418\t\n419\t  describe('compileSubagentDefinition', () => {\n420\t    it('produces correct instructions string (AC #6)', () => {\n421\t      const agent = makeMinimalAgent();\n422\t      const result = compileSubagentDefinition(agent);\n423\t\n424\t      expect(result.name).toBe('test-agent');\n425\t      expect(result.model).toBe('claude-sonnet-4-20250514');\n426\t      expect(result.bare).toBe(true);\n427\t      expect(result.instructions).toContain('You are A test agent for unit tests');\n428\t      expect(result.instructions).toContain('Communication style: Direct and clear');\n429\t      expect(result.instructions).toContain('Principles:');\n430\t      expect(result.instructions).toContain('- Be thorough');\n431\t      expect(result.instructions).toContain('- Be honest');\n432\t    });\n433\t\n434\t    it('includes prompt_patches.append in instructions (AC #6)', () => {\n435\t      const agent = makeMinimalAgent({\n436\t        prompt_patches: { append: 'Run npm build first.' },\n437\t      });\n438\t      const result = compileSubagentDefinition(agent);\n439\t      expect(result.instructions).toContain('Run npm build first.');\n440\t    });\n441\t\n442\t    it('preserves disallowedTools for evaluator (AC #7)', () => {\n443\t      const agent = loadEmbeddedAgent('evaluator');\n444\t      const result = compileSubagentDefinition(agent);\n445\t      expect(result.disallowedTools).toContain('Edit');\n446\t      expect(result.disallowedTools).toContain('Write');\n447\t      expect(result.disallowedTools).toHaveLength(2);\n448\t    });\n449\t\n450\t    it('returns empty disallowedTools when not present', () => {\n451\t      const agent = makeMinimalAgent();\n452\t      const result = compileSubagentDefinition(agent);\n453\t      expect(result.disallowedTools).toEqual([]);\n454\t    });\n455\t\n456\t    it('sets bare: true always (AD2)', () => {\n457\t      const agent = makeMinimalAgent();\n458\t      const result = compileSubagentDefinition(agent);\n459\t      expect(result.bare).toBe(true);\n460\t    });\n461\t\n462\t    it('sets default model', (