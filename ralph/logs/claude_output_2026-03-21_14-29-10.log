laude:bmad-index-docs\",\".claude:bmad-document-project\",\".claude:bmad-edit-prd\",\".claude:bmad-sprint-planning\",\".claude:bmad-qa\",\".claude:bmad-create-architecture\",\".claude:bmad-pm\",\".claude:bmad-architect\",\".claude:bmad-sprint-status\",\".claude:bmad-qa-generate-e2e-tests\",\".claude:bmad-create-prd\",\".claude:bmad-market-research\",\".claude:bmad-editorial-review-structure\",\".claude:bmad-technical-research\",\".claude:bmad-sm\",\".claude:bmad-quick-dev\",\".claude:bmad-party-mode\",\".claude:bmad-quick-flow-solo-dev\",\"plugin-dev:command-development\",\"plugin-dev:hook-development\",\"plugin-dev:plugin-structure\",\"plugin-dev:skill-development\",\"plugin-dev:mcp-integration\",\"plugin-dev:agent-development\",\"plugin-dev:plugin-settings\",\"codeharness:visibility-enforcement\",\"codeharness:bmad-integration\",\"codeharness:verification-enforcement\",\"plugin-ops:release\",\"plugin-ops:issues\",\"plugin-ops:fix\",\"plugin-ops:reflect\",\"plugin-ops:optimize\",\"plugin-ops:diagnose\",\"plugin-ops:marketplace\",\"compact\",\"context\",\"cost\",\"heapdump\",\"init\",\"pr-comments\",\"release-notes\",\"review\",\"security-review\",\"extra-usage\",\"insights\"],\"apiKeySource\":\"none\",\"claude_code_version\":\"2.1.81\",\"output_style\":\"default\",\"agents\":[\"general-purpose\",\"statusline-setup\",\"Explore\",\"Plan\",\"plugin-dev:agent-creator\",\"plugin-dev:skill-reviewer\",\"plugin-dev:plugin-validator\",\"codeharness:verifier\",\"codeharness:doc-gardener\",\"plugin-ops:plugin-diagnostician\",\"plugin-ops:plugin-auditor\",\"plugin-ops:plugin-optimizer\"],\"skills\":[\"update-config\",\"debug\",\"simplify\",\"batch\",\"loop\",\"claude-api\",\"bmad-editorial-review-structure\",\"bmad-technical-research\",\"bmad-help\",\"bmad-retrospective\",\"bmad-analyst\",\"bmad-dev\",\"bmad-create-story\",\"bmad-tech-writer\",\"bmad-quick-dev-new-preview\",\"bmad-domain-research\",\"bmad-quick-dev\",\"bmad-qa-generate-e2e-tests\",\"bmad-sprint-planning\",\"bm