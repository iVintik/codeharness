 expect(restored).toEqual(original);\n246\t  });\n247\t});\n248\t\n249\tdescribe('array element validation', () => {\n250\t  it('rejects tasks_completed with invalid element types', () => {\n251\t    mkdirSync(join(testDir, '.codeharness'), { recursive: true });\n252\t    const yaml = `workflow_name: test\n253\tstarted: \"2026-01-01T00:00:00Z\"\n254\titeration: 1\n255\tphase: idle\n256\ttasks_completed:\n257\t  - 42\n258\t  - \"garbage\"\n259\tevaluator_scores: []\n260\tcircuit_breaker:\n261\t  triggered: false\n262\t  reason: null\n263\t  score_history: []\n264\t`;\n265\t    writeFileSync(join(testDir, '.codeharness', 'workflow-state.yaml'), yaml, 'utf-8');\n266\t    const state = readWorkflowState(testDir);\n267\t    expect(state).toEqual(getDefaultWorkflowState());\n268\t    expect(warn).toHaveBeenCalledWith(expect.stringContaining('invalid shape'));\n269\t  });\n270\t\n271\t  it('rejects tasks_completed with missing required fields', () => {\n272\t    mkdirSync(join(testDir, '.codeharness'), { recursive: true });\n273\t    const yaml = `workflow_name: test\n274\tstarted: \"2026-01-01T00:00:00Z\"\n275\titeration: 1\n276\tphase: idle\n277\ttasks_completed:\n278\t  - task_name: implement\n279\tevaluator_scores: []\n280\tcircuit_breaker:\n281\t  triggered: false\n282\t  reason: null\n283\t  score_history: []\n284\t`;\n285\t    writeFileSync(join(testDir, '.codeharness', 'workflow-state.yaml'), yaml, 'utf-8');\n286\t    const state = readWorkflowState(testDir);\n287\t    expect(state).toEqual(getDefaultWorkflowState());\n288\t    expect(warn).toHaveBeenCalledWith(expect.stringContaining('invalid shape'));\n289\t  });\n290\t\n291\t  it('rejects evaluator_scores with invalid element types', () => {\n292\t    mkdirSync(join(testDir, '.codeharness'), { recursive: true });\n293\t    const yaml = `workflow_name: test\n294\tstarted: \"2026-01-01T00:00:00Z\"\n295\titeration: 1\n296\tphase: idle\n297\ttasks_completed: []\n298\tevaluator_scores:\n299\t  - \"not an object\"\n300\tcircuit_breaker:\n301\t  triggered: false\n302\t  reason: null\n303\t  score_history: []\n304\t`;\n305\t    writeFileSync(join(testDir, '.codeharness', 'workflow-state.yaml'), yaml, 'utf-8');\n306\t    const state = readWorkflowState(testDir);\n307\t    expect(state).toEqual(getDefaultWorkflowState());\n308\t    expect(warn).toHaveBeenCalledWith(expect.stringContaining('invalid shape'));\n309\t  });\n310\t\n311\t  it('rejects evaluator_scores with missing required number fields', () => {\n312\t    mkdirSync(join(testDir, '.codeharness'), { recursive: true });\n313\t    const yaml = `workflow_name: test\n314\tstarted: \"2026-01-01T00:00:00Z\"\n315\titeration: 1\n316\tphase: idle\n317\ttasks_completed: []\n318\tevaluator_scores:\n319\t  - iteration: 1\n320\t    passed: \"not a number\"\n321\t    failed: 0\n322\t    unknown: 0\n323\t    total: 1\n324\t    timestamp: \"2026-01-01T00:00:00Z\"\n325\tcircuit_breaker:\n326\t  triggered: false\n327\t  reason: null\n328\t  score_history: []\n329\t`;\n330\t    writeFileSync(join(testDir, '.codeharness', 'workflow-state.yaml'), yaml, 'utf-8');\n331\t    const state = readWorkflowState(testDir);\n332\t    expect(state).toEqual(getDefaultWorkflowState());\n333\t    expect(warn).toHaveBeenCalledWith(expect.stringContaining('invalid shape'));\n334\t  });\n335\t\n336\t  it('rejects score_history with non-number elements', () => {\n337\t    mkdirSync(join(testDir, '.codeharness'), { recursive: true });\n338\t    const yaml = `workflow_name: test\n339\tstarted: \"2026-01-01T00:00:00Z\"\n340\titeration: 1\n341\tphase: idle\n342\ttasks_completed: []\n343\tevaluator_scores: []\n344\tcircuit_breaker:\n345\t  triggered: false\n346\t  reason: null\n347\t  score_history:\n348\t    - \"not a number\"\n349\t    - 0.75\n350\t`;\n351\t    writeFileSync(join(testDir, '.codeharness', 'workflow-state.yaml'), yaml, 'utf-8');\n352\t    const state = readWorkflowState(testDir);\n353\t    expect(state).toEqual(getDefaultWorkflowState());\n354\t    expect(warn).toHaveBeenCalledWith(expect.stringContaining('invalid shape'));\n355\t  });\n356\t\n357\t  it('accepts valid tasks_completed and evaluator_scores elements', () => {\n358\t    const state = buildFullState();\n359\t    writeWorkflowState(state, testDir);\n360\t    const restored = readWorkflowState(testDir);\n361\t    expect(restored.tasks_completed).toHaveLength(2);\n362\t    expect(restored.evaluator_scores).toHaveLength(1);\n363\t  });\n364\t});\n365\t\n366\tdescribe('concurrent/sequential writes', () => {\n367\t  it('last write wins with rapid sequential writes', () => {\n368\t    const state1: WorkflowState = { ...getDefaultWorkflowState(), phase: 'first' };\n369\t    const state2: WorkflowState = { ...getDefaultWorkflowState(), phase: 'second' };\n370\t    const state3: WorkflowState = { ...getDefaultWorkflowState(), phase: 'third' };\n371\t\n372\t    writeWorkflowState(state1, testDir);\n373\t    writeWorkflowState(state2, testDir);\n374\t    writeWorkflowState(state3, testDir);\n375\t\n376\t    const result = readWorkflowState(testDir);\n377\t    expect(result.phase).toBe('third');\n378\t  });\n379\t\n380\t  it('file always contains complete valid YAML after sequential writes', () => {\n381\t    for (let i = 0; i < 10; i++) {\n382\t      const state = getDefaultWorkflowState();\n383\t      state.iteration = i;\n384\t      state.phase = `phase-${i}`;\n385\t      writeWorkflowState(state, testDir);\n386\t    }\n387\t    const result = readWorkflowState(testDir);\n388\t    expect(result.iteration).toBe(9);\n389\t    expect(result.phase).toBe('phase-9');\n390\t  });\n391\t});\n392\t"}]},"parent_tool_use_id":"toolu_019TBFFZNMZrpi1d6hu8LDFG","session_id":"06dc1e0b-83a0-4950-9e66-ec9396bae461","uuid":"d5bdde74-fa63-4583-bbdc-da688167913c","timestamp":"2026-04-02T11:28:51.257Z"}
