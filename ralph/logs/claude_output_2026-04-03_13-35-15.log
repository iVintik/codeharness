{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PkWJUf3QtFdMzLCzvFz298","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { parse } from 'yaml';\n3\timport { warn } from './output.js';\n4\timport { DispatchError } from './agent-dispatch.js';\n5\timport type { DispatchErrorCode } from './agent-dispatch.js';\n6\t// Note: dispatchAgent is no longer imported — dispatch goes through the driver factory\n7\timport { getDriver } from './agents/drivers/factory.js';\n8\timport { resolveModel } from './agents/model-resolver.js';\n9\timport type { DispatchOpts } from './agents/types.js';\n10\timport type { ResultEvent } from './agents/stream-parser.js';\n11\timport type { SubagentDefinition } from './agent-resolver.js';\n12\timport type { ResolvedWorkflow, ResolvedTask, FlowStep, LoopBlock } from './workflow-parser.js';\n13\timport {\n14\t  readWorkflowState,\n15\t  writeWorkflowState,\n16\t} from './workflow-state.js';\n17\timport type { WorkflowState, TaskCheckpoint } from './workflow-state.js';\n18\timport { createIsolatedWorkspace } from './source-isolation.js';\n19\timport { generateTraceId, formatTracePrompt, recordTraceId } from './trace-id.js';\n20\timport { resolveSessionId, recordSessionId } from './session-manager.js';\n21\timport type { SessionLookupKey } from './session-manager.js';\n22\timport { parseVerdict, VerdictParseError } from './verdict-parser.js';\n23\timport type { EvaluatorVerdict } from './verdict-parser.js';\n24\timport { evaluateProgress } from './circuit-breaker.js';\n25\t\n26\t// Re-export EvaluatorVerdict for downstream consumers that import from workflow-engine\n27\texport type { EvaluatorVerdict } from './verdict-parser.js';\n28\texport { parseVerdict } from './verdict-parser.js';\n29\t\n30\t// --- Interfaces ---\n31\t\n32\t/**\n33\t * Configuration for the workflow engine.\n34\t */\n35\texport interface EngineConfig {\n36\t  /** The resolved workflow with tasks and flow steps. */\n37\t  workflow: ResolvedWorkflow;\n38\t  /** Pre-compiled agent definitions keyed by agent name. */\n39\t  agents: Record<string, SubagentDefinition>;\n40\t  /** Path to sprint-status.yaml for work item discovery. */\n41\t  sprintStatusPath: string;\n42\t  /** Optional path to issues.yaml for additional work items. */\n43\t  issuesPath?: string;\n44\t  /** Unique identifier for this engine run. */\n45\t  runId: string;\n46\t  /** Project root directory. Defaults to process.cwd(). */\n47\t  projectDir?: string;\n48\t  /** Maximum loop iterations before termination. Defaults to 5. */\n49\t  maxIterations?: number;\n50\t}\n51\t\n52\t/**\n53\t * Result returned by executeWorkflow().\n54\t */\n55\texport interface EngineResult {\n56\t  /** Whether the workflow completed without errors. */\n57\t  success: boolean;\n58\t  /** Number of task dispatches completed. */\n59\t  tasksCompleted: number;\n60\t  /** Number of work items (stories/issues) processed. */\n61\t  storiesProcessed: number;\n62\t  /** Errors encountered during execution. */\n63\t  errors: EngineError[];\n64\t  /** Wall-clock duration of the entire workflow in milliseconds. */\n65\t  durationMs: number;\n66\t}\n67\t\n68\t/**\n69\t * Structured error recorded during workflow execution.\n70\t */\n71\texport interface EngineError {\n72\t  taskName: string;\n73\t  storyKey: string;\n74\t  code: string;\n75\t  message: string;\n76\t}\n77\t\n78\t/**\n79\t * A work item (story or issue) ready for execution.\n80\t */\n81\texport interface WorkItem {\n82\t  key: string;\n83\t  title?: string;\n84\t  source: 'sprint' | 'issues';\n85\t}\n86\t\n87\t// --- Constants ---\n88\t\n89\t/** Sentinel story key for per-run tasks. */\n90\texport const PER_RUN_SENTINEL = '__run__';\n91\t\n92\t/** DispatchError codes that should halt execution immediately. */\n93\tconst HALT_ERROR_CODES = new Set(['RATE_LIMIT', 'NETWORK', 'SDK_INIT']);\n94\t\n95\t/** Default maximum loop iterations before termination. */\n96\tconst DEFAULT_MAX_ITERATIONS = 5;\n97\t\n98\t// --- Crash Recovery: Task Completion Check ---\n99\t\n100\t/**\n101\t * Check whether a (taskName, storyKey) combination is already recorded\n102\t * in the workflow state's tasks_completed array.\n103\t *\n104\t * Both fields must match for the task to be considered completed.\n105\t * Used by the resume logic to skip already-completed dispatches.\n106\t */\n107\texport function isTaskCompleted(\n108\t  state: WorkflowState,\n109\t  taskName: string,\n110\t  storyKey: string,\n111\t): boolean {\n112\t  return state.tasks_completed.some(\n113\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey && !cp.error,\n114\t  );\n115\t}\n116\t\n117\t/**\n118\t * Check whether a (taskName, storyKey) combination has been completed\n119\t * enough times to cover the current iteration in a loop block.\n120\t *\n121\t * Loop tasks execute the same (taskName, storyKey) pair each iteration,\n122\t * recording a new checkpoint each time. To determine if a task is done\n123\t * for the current iteration, we count how many matching checkpoints exist\n124\t * and compare to the current iteration number.\n125\t */\n126\texport function isLoopTaskCompleted(\n127\t  state: WorkflowState,\n128\t  taskName: string,\n129\t  storyKey: string,\n130\t  iteration: number,\n131\t): boolean {\n132\t  const count = state.tasks_completed.filter(\n133\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey && !cp.error,\n134\t  ).length;\n135\t  return count >= iteration;\n136\t}\n137\t\n138\t// --- Work Item Loading ---\n139\t\n140\t/**\n141\t * Load work items from sprint-status.yaml and optionally issues.yaml.\n142\t *\n143\t * Stories are extracted from the `development_status` section of sprint-status.yaml.\n144\t * Issues are extracted from the `issues` array of issues.yaml.\n145\t *\n146\t * Only items with status `backlog` or `ready-for-dev` are included.\n147\t * Epic keys (`epic-*`) and retrospective keys (`*-retrospective`) are excluded.\n148\t *\n149\t * If issues.yaml does not exist, returns only stories (no error).\n150\t */\n151\texport function loadWorkItems(sprintStatusPath: string, issuesPath?: string): WorkItem[] {\n152\t  const items: WorkItem[] = [];\n153\t\n154\t  // --- Load stories from sprint-status.yaml ---\n155\t  if (existsSync(sprintStatusPath)) {\n156\t    let raw: string;\n157\t    try {\n158\t      raw = readFileSync(sprintStatusPath, 'utf-8');\n159\t    } catch { // IGNORE: unreadable file — warn and return empty\n160\t      warn(`workflow-engine: could not read sprint-status.yaml at ${sprintStatusPath}`);\n161\t      return items;\n162\t    }\n163\t\n164\t    let parsed: unknown;\n165\t    try {\n166\t      parsed = parse(raw);\n167\t    } catch { // IGNORE: malformed YAML — warn and return empty\n168\t      warn(`workflow-engine: invalid YAML in sprint-status.yaml at ${sprintStatusPath}`);\n169\t      return items;\n170\t    }\n171\t\n172\t    if (parsed && typeof parsed === 'object') {\n173\t      const data = parsed as Record<string, unknown>;\n174\t      const devStatus = data.development_status as Record<string, unknown> | undefined;\n175\t\n176\t      if (devStatus && typeof devStatus === 'object') {\n177\t        for (const [key, status] of Object.entries(devStatus)) {\n178\t          // Skip epic keys and retrospective keys\n179\t          if (key.startsWith('epic-')) continue;\n180\t          if (key.endsWith('-retrospective')) continue;\n181\t\n182\t          // Only include backlog or ready-for-dev\n183\t          if (status === 'backlog' || status === 'ready-for-dev') {\n184\t            items.push({ key, source: 'sprint' });\n185\t          }\n186\t        }\n187\t      }\n188\t    }\n189\t  }\n190\t\n191\t  // --- Load issues from issues.yaml ---\n192\t  if (issuesPath && existsSync(issuesPath)) {\n193\t    let raw: string;\n194\t    try {\n195\t      raw = readFileSync(issuesPath, 'utf-8');\n196\t    } catch { // IGNORE: unreadable issues file — warn and return what we have\n197\t      warn(`workflow-engine: could not read issues.yaml at ${issuesPath}`);\n198\t      return items;\n199\t    }\n200\t\n201\t    let parsed: unknown;\n202\t    try {\n203\t      parsed = parse(raw);\n204\t    } catch { // IGNORE: malformed issues YAML — warn and return what we have\n205\t      warn(`workflow-engine: invalid YAML in issues.yaml at ${issuesPath}`);\n206\t      return items;\n207\t    }\n208\t\n209\t    if (parsed && typeof parsed === 'object') {\n210\t      const data = parsed as Record<string, unknown>;\n211\t      const issuesList = data.issues as Array<Record<string, unknown>> | undefined;\n212\t\n213\t      if (Array.isArray(issuesList)) {\n214\t        for (const issue of issuesList) {\n215\t          if (issue && typeof issue === 'object') {\n216\t            const status = issue.status as string | undefined;\n217\t            if (status === 'backlog' || status === 'ready-for-dev') {\n218\t              items.push({\n219\t                key: issue.id as string,\n220\t                title: issue.title as string | undefined,\n221\t                source: 'issues',\n222\t              });\n223\t            }\n224\t          }\n225\t        }\n226\t      }\n227\t    }\n228\t  }\n229\t\n230\t  return items;\n231\t}\n232\t\n233\t// --- Single Task Dispatch ---\n234\t\n235\t/**\n236\t * Dispatch a single task for a specific work item (or per-run sentinel).\n237\t *\n238\t * Handles: trace ID generation, session resolution, source isolation,\n239\t * agent dispatch, state checkpointing, and cleanup.\n240\t *\n241\t * Returns the updated workflow state after recording the dispatch.\n242\t */\n243\texport async function dispatchTask(\n244\t  task: ResolvedTask,\n245\t  taskName: string,\n246\t  storyKey: string,\n247\t  definition: SubagentDefinition,\n248\t  state: WorkflowState,\n249\t  config: EngineConfig,\n250\t  customPrompt?: string,\n251\t): Promise<WorkflowState> {\n252\t  const { updatedState } = await dispatchTaskWithResult(\n253\t    task, taskName, storyKey, definition, state, config, customPrompt,\n254\t  );\n255\t  return updatedState;\n256\t}\n257\t\n258\t// --- Flow Step Type Guard ---\n259\t\n260\tfunction isLoopBlock(step: FlowStep): step is LoopBlock {\n261\t  return typeof step === 'object' && step !== null && 'loop' in step;\n262\t}\n263\t\n264\t// --- Core Dispatch (shared by dispatchTask and loop block execution) ---\n265\t\n266\t/**\n267\t * Dispatch a task and return both the updated state and the raw dispatch output.\n268\t * This is the single implementation of task dispatch logic. Both `dispatchTask()`\n269\t * and loop block execution delegate here.\n270\t */\n271\tasync function dispatchTaskWithResult(\n272\t  task: ResolvedTask,\n273\t  taskName: string,\n274\t  storyKey: string,\n275\t  definition: SubagentDefinition,\n276\t  state: WorkflowState,\n277\t  config: EngineConfig,\n278\t  customPrompt?: string,\n279\t): Promise<{ updatedState: WorkflowState; output: string }> {\n280\t  const projectDir = config.projectDir ?? process.cwd();\n281\t\n282\t  // 1. Generate trace ID\n283\t  const traceId = generateTraceId(config.runId, state.iteration, taskName);\n284\t\n285\t  // 2. Format trace prompt — injected into driver via DispatchOpts.appendSystemPrompt\n286\t  const tracePrompt = formatTracePrompt(traceId);\n287\t\n288\t  // 3. Resolve session ID\n289\t  const sessionKey: SessionLookupKey = { taskName, storyKey };\n290\t  const sessionId = resolveSessionId(task.session, sessionKey, state);\n291\t\n292\t  // 4. Resolve driver\n293\t  const driverName = task.driver ?? 'claude-code';\n294\t  const driver = getDriver(driverName);\n295\t\n296\t  // 5. Resolve model via cascade: task → agent → driver\n297\t  const agentAsModelSource = { model: definition.model };\n298\t  const model = resolveModel(task, agentAsModelSource, driver);\n299\t\n300\t  // 6. Determine cwd based on source_access\n301\t  let cwd: string;\n302\t  let workspace: Awaited<ReturnType<typeof createIsolatedWorkspace>> | null = null;\n303\t\n304\t  if (task.source_access === false) {\n305\t    workspace = await createIsolatedWorkspace({ runId: config.runId, storyFiles: [] });\n306\t    cwd = workspace.toDispatchOptions().cwd ?? projectDir;\n307\t  } else {\n308\t    cwd = projectDir;\n309\t  }\n310\t\n311\t  // 7. Construct prompt\n312\t  const prompt = customPrompt\n313\t    ?? (storyKey === PER_RUN_SENTINEL\n314\t      ? `Execute task \"${taskName}\" for the current run.`\n315\t      : `Implement story ${storyKey}`);\n316\t\n317\t  // 8. Build DispatchOpts for the driver\n318\t  const dispatchOpts: DispatchOpts = {\n319\t    prompt,\n320\t    model,\n321\t    cwd,\n322\t    sourceAccess: task.source_access !== false,\n323\t    ...(sessionId ? { sessionId } : {}),\n324\t    ...(tracePrompt ? { appendSystemPrompt: tracePrompt } : {}),\n325\t    ...(task.plugins ? { plugins: task.plugins } : {}),\n326\t    ...(task.max_budget_usd != null ? { timeout: task.max_budget_usd } : {}),\n327\t  };\n328\t\n329\t  // 9. Dispatch through the driver and consume AsyncIterable<StreamEvent>\n330\t  let output = '';\n331\t  let resultSessionId = '';\n332\t  let cost = 0;\n333\t  let errorEvent: { error: string; errorCategory?: string } | null = null;\n334\t\n335\t  try {\n336\t    for await (const event of driver.dispatch(dispatchOpts)) {\n337\t      if (event.type === 'text') {\n338\t        output += event.text;\n339\t      }\n340\t      if (event.type === 'result') {\n341\t        const resultEvt = event as ResultEvent;\n342\t        resultSessionId = resultEvt.sessionId;\n343\t        cost = resultEvt.cost;\n344\t        if (resultEvt.error) {\n345\t          errorEvent = { error: resultEvt.error, errorCategory: resultEvt.errorCategory };\n346\t        }\n347\t      }\n348\t    }\n349\t  } finally {\n350\t    // Cleanup workspace regardless of dispatch success/failure\n351\t    if (workspace) {\n352\t      await workspace.cleanup();\n353\t    }\n354\t  }\n355\t\n356\t  // 10. If the driver reported an error in the result event, throw DispatchError\n357\t  if (errorEvent) {\n358\t    // Map ErrorCategory to DispatchErrorCode\n359\t    const categoryToCode: Record<string, string> = {\n360\t      RATE_LIMIT: 'RATE_LIMIT',\n361\t      NETWORK: 'NETWORK',\n362\t      SDK_INIT: 'SDK_INIT',\n363\t      AUTH: 'UNKNOWN',\n364\t      TIMEOUT: 'UNKNOWN',\n365\t      UNKNOWN: 'UNKNOWN',\n366\t    };\n367\t    const code = categoryToCode[errorEvent.errorCategory ?? 'UNKNOWN'] ?? 'UNKNOWN';\n368\t    throw new DispatchError(\n369\t      errorEvent.error,\n370\t      code as DispatchErrorCode,\n371\t      definition.name,\n372\t      errorEvent,\n373\t    );\n374\t  }\n375\t\n376\t  // 11. Record session ID (if dispatch returned one)\n377\t  let updatedState = state;\n378\t  if (resultSessionId) {\n379\t    updatedState = recordSessionId(sessionKey, resultSessionId, updatedState);\n380\t  } else {\n381\t    // Append checkpoint manually when no session ID is returned\n382\t    const checkpoint: TaskCheckpoint = {\n383\t      task_name: taskName,\n384\t      story_key: storyKey,\n385\t      completed_at: new Date().toISOString(),\n386\t    };\n387\t    updatedState = {\n388\t      ...updatedState,\n389\t      tasks_completed: [...updatedState.tasks_completed, checkpoint],\n390\t    };\n391\t  }\n392\t\n393\t  // 12. Record trace ID\n394\t  updatedState = recordTraceId(traceId, updatedState);\n395\t\n396\t  // 13. Write state to disk\n397\t  writeWorkflowState(updatedState, projectDir);\n398\t\n399\t  return { updatedState, output };\n400\t}\n401\t\n402\t// --- Retry Prompt Construction (Task 3) ---\n403\t\n404\t/**\n405\t * Build a retry prompt with evaluator findings injected.\n406\t * Includes only failed/unknown findings.\n407\t */\n408\texport function buildRetryPrompt(storyKey: string, findings: EvaluatorVerdict['findings']): string {\n409\t  const failedFindings = findings.filter(\n410\t    (f) => f.status === 'fail' || f.status === 'unknown',\n411\t  );\n412\t\n413\t  if (failedFindings.length === 0) {\n414\t    return `Implement story ${storyKey}`;\n415\t  }\n416\t\n417\t  const formattedFindings = failedFindings\n418\t    .map((f) => {\n419\t      const status = f.status.toUpperCase();\n420\t      let entry = `AC #${f.ac} (${status}): ${f.description}`;\n421\t      if (f.evidence?.reasoning) {\n422\t        entry += `\\n  Evidence: ${f.evidence.reasoning}`;\n423\t      }\n424\t      return entry;\n425\t    })\n426\t    .join('\\n\\n');\n427\t\n428\t  return `Retry story ${storyKey}. Previous evaluator findings:\\n\\n${formattedFindings}\\n\\nFocus on fixing the failed criteria above.`;\n429\t}\n430\t\n431\t// --- All-UNKNOWN Verdict Builder ---\n432\t\n433\t/**\n434\t * Build an all-UNKNOWN EvaluatorVerdict as fallback when the evaluator\n435\t * fails to produce valid JSON after retry.\n436\t */\n437\texport function buildAllUnknownVerdict(\n438\t  workItems: WorkItem[],\n439\t  reasoning: string,\n440\t): EvaluatorVerdict {\n441\t  const findings = workItems.map((_, index) => ({\n442\t    ac: index + 1,\n443\t    description: `AC #${index + 1}`,\n444\t    status: 'unknown' as const,\n445\t    evidence: {\n446\t      commands_run: [] as string[],\n447\t      output_observed: '',\n448\t      reasoning,\n449\t    },\n450\t  }));\n451\t\n452\t  return {\n453\t    verdict: 'fail',\n454\t    score: {\n455\t      passed: 0,\n456\t      failed: 0,\n457\t      unknown: findings.length,\n458\t      total: findings.length,\n459\t    },\n460\t    findings,\n461\t  };\n462\t}\n463\t\n464\t// --- Failed Story Filtering (Task 4) ---\n465\t\n466\t/**\n467\t * Determine which work items failed based on evaluator findings.\n468\t * If verdict is null (parse failure), returns all items (conservative fallback).\n469\t */\n470\texport function getFailedItems(\n471\t  verdict: EvaluatorVerdict | null,\n472\t  allItems: WorkItem[],\n473\t): WorkItem[] {\n474\t  if (!verdict) return allItems;\n475\t\n476\t  // If verdict passed, no items need retry\n477\t  if (verdict.verdict === 'pass') return [];\n478\t\n479\t  // All items are retried on failure — per-story filtering based on individual\n480\t  // story results is not possible with the current verdict shape (verdict is per-run).\n481\t  // The findings track ACs, not stories. Conservative: retry all on failure.\n482\t  return allItems;\n483\t}\n484\t\n485\t// --- Loop Block Execution (Task 5) ---\n486\t\n487\t/**\n488\t * Result of loop block execution.\n489\t */\n490\tinterface LoopBlockResult {\n491\t  state: WorkflowState;\n492\t  errors: EngineError[];\n493\t  tasksCompleted: number;\n494\t  halted: boolean;\n495\t}\n496\t\n497\t/**\n498\t * Execute a loop block: iterate tasks until pass, max iterations, or circuit breaker.\n499\t */\n500\texport async function executeLoopBlock(\n501\t  loopBlock: LoopBlock,\n502\t  state: WorkflowState,\n503\t  config: EngineConfig,\n504\t  workItems: WorkItem[],\n505\t): Promise<LoopBlockResult> {\n506\t  const projectDir = config.projectDir ?? process.cwd();\n507\t  const maxIterations = config.maxIterations ?? DEFAULT_MAX_ITERATIONS;\n508\t  const errors: EngineError[] = [];\n509\t  let tasksCompleted = 0;\n510\t  let currentState = state;\n511\t  let lastVerdict: EvaluatorVerdict | null = null;\n512\t\n513\t  // Handle empty loop block\n514\t  if (loopBlock.loop.length === 0) {\n515\t    return { state: currentState, errors, tasksCompleted, halted: false };\n516\t  }\n517\t\n518\t  while (true) {\n519\t    // 1. Determine whether to increment iteration or resume a partial one.\n520\t    //    On fresh start (iteration === 0), always increment.\n521\t    //    On resume (iteration > 0), check if the current iteration is fully done.\n522\t    const nextIteration = currentState.iteration + 1;\n523\t    const allCurrentIterationDone = currentState.iteration > 0 && loopBlock.loop.every((tn) => {\n524\t      const t = config.workflow.tasks[tn];\n525\t      if (!t) return true; // missing task = skip = \"done\"\n526\t      if (t.scope === 'per-story') {\n527\t        return workItems.every((item) =>\n528\t          isLoopTaskCompleted(currentState, tn, item.key, currentState.iteration));\n529\t      }\n530\t      return isLoopTaskCompleted(currentState, tn, PER_RUN_SENTINEL, currentState.iteration);\n531\t    });\n532\t\n533\t    if (currentState.iteration === 0 || allCurrentIterationDone) {\n534\t      // Fresh start or current iteration fully done — advance\n535\t      currentState = {\n536\t        ...currentState,\n537\t        iteration: nextIteration,\n538\t      };\n539\t      writeWorkflowState(currentState, projectDir);\n540\t    }\n541\t    // else: resuming a partially completed iteration — keep current iteration\n542\t\n543\t    let haltedInLoop = false;\n544\t\n545\t    // 2. Execute each task in the loop\n546\t    for (const taskName of loopBlock.loop) {\n547\t      const task = config.workflow.tasks[taskName];\n548\t      if (!task) {\n549\t        warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n550\t        continue;\n551\t      }\n552\t\n553\t      const definition = config.agents[task.agent];\n554\t      if (!definition) {\n555\t        warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n556\t        continue;\n557\t      }\n558\t\n559\t      if (task.scope === 'per-story') {\n560\t        // Determine which items to dispatch for\n561\t        const itemsToRetry = lastVerdict ? getFailedItems(lastVerdict, workItems) : workItems;\n562\t\n563\t        for (const item of itemsToRetry) {\n564\t          // Skip if already completed for this iteration (crash recovery — AC #4)\n565\t          if (isLoopTaskCompleted(currentState, taskName, item.key, currentState.iteration)) {\n566\t            warn(`workflow-engine: skipping completed task ${taskName} for ${item.key}`);\n567\t            continue;\n568\t          }\n569\t\n570\t          // Build prompt: inject findings if we have a previous verdict\n571\t          const prompt = lastVerdict\n572\t            ? buildRetryPrompt(item.key, lastVerdict.findings)\n573\t            : undefined;\n574\t\n575\t          try {\n576\t            currentState = await dispatchTask(\n577\t              task, taskName, item.key, definition, currentState, config, prompt,\n578\t            );\n579\t            tasksCompleted++;\n580\t          } catch (err: unknown) {\n581\t            const engineError = handleDispatchError(err, taskName, item.key);\n582\t            errors.push(engineError);\n583\t            currentState = recordErrorInState(currentState, taskName, item.key, engineError);\n584\t            writeWorkflowState(currentState, projectDir);\n585\t\n586\t            if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n587\t              haltedInLoop = true;\n588\t              break;\n589\t            }\n590\t            continue;\n591\t          }\n592\t        }\n593\t\n594\t        if (haltedInLoop) break;\n595\t      } else {\n596\t        // per-run task (e.g., verify)\n597\t        // Skip if already completed for this iteration (crash recovery — AC #4)\n598\t        if (isLoopTaskCompleted(currentState, taskName, PER_RUN_SENTINEL, currentState.iteration)) {\n599\t          warn(`workflow-engine: skipping completed task ${taskName} for ${PER_RUN_SENTINEL}`);\n600\t          continue;\n601\t        }\n602\t\n603\t        try {\n604\t          // We need the dispatch result output to parse verdict\n605\t          // dispatchTask doesn't return the DispatchResult directly, so we\n606\t          // intercept via a wrapper that captures the output\n607\t          const dispatchResult = await dispatchTaskWithResult(\n608\t            task, taskName, PER_RUN_SENTINEL, definition, currentState, config,\n609\t          );\n610\t          currentState = dispatchResult.updatedState;\n611\t          tasksCompleted++;\n612\t\n613\t          // Attempt to parse verdict from output with retry semantics (story 6-2)\n614\t          let verdict: EvaluatorVerdict | null = null;\n615\t          try {\n616\t            verdict = parseVerdict(dispatchResult.output);\n617\t          } catch (parseErr: unknown) {\n618\t            if (parseErr instanceof VerdictParseError && parseErr.retryable) {\n619\t              // Re-dispatch evaluator for one retry attempt\n620\t              warn(`workflow-engine: verdict parse failed, retrying evaluator for ${taskName}`);\n621\t              try {\n622\t                const retryResult = await dispatchTaskWithResult(\n623\t                  task, taskName, PER_RUN_SENTINEL, definition, currentState, config,\n624\t                );\n625\t                currentState = retryResult.updatedState;\n626\t                tasksCompleted++;\n627\t                verdict = parseVerdict(retryResult.output);\n628\t              } catch { // IGNORE: retry failed — fall back to all-UNKNOWN verdict\n629\t                // Second failure: generate all-UNKNOWN verdict\n630\t                verdict = buildAllUnknownVerdict(\n631\t                  workItems,\n632\t                  'Evaluator failed to produce valid JSON after retry',\n633\t                );\n634\t              }\n635\t            }\n636\t            // If not a VerdictParseError or not retryable, verdict stays null\n637\t          }\n638\t          lastVerdict = verdict;\n639\t\n640\t          // Record score in state\n641\t          if (verdict) {\n642\t            const score = {\n643\t              iteration: currentState.iteration,\n644\t              passed: verdict.score.passed,\n645\t              failed: verdict.score.failed,\n646\t              unknown: verdict.score.unknown,\n647\t              total: verdict.score.total,\n648\t              timestamp: new Date().toISOString(),\n649\t            };\n650\t            currentState = {\n651\t              ...currentState,\n652\t              evaluator_scores: [...currentState.evaluator_scores, score],\n653\t            };\n654\t          } else {\n655\t            // Parse failure: record all-UNKNOWN score\n656\t            const totalItems = workItems.length;\n657\t            const score = {\n658\t              iteration: currentState.iteration,\n659\t              passed: 0,\n660\t              failed: 0,\n661\t              unknown: totalItems,\n662\t              total: totalItems,\n663\t              timestamp: new Date().toISOString(),\n664\t            };\n665\t            currentState = {\n666\t              ...currentState,\n667\t              evaluator_scores: [...currentState.evaluator_scores, score],\n668\t            };\n669\t          }\n670\t          writeWorkflowState(currentState, projectDir);\n671\t\n672\t          // Circuit breaker: evaluate progress after recording score\n673\t          const cbDecision = evaluateProgress(currentState.evaluator_scores);\n674\t          if (cbDecision.halt) {\n675\t            currentState = {\n676\t              ...currentState,\n677\t              circuit_breaker: {\n678\t                triggered: true,\n679\t                reason: cbDecision.reason,\n680\t                score_history: cbDecision.scoreHistory,\n681\t              },\n682\t            };\n683\t            writeWorkflowState(currentState, projectDir);\n684\t          }\n685\t        } catch (err: unknown) {\n686\t          const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n687\t          errors.push(engineError);\n688\t          currentState = recordErrorInState(currentState, taskName, PER_RUN_SENTINEL, engineError);\n689\t          writeWorkflowState(currentState, projectDir);\n690\t\n691\t          // Clear stale verdict so next iteration retries all items\n692\t          lastVerdict = null;\n693\t\n694\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n695\t            haltedInLoop = true;\n696\t            break;\n697\t          }\n698\t          continue;\n699\t        }\n700\t      }\n701\t    }\n702\t\n703\t    if (haltedInLoop) {\n704\t      return { state: currentState, errors, tasksCompleted, halted: true };\n705\t    }\n706\t\n707\t    // 3. Check termination conditions\n708\t    if (lastVerdict?.verdict === 'pass') {\n709\t      // Success: loop passes\n710\t      return { state: currentState, errors, tasksCompleted, halted: false };\n711\t    }\n712\t\n713\t    if (currentState.iteration >= maxIterations) {\n714\t      currentState = { ...currentState, phase: 'max-iterations' };\n715\t      writeWorkflowState(currentState, projectDir);\n716\t      return { state: currentState, errors, tasksCompleted, halted: false };\n717\t    }\n718\t\n719\t    if (currentState.circuit_breaker.triggered) {\n720\t      currentState = { ...currentState, phase: 'circuit-breaker' };\n721\t      writeWorkflowState(currentState, projectDir);\n722\t      return { state: currentState, errors, tasksCompleted, halted: false };\n723\t    }\n724\t  }\n725\t}\n726\t\n727\t\n728\t// --- Main Execution ---\n729\t\n730\t/**\n731\t * Execute a workflow sequentially: iterate through flow steps, dispatch tasks\n732\t * per-story or per-run, checkpoint state after each dispatch.\n733\t *\n734\t * Loop blocks execute iteratively until pass, max-iterations, or circuit-breaker.\n735\t *\n736\t * Returns an EngineResult summarizing the execution.\n737\t */\n738\texport async function executeWorkflow(config: EngineConfig): Promise<EngineResult> {\n739\t  const startMs = Date.now();\n740\t  const projectDir = config.projectDir ?? process.cwd();\n741\t  const errors: EngineError[] = [];\n742\t  let tasksCompleted = 0;\n743\t  const processedStories = new Set<string>();\n744\t\n745\t  // 1. Read or initialize workflow state\n746\t  let state = readWorkflowState(projectDir);\n747\t\n748\t  // Early exit: workflow already completed (AC #6)\n749\t  if (state.phase === 'completed') {\n750\t    return {\n751\t      success: true,\n752\t      tasksCompleted: 0,\n753\t      storiesProcessed: 0,\n754\t      errors: [],\n755\t      durationMs: 0,\n756\t    };\n757\t  }\n758\t\n759\t  state = {\n760\t    ...state,\n761\t    phase: 'executing',\n762\t    started: state.started || new Date().toISOString(),\n763\t    workflow_name: config.workflow.flow.filter((s) => typeof s === 'string').join(' -> '),\n764\t  };\n765\t  writeWorkflowState(state, projectDir);\n766\t\n767\t  // 2. Load work items\n768\t  const workItems = loadWorkItems(config.sprintStatusPath, config.issuesPath);\n769\t\n770\t  // 3. Iterate through flow steps\n771\t  let halted = false;\n772\t  for (const step of config.workflow.flow) {\n773\t    if (halted) break;\n774\t\n775\t    // Execute loop blocks\n776\t    if (isLoopBlock(step)) {\n777\t      const loopResult = await executeLoopBlock(step, state, config, workItems);\n778\t      state = loopResult.state;\n779\t      errors.push(...loopResult.errors);\n780\t      tasksCompleted += loopResult.tasksCompleted;\n781\t\n782\t      // Track processed stories from loop\n783\t      for (const item of workItems) {\n784\t        processedStories.add(item.key);\n785\t      }\n786\t\n787\t      if (loopResult.halted) {\n788\t        halted = true;\n789\t      }\n790\t\n791\t      // If loop ended with max-iterations or circuit-breaker, treat as failure\n792\t      if (state.phase === 'max-iterations' || state.phase === 'circuit-breaker') {\n793\t        halted = true;\n794\t      }\n795\t      continue;\n796\t    }\n797\t\n798\t    // step is a string task name\n799\t    const taskName = step;\n800\t    const task = config.workflow.tasks[taskName];\n801\t\n802\t    if (!task) {\n803\t      warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n804\t      continue;\n805\t    }\n806\t\n807\t    // Look up the agent definition\n808\t    const definition = config.agents[task.agent];\n809\t    if (!definition) {\n810\t      warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n811\t      continue;\n812\t    }\n813\t\n814\t    if (task.scope === 'per-run') {\n815\t      // Skip if already completed (crash recovery — AC #3)\n816\t      if (isTaskCompleted(state, taskName, PER_RUN_SENTINEL)) {\n817\t        warn(`workflow-engine: skipping completed task ${taskName} for ${PER_RUN_SENTINEL}`);\n818\t        continue;\n819\t      }\n820\t\n821\t      // Per-run: dispatch once with sentinel key\n822\t      try {\n823\t        state = await dispatchTask(task, taskName, PER_RUN_SENTINEL, definition, state, config);\n824\t        tasksCompleted++;\n825\t      } catch (err: unknown) {\n826\t        const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n827\t        errors.push(engineError);\n828\t\n829\t        // Record error checkpoint in state (AC #13)\n830\t        state = recordErrorInState(state, taskName, PER_RUN_SENTINEL, engineError);\n831\t        writeWorkflowState(state, projectDir);\n832\t\n833\t        // Halt on critical errors\n834\t        if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n835\t          halted = true;\n836\t        }\n837\t      }\n838\t    } else {\n839\t      // Per-story: dispatch once per work item\n840\t      for (const item of workItems) {\n841\t        processedStories.add(item.key);\n842\t\n843\t        // Skip if already completed (crash recovery — AC #1, #2, #7)\n844\t        if (isTaskCompleted(state, taskName, item.key)) {\n845\t          warn(`workflow-engine: skipping completed task ${taskName} for ${item.key}`);\n846\t          continue;\n847\t        }\n848\t\n849\t        try {\n850\t          state = await dispatchTask(task, taskName, item.key, definition, state, config);\n851\t          tasksCompleted++;\n852\t        } catch (err: unknown) {\n853\t          const engineError = handleDispatchError(err, taskName, item.key);\n854\t          errors.push(engineError);\n855\t\n856\t          // Record error checkpoint in state (AC #13)\n857\t          state = recordErrorInState(state, taskName, item.key, engineError);\n858\t          writeWorkflowState(state, projectDir);\n859\t\n860\t          // Halt on critical errors, continue on UNKNOWN\n861\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n862\t            halted = true;\n863\t            break;\n864\t          }\n865\t          // UNKNOWN errors: record and continue to next story\n866\t          continue;\n867\t        }\n868\t      }\n869\t    }\n870\t  }\n871\t\n872\t  // 4. Set final phase if no errors and phase not already set by loop termination\n873\t  if (errors.length === 0 && state.phase !== 'max-iterations' && state.phase !== 'circuit-breaker') {\n874\t    state = { ...state, phase: 'completed' };\n875\t    writeWorkflowState(state, projectDir);\n876\t  }\n877\t\n878\t  // 5. Return result\n879\t  const loopTerminated = state.phase === 'max-iterations' || state.phase === 'circuit-breaker';\n880\t  return {\n881\t    success: errors.length === 0 && !loopTerminated,\n882\t    tasksCompleted,\n883\t    storiesProcessed: processedStories.size,\n884\t    errors,\n885\t    durationMs: Date.now() - startMs,\n886\t  };\n887\t}\n888\t\n889\t// --- Error Handling ---\n890\t\n891\t/**\n892\t * Record a dispatch error in workflow state: set phase to \"error\" and append\n893\t * a TaskCheckpoint with the error details (AC #13).\n894\t */\n895\tfunction recordErrorInState(\n896\t  state: WorkflowState,\n897\t  taskName: string,\n898\t  storyKey: string,\n899\t  error: EngineError,\n900\t): WorkflowState {\n901\t  const errorCheckpoint: TaskCheckpoint = {\n902\t    task_name: taskName,\n903\t    story_key: storyKey,\n904\t    completed_at: new Date().toISOString(),\n905\t    error: true,\n906\t  };\n907\t  return {\n908\t    ...state,\n909\t    phase: 'error',\n910\t    tasks_completed: [...state.tasks_completed, errorCheckpoint],\n911\t  };\n912\t}\n913\t\n914\tfunction handleDispatchError(err: unknown, taskName: string, storyKey: string): EngineError {\n915\t  if (err instanceof DispatchError) {\n916\t    return {\n917\t      taskName,\n918\t      storyKey,\n919\t      code: err.code,\n920\t      message: err.message,\n921\t    };\n922\t  }\n923\t\n924\t  const message = err instanceof Error ? err.message : String(err);\n925\t  return {\n926\t    taskName,\n927\t    storyKey,\n928\t    code: 'UNKNOWN',\n929\t    message,\n930\t  };\n931\t}\n932\t"}]},"parent_tool_use_id":"toolu_01J1hA6EdKQNp4qhAx3VLe1g","session_id":"b101ea9e-2f9e-4377-9c5a-f109fa318b32","uuid":"42873616-9ba2-495f-bedf-627b57e6e8a2","timestamp":"2026-04-03T09:41:02.951Z"}
