{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VvT67yUgMRmDcvSeneGvcy","type":"tool_result","content":"1\timport type { ResolvedTask, FlowStep, LoopBlock } from './workflow-parser.js';\n2\t\n3\t// --- Interfaces ---\n4\t\n5\texport interface ExecutionConfig {\n6\t  max_parallel: number;\n7\t  isolation: 'worktree' | 'none';\n8\t  merge_strategy: 'rebase' | 'merge-commit';\n9\t  epic_strategy: 'parallel' | 'sequential';\n10\t  story_strategy: 'sequential' | 'parallel';\n11\t}\n12\t\n13\texport interface HierarchicalFlow {\n14\t  execution: ExecutionConfig;\n15\t  storyFlow: FlowStep[];\n16\t  epicFlow: FlowStep[];\n17\t  tasks: Record<string, ResolvedTask>;\n18\t}\n19\t\n20\t// --- Constants ---\n21\t\n22\t/** Built-in epic flow task names that do not need entries in `tasks:`. */\n23\texport const BUILTIN_EPIC_FLOW_TASKS = new Set(['merge', 'validate']);\n24\t\n25\t/** Default execution configuration values. */\n26\texport const EXECUTION_DEFAULTS: ExecutionConfig = {\n27\t  max_parallel: 1,\n28\t  isolation: 'none',\n29\t  merge_strategy: 'merge-commit',\n30\t  epic_strategy: 'sequential',\n31\t  story_strategy: 'sequential',\n32\t};\n33\t\n34\t/** Valid enum values for execution config fields. */\n35\tconst VALID_ISOLATION = new Set<string>(['worktree', 'none']);\n36\tconst VALID_MERGE_STRATEGY = new Set<string>(['rebase', 'merge-commit']);\n37\tconst VALID_EPIC_STRATEGY = new Set<string>(['parallel', 'sequential']);\n38\tconst VALID_STORY_STRATEGY = new Set<string>(['sequential', 'parallel']);\n39\t\n40\t// --- Resolution ---\n41\t\n42\t/**\n43\t * Resolve a parsed workflow YAML object into a HierarchicalFlow.\n44\t *\n45\t * Handles three cases:\n46\t * 1. Legacy: only `flow` present → normalized to `storyFlow`\n47\t * 2. Hierarchical: `story_flow` (and optionally `epic_flow`, `execution`) present\n48\t * 3. Conflict: both `flow` and `story_flow` → rejected with error\n49\t *\n50\t * This is a pure parsing/normalization function with no side effects.\n51\t */\n52\texport function resolveHierarchicalFlow(\n53\t  parsed: Record<string, unknown>,\n54\t  resolvedTasks: Record<string, ResolvedTask>,\n55\t): HierarchicalFlow {\n56\t  const hasFlow = 'flow' in parsed && parsed.flow !== undefined;\n57\t  const hasStoryFlow = 'story_flow' in parsed && parsed.story_flow !== undefined;\n58\t\n59\t  // Reject coexistence of flow and story_flow\n60\t  if (hasFlow && hasStoryFlow) {\n61\t    throw new HierarchicalFlowError(\n62\t      'Workflow cannot have both \"flow\" and \"story_flow\" — use \"story_flow\" for hierarchical workflows or \"flow\" for legacy mode',\n63\t    );\n64\t  }\n65\t\n66\t  // Resolve execution config with defaults and validation\n67\t  const rawExecution = (parsed.execution != null && typeof parsed.execution === 'object')\n68\t    ? parsed.execution as Record<string, unknown>\n69\t    : {};\n70\t  const execution = resolveExecutionConfig(rawExecution);\n71\t\n72\t  // Resolve story flow\n73\t  const rawStoryFlow = hasStoryFlow ? parsed.story_flow : parsed.flow;\n74\t  const storyFlow: FlowStep[] = normalizeFlowArray(rawStoryFlow);\n75\t\n76\t  // Resolve epic flow\n77\t  const epicFlow: FlowStep[] = normalizeFlowArray(parsed.epic_flow);\n78\t\n79\t  return {\n80\t    execution,\n81\t    storyFlow,\n82\t    epicFlow,\n83\t    tasks: resolvedTasks,\n84\t  };\n85\t}\n86\t\n87\t/**\n88\t * Resolve and validate execution config, applying defaults for missing fields.\n89\t * Rejects invalid enum values with a descriptive error.\n90\t */\n91\tfunction resolveExecutionConfig(raw: Record<string, unknown>): ExecutionConfig {\n92\t  const maxParallel = raw.max_parallel;\n93\t  if (maxParallel !== undefined && (typeof maxParallel !== 'number' || !Number.isInteger(maxParallel) || maxParallel < 1)) {\n94\t    throw new HierarchicalFlowError(\n95\t      `Invalid execution.max_parallel: expected positive integer, got ${JSON.stringify(maxParallel)}`,\n96\t    );\n97\t  }\n98\t\n99\t  if (raw.isolation !== undefined && !VALID_ISOLATION.has(String(raw.isolation))) {\n100\t    throw new HierarchicalFlowError(\n101\t      `Invalid execution.isolation: expected \"worktree\" or \"none\", got ${JSON.stringify(raw.isolation)}`,\n102\t    );\n103\t  }\n104\t\n105\t  if (raw.merge_strategy !== undefined && !VALID_MERGE_STRATEGY.has(String(raw.merge_strategy))) {\n106\t    throw new HierarchicalFlowError(\n107\t      `Invalid execution.merge_strategy: expected \"rebase\" or \"merge-commit\", got ${JSON.stringify(raw.merge_strategy)}`,\n108\t    );\n109\t  }\n110\t\n111\t  if (raw.epic_strategy !== undefined && !VALID_EPIC_STRATEGY.has(String(raw.epic_strategy))) {\n112\t    throw new HierarchicalFlowError(\n113\t      `Invalid execution.epic_strategy: expected \"parallel\" or \"sequential\", got ${JSON.stringify(raw.epic_strategy)}`,\n114\t    );\n115\t  }\n116\t\n117\t  if (raw.story_strategy !== undefined && !VALID_STORY_STRATEGY.has(String(raw.story_strategy))) {\n118\t    throw new HierarchicalFlowError(\n119\t      `Invalid execution.story_strategy: expected \"sequential\" or \"parallel\", got ${JSON.stringify(raw.story_strategy)}`,\n120\t    );\n121\t  }\n122\t\n123\t  return {\n124\t    max_parallel: (maxParallel as number) ?? EXECUTION_DEFAULTS.max_parallel,\n125\t    isolation: (raw.isolation as ExecutionConfig['isolation']) ?? EXECUTION_DEFAULTS.isolation,\n126\t    merge_strategy: (raw.merge_strategy as ExecutionConfig['merge_strategy']) ?? EXECUTION_DEFAULTS.merge_strategy,\n127\t    epic_strategy: (raw.epic_strategy as ExecutionConfig['epic_strategy']) ?? EXECUTION_DEFAULTS.epic_strategy,\n128\t    story_strategy: (raw.story_strategy as ExecutionConfig['story_strategy']) ?? EXECUTION_DEFAULTS.story_strategy,\n129\t  };\n130\t}\n131\t\n132\t/**\n133\t * Normalize an unknown value into a FlowStep array.\n134\t * Returns [] for undefined/null. Validates that each step is a string or loop block.\n135\t */\n136\tfunction normalizeFlowArray(raw: unknown): FlowStep[] {\n137\t  if (raw === undefined || raw === null) return [];\n138\t  if (!Array.isArray(raw)) {\n139\t    throw new HierarchicalFlowError(\n140\t      `Expected flow to be an array, got ${typeof raw}`,\n141\t    );\n142\t  }\n143\t  return raw.map((step: unknown, i: number) => {\n144\t    if (typeof step === 'string') return step;\n145\t    if (typeof step === 'object' && step !== null && 'loop' in step) {\n146\t      const loopVal = (step as Record<string, unknown>).loop;\n147\t      if (!Array.isArray(loopVal) || !loopVal.every((v) => typeof v === 'string')) {\n148\t        throw new HierarchicalFlowError(\n149\t          `Invalid loop block at index ${i}: \"loop\" must be an array of strings`,\n150\t        );\n151\t      }\n152\t      return step as LoopBlock;\n153\t    }\n154\t    throw new HierarchicalFlowError(\n155\t      `Invalid flow step at index ${i}: expected string or loop block, got ${JSON.stringify(step)}`,\n156\t    );\n157\t  });\n158\t}\n159\t\n160\t// --- Error Class ---\n161\t\n162\texport class HierarchicalFlowError extends Error {\n163\t  constructor(message: string) {\n164\t    super(message);\n165\t    this.name = 'HierarchicalFlowError';\n166\t  }\n167\t}\n168\t"}]},"parent_tool_use_id":"toolu_01QNNr4yQoQQfPTTg7FsQuMG","session_id":"e648a229-0e5b-4ea4-9861-593afdfcccd5","uuid":"f431513d-cc67-4be3-9993-1459f7a9b2a4","timestamp":"2026-04-03T19:02:05.397Z"}
