{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01H1WFfXBKuX6YGxrG3HMMeH","type":"tool_result","content":"1\timport { mkdirSync, copyFileSync, existsSync, rmSync } from 'node:fs';\n2\timport { join, basename } from 'node:path';\n3\timport { warn } from './output.js';\n4\timport type { DispatchOptions } from './agent-dispatch.js';\n5\t\n6\t// --- Interfaces ---\n7\t\n8\t/**\n9\t * Options for creating an isolated workspace.\n10\t */\n11\texport interface IsolationOptions {\n12\t  /** Unique run identifier used in the temp directory name. */\n13\t  runId: string;\n14\t  /** Absolute paths to story files to copy into the workspace. */\n15\t  storyFiles: string[];\n16\t}\n17\t\n18\t/**\n19\t * An isolated workspace with no source code — only story files and a verdict directory.\n20\t */\n21\texport interface IsolatedWorkspace {\n22\t  /** Root directory of the isolated workspace. */\n23\t  dir: string;\n24\t  /** Directory containing copied story files. */\n25\t  storyFilesDir: string;\n26\t  /** Directory where the evaluator writes its verdict. */\n27\t  verdictDir: string;\n28\t  /** Returns DispatchOptions with cwd set to this workspace. */\n29\t  toDispatchOptions(): DispatchOptions;\n30\t  /** Remove the workspace from disk. Idempotent — safe to call multiple times. */\n31\t  cleanup(): Promise<void>;\n32\t}\n33\t\n34\t// --- Helpers ---\n35\t\n36\t/** Sanitize runId to prevent path traversal — allow only alphanumeric, dash, underscore, dot. */\n37\tfunction sanitizeRunId(runId: string): string {\n38\t  // Replace disallowed characters with underscores\n39\t  let sanitized = runId.replace(/[^a-zA-Z0-9._-]/g, '_');\n40\t  // Strip leading dots to prevent \"..\" path traversal\n41\t  sanitized = sanitized.replace(/^\\.+/, '');\n42\t  if (sanitized.length === 0) {\n43\t    throw new Error('Source isolation: runId is empty after sanitization');\n44\t  }\n45\t  return sanitized;\n46\t}\n47\t\n48\t/** Deduplicate a filename within a directory by appending a numeric suffix. */\n49\tfunction deduplicateFilename(dir: string, name: string): string {\n50\t  if (!existsSync(join(dir, name))) {\n51\t    return name;\n52\t  }\n53\t  const dotIdx = name.lastIndexOf('.');\n54\t  const stem = dotIdx > 0 ? name.slice(0, dotIdx) : name;\n55\t  const ext = dotIdx > 0 ? name.slice(dotIdx) : '';\n56\t  let counter = 1;\n57\t  let candidate: string;\n58\t  do {\n59\t    candidate = `${stem}-${counter}${ext}`;\n60\t    counter++;"}]},"parent_tool_use_id":"toolu_011dV6c9xFAQaHP6KDdoVM36","session_id":"7bb08296-a865-42eb-9710-ebdb6ccedbda","uuid":"9f2313ed-ff9d-4c2f-af9b-aa906623e5de","timestamp":"2026-04-02T21:55:25.813Z"}
