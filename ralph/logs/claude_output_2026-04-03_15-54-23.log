{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G6dypSWWmvPCwtfQtMR7jL","type":"tool_result","content":"0\timport { describe, it, expect, afterEach, vi } from 'vitest';\n1\timport { render } from 'ink-testing-library';\n2\timport React from 'react';\n3\timport { startRenderer } from '../ink-renderer.js';\n4\timport type { RendererHandle } from '../ink-renderer.js';\n5\timport type { StreamEvent } from '../agents/stream-parser.js';\n6\timport {\n7\t  App,\n8\t  Header,\n9\t  Separator,\n10\t  CompletedTool,\n11\t  ActiveTool,\n12\t  LastThought,\n13\t  RetryNotice,\n14\t  StoryBreakdown,\n15\t  StoryMessageLine,\n16\t  type RendererState,\n17\t  type SprintInfo,\n18\t  type CompletedToolEntry,\n19\t  type StoryStatusEntry,\n20\t  type StoryMessage,\n21\t} from '../ink-components.js';\n22\t\n23\t// --- Helpers ---\n24\t\n25\tfunction makeState(overrides?: Partial<RendererState>): RendererState {\n26\t  return {\n27\t    sprintInfo: null,\n28\t    stories: [],\n29\t    messages: [],\n30\t    completedTools: [],\n31\t    activeTool: null,\n32\t    activeToolArgs: '',\n33\t    lastThought: null,\n34\t    retryInfo: null,\n35\t    workflowFlow: [],\n36\t    currentTaskName: null,\n37\t    taskStates: {},\n38\t    taskMeta: {},\n39\t    ...overrides,\n40\t  };\n41\t}\n42\t\n43\t// --- Component Tests (using ink-testing-library) ---\n44\t\n45\tdescribe('Header component', () => {\n46\t  it('renders plain text header line (no Box border, no diamond prefix)', () => {\n47\t    const info: SprintInfo = {\n48\t      storyKey: '0-5-3',\n49\t      phase: 'dev',"}]},"parent_tool_use_id":"toolu_0156ZxQEd4RjGj7cfTpUYE1h","session_id":"a29ee53b-c2b0-4802-9455-7215112648b1","uuid":"89863ff6-9336-4fdd-8de5-2bf0393e169b","timestamp":"2026-04-03T12:03:40.084Z"}
