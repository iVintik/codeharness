{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015drG6ndGFVjBZ95q2RaEEx","type":"tool_result","content":"1\timport { Command } from 'commander';\n2\timport { existsSync, readFileSync } from 'node:fs';\n3\timport { join } from 'node:path';\n4\timport { ok, fail, info, warn, jsonOutput } from '../lib/output.js';\n5\timport { parseRetroActionItems, classifyFinding, parseRetroSections, isDuplicate, derivePriority } from '../lib/retro-parser.js';\n6\timport { createIssue, readIssues } from '../lib/issue-tracker.js';\n7\timport { isGhAvailable, findExistingGhIssue, ghIssueCreate, ensureLabels, getRepoFromRemote } from '../lib/github.js';\n8\timport { readState, StateFileNotFoundError } from '../lib/state.js';\n9\timport type { Classification } from '../lib/retro-parser.js';\n10\timport type { RetroIssueTarget } from '../lib/github.js';\n11\t\n12\tconst STORY_DIR = '_bmad-output/implementation-artifacts';\n13\t\n14\t/** Maximum length for issue titles derived from action item descriptions. */\n15\tconst MAX_TITLE_LENGTH = 120;\n16\t\n17\tinterface ImportedIssue {\n18\t  number: string;\n19\t  title: string;\n20\t  gapId: string;\n21\t  classification: string;\n22\t  created: boolean;\n23\t  status: string;\n24\t  notes: string;\n25\t}\n26\t\n27\tinterface LocalImportResult {\n28\t  imported: number;\n29\t  skipped: number;\n30\t  duplicates: number;\n31\t  issues: Array<{ id: string; title: string; source: string; priority: string }>;\n32\t}\n33\t\n34\tinterface GitHubResult {\n35\t  created: number;\n36\t  skipped: number;\n37\t  errors: number;\n38\t}\n39\t\n40\tfunction classificationToString(c: Classification): string {\n41\t  if (c.type === 'tool') {\n42\t    return `tool:${c.name}`;\n43\t  }\n44\t  return c.type;\n45\t}\n46\t\n47\texport function registerRetroImportCommand(program: Command): void {\n48\t  program\n49\t    .command('retro-import')\n50\t    .description('Import retrospective action items as GitHub issues')\n51\t    .requiredOption('--epic <n>', 'Epic number to import action items from')\n52\t    .action((opts, cmd) => {\n53\t      const globalOpts = cmd.optsWithGlobals();\n54\t      const isJson = globalOpts.json === true;\n55\t      const root = process.cwd();\n56\t\n57\t      // Validate epic number\n58\t      const epicNum = parseInt(opts.epic, 10);\n59\t      if (isNaN(epicNum) || epicNum < 1) {\n60\t        fail(`Invalid epic number: ${opts.epic}`, { json: isJson });\n61\t        process.exitCode = 1;\n62\t        return;\n63\t      }\n64\t\n65\t      // Read retro file\n66\t      const retroFile = `epic-${epicNum}-retrospective.md`;\n67\t      const retroPath = join(root, STORY_DIR, retroFile);\n68\t\n69\t      if (!existsSync(retroPath)) {\n70\t        fail(`Retro file not found: ${retroFile}`, { json: isJson });\n71\t        process.exitCode = 1;\n72\t        return;\n73\t      }\n74\t\n75\t      let content: string;\n76\t      try {\n77\t        content = readFileSync(retroPath, 'utf-8');\n78\t      } catch (err: unknown) {\n79\t        const message = err instanceof Error ? err.message : String(err);\n80\t        fail(`Failed to read retro file: ${message}`, { json: isJson });\n81\t        process.exitCode = 1;\n82\t        return;\n83\t      }\n84\t\n85\t      // ─── Local issues.yaml import ──────────────────────────────────────\n86\t      const localResult = importToIssuesYaml(content, epicNum, root, isJson);\n87\t\n88\t      // Parse table-based action items for GitHub phase\n89\t      const items = parseRetroActionItems(content);\n90\t\n91\t      // If both parsers found nothing, report and exit\n92\t      if (items.length === 0 && localResult.imported === 0 && localResult.skipped === 0 && localResult.duplicates === 0) {\n93\t        if (isJson) {\n94\t          jsonOutput({ imported: 0, skipped: 0, duplicates: 0, issues: [] });\n95\t        } else {\n96\t          info('No action items found in retro file');\n97\t        }\n98\t        return;\n99\t      }\n100\t\n101\t      const issues: ImportedIssue[] = [];\n102\t\n103\t      for (const item of items) {\n104\t        const classification = classifyFinding(item);\n105\t        const gapId = `[gap:retro:epic-${epicNum}-item-${item.number}]`;\n106\t\n107\t        // Truncate title to reasonable length\n108\t        const title =\n109\t          item.description.length > MAX_TITLE_LENGTH\n110\t            ? item.description.slice(0, MAX_TITLE_LENGTH - 3) + '...'\n111\t            : item.description;\n112\t\n113\t        const issueRecord: ImportedIssue = {\n114\t          number: item.number,\n115\t          title,\n116\t          gapId,\n117\t          classification: classificationToString(classification),\n118\t          created: false,\n119\t          status: item.status,\n120\t          notes: item.notes,\n121\t        };\n122\t\n123\t        issues.push(issueRecord);\n124\t\n125\t        if (!isJson) {\n126\t          info(`Parsed: ${title}`);\n127\t        }\n128\t      }\n129\t\n130\t      // ─── GitHub Issue Creation Phase ────────────────────────────────────\n131\t      const githubResult = createGitHubIssues(issues, epicNum, isJson);\n132\t\n133\t      if (isJson) {\n134\t        jsonOutput({\n135\t          imported: localResult.imported,\n136\t          skipped: localResult.skipped,\n137\t          duplicates: localResult.duplicates,\n138\t          issues: localResult.issues as unknown as Record<string, unknown>[],\n139\t          github: githubResult as unknown as Record<string, unknown>,\n140\t        });\n141\t      }\n142\t    });\n143\t}\n144\t\n145\t/**\n146\t * Import retro action items into `.codeharness/issues.yaml`.\n147\t * Tries section-based parsing first, falls back to table-based parsing.\n148\t */\n149\tfunction importToIssuesYaml(\n150\t  content: string,\n151\t  epicNum: number,\n152\t  dir: string,\n153\t  isJson: boolean,\n154\t): LocalImportResult {\n155\t  const source = `retro-epic-${epicNum}`;\n156\t  const result: LocalImportResult = { imported: 0, skipped: 0, duplicates: 0, issues: [] };\n157\t\n158\t  // Read existing issue titles for dedup\n159\t  const existingIssues = readIssues(dir);\n160\t  const existingTitles = existingIssues.issues.map(i => i.title);\n161\t\n162\t  // Strategy: try section-based first, fall back to table-based\n163\t  const sectionItems = parseRetroSections(content);\n164\t  const actionableSections = sectionItems.filter(i => i.section !== 'backlog');\n165\t  const backlogSections = sectionItems.filter(i => i.section === 'backlog');\n166\t\n167\t  if (actionableSections.length > 0 || backlogSections.length > 0) {\n168\t    // Section-based format found\n169\t    for (const item of backlogSections) {\n170\t      result.skipped++;\n171\t      if (!isJson) {\n172\t        info(`Skipped (backlog — non-actionable): ${item.text}`);\n173\t      }\n174\t    }\n175\t\n176\t    for (const item of actionableSections) {\n177\t      const priority = item.section === 'fix-now' ? 'high' : 'medium';\n178\t\n179\t      // Check for duplicates\n180\t      const dupCheck = isDuplicate(item.text, existingTitles);\n181\t      if (dupCheck.duplicate) {\n182\t        result.duplicates++;\n183\t        if (!isJson) {\n184\t          info(`Skipped (duplicate of \"${dupCheck.matchedTitle}\"): ${item.text}`);\n185\t        }\n186\t        continue;\n187\t      }\n188\t\n189\t      const issue = createIssue(item.text, { priority, source }, dir);\n190\t      existingTitles.push(issue.title);\n191\t      result.imported++;\n192\t      result.issues.push({ id: issue.id, title: issue.title, source: issue.source, priority: issue.priority });\n193\t\n194\t      if (!isJson) {\n195\t        ok(`Imported [${issue.id}] (${priority}): ${item.text}`);\n196\t      }\n197\t    }\n198\t\n199\t    return result;\n200\t  }\n201\t\n202\t  // Fall back to table-based parsing\n203\t  const tableItems = parseRetroActionItems(content);\n204\t\n205\t  if (tableItems.length === 0) {\n206\t    return result;\n207\t  }\n208\t\n209\t  for (const item of tableItems) {\n210\t    const priorityNum = derivePriority(item);\n211\t    const priority = priorityNum === 1 ? 'high' : 'medium';\n212\t\n213\t    // Check for duplicates\n214\t    const dupCheck = isDuplicate(item.description, existingTitles);\n215\t    if (dupCheck.duplicate) {\n216\t      result.duplicates++;\n217\t      if (!isJson) {\n218\t        info(`Skipped (duplicate of \"${dupCheck.matchedTitle}\"): ${item.description}`);\n219\t      }\n220\t      continue;\n221\t    }\n222\t\n223\t    const issue = createIssue(item.description, { priority, source }, dir);\n224\t    existingTitles.push(issue.title);\n225\t    result.imported++;\n226\t    result.issues.push({ id: issue.id, title: issue.title, source: issue.source, priority: issue.priority });\n227\t\n228\t    if (!isJson) {\n229\t      ok(`Imported [${issue.id}] (${priority}): ${item.description}`);\n230\t    }\n231\t  }\n232\t\n233\t  return result;\n234\t}\n235\t\n236\t/**\n237\t * Resolves the target repo for a classification based on retro_issue_targets config.\n238\t */\n239\tfunction resolveTargetRepo(\n240\t  classification: string,\n241\t  targets: RetroIssueTarget[],\n242\t): RetroIssueTarget | undefined {\n243\t  if (targets.length === 0) return undefined;\n244\t\n245\t  if (classification === 'harness') {\n246\t    // Prefer explicit codeharness repo, then first non-auto, then auto as fallback\n247\t    const explicit = targets.find(t => t.repo === 'iVintik/codeharness');\n248\t    if (explicit) return explicit;\n249\t    const nonAuto = targets.find(t => t.repo !== 'auto');\n250\t    if (nonAuto) return nonAuto;\n251\t    return targets[0];\n252\t  }\n253\t\n254\t  // project or tool:* → prefer auto, else first target\n255\t  const auto = targets.find(t => t.repo === 'auto');\n256\t  if (auto) return auto;\n257\t  return targets[0];\n258\t}\n259\t\n260\t/**\n261\t * Builds the GitHub issue body with retro context and gap-id for dedup.\n262\t */\n263\tfunction buildGitHubIssueBody(\n264\t  item: ImportedIssue,\n265\t  epicNum: number,\n266\t  projectName: string,\n267\t): string {\n268\t  return `## Retro Action Item ${item.number} — Epic ${epicNum}\n269\t\n270\t**Source project:** ${projectName}\n271\t**Classification:** ${item.classification}\n272\t**Original status:** ${item.status}\n273\t**Notes:** ${item.notes}\n274\t\n275\t${item.title}\n276\t\n277\t<!-- gap-id: ${item.gapId} -->`;\n278\t}\n279\t\n280\t/**\n281\t * GitHub issue creation phase.\n282\t */\n283\tfunction createGitHubIssues(\n284\t  issues: ImportedIssue[],\n285\t  epicNum: number,\n286\t  isJson: boolean,\n287\t): GitHubResult | undefined {\n288\t  // Read state to check for retro_issue_targets\n289\t  let targets: RetroIssueTarget[] | undefined;\n290\t  try {\n291\t    const state = readState();\n292\t    targets = state.retro_issue_targets;\n293\t  } catch (err: unknown) {\n294\t    if (err instanceof StateFileNotFoundError) {\n295\t      if (!isJson) {\n296\t        info('No state file found — skipping GitHub issues');\n297\t      }\n298\t      return undefined;\n299\t    }\n300\t    // Other state errors — skip GitHub phase gracefully\n301\t    if (!isJson) {\n302\t      info('Could not read state file — skipping GitHub issues');\n303\t    }\n304\t    return undefined;\n305\t  }\n306\t\n307\t  if (!targets || targets.length === 0) {\n308\t    if (!isJson) {\n309\t      info('No retro_issue_targets configured — skipping GitHub issues');\n310\t    }\n311\t    return undefined;\n312\t  }\n313\t\n314\t  // Check gh CLI availability\n315\t  if (!isGhAvailable()) {\n316\t    if (!isJson) {\n317\t      warn('gh CLI not available — skipping GitHub issue creation');\n318\t    }\n319\t    return undefined;\n320\t  }\n321\t\n322\t  // Resolve \"auto\" repos\n323\t  const resolvedAutoRepo = getRepoFromRemote();\n324\t\n325\t  const result: GitHubResult = { created: 0, skipped: 0, errors: 0 };\n326\t\n327\t  // Detect project name from git remote\n328\t  const projectName = resolvedAutoRepo ?? 'unknown';\n329\t\n330\t  for (const item of issues) {\n331\t    const target = resolveTargetRepo(item.classification, targets);\n332\t    if (!target) continue;\n333\t\n334\t    // Resolve actual repo name\n335\t    const repo = target.repo === 'auto' ? resolvedAutoRepo : target.repo;\n336\t    if (!repo) {\n337\t      if (!isJson) {\n338\t        warn(`Cannot resolve repo for ${item.number} — git remote not detected`);\n339\t      }\n340\t      result.errors++;\n341\t      continue;\n342\t    }\n343\t\n344\t    try {\n345\t      // Check for existing issue (dedup)\n346\t      const existing = findExistingGhIssue(repo, item.gapId);\n347\t      if (existing) {\n348\t        if (!isJson) {\n349\t          info(`GitHub issue exists: ${repo}#${existing.number}`);\n350\t        }\n351\t        result.skipped++;\n352\t        continue;\n353\t      }\n354\t\n355\t      // Ensure labels exist\n356\t      ensureLabels(repo, target.labels);\n357\t\n358\t      // Create the issue\n359\t      const body = buildGitHubIssueBody(item, epicNum, projectName);\n360\t      const created = ghIssueCreate(repo, item.title, body, target.labels);\n361\t      if (!isJson) {\n362\t        ok(`GitHub issue created: ${repo}#${created.number}`);\n363\t      }\n364\t      result.created++;\n365\t    } catch (err: unknown) {\n366\t      const message = err instanceof Error ? err.message : String(err);\n367\t      if (!isJson) {\n368\t        fail(`GitHub issue failed for ${item.number}: ${message}`);\n369\t      }\n370\t      result.errors++;\n371\t    }\n372\t  }\n373\t\n374\t  return result;\n375\t}\n376\t"}]},"parent_tool_use_id":"toolu_01U1QxzZy7C659GJM4oxEmEf","session_id":"3f15b50c-2c9b-40fa-9e63-9fad2199af43","uuid":"2b7197c7-f71f-4c00-b085-442a57f79d1d","timestamp":"2026-04-03T02:27:41.813Z"}
