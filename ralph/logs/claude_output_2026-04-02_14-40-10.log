{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017oNYYDisxvvDHspcRSsg6B","type":"tool_result","content":"1\t{\n2\t  \"name\": \"codeharness\",\n3\t  \"version\": \"0.26.5\",\n4\t  \"type\": \"module\",\n5\t  \"description\": \"CLI for codeharness — makes autonomous coding agents produce software that actually works\",\n6\t  \"bin\": {\n7\t    \"codeharness\": \"dist/index.js\"\n8\t  },\n9\t  \"files\": [\n10\t    \"dist\",\n11\t    \"bin\",\n12\t    \"patches\",\n13\t    \"templates/Dockerfile.verify\",\n14\t    \"templates/Dockerfile.verify.rust\",\n15\t    \"templates/Dockerfile.verify.generic\",\n16\t    \"templates/dockerfiles/\",\n17\t    \"templates/compose/\",\n18\t    \"templates/prompts/\",\n19\t    \"templates/docs/\",\n20\t    \"templates/otlp/\"\n21\t  ],\n22\t  \"repository\": {\n23\t    \"type\": \"git\",\n24\t    \"url\": \"https://github.com/iVintik/codeharness.git\"\n25\t  },\n26\t  \"license\": \"MIT\",\n27\t  \"engines\": {\n28\t    \"node\": \">=18\"\n29\t  },\n30\t  \"scripts\": {\n31\t    \"build\": \"tsup\",\n32\t    \"test\": \"bats tests/\",\n33\t    \"test:unit\": \"vitest run\",\n34\t    \"test:coverage\": \"vitest run --coverage\",\n35\t    \"lint\": \"eslint src/\",\n36\t    \"lint:sizes\": \"bash scripts/check-file-sizes.sh\"\n37\t  },\n38\t  \"dependencies\": {\n39\t    \"@inkjs/ui\": \"^2.0.0\",\n40\t    \"commander\": \"^14.0.3\",\n41\t    \"ink\": \"^6.8.0\",\n42\t    \"react\": \"^19.2.4\",\n43\t    \"yaml\": \"^2.8.2\"\n44\t  },\n45\t  \"devDependencies\": {\n46\t    \"@eslint/js\": \"^10.0.1\",\n47\t    \"@opentelemetry/auto-instrumentations-node\": \"^0.71.0\",\n48\t    \"@opentelemetry/exporter-logs-otlp-http\": \"^0.213.0\",\n49\t    \"@opentelemetry/exporter-metrics-otlp-http\": \"^0.213.0\",\n50\t    \"@opentelemetry/exporter-trace-otlp-http\": \"^0.213.0\",\n51\t    \"@types/node\": \"^25.5.0\",\n52\t    \"@types/react\": \"^19.2.14\",\n53\t    \"@vitest/coverage-v8\": \"^4.1.0\",\n54\t    \"eslint\": \"^10.1.0\",\n55\t    \"ink-testing-library\": \"^4.0.0\",\n56\t    \"tsup\": \"^8.5.1\",\n57\t    \"typescript\": \"^5.9.3\",\n58\t    \"typescript-eslint\": \"^8.57.2\",\n59\t    \"vitest\": \"^4.1.0\"\n60\t  }\n61\t}\n62\t"}]},"parent_tool_use_id":"toolu_01YBKjSQmG6oMvDHLp8ma2Uz","session_id":"aeb5b1ee-06a7-4bdc-8279-6cd22d306d14","uuid":"8e625f00-4664-49b8-a154-4610c824d8f2","timestamp":"2026-04-02T10:55:53.239Z"}
