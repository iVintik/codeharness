{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LPhLbz2qxrC432XzKeAksz","type":"tool_result","content":"1\timport { mkdirSync, copyFileSync, existsSync, rmSync } from 'node:fs';\n2\timport { join, basename } from 'node:path';\n3\timport { warn } from './output.js';\n4\timport type { DispatchOptions } from './agent-dispatch.js';\n5\t\n6\t// --- Interfaces ---\n7\t\n8\t/**\n9\t * Options for creating an isolated workspace.\n10\t */\n11\texport interface IsolationOptions {\n12\t  /** Unique run identifier used in the temp directory name. */\n13\t  runId: string;\n14\t  /** Absolute paths to story files to copy into the workspace. */\n15\t  storyFiles: string[];\n16\t}\n17\t\n18\t/**\n19\t * An isolated workspace with no source code — only story files and a verdict directory.\n20\t */\n21\texport interface IsolatedWorkspace {\n22\t  /** Root directory of the isolated workspace. */\n23\t  dir: string;\n24\t  /** Directory containing copied story files. */\n25\t  storyFilesDir: string;\n26\t  /** Directory where the evaluator writes its verdict. */\n27\t  verdictDir: string;\n28\t  /** Returns DispatchOptions with cwd set to this workspace. */\n29\t  toDispatchOptions(): DispatchOptions;\n30\t  /** Remove the workspace from disk. Idempotent — safe to call multiple times. */\n31\t  cleanup(): Promise<void>;\n32\t}\n33\t\n34\t// --- Implementation ---\n35\t\n36\t/**\n37\t * Create an isolated workspace at /tmp/codeharness-verify-{runId}/.\n38\t *\n39\t * The workspace contains only:\n40\t *   - story-files/  — copies of the provided story files\n41\t *   - verdict/      — empty directory for evaluator output\n42\t *\n43\t * No source code, node_modules, package.json, or .git is present.\n44\t * Missing story files are skipped with a warning (no throw).\n45\t */\n46\texport async function createIsolatedWorkspace(\n47\t  options: IsolationOptions,\n48\t): Promise<IsolatedWorkspace> {\n49\t  const dir = `/tmp/codeharness-verify-${options.runId}`;\n50\t  const storyFilesDir = join(dir, 'story-files');\n51\t  const verdictDir = join(dir, 'verdict');\n52\t\n53\t  // Create directory structure\n54\t  mkdirSync(storyFilesDir, { recursive: true });\n55\t  mkdirSync(verdictDir, { recursive: true });\n56\t\n57\t  // Copy story files, skipping missing ones\n58\t  for (const filePath of options.storyFiles) {\n59\t    if (!existsSync(filePath)) {\n60\t      warn(`Source isolation: story file not found, skipping: ${filePath}`);\n61\t      continue;\n62\t    }\n63\t    const dest = join(storyFilesDir, basename(filePath));\n64\t    copyFileSync(filePath, dest);\n65\t  }\n66\t\n67\t  const workspace: IsolatedWorkspace = {\n68\t    dir,\n69\t    storyFilesDir,\n70\t    verdictDir,\n71\t\n72\t    toDispatchOptions(): DispatchOptions {\n73\t      return { cwd: dir };\n74\t    },\n75\t\n76\t    async cleanup(): Promise<void> {\n77\t      if (existsSync(dir)) {\n78\t        rmSync(dir, { recursive: true, force: true });\n79\t      }\n80\t    },\n81\t  };\n82\t\n83\t  return workspace;\n84\t}\n85\t"}]},"parent_tool_use_id":"toolu_016VHKytFCmN6FUa3CVJara9","session_id":"1d3ed03d-179a-4015-85c3-0be0521b6265","uuid":"8b4e8f00-b81d-4bf8-9226-33be52f3d35e","timestamp":"2026-04-02T21:20:25.859Z"}
