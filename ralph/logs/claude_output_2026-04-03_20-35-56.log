{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018GNo4vFSohQoAjLBN88e8R","type":"tool_result","content":"318\t    // 4x margin (200ms vs 50ms) provides reliable assertion even under CI load.\n319\t    await expect(checkDriverHealth(workflow, 50)).rejects.toThrow('Driver health check timed out');\n320\t  });\n321\t\n322\t  it('timeout error reports only drivers that did not respond', async () => {\n323\t    const workflow: ResolvedWorkflow = {\n324\t      tasks: {\n325\t        task1: makeTask({ driver: 'fast-driver' }),\n326\t        task2: makeTask({ driver: 'slow-driver' }),\n327\t      },\n328\t      flow: ['task1', 'task2'],\n329\t    };\n330\t\n331\t    // fast-driver resolves instantly; slow-driver hangs\n332\t    const fastDriver = {\n333\t      name: 'fast-driver',\n334\t      defaultModel: 'test-model',\n335\t      capabilities: { supportsPlugins: false, supportsStreaming: true, costReporting: true, costTier: 1 },\n336\t      healthCheck: vi.fn().mockResolvedValue(makeHealthy()),\n337\t      dispatch: vi.fn(),\n338\t      getLastCost: vi.fn().mockReturnValue(null),\n339\t    };\n340\t    const slowDriver = {\n341\t      name: 'slow-driver',\n342\t      defaultModel: 'test-model',\n343\t      capabilities: { supportsPlugins: false, supportsStreaming: true, costReporting: true, costTier: 1 },\n344\t      healthCheck: vi.fn().mockImplementation(() => new Promise(() => { /* never resolves */ })),\n345\t      dispatch: vi.fn(),\n346\t      getLastCost: vi.fn().mockReturnValue(null),\n347\t    };\n348\t\n349\t    mockGetDriver.mockImplementation((name: string) => {\n350\t      if (name === 'fast-driver') return fastDriver;\n351\t      if (name === 'slow-driver') return slowDriver;\n352\t      throw new Error(`Unknown driver: ${name}`);\n353\t    });\n354\t\n355\t    const err = await checkDriverHealth(workflow, 50).catch((e: Error) => e);\n356\t    expect(err).toBeInstanceOf(Error);\n357\t    // Should mention the slow driver that didn't