{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UiAAPYFYrFM3MCCmCi9wga","type":"tool_result","content":"     1→import { execFileSync } from 'node:child_process';\n     2→import { ok, fail as failOutput, info } from './output.js';\n     3→\n     4→export interface InstallCommand {\n     5→  cmd: string;\n     6→  args: string[];\n     7→}\n     8→\n     9→export interface DependencySpec {\n    10→  name: string;\n    11→  displayName: string;\n    12→  installCommands: InstallCommand[];\n    13→  checkCommand: InstallCommand;\n    14→  critical: boolean;\n    15→}\n    16→\n    17→export interface DependencyResult {\n    18→  name: string;\n    19→  displayName: string;\n    20→  status: 'installed' | 'already-installed' | 'skipped' | 'failed';\n    21→  version: string | null;\n    22→  error?: string;\n    23→}\n    24→\n    25→export const DEPENDENCY_REGISTRY: readonly DependencySpec[] = [\n    26→  {\n    27→    name: 'showboat',\n    28→    displayName: 'Showboat',\n    29→    installCommands: [\n    30→      { cmd: 'pip', args: ['install', 'showboat'] },\n    31→      { cmd: 'pipx', args: ['install', 'showboat'] },\n    32→    ],\n    33→    checkCommand: { cmd: 'showboat', args: ['--version'] },\n    34→    critical: false,\n    35→  },\n    36→  {\n    37→    name: 'agent-browser',\n    38→    displayName: 'agent-browser',\n    39→    installCommands: [\n    40→      { cmd: 'npm', args: ['install', '-g', '@anthropic/agent-browser'] },\n    41→    ],\n    42→    checkCommand: { cmd: 'agent-browser', args: ['--version'] },\n    43→    critical: false,\n    44→  },\n    45→  {\n    46→    name: 'beads',\n    47→    displayName: 'beads',\n    48→    installCommands: [\n    49→      { cmd: 'pip', args: ['install', 'beads'] },\n    50→      { cmd: 'pipx', args: ['install', 'beads'] },\n    51→    ],\n    52→    checkCommand: { cmd: 'bd', args: ['--version'] },\n    53→    critical: false,\n    54→  },\n    55→];\n    56→\n    57→export function checkInstalled(spec: DependencySpec): { installed: boolean; version: string | null } {\n    58→  try {\n    59→    const output = execFileSync(spec.checkCommand.cmd, spec.checkCommand.args, { stdio: 'pipe', timeout: 15_000 }).toString().trim();\n    60→    const version = parseVersion(output);\n    61→    return { installed: true, version };\n    62→  } catch {\n    63→    return { installed: false, version: null };\n    64→  }\n    65→}\n    66→\n    67→export function parseVersion(output: string): string | null {\n    68→  const match = /(\\d+\\.\\d+[\\w.-]*)/.exec(output);\n    69→  return match ? match[1] : null;\n    70→}\n    71→\n    72→export function installDependency(spec: DependencySpec): DependencyResult {\n    73→  // Check if already installed\n    74→  const check = checkInstalled(spec);\n    75→  if (check.installed) {\n    76→    return {\n    77→      name: spec.name,\n    78→      displayName: spec.displayName,\n    79→      status: 'already-installed',\n    80→      version: check.version,\n    81→    };\n    82→  }\n    83→\n    84→  // Try each install command in the fallback chain\n    85→  for (const installCmd of spec.installCommands) {\n    86→    try {\n    87→      execFileSync(installCmd.cmd, installCmd.args, { stdio: 'pipe', timeout: 300_000 });\n    88→\n    89→      // Verify installation succeeded by checking version\n    90→      const postCheck = checkInstalled(spec);\n    91→      if (postCheck.installed) {\n    92→        return {\n    93→          name: spec.name,\n    94→          displayName: spec.displayName,\n    95→          status: 'installed',\n    96→          version: postCheck.version,\n    97→        };\n    98→      }\n    99→    } catch {\n   100→      // Try next fallback\n   101→      continue;\n   102→    }\n   103→  }\n   104→\n   105→  // All install commands failed\n   106→  const remedy = spec.installCommands.map(c => [c.cmd, ...c.args].join(' ')).join(' or ');\n   107→  return {\n   108→    name: spec.name,\n   109→    displayName: spec.displayName,\n   110→    status: 'failed',\n   111→    version: null,\n   112→    error: `Install failed. Try: ${remedy}`,\n   113→  };\n   114→}\n   115→\n   116→export function installAllDependencies(opts: { json?: boolean }): DependencyResult[] {\n   117→  const results: DependencyResult[] = [];\n   118→\n   119→  for (const spec of DEPENDENCY_REGISTRY) {\n   120→    const result = installDependency(spec);\n   121→    results.push(result);\n   122→\n   123→    if (!opts.json) {\n   124→      if (result.status === 'installed') {\n   125→        const versionStr = result.version ? ` (v${result.version})` : '';\n   126→        ok(`${spec.displayName}: installed${versionStr}`);\n   127→      } else if (result.status === 'already-installed') {\n   128→        const versionStr = result.version ? ` (v${result.version})` : '';\n   129→        ok(`${spec.displayName}: already installed${versionStr}`);\n   130→      } else if (result.status === 'failed') {\n   131→        failOutput(`${spec.displayName}: install failed. ${result.error ?? ''}`);\n   132→        if (!spec.critical) {\n   133→          info(`${spec.displayName} is optional — continuing without it`);\n   134→        }\n   135→      }\n   136→    }\n   137→\n   138→    if (result.status === 'failed' && spec.critical) {\n   139→      throw new CriticalDependencyError(spec.displayName, result.error ?? 'Install failed');\n   140→    }\n   141→  }\n   142→\n   143→  return results;\n   144→}\n   145→\n   146→export class CriticalDependencyError extends Error {\n   147→  constructor(\n   148→    public readonly dependencyName: string,\n   149→    public readonly reason: string,\n   150→  ) {\n   151→    super(`Critical dependency '${dependencyName}' failed to install: ${reason}`);\n   152→    this.name = 'CriticalDependencyError';\n   153→  }\n   154→}\n   155→"}]},"parent_tool_use_id":"toolu_01FVdVXwr4A1SuLMz7rmo6Vd","session_id":"02b06ad8-9233-430d-bd8e-764032ea190c","uuid":"41