alues\n123\t  const normalizedTier: VerificationTier | null = rawTierValue\n124\t    ? (LEGACY_TIER_MAP[rawTierValue] as VerificationTier | undefined) ?? (TIER_HIERARCHY.includes(rawTierValue as VerificationTier) ? rawTierValue as VerificationTier : null)\n125\t    : null;\n126\t  // Only environment-provable requires Docker evidence; all others skip\n127\t  const skipDockerEnforcement = normalizedTier !== null && normalizedTier !== 'environment-provable';\n128\t  // Always compute metrics for diagnostics; override blackBoxPass when skipping\n129\t  const bbRawEnforcement = checkBlackBoxEnforcement(content);\n130\t  const bbEnforcement = skipDockerEnforcement\n131\t    ? { ...bbRawEnforcement, blackBoxPass: true }\n132\t    : bbRawEnforcement;\n133\t\n134\t  /** Helper: merge base counts with black-box metrics */\n135\t  function buildResult(base: {\n136\t    verified: number; pending: number; escalated: number; total: number;\n137\t  }): ProofQuality {\n138\t    const basePassed = base.pending === 0 && base.verified > 0;\n139\t    return {\n140\t      ...base,\n141\t      passed: basePassed && bbEnforcement.blackBoxPass,\n142\t      grepSrcCount: bbEnforcement.grepSrcCount,\n143\t      dockerExecCount: bbEnforcement.dockerExecCount,\n144\t      observabilityCount: bbEnforcement.observabilityCount,\n145\t      otherCount: bbEnforcement.otherCount,\n146\t      blackBoxPass: bbEnforcement.blackBoxPass,\n147\t    };\n148\t  }\n149\t\n150\t  // Format 1: ## AC N: section headers\n151\t  const acHeaderPattern = /^## AC ?(\\d+):/gm;\n152\t  const matches = [...content.matchAll(acHeaderPattern)];\n153\t\n154\t  // Find all ## headings that are NOT AC headers (e.g. ## Summary, ## Test Evidence)\n155\t  // These bound the last AC section so it doesn't bleed into trailing sections\n156\t  const nonAcHeadingPattern = /^## (?!AC ?\\d+:)/gm;\n157\t  const nonAcHeadings = [...content.matchAll(nonAcHeadingPattern)].map(m => m.index!);\n158\t\n159\t  let verified = 0;\n160\t  let pending = 0;\n161\t  let escalated = 0;\n162\t\n163\t  if (matches.length > 0) {\n164\t    for (let i = 0; i < matches.length; i++) {\n165\t      const start = matches[i].index!;\n166\t      // End at the next ## AC header or any non-AC ## heading (e.g. ## Summary), whichever comes first\n167\t      const nextAcEnd = i + 1 < matches.length ? matches[i + 1].index! : content.length;\n168\t      const nextNonAcHeading = nonAcHeadings.find(h => h > start);\n169\t      const end = nextNonAcHeading !== undefined && nextNonAcHeading < nextAcEnd\n170\t        ? nextNonAcHeading\n171\t        : nextAcEnd;\n172\t      const section = content.slice(start, end);\n173\t\n174\t      if (section.includes('[ESCALATE]')) {\n175\t        escalated++;\n176\t        continue;\n177\t      }\n178\t\n179\t      if (hasFailVerdict(section)) {\n180\t        pending++;\n181\t        continue;\n182\t      }\n183\t\n184\t      const hasEvidence =\n185\t        section.includes('<!-- /showboat exec -->') ||\n186\t        section.includes('<!-- showboat image:') ||\n187\t        /```(?:bash|shell)\\n[\\s\\S]*?```\\n+```output\\n/m.test(section);\n188\t\n189\t      if (hasEvidence) {\n190\t        verified++;\n191\t      } else {\n192\t        pending++;\n193\t      }\n194\t    }\n195\t  } else {\n196\t    // Format 2: showboat native — inline --- ACN: markers\n197\t    const inlineAcPattern = /--- AC ?(\\d+):/g;\n198\t    const inlineMatches = [...content.matchAll(inlineAcPattern)];\n199\t    const acNumbers = new Set(inlineMatches.map(m => m[1]));\n200\t\n201\t    if (acNumbers.size === 0) {\n202\t      // Format 3: narrative proofs with === AC N: markers\n203\t      const narrativeAcPattern = /=== AC ?(\\d+):/g;\n204\t      const narrativeMatches = [...content.matchAll(narrativeAcPattern)];\n205\t      const narrativeAcNumbers = new Set(narrativeMatches.map(m => m[1]));\n206\t\n207\t      if (narrativeAcNumbers.size === 0) {\n208\t        // Format 4: bullet-list AC summaries\n209\t        const bulletAcPattern = /^- AC ?(\\d+)[^:\\n]*:/gm;\n210\t        const bulletMatches = [...content.matchAll(bulletAcPattern)];\n211\t        const bulletAcNumbers = new Set(bulletMatches.map(m => m[1]));\n212\t\n213\t        if (bulletAcNumbers.size === 0) {\n214\t          return buildResult({ verified: 0, pending: 0, escalated: 0, total: 0 });\n215\t        }\n216\t\n217\t        let bVerified = 0;\n218\t        let bPending = 0;\n219\t        let bEscalated = 0;\n220\t\n221\t        for (const acNum of bulletAcNumbers) {\n222\t          const bulletPattern = new RegExp(`^- AC ?${acNum}[^:\\\\n]*:(.*)$`, 'm');\n223\t          const bulletMatch = content.match(bulletPattern);\n224\t          if (!bulletMatch) { bPending++; continue; }\n225\t\n226\t          const bulletText = bulletMatch[1].toLowerCase();\n227\t          if (bulletText.includes('n/a') || bulletText.includes('escalat') || bulletText.includes('superseded')) {\n228\t            bEscalated++;\n229\t          } else if (bulletText.includes('fail')) {\n230\t            bPending++;\n231\t          } else {\n232\t            bVerified++;\n233\t          }\n234\t        }\n235\t\n236\t        const hasAnyEvidence = /```output\\n/m.test(content);\n237\t        if (!hasAnyEvidence) {\n238\t          bPending += bVerified;\n239\t          bVerified = 0;\n240\t        }\n241\t\n242\t        const bTotal = bVerified + bPending + bEscalated;\n243\t        return buildResult({\n244\t          verified: bVerified,\n245\t          pending: bPending,\n246\t          escalated: bEscalated,\n247\t          total: bTotal,\n248\t        });\n249\t      }\n250\t\n251\t      // Sort AC markers by position for region-based analysis\n252\t      const sortedAcs = narrativeMatches\n253\t        .map(m => ({ num: m[1], idx: m.index! }))\n254\t        .filter((v, i, a) => a.findIndex(x => x.num === v.num) === i)\n255\t        .sort((a, b) => a.idx - b.idx);\n256\t\n257\t      for (let i = 0; i < sortedAcs.length; i++) {\n258\t        const regionStart = i > 0 ? sortedAcs[i - 1].idx : 0;\n259\t        const regionEnd = i + 1 < sortedAcs.length ? sortedAcs[i + 1].idx : content.length;\n260\t        const section = content.slice(regionStart, regionEnd);\n261\t\n262\t        if (section.includes('[ESCALATE]')) {\n263\t          escalated++;\n264\t        } else if (hasFailVerdict(section)) {\n265\t          pending++;\n266\t        } else if (/```output/m.test(section)) {\n267\t          verified++;\n268\t        } else {\n269\t          pending++;\n270\t        }\n271\t      }\n272\t\n273\t      const narrativeTotal = verified + pending + escalated;\n274\t      return buildResult({\n275\t        verified,\n276\t        pending,\n277\t        escalated,\n278\t        total: narrativeTotal,\n279\t      });\n280\t    }\n281\t\n282\t    for (const acNum of acNumbers) {\n283\t      const acPattern2 = new RegExp(`--- AC ?${acNum}:`, 'g');\n284\t      const acIdx = content.search(acPattern2);\n285\t      if (acIdx === -1) { pending++; continue; }\n286\t\n287\t      const nextAcPattern = new RegExp(`--- AC ?(?!${acNum})\\\\d+:`, 'g');\n288\t      nextAcPattern.lastIndex = acIdx + 1;\n289\t      const nextMatch = nextAcPattern.exec(content);\n290\t      const section = content.slice(acIdx, nextMatch ? nextMatch.index : content.length);\n291\t\n292\t      if (section.includes('[ESCALATE]')) {\n293\t        escalated++;\n294\t      } else if (hasFailVerdict(section)) {\n295\t        pending++;\n296\t      } else if (/```output\\n/m.test(section)) {\n297\t        verified++;\n298\t      } else {\n299\t        pending++;\n300\t      }\n301\t    }\n302\t  }\n303\t\n304\t  const total = verified + pending + escalated;\n305\t  return buildResult({ verified, pending, escalated, total });\n306\t}\n307\t\n308\t/** @deprecated Use `validateProofQuality()` instead. */\n309\texport function proofHasContent(proofPath: string): boolean {\n310\t  return validateProofQuality(proofPath).passed;\n311\t}\n312\t"}]},"parent_