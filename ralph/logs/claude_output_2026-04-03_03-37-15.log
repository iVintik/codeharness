{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BrhgDNfGNSJ4X8YW9m8pNd","type":"tool_result","content":"1\timport { execFileSync } from 'node:child_process';\n2\t\n3\texport interface DockerServiceStatus {\n4\t  name: string;\n5\t  status: string;\n6\t  port: string;\n7\t}\n8\t\n9\texport interface DockerStartResult {\n10\t  started: boolean;\n11\t  services: DockerServiceStatus[];\n12\t  error?: string;\n13\t}\n14\t\n15\texport interface DockerHealthService {\n16\t  name: string;\n17\t  running: boolean;\n18\t}\n19\t\n20\texport interface DockerHealthResult {\n21\t  healthy: boolean;\n22\t  services: DockerHealthService[];\n23\t  remedy?: string;\n24\t}\n25\t\n26\texport interface RemoteEndpointCheckResult {\n27\t  reachable: boolean;\n28\t  error?: string;\n29\t}\n30\t\n31\texport function isDockerAvailable(): boolean {\n32\t  try {\n33\t    execFileSync('docker', ['--version'], { stdio: 'pipe', timeout: 10_000 });\n34\t    return true;\n35\t  } catch {\n36\t    // IGNORE: docker CLI not available\n37\t    return false;\n38\t  }\n39\t}\n40\t\n41\texport function isDockerComposeAvailable(): boolean {\n42\t  try {\n43\t    execFileSync('docker', ['compose', 'version'], { stdio: 'pipe', timeout: 10_000 });\n44\t    return true;\n45\t  } catch {\n46\t    // IGNORE: docker compose not available\n47\t    return false;\n48\t  }\n49\t}\n50\t\n51\texport function getStackHealth(composeFile: string, projectName?: string): DockerHealthResult {\n52\t  const expectedServices = ['victoria-logs', 'victoria-metrics', 'victoria-traces', 'otel-collector'];\n53\t\n54\t  try {\n55\t    const args = projectName\n56\t      ? ['compose', '-p', projectName, '-f', composeFile, 'ps', '--format', 'json']\n57\t      : ['compose', '-f', composeFile, 'ps', '--format', 'json'];\n58\t\n59\t    const output = execFileSync('docker', args, {\n60\t      stdio: 'pipe',\n61\t      timeout: 15_000,\n62\t    });\n63\t    const text = output.toString().trim();\n64\t    const runningNames = new Set<string>();\n65\t\n66\t    if (text) {\n67\t      const lines = text.split('\\n').filter(l => l.trim());\n68\t      for (const line of lines) {\n69\t        const svc = JSON.parse(line) as { Service?: string; State?: string };\n70\t        if (svc.State === 'running' && svc.Service) {\n71\t          runningNames.add(svc.Service);\n72\t        }\n73\t      }\n74\t    }\n75\t\n76\t    const services: DockerHealthService[] = expectedServices.map(name => ({\n77\t      name,\n78\t      running: runningNames.has(name),\n79\t    }));\n80\t\n81\t    const healthy = services.every(s => s.running);\n82\t    const remedyCmd = projectName\n83\t      ? `docker compose -p ${projectName} -f ${composeFile} up -d`\n84\t      : `docker compose -f ${composeFile} up -d`;\n85\t\n86\t    return {\n87\t      healthy,\n88\t      services,\n89\t      remedy: healthy ? undefined : `Restart: ${remedyCmd}`,\n90\t    };\n91\t  } catch {\n92\t    // IGNORE: docker compose ps failed, report all services as down\n93\t    const remedyCmd = projectName\n94\t      ? `docker compose -p ${projectName} -f ${composeFile} up -d`\n95\t      : `docker compose -f ${composeFile} up -d`;\n96\t\n97\t    const services: DockerHealthService[] = expectedServices.map(name => ({\n98\t      name,\n99\t      running: false,\n100\t    }));\n101\t\n102\t    return {\n103\t      healthy: false,\n104\t      services,\n105\t      remedy: `Restart: ${remedyCmd}`,\n106\t    };\n107\t  }\n108\t}\n109\t\n110\texport function getCollectorHealth(composeFile: string): DockerHealthResult {\n111\t  const expectedServices = ['otel-collector'];\n112\t\n113\t  try {\n114\t    const output = execFileSync('docker', ['compose', '-p', 'codeharness-collector', '-f', composeFile, 'ps', '--format', 'json'], {\n115\t      stdio: 'pipe',\n116\t      timeout: 15_000,\n117\t    });\n118\t    const text = output.toString().trim();\n119\t    const runningNames = new Set<string>();\n120\t\n121\t    if (text) {\n122\t      const lines = text.split('\\n').filter(l => l.trim());\n123\t      for (const line of lines) {\n124\t        const svc = JSON.parse(line) as { Service?: string; State?: string };\n125\t        if (svc.State === 'running' && svc.Service) {\n126\t          runningNames.add(svc.Service);\n127\t        }\n128\t      }\n129\t    }\n130\t\n131\t    const services: DockerHealthService[] = expectedServices.map(name => ({\n132\t      name,\n133\t      running: runningNames.has(name),\n134\t    }));\n135\t\n136\t    const healthy = services.every(s => s.running);\n137\t\n138\t    return {\n139\t      healthy,\n140\t      services,\n141\t      remedy: healthy ? undefined : `Restart: docker compose -p codeharness-collector -f ${composeFile} up -d`,\n142\t    };\n143\t  } catch {\n144\t    // IGNORE: collector health check failed, report as unhealthy\n145\t    const services: DockerHealthService[] = expectedServices.map(name => ({\n146\t      name,\n147\t      running: false,\n148\t    }));\n149\t\n150\t    return {\n151\t      healthy: false,\n152\t      services,\n153\t      remedy: `Restart: docker compose -p codeharness-collector -f ${composeFile} up -d`,\n154\t    };\n155\t  }\n156\t}\n157\t\n158\texport async function checkRemoteEndpoint(url: string): Promise<RemoteEndpointCheckResult> {\n159\t  try {\n160\t    const controller = new AbortController();\n161\t    const timeout = setTimeout(() => controller.abort(), 5000);\n162\t    try {\n163\t      await fetch(url, { signal: controller.signal });\n164\t      return { reachable: true };\n165\t    } finally {\n166\t      clearTimeout(timeout);\n167\t    }\n168\t  } catch (err) {\n169\t    const message = err instanceof Error ? err.message : String(err);\n170\t    return { reachable: false, error: message };\n171\t  }\n172\t}\n173\t"}]},"parent_tool_use_id":"toolu_01UWCDAVJnDwJQvBDbzgFBYG","session_id":"e9c90575-92e6-47e7-805a-c4ec47a0ac4f","uuid":"2ede6dac-4c40-4ec5-b8ac-2a90860f8c11","timestamp":"2026-04-02T23:43:17.843Z"}
