{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016Bx3vk7xA3zMSwjF2duNg3","type":"tool_result","content":"     1→import { defineConfig } from 'vitest/config';\n     2→import { readFileSync } from 'node:fs';\n     3→\n     4→const pkg = JSON.parse(readFileSync('package.json', 'utf-8'));\n     5→\n     6→export default defineConfig({\n     7→  define: {\n     8→    '__PKG_VERSION__': JSON.stringify(pkg.version),\n     9→  },\n    10→  test: {\n    11→    root: 'src',\n    12→    coverage: {\n    13→      provider: 'v8',\n    14→      include: ['**/*.ts', '**/*.tsx'],\n    15→      exclude: ['**/__tests__/**', '**/*.test.ts', '**/*.test.tsx'],\n    16→      reporter: ['text', 'json-summary'],\n    17→      reportsDirectory: '../coverage',\n    18→    },\n    19→  },\n    20→});\n    21→"}]},"parent_tool_use_id":"toolu_01JZ7cmNZZkp82ndK5epjGGA","session_id":"eb26302c-c52a-41c7-9204-5eb8c12a854c","uuid":"5e96618f-7332-482f-8d15-b815dcf5bc02","timestamp":"2026-03-21T11:17:10.379Z"}
