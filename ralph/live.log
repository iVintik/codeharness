{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013EaRMrk4y6ZweZDXL726wp","type":"tool_result","content":"     1→import { join } from 'node:path';\n     2→import { getSprintState, writeStateAtomic } from '../modules/sprint/state.js';\n     3→import type { SprintState } from '../types/state.js';\n     4→\n     5→const RETRIES_FILE = '.story_retries';\n     6→const FLAGGED_FILE = '.flagged_stories';\n     7→\n     8→/**\n     9→ * Internal helper: read current state, apply a mutation, write back atomically.\n    10→ * Returns silently on failure to preserve backward-compatible void API.\n    11→ */\n    12→function mutateState(mutator: (state: SprintState) => SprintState): void {\n    13→  const result = getSprintState();\n    14→  if (!result.success) return;\n    15→  writeStateAtomic(mutator(result.data));\n    16→}\n    17→\n    18→/**\n    19→ * @deprecated Legacy path helper. retry-state now reads/writes sprint-state.json.\n    20→ * Kept for backward compatibility — will be removed in story 11-3.\n    21→ */\n    22→export function retriesPath(dir: string): string {\n    23→  return join(dir, RETRIES_FILE);\n    24→}\n    25→\n    26→/**\n    27→ * @deprecated Legacy path helper. retry-state now reads/writes sprint-state.json.\n    28→ * Kept for backward compatibility — will be removed in story 11-3.\n    29→ */\n    30→export function flaggedPath(dir: string): string {\n    31→  return join(dir, FLAGGED_FILE);\n    32→}\n    33→\n    34→/**\n    35→ * Read retries from sprint-state.json as a Map<storyKey, retryCount>.\n    36→ * The `dir` parameter is kept for backward compatibility but is not used.\n    37→ */\n    38→export function readRetries(_dir: string): Map<string, number> {\n    39→  const result = getSprintState();\n    40→  if (!result.success) {\n    41→    return new Map();\n    42→  }\n    43→  return new Map(Object.entries(result.data.retries));\n    44→}\n    45→\n    46→/**\n    47→ * Write retries map to sprint-state.json.\n    48→ * The `dir` parameter is kept for backward compatibility but is not used.\n    49→ */\n    50→export function writeRetries(_dir: string, retries: Map<string, number>): void {\n    51→  mutateState(state => ({\n    52→    ...state,\n    53→    retries: Object.fromEntries(retries),\n    54→  }));\n    55→}\n    56→\n    57→/**\n    58→ * Get retry count for a single story. Returns 0 if not found.\n    59→ */\n    60→export function getRetryCount(dir: string, storyKey: string): number {\n    61→  const retries = readRetries(dir);\n    62→  return retries.get(storyKey) ?? 0;\n    63→}\n    64→\n    65→/**\n    66→ * Set retry count for a single story. Deduplicates automatically.\n    67→ */\n    68→export function setRetryCount(dir: string, storyKey: string, count: number): void {\n    69→  const retries = readRetries(dir);\n    70→  retries.set(storyKey, count);\n    71→  writeRetries(dir, retries);\n    72→}\n    73→\n    74→/**\n    75→ * Reset retry state. If storyKey is provided, removes only that entry.\n    76→ * Otherwise clears all entries. Also clears flagged stories accordingly.\n    77→ */\n    78→export function resetRetry(dir: string, storyKey?: string): void {\n    79→  if (storyKey) {\n    80→    const retries = readRetries(dir);\n    81→    retries.delete(storyKey);\n    82→    writeRetries(dir, retries);\n    83→    removeFlaggedStory(dir, storyKey);\n    84→  } else {\n    85→    writeRetries(dir, new Map());\n    86→    writeFlaggedStories(dir, []);\n    87→  }\n    88→}\n    89→\n    90→/**\n    91→ * Read flagged stories from sprint-state.json.\n    92→ * The `dir` parameter is kept for backward compatibility but is not used.\n    93→ */\n    94→export function readFlaggedStories(_dir: string): string[] {\n    95→  const result = getSprintState();\n    96→  if (!result.success) {\n    97→    return [];\n    98→  }\n    99→  return [...result.data.flagged];\n   100→}\n   101→\n   102→/**\n   103→ * Write flagged stories list to sprint-state.json.\n   104→ * The `dir` parameter is kept for backward compatibility but is not used.\n   105→ */\n   106→export function writeFlaggedStories(_dir: string, stories: string[]): void {\n   107→  mutateState(state => ({\n   108→    ...state,\n   109→    flagged: stories,\n   110→  }));\n   111→}\n   112→\n   113→/**\n   114→ * Remove a single story from flagged stories in sprint-state.json.\n   115→ */\n   116→export function removeFlaggedStory(dir: string, key: string): void {\n   117→  const stories = readFlaggedStories(dir);\n   118→  const filtered = stories.filter(s => s !== key);\n   119→  writeFlaggedStories(dir, filtered);\n   120→}\n   121→"}]},"parent_tool_use_id":"toolu_011K77Q1Nc8EiPZnCgrdVKHN","session_id":"01503c00-15e6-46f1-b837-b4628ff69656","uuid":"3683bbca-0f5a-4037-b7ed-bdcfb61b2358","timestamp":"2026-03-24T11:33:06.925Z"}
