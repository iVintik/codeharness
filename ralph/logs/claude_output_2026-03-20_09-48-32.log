{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ADAhEXk8xnGKQEX33ZhjW6","type":"tool_result","content":"     1→/**\n     2→ * Observability coverage gate — checks if coverage meets targets for commit gating.\n     3→ *\n     4→ * Implements Story 2.2: reads cached coverage from sprint-state.json and compares\n     5→ * against targets. Does NOT re-run Semgrep — uses cached results for performance.\n     6→ * Static coverage is always required; runtime is only checked when data exists.\n     7→ */\n     8→\n     9→import { ok, fail } from '../../types/result.js';\n    10→import type { Result } from '../../types/result.js';\n    11→import { readCoverageState } from './coverage.js';\n    12→import type {\n    13→  ObservabilityCoverageGateResult,\n    14→  CoverageTargetResult,\n    15→  ObservabilityGap,\n    16→} from './types.js';\n    17→\n    18→const DEFAULT_STATIC_TARGET = 80;\n    19→const DEFAULT_RUNTIME_TARGET = 60;\n    20→\n    21→/**\n    22→ * Check observability coverage against targets for commit gating.\n    23→ *\n    24→ * Reads static and runtime coverage from sprint-state.json. Static coverage\n    25→ * is always checked. Runtime coverage is only checked when runtime data exists\n    26→ * in the state file (i.e., after at least one verification run).\n    27→ *\n    28→ * @param projectDir - Project root directory\n    29→ * @param overrides - Optional target overrides\n    30→ * @returns Gate result with pass/fail, per-dimension results, and gap summary\n    31→ */\n    32→export function checkObservabilityCoverageGate(\n    33→  projectDir: string,\n    34→  overrides?: { staticTarget?: number; runtimeTarget?: number },\n    35→): Result<ObservabilityCoverageGateResult> {\n    36→  if (!projectDir || typeof projectDir !== 'string') {\n    37→    return fail('projectDir is required and must be a non-empty string');\n    38→  }\n    39→\n    40→  const stateResult = readCoverageState(projectDir);\n    41→  if (!stateResult.success) {\n    42→    return fail(stateResult.error);\n    43→  }\n    44→\n    45→  const state = stateResult.data;\n    46→  const staticTarget =\n    47→    overrides?.staticTarget ?? state.targets.staticTarget ?? DEFAULT_STATIC_TARGET;\n    48→  const runtimeTarget =\n    49→    overrides?.runtimeTarget ?? state.targets.runtimeTarget ?? DEFAULT_RUNTIME_TARGET;\n    50→\n    51→  // Static coverage check (always required)\n    52→  const staticCurrent = state.static.coveragePercent;\n    53→  const staticMet = staticCurrent >= staticTarget;\n    54→  const staticResult: CoverageTargetResult = {\n    55→    met: staticMet,\n    56→    current: staticCurrent,\n    57→    target: staticTarget,\n    58→    gap: staticMet ? 0 : staticTarget - staticCurrent,\n    59→  };\n    60→\n    61→  // Runtime coverage check (only when runtime data exists)\n    62→  let runtimeResult: CoverageTargetResult | null = null;\n    63→  if (state.runtime) {\n    64→    const runtimeCurrent = state.runtime.coveragePercent;\n    65→    const runtimeMet = runtimeCurrent >= runtimeTarget;\n    66→    runtimeResult = {\n    67→      met: runtimeMet,\n    68→      current: runtimeCurrent,\n    69→      target: runtimeTarget,\n    70→      gap: runtimeMet ? 0 : runtimeTarget - runtimeCurrent,\n    71→    };\n    72→  }\n    73→\n    74→  // Gate passes only when all checked dimensions pass\n    75→  const passed = staticResult.met && (runtimeResult === null || runtimeResult.met);\n    76→\n    77→  // Gap summary is empty here — full gap details require re-running the analyzer.\n    78→  // The hook message directs users to run `codeharness analyze` for details.\n    79→  const gapSummary: ObservabilityGap[] = [];\n    80→\n    81→  return ok({ passed, staticResult, runtimeResult, gapSummary });\n    82→}\n    83→"}]},"parent_tool_use_id":"toolu_01L7x1Zkv5Yv1DsfgSndzqDQ","session_id":"f7a66acd-0cc1-40de-a592-d59e75273c0b","uuid":"2f24d761-c2cd-4c41-a7bf-e6e71284ca5f","timestamp":"2026-03-20T06:00:15.736Z"}
