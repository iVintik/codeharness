{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016fnzWaQQwWuHAkpdCeeZNs","type":"tool_result","content":"     1→/**\n     2→ * Project initialization orchestrator.\n     3→ * Composes sub-steps: stack detection, deps, Docker, BMAD, beads, state, docs, OTLP.\n     4→ */\n     5→\n     6→import { existsSync } from 'node:fs';\n     7→import { basename } from 'node:path';\n     8→import { ok as okOutput, fail as failOutput, info, jsonOutput } from '../../lib/output.js';\n     9→import { detectStack, detectAppType } from '../../lib/stack-detect.js';\n    10→import { readState, writeState, getDefaultState, getStatePath } from '../../lib/state.js';\n    11→import type { HarnessState } from '../../lib/state.js';\n    12→import { instrumentProject } from '../../lib/otlp.js';\n    13→import type { Result } from '../../types/result.js';\n    14→import { ok, fail, isOk } from '../../types/result.js';\n    15→import type { InitOptions, InitResult } from './types.js';\n    16→import { checkDocker, setupDocker } from './docker-setup.js';\n    17→import { installDeps, verifyDeps } from './deps-install.js';\n    18→import { setupBmad, verifyBmadOnRerun } from './bmad-setup.js';\n    19→import { initializeBeads } from './beads-init.js';\n    20→import { scaffoldDocs, getCoverageTool, getStackLabel } from './docs-scaffold.js';\n    21→import { generateDockerfileTemplate } from './dockerfile-template.js';\n    22→\n    23→declare const __PKG_VERSION__: string;\n    24→const HARNESS_VERSION = typeof __PKG_VERSION__ !== 'undefined' ? __PKG_VERSION__ : '0.0.0-dev';\n    25→\n    26→/** Helper: build a fail-status InitResult for early returns */\n    27→function failResult(opts: InitOptions, error: string): InitResult {\n    28→  return {\n    29→    status: 'fail', stack: null, error,\n    30→    enforcement: { frontend: opts.frontend, database: opts.database, api: opts.api },\n    31→    documentation: { agents_md: 'skipped', docs_scaffold: 'skipped', readme: 'skipped' },\n    32→  };\n    33→}\n    34→\n    35→/** Output error and set exit code for validation/critical failures */\n    36→function emitError(error: string, isJson: boolean): void {\n    37→  if (isJson) { jsonOutput({ status: 'fail', error }); } else { failOutput(error); }\n    38→  process.exitCode = 1;\n    39→}\n    40→\n    41→/** Main project initialization orchestrator. Never throws — returns fail() on unexpected errors. */\n    42→export async function initProject(opts: InitOptions): Promise<Result<InitResult>> {\n    43→  try {\n    44→    return await initProjectInner(opts);\n    45→  } catch (err) {\n    46→    const message = err instanceof Error ? err.message : String(err);\n    47→    return fail(`Unexpected init error: ${message}`);\n    48→  }\n    49→}\n    50→\n    51→async function initProjectInner(opts: InitOptions): Promise<Result<InitResult>> {\n    52→  const { projectDir, json: isJson = false } = opts;\n    53→  const result: InitResult = {\n    54→    status: 'ok', stack: null,\n    55→    enforcement: { frontend: opts.frontend, database: opts.database, api: opts.api },\n    56→    documentation: { agents_md: 'skipped', docs_scaffold: 'skipped', readme: 'skipped' },\n    57→  };\n    58→\n    59→  // --- Idempotent re-run check ---\n    60→  const rerunResult = handleRerun(opts, result);\n    61→  if (rerunResult !== null) return rerunResult;\n    62→\n    63→  // --- Remote endpoint URL validation ---\n    64→  const urlError = validateRemoteUrls(opts);\n    65→  if (urlError !== null) { emitError(urlError, isJson); return ok(failResult(opts, urlError)); }\n    66→\n    67→  // --- Stack detection ---\n    68→  const stack = detectStack(projectDir);\n    69→  result.stack = stack;\n    70→  const appType = detectAppType(projectDir, stack);\n    71→  result.app_type = appType;\n    72→  if (!isJson) {\n    73→    if (stack) info(`Stack detected: ${getStackLabel(stack)}`);\n    74→    info(`App type: ${appType}`);\n    75→  }\n    76→\n    77→  // --- Dockerfile template generation ---\n    78→  const dfResult = generateDockerfileTemplate(projectDir, stack);\n    79→  if (isOk(dfResult)) {\n    80→    result.dockerfile = { generated: true, stack: dfResult.data.stack };\n    81→    if (!isJson) info(`Generated Dockerfile for ${dfResult.data.stack} project.`);\n    82→  } else {\n    83→    if (!isJson) info('Dockerfile already exists -- skipping template generation.');\n    84→  }\n    85→\n    86→  // --- Docker check ---\n    87→  const dockerCheck = checkDocker({ observability: opts.observability, otelEndpoint: opts.otelEndpoint, logsUrl: opts.logsUrl, opensearchUrl: opts.opensearchUrl, isJson });\n    88→  if (!isOk(dockerCheck)) return fail(dockerCheck.error);\n    89→  const { available: dockerAvailable, criticalFailure, dockerResult: criticalDockerResult } = dockerCheck.data;\n    90→  if (criticalFailure) {\n    91→    result.status = 'fail'; result.error = 'Docker not installed'; result.docker = criticalDockerResult;\n    92→    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); }\n    93→    else { failOutput('Docker not installed'); info('\\u2192 Install Docker: https://docs.docker.com/engine/install/'); info('\\u2192 Or skip observability: codeharness init --no-observability'); }\n    94→    process.exitCode = 1;\n    95→    return ok(result);\n    96→  }\n    97→\n    98→  // --- Dependency install ---\n    99→  const depResult = installDeps({ isJson });\n   100→  if (!isOk(depResult)) {\n   101→    result.status = 'fail'; result.error = depResult.error;\n   102→    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); } else { info('Critical dependency failed — aborting init'); }\n   103→    process.exitCode = 1;\n   104→    return ok(result);\n   105→  }\n   106→  result.dependencies = depResult.data;\n   107→\n   108→  // --- Beads initialization ---\n   109→  result.beads = initializeBeads(projectDir, isJson);\n   110→\n   111→  // --- BMAD installation ---\n   112→  const bmadResult = setupBmad({ projectDir, isJson });\n   113→  if (isOk(bmadResult)) result.bmad = bmadResult.data;\n   114→\n   115→  // --- State file creation ---\n   116→  let state: HarnessState = getDefaultState(stack);\n   117→  state.harness_version = HARNESS_VERSION;\n   118→  state.initialized = true;\n   119→  state.app_type = appType;\n   120→  state.enforcement = { frontend: opts.frontend, database: opts.database, api: opts.api };\n   121→  state.coverage.tool = getCoverageTool(stack);\n   122→  writeState(state, projectDir);\n   123→  if (!isJson) okOutput('State file: .claude/codeharness.local.md created');\n   124→\n   125→  // --- Documentation scaffold ---\n   126→  const docsResult = await scaffoldDocs({ projectDir, stack, isJson });\n   127→  if (isOk(docsResult)) result.documentation = docsResult.data;\n   128→\n   129→  // --- OTLP instrumentation ---\n   130→  if (!opts.observability) {\n   131→    result.otlp = { status: 'skipped', packages_installed: false, start_script_patched: false, env_vars_configured: false };\n   132→    if (!isJson) info('OTLP: skipped (--no-observability)');\n   133→  } else {\n   134→    result.otlp = instrumentProject(projectDir, stack, { json: isJson, appType });\n   135→  }\n   136→\n   137→  // Re-read state to pick up otlp changes written by instrumentProject\n   138→  try { const u = readState(projectDir); if (u.otlp) state.otlp = u.otlp; } catch { /* ignore */ }\n   139→  if (!state.otlp) {\n   140→    state.otlp = { enabled: true, endpoint: 'http://localhost:4318', service_name: basename(projectDir), mode: 'local-shared' };\n   141→  }\n   142→\n   143→  // --- Docker stack setup ---\n   144→  const dockerSetup = setupDocker({\n   145→    observability: opts.observability, otelEndpoint: opts.otelEndpoint,\n   146→    opensearchUrl: opts.opensearchUrl,\n   147→    logsUrl: opts.logsUrl, metricsUrl: opts.metricsUrl, tracesUrl: opts.tracesUrl,\n   148→    isJson, dockerAvailable, appType, state, projectDir,\n   149→  });\n   150→  if (isOk(dockerSetup)) result.docker = dockerSetup.data.docker;\n   151→\n   152→  // --- Enforcement summary ---\n   153→  if (!isJson) {\n   154→    const e = state.enforcement;\n   155→    const fmt = (v: boolean): string => v ? 'ON' : 'OFF';\n   156→    okOutput(`Enforcement: frontend:${fmt(e.frontend)} database:${fmt(e.database)} api:${fmt(e.api)} observability:ON`);\n   157→    info('Harness initialized. Run: codeharness bridge --epics <path>');\n   158→  }\n   159→  if (isJson) jsonOutput(result as unknown as Record<string, unknown>);\n   160→\n   161→  return ok(result);\n   162→}\n   163→\n   164→function handleRerun(opts: InitOptions, result: InitResult): Result<InitResult> | null {\n   165→  const { projectDir, json: isJson = false } = opts;\n   166→  if (!existsSync(getStatePath(projectDir))) return null;\n   167→\n   168→  try {\n   169→    const existingState = readState(projectDir);\n   170→    const legacyObsDisabled = (existingState.enforcement as Record<string, unknown>).observability === false;\n   171→    if (!existingState.initialized || legacyObsDisabled) {\n   172→      if (legacyObsDisabled && !isJson) info('Observability upgraded from disabled to enabled');\n   173→      return null;\n   174→    }\n   175→    result.stack = existingState.stack;\n   176→    result.enforcement = existingState.enforcement;\n   177→    result.documentation = { agents_md: 'exists', docs_scaffold: 'exists', readme: 'exists' };\n   178→    result.dependencies = verifyDeps(isJson);\n   179→    result.docker = existingState.docker\n   180→      ? { compose_file: existingState.docker.compose_file, stack_running: existingState.docker.stack_running, services: [], ports: existingState.docker.ports }\n   181→      : null;\n   182→    const bmadResult = verifyBmadOnRerun(projectDir, isJson);\n   183→    if (bmadResult) result.bmad = bmadResult;\n   184→    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); }\n   185→    else { info('Harness already initialized — verifying configuration'); okOutput('Configuration verified'); }\n   186→    return ok(result);\n   187→  } catch {\n   188→    return null;\n   189→  }\n   190→}\n   191→\n   192→/** Returns error message string if validation fails, null if OK */\n   193→function validateRemoteUrls(opts: InitOptions): string | null {\n   194→  const remoteUrls = [opts.otelEndpoint, opts.opensearchUrl, opts.logsUrl, opts.metricsUrl, opts.tracesUrl].filter(Boolean) as string[];\n   195→  for (const url of remoteUrls) {\n   196→    if (!/^https?:\\/\\//i.test(url)) return `Invalid URL: '${url}' \\u2014 must start with http:// or https://`;\n   197→  }\n   198→  if (opts.otelEndpoint && (opts.logsUrl || opts.metricsUrl || opts.tracesUrl)) {\n   199→    return 'Cannot combine --otel-endpoint with --logs-url/--metrics-url/--traces-url';\n   200→  }\n   201→  const hasAny = opts.logsUrl || opts.metricsUrl || opts.tracesUrl;\n   202→  if (hasAny && !(opts.logsUrl && opts.metricsUrl && opts.tracesUrl)) {\n   203→    return 'When using remote backends, all three are required: --logs-url, --metrics-url, --traces-url';\n   204→  }\n   205→  return null;\n   206→}\n   207→"}]},"parent_tool_use_id":"toolu_01QPLvTF7hH7ZEy1LqPE8PcP","session_id":"daf25720-e009-4a3c-8a3c-df9d68d99484","uuid":"b60a94dc-86fa-48b1-aa5c-dc4ac919d8b1","timestamp":"2026-03-23T06:48:31.401Z"}
