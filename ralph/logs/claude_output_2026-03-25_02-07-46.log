{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JN6gKgHv1ztFkMSdxmbGG1","type":"tool_result","content":"     1→/**\n     2→ * Story selection — cross-epic prioritization logic.\n     3→ *\n     4→ * Selects the next actionable story from sprint state based on priority tiers:\n     5→ *   0: in-progress (continue current work)\n     6→ *   1: verifying with proof (proofPath set)\n     7→ *   2: verifying without proof\n     8→ *   3: backlog\n     9→ *\n    10→ * Stories that are done, failed, blocked, or retry-exhausted are excluded.\n    11→ */\n    12→\n    13→import { ok, fail } from '../../types/result.js';\n    14→import type { Result } from '../../types/result.js';\n    15→import type { SprintState, StoryState } from '../../types/state.js';\n    16→import type { StorySelection, SelectionResult, RetryExhaustedInfo } from './types.js';\n    17→\n    18→/** Maximum attempts before a story is considered retry-exhausted */\n    19→export const MAX_STORY_ATTEMPTS = 10;\n    20→\n    21→/** Statuses that are terminal — no further action possible */\n    22→const TERMINAL_STATUSES = new Set(['done', 'failed', 'blocked']);\n    23→\n    24→/**\n    25→ * Compute the priority tier for a story.\n    26→ * Lower number = higher priority.\n    27→ * Returns null if the story should be excluded from selection.\n    28→ */\n    29→function priorityTier(story: StoryState): number | null {\n    30→  if (TERMINAL_STATUSES.has(story.status)) {\n    31→    return null;\n    32→  }\n    33→  // Note: retry-exhausted check (attempts >= MAX_STORY_ATTEMPTS) is handled\n    34→  // by the caller before priorityTier is invoked.\n    35→\n    36→  switch (story.status) {\n    37→    case 'in-progress':\n    38→      return 0;\n    39→    case 'verifying':\n    40→      return story.proofPath !== null ? 1 : 2;\n    41→    case 'backlog':\n    42→    case 'ready':\n    43→    case 'review':\n    44→      return 3;\n    45→    default:\n    46→      return null;\n    47→  }\n    48→}\n    49→\n    50→/** Transform a story key into a human-readable title */\n    51→function keyToTitle(key: string): string {\n    52→  if (key.length === 0) return key;\n    53→  const spaced = key.replace(/-/g, ' ');\n    54→  return spaced.charAt(0).toUpperCase() + spaced.slice(1);\n    55→}\n    56→\n    57→/**\n    58→ * Select the next actionable story from sprint state.\n    59→ *\n    60→ * Priority order: in-progress > verifying-with-proof > verifying > backlog.\n    61→ * Within the same tier: fewer attempts first, then lexicographic key order.\n    62→ *\n    63→ * Returns ok(null) when no actionable stories remain.\n    64→ */\n    65→export function selectNextStory(\n    66→  state: SprintState,\n    67→): Result<SelectionResult> {\n    68→  try {\n    69→    const candidates: Array<{\n    70→      key: string;\n    71→      story: StoryState;\n    72→      tier: number;\n    73→    }> = [];\n    74→    const retryExhausted: RetryExhaustedInfo[] = [];\n    75→\n    76→    for (const [key, story] of Object.entries(state.stories)) {\n    77→      // Track retry-exhausted stories (AC #2)\n    78→      if (\n    79→        !TERMINAL_STATUSES.has(story.status) &&\n    80→        story.attempts >= MAX_STORY_ATTEMPTS\n    81→      ) {\n    82→        retryExhausted.push({\n    83→          key,\n    84→          attempts: story.attempts,\n    85→          reason: 'retry-exhausted',\n    86→        });\n    87→        continue;\n    88→      }\n    89→\n    90→      const tier = priorityTier(story);\n    91→      if (tier !== null) {\n    92→        candidates.push({ key, story, tier });\n    93→      }\n    94→    }\n    95→\n    96→    if (candidates.length === 0) {\n    97→      return ok({ selected: null, retryExhausted });\n    98→    }\n    99→\n   100→    candidates.sort((a, b) => {\n   101→      // Primary: priority tier ascending (lower = higher priority)\n   102→      if (a.tier !== b.tier) return a.tier - b.tier;\n   103→      // Secondary: fewer attempts first\n   104→      if (a.story.attempts !== b.story.attempts) {\n   105→        return a.story.attempts - b.story.attempts;\n   106→      }\n   107→      // Tertiary: lexicographic key order\n   108→      return a.key.localeCompare(b.key);\n   109→    });\n   110→\n   111→    const winner = candidates[0];\n   112→    const selection: StorySelection = {\n   113→      key: winner.key,\n   114→      title: keyToTitle(winner.key),\n   115→      priority: winner.tier,\n   116→    };\n   117→\n   118→    return ok({ selected: selection, retryExhausted });\n   119→  } catch (err: unknown) {\n   120→    const msg = err instanceof Error ? err.message : String(err);\n   121→    return fail(`Story selection failed: ${msg}`);\n   122→  }\n   123→}\n   124→"}]},"parent_tool_use_id":"toolu_01YSLgmTQ3U7drywxsM2yupJ","session_id":"e0c38769-c734-43c9-928b-954c93aa963e","uuid":"0d9663c9-4212-4c9b-a4fa-0683bf8bfbd1","timestamp":"2026-03-24T22:12:44.712Z"}
