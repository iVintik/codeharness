{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SGWQxL6wQpWz3EsBzxzAm8","type":"tool_result","content":"     1→/**\n     2→ * Standalone runtime validator — validates telemetry outside Docker verification.\n     3→ * Implements Story 2.3: run tests with OTLP, query backend, report module coverage.\n     4→ */\n     5→\n     6→import { execSync } from 'node:child_process';\n     7→import { readdirSync, statSync } from 'node:fs';\n     8→import { join } from 'node:path';\n     9→import { ok, fail } from '../../types/result.js';\n    10→import type { Result } from '../../types/result.js';\n    11→import type {\n    12→  RuntimeValidationConfig,\n    13→  RuntimeValidationResult,\n    14→  ModuleTelemetryEntry,\n    15→  TelemetryEvent,\n    16→} from './types.js';\n    17→\n    18→const DEFAULT_CONFIG: RuntimeValidationConfig = {\n    19→  testCommand: 'npm test',\n    20→  otlpEndpoint: 'http://localhost:4318',\n    21→  queryEndpoint: 'http://localhost:9428',\n    22→  timeoutMs: 120_000,\n    23→};\n    24→\n    25→const HEALTH_TIMEOUT_MS = 3_000;\n    26→const QUERY_TIMEOUT_MS = 30_000;\n    27→/** Run tests with OTLP enabled, query backend for events, compute module coverage. */\n    28→export async function validateRuntime(\n    29→  projectDir: string,\n    30→  config?: Partial<RuntimeValidationConfig>,\n    31→): Promise<Result<RuntimeValidationResult>> {\n    32→  if (!projectDir || typeof projectDir !== 'string') {\n    33→    return fail('projectDir is required and must be a non-empty string');\n    34→  }\n    35→\n    36→  const cfg: RuntimeValidationConfig = { ...DEFAULT_CONFIG, ...config };\n    37→\n    38→  // Reject test commands containing shell metacharacters to prevent injection\n    39→  if (/[;&|`$(){}!#]/.test(cfg.testCommand)) {\n    40→    return fail(`testCommand contains disallowed shell metacharacters: ${cfg.testCommand}`);\n    41→  }\n    42→\n    43→  // Step 1: Check backend health\n    44→  const healthy = await checkBackendHealth(cfg.queryEndpoint);\n    45→  if (!healthy) {\n    46→    const modules = discoverModules(projectDir);\n    47→    const entries: ModuleTelemetryEntry[] = modules.map((m) => ({\n    48→      moduleName: m,\n    49→      telemetryDetected: false,\n    50→      eventCount: 0,\n    51→    }));\n    52→    return ok({\n    53→      entries,\n    54→      totalModules: modules.length,\n    55→      modulesWithTelemetry: 0,\n    56→      coveragePercent: 0,\n    57→      skipped: true,\n    58→      skipReason: 'runtime validation skipped -- observability stack not available',\n    59→    });\n    60→  }\n    61→\n    62→  // Step 2: Record start time and run tests\n    63→  const startTime = new Date().toISOString();\n    64→  try {\n    65→    execSync(cfg.testCommand, {\n    66→      cwd: projectDir,\n    67→      timeout: cfg.timeoutMs,\n    68→      env: {\n    69→        ...process.env,\n    70→        OTEL_EXPORTER_OTLP_ENDPOINT: cfg.otlpEndpoint,\n    71→      },\n    72→      stdio: 'pipe',\n    73→    });\n    74→  } catch (err: unknown) {\n    75→    const msg = err instanceof Error ? err.message : String(err);\n    76→    return fail(`Test command failed: ${msg}`);\n    77→  }\n    78→  const endTime = new Date().toISOString();\n    79→\n    80→  // Step 3: Query telemetry events\n    81→  const eventsResult = await queryTelemetryEvents(cfg.queryEndpoint, startTime, endTime);\n    82→  if (!eventsResult.success) {\n    83→    return fail(eventsResult.error);\n    84→  }\n    85→\n    86→  // Step 4: Map events to modules and compute coverage\n    87→  const modules = discoverModules(projectDir);\n    88→  const entries = mapEventsToModules(eventsResult.data, projectDir, modules);\n    89→  const modulesWithTelemetry = entries.filter((e) => e.telemetryDetected).length;\n    90→  const totalModules = entries.length;\n    91→  const coveragePercent = totalModules === 0 ? 0 : (modulesWithTelemetry / totalModules) * 100;\n    92→\n    93→  return ok({\n    94→    entries,\n    95→    totalModules,\n    96→    modulesWithTelemetry,\n    97→    coveragePercent,\n    98→    skipped: false,\n    99→  });\n   100→}\n   101→\n   102→/** Check if the observability backend is reachable (2xx within 3s). */\n   103→export async function checkBackendHealth(queryEndpoint: string): Promise<boolean> {\n   104→  try {\n   105→    const response = await fetch(`${queryEndpoint}/health`, {\n   106→      signal: AbortSignal.timeout(HEALTH_TIMEOUT_MS),\n   107→    });\n   108→    return response.ok;\n   109→  } catch {\n   110→    return false;\n   111→  }\n   112→}\n   113→\n   114→/** Query VictoriaLogs for telemetry events within a time window. */\n   115→export async function queryTelemetryEvents(\n   116→  queryEndpoint: string,\n   117→  startTime: string,\n   118→  endTime: string,\n   119→): Promise<Result<TelemetryEvent[]>> {\n   120→  let url: URL;\n   121→  try {\n   122→    url = new URL('/select/logsql/query', queryEndpoint);\n   123→  } catch {\n   124→    return fail(`Invalid queryEndpoint URL: ${queryEndpoint}`);\n   125→  }\n   126→  url.searchParams.set('query', '_stream_id:*');\n   127→  url.searchParams.set('start', startTime);\n   128→  url.searchParams.set('end', endTime);\n   129→  url.searchParams.set('limit', '1000');\n   130→\n   131→  try {\n   132→    const response = await fetch(url.toString(), {\n   133→      signal: AbortSignal.timeout(QUERY_TIMEOUT_MS),\n   134→    });\n   135→    if (!response.ok) {\n   136→      return fail(`VictoriaLogs returned ${response.status}`);\n   137→    }\n   138→    const text = await response.text();\n   139→    const events = parseLogEvents(text);\n   140→    return ok(events);\n   141→  } catch (err: unknown) {\n   142→    const msg = err instanceof Error ? err.message : String(err);\n   143→    return fail(`Failed to query telemetry events: ${msg}`);\n   144→  }\n   145→}\n   146→\n   147→/** Map telemetry events to project modules by matching source paths. */\n   148→export function mapEventsToModules(\n   149→  events: TelemetryEvent[],\n   150→  projectDir: string,\n   151→  modules?: string[],\n   152→): ModuleTelemetryEntry[] {\n   153→  void projectDir; // Reserved for future source-path resolution\n   154→  const moduleList = modules ?? [];\n   155→  const moduleCounts = new Map<string, number>();\n   156→  for (const mod of moduleList) {\n   157→    moduleCounts.set(mod, 0);\n   158→  }\n   159→\n   160→  for (const event of events) {\n   161→    for (const mod of moduleList) {\n   162→      if (event.source.includes(mod) || event.message.includes(mod)) {\n   163→        moduleCounts.set(mod, (moduleCounts.get(mod) ?? 0) + 1);\n   164→      }\n   165→    }\n   166→  }\n   167→\n   168→  return moduleList.map((mod) => {\n   169→    const count = moduleCounts.get(mod) ?? 0;\n   170→    return {\n   171→      moduleName: mod,\n   172→      telemetryDetected: count > 0,\n   173→      eventCount: count,\n   174→    };\n   175→  });\n   176→}\n   177→\n   178→/** Discover top-level module directories under src/ */\n   179→function discoverModules(projectDir: string): string[] {\n   180→  const srcDir = join(projectDir, 'src');\n   181→  try {\n   182→    return readdirSync(srcDir).filter((name) => {\n   183→      try {\n   184→        return statSync(join(srcDir, name)).isDirectory();\n   185→      } catch {\n   186→        return false;\n   187→      }\n   188→    });\n   189→  } catch {\n   190→    return [];\n   191→  }\n   192→}\n   193→\n   194→/** Parse newline-delimited JSON from VictoriaLogs into TelemetryEvent[] */\n   195→function parseLogEvents(text: string): TelemetryEvent[] {\n   196→  if (!text.trim()) return [];\n   197→  const lines = text.trim().split('\\n');\n   198→  const events: TelemetryEvent[] = [];\n   199→  for (const line of lines) {\n   200→    try {\n   201→      const raw = JSON.parse(line) as Record<string, unknown>;\n   202→      events.push({\n   203→        timestamp: String(raw._time ?? raw.timestamp ?? ''),\n   204→        message: String(raw._msg ?? raw.message ?? ''),\n   205→        source: String(raw.source ?? raw._source ?? raw.service ?? ''),\n   206→      });\n   207→    } catch {\n   208→      // skip malformed lines\n   209→    }\n   210→  }\n   211→  return events;\n   212→}\n   213→"}]},"parent_tool_use_id":null,"session_id":"ea9dcd26-048d-426f-9aa1-49ae9968ed9a","uuid":"30f1c9fc-4872-4c87-b296-7b9244907183","timestamp":"2026-03-20T06:56:54.856Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ivintik/dev/personal/codeharness/src/modules/observability/runtime-validator.ts","content":"/**\n * Standalone runtime validator — validates telemetry outside Docker verification.\n * Implements Story 2.3: run tests with OTLP, query backend, report module coverage.\n */\n\nimport { execSync } from 'node:child_process';\nimport { readdirSync, statSync } from 'node:fs';\nimport { join } from 'node:path';\nimport { ok, fail } from '../../types/result.js';\nimport type { Result } from '../../types/result.js';\nimport type {\n  RuntimeValidationConfig,\n  RuntimeValidationResult,\n  ModuleTelemetryEntry,\n  TelemetryEvent,\n} from './types.js';\n\nconst DEFAULT_CONFIG: RuntimeValidationConfig = {\n  testCommand: 'npm test',\n  otlpEndpoint: 'http://localhost:4318',\n  queryEndpoint: 'http://localhost:9428',\n  timeoutMs: 120_000,\n};\n\nconst HEALTH_TIMEOUT_MS = 3_000;\nconst QUERY_TIMEOUT_MS = 30_000;\n/** Run tests with OTLP enabled, query backend for events, compute module coverage. */\nexport async function validateRuntime(\n  projectDir: string,\n  config?: Partial<RuntimeValidationConfig>,\n): Promise<Result<RuntimeValidationResult>> {\n  if (!projectDir || typeof projectDir !== 'string') {\n    return fail('projectDir is required and must be a non-empty string');\n  }\n\n  const cfg: RuntimeValidationConfig = { ...DEFAULT_CONFIG, ...config };\n\n  // Reject test commands containing shell metacharacters to prevent injection\n  if (/[;&|`$(){}!#]/.test(cfg.testCommand)) {\n    return fail(`testCommand contains disallowed shell metacharacters: ${cfg.testCommand}`);\n  }\n\n  // Step 1: Check backend health\n  const healthy = await checkBackendHealth(cfg.queryEndpoint);\n  if (!healthy) {\n    const modules = discoverModules(projectDir);\n    const entries: ModuleTelemetryEntry[] = modules.map((m) => ({\n      moduleName: m,\n      telemetryDetected: false,\n      eventCount: 0,\n    }));\n    return ok({\n      entries,\n      totalModules: modules.length,\n      modulesWithTelemetry: 0,\n      coveragePercent: 0,\n      skipped: true,\n      skipReason: 'runtime validation skipped -- observability stack not available',\n    });\n  }\n\n  // Step 2: Record start time and run tests\n  const startTime = new Date().toISOString();\n  try {\n    execSync(cfg.testCommand, {\n      cwd: projectDir,\n      timeout: cfg.timeoutMs,\n      env: {\n        ...process.env,\n        OTEL_EXPORTER_OTLP_ENDPOINT: cfg.otlpEndpoint,\n      },\n      stdio: 'pipe',\n    });\n  } catch (err: unknown) {\n    const msg = err instanceof Error ? err.message : String(err);\n    return fail(`Test command failed: ${msg}`);\n  }\n  const endTime = new Date().toISOString();\n\n  // Step 3: Query telemetry events\n  const eventsResult = await queryTelemetryEvents(cfg.queryEndpoint, startTime, endTime);\n  if (!eventsResult.success) {\n    return fail(eventsResult.error);\n  }\n\n  // Step 4: Map events to modules and compute coverage\n  const modules = discoverModules(projectDir);\n  const entries = mapEventsToModules(eventsResult.data, projectDir, modules);\n  const modulesWithTelemetry = entries.filter((e) => e.telemetryDetected).length;\n  const totalModules = entries.length;\n  const coveragePercent = totalModules === 0 ? 0 : (modulesWithTelemetry / totalModules) * 100;\n\n  return ok({\n    entries,\n    totalModules,\n    modulesWithTelemetry,\n    coveragePercent,\n    skipped: false,\n  });\n}\n\n/** Check if the observability backend is reachable (2xx within 3s). */\nexport async function checkBackendHealth(queryEndpoint: string): Promise<boolean> {\n  try {\n    const response = await fetch(`${queryEndpoint}/health`, {\n      signal: AbortSignal.timeout(HEALTH_TIMEOUT_MS),\n    });\n    return response.ok;\n  } catch {\n    return false;\n  }\n}\n\n/** Query VictoriaLogs for telemetry events within a time window. */\nexport async function queryTelemetryEvents(\n  queryEndpoint: string,\n  startTime: string,\n  endTime: string,\n): Promise<Result<TelemetryEvent[]>> {\n  let url: URL;\n  try {\n    url = new URL('/select/logsql/query', queryEndpoint);\n  } catch {\n    return fail(`Invalid queryEndpoint URL: ${queryEndpoint}`);\n  }\n  url.searchParams.set('query', '_stream_id:*');\n  url.searchParams.set('start', startTime);\n  url.searchParams.set('end', endTime);\n  url.searchParams.set('limit', '1000');\n\n  try {\n    const response = await fetch(url.toString(), {\n      signal: AbortSignal.timeout(QUERY_TIMEOUT_MS),\n    });\n    if (!response.ok) {\n      return fail(`VictoriaLogs returned ${response.status}`);\n    }\n    const text = await response.text();\n    const events = parseLogEvents(text);\n    return ok(events);\n  } catch (err: unknown) {\n    const msg = err instanceof Error ? err.message : String(err);\n    return fail(`Failed to query telemetry events: ${msg}`);\n  }\n}\n\n/** Map telemetry events to project modules by matching source paths. */\nexport function mapEventsToModules(\n  events: TelemetryEvent[],\n  projectDir: string,\n  modules?: string[],\n): ModuleTelemetryEntry[] {\n  void projectDir; // Reserved for future source-path resolution\n  const moduleList = modules ?? [];\n  const moduleCounts = new Map<string, number>();\n  for (const mod of moduleList) {\n    moduleCounts.set(mod, 0);\n  }\n\n  for (const event of events) {\n    for (const mod of moduleList) {\n      if (event.source.includes(mod) || event.message.includes(mod)) {\n        moduleCounts.set(mod, (moduleCounts.get(mod) ?? 0) + 1);\n      }\n    }\n  }\n\n  return moduleList.map((mod) => {\n    const count = moduleCounts.get(mod) ?? 0;\n    return {\n      moduleName: mod,\n      telemetryDetected: count > 0,\n      eventCount: count,\n    };\n  });\n}\n\n/** Discover top-level module directories under src/ */\nfunction discoverModules(projectDir: string): string[] {\n  const srcDir = join(projectDir, 'src');\n  try {\n    return readdirSync(srcDir).filter((name) => {\n      try {\n        return statSync(join(srcDir, name)).isDirectory();\n      } catch {\n        return false;\n      }\n    });\n  } catch {\n    return [];\n  }\n}\n\n/** Parse newline-delimited JSON from VictoriaLogs into TelemetryEvent[] */\nfunction parseLogEvents(text: string): TelemetryEvent[] {\n  if (!text.trim()) return [];\n  const lines = text.trim().split('\\n');\n  const events: TelemetryEvent[] = [];\n  for (const line of lines) {\n    try {\n      const raw = JSON.parse(line) as Record<string, unknown>;\n      events.push({\n        timestamp: String(raw._time ?? raw.timestamp ?? ''),\n        message: String(raw._msg ?? raw.message ?? ''),\n        source: String(raw.source ?? raw._source ?? raw.service ?? ''),\n      });\n    } catch {\n      // skip malformed lines\n    }\n  }\n  return events;\n}\n","numLines":213,"startLine":1,"totalLines":213}}}
