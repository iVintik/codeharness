{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FU25nxZwGFrovt3zAfJqgb","type":"tool_result","content":"1\t/**\n2\t * Lane Pool.\n3\t *\n4\t * Schedules epics concurrently up to `maxParallel` using a fixed-size\n5\t * lane pool. Each lane is an async task backed by a git worktree that\n6\t * runs a workflow engine instance via a caller-provided callback.\n7\t * `Promise.race()` detects lane completion and schedules the next\n8\t * independent epic.\n9\t *\n10\t * @see Story 17-2: Lane Pool\n11\t */\n12\t\n13\timport type { WorktreeManager } from './worktree-manager.js';\n14\timport type { EngineResult } from './workflow-engine.js';\n15\t\n16\t// --- Types ---\n17\t\n18\t/**\n19\t * Describes an epic to be scheduled in the lane pool.\n20\t */\n21\texport interface EpicDescriptor {\n22\t  /** Unique epic identifier. */\n23\t  readonly id: string;\n24\t  /** Human-readable slug for branch naming. */\n25\t  readonly slug: string;\n26\t  /** Story keys belonging to this epic. */\n27\t  readonly stories: string[];\n28\t}\n29\t\n30\t/**\n31\t * Status of an individual lane.\n32\t */\n33\texport type LaneStatus = 'executing' | 'completed' | 'failed';\n34\t\n35\t/**\n36\t * Internal representation of an active lane.\n37\t */\n38\texport interface Lane {\n39\t  /** The epic identifier running in this lane. */\n40\t  readonly epicId: string;\n41\t  /** The lane index (0-based). */\n42\t  readonly laneIndex: number;\n43\t  /** Absolute path to the worktree directory. */\n44\t  readonly worktreePath: string;\n45\t  /** Current lane status. */\n46\t  status: LaneStatus;\n47\t  /** The promise tracking the epic execution. */\n48\t  readonly promise: Promise<EngineResult>;\n49\t}\n50\t\n51\t/**\n52\t * Event emitted during lane pool execution for TUI consumption.\n53\t */\n54\texport interface LaneEvent {\n55\t  /** Event type. */\n56\t  readonly type: 'lane-started' | 'lane-completed' | 'lane-failed' | 'epic-queued';\n57\t  /** The epic identifier. */\n58\t  readonly epicId: string;\n59\t  /** The lane index (0-based, -1 for queued events). */\n60\t  readonly laneIndex: number;\n61\t  /** ISO 8601 timestamp. */\n62\t  readonly timestamp: string;\n63\t  /** Error message (only for `lane-failed` events). */\n64\t  readonly error?: string;\n65\t  /** Engine result (only for `lane-completed` events). */\n66\t  readonly result?: EngineResult;\n67\t}\n68\t\n69\t/**\n70\t * Per-epic result collected after execution.\n71\t */\n72\texport interface EpicResult {\n73\t  /** The epic identifier. */\n74\t  readonly epicId: string;\n75\t  /** Final status. */\n76\t  readonly status: 'completed' | 'failed';\n77\t  /** Engine result (only for completed epics). */\n78\t  readonly engineResult?: EngineResult;\n79\t  /** Error message (only for failed epics). */\n80\t  readonly error?: string;\n81\t  /** Wall-clock duration in milliseconds. */\n82\t  readonly durationMs: number;\n83\t}\n84\t\n85\t/**\n86\t * Aggregate result returned when all epics have been processed.\n87\t */\n88\texport interface PoolResult {\n89\t  /** True if all epics completed successfully. */\n90\t  readonly success: boolean;\n91\t  /** Total number of epics processed (completed + failed). */\n92\t  readonly epicsProcessed: number;\n93\t  /** Per-epic results keyed by epic ID. */\n94\t  readonly epicResults: Map<string, EpicResult>;\n95\t  /** Wall-clock duration of the entire pool run in milliseconds. */\n96\t  readonly durationMs: number;\n97\t}\n98\t\n99\t/**\n100\t * Callback function that executes an epic's stories in a worktree.\n101\t *\n102\t * @param epicId  The epic identifier.\n103\t * @param worktreePath  Absolute path to the worktree directory (use as `cwd`).\n104\t * @returns The engine result for the epic.\n105\t */\n106\texport type ExecuteEpicFn = (epicId: string, worktreePath: string) => Promise<EngineResult>;\n107\t\n108\t// --- Error Class ---\n109\t\n110\t/**\n111\t * Error thrown by lane pool operations.\n112\t */\n113\texport class LanePoolError extends Error {\n114\t  constructor(message: string) {\n115\t    super(message);\n116\t    this.name = 'LanePoolError';\n117\t  }\n118\t}\n119\t\n120\t// --- LanePool Class ---\n121\t\n122\t/**\n123\t * Lane pool that schedules epics concurrently up to `maxParallel`.\n124\t *\n125\t * Each lane gets its own worktree via `WorktreeManager` and runs\n126\t * the workflow engine via a caller-provided `ExecuteEpicFn` callback.\n127\t * `Promise.race()` detects lane completion and the next independent\n128\t * epic is scheduled into the freed slot.\n129\t */\n130\texport class LanePool {\n131\t  private readonly worktreeManager: WorktreeManager;\n132\t  private readonly maxParallel: number;\n133\t  private readonly listeners: Array<(event: LaneEvent) => void> = [];\n134\t\n135\t  // Internal state (set during startPool)\n136\t  private activeLanes: Map<string, Lane> = new Map();\n137\t  private completedEpicIds: Set<string> = new Set();\n138\t  private failedEpicIds: Set<string> = new Set();\n139\t  private epicIndexMap: Map<string, number> = new Map();\n140\t  private laneCounter = 0;\n141\t\n142\t  /**\n143\t   * @param worktreeManager  The worktree manager for creating/cleaning up worktrees.\n144\t   * @param maxParallel  Maximum number of lanes to run simultaneously.\n145\t   */\n146\t  constructor(worktreeManager: WorktreeManager, maxParallel: number) {\n147\t    if (maxParallel < 1) {\n148\t      throw new LanePoolError('maxParallel must be at least 1');\n149\t    }\n150\t    this.worktreeManager = worktreeManager;\n151\t    this.maxParallel = maxParallel;\n152\t  }\n153\t\n154\t  /**\n155\t   * Register a listener for lane events.\n156\t   *\n157\t   * @param callback  Function called for each `LaneEvent`.\n158\t   */\n159\t  onEvent(callback: (event: LaneEvent) => void): void {\n160\t    this.listeners.push(callback);\n161\t  }\n162\t\n163\t  /**\n164\t   * Run all epics through the lane pool.\n165\t   *\n166\t   * Creates up to `maxParallel` lanes simultaneously. Each lane\n167\t   * executes one epic via the provided callback. When a lane completes,\n168\t   * the next independent epic is scheduled.\n169\t   *\n170\t   * @param epics  The epics to execute.\n171\t   * @param executeFn  Callback that runs the workflow engine for an epic.\n172\t   * @returns Aggregate pool result with per-epic outcomes.\n173\t   */\n174\t  async startPool(epics: EpicDescriptor[], executeFn: ExecuteEpicFn): Promise<PoolResult> {\n175\t    const poolStart = Date.now();\n176\t\n177\t    // Edge case: empty epics array (AC #11)\n178\t    if (epics.length === 0) {\n179\t      return {\n180\t        success: true,\n181\t        epicsProcessed: 0,\n182\t        epicResults: new Map(),\n183\t        durationMs: Date.now() - poolStart,\n184\t      };\n185\t    }\n186\t\n187\t    // Reset internal state\n188\t    this.activeLanes = new Map();\n189\t    this.completedEpicIds = new Set();\n190\t    this.failedEpicIds = new Set();\n191\t    this.epicIndexMap = new Map();\n192\t    this.laneCounter = 0;\n193\t\n194\t    // Build index map and pending queue\n195\t    const pendingEpics: EpicDescriptor[] = [];\n196\t    for (let i = 0; i < epics.length; i++) {\n197\t      this.epicIndexMap.set(epics[i].id, i);\n198\t      pendingEpics.push(epics[i]);\n199\t    }\n200\t\n201\t    // Emit epic-queued events\n202\t    for (const epic of epics) {\n203\t      this.emit({\n204\t        type: 'epic-queued',\n205\t        epicId: epic.id,\n206\t        laneIndex: -1,\n207\t        timestamp: new Date().toISOString(),\n208\t      });\n209\t    }\n210\t\n211\t    const epicResults = new Map<string, EpicResult>();\n212\t    const epicStartTimes = new Map<string, number>();\n213\t\n214\t    // Main scheduling loop (AC #3, #4)\n215\t    while (pendingEpics.length > 0 || this.activeLanes.size > 0) {\n216\t      // Collect ready epics to fill lanes up to maxParallel (AC #1, #2)\n217\t      // Determine candidates BEFORE adding to activeLanes so that epics\n218\t      // in the same batch don't block each other's independence check.\n219\t      const slotsAvailable = this.maxParallel - this.activeLanes.size;\n220\t      const candidates: EpicDescriptor[] = [];\n221\t\n222\t      for (let s = 0; s < slotsAvailable && pendingEpics.length > 0; s++) {\n223\t        const readyIndex = this.findNextReadyEpic(pendingEpics);\n224\t        if (readyIndex === -1) break;\n225\t        candidates.push(pendingEpics.splice(readyIndex, 1)[0]);\n226\t      }\n227\t\n228\t      // Launch all candidates into lanes\n229\t      for (const epic of candidates) {\n230\t        epicStartTimes.set(epic.id, Date.now());\n231\t        const lane = this.createLane(epic, executeFn);\n232\t        if (lane) {\n233\t          this.activeLanes.set(epic.id, lane);\n234\t        } else {\n235\t          // Worktree creation failed — treat as lane failure (AC #8)\n236\t          const duration = Date.now() - epicStartTimes.get(epic.id)!;\n237\t          this.failedEpicIds.add(epic.id);\n238\t          epicResults.set(epic.id, {\n239\t            epicId: epic.id,\n240\t            status: 'failed',\n241\t            error: 'Worktree creation failed',\n242\t            durationMs: duration,\n243\t          });\n244\t        }\n245\t      }\n246\t\n247\t      // If no active lanes, break (all remaining epics are blocked or done)\n248\t      if (this.activeLanes.size === 0) break;\n249\t\n250\t      // Wait for any lane to complete via Promise.race (AC #4)\n251\t      const completed = await Promise.race(\n252\t        [...this.activeLanes.values()].map((l) =>\n253\t          l.promise.then(\n254\t            (result) => ({ epicId: l.epicId, result, error: undefined as string | undefined }),\n255\t            (err: unknown) => ({\n256\t              epicId: l.epicId,\n257\t              result: undefined as EngineResult | undefined,\n258\t              error: err instanceof Error ? err.message : String(err),\n259\t            }),\n260\t          ),\n261\t        ),\n262\t      );\n263\t\n264\t      // Process the completed lane\n265\t      const lane = this.activeLanes.get(completed.epicId)!;\n266\t      this.activeLanes.delete(completed.epicId);\n267\t      const epicDuration = Date.now() - epicStartTimes.get(completed.epicId)!;\n268\t\n269\t      if (completed.error === undefined && completed.result) {\n270\t        // Lane success (AC #4)\n271\t        this.completedEpicIds.add(completed.epicId);\n272\t        epicResults.set(completed.epicId, {\n273\t          epicId: completed.epicId,\n274\t          status: 'completed',\n275\t          engineResult: completed.result,\n276\t          durationMs: epicDuration,\n277\t        });\n278\t        this.emit({\n279\t          type: 'lane-completed',\n280\t          epicId: completed.epicId,\n281\t          laneIndex: lane.laneIndex,\n282\t          timestamp: new Date().toISOString(),\n283\t          result: completed.result,\n284\t        });\n285\t      } else {\n286\t        // Lane failure (AC #8)\n287\t        this.failedEpicIds.add(completed.epicId);\n288\t        epicResults.set(completed.epicId, {\n289\t          epicId: completed.epicId,\n290\t          status: 'failed',\n291\t          error: completed.error ?? 'Unknown error',\n292\t          durationMs: epicDuration,\n293\t        });\n294\t\n295\t        // Clean up worktree on failure\n296\t        try {\n297\t          this.worktreeManager.cleanupWorktree(completed.epicId);\n298\t        } catch { // IGNORE: worktree cleanup is best-effort — failure does not affect pool scheduling per AC #8\n299\t        }\n300\t\n301\t        this.emit({\n302\t          type: 'lane-failed',\n303\t          epicId: completed.epicId,\n304\t          laneIndex: lane.laneIndex,\n305\t          timestamp: new Date().toISOString(),\n306\t          error: completed.error ?? 'Unknown error',\n307\t        });\n308\t      }\n309\t    }\n310\t\n311\t    // Build final result (AC #9)\n312\t    const allSuccess = this.failedEpicIds.size === 0 && this.completedEpicIds.size === epics.length;\n313\t\n314\t    return {\n315\t      success: allSuccess,\n316\t      epicsProcessed: epicResults.size,\n317\t      epicResults,\n318\t      durationMs: Date.now() - poolStart,\n319\t    };\n320\t  }\n321\t\n322\t  // --- Private Methods ---\n323\t\n324\t  /**\n325\t   * Create a lane for an epic: create worktree, then start execution.\n326\t   *\n327\t   * @returns The lane, or `null` if worktree creation failed.\n328\t   */\n329\t  private createLane(\n330\t    epic: EpicDescriptor,\n331\t    executeFn: ExecuteEpicFn,\n332\t  ): Lane | null {\n333\t    const laneIndex = this.laneCounter++;\n334\t    let worktreePath: string;\n335\t\n336\t    try {\n337\t      worktreePath = this.worktreeManager.createWorktree(epic.id, epic.slug);\n338\t    } catch (err: unknown) {\n339\t      // Worktree creation failure — emit lane-failed event (AC #8)\n340\t      const errorMsg = err instanceof Error ? err.message : String(err);\n341\t      this.emit({\n342\t        type: 'lane-failed',\n343\t        epicId: epic.id,\n344\t        laneIndex,\n345\t        timestamp: new Date().toISOString(),\n346\t        error: errorMsg,\n347\t      });\n348\t      return null;\n349\t    }\n350\t\n351\t    // Emit lane-started event (AC #6)\n352\t    this.emit({\n353\t      type: 'lane-started',\n354\t      epicId: epic.id,\n355\t      laneIndex,\n356\t      timestamp: new Date().toISOString(),\n357\t    });\n358\t\n359\t    // Start execution (AC #3) — the promise tracks completion\n360\t    const promise = executeFn(epic.id, worktreePath);\n361\t\n362\t    return {\n363\t      epicId: epic.id,\n364\t      laneIndex,\n365\t      worktreePath,\n366\t      status: 'executing',\n367\t      promise,\n368\t    };\n369\t  }\n370\t\n371\t  /**\n372\t   * Find the index of the next ready epic in the pending queue.\n373\t   *\n374\t   * Epic N is ready only if no epic with index < N is still active\n375\t   * (except those already done/failed). (AC #5)\n376\t   *\n377\t   * @returns Index into `pendingEpics`, or -1 if none are ready.\n378\t   */\n379\t  private findNextReadyEpic(pendingEpics: EpicDescriptor[]): number {\n380\t    for (let i = 0; i < pendingEpics.length; i++) {\n381\t      const epicIndex = this.epicIndexMap.get(pendingEpics[i].id)!;\n382\t      if (this.isEpicReady(epicIndex)) {\n383\t        return i;\n384\t      }\n385\t    }\n386\t    return -1;\n387\t  }\n388\t\n389\t  /**\n390\t   * Check if an epic is ready to be scheduled.\n391\t   *\n392\t   * Epic N is ready only if no epic with a lower index is still\n393\t   * active (i.e., all preceding epics are either completed or failed).\n394\t   */\n395\t  private isEpicReady(epicIndex: number): boolean {\n396\t    for (const [, lane] of this.activeLanes) {\n397\t      const activeIndex = this.epicIndexMap.get(lane.epicId);\n398\t      if (activeIndex !== undefined && activeIndex < epicIndex) {\n399\t        return false;\n400\t      }\n401\t    }\n402\t    return true;\n403\t  }\n404\t\n405\t  /**\n406\t   * Emit a lane event to all registered listeners.\n407\t   */\n408\t  private emit(event: LaneEvent): void {\n409\t    for (const listener of this.listeners) {\n410\t      listener(event);\n411\t    }\n412\t  }\n413\t}\n414\t"}]},"parent_tool_use_id":"toolu_01KrDuJXvL9iMGiH4fKqNTEw","session_id":"1e0d780f-040f-4c10-b8e5-df49ae6fae2c","uuid":"9eea8cea-7366-4893-906f-33d2b7ab0595","timestamp":"2026-04-03T20:57:46.000Z"}
