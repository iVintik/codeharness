{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01W448Tve3TQEgmi5uSHPW5q","type":"tool_result","content":"    85→\n    86→  it('prints per-epic summary and total imported count', async () => {\n    87→    const program = createProgram();\n    88→\n    89→    await program.parseAsync(['node', 'test', 'bridge', '--epics', SAMPLE_EPICS]);\n    90→\n    91→    const calls = consoleSpy.mock.calls.map(c => c[0] as string);\n    92→    expect(calls).toContainEqual(expect.stringContaining('[OK] Epic 1: Foundation'));\n    93→    expect(calls).toContainEqual(expect.stringContaining('[OK] Epic 2: Core Features'));\n    94→    expect(calls).toContainEqual(expect.stringContaining('[OK] Epic 3: Polish'));\n    95→    expect(calls).toContainEqual(expect.stringContaining('[OK] Bridge: 5 stories processed'));\n    96→    expect(process.exitCode).toBe(0);\n    97→  });\n    98→\n    99→  it('--dry-run mode prints without creating beads issues', async () => {\n   100→    const program = createProgram();\n   101→\n   102→    await program.parseAsync(['node', 'test', 'bridge', '--epics', SAMPLE_EPICS, '--dry-run']);\n   103→\n   104→    expect(mockCreateIssue).not.toHaveBeenCalled();\n   105→    const calls = consoleSpy.mock.calls.map(c => c[0] as string);\n   106→    expect(calls).toContainEqual(expect.stringContaining('[INFO] Dry run: would import'));\n   107→    expect(calls).toContainEqual(expect.stringContaining('dry run, nothing created'));\n   108→    expect(process.exitCode).toBe(0);\n   109→  });\n   110→\n   111→  it('--json outputs valid JSON with expected structure', async () => {\n   112→    const program = createProgram();\n   113→\n   114→    await program.parseAsync(['node', 'test', '--json', 'bridge', '--epics', SAMPLE_EPICS, '--dry-run']);\n   115→\n   116→    // Find the JSON output call (the one with the BridgeResult)\n   117→    const jsonCalls = consoleSpy.mock.calls.filter(c => {\n   118→      const msg = c[0] as string;\n   119→      try {\n   120→        const parsed = JSON.parse(msg) as Record<string, unknown>;\n   121→        return 'epics_parsed' in parsed;\n   122→      } catch {\n   123→        return false;\n   124→      }\n   125→    });\n   126→\n   127→    expect(jsonCalls).toHaveLength(1);\n   128→    const result = JSON.parse(jsonCalls[0][0] as string) as Record<string, unknown>;\n   129→    expect(result.status).toBe('ok');\n   130→    expect(result.epics_parsed).toBe(3);\n   131→    expect(result.stories_processed).toBe(5);\n   132→    expect(result.stories_created).toBe(0); // dry run\n   133→    expect(result.stories_existing).toBe(0);\n   134→    expect(Array.isArray(result.results)).toBe(true);\n   135→    const results = result.results as Array<Record<string, unknown>>;\n   136→    expect(results.length).toBe(5);\n   137→    expect(results[0]).toHaveProperty('storyKey');\n   138→    expect(results[0]).toHaveProperty('title');\n   139→    expect(results[0]).toHaveProperty('storyFilePath');\n   140→  });\n   141→\n   142→  it('handles empty epics file gracefully', async () => {\n   143→    const emptyFile = join(testDir, 'empty.md');\n   144→    writeFileSync(emptyFile, '');\n   145→    const program = createProgram();\n   146→\n   147→    await program.parseAsync(['node', 'test', 'bridge', '--epics', emptyFile]);\n   148→\n   149→    const calls = consoleSpy.mock.calls.map(c => c[0] as string);\n   150→    expect(calls).toContainEqual(expect.stringContaining('[WARN] No stories found'));\n   151→    expect(process.exitCode).toBe(0);\n   152→  });\n   153→\n   154→  it('warns about stories without acceptance criteria', async () => {\n   155→    const program = createProgram();\n   156→\n   157→    await program.parseAsync(['node', 'test', 'bridge', '--epics', SAMPLE_EPICS, '--dry-run']);\n   158→\n   159→    const calls = consoleSpy.mock.calls.map(c => c[0] as string);\n   160→    expect(calls).toContainEqual(\n   161→      expect.stringContaining('[WARN] Story Story Without ACs: no