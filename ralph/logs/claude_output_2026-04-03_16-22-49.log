{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0183aRdrbCrEMw7DPiajP5wf","type":"tool_result","content":"1\t{\n2\t  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n3\t  \"$id\": \"https://codeharness.dev/schemas/agent.schema.json\",\n4\t  \"title\": \"Codeharness Agent\",\n5\t  \"description\": \"Schema for codeharness agent configuration YAML files\",\n6\t  \"type\": \"object\",\n7\t  \"required\": [\"name\", \"role\", \"persona\"],\n8\t  \"properties\": {\n9\t    \"name\": {\n10\t      \"type\": \"string\",\n11\t      \"minLength\": 1,\n12\t      \"description\": \"Agent identifier\"\n13\t    },\n14\t    \"role\": {\n15\t      \"type\": \"object\",\n16\t      \"required\": [\"title\", \"purpose\"],\n17\t      \"properties\": {\n18\t        \"title\": {\n19\t          \"type\": \"string\",\n20\t          \"minLength\": 1,\n21\t          \"description\": \"Agent's role title\"\n22\t        },\n23\t        \"purpose\": {\n24\t          \"type\": \"string\",\n25\t          \"minLength\": 1,\n26\t          \"description\": \"What this agent does\"\n27\t        }\n28\t      },\n29\t      \"additionalProperties\": false\n30\t    },\n31\t    \"persona\": {\n32\t      \"type\": \"object\",\n33\t      \"required\": [\"identity\", \"communication_style\", \"principles\"],\n34\t      \"properties\": {\n35\t        \"identity\": {\n36\t          \"type\": \"string\",\n37\t          \"minLength\": 1,\n38\t          \"description\": \"Who this agent is\"\n39\t        },\n40\t        \"communication_style\": {\n41\t          \"type\": \"string\",\n42\t          \"minLength\": 1,\n43\t          \"description\": \"How this agent communicates\"\n44\t        },\n45\t        \"principles\": {\n46\t          \"type\": \"array\",\n47\t          \"items\": {\n48\t            \"type\": \"string\",\n49\t            \"minLength\": 1\n50\t          },\n51\t          \"minItems\": 1,\n52\t          \"description\": \"Behavioral principles\"\n53\t        }\n54\t      },\n55\t      \"additionalProperties\": false\n56\t    },\n57\t    \"personality\": {\n58\t      \"type\": \"object\",\n59\t      \"required\": [\"traits\"],\n60\t      \"properties\": {\n61\t        \"traits\": {\n62\t          \"type\": \"object\",\n63\t          \"additionalProperties\": {\n64\t            \"type\": \"number\",\n65\t            \"minimum\": 0,\n66\t            \"maximum\": 1\n67\t          },\n68\t          \"description\": \"PersonaNexus-compatible traits with values constrained to 0-1\"\n69\t        }\n70\t      },\n71\t      \"additionalProperties\": false\n72\t    },\n73\t    \"disallowedTools\": {\n74\t      \"type\": \"array\",\n75\t      \"items\": {\n76\t        \"type\": \"string\"\n77\t      },\n78\t      \"description\": \"Tools this agent is not allowed to use\"\n79\t    },\n80\t    \"prompt_template\": {\n81\t      \"type\": \"string\",\n82\t      \"description\": \"Task-specific prompt template included in compiled instructions\"\n83\t    }\n84\t  },\n85\t  \"additionalProperties\": false\n86\t}\n87\t"}]},"parent_tool_use_id":"toolu_01MERTQEVoM1FQ7mMnPAJnfv","session_id":"49777568-67d3-419d-b985-1c272283fc99","uuid":"e701c633-749c-42cc-a61f-3d8d894aa1f9","timestamp":"2026-04-03T12:25:09.761Z"}
