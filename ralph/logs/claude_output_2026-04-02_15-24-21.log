{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MyycDdPGwrZLskcAnpEPNM","type":"tool_result","content":"1\timport { readFileSync } from 'node:fs';\n2\timport { parse } from 'yaml';\n3\timport { validateWorkflowSchema } from './schema-validate.js';\n4\t\n5\t// --- Interfaces ---\n6\t\n7\texport interface ResolvedTask {\n8\t  agent: string;\n9\t  scope: 'per-story' | 'per-run';\n10\t  session: 'fresh' | 'continue';\n11\t  source_access: boolean;\n12\t  prompt_template?: string;\n13\t  input_contract?: Record<string, unknown>;\n14\t  output_contract?: Record<string, unknown>;\n15\t  max_budget_usd?: number;\n16\t}\n17\t\n18\texport interface LoopBlock {\n19\t  loop: string[];\n20\t}\n21\t\n22\texport type FlowStep = string | LoopBlock;\n23\t\n24\texport interface ResolvedWorkflow {\n25\t  tasks: Record<string, ResolvedTask>;\n26\t  flow: FlowStep[];\n27\t}\n28\t\n29\t// --- Error Class ---\n30\t\n31\texport class WorkflowParseError extends Error {\n32\t  public readonly errors: Array<{ path: string; message: string }>;\n33\t\n34\t  constructor(message: string, errors?: Array<{ path: string; message: string }>) {\n35\t    super(message);\n36\t    this.name = 'WorkflowParseError';\n37\t    this.errors = errors ?? [];\n38\t  }\n39\t}\n40\t\n41\t// --- Parser ---\n42\t\n43\t/**\n44\t * Parse a workflow YAML file from disk, validate it against the JSON schema,\n45\t * check referential integrity, apply defaults, and return a typed ResolvedWorkflow.\n46\t */\n47\texport function parseWorkflow(filePath: string): ResolvedWorkflow {\n48\t  // 1. Read file\n49\t  let raw: string;\n50\t  try {\n51\t    raw = readFileSync(filePath, 'utf-8');\n52\t  } catch {\n53\t    throw new WorkflowParseError(`File not found: ${filePath}`, [\n54\t      { path: filePath, message: 'File not found or unreadable' },\n55\t    ]);\n56\t  }\n57\t\n58\t  // 2. Parse YAML\n59\t  let parsed: unknown;\n60\t  try {\n61\t    parsed = parse(raw);\n62\t  } catch (err: unknown) {\n63\t    const yamlMsg = err instanceof Error ? err.message : String(err);\n64\t    throw new WorkflowParseError(`Invalid YAML syntax: ${yamlMsg}`, [\n65\t      { path: filePath, message: yamlMsg },\n66\t    ]);\n67\t  }\n68\t\n69\t  // 3. Validate against JSON schema\n70\t  const result = validateWorkflowSchema(parsed);\n71\t  if (!result.valid) {\n72\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n73\t    throw new WorkflowParseError(\n74\t      `Schema validation failed: ${details}`,\n75\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n76\t    );\n77\t  }\n78\t\n79\t  // At this point, parsed has passed schema validation — safe to cast\n80\t  const data = parsed as { tasks: Record<string, Record<string, unknown>>; flow: unknown[] };\n81\t\n82\t  // 4. Referential integrity check\n83\t  const taskNames = new Set(Object.keys(data.tasks));\n84\t  const danglingRefs: Array<{ path: string; message: string }> = [];\n85\t\n86\t  for (let i = 0; i < data.flow.length; i++) {\n87\t    const step = data.flow[i];\n88\t    if (typeof step === 'string') {\n89\t      if (!taskNames.has(step)) {\n90\t        danglingRefs.push({\n91\t          path: `/flow/${i}`,\n92\t          message: `Task \"${step}\" referenced in flow but not defined in tasks`,\n93\t        });\n94\t      }\n95\t    } else if (typeof step === 'object' && step !== null && 'loop' in step) {\n96\t      const loopBlock = step as { loop: string[] };\n97\t      for (let j = 0; j < loopBlock.loop.length; j++) {\n98\t        const ref = loopBlock.loop[j];\n99\t        if (!taskNames.has(ref)) {\n100\t          danglingRefs.push({\n101\t            path: `/flow/${i}/loop/${j}`,\n102\t            message: `Task \"${ref}\" referenced in loop but not defined in tasks`,\n103\t          });\n104\t        }\n105\t      }\n106\t    }\n107\t  }\n108\t\n109\t  if (danglingRefs.length > 0) {\n110\t    const details = danglingRefs.map((e) => e.message).join('; ');\n111\t    throw new WorkflowParseError(`Dangling task references: ${details}`, danglingRefs);\n112\t  }\n113\t\n114\t  // 5. Apply defaults and build resolved tasks\n115\t  const resolvedTasks: Record<string, ResolvedTask> = {};\n116\t  for (const [name, task] of Object.entries(data.tasks)) {\n117\t    const resolved: ResolvedTask = {\n118\t      agent: task.agent as string,\n119\t      scope: (task.scope as ResolvedTask['scope']) ?? 'per-story',\n120\t      session: (task.session as ResolvedTask['session']) ?? 'fresh',\n121\t      source_access: (task.source_access as boolean) ?? true,\n122\t    };\n123\t    if (task.prompt_template !== undefined) {\n124\t      resolved.prompt_template = task.prompt_template as string;\n125\t    }\n126\t    if (task.input_contract !== undefined) {\n127\t      resolved.input_contract = task.input_contract as Record<string, unknown>;\n128\t    }\n129\t    if (task.output_contract !== undefined) {\n130\t      resolved.output_contract = task.output_contract as Record<string, unknown>;\n131\t    }\n132\t    if (task.max_budget_usd !== undefined) {\n133\t      resolved.max_budget_usd = task.max_budget_usd as number;\n134\t    }\n135\t    resolvedTasks[name] = resolved;\n136\t  }\n137\t\n138\t  // 6. Build resolved flow\n139\t  const resolvedFlow: FlowStep[] = data.flow.map((step) => {\n140\t    if (typeof step === 'string') {\n141\t      return step;\n142\t    }\n143\t    return step as LoopBlock;\n144\t  });\n145\t\n146\t  return { tasks: resolvedTasks, flow: resolvedFlow };\n147\t}\n148\t"}]},"parent_tool_use_id":"toolu_01HyS3onm3YhU66FXQgZALNu","session_id":"06dc1e0b-83a0-4950-9e66-ec9396bae461","uuid":"29b49364-c7b9-458e-bda1-50624c25a857","timestamp":"2026-04-02T11:32:39.912Z"}
