{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013kGs8qjLKqKSP2FkFKYkcV","type":"tool_result","content":"1\t/**\n2\t * Worktree Manager.\n3\t *\n4\t * Handles git worktree lifecycle for parallel epic execution:\n5\t * create, cleanup, list, and orphan detection. Each epic gets\n6\t * its own git worktree on a dedicated branch under the\n7\t * `codeharness/` namespace.\n8\t *\n9\t * @see Story 17-1: Worktree Manager\n10\t */\n11\t\n12\timport { exec, execSync } from 'node:child_process';\n13\timport { existsSync, readFileSync, statSync } from 'node:fs';\n14\timport { join } from 'node:path';\n15\timport { promisify } from 'node:util';\n16\t\n17\tconst execAsync = promisify(exec);\n18\t\n19\t// --- Constants ---\n20\t\n21\t/** Branch prefix for all codeharness worktree branches. */\n22\texport const BRANCH_PREFIX = 'codeharness/epic-';\n23\t\n24\t/** Base path for worktree directories in /tmp. */\n25\texport const WORKTREE_BASE = '/tmp/codeharness-wt-epic-';\n26\t\n27\t// --- Interfaces ---\n28\t\n29\t/**\n30\t * Information about a codeharness worktree.\n31\t */\n32\texport interface WorktreeInfo {\n33\t  /** Epic identifier extracted from the branch name. */\n34\t  readonly epicId: string;\n35\t  /** Absolute path to the worktree directory. */\n36\t  readonly path: string;\n37\t  /** Full branch name (e.g., `codeharness/epic-17-worktree-manager`). */\n38\t  readonly branch: string;\n39\t  /** Timestamp when the worktree was created. */\n40\t  readonly createdAt: Date;\n41\t}\n42\t\n43\t// --- Error Class ---\n44\t\n45\t/**\n46\t * Error thrown by worktree operations. Includes stderr from git commands.\n47\t */\n48\texport class WorktreeError extends Error {\n49\t  /** Raw stderr output from the failed git command. */\n50\t  readonly stderr: string;\n51\t\n52\t  constructor(message: string, stderr: string) {\n53\t    super(message);\n54\t    this.name = 'WorktreeError';\n55\t    this.stderr = stderr;\n56\t  }\n57\t}\n58\t\n59\t// --- Merge Types ---\n60\t\n61\t/**\n62\t * Strategy used when merging an epic branch into main.\n63\t */\n64\texport type MergeStrategy = 'rebase' | 'merge-commit';\n65\t\n66\t/**\n67\t * Result of a merge operation.\n68\t */\n69\texport interface MergeResult {\n70\t  /** Whether the merge and post-merge validation succeeded. */\n71\t  success: boolean;\n72\t  /** Reason for failure, if any. */\n73\t  reason?: 'conflict' | 'tests-failed' | 'git-error';\n74\t  /** List of conflicting file paths, when reason is 'conflict'. */\n75\t  conflicts?: string[];\n76\t  /** Test suite results from post-merge validation. */\n77\t  testResults?: { passed: number; failed: number; coverage?: number };\n78\t  /** Total wall-clock duration of the merge operation in milliseconds. */\n79\t  durationMs: number;\n80\t}\n81\t\n82\t// --- Async Mutex ---\n83\t\n84\t/**\n85\t * Simple async mutex for serializing merge operations.\n86\t * No external dependencies — uses a promise-based wait queue.\n87\t */\n88\texport class AsyncMutex {\n89\t  private locked = false;\n90\t  private waitQueue: Array<() => void> = [];\n91\t\n92\t  async acquire(): Promise<() => void> {\n93\t    while (this.locked) {\n94\t      await new Promise<void>((resolve) => this.waitQueue.push(resolve));\n95\t    }\n96\t    this.locked = true;\n97\t    return () => {\n98\t      this.locked = false;\n99\t      const next = this.waitQueue.shift();\n100\t      if (next) next();\n101\t    };\n102\t  }\n103\t}\n104\t\n105\t/** Module-level singleton merge mutex shared across all WorktreeManager instances. */\n106\texport const mergeMutex = new AsyncMutex();\n107\t\n108\t// --- WorktreeManager Class ---\n109\t\n110\t/**\n111\t * Manages git worktrees for parallel epic execution.\n112\t *\n113\t * Creates isolated working directories (worktrees) for each epic,\n114\t * each on its own branch under the `codeharness/` namespace.\n115\t */\n116\texport class WorktreeManager {\n117\t  private readonly mainBranch: string;\n118\t  private readonly cwd: string;\n119\t\n120\t  /**\n121\t   * @param mainBranch  The main branch to base new worktree branches on (default: `'main'`).\n122\t   * @param cwd  The git repository root directory (default: `process.cwd()`).\n123\t   */\n124\t  constructor(mainBranch: string = 'main', cwd?: string) {\n125\t    this.mainBranch = mainBranch;\n126\t    this.cwd = cwd ?? process.cwd();\n127\t  }\n128\t\n129\t  /**\n130\t   * Create a worktree for a parallel epic.\n131\t   *\n132\t   * Creates a branch `codeharness/epic-{epicId}-{slug}` from the main branch HEAD,\n133\t   * then creates a git worktree at `/tmp/codeharness-wt-epic-{epicId}`.\n134\t   *\n135\t   * If a stale branch or worktree exists from a previous crashed run,\n136\t   * it is cleaned up before re-creating (idempotent recovery).\n137\t   *\n138\t   * @param epicId  The epic identifier (numeric or string).\n139\t   * @param slug  A human-readable slug for the branch name (sanitized to `[a-z0-9-]`).\n140\t   * @returns The absolute path to the created worktree directory.\n141\t   * @throws {WorktreeError} If the git command fails.\n142\t   */\n143\t  createWorktree(epicId: string, slug: string): string {\n144\t    this.validateEpicId(epicId);\n145\t    const sanitizedSlug = this.sanitizeSlug(slug);\n146\t    const branchName = `${BRANCH_PREFIX}${epicId}-${sanitizedSlug}`;\n147\t    const worktreePath = `${WORKTREE_BASE}${epicId}`;\n148\t\n149\t    // Clean up stale state from previous crashed runs (AC #9)\n150\t    this.cleanupStale(epicId, branchName, worktreePath);\n151\t\n152\t    let branchCreated = false;\n153\t    try {\n154\t      // Create branch from main branch HEAD\n155\t      this.execGit(`git branch ${branchName} ${this.mainBranch}`);\n156\t      branchCreated = true;\n157\t\n158\t      // Create worktree\n159\t      this.execGit(`git worktree add ${worktreePath} ${branchName}`);\n160\t\n161\t      return worktreePath;\n162\t    } catch (err: unknown) {\n163\t      // Clean up partial state on failure (AC #10)\n164\t      this.cleanupPartial(branchCreated, branchName, worktreePath);\n165\t\n166\t      // execGit always wraps errors as WorktreeError; re-throw directly\n167\t      if (err instanceof WorktreeError) {\n168\t        throw err;\n169\t      }\n170\t\n171\t      // Defensive: handle unexpected non-WorktreeError (should not happen)\n172\t      const message = err instanceof Error ? err.message : String(err);\n173\t      throw new WorktreeError(\n174\t        `Failed to create worktree for epic ${epicId}: ${message}`,\n175\t        '',\n176\t      );\n177\t    }\n178\t  }\n179\t\n180\t  /**\n181\t   * Remove a worktree and its branch for an epic.\n182\t   *\n183\t   * Idempotent: completes without error if the worktree or branch\n184\t   * does not exist (AC #5).\n185\t   *\n186\t   * @param epicId  The epic identifier.\n187\t   */\n188\t  cleanupWorktree(epicId: string): void {\n189\t    this.validateEpicId(epicId);\n190\t    const worktreePath = `${WORKTREE_BASE}${epicId}`;\n191\t\n192\t    // Remove worktree (ignore errors if it doesn't exist)\n193\t    try {\n194\t      this.execGit(`git worktree remove ${worktreePath} --force`);\n195\t    } catch { // IGNORE: idempotent cleanup — worktree may not exist per AC #5\n196\t    }\n197\t\n198\t    // Find and delete the branch matching this epicId\n199\t    const branch = this.findBranchForEpic(epicId);\n200\t    if (branch) {\n201\t      try {\n202\t        this.execGit(`git branch -D ${branch}`);\n203\t      } catch { // IGNORE: idempotent cleanup — branch may not exist per AC #5\n204\t      }\n205\t    }\n206\t  }\n207\t\n208\t  /**\n209\t   * List all codeharness worktrees.\n210\t   *\n211\t   * @returns An array of `WorktreeInfo` objects sorted by epicId.\n212\t   *          Returns an empty array when no codeharness worktrees exist.\n213\t   */\n214\t  listWorktrees(): WorktreeInfo[] {\n215\t    let output: string;\n216\t    try {\n217\t      output = this.execGit('git worktree list --porcelain');\n218\t    } catch { // IGNORE: non-git-repo or corrupt state returns empty list safely\n219\t      return [];\n220\t    }\n221\t\n222\t    const entries = this.parsePorcelainOutput(output);\n223\t    return entries\n224\t      .filter((e) => e.branch.startsWith(`refs/heads/${BRANCH_PREFIX}`))\n225\t      .map((e) => {\n226\t        const branchName = e.branch.replace('refs/heads/', '');\n227\t        const epicId = this.extractEpicId(branchName);\n228\t        return {\n229\t          epicId,\n230\t          path: e.path,\n231\t          branch: branchName,\n232\t          createdAt: this.getWorktreeCreatedAt(e.path),\n233\t        };\n234\t      })\n235\t      .sort((a, b) => a.epicId.localeCompare(b.epicId, undefined, { numeric: true }));\n236\t  }\n237\t\n238\t  /**\n239\t   * Detect orphaned worktrees from previous crashed runs.\n240\t   *\n241\t   * A worktree is considered orphaned if its directory exists on disk\n242\t   * but has no `.codeharness/lane-state.json` file or the file has\n243\t   * no active PID.\n244\t   *\n245\t   * @returns An array of orphaned `WorktreeInfo` entries.\n246\t   */\n247\t  detectOrphans(): WorktreeInfo[] {\n248\t    const worktrees = this.listWorktrees();\n249\t    return worktrees.filter((wt) => this.isOrphaned(wt));\n250\t  }\n251\t\n252\t  /**\n253\t   * Merge an epic branch into the main branch with serialized access.\n254\t   *\n255\t   * Acquires a module-level mutex so only one merge runs at a time.\n256\t   * After a clean merge, runs the test suite. If tests fail, the merge\n257\t   * is reverted. On conflict or git error, the main branch is restored.\n258\t   *\n259\t   * @param epicId  The epic identifier whose branch should be merged.\n260\t   * @param strategy  Merge strategy: `'merge-commit'` (default) or `'rebase'`.\n261\t   * @param testCommand  Command to run for post-merge validation (default: `'npm test'`).\n262\t   * @returns A `MergeResult` describing the outcome.\n263\t   */\n264\t  async mergeWorktree(\n265\t    epicId: string,\n266\t    strategy: MergeStrategy = 'merge-commit',\n267\t    testCommand: string = 'npm test',\n268\t  ): Promise<MergeResult> {\n269\t    const start = Date.now();\n270\t\n271\t    // Validate testCommand to prevent shell injection — only allow safe characters\n272\t    if (!/^[a-zA-Z0-9_./ -]+$/.test(testCommand)) {\n273\t      return {\n274\t        success: false,\n275\t        reason: 'git-error',\n276\t        durationMs: Date.now() - start,\n277\t      };\n278\t    }\n279\t\n280\t    // Find branch for this epicId\n281\t    const branch = this.findBranchForEpic(epicId);\n282\t    if (!branch) {\n283\t      return {\n284\t        success: false,\n285\t        reason: 'git-error',\n286\t        durationMs: Date.now() - start,\n287\t      };\n288\t    }\n289\t\n290\t    // Validate branch name to prevent command injection via malicious branch names\n291\t    if (!/^[a-zA-Z0-9_./-]+$/.test(branch)) {\n292\t      return {\n293\t        success: false,\n294\t        reason: 'git-error',\n295\t        durationMs: Date.now() - start,\n296\t      };\n297\t    }\n298\t\n299\t    const release = await mergeMutex.acquire();\n300\t    try {\n301\t      // Re-verify branch still exists after acquiring mutex (could be deleted while waiting)\n302\t      const branchCheck = this.findBranchForEpic(epicId);\n303\t      if (!branchCheck || branchCheck !== branch) {\n304\t        return {\n305\t          success: false,\n306\t          reason: 'git-error',\n307\t          durationMs: Date.now() - start,\n308\t        };\n309\t      }\n310\t\n311\t      // Verify main branch is clean before merge\n312\t      const status = this.execGit('git status --porcelain');\n313\t      if (status.length > 0) {\n314\t        return {\n315\t          success: false,\n316\t          reason: 'git-error',\n317\t          durationMs: Date.now() - start,\n318\t        };\n319\t      }\n320\t\n321\t      // Attempt merge or rebase\n322\t      try {\n323\t        if (strategy === 'rebase') {\n324\t          this.execGit(`git rebase ${branch}`);\n325\t        } else {\n326\t          this.execGit(`git merge --no-ff ${branch}`);\n327\t        }\n328\t      } catch { // IGNORE: merge/rebase failure is expected — detect conflict vs git-error below\n329\t        const conflicts = this.detectConflicts();\n330\t        if (conflicts.length > 0) {\n331\t          this.abortMerge(strategy);\n332\t          return {\n333\t            success: false,\n334\t            reason: 'conflict',\n335\t            conflicts,\n336\t            durationMs: Date.now() - start,\n337\t          };\n338\t        }\n339\t        // Not a conflict — unexpected git error\n340\t        this.abortMerge(strategy);\n341\t        return {\n342\t          success: false,\n343\t          reason: 'git-error',\n344\t          durationMs: Date.now() - start,\n345\t        };\n346\t      }\n347\t\n348\t      // Run test suite after successful merge\n349\t      const testResults = await this.runTestSuite(testCommand);\n350\t      if (testResults.failed > 0) {\n351\t        // Revert merge on test failure\n352\t        try {\n353\t          this.execGit('git reset --hard HEAD~1');\n354\t        } catch { // IGNORE: reset failure indicates corrupted git state; still return tests-failed\n355\t        }\n356\t        return {\n357\t          success: false,\n358\t          reason: 'tests-failed',\n359\t          testResults,\n360\t          durationMs: Date.now() - start,\n361\t        };\n362\t      }\n363\t\n364\t      // Success — cleanup worktree\n365\t      this.cleanupWorktree(epicId);\n366\t      return {\n367\t        success: true,\n368\t        testResults,\n369\t        durationMs: Date.now() - start,\n370\t      };\n371\t    } finally {\n372\t      release();\n373\t    }\n374\t  }\n375\t\n376\t  // --- Private Helpers ---\n377\t\n378\t  /**\n379\t   * Get the creation time of a worktree directory.\n380\t   * Falls back to current time if the directory doesn't exist or