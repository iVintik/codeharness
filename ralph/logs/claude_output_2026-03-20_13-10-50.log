{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014pQR6L8g2KmgR7NZxhYbe9","type":"tool_result","content":"     1→/**\n     2→ * Sprint state — read/write unified sprint-state.json with atomic writes.\n     3→ */\n     4→\n     5→import { readFileSync, writeFileSync, renameSync, existsSync } from 'node:fs';\n     6→import { join } from 'node:path';\n     7→import { ok, fail } from '../../types/result.js';\n     8→import type { Result } from '../../types/result.js';\n     9→import type { SprintState, StoryStatus, StoryState } from '../../types/state.js';\n    10→import type { StoryDetail, RunProgressUpdate } from './types.js';\n    11→import { migrateFromOldFormat } from './migration.js';\n    12→\n    13→/** Resolve project root (directory containing package.json) */\n    14→function projectRoot(): string {\n    15→  return process.cwd();\n    16→}\n    17→\n    18→/** Path to the sprint state file */\n    19→export function statePath(): string {\n    20→  return join(projectRoot(), 'sprint-state.json');\n    21→}\n    22→\n    23→/** Path to the temporary file used for atomic writes */\n    24→function tmpPath(): string {\n    25→  return join(projectRoot(), '.sprint-state.json.tmp');\n    26→}\n    27→\n    28→/** Return an empty default SprintState */\n    29→export function defaultState(): SprintState {\n    30→  return {\n    31→    version: 1,\n    32→    sprint: {\n    33→      total: 0,\n    34→      done: 0,\n    35→      failed: 0,\n    36→      blocked: 0,\n    37→      inProgress: null,\n    38→    },\n    39→    stories: {},\n    40→    run: {\n    41→      active: false,\n    42→      startedAt: null,\n    43→      iteration: 0,\n    44→      cost: 0,\n    45→      completed: [],\n    46→      failed: [],\n    47→      currentStory: null,\n    48→      currentPhase: null,\n    49→      lastAction: null,\n    50→      acProgress: null,\n    51→    },\n    52→    actionItems: [],\n    53→  };\n    54→}\n    55→\n    56→/** Return a default StoryState */\n    57→function defaultStoryState(): StoryState {\n    58→  return {\n    59→    status: 'backlog',\n    60→    attempts: 0,\n    61→    lastAttempt: null,\n    62→    lastError: null,\n    63→    proofPath: null,\n    64→    acResults: null,\n    65→  };\n    66→}\n    67→\n    68→/**\n    69→ * Write state to disk atomically: write to tmp, then rename.\n    70→ */\n    71→export function writeStateAtomic(state: SprintState): Result<void> {\n    72→  try {\n    73→    const data = JSON.stringify(state, null, 2) + '\\n';\n    74→    const tmp = tmpPath();\n    75→    const final = statePath();\n    76→    writeFileSync(tmp, data, 'utf-8');\n    77→    renameSync(tmp, final);\n    78→    return ok(undefined);\n    79→  } catch (err: unknown) {\n    80→    const msg = err instanceof Error ? err.message : String(err);\n    81→    return fail(`Failed to write sprint state: ${msg}`);\n    82→  }\n    83→}\n    84→\n    85→/**\n    86→ * Read and parse sprint-state.json.\n    87→ * If the file does not exist, attempt migration from old files.\n    88→ * If no old files exist either, return defaultState().\n    89→ */\n    90→export function getSprintState(): Result<SprintState> {\n    91→  const fp = statePath();\n    92→\n    93→  if (existsSync(fp)) {\n    94→    try {\n    95→      const raw = readFileSync(fp, 'utf-8');\n    96→      const parsed = JSON.parse(raw) as Record<string, unknown>;\n    97→      // Merge with defaults to handle old state files missing new fields\n    98→      const defaults = defaultState();\n    99→      const run = parsed.run as Record<string, unknown> | undefined;\n   100→      const state: SprintState = {\n   101→        ...(parsed as unknown as SprintState),\n   102→        run: {\n   103→          ...defaults.run,\n   104→          ...(run as SprintState['run']),\n   105→        },\n   106→      };\n   107→      return ok(state);\n   108→    } catch (err: unknown) {\n   109→      const msg = err instanceof Error ? err.message : String(err);\n   110→      return fail(`Failed to read sprint state: ${msg}`);\n   111→    }\n   112→  }\n   113→\n   114→  // No sprint-state.json — try migration\n   115→  const migrationResult = migrateFromOldFormat();\n   116→  if (migrationResult.success) {\n   117→    return migrationResult;\n   118→  }\n   119→\n   120→  // Migration found nothing or failed — return default\n   121→  return ok(defaultState());\n   122→}\n   123→\n   124→/** Recompute sprint summary counts from story data */\n   125→export function computeSprintCounts(\n   126→  stories: Record<string, StoryState>,\n   127→): SprintState['sprint'] {\n   128→  let total = 0;\n   129→  let done = 0;\n   130→  let failed = 0;\n   131→  let blocked = 0;\n   132→  let inProgress: string | null = null;\n   133→\n   134→  for (const [key, story] of Object.entries(stories)) {\n   135→    total++;\n   136→    if (story.status === 'done') done++;\n   137→    else if (story.status === 'failed') failed++;\n   138→    else if (story.status === 'blocked') blocked++;\n   139→    else if (story.status === 'in-progress') inProgress = key;\n   140→  }\n   141→\n   142→  return { total, done, failed, blocked, inProgress };\n   143→}\n   144→\n   145→/**\n   146→ * Update a single story's status in sprint-state.json.\n   147→ * Reads current state, merges update, writes atomically.\n   148→ */\n   149→export function updateStoryStatus(\n   150→  key: string,\n   151→  status: StoryStatus,\n   152→  detail?: StoryDetail,\n   153→): Result<void> {\n   154→  const stateResult = getSprintState();\n   155→  if (!stateResult.success) {\n   156→    return fail(stateResult.error);\n   157→  }\n   158→\n   159→  const current = stateResult.data;\n   160→  const existingStory = current.stories[key] ?? defaultStoryState();\n   161→\n   162→  const isNewAttempt = status === 'in-progress';\n   163→\n   164→  const updatedStory: StoryState = {\n   165→    ...existingStory,\n   166→    status,\n   167→    attempts: isNewAttempt\n   168→      ? existingStory.attempts + 1\n   169→      : existingStory.attempts,\n   170→    lastAttempt: isNewAttempt\n   171→      ? new Date().toISOString()\n   172→      : existingStory.lastAttempt,\n   173→    lastError: detail?.error ?? existingStory.lastError,\n   174→    proofPath: detail?.proofPath ?? existingStory.proofPath,\n   175→    acResults: existingStory.acResults,\n   176→  };\n   177→\n   178→  const updatedStories = { ...current.stories, [key]: updatedStory };\n   179→  const updatedSprint = computeSprintCounts(updatedStories);\n   180→\n   181→  const updatedState: SprintState = {\n   182→    ...current,\n   183→    sprint: updatedSprint,\n   184→    stories: updatedStories,\n   185→  };\n   186→\n   187→  return writeStateAtomic(updatedState);\n   188→}\n   189→\n   190→/**\n   191→ * Update live run progress fields in sprint-state.json.\n   192→ * Only provided fields are updated; omitted fields retain their current values.\n   193→ */\n   194→export function updateRunProgress(update: RunProgressUpdate): Result<void> {\n   195→  const stateResult = getSprintState();\n   196→  if (!stateResult.success) {\n   197→    return fail(stateResult.error);\n   198→  }\n   199→\n   200→  const current = stateResult.data;\n   201→  const updatedRun = {\n   202→    ...current.run,\n   203→    ...(update.currentStory !== undefined && { currentStory: update.currentStory }),\n   204→    ...(update.currentPhase !== undefined && { currentPhase: update.currentPhase }),\n   205→    ...(update.lastAction !== undefined && { lastAction: update.lastAction }),\n   206→    ...(update.acProgress !== undefined && { acProgress: update.acProgress }),\n   207→  };\n   208→\n   209→  const updatedState: SprintState = {\n   210→    ...current,\n   211→    run: updatedRun,\n   212→  };\n   213→\n   214→  return writeStateAtomic(updatedState);\n   215→}\n   216→\n   217→/**\n   218→ * Clear all live run progress fields to null.\n   219→ * Called when a story completes or fails.\n   220→ */\n   221→export function clearRunProgress(): Result<void> {\n   222→  const stateResult = getSprintState();\n   223→  if (!stateResult.success) {\n   224→    return fail(stateResult.error);\n   225→  }\n   226→\n   227→  const current = stateResult.data;\n   228→  const updatedState: SprintState = {\n   229→    ...current,\n   230→    run: {\n   231→      ...current.run,\n   232→      currentStory: null,\n   233→      currentPhase: null,\n   234→      lastAction: null,\n   235→      acProgress: null,\n   236→    },\n   237→  };\n   238→\n   239→  return writeStateAtomic(updatedState);\n   240→}\n   241→"}]},"parent_tool_use_id":"toolu_01HFX9goKWGsXmLXf2BWi9oC","session_id":"0deb1693-f450-4ee3-ba9f-130c7ba0aec5","uuid":"dc345eec-8277-4d2d-b913-5819865b4de5","timestamp":"2026-03-20T09:15:43.539Z"}
