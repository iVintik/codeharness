{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Anj67XxvLXVhXzajWx85ig","type":"tool_result","content":"1\t/**\n2\t * Verification orchestrator.\n3\t * Checks preconditions, creates proof documents, runs showboat verify,\n4\t * and updates state.\n5\t *\n6\t * Architecture Decision 8: CLI orchestrates verification.\n7\t */\n8\t\n9\timport { execFileSync } from 'node:child_process';\n10\timport { existsSync, mkdirSync, writeFileSync } from 'node:fs';\n11\timport { join } from 'node:path';\n12\timport { warn } from '../../lib/output.js';\n13\timport { readState, readStateWithBody, writeState } from '../../lib/state.js';\n14\timport { checkStoryDocFreshness } from '../../lib/doc-health/index.js';\n15\timport type {\n16\t  ParsedAC,\n17\t  VerifyResult,\n18\t  PreconditionResult,\n19\t  ShowboatVerifyResult,\n20\t} from './types.js';\n21\t\n22\t// ─── Preconditions ──────────────────────────────────────────────────────────\n23\t\n24\t/**\n25\t * Checks that tests_passed and coverage_met flags are true in state,\n26\t * and that documentation is fresh for the story being verified.\n27\t */\n28\texport function checkPreconditions(dir?: string, storyId?: string): PreconditionResult {\n29\t  const state = readState(dir);\n30\t  const failures: string[] = [];\n31\t\n32\t  if (!state.session_flags.tests_passed) {\n33\t    failures.push('tests_passed is false — run tests first');\n34\t  }\n35\t  if (!state.session_flags.coverage_met) {\n36\t    failures.push('coverage_met is false — ensure coverage target is met');\n37\t  }\n38\t\n39\t  // Check doc freshness for the story being verified\n40\t  if (storyId) {\n41\t    try {\n42\t      const docReport = checkStoryDocFreshness(storyId, dir);\n43\t      if (!docReport.passed) {\n44\t        for (const doc of docReport.documents) {\n45\t          if (doc.grade === 'stale') {\n46\t            failures.push(doc.reason);\n47\t          } else if (doc.grade === 'missing') {\n48\t            failures.push(doc.reason);\n49\t          }\n50\t        }\n51\t      }\n52\t    } catch {\n53\t      // IGNORE: doc health check failed, don't block verification\n54\t      warn('Doc health check failed — skipping');\n55\t    }\n56\t  }\n57\t\n58\t  return {\n59\t    passed: failures.length === 0,\n60\t    failures,\n61\t  };\n62\t}\n63\t\n64\t// ─── Proof Document ─────────────────────────────────────────────────────────\n65\t\n66\t/**\n67\t * Creates the proof document skeleton at verification/<story-id>-proof.md.\n68\t * Creates verification/ and verification/screenshots/ directories if needed.\n69\t * Returns the proof file path.\n70\t */\n71\t// TODO: v2 blind evaluator (Epic 6) — proof document creation removed with showboat template.\n72\t// createProofDocument will be replaced by JSON verdict generation in Epic 6.\n73\texport function createProofDocument(\n74\t  storyId: string,\n75\t  _storyTitle: string,\n76\t  _acs: ParsedAC[],\n77\t  dir?: string,\n78\t): string {\n79\t  const root = dir ?? process.cwd();\n80\t  const verificationDir = join(root, 'verification');\n81\t  mkdirSync(verificationDir, { recursive: true });\n82\t\n83\t  const proofPath = join(verificationDir, `${storyId}-proof.md`);\n84\t  writeFileSync(proofPath, `# ${storyId} — Proof\\n\\nPending: blind evaluator (Epic 6)\\n`, 'utf-8');\n85\t\n86\t  return proofPath;\n87\t}\n88\t\n89\t// ─── Showboat Verify ────────────────────────────────────────────────────────\n90\t\n91\t/**\n92\t * Runs `showboat verify <proofPath>`.\n93\t * Returns pass/fail based on exit code. Handles showboat not installed.\n94\t */\n95\texport function runShowboatVerify(proofPath: string): ShowboatVerifyResult {\n96\t  try {\n97\t    const output = execFileSync('showboat', ['verify', proofPath], {\n98\t      stdio: 'pipe',\n99\t      timeout: 300_000,\n100\t    });\n101\t    return { passed: true, output: output.toString().trim() };\n102\t  } catch (err: unknown) {\n103\t    const message = err instanceof Error ? err.message : String(err);\n104\t    if (message.includes('ENOENT') || message.includes('not found')) {\n105\t      return { passed: false, output: 'showboat not available' };\n106\t    }\n107\t    const stderr = (err as { stderr?: Buffer })?.stderr?.toString().trim() ?? '';\n108\t    const stdout = (err as { stdout?: Buffer })?.stdout?.toString().trim() ?? '';\n109\t    return { passed: false, output: stdout || stderr || message };\n110\t  }\n111\t}\n112\t\n113\t// ─── State Update ───────────────────────────────────────────────────────────\n114\t\n115\t/**\n116\t * Updates state: sets verification_run = true, appends to verification_log.\n117\t */\n118\texport function updateVerificationState(\n119\t  storyId: string,\n120\t  result: VerifyResult,\n121\t  dir?: string,\n122\t): void {\n123\t  const { state, body } = readStateWithBody(dir);\n124\t  state.session_flags.verification_run = true;\n125\t\n126\t  const status = result.success ? 'pass' : 'fail';\n127\t  const timestamp = new Date().toISOString();\n128\t  state.verification_log.push(`${storyId}: ${status} at ${timestamp}`);\n129\t\n130\t  writeState(state, dir, body);\n131\t}\n132\t\n133\t// ─── Beads Close (removed — Epic 8 replacement pending) ────────────────────\n134\t\n135\t// TODO: v2 issue tracker (Epic 8) — closeBeadsIssue removed with beads cleanup\n136\t/**\n137\t * Stub: no-op since beads has been removed.\n138\t */\n139\texport function closeBeadsIssue(_storyId: string, _dir?: string): void {\n140\t  // No-op: beads integration removed. Will be replaced by issue tracker in Epic 8.\n141\t}\n142\t"}]},"parent_tool_use_id":"toolu_016tHrCUqdH9scyVU8wnefbD","session_id":"b6bb3bfc-8778-4f16-a616-88028acc2431","uuid":"6b6724d1-bce1-49d9-a1a1-017f822b61d9","timestamp":"2026-04-03T18:27:09.544Z"}
