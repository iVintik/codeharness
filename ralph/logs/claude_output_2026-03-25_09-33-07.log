{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JMmz9LWbVCNF3H2z8884Zz","type":"tool_result","content":"     1→/**\n     2→ * Python stack provider — encapsulates all Python-specific behavior.\n     3→ * Implements every StackProvider method for the python stack.\n     4→ *\n     5→ * Story 10-3: full implementation following NodejsProvider pattern from story 10-2.\n     6→ */\n     7→\n     8→import { execFileSync } from 'node:child_process';\n     9→import { existsSync, readFileSync } from 'node:fs';\n    10→import { join } from 'node:path';\n    11→\n    12→import { renderTemplateFile } from '../templates.js';\n    13→import type {\n    14→  AppType,\n    15→  CoverageToolInfo,\n    16→  CoverageToolName,\n    17→  OtlpResult,\n    18→  StackProvider,\n    19→  TestCounts,\n    20→} from './types.js';\n    21→import { readTextSafe, getPythonDepsContent, hasPythonDep } from './utils.js';\n    22→\n    23→/** Dependency names that signal an AI/agent project. */\n    24→const AGENT_DEPS = [\n    25→  'anthropic',\n    26→  'openai',\n    27→  'langchain',\n    28→  'llama-index',\n    29→  'traceloop-sdk',\n    30→];\n    31→\n    32→/** Dependency names that signal a web framework project. */\n    33→const WEB_FRAMEWORK_DEPS = ['flask', 'django', 'fastapi', 'streamlit'];\n    34→\n    35→/** OTLP packages required for Python instrumentation. */\n    36→const PYTHON_OTLP_PACKAGES = [\n    37→  'opentelemetry-distro',\n    38→  'opentelemetry-exporter-otlp',\n    39→];\n    40→\n    41→export class PythonProvider implements StackProvider {\n    42→  readonly name = 'python' as const;\n    43→  readonly markers = ['requirements.txt', 'pyproject.toml', 'setup.py'];\n    44→  readonly displayName = 'Python';\n    45→\n    46→  // ── Task 2: detectAppType ──────────────────────────────────────────────\n    47→\n    48→  detectAppType(dir: string): AppType {\n    49→    const content = getPythonDepsContent(dir);\n    50→\n    51→    // Priority 1: Agent detection\n    52→    if (AGENT_DEPS.some((d) => hasPythonDep(content, d))) {\n    53→      return 'agent';\n    54→    }\n    55→\n    56→    // Priority 2: Web detection (framework + templates/static dirs)\n    57→    const hasWebFramework = WEB_FRAMEWORK_DEPS.some((d) => hasPythonDep(content, d));\n    58→    if (hasWebFramework) {\n    59→      const hasTemplates = existsSync(join(dir, 'templates'));\n    60→      const hasStatic = existsSync(join(dir, 'static'));\n    61→      if (hasTemplates || hasStatic) {\n    62→        return 'web';\n    63→      }\n    64→      // Bare Flask/Django/FastAPI without templates => server\n    65→      return 'server';\n    66→    }\n    67→\n    68→    // Priority 3: Server detection (has main entry point)\n    69→    if (\n    70→      existsSync(join(dir, 'app.py')) ||\n    71→      existsSync(join(dir, 'main.py')) ||\n    72→      existsSync(join(dir, 'manage.py'))\n    73→    ) {\n    74→      return 'server';\n    75→    }\n    76→\n    77→    return 'generic';\n    78→  }\n    79→\n    80→  // ── Task 4: getCoverageTool ────────────────────────────────────────────\n    81→\n    82→  getCoverageTool(): CoverageToolName {\n    83→    return 'coverage-py';\n    84→  }\n    85→\n    86→  // ── Task 5: detectCoverageConfig ───────────────────────────────────────\n    87→\n    88→  detectCoverageConfig(dir: string): CoverageToolInfo {\n    89→    // Check requirements.txt\n    90→    const reqPath = join(dir, 'requirements.txt');\n    91→    const reqContent = readTextSafe(reqPath);\n    92→    if (reqContent) {\n    93→      if (hasPythonDep(reqContent, 'pytest-cov') || hasPythonDep(reqContent, 'coverage')) {\n    94→        return { tool: 'coverage-py', configFile: reqPath };\n    95→      }\n    96→    }\n    97→\n    98→    // Check pyproject.toml — use includes() here because coverage config sections\n    99→    // (e.g. [tool.coverage.run]) are not package deps and won't match hasPythonDep().\n   100→    const pyprojectPath = join(dir, 'pyproject.toml');\n   101→    const pyprojectContent = readTextSafe(pyprojectPath);\n   102→    if (pyprojectContent) {\n   103→      if (\n   104→        hasPythonDep(pyprojectContent, 'pytest-cov') ||\n   105→        hasPythonDep(pyprojectContent, 'coverage') ||\n   106→        pyprojectContent.includes('[tool.coverage')\n   107→      ) {\n   108→        return { tool: 'coverage-py', configFile: pyprojectPath };\n   109→      }\n   110→    }\n   111→\n   112→    return { tool: 'none' };\n   113→  }\n   114→\n   115→  // ── Task 6: getOtlpPackages ────────────────────────────────────────────\n   116→\n   117→  getOtlpPackages(): string[] {\n   118→    return [...PYTHON_OTLP_PACKAGES];\n   119→  }\n   120→\n   121→  // ── Task 7: installOtlp ───────────────────────────────────────────────\n   122→\n   123→  installOtlp(dir: string): OtlpResult {\n   124→    // Primary: pip install both packages in one command\n   125→    try {\n   126→      execFileSync('pip', ['install', ...PYTHON_OTLP_PACKAGES], {\n   127→        cwd: dir,\n   128→        stdio: 'pipe',\n   129→        timeout: 300_000,\n   130→      });\n   131→      return {\n   132→        success: true,\n   133→        packagesInstalled: [...PYTHON_OTLP_PACKAGES],\n   134→      };\n   135→    } catch {\n   136→      // IGNORE: pip install failed, fallback to pipx\n   137→    }\n   138→\n   139→    const installed: string[] = [];\n   140→    try {\n   141→      for (const pkg of PYTHON_OTLP_PACKAGES) {\n   142→        execFileSync('pipx', ['install', pkg], {\n   143→          cwd: dir,\n   144→          stdio: 'pipe',\n   145→          timeout: 300_000,\n   146→        });\n   147→        installed.push(pkg);\n   148→      }\n   149→      return {\n   150→        success: true,\n   151→        packagesInstalled: installed,\n   152→      };\n   153→    } catch (err) {\n   154→      const message = err instanceof Error ? err.message : 'Unknown error';\n   155→      return {\n   156→        success: false,\n   157→        packagesInstalled: installed,\n   158→        error: `Failed to install Python OTLP packages: ${message.length > 200 ? message.slice(0, 200) + '... (truncated)' : message}`,\n   159→      };\n   160→    }\n   161→  }\n   162→\n   163→  // ── Task 8: getDockerfileTemplate ─────────────────────────────────────\n   164→\n   165→  getDockerfileTemplate(): string {\n   166→    return renderTemplateFile('templates/dockerfiles/Dockerfile.python');\n   167→  }\n   168→\n   169→  // ── Task 9: getDockerBuildStage ───────────────────────────────────────\n   170→\n   171→  getDockerBuildStage(): string {\n   172→    return `# === Build stage: python ===\n   173→FROM python:3.12-slim AS build-python\n   174→WORKDIR /build\n   175→COPY . .\n   176→RUN pip install --target=/build/dist .\n   177→`;\n   178→  }\n   179→\n   180→  // ── Task 10: getRuntimeCopyDirectives ──────────────────────────────────\n   181→\n   182→  getRuntimeCopyDirectives(): string {\n   183→    return 'COPY --from=build-python /build/dist /opt/app/python/';\n   184→  }\n   185→\n   186→  // ── Task 11: getBuildCommands ──────────────────────────────────────────\n   187→\n   188→  getBuildCommands(): string[] {\n   189→    return ['pip install -r requirements.txt'];\n   190→  }\n   191→\n   192→  // ── Task 12: getTestCommands ──────────────────────────────────────────\n   193→\n   194→  getTestCommands(): string[] {\n   195→    return ['python -m pytest'];\n   196→  }\n   197→\n   198→  // ── Task 13: getSemgrepLanguages ──────────────────────────────────────\n   199→\n   200→  getSemgrepLanguages(): string[] {\n   201→    return ['python'];\n   202→  }\n   203→\n   204→  // ── Task 14: parseTestOutput ──────────────────────────────────────────\n   205→\n   206→  parseTestOutput(output: string): TestCounts {\n   207→    // Pytest format: \"12 passed, 3 failed\" or \"5 passed\" or \"12 passed, 3 failed, 1 skipped\"\n   208→    const passedMatch = /(\\d+)\\s+passed/i.exec(output);\n   209→    if (passedMatch) {\n   210→      const passed = parseInt(passedMatch[1], 10);\n   211→      const failedMatch = /(\\d+)\\s+failed/i.exec(output);\n   212→      const skippedMatch = /(\\d+)\\s+skipped/i.exec(output);\n   213→      const failed = failedMatch ? parseInt(failedMatch[1], 10) : 0;\n   214→      const skipped = skippedMatch ? parseInt(skippedMatch[1], 10) : 0;\n   215→      return { passed, failed, skipped, total: passed + failed + skipped };\n   216→    }\n   217→\n   218→    return { passed: 0, failed: 0, skipped: 0, total: 0 };\n   219→  }\n   220→\n   221→  // ── Task 15: parseCoverageReport ──────────────────────────────────────\n   222→\n   223→  parseCoverageReport(dir: string): number {\n   224→    const reportPath = join(dir, 'coverage.json');\n   225→    if (!existsSync(reportPath)) return 0;\n   226→\n   227→    try {\n   228→      const report = JSON.parse(readFileSync(reportPath, 'utf-8')) as {\n   229→        totals?: { percent_covered?: number };\n   230→      };\n   231→      return report.totals?.percent_covered ?? 0;\n   232→    } catch {\n   233→      // IGNORE: Python coverage report may be malformed\n   234→      return 0;\n   235→    }\n   236→  }\n   237→\n   238→  // ── Task 16: getProjectName ───────────────────────────────────────────\n   239→\n   240→  // ── getVerifyDockerfileSection ──────────────────────────────────────\n   241→\n   242→  getVerifyDockerfileSection(_projectDir: string): string {\n   243→    return [\n   244→      '# --- Python tooling ---',\n   245→      'RUN apt-get update && apt-get install -y --no-install-recommends \\\\',\n   246→      '    python3-pip python3-venv \\\\',\n   247→      '    && rm -rf /var/lib/apt/lists/*',\n   248→      'RUN pip install --break-system-packages coverage pytest',\n   249→    ].join('\\n');\n   250→  }\n   251→\n   252→  getProjectName(dir: string): string | null {\n   253→    // Try pyproject.toml first\n   254→    const pyprojectContent = readTextSafe(join(dir, 'pyproject.toml'));\n   255→    if (pyprojectContent) {\n   256→      // Extract the [project] section (up to the next section header or EOF)\n   257→      const projectIdx = pyprojectContent.search(/^\\[project\\]\\s*$/m);\n   258→      if (projectIdx !== -1) {\n   259→        const afterHeader = pyprojectContent.slice(\n   260→          projectIdx + pyprojectContent.slice(projectIdx).indexOf('\\n') + 1,\n   261→        );\n   262→        // Find where next section starts (line beginning with '[')\n   263→        const nextSectionIdx = afterHeader.search(/^\\[/m);\n   264→        const section = nextSectionIdx === -1 ? afterHeader : afterHeader.slice(0, nextSectionIdx);\n   265→        // Match name = \"...\" or name = '...' within the [project] section only\n   266→        const nameMatch = /^\\s*name\\s*=\\s*[\"']([^\"']+)[\"']/m.exec(section);\n   267→        if (nameMatch) return nameMatch[1];\n   268→      }\n   269→    }\n   270→\n   271→    // Try setup.py\n   272→    const setupContent = readTextSafe(join(dir, 'setup.py'));\n   273→    if (setupContent) {\n   274→      const match = /name\\s*=\\s*['\"]([^'\"]+)['\"]/m.exec(setupContent);\n   275→      if (match) return match[1];\n   276→    }\n   277→\n   278→    return null;\n   279→  }\n   280→}\n   281→"}]},"parent_tool_use_id":"toolu_01XDjxyLwkaMXpxX2UKGshtf","session_id":"f5f7e8e8-6408-46c1-8863-2380ea5a7335","uuid":"5cdd3f8e-5841-4e72-ad4f-1dbbe1df877e","timestamp":"2026-03-25T05:36:44.259Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PqafQ3HNYxboh5K5Mydj4D","type":"tool_result","content":"     1→/**\n     2→ * Rust stack provider — encapsulates all Rust-specific behavior.\n     3→ * Implements every StackProvider method for the rust stack.\n     4→ *\n     5→ * Story 10-4: full implementation following NodejsProvider/PythonProvider patterns.\n     6→ */\n     7→\n     8→import { execFileSync } from 'node:child_process';\n     9→import { existsSync, readFileSync } from 'node:fs';\n    10→import { join } from 'node:path';\n    11→\n    12→import { renderTemplateFile } from '../templates.js';\n    13→import type {\n    14→  AppType,\n    15→  CoverageToolInfo,\n    16→  CoverageToolName,\n    17→  OtlpResult,\n    18→  StackProvider,\n    19→  TestCounts,\n    20→} from './types.js';\n    21→import { readTextSafe, getCargoDepsSection, hasCargoDep } from './utils.js';\n    22→\n    23→/** Dependency names that signal an AI/agent project. */\n    24→const RUST_AGENT_DEPS = ['async-openai', 'anthropic', 'llm-chain'];\n    25→\n    26→/** Dependency names that signal a web framework project. */\n    27→const RUST_WEB_FRAMEWORKS = ['actix-web', 'axum', 'rocket', 'tide', 'warp'];\n    28→\n    29→/** OTLP packages required for Rust instrumentation. */\n    30→const RUST_OTLP_PACKAGES = [\n    31→  'opentelemetry',\n    32→  'opentelemetry-otlp',\n    33→  'tracing-opentelemetry',\n    34→  'tracing-subscriber',\n    35→];\n    36→\n    37→export class RustProvider implements StackProvider {\n    38→  readonly name = 'rust' as const;\n    39→  readonly markers = ['Cargo.toml'];\n    40→  readonly displayName = 'Rust (Cargo.toml)';\n    41→\n    42→  // ── Task 3: detectAppType ──────────────────────────────────────────────\n    43→\n    44→  detectAppType(dir: string): AppType {\n    45→    const cargoContent = readTextSafe(join(dir, 'Cargo.toml'));\n    46→    if (!cargoContent) return 'generic';\n    47→\n    48→    const depsSection = getCargoDepsSection(cargoContent);\n    49→\n    50→    // Priority 1: Agent detection (only in [dependencies], not [dev-dependencies])\n    51→    if (RUST_AGENT_DEPS.some((d) => hasCargoDep(depsSection, d))) {\n    52→      return 'agent';\n    53→    }\n    54→\n    55→    // Priority 2: Server detection (web framework in [dependencies])\n    56→    if (RUST_WEB_FRAMEWORKS.some((d) => hasCargoDep(depsSection, d))) {\n    57→      return 'server';\n    58→    }\n    59→\n    60→    // Priority 3: CLI detection ([[bin]] section present)\n    61→    if (/^\\[\\[bin\\]\\]\\s*$/m.test(cargoContent)) {\n    62→      return 'cli';\n    63→    }\n    64→\n    65→    // Priority 4: Library detection ([lib] section present, no [[bin]])\n    66→    if (/^\\[lib\\]\\s*$/m.test(cargoContent)) {\n    67→      return 'generic';\n    68→    }\n    69→\n    70→    return 'generic';\n    71→  }\n    72→\n    73→  // ── Task 4: getCoverageTool ────────────────────────────────────────────\n    74→\n    75→  getCoverageTool(): CoverageToolName {\n    76→    return 'tarpaulin';\n    77→  }\n    78→\n    79→  // ── Task 5: detectCoverageConfig ───────────────────────────────────────\n    80→\n    81→  detectCoverageConfig(dir: string): CoverageToolInfo {\n    82→    const cargoPath = join(dir, 'Cargo.toml');\n    83→    if (!existsSync(cargoPath)) {\n    84→      return { tool: 'none' };\n    85→    }\n    86→\n    87→    return { tool: 'tarpaulin', configFile: cargoPath };\n    88→  }\n    89→\n    90→  // ── Task 6: getOtlpPackages ────────────────────────────────────────────\n    91→\n    92→  getOtlpPackages(): string[] {\n    93→    return [...RUST_OTLP_PACKAGES];\n    94→  }\n    95→\n    96→  // ── Task 7: installOtlp ───────────────────────────────────────────────\n    97→\n    98→  installOtlp(dir: string): OtlpResult {\n    99→    try {\n   100→      execFileSync('cargo', ['add', ...RUST_OTLP_PACKAGES], {\n   101→        cwd: dir,\n   102→        stdio: 'pipe',\n   103→        timeout: 300_000,\n   104→      });\n   105→      return {\n   106→        success: true,\n   107→        packagesInstalled: [...RUST_OTLP_PACKAGES],\n   108→      };\n   109→    } catch (err) {\n   110→      const message = err instanceof Error ? err.message : 'Unknown error';\n   111→      return {\n   112→        success: false,\n   113→        packagesInstalled: [],\n   114→        error: `Failed to install Rust OTLP packages: ${message.length > 200 ? message.slice(0, 200) + '... (truncated)' : message}`,\n   115→      };\n   116→    }\n   117→  }\n   118→\n   119→  // ── Task 8: getDockerfileTemplate ─────────────────────────────────────\n   120→\n   121→  getDockerfileTemplate(): string {\n   122→    return renderTemplateFile('templates/dockerfiles/Dockerfile.rust');\n   123→  }\n   124→\n   125→  // ── Task 9: getDockerBuildStage ───────────────────────────────────────\n   126→\n   127→  getDockerBuildStage(): string {\n   128→    return `# === Build stage: rust ===\n   129→FROM rust:1.82-slim AS build-rust\n   130→WORKDIR /build\n   131→COPY . .\n   132→RUN cargo build --release\n   133→`;\n   134→  }\n   135→\n   136→  // ── Task 10: getRuntimeCopyDirectives ──────────────────────────────────\n   137→\n   138→  getRuntimeCopyDirectives(): string {\n   139→    return 'COPY --from=build-rust /build/target/release/myapp /usr/local/bin/myapp';\n   140→  }\n   141→\n   142→  // ── Task 11: getBuildCommands ──────────────────────────────────────────\n   143→\n   144→  getBuildCommands(): string[] {\n   145→    return ['cargo build', 'cargo test'];\n   146→  }\n   147→\n   148→  // ── Task 12: getTestCommands ──────────────────────────────────────────\n   149→\n   150→  getTestCommands(): string[] {\n   151→    return ['cargo test'];\n   152→  }\n   153→\n   154→  // ── Task 13: getSemgrepLanguages ──────────────────────────────────────\n   155→\n   156→  getSemgrepLanguages(): string[] {\n   157→    return ['rust'];\n   158→  }\n   159→\n   160→  // ── Task 14: parseTestOutput ──────────────────────────────────────────\n   161→\n   162→  parseTestOutput(output: string): TestCounts {\n   163→    // Cargo test format: \"test result: ok. N passed; M failed; K ignored\"\n   164→    // Workspace projects emit multiple \"test result:\" lines — aggregate all.\n   165→    const pattern = /test result:.*?(\\d+)\\s+passed;\\s*(\\d+)\\s+failed(?:;\\s*(\\d+)\\s+ignored)?/g;\n   166→    let passed = 0;\n   167→    let failed = 0;\n   168→    let skipped = 0;\n   169→    let match: RegExpExecArray | null;\n   170→\n   171→    while ((match = pattern.exec(output)) !== null) {\n   172→      passed += parseInt(match[1], 10);\n   173→      failed += parseInt(match[2], 10);\n   174→      skipped += match[3] ? parseInt(match[3], 10) : 0;\n   175→    }\n   176→\n   177→    const total = passed + failed + skipped;\n   178→    return { passed, failed, skipped, total };\n   179→  }\n   180→\n   181→  // ── Task 15: parseCoverageReport ──────────────────────────────────────\n   182→\n   183→  parseCoverageReport(dir: string): number {\n   184→    const reportPath = join(dir, 'coverage', 'tarpaulin-report.json');\n   185→    if (!existsSync(reportPath)) return 0;\n   186→\n   187→    try {\n   188→      const report = JSON.parse(readFileSync(reportPath, 'utf-8')) as { coverage?: number };\n   189→      return report.coverage ?? 0;\n   190→    } catch {\n   191→      // IGNORE: tarpaulin report may be malformed\n   192→      return 0;\n   193→    }\n   194→  }\n   195→\n   196→  // ── Task 16: getProjectName ───────────────────────────────────────────\n   197→\n   198→  // ── getVerifyDockerfileSection ──────────────────────────────────────\n   199→\n   200→  getVerifyDockerfileSection(projectDir: string): string {\n   201→    const lines: string[] = [\n   202→      '# --- Rust tooling ---',\n   203→      'RUN curl --proto \"=https\" --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable',\n   204→      'ENV PATH=\"/root/.cargo/bin:$PATH\"',\n   205→      'RUN rustup component add clippy',\n   206→      'RUN cargo install cargo-tarpaulin',\n   207→    ];\n   208→\n   209→    // Detect Bevy dependency for system libs\n   210→    const cargoContent = readTextSafe(join(projectDir, 'Cargo.toml'));\n   211→    if (cargoContent) {\n   212→      const depsSection = getCargoDepsSection(cargoContent);\n   213→      if (hasCargoDep(depsSection, 'bevy')) {\n   214→        lines.push(\n   215→          'RUN apt-get update && apt-get install -y --no-install-recommends \\\\',\n   216→          '    libudev-dev libasound2-dev libwayland-dev libxkbcommon-dev \\\\',\n   217→          '    libfontconfig1-dev libx11-dev \\\\',\n   218→          '    && rm -rf /var/lib/apt/lists/*',\n   219→        );\n   220→      }\n   221→    }\n   222→\n   223→    return lines.join('\\n');\n   224→  }\n   225→\n   226→  getProjectName(dir: string): string | null {\n   227→    const cargoContent = readTextSafe(join(dir, 'Cargo.toml'));\n   228→    if (!cargoContent) return null;\n   229→\n   230→    // Extract the [package] section (up to the next section header or EOF)\n   231→    const packageIdx = cargoContent.search(/^\\[package\\]\\s*$/m);\n   232→    if (packageIdx === -1) return null;\n   233→\n   234→    const afterHeader = cargoContent.slice(\n   235→      packageIdx + cargoContent.slice(packageIdx).indexOf('\\n') + 1,\n   236→    );\n   237→    // Find where next section starts (line beginning with '[')\n   238→    const nextSectionIdx = afterHeader.search(/^\\[/m);\n   239→    const section = nextSectionIdx === -1 ? afterHeader : afterHeader.slice(0, nextSectionIdx);\n   240→\n   241→    // Match name = \"...\" or name = '...' within the [package] section only\n   242→    const nameMatch = /^\\s*name\\s*=\\s*[\"']([^\"']+)[\"']/m.exec(section);\n   243→    return nameMatch ? nameMatch[1] : null;\n   244→  }\n   245→}\n   246→"}]},"parent_tool_use_id":"toolu_01XDjxyLwkaMXpxX2UKGshtf","session_id":"f5f7e8e8-6408-46c1-8863-2380ea5a7335","uuid":"29a6b10b-6f63-46fb-a104-52c7104bba60","timestamp":"2026-03-25T05:36:44.261Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QprY8sBEAN9bqnhZu8gz17","type":"tool_result","content":"     1→/**\n     2→ * Node.js stack provider — encapsulates all Node.js-specific behavior.\n     3→ * Implements every StackProvider method for the nodejs stack.\n     4→ *\n     5→ * Story 10-2: full implementation replacing stubs from story 10-1.\n     6→ */\n     7→\n     8→import { execFileSync } from 'node:child_process';\n     9→import { existsSync, readFileSync, writeFileSync } from 'node:fs';\n    10→import { join } from 'node:path';\n    11→\n    12→import { renderTemplateFile } from '../templates.js';\n    13→import type {\n    14→  AppType,\n    15→  CoverageToolInfo,\n    16→  CoverageToolName,\n    17→  OtlpResult,\n    18→  StackProvider,\n    19→  TestCounts,\n    20→} from './types.js';\n    21→import { readJsonSafe, getNodeDeps } from './utils.js';\n    22→\n    23→/** Dependency names that signal an AI/agent project. */\n    24→const AGENT_DEPS = [\n    25→  'anthropic',\n    26→  '@anthropic-ai/sdk',\n    27→  'openai',\n    28→  'langchain',\n    29→  '@langchain/core',\n    30→  'llamaindex',\n    31→];\n    32→\n    33→/** Dependency names that signal a web frontend project. */\n    34→const WEB_FRAMEWORK_DEPS = [\n    35→  'react',\n    36→  'vue',\n    37→  'svelte',\n    38→  'angular',\n    39→  '@angular/core',\n    40→  'next',\n    41→  'nuxt',\n    42→  'vite',\n    43→  'webpack',\n    44→];\n    45→\n    46→/** OTLP packages required for Node.js instrumentation. */\n    47→const NODE_OTLP_PACKAGES = [\n    48→  '@opentelemetry/auto-instrumentations-node',\n    49→  '@opentelemetry/sdk-node',\n    50→  '@opentelemetry/exporter-trace-otlp-http',\n    51→  '@opentelemetry/exporter-metrics-otlp-http',\n    52→];\n    53→\n    54→const NODE_REQUIRE_FLAG = '--require @opentelemetry/auto-instrumentations-node/register';\n    55→\n    56→export class NodejsProvider implements StackProvider {\n    57→  readonly name = 'nodejs' as const;\n    58→  readonly markers = ['package.json'];\n    59→  readonly displayName = 'Node.js (package.json)';\n    60→\n    61→  // ── Task 1: detectAppType ──────────────────────────────────────────────\n    62→\n    63→  detectAppType(dir: string): AppType {\n    64→    const pkg = readJsonSafe(join(dir, 'package.json'));\n    65→    if (!pkg) return 'generic';\n    66→\n    67→    const deps = getNodeDeps(pkg);\n    68→\n    69→    // Priority 1: Agent detection\n    70→    if (AGENT_DEPS.some((d) => deps.has(d))) {\n    71→      return 'agent';\n    72→    }\n    73→\n    74→    // Priority 2: Web detection\n    75→    if (WEB_FRAMEWORK_DEPS.some((d) => deps.has(d))) {\n    76→      return 'web';\n    77→    }\n    78→    if (\n    79→      existsSync(join(dir, 'index.html')) ||\n    80→      existsSync(join(dir, 'public', 'index.html')) ||\n    81→      existsSync(join(dir, 'src', 'index.html'))\n    82→    ) {\n    83→      return 'web';\n    84→    }\n    85→\n    86→    // Priority 3: CLI detection\n    87→    const bin = pkg['bin'];\n    88→    const scripts = pkg['scripts'] as Record<string, string> | undefined;\n    89→    const hasStart = scripts?.['start'] !== undefined;\n    90→    if (bin && !hasStart) {\n    91→      return 'cli';\n    92→    }\n    93→\n    94→    // Priority 4: Server detection\n    95→    if (hasStart) {\n    96→      return 'server';\n    97→    }\n    98→\n    99→    return 'generic';\n   100→  }\n   101→\n   102→  // ── Task 2: getCoverageTool ────────────────────────────────────────────\n   103→\n   104→  getCoverageTool(): CoverageToolName {\n   105→    return 'c8';\n   106→  }\n   107→\n   108→  // ── Task 3: detectCoverageConfig ───────────────────────────────────────\n   109→\n   110→  detectCoverageConfig(dir: string): CoverageToolInfo {\n   111→    // Check for Vitest config files\n   112→    const vitestConfigTs = join(dir, 'vitest.config.ts');\n   113→    const vitestConfigJs = join(dir, 'vitest.config.js');\n   114→    const hasVitestConfig = existsSync(vitestConfigTs) || existsSync(vitestConfigJs);\n   115→\n   116→    // Check package.json devDependencies\n   117→    const pkg = readJsonSafe(join(dir, 'package.json'));\n   118→    let hasVitestCoverageV8 = false;\n   119→    let hasVitestCoverageIstanbul = false;\n   120→    let hasC8 = false;\n   121→    let hasJest = false;\n   122→\n   123→    if (pkg) {\n   124→      const allDeps = getNodeDeps(pkg);\n   125→      hasVitestCoverageV8 = allDeps.has('@vitest/coverage-v8');\n   126→      hasVitestCoverageIstanbul = allDeps.has('@vitest/coverage-istanbul');\n   127→      hasC8 = allDeps.has('c8');\n   128→      hasJest = allDeps.has('jest');\n   129→    }\n   130→\n   131→    // Vitest detection\n   132→    if (hasVitestConfig || hasVitestCoverageV8 || hasVitestCoverageIstanbul) {\n   133→      const configFile = existsSync(vitestConfigTs)\n   134→        ? vitestConfigTs\n   135→        : existsSync(vitestConfigJs)\n   136→          ? vitestConfigJs\n   137→          : undefined;\n   138→      return { tool: 'c8', configFile };\n   139→    }\n   140→\n   141→    // Standalone c8\n   142→    if (hasC8) {\n   143→      return { tool: 'c8' };\n   144→    }\n   145→\n   146→    // Jest (uses c8/istanbul underneath)\n   147→    if (hasJest) {\n   148→      return { tool: 'c8' };\n   149→    }\n   150→\n   151→    return { tool: 'none' };\n   152→  }\n   153→\n   154→  // ── Task 4: getOtlpPackages ────────────────────────────────────────────\n   155→\n   156→  getOtlpPackages(): string[] {\n   157→    return [...NODE_OTLP_PACKAGES];\n   158→  }\n   159→\n   160→  // ── Task 5: installOtlp ───────────────────────────────────────────────\n   161→\n   162→  installOtlp(dir: string): OtlpResult {\n   163→    try {\n   164→      execFileSync('npm', ['install', ...NODE_OTLP_PACKAGES], {\n   165→        cwd: dir,\n   166→        stdio: 'pipe',\n   167→        timeout: 300_000,\n   168→      });\n   169→      return {\n   170→        success: true,\n   171→        packagesInstalled: [...NODE_OTLP_PACKAGES],\n   172→      };\n   173→    } catch (err) {\n   174→      const message = err instanceof Error ? err.message : 'Unknown error';\n   175→      return {\n   176→        success: false,\n   177→        packagesInstalled: [],\n   178→        error: `Failed to install Node.js OTLP packages: ${message.length > 200 ? message.slice(0, 200) + '... (truncated)' : message}`,\n   179→      };\n   180→    }\n   181→  }\n   182→\n   183→  // ── Task 6: patchStartScript ──────────────────────────────────────────\n   184→\n   185→  patchStartScript(dir: string): boolean {\n   186→    const pkgPath = join(dir, 'package.json');\n   187→    if (!existsSync(pkgPath)) return false;\n   188→\n   189→    let raw: string;\n   190→    let pkg: Record<string, unknown>;\n   191→    try {\n   192→      raw = readFileSync(pkgPath, 'utf-8');\n   193→      pkg = JSON.parse(raw) as Record<string, unknown>;\n   194→    } catch {\n   195→      // IGNORE: package.json may not exist or be malformed\n   196→      return false;\n   197→    }\n   198→\n   199→    const scripts = pkg['scripts'] as Record<string, string> | undefined;\n   200→    if (!scripts) return false;\n   201→\n   202→    const targetKey = scripts['start'] ? 'start' : scripts['dev'] ? 'dev' : null;\n   203→    if (!targetKey) return false;\n   204→\n   205→    const instrumentedKey = `${targetKey}:instrumented`;\n   206→\n   207→    // Already patched\n   208→    if (scripts[instrumentedKey]?.includes(NODE_REQUIRE_FLAG)) {\n   209→      return false;\n   210→    }\n   211→\n   212→    scripts[instrumentedKey] = `NODE_OPTIONS='${NODE_REQUIRE_FLAG}' ${scripts[targetKey]}`;\n   213→\n   214→    writeFileSync(pkgPath, JSON.stringify(pkg, null, 2) + '\\n', 'utf-8');\n   215→    return true;\n   216→  }\n   217→\n   218→  // ── Task 7: getDockerfileTemplate ─────────────────────────────────────\n   219→\n   220→  getDockerfileTemplate(): string {\n   221→    return renderTemplateFile('templates/dockerfiles/Dockerfile.nodejs');\n   222→  }\n   223→\n   224→  // ── Task 8: getDockerBuildStage ───────────────────────────────────────\n   225→\n   226→  getDockerBuildStage(): string {\n   227→    return `# === Build stage: nodejs ===\n   228→FROM node:22-slim AS build-nodejs\n   229→WORKDIR /build\n   230→COPY package*.json ./\n   231→RUN npm ci --production\n   232→COPY . .\n   233→`;\n   234→  }\n   235→\n   236→  // ── Task 9: getRuntimeCopyDirectives ──────────────────────────────────\n   237→\n   238→  getRuntimeCopyDirectives(): string {\n   239→    return [\n   240→      'COPY --from=build-nodejs /build/node_modules ./node_modules',\n   241→      'COPY --from=build-nodejs /build/ ./app/',\n   242→    ].join('\\n');\n   243→  }\n   244→\n   245→  // ── Task 10: getBuildCommands ──────────────────────────────────────────\n   246→\n   247→  getBuildCommands(): string[] {\n   248→    return ['npm install', 'npm run build'];\n   249→  }\n   250→\n   251→  // ── Task 11: getTestCommands ──────────────────────────────────────────\n   252→\n   253→  getTestCommands(): string[] {\n   254→    return ['npm test'];\n   255→  }\n   256→\n   257→  // ── Task 12: getSemgrepLanguages ──────────────────────────────────────\n   258→\n   259→  getSemgrepLanguages(): string[] {\n   260→    return ['javascript', 'typescript'];\n   261→  }\n   262→\n   263→  // ── Task 13: parseTestOutput ──────────────────────────────────────────\n   264→\n   265→  parseTestOutput(output: string): TestCounts {\n   266→    // Vitest format: \"Tests  12 passed | 3 failed | 1 skipped\"\n   267→    // Each segment (passed/failed/skipped) is optional except passed which triggers the match.\n   268→    const vitestMatch = /Tests\\s+(\\d+)\\s+passed(?:\\s*\\|\\s*(\\d+)\\s+failed)?(?:\\s*\\|\\s*(\\d+)\\s+skipped)?/i.exec(output);\n   269→    if (vitestMatch) {\n   270→      const passed = parseInt(vitestMatch[1], 10);\n   271→      const failed = vitestMatch[2] ? parseInt(vitestMatch[2], 10) : 0;\n   272→      const skipped = vitestMatch[3] ? parseInt(vitestMatch[3], 10) : 0;\n   273→      return { passed, failed, skipped, total: passed + failed + skipped };\n   274→    }\n   275→\n   276→    // Jest format: \"Tests:  3 failed, 12 passed, 2 skipped, 17 total\"\n   277→    // Extract each field independently since ordering can vary.\n   278→    const jestPassedMatch = /Tests:.*?(\\d+)\\s+passed/i.exec(output);\n   279→    if (jestPassedMatch) {\n   280→      const passed = parseInt(jestPassedMatch[1], 10);\n   281→      const failedMatch = /Tests:.*?(\\d+)\\s+failed/i.exec(output);\n   282→      const skippedMatch = /Tests:.*?(\\d+)\\s+skipped/i.exec(output);\n   283→      const totalMatch = /Tests:.*?(\\d+)\\s+total/i.exec(output);\n   284→      const failed = failedMatch ? parseInt(failedMatch[1], 10) : 0;\n   285→      const skipped = skippedMatch ? parseInt(skippedMatch[1], 10) : 0;\n   286→      const total = totalMatch ? parseInt(totalMatch[1], 10) : passed + failed + skipped;\n   287→      return { passed, failed, skipped, total };\n   288→    }\n   289→\n   290→    return { passed: 0, failed: 0, skipped: 0, total: 0 };\n   291→  }\n   292→\n   293→  // ── Task 14: parseCoverageReport ──────────────────────────────────────\n   294→\n   295→  parseCoverageReport(dir: string): number {\n   296→    const candidates = [\n   297→      join(dir, 'coverage', 'coverage-summary.json'),\n   298→      join(dir, 'src', 'coverage', 'coverage-summary.json'),\n   299→    ];\n   300→\n   301→    let reportPath: string | null = null;\n   302→    for (const p of candidates) {\n   303→      if (existsSync(p)) {\n   304→        reportPath = p;\n   305→        break;\n   306→      }\n   307→    }\n   308→\n   309→    if (!reportPath) return 0;\n   310→\n   311→    try {\n   312→      const report = JSON.parse(readFileSync(reportPath, 'utf-8')) as {\n   313→        total?: {\n   314→          statements?: { pct?: number };\n   315→        };\n   316→      };\n   317→      return report.total?.statements?.pct ?? 0;\n   318→    } catch {\n   319→      // IGNORE: coverage report may be malformed\n   320→      return 0;\n   321→    }\n   322→  }\n   323→\n   324→  // ── Task 15: getProjectName ───────────────────────────────────────────\n   325→\n   326→  // ── getVerifyDockerfileSection ──────────────────────────────────────\n   327→\n   328→  getVerifyDockerfileSection(_projectDir: string): string {\n   329→    return [\n   330→      '# --- Node.js tooling ---',\n   331→      'RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \\\\',\n   332→      '    && apt-get install -y --no-install-recommends nodejs \\\\',\n   333→      '    && rm -rf /var/lib/apt/lists/*',\n   334→      'RUN npm install -g showboat @anthropic-ai/claude-code',\n   335→    ].join('\\n');\n   336→  }\n   337→\n   338→  getProjectName(dir: string): string | null {\n   339→    const pkg = readJsonSafe(join(dir, 'package.json'));\n   340→    if (pkg && typeof pkg.name === 'string') {\n   341→      return pkg.name;\n   342→    }\n   343→    return null;\n   344→  }\n   345→}\n   346→"}]},"parent_tool_use_id":"toolu_01XDjxyLwkaMXpxX2UKGshtf","session_id":"f5f7e8e8-6408-46c1-8863-2380ea5a7335","uuid":"efb03478-9f09-48b0-8a25-fcf9158b0a33","timestamp":"2026-03-25T05:36:44.349Z"}
