rifyEnv,\n    49→  cleanupVerifyEnv,\n    50→  cleanupStaleContainers,\n    51→} from '../env.js';\n    52→\n    53→const mockExecFileSync = vi.mocked(execFileSync);\n    54→const mockIsDockerAvailable = vi.mocked(isDockerAvailable);\n    55→const mockDetectStack = vi.mocked(detectStack);\n    56→const mockReadStateWithBody = vi.mocked(readStateWithBody);\n    57→const mockWriteState = vi.mocked(writeState);\n    58→\n    59→let testDir: string;\n    60→\n    61→beforeEach(() => {\n    62→  vi.clearAllMocks();\n    63→  testDir = mkdtempSync(join(tmpdir(), 'ch-verify-env-test-'));\n    64→  // Create templates/Dockerfile.verify so buildVerifyImage can find it\n    65→  mkdirSync(join(testDir, 'templates'), { recursive: true });\n    66→  writeFileSync(join(testDir, 'templates', 'Dockerfile.verify'), 'FROM node:20-slim\\nARG TARBALL=package.tgz\\nCOPY ${TARBALL} /tmp/\\n');\n    67→  writeFileSync(join(testDir, 'templates', 'Dockerfile.verify.generic'), 'FROM node:20-slim\\nRUN apt-get update\\n');\n    68→  // Reset default mock behaviors after clearAllMocks\n    69→  mockIsDockerAvailable.mockReturnValue(true);\n    70→  mockDetectStack.mockReturnValue('nodejs');\n    71→});\n    72→\n    73→afterEach(() => {\n    74→  rmSync(testDir, { recursive: true, force: true });\n    75→});"}]},"parent_tool_use_id":"toolu_01CVfsuk3fYkb5FT4qRVJXrF","session_id":"58ae4f51-bff6-4a66-807a-d4f10c8bdaa3","uuid":"b53f6ba5-fe8a-4a7a-8715-8404e61d4137","timestamp":"2026-03-23T15:44:46.044Z"}
