{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HBfg7pFMW7t3CSUcs3x3pY","type":"tool_result","content":"1\timport { mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n2\timport { dirname, resolve } from 'node:path';\n3\timport { fileURLToPath } from 'node:url';\n4\t\n5\tconst __dirname = dirname(fileURLToPath(import.meta.url));\n6\t\n7\t/** Package root directory — works for both dev (src/) and installed (dist/) layouts. */\n8\texport function getPackageRoot(): string {\n9\t  // __dirname is src/lib/ in dev or dist/ in installed package.\n10\t  // Dev:       src/lib/  → ../.. → project root (contains package.json + templates/)\n11\t  // Installed: dist/     → ..    → package root (contains package.json + templates/)\n12\t  // Check if we're in a nested src/ path or flat dist/ path.\n13\t  if (__dirname.endsWith('/src/lib') || __dirname.endsWith('\\\\src\\\\lib')) {\n14\t    return resolve(__dirname, '..', '..');\n15\t  }\n16\t  // dist/ or dist/chunk — go up to package root\n17\t  return resolve(__dirname, '..');\n18\t}\n19\t\n20\texport function generateFile(targetPath: string, content: string): void {\n21\t  mkdirSync(dirname(targetPath), { recursive: true });\n22\t  writeFileSync(targetPath, content, 'utf-8');\n23\t}\n24\t\n25\t/**\n26\t * Interpolates `{{VAR}}` placeholders in a template string.\n27\t * Unmatched placeholders are left as-is.\n28\t */\n29\texport function renderTemplate(template: string, vars: Record<string, string>): string {\n30\t  return template.replace(/\\{\\{(\\w+)\\}\\}/g, (match, key: string) => vars[key] ?? match);\n31\t}\n32\t\n33\t/**\n34\t * Reads a template file relative to the package root and interpolates `{{VAR}}` placeholders.\n35\t * @param templatePath - Path relative to package root, e.g. 'templates/dockerfiles/Dockerfile.nodejs'\n36\t * @param vars - Key/value pairs for placeholder interpolation\n37\t * @returns The rendered template content\n38\t */\n39\texport function renderTemplateFile(templatePath: string, vars: Record<string, string> = {}): string {\n40\t  const fullPath = resolve(getPackageRoot(), templatePath);\n41\t  const content = readFileSync(fullPath, 'utf-8');\n42\t  if (Object.keys(vars).length === 0) return content;\n43\t  return renderTemplate(content, vars);\n44\t}\n45\t"}]},"parent_tool_use_id":"toolu_01CCM5MwgB4Cmai7i1sHHZbw","session_id":"5e9a7eca-0e0b-47b2-8610-117311a6629c","uuid":"bad241ac-66b8-46bc-9af5-c6adb5a42cc7","timestamp":"2026-04-02T14:35:17.681Z"}
