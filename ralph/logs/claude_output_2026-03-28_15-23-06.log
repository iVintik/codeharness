{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JaYRjDcG5nVKJo6buhJuDM","type":"tool_result","content":"     1→import { describe, it, expect, beforeAll } from 'vitest';\n     2→import { readFileSync, existsSync } from 'node:fs';\n     3→import { resolve } from 'node:path';\n     4→\n     5→const ROOT = resolve(__dirname, '..', '..', '..', '..');\n     6→\n     7→const FOUR_TIERS = ['test-provable', 'runtime-provable', 'environment-provable', 'escalate'] as const;\n     8→const LEGACY_TERMS = ['cli-verifiable', 'integration-required', 'unit-testable', 'black-box'] as const;\n     9→\n    10→let knowledgeDoc: string;\n    11→let devEnforcement: string;\n    12→let reviewEnforcement: string;\n    13→let storyVerification: string;\n    14→\n    15→const DOC_PATHS = {\n    16→  knowledge: resolve(ROOT, 'knowledge/verification-patterns.md'),\n    17→  devEnforcement: resolve(ROOT, 'patches/dev/enforcement.md'),\n    18→  reviewEnforcement: resolve(ROOT, 'patches/review/enforcement.md'),\n    19→  storyVerification: resolve(ROOT, 'patches/verify/story-verification.md'),\n    20→} as const;\n    21→\n    22→beforeAll(() => {\n    23→  for (const [key, path] of Object.entries(DOC_PATHS)) {\n    24→    if (!existsSync(path)) {\n    25→      throw new Error(`Required doc file missing: ${key} at ${path}`);\n    26→    }\n    27→  }\n    28→  knowledgeDoc = readFileSync(DOC_PATHS.knowledge, 'utf-8');\n    29→  devEnforcement = readFileSync(DOC_PATHS.devEnforcement, 'utf-8');\n    30→  reviewEnforcement = readFileSync(DOC_PATHS.reviewEnforcement, 'utf-8');\n    31→  storyVerification = readFileSync(DOC_PATHS.storyVerification, 'utf-8');\n    32→});\n    33→\n    34→// ─── AC1: knowledge/verification-patterns.md has Verification Tier Guide ─────\n    35→\n    36→describe('knowledge/verification-patterns.md — Verification Tier Guide (AC1)', () => {\n    37→  it('contains a \"Verification Tier Guide\" section', () => {\n    38→    expect(knowledgeDoc).toCo