{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Y4pgeEKma31tSLNNi9RDmq","type":"tool_result","content":"110\t *\n111\t * This sets `session_flags.tests_passed` and `session_flags.coverage_met`\n112\t * before the verify task runs, so verify's precondition check passes\n113\t * without re-running coverage.\n114\t */\n115\tfunction propagateVerifyFlags(\n116\t  taskName: string,\n117\t  contract: OutputContract | null,\n118\t  projectDir: string,\n119\t): void {\n120\t  // Guard: only run for implement tasks\n121\t  if (taskName !== 'implement') return;\n122\t\n123\t  // Guard: skip if no contract or no test results\n124\t  if (!contract?.testResults) return;\n125\t\n126\t  const { failed, coverage } = contract.testResults;\n127\t\n128\t  try {\n129\t    const { state, body } = readStateWithBody(projectDir);\n130\t\n131\t    // Set tests_passed if all tests passed\n132\t    if (failed === 0) {\n133\t      state.session_flags.tests_passed = true;\n134\t    }\n135\t\n136\t    // Set coverage_met if coverage meets the target\n137\t    // null coverage is not >= any target (null >= N is false in JS)\n138\t    if (coverage !== null && coverage !== undefined && coverage >= state.coverage.target) {\n139\t      state.session_flags.coverage_met = true;\n140\t    }\n141\t\n142\t    writeState(state, projectDir, body);\n143\t  } catch (err: unknown) {\n144\t    // IGNORE: if state file doesn't exist or can't be written,\n145\t    // flag propagation is best-effort — the verify step will\n146\t    // still work via the coverage evaluator path.\n147\t    const msg = err instanceof Error ? err.message : String(err);\n148\t    warn(`workflow-engine: flag propagation failed for ${taskName}: ${msg}`);\n149\t  }\n150\t}\n151\t\n152\t// --- Crash Recovery: Task Completion Check ---\n153\t\n154\t/**\n155\t * Check whether a (taskName, storyKey) combination is already recorded\n156\t * in the workflow state's tasks_completed array.\n157\t *\n158\t * Both fields must match for the task to be considered completed.\n159\t * Used by the resume logic to skip already-completed dispatches.\n160\t */\n161\texport function isTaskCompleted(\n162\t  state: WorkflowState,\n163\t  taskName: string,\n164\t  storyKey: string,\n165\t): boolean {\n166\t  return state.tasks_completed.some(\n167\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey && !cp.error,\n168\t  );\n169\t}"}]},"parent_tool_use_id":"toolu_01RVPCAfmmYHqZS2P5pEYVwW","session_id":"9476bbd2-ee0a-4a5e-ac2a-0ed5228c47bf","uuid":"dafd980b-991e-4990-ac93-5c48ee206393","timestamp":"2026-04-03T18:17:52.487Z"}
