() => {\n    48→  it('includes base image and common tools for any project', () => {\n    49→    mockDetectStacks.mockReturnValue([]);\n    50→    const result = generateVerifyDockerfile(testDir);\n    51→    expect(result).toContain('FROM ubuntu:22.04');\n    52→    expect(result).toContain('curl jq git python3 pipx');\n    53→    expect(result).toContain('pipx install semgrep');\n    54→    expect(result).toContain('WORKDIR /workspace');\n    55→  });\n    56→\n    57→  it('includes OTLP env vars', () => {\n    58→    mockDetectStacks.mockReturnValue([]);\n    59→    const result = generateVerifyDockerfile(testDir);\n    60→    expect(result).toContain('OTEL_EXPORTER_OTLP_ENDPOINT');\n    61→    expect(result).toContain('OTEL_SERVICE_NAME');\n    62→    expect(result).toContain('OTEL_TRACES_EXPORTER');\n    63→    expect(result).toContain('OTEL_METRICS_EXPORTER');\n    64→  });\n    65→\n    66→  it('includes Node.js section for nodejs stack', () => {\n    67→    mockDetectStacks.mockReturnValue([{ stack: 'nodejs', dir: '.' }]);\n    68→    const result = generateVerifyDockerfile(testDir);\n    69→    expect(result).toContain('nodesource');\n    70→    expect(result).toContain('nodejs');\n    71→    expect(result).toContain('showboat');\n    72→  });\n    73→\n    74→  it('includes Python section for python stack', () => {\n    75→    mockDetectStacks.mockReturnValue([{ stack: 'python', dir: '.' }]);\n    76→    const result = generateVerifyDockerfile(testDir);\n    77→    expect(result).toContain('python3-pip');\n    78→    expect(result).toContain('coverage');\n    79→    expect(result).toContain('pytest');\n    80→  });\n    81→\n    82→  it('includes Rust section for rust stack without bevy', () => {\n    83→    mockDetectStacks.mockReturnValue([{ stack: 'rust', dir: '.' }]);\n    84→    // No Cargo.toml -> no bevy detection\n    85→    const result = generateVerifyDockerfile(testDir);\n    86→    expect(result).toContain('rustup');\n    87→    expect(result).