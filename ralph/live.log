{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WH64tkrrvd4sJTzNscdaEu","type":"tool_result","content":"     1→/**\n     2→ * Sprint state — read/write unified sprint-state.json with atomic writes.\n     3→ * Also generates sprint-status.yaml as a derived human-readable view.\n     4→ */\n     5→\n     6→import { readFileSync, writeFileSync, renameSync, existsSync } from 'node:fs';\n     7→import { join, dirname } from 'node:path';\n     8→import { ok, fail } from '../../types/result.js';\n     9→import type { Result } from '../../types/result.js';\n    10→import type { SprintState, SprintStateAny, StoryStatus, StoryState } from '../../types/state.js';\n    11→import type { StoryDetail, RunProgressUpdate } from './types.js';\n    12→import { migrateFromOldFormat, migrateV1ToV2 } from './migration.js';\n    13→\n    14→/** Resolve project root (directory containing package.json) */\n    15→function projectRoot(): string {\n    16→  return process.cwd();\n    17→}\n    18→\n    19→/** Path to the sprint state file */\n    20→export function statePath(): string {\n    21→  return join(projectRoot(), 'sprint-state.json');\n    22→}\n    23→\n    24→/** Path to the temporary file used for atomic writes */\n    25→function tmpPath(): string {\n    26→  return join(projectRoot(), '.sprint-state.json.tmp');\n    27→}\n    28→\n    29→/** Path to the sprint-status.yaml file (derived view) */\n    30→export function sprintStatusYamlPath(): string {\n    31→  return join(projectRoot(), '_bmad-output', 'implementation-artifacts', 'sprint-status.yaml');\n    32→}\n    33→\n    34→/** Return an empty default SprintState (v2) */\n    35→export function defaultState(): SprintState {\n    36→  return {\n    37→    version: 2,\n    38→    sprint: {\n    39→      total: 0,\n    40→      done: 0,\n    41→      failed: 0,\n    42→      blocked: 0,\n    43→      inProgress: null,\n    44→    },\n    45→    stories: {},\n    46→    retries: {},\n    47→    flagged: [],\n    48→    epics: {},\n    49→    session: {\n    50→      active: false,\n    51→      startedAt: null,\n    52→      iteration: 0,\n    53→      elapsedSeconds: 0,\n    54→    },\n    55→    observability: {\n    56→      statementCoverage: null,\n    57→      branchCoverage: null,\n    58→      functionCoverage: null,\n    59→      lineCoverage: null,\n    60→    },\n    61→    run: {\n    62→      active: false,\n    63→      startedAt: null,\n    64→      iteration: 0,\n    65→      cost: 0,\n    66→      completed: [],\n    67→      failed: [],\n    68→      currentStory: null,\n    69→      currentPhase: null,\n    70→      lastAction: null,\n    71→      acProgress: null,\n    72→    },\n    73→    actionItems: [],\n    74→  };\n    75→}\n    76→\n    77→/** Return a default StoryState */\n    78→function defaultStoryState(): StoryState {\n    79→  return {\n    80→    status: 'backlog',\n    81→    attempts: 0,\n    82→    lastAttempt: null,\n    83→    lastError: null,\n    84→    proofPath: null,\n    85→    acResults: null,\n    86→  };\n    87→}\n    88→\n    89→/**\n    90→ * Derive a flat story-key → status map from sprint state.\n    91→ * This replaces the old `readSprintStatus()` which parsed YAML.\n    92→ * Only includes story keys (digit-digit-name pattern), not epic keys.\n    93→ */\n    94→export function getStoryStatusesFromState(state: SprintState): Record<string, string> {\n    95→  const result: Record<string, string> = {};\n    96→  for (const [key, story] of Object.entries(state.stories)) {\n    97→    result[key] = story.status;\n    98→  }\n    99→  return result;\n   100→}\n   101→\n   102→/**\n   103→ * Map internal StoryStatus values to sprint-status.yaml status strings.\n   104→ * Most map 1:1, but 'ready' maps to 'ready-for-dev' for YAML compatibility.\n   105→ */\n   106→function yamlStatus(status: StoryStatus): string {\n   107→  if (status === 'ready') return 'ready-for-dev';\n   108→  return status;\n   109→}\n   110→\n   111→/**\n   112→ * Generate sprint-status.yaml content from sprint state.\n   113→ * Groups stories by epic prefix and produces the same YAML structure\n   114→ * that existed as the hand-maintained file.\n   115→ */\n   116→export function generateSprintStatusYaml(state: SprintState): string {\n   117→  const lines: string[] = [\n   118→    '# codeharness Sprint Status (auto-generated from sprint-state.json)',\n   119→    `# generated: ${new Date().toISOString().slice(0, 10)}`,\n   120→    '# This file is a derived view — do NOT edit manually.',\n   121→    '# Source of truth: sprint-state.json',\n   122→    '',\n   123→    'development_status:',\n   124→  ];\n   125→\n   126→  // Group stories by epic prefix (first number segment)\n   127→  const epicGroups = new Map<string, string[]>();\n   128→  const sortedKeys = Object.keys(state.stories).sort((a, b) => {\n   129→    // Sort by epic number, then story number\n   130→    const [aEpic, aStory] = parseStoryKey(a);\n   131→    const [bEpic, bStory] = parseStoryKey(b);\n   132→    if (aEpic !== bEpic) return aEpic - bEpic;\n   133→    return aStory - bStory;\n   134→  });\n   135→\n   136→  for (const key of sortedKeys) {\n   137→    const epicNum = parseStoryKey(key)[0];\n   138→    const epicKey = String(epicNum);\n   139→    if (!epicGroups.has(epicKey)) {\n   140→      epicGroups.set(epicKey, []);\n   141→    }\n   142→    epicGroups.get(epicKey)!.push(key);\n   143→  }\n   144→\n   145→  // Emit each epic group\n   146→  for (const [epicKey, storyKeys] of epicGroups) {\n   147→    lines.push('');\n   148→    lines.push(`  # Epic ${epicKey}`);\n   149→\n   150→    // Compute epic status from stories\n   151→    const allDone = storyKeys.every(k => state.stories[k].status === 'done');\n   152→    const epicStatus = allDone ? 'done' : 'backlog';\n   153→    lines.push(`  epic-${epicKey}: ${epicStatus}`);\n   154→\n   155→    for (const key of storyKeys) {\n   156→      const story = state.stories[key];\n   157→      lines.push(`  ${key}: ${yamlStatus(story.status)}`);\n   158→    }\n   159→  }\n   160→\n   161→  lines.push('');\n   162→  return lines.join('\\n');\n   163→}\n   164→\n   165→/**\n   166→ * Parse a story key into [epicNumber, storyNumber].\n   167→ * e.g. \"11-2-sprint-status-yaml-derived-view\" → [11, 2]\n   168→ */\n   169→function parseStoryKey(key: string): [number, number] {\n   170→  const match = key.match(/^(\\d+)-(\\d+)/);\n   171→  if (!match) return [Infinity, Infinity];\n   172→  return [parseInt(match[1], 10), parseInt(match[2], 10)];\n   173→}\n   174→\n   175→/**\n   176→ * Write the derived sprint-status.yaml from current state.\n   177→ * Best-effort: failures are silently ignored since this is a convenience view.\n   178→ */\n   179→function writeSprintStatusYaml(state: SprintState): void {\n   180→  try {\n   181→    const yamlPath = sprintStatusYamlPath();\n   182→    // Only write if the directory exists (project has been set up)\n   183→    const dir = dirname(yamlPath);\n   184→    if (!existsSync(dir)) return;\n   185→    const content = generateSprintStatusYaml(state);\n   186→    writeFileSync(yamlPath, content, 'utf-8');\n   187→  } catch {\n   188→    // Best-effort: YAML view is not critical\n   189→  }\n   190→}\n   191→\n   192→/**\n   193→ * Write state to disk atomically: write to tmp, then rename.\n   194→ * Also regenerates sprint-status.yaml as a derived view.\n   195→ */\n   196→export function writeStateAtomic(state: SprintState): Result<void> {\n   197→  try {\n   198→    const data = JSON.stringify(state, null, 2) + '\\n';\n   199→    const tmp = tmpPath();\n   200→    const final = statePath();\n   201→    writeFileSync(tmp, data, 'utf-8');\n   202→    renameSync(tmp, final);\n   203→    // Regenerate YAML view after successful state write\n   204→    writeSprintStatusYaml(state);\n   205→    return ok(undefined);\n   206→  } catch (err: unknown) {\n   207→    const msg = err instanceof Error ? err.message : String(err);\n   208→    return fail(`Failed to write sprint state: ${msg}`);\n   209→  }\n   210→}\n   211→\n   212→/**\n   213→ * Read and parse sprint-state.json.\n   214→ * If the file does not exist, attempt migration from old files.\n   215→ * If no old files exist either, return defaultState().\n   216→ * Automatically migrates v1 state to v2.\n   217→ */\n   218→export function getSprintState(): Result<SprintState> {\n   219→  const fp = statePath();\n   220→\n   221→  if (existsSync(fp)) {\n   222→    try {\n   223→      const raw = readFileSync(fp, 'utf-8');\n   224→      const parsed = JSON.parse(raw) as Record<string, unknown>;\n   225→      const version = parsed.version as number | undefined;\n   226→\n   227→      // Already v2 — merge with defaults and return\n   228→      if (version === 2) {\n   229→        const defaults = defaultState();\n   230→        const run = parsed.run as Record<string, unknown> | undefined;\n   231→        const sprint = parsed.sprint as Record<string, unknown> | undefined;\n   232→        const session = parsed.session as Record<string, unknown> | undefined;\n   233→        const observability = parsed.observability as Record<string, unknown> | undefined;\n   234→        const state: SprintState = {\n   235→          ...(parsed as unknown as SprintState),\n   236→          sprint: {\n   237→            ...defaults.sprint,\n   238→            ...(sprint as unknown as SprintState['sprint']),\n   239→          },\n   240→          run: {\n   241→            ...defaults.run,\n   242→            ...(run as unknown as SprintState['run']),\n   243→          },\n   244→          session: {\n   245→            ...defaults.session,\n   246→            ...(session as unknown as SprintState['session']),\n   247→          },\n   248→          observability: {\n   249→            ...defaults.observability,\n   250→            ...(observability as unknown as SprintState['observability']),\n   251→          },\n   252→          retries: (parsed.retries as Record<string, number>) ?? {},\n   253→          flagged: (parsed.flagged as string[]) ?? [],\n   254→          epics: (parsed.epics as Record<string, import('../../types/state.js').EpicState>) ?? {},\n   255→        };\n   256→        return ok(state);\n   257→      }\n   258→\n   259→      // v1 or missing version — migrate to v2\n   260→      const v1State = parsed as unknown as import('../../types/state.js').SprintStateV1;\n   261→      const migrated = migrateV1ToV2(v1State);\n   262→      const writeResult = writeStateAtomic(migrated);\n   263→      if (!writeResult.success) {\n   264→        return fail(writeResult.error);\n   265→      }\n   266→      return ok(migrated);\n   267→    } catch (err: unknown) {\n   268→      const msg = err instanceof Error ? err.message : String(err);\n   269→      return fail(`Failed to read sprint state: ${msg}`);\n   270→    }\n   271→  }\n   272→\n   273→  // No sprint-state.json — try migration from old scattered files\n   274→  const migrationResult = migrateFromOldFormat();\n   275→  if (migrationResult.success) {\n   276→    return migrationResult;\n   277→  }\n   278→\n   279→  // Migration found nothing or failed — return default\n   280→  return ok(defaultState());\n   281→}\n   282→\n   283→/** Recompute sprint summary counts from story data */\n   284→export function computeSprintCounts(\n   285→  stories: Record<string, StoryState>,\n   286→): SprintState['sprint'] {\n   287→  let total = 0;\n   288→  let done = 0;\n   289→  let failed = 0;\n   290→  let blocked = 0;\n   291→  let inProgress: string | null = null;\n   292→\n   293→  for (const [key, story] of Object.entries(stories)) {\n   294→    total++;\n   295→    if (story.status === 'done') done++;\n   296→    else if (story.status === 'failed') failed++;\n   297→    else if (story.status === 'blocked') blocked++;\n   298→    else if (story.status === 'in-progress') inProgress = key;\n   299→  }\n   300→\n   301→  return { total, done, failed, blocked, inProgress };\n   302→}\n   303→\n   304→/**\n   305→ * Update a single story's status in sprint-state.json.\n   306→ * Reads current state, merges update, writes atomically.\n   307→ */\n   308→export function updateStoryStatus(\n   309→  key: string,\n   310→  status: StoryStatus,\n   311→  detail?: StoryDetail,\n   312→): Result<void> {\n   313→  const stateResult = getSprintState();\n   314→  if (!stateResult.success) {\n   315→    return fail(stateResult.error);\n   316→  }\n   317→\n   318→  const current = stateResult.data;\n   319→  const existingStory = current.stories[key] ?? defaultStoryState();\n   320→\n   321→  const isNewAttempt = status === 'in-progress';\n   322→\n   323→  const updatedStory: StoryState = {\n   324→    ...existingStory,\n   325→    status,\n   326→    attempts: isNewAttempt\n   327→      ? existingStory.attempts + 1\n   328→      : existingStory.attempts,\n   329→    lastAttempt: isNewAttempt\n   330→      ? new Date().toISOString()\n   331→      : existingStory.lastAttempt,\n   332→    lastError: detail?.error ?? existingStory.lastError,\n   333→    proofPath: detail?.proofPath ?? existingStory.proofPath,\n   334→    acResults: existingStory.acResults,\n   335→  };\n   336→\n   337→  const updatedStories = { ...current.stories, [key]: updatedStory };\n   338→  const updatedSprint = computeSprintCounts(updatedStories);\n   339→\n   340→  const updatedState: SprintState = {\n   341→    ...current,\n   342→    sprint: updatedSprint,\n   343→    stories: updatedStories,\n   344→  };\n   345→\n   346→  return writeStateAtomic(updatedState);\n   347→}\n   348→\n   349→/**\n   350→ * Update live run progress fields in sprint-state.json.\n   351→ * Only provided fields are updated; omitted fields retain their current values.\n   352→ */\n   353→export function updateRunProgress(update: RunProgressUpdate): Result<void> {\n   354→  const stateResult = getSprintState();\n   355→  if (!stateResult.success) {\n   356→    return fail(stateResult.error);\n   357→  }\n   358→\n   359→  const current = stateResult.data;\n   360→  const updatedRun = {\n   361→    ...current.run,\n   362→    ...(update.currentStory !== undefined && { currentStory: update.currentStory }),\n   363→    ...(update.currentPhase !== undefined && { currentPhase: update.currentPhase }),\n   364→    ...(update.lastAction !== undefined && { lastAction: update.lastAction }),\n   365→    ...(update.acProgress !== undefined && { acProgress: update.acProgress }),\n   366→  };\n   367→\n   368→  const updatedState: SprintState = {\n   369→    ...current,\n   370→    run: updatedRun,\n   371→  };\n   372→\n   373→  return writeStateAtomic(updatedState);\n   374→}\n   375→\n   376→/**\n   377→ * Clear all live run progress fields to null.\n   378→ * Called when a story completes or fails.\n   379→ */\n   380→export function clearRunProgress(): Result<void> {\n   381→  const stateResult = getSprintState();\n   382→  if (!stateResult.success) {\n   383→    return fail(stateResult.error);\n   384→  }\n   385→\n   386→  const current = stateResult.data;\n   387→  const updatedState: SprintState = {\n   388→    ...current,\n   389→    run: {\n   390→      ...current.run,\n   391→      currentStory: null,\n   392→      currentPhase: null,\n   393→      lastAction: null,\n   394→      acProgress: null,\n   395→    },\n   396→  };\n   397→\n   398→  return writeStateAtomic(updatedState);\n   399→}\n   400→"}]},"parent_tool_use_id":"toolu_011K77Q1Nc8EiPZnCgrdVKHN","session_id":"01503c00-15e6-46f1-b837-b4628ff69656","uuid":"f8849a98-eb2d-4541-949c-13d2ee6a39f2","timestamp":"2026-03-24T11:32:53.139Z"}
