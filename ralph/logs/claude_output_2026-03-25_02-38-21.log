{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018SaLyYcqzxroc6ExZyHQhL","type":"tool_result","content":"     1→import { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n     2→import { join, dirname } from 'node:path';\n     3→import { StringDecoder } from 'node:string_decoder';\n     4→import { Command } from 'commander';\n     5→import { fail, info, jsonOutput } from '../lib/output.js';\n     6→import { readSprintStatusFromState, reconcileState } from '../modules/sprint/index.js';\n     7→import { generateRalphPrompt } from '../lib/agents/ralph-prompt.js';\n     8→import { startRenderer, type SprintInfo } from '../lib/ink-renderer.js';\n     9→import { getSprintState } from '../modules/sprint/index.js';\n    10→import { formatElapsed, mapSprintStatuses, countStories } from '../lib/run-helpers.js';\n    11→import { getDriver } from '../lib/agents/index.js';\n    12→import type { AgentDriver, AgentEvent } from '../lib/agents/types.js';\n    13→import type { RendererHandle } from '../lib/ink-renderer.js';\n    14→\n    15→/** Resolves the plugin directory path (.claude/ in project root). */\n    16→export function resolvePluginDir(): string {\n    17→  return join(process.cwd(), '.claude');\n    18→}\n    19→\n    20→// Re-export helpers that tests import from run.ts\n    21→export { countStories } from '../lib/run-helpers.js';\n    22→\n    23→/** Dispatches an AgentEvent to the appropriate renderer method. */\n    24→function handleAgentEvent(\n    25→  event: AgentEvent,\n    26→  rendererHandle: RendererHandle,\n    27→  state: { currentIterationCount: number },\n    28→): void {\n    29→  switch (event.type) {\n    30→    case 'tool-start':\n    31→    case 'tool-complete':\n    32→    case 'text':\n    33→    case 'result':\n    34→    case 'retry':\n    35→      // These AgentEvent types match StreamEvent shapes — pass through to renderer\n    36→      rendererHandle.update(event as Parameters<RendererHandle['update']>[0]);\n    37→      break;\n    38→    case 'story-complete':\n    39→      rendererHandle.addMessage({ type: 'ok', key: event.key, message: event.details });\n    40→      break;\n    41→    case 'story-failed':\n    42→      rendererHandle.addMessage({ type: 'fail', key: event.key, message: event.reason });\n    43→      break;\n    44→    case 'iteration':\n    45→      state.currentIterationCount = event.count;\n    46→      break;\n    47→  }\n    48→}\n    49→\n    50→/** Line splitter: buffers partial lines, calls driver.parseOutput(), dispatches via handleAgentEvent(). */\n    51→function createDriverLineHandler(\n    52→  driver: AgentDriver,\n    53→  rendererHandle: RendererHandle,\n    54→  state: { currentIterationCount: number },\n    55→): (data: Buffer) => void {\n    56→  let partial = '';\n    57→  const decoder = new StringDecoder('utf8');\n    58→  return (data: Buffer): void => {\n    59→    const text = partial + decoder.write(data);\n    60→    const parts = text.split('\\n');\n    61→    partial = parts.pop() ?? '';\n    62→    for (const line of parts) {\n    63→      if (line.trim().length === 0) continue;\n    64→      const event = driver.parseOutput(line);\n    65→      if (event) {\n    66→        handleAgentEvent(event, rendererHandle, state);\n    67→      }\n    68→    }\n    69→  };\n    70→}\n    71→\n    72→export function registerRunCommand(program: Command): void {\n    73→  program\n    74→    .command('run')\n    75→    .description('Execute the autonomous coding loop')\n    76→    .option('--max-iterations <n>', 'Maximum loop iterations', '50')\n    77→    .option('--timeout <seconds>', 'Total loop timeout in seconds', '43200')\n    78→    .option('--iteration-timeout <minutes>', 'Per-iteration timeout in minutes', '30')\n    79→    .option('--quiet', 'Suppress terminal output (background mode)', false)\n    80→    .option('--calls <n>', 'Max API calls per hour', '100')\n    81→    .option('--max-story-retries <n>', 'Max retries per story before flagging', '10')\n    82→    .option('--reset', 'Clear retry counters, flagged stories, and circuit breaker before starting', false)\n    83→    .action(async (options, cmd) => {\n    84→      const globalOpts = cmd.optsWithGlobals();\n    85→      const isJson = !!globalOpts.json;\n    86→      const outputOpts = { json: isJson };\n    87→\n    88→      // 1. Resolve plugin directory\n    89→      const pluginDir = resolvePluginDir();\n    90→      if (!existsSync(pluginDir)) {\n    91→        fail('Plugin directory not found — run codeharness init first', outputOpts);\n    92→        process.exitCode = 1;\n    93→        return;\n    94→      }\n    95→\n    96→      // 1b. Reconcile state (best-effort — failures warn but don't abort)\n    97→      const reconciliation = reconcileState();\n    98→      if (reconciliation.success && reconciliation.data.corrections.length > 0) {\n    99→        for (const correction of reconciliation.data.corrections) {\n   100→          info(`[INFO] Reconciled: ${correction}`, outputOpts);\n   101→        }\n   102→      } else if (!reconciliation.success) {\n   103→        info(`[WARN] State reconciliation failed: ${reconciliation.error}`, outputOpts);\n   104→      }\n   105→\n   106→      // 2. Read sprint status for story count (from sprint-state.json)\n   107→      const projectDir = process.cwd();\n   108→      const sprintStatusPath = join(projectDir, '_bmad-output', 'implementation-artifacts', 'sprint-status.yaml');\n   109→      const statuses = readSprintStatusFromState();\n   110→      const counts = countStories(statuses);\n   111→\n   112→      if (counts.total === 0) {\n   113→        fail('No stories found in sprint-state.json — nothing to execute', outputOpts);\n   114→        process.exitCode = 1;\n   115→        return;\n   116→      }\n   117→\n   118→      info(`Starting autonomous execution — ${counts.ready} ready, ${counts.inProgress} in progress, ${counts.verified} verified, ${counts.done}/${counts.total} done`, outputOpts);\n   119→\n   120→      // 3. Parse and validate numeric options\n   121→      const maxIterations = parseInt(options.maxIterations, 10);\n   122→      const timeout = parseInt(options.timeout, 10);\n   123→      const iterationTimeout = parseInt(options.iterationTimeout, 10);\n   124→      const calls = parseInt(options.calls, 10);\n   125→      const maxStoryRetries = parseInt(options.maxStoryRetries, 10);\n   126→\n   127→      if (isNaN(maxIterations) || isNaN(timeout) || isNaN(iterationTimeout) || isNaN(calls) || isNaN(maxStoryRetries)) {\n   128→        fail('Invalid numeric option — --max-iterations, --timeout, --iteration-timeout, --calls, and --max-story-retries must be numbers', outputOpts);\n   129→        process.exitCode = 1;\n   130→        return;\n   131→      }\n   132→\n   133→      // 4. Generate prompt file (with flagged stories context if available)\n   134→      const promptFile = join(projectDir, 'ralph', '.harness-prompt.md');\n   135→      let flaggedStories: string[] | undefined;\n   136→      const flaggedState = getSprintState();\n   137→      if (flaggedState.success && flaggedState.data.flagged?.length > 0) {\n   138→        flaggedStories = flaggedState.data.flagged;\n   139→      }\n   140→      const promptContent = generateRalphPrompt({\n   141→        projectDir,\n   142→        sprintStatusPath,\n   143→        flaggedStories,\n   144→      });\n   145→      try {\n   146→        mkdirSync(dirname(promptFile), { recursive: true });\n   147→        writeFileSync(promptFile, promptContent, 'utf-8');\n   148→      } catch (err) {\n   149→        const message = err instanceof Error ? err.message : String(err);\n   150→        fail(`Failed to write prompt file: ${message}`, outputOpts);\n   151→        process.exitCode = 1;\n   152→        return;\n   153→      }\n   154→\n   155→      // 5. Create driver with ralph-specific configuration\n   156→      const quiet = options.quiet;\n   157→      const driver = getDriver('ralph', {\n   158→        pluginDir,\n   159→        maxIterations,\n   160→        iterationTimeout,\n   161→        calls,\n   162→        quiet,\n   163→        maxStoryRetries,\n   164→        reset: options.reset,\n   165→      });\n   166→\n   167→      // 6. Set environment — stream-json is always the output format\n   168→      const env: Record<string, string> = {};\n   169→      if (isJson) {\n   170→        env.CLAUDE_OUTPUT_FORMAT = 'stream-json';\n   171→      }\n   172→\n   173→      // 7. Spawn agent — pipe stdout/stderr through driver.parseOutput() → Ink renderer\n   174→      const rendererHandle = startRenderer({ quiet });\n   175→      let sprintStateInterval: ReturnType<typeof setInterval> | null = null;\n   176→      const sessionStartTime = Date.now();\n   177→      const eventState = { currentIterationCount: 0 };\n   178→\n   179→      try {\n   180→        // Read initial sprint state for the renderer header\n   181→        const initialState = getSprintState();\n   182→        if (initialState.success) {\n   183→          const s = initialState.data;\n   184→          const sprintInfo: SprintInfo = {\n   185→            storyKey: s.run.currentStory ?? '',\n   186→            phase: s.run.currentPhase ?? '',\n   187→            done: s.sprint.done,\n   188→            total: s.sprint.total,\n   189→            elapsed: formatElapsed(Date.now() - sessionStartTime),\n   190→            iterationCount: eventState.currentIterationCount,\n   191→          };\n   192→          rendererHandle.updateSprintState(sprintInfo);\n   193→        }\n   194→\n   195→        // Feed initial per-story statuses to the renderer\n   196→        const initialStatuses = readSprintStatusFromState();\n   197→        const initialStories = mapSprintStatuses(initialStatuses);\n   198→        if (initialStories.length > 0) {\n   199→          rendererHandle.updateStories(initialStories);\n   200→        }\n   201→\n   202→        const child = driver.spawn({\n   203→          storyKey: '',\n   204→          prompt: promptFile,\n   205→          workDir: projectDir,\n   206→          timeout,\n   207→          env,\n   208→        });\n   209→\n   210→        if (!quiet && child.stdout && child.stderr) {\n   211→          const lineHandler = createDriverLineHandler(driver, rendererHandle, eventState);\n   212→          child.stdout.on('data', lineHandler);\n   213→          child.stderr.on('data', lineHandler);\n   214→\n   215→          // Periodically refresh sprint state for the header display\n   216→          sprintStateInterval = setInterval(() => {\n   217→            try {\n   218→              const stateResult = getSprintState();\n   219→              if (stateResult.success) {\n   220→                const s = stateResult.data;\n   221→                const sprintInfo: SprintInfo = {\n   222→                  storyKey: s.run.currentStory ?? '',\n   223→                  phase: s.run.currentPhase ?? '',\n   224→                  done: s.sprint.done,\n   225→                  total: s.sprint.total,\n   226→                  elapsed: formatElapsed(Date.now() - sessionStartTime),\n   227→                  iterationCount: eventState.currentIterationCount,\n   228→                };\n   229→                rendererHandle.updateSprintState(sprintInfo);\n   230→              }\n   231→              // Refresh per-story statuses\n   232→              const currentStatuses = readSprintStatusFromState();\n   233→              const storyEntries = mapSprintStatuses(currentStatuses);\n   234→              rendererHandle.updateStories(storyEntries);\n   235→            } catch {\n   236→              // Ignore read errors during polling\n   237→            }\n   238→          }, 5_000);\n   239→        }\n   240→\n   241→        const exitCode = await new Promise<number>((resolve, reject) => {\n   242→          child.on('error', (err) => {\n   243→            if (sprintStateInterval) clearInterval(sprintStateInterval);\n   244→            rendererHandle.cleanup();\n   245→            reject(err);\n   246→          });\n   247→          child.on('close', (code) => {\n   248→            if (sprintStateInterval) clearInterval(sprintStateInterval);\n   249→            rendererHandle.cleanup();\n   250→            resolve(code ?? 1);\n   251→          });\n   252→        });\n   253→\n   254→        // 8. Handle JSON output on exit\n   255→        if (isJson) {\n   256→          const statusFile = join(projectDir, driver.getStatusFile());\n   257→          let statusData: Record<string, unknown> | null = null;\n   258→          let exitReason = 'status_file_missing';\n   259→          if (existsSync(statusFile)) {\n   260→            try {\n   261→              statusData = JSON.parse(readFileSync(statusFile, 'utf-8'));\n   262→              exitReason = '';\n   263→            } catch { exitReason = 'status_file_unreadable'; }\n   264→          }\n   265→          const fc = statusData ? countStories(readSprintStatusFromState()) : counts;\n   266→          jsonOutput({\n   267→            status: statusData?.status ?? (exitCode === 0 ? 'completed' : 'stopped'),\n   268→            iterations: (statusData?.loop_count as number) ?? 0,\n   269→            storiesCompleted: statusData ? fc.done : 0,\n   270→            storiesTotal: fc.total,\n   271→            storiesRemaining: statusData ? fc.total - fc.done : fc.total,\n   272→            elapsedSeconds: (statusData?.elapsed_seconds as number) ?? 0,\n   273→            flaggedStories: (statusData?.flagged_stories as string[]) ?? [],\n   274→            exitReason: (statusData?.exit_reason as string) ?? exitReason,\n   275→          });\n   276→        }\n   277→\n   278→        process.exitCode = exitCode;\n   279→      } catch (err) {\n   280→        if (sprintStateInterval) clearInterval(sprintStateInterval);\n   281→        rendererHandle.cleanup();\n   282→        const message = err instanceof Error ? err.message : String(err);\n   283→        fail(`Failed to start agent: ${message}`, outputOpts);\n   284→        process.exitCode = 1;\n   285→      }\n   286→    });\n   287→}\n   288→"}]},"parent_tool_use_id":"toolu_01LE7RFzUgPSCiom8nKkvXNg","session_id":"174e0897-5fbc-4ae0-bbc6-8b881d5c7525","uuid":"63266c4c-9b1f-47fa-9797-56d82574c23e","timestamp":"2026-03-24T22:42:15.651Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01V59zeeLuagzXsLTsfvLayN","type":"tool_result","content":"     1→/**\n     2→ * Verification environment management: Docker image lifecycle, clean workspace,\n     3→ * and environment checks for black-box verification.\n     4→ */\n     5→import { execFileSync } from 'node:child_process';\n     6→import { existsSync, mkdirSync, readdirSync, readFileSync, cpSync, rmSync, statSync } from 'node:fs';\n     7→import { join, basename } from 'node:path';\n     8→import { createHash } from 'node:crypto';\n     9→import { info } from '../../lib/output.js';\n    10→import { detectStacks } from '../../lib/stacks/index.js';\n    11→import { readStateWithBody, writeState } from '../../lib/state.js';\n    12→import { isDockerAvailable } from '../../lib/docker/index.js';\n    13→import type { BuildOptions, BuildResult, CheckResult, ProjectType } from './types.js';\n    14→\n    15→const IMAGE_TAG = 'codeharness-verify';\n    16→const STORY_DIR = '_bmad-output/implementation-artifacts';\n    17→const TEMP_PREFIX = '/tmp/codeharness-verify-';\n    18→const STATE_KEY_DIST_HASH = 'verify_env_dist_hash';\n    19→\n    20→/** Validates that a story key is safe for file paths and container names. */\n    21→export function isValidStoryKey(storyKey: string): boolean {\n    22→  if (!storyKey || storyKey.includes('..') || storyKey.includes('/') || storyKey.includes('\\\\')) {\n    23→    return false;\n    24→  }\n    25→  return /^[a-zA-Z0-9_-]+$/.test(storyKey);\n    26→}\n    27→\n    28→/** Computes a SHA-256 hash of all files in dist/ for cache invalidation. */\n    29→export function computeDistHash(projectDir: string): string | null {\n    30→  const distDir = join(projectDir, 'dist');\n    31→  if (!existsSync(distDir)) return null;\n    32→  const hash = createHash('sha256');\n    33→  const files = collectFiles(distDir).sort();\n    34→  for (const file of files) {\n    35→    hash.update(file.slice(distDir.length));\n    36→    hash.update(readFileSync(file));\n    37→  }\n    38→  return hash.digest('hex');\n    39→}\n    40→\n    41→function collectFiles(dir: string): string[] {\n    42→  const results: string[] = [];\n    43→  for (const entry of readdirSync(dir, { withFileTypes: true })) {\n    44→    const fullPath = join(dir, entry.name);\n    45→    if (entry.isDirectory()) { results.push(...collectFiles(fullPath)); }\n    46→    else { results.push(fullPath); }\n    47→  }\n    48→  return results;\n    49→}\n    50→\n    51→function getStoredDistHash(projectDir: string): string | null {\n    52→  try {\n    53→    const { state } = readStateWithBody(projectDir);\n    54→    return ((state as unknown as Record<string, unknown>)[STATE_KEY_DIST_HASH] as string) ?? null;\n    55→  } catch { return null; }\n    56→}\n    57→\n    58→function storeDistHash(projectDir: string, hash: string): void {\n    59→  try {\n    60→    const { state, body } = readStateWithBody(projectDir);\n    61→    (state as unknown as Record<string, unknown>)[STATE_KEY_DIST_HASH] = hash;\n    62→    writeState(state, projectDir, body);\n    63→  } catch {\n    64→    info('Could not persist dist hash to state file — cache will not be available until state is initialized');\n    65→  }\n    66→}\n    67→\n    68→/** Detects the project type for verification strategy selection. */\n    69→/** Stack names that map directly to ProjectType values. */\n    70→const STACK_TO_PROJECT_TYPE: Record<string, ProjectType> = {\n    71→  nodejs: 'nodejs',\n    72→  python: 'python',\n    73→  rust: 'rust',\n    74→};\n    75→\n    76→export function detectProjectType(projectDir: string): ProjectType {\n    77→  // Use detectStacks() (plural) for multi-stack awareness; derive primary from root detection\n    78→  const allStacks = detectStacks(projectDir);\n    79→  const rootDetection = allStacks.find(s => s.dir === '.');\n    80→  const stack = rootDetection ? rootDetection.stack : null;\n    81→  // Prefer known stacks when the project has a buildable package — the npm tarball\n    82→  // or Python wheel includes all distributable files. Plugin-only detection is the\n    83→  // fallback for projects that are purely Claude Code plugins with no build artifact.\n    84→  if (stack && STACK_TO_PROJECT_TYPE[stack]) return STACK_TO_PROJECT_TYPE[stack];\n    85→  if (existsSync(join(projectDir, '.claude-plugin', 'plugin.json'))) return 'plugin';\n    86→  return 'generic';\n    87→}\n    88→\n    89→/** Builds the verification Docker image with cache invalidation. */\n    90→export function buildVerifyImage(options: BuildOptions = {}): BuildResult {\n    91→  const projectDir = options.projectDir ?? process.cwd();\n    92→  if (!isDockerAvailable()) {\n    93→    throw new Error('Docker is not available. Install Docker and ensure the daemon is running.');\n    94→  }\n    95→  const projectType = detectProjectType(projectDir);\n    96→  const currentHash = computeDistHash(projectDir);\n    97→  /** Project types that don't require dist/ for verification image build */\n    98→  const NO_DIST_REQUIRED = new Set<ProjectType>(['generic', 'plugin', 'rust']);\n    99→  if (NO_DIST_REQUIRED.has(projectType)) {\n   100→    // Generic, plugin, and Rust projects may not have dist/ — skip hash check\n   101→  } else if (!currentHash) {\n   102→    throw new Error('No dist/ directory found. Run your build command first (e.g., npm run build).');\n   103→  }\n   104→  if (currentHash) {\n   105→    const storedHash = getStoredDistHash(projectDir);\n   106→    if (storedHash === currentHash && dockerImageExists(IMAGE_TAG)) {\n   107→      return { imageTag: IMAGE_TAG, imageSize: getImageSize(IMAGE_TAG), buildTimeMs: 0, cached: true };\n   108→    }\n   109→  }\n   110→  const startTime = Date.now();\n   111→  /** Per-project-type Docker image builders (no stack string comparisons). */\n   112→  const imageBuilders: Record<ProjectType, () => void> = {\n   113→    nodejs: () => buildNodeImage(projectDir),\n   114→    python: () => buildPythonImage(projectDir),\n   115→    rust: () => buildSimpleImage(projectDir, 'rust', 300_000),\n   116→    plugin: () => buildPluginImage(projectDir),\n   117→    generic: () => buildSimpleImage(projectDir, 'generic'),\n   118→  };\n   119→  imageBuilders[projectType]();\n   120→  if (currentHash) { storeDistHash(projectDir, currentHash); }\n   121→  return { imageTag: IMAGE_TAG, imageSize: getImageSize(IMAGE_TAG), buildTimeMs: Date.now() - startTime, cached: false };\n   122→}\n   123→\n   124→function buildNodeImage(projectDir: string): void {\n   125→  const packOutput = execFileSync('npm', ['pack', '--pack-destination', '/tmp'], {\n   126→    cwd: projectDir, stdio: 'pipe', timeout: 60_000,\n   127→  }).toString().trim();\n   128→  const lastLine = packOutput.split('\\n').pop()?.trim();\n   129→  if (!lastLine) throw new Error('npm pack produced no output — cannot determine tarball filename.');\n   130→  const tarballName = basename(lastLine);\n   131→  const tarballPath = join('/tmp', tarballName);\n   132→  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   133→  mkdirSync(buildContext, { recursive: true });\n   134→  try {\n   135→    cpSync(tarballPath, join(buildContext, tarballName));\n   136→    cpSync(resolveDockerfileTemplate(projectDir), join(buildContext, 'Dockerfile'));\n   137→    execFileSync('docker', ['build', '-t', IMAGE_TAG, '--build-arg', `TARBALL=${tarballName}`, '.'], {\n   138→      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   139→    });\n   140→  } finally {\n   141→    rmSync(buildContext, { recursive: true, force: true });\n   142→    rmSync(tarballPath, { force: true });\n   143→  }\n   144→}\n   145→\n   146→function buildPythonImage(projectDir: string): void {\n   147→  const distDir = join(projectDir, 'dist');\n   148→  const distFiles = readdirSync(distDir).filter(f => f.endsWith('.tar.gz') || f.endsWith('.whl'));\n   149→  if (distFiles.length === 0) {\n   150→    throw new Error('No distribution files found in dist/. Run your build command first (e.g., python -m build).');\n   151→  }\n   152→  const distFile = distFiles.filter(f => f.endsWith('.tar.gz'))[0] ?? distFiles[0];\n   153→  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   154→  mkdirSync(buildContext, { recursive: true });\n   155→  try {\n   156→    cpSync(join(distDir, distFile), join(buildContext, distFile));\n   157→    cpSync(resolveDockerfileTemplate(projectDir), join(buildContext, 'Dockerfile'));\n   158→    execFileSync('docker', ['build', '-t', IMAGE_TAG, '--build-arg', `TARBALL=${distFile}`, '.'], {\n   159→      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   160→    });\n   161→  } finally {\n   162→    rmSync(buildContext, { recursive: true, force: true });\n   163→  }\n   164→}\n   165→\n   166→/** Creates a clean temp workspace for verification (no src/, tests/, .git/). */\n   167→export function prepareVerifyWorkspace(storyKey: string, projectDir?: string): string {\n   168→  const root = projectDir ?? process.cwd();\n   169→  if (!isValidStoryKey(storyKey)) {\n   170→    throw new Error(`Invalid story key: ${storyKey}. Keys must contain only alphanumeric characters, hyphens, and underscores.`);\n   171→  }\n   172→  const storyFile = join(root, STORY_DIR, `${storyKey}.md`);\n   173→  if (!existsSync(storyFile)) throw new Error(`Story file not found: ${storyFile}`);\n   174→  const workspace = `${TEMP_PREFIX}${storyKey}`;\n   175→  if (existsSync(workspace)) rmSync(workspace, { recursive: true, force: true });\n   176→  mkdirSync(workspace, { recursive: true });\n   177→  cpSync(storyFile, join(workspace, 'story.md'));\n   178→  const readmePath = join(root, 'README.md');\n   179→  if (existsSync(readmePath)) cpSync(readmePath, join(workspace, 'README.md'));\n   180→  const docsDir = join(root, 'docs');\n   181→  if (existsSync(docsDir) && statSync(docsDir).isDirectory()) {\n   182→    cpSync(docsDir, join(workspace, 'docs'), { recursive: true });\n   183→  }\n   184→  mkdirSync(join(workspace, 'verification'), { recursive: true });\n   185→  return workspace;\n   186→}\n   187→\n   188→/** Validates verification environment: image, CLI, observability. */\n   189→export function checkVerifyEnv(): CheckResult {\n   190→  let imageExists = false;\n   191→  let cliWorks = false;\n   192→  let otelReachable = false;\n   193→\n   194→  imageExists = dockerImageExists(IMAGE_TAG);\n   195→  if (!imageExists) return { imageExists, cliWorks, otelReachable };\n   196→  try {\n   197→    execFileSync('docker', ['run', '--rm', IMAGE_TAG, 'codeharness', '--help'], {\n   198→      stdio: 'pipe', timeout: 30_000,\n   199→    });\n   200→    cliWorks = true;\n   201→  } catch { cliWorks = false; }\n   202→  try {\n   203→    execFileSync('docker', [\n   204→      'run', '--rm', '--add-host=host.docker.internal:host-gateway', IMAGE_TAG,\n   205→      'curl', '-sf', '--max-time', '5', 'http://host.docker.internal:4318/v1/status',\n   206→    ], { stdio: 'pipe', timeout: 30_000 });\n   207→    otelReachable = true;\n   208→  } catch { otelReachable = false; }\n   209→  return { imageExists, cliWorks, otelReachable };\n   210→}\n   211→\n   212→/** Cleans up all stale containers matching `codeharness-verify-*` pattern. Idempotent. */\n   213→export function cleanupStaleContainers(): void {\n   214→  try {\n   215→    const output = execFileSync(\n   216→      'docker', ['ps', '-a', '--filter', 'name=codeharness-verify-', '--format', '{{.Names}}'],\n   217→      { stdio: 'pipe', timeout: 15_000 },\n   218→    ).toString('utf-8').trim();\n   219→    if (output.length === 0) return;\n   220→    const containers = output.split('\\n').filter(name => name.length > 0);\n   221→    for (const name of containers) {\n   222→      try {\n   223→        execFileSync('docker', ['rm', '-f', name], { stdio: 'pipe', timeout: 15_000 });\n   224→      } catch { /* container may already be removed */ }\n   225→    }\n   226→  } catch { /* docker not available or no containers — ignore */ }\n   227→}\n   228→\n   229→/** Removes temp workspace and stops/removes the container. Idempotent. */\n   230→export function cleanupVerifyEnv(storyKey: string): void {\n   231→  if (!isValidStoryKey(storyKey)) {\n   232→    throw new Error(`Invalid story key: ${storyKey}. Keys must contain only alphanumeric characters, hyphens, and underscores.`);\n   233→  }\n   234→  const workspace = `${TEMP_PREFIX}${storyKey}`;\n   235→  const containerName = `codeharness-verify-${storyKey}`;\n   236→  if (existsSync(workspace)) rmSync(workspace, { recursive: true, force: true });\n   237→  try { execFileSync('docker', ['stop', containerName], { stdio: 'pipe', timeout: 15_000 }); }\n   238→  catch { /* container may not exist */ }\n   239→  try { execFileSync('docker', ['rm', '-f', containerName], { stdio: 'pipe', timeout: 15_000 }); }\n   240→  catch { /* container may not exist */ }\n   241→}\n   242→\n   243→function buildPluginImage(projectDir: string): void {\n   244→  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   245→  mkdirSync(buildContext, { recursive: true });\n   246→  try {\n   247→    // Copy plugin source into build context\n   248→    const pluginDir = join(projectDir, '.claude-plugin');\n   249→    cpSync(pluginDir, join(buildContext, '.claude-plugin'), { recursive: true });\n   250→    // Copy any commands, hooks, knowledge, skills directories if they exist\n   251→    for (const dir of ['commands', 'hooks', 'knowledge', 'skills']) {\n   252→      const src = join(projectDir, dir);\n   253→      if (existsSync(src) && statSync(src).isDirectory()) {\n   254→        cpSync(src, join(buildContext, dir), { recursive: true });\n   255→      }\n   256→    }\n   257→    cpSync(resolveDockerfileTemplate(projectDir, 'generic'), join(buildContext, 'Dockerfile'));\n   258→    execFileSync('docker', ['build', '-t', IMAGE_TAG, '.'], {\n   259→      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   260→    });\n   261→  } finally {\n   262→    rmSync(buildContext, { recursive: true, force: true });\n   263→  }\n   264→}\n   265→\n   266→function buildSimpleImage(projectDir: string, variant: string, timeout = 120_000): void {\n   267→  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   268→  mkdirSync(buildContext, { recursive: true });\n   269→  try {\n   270→    cpSync(resolveDockerfileTemplate(projectDir, variant), join(buildContext, 'Dockerfile'));\n   271→    execFileSync('docker', ['build', '-t', IMAGE_TAG, '.'], {\n   272→      cwd: buildContext, stdio: 'pipe', timeout,\n   273→    });\n   274→  } finally {\n   275→    rmSync(buildContext, { recursive: true, force: true });\n   276→  }\n   277→}\n   278→\n   279→const DOCKERFILE_VARIANTS: Record<string, string> = {\n   280→  generic: 'Dockerfile.verify.generic',\n   281→  rust: 'Dockerfile.verify.rust',\n   282→};\n   283→\n   284→function resolveDockerfileTemplate(projectDir: string, variant?: string): string {\n   285→  const filename = (variant && DOCKERFILE_VARIANTS[variant]) ?? 'Dockerfile.verify';\n   286→  const local = join(projectDir, 'templates', filename);\n   287→  if (existsSync(local)) return local;\n   288→  const pkgDir = new URL('../../', import.meta.url).pathname;\n   289→  const pkg = join(pkgDir, 'templates', filename);\n   290→  if (existsSync(pkg)) return pkg;\n   291→  throw new Error(`${filename} not found. Ensure templates/${filename} exists.`);\n   292→}\n   293→\n   294→function dockerImageExists(tag: string): boolean {\n   295→  try {\n   296→    execFileSync('docker', ['image', 'inspect', tag], { stdio: 'pipe', timeout: 10_000 });\n   297→    return true;\n   298→  } catch { return false; }\n   299→}\n   300→\n   301→function getImageSize(tag: string): string {\n   302→  try {\n   303→    const output = execFileSync('docker', ['image', 'inspect', tag, '--format', '{{.Size}}'], {\n   304→      stdio: 'pipe', timeout: 10_000,\n   305→    }).toString().trim();\n   306→    const bytes = parseInt(output, 10);\n   307→    if (isNaN(bytes)) return output;\n   308→    if (bytes >= 1_000_000_000) return `${(bytes / 1_000_000_000).toFixed(1)}GB`;\n   309→    if (bytes >= 1_000_000) return `${(bytes / 1_000_000).toFixed(1)}MB`;\n   310→    if (bytes >= 1_000) return `${(bytes / 1_000).toFixed(1)}KB`;\n   311→    return `${bytes}B`;\n   312→  } catch { return 'unknown'; }\n   313→}\n   314→"}]},"parent_tool_use_id":"toolu_01LE7RFzUgPSCiom8nKkvXNg","session_id":"174e0897-5fbc-4ae0-bbc6-8b881d5c7525","uuid":"48efabd5-8401-41e0-ab62-8eb06adbe96f","timestamp":"2026-03-24T22:42:15.697Z"}
