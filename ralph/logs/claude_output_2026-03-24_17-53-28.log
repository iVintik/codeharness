mpSync(join(tmpdir(), 'ch-state-'));\n    51→  originalCwd = process.cwd();\n    52→  process.chdir(testDir);\n    53→});\n    54→\n    55→afterEach(() => {\n    56→  process.chdir(originalCwd);\n    57→  rmSync(testDir, { recursive: true, force: true });\n    58→});\n    59→\n    60→describe('defaultState', () => {\n    61→  it('returns version 2 with empty stories and v2 fields', () => {\n    62→    const state = defaultState();\n    63→    expect(state.version).toBe(2);\n    64→    expect(state.stories).toEqual({});\n    65→    expect(state.run.active).toBe(false);\n    66→    expect(state.run.iteration).toBe(0);\n    67→    expect(state.sprint.total).toBe(0);\n    68→    expect(state.actionItems).toEqual([]);\n    69→  });\n    70→});\n    71→\n    72→describe('statePath', () => {\n    73→  it('returns path ending in sprint-state.json', () => {\n    74→    expect(statePath()).toBe(stateFile());\n    75→  });\n    76→});\n    77→\n    78→describe('writeStateAtomic', () => {\n    79→  it('writes valid JSON to sprint-state.json', () => {\n    80→    const state = defaultState();"}]},"parent_tool_use_id":"toolu_01ApBdeVdWe8XvBt2HXWCWHK","session_id":"fecf2c57-a859-44f9-9426-67d9679ac1d8","uuid":"8755247f-e76a-4543-9be2-37c87f86e668","timestamp":"2026-03-24T14:08:14.651Z"}
