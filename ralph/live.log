{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017wiHNTPdwCFetjDB5kguY6","type":"tool_result","content":"     1→import { describe, it, expect, beforeAll } from 'vitest';\n     2→import { readFileSync, existsSync } from 'node:fs';\n     3→import { resolve } from 'node:path';\n     4→import { parse as parseYaml } from 'yaml';\n     5→import { parseSemgrepOutput, computeSummary } from '../analyzer.js';\n     6→\n     7→const ROOT = resolve(__dirname, '..', '..', '..', '..');\n     8→const PATCHES_DIR = resolve(ROOT, 'patches/observability');\n     9→\n    10→// Load all three Rust rule files\n    11→interface SemgrepRule {\n    12→  id: string;\n    13→  patterns?: unknown[];\n    14→  message: string;\n    15→  languages: string[];\n    16→  severity: string;\n    17→  metadata?: {\n    18→    category?: string;\n    19→    cwe?: string;\n    20→  };\n    21→}\n    22→\n    23→interface SemgrepConfig {\n    24→  rules: SemgrepRule[];\n    25→}\n    26→\n    27→function loadRule(filename: string): SemgrepConfig {\n    28→  const path = resolve(PATCHES_DIR, filename);\n    29→  const content = readFileSync(path, 'utf-8');\n    30→  return parseYaml(content) as SemgrepConfig;\n    31→}\n    32→\n    33→// ============================================================\n    34→// rust-function-no-tracing.yaml\n    35→// ============================================================\n    36→\n    37→describe('rust-function-no-tracing.yaml', () => {\n    38→  let config: SemgrepConfig;\n    39→\n    40→  beforeAll(() => {\n    41→    config = loadRule('rust-function-no-tracing.yaml');\n    42→  });\n    43→\n    44→  it('file exists', () => {\n    45→    expect(existsSync(resolve(PATCHES_DIR, 'rust-function-no-tracing.yaml'))).toBe(true);\n    46→  });\n    47→\n    48→  it('has exactly one rule', () => {\n    49→    expect(config.rules).toHaveLength(1);\n    50→  });"}]},"parent_tool_use_id":null,"session_id":"6dce843f-9ba8-4a40-8e6f-55f9620fecc1","uui