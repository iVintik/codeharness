{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XhzsdhTedB1Pv3czUbhJL3","type":"tool_result","content":"     1→/**\n     2→ * Story file acceptance criteria parser.\n     3→ * Reads story markdown files and extracts numbered ACs with type classification.\n     4→ */\n     5→\n     6→import { existsSync, readFileSync } from 'node:fs';\n     7→import { warn } from '../../lib/output.js';\n     8→import type { ParsedAC, Verifiability, VerificationStrategy, VerificationTier, ObservabilityGapResult, ObservabilityGapEntry } from './types.js';\n     9→import { LEGACY_TIER_MAP } from './types.js';\n    10→\n    11→// ─── Keywords for Classification ────────────────────────────────────────────\n    12→\n    13→const UI_KEYWORDS = [\n    14→  'agent-browser',\n    15→  'screenshot',\n    16→  'navigate',\n    17→  'click',\n    18→  'form',\n    19→  'ui verification',\n    20→  'ui acceptance',\n    21→];\n    22→\n    23→const API_KEYWORDS = [\n    24→  'http',\n    25→  'api',\n    26→  'endpoint',\n    27→  'curl',\n    28→  'rest',\n    29→  'response bod',\n    30→];\n    31→\n    32→const DB_KEYWORDS = [\n    33→  'database',\n    34→  'db state',\n    35→  'db mcp',\n    36→  'query',\n    37→  'sql',\n    38→  'table',\n    39→];\n    40→\n    41→// ─── Integration Keywords ───────────────────────────────────────────────────\n    42→\n    43→export const INTEGRATION_KEYWORDS = [\n    44→  'external system',\n    45→  'real infrastructure',\n    46→  'manual verification',\n    47→];\n    48→\n    49→// Keywords that indicate true escalation (cannot be automated at all)\n    50→const ESCALATE_KEYWORDS = [\n    51→  'physical hardware',\n    52→  'manual human',\n    53→  'visual inspection by human',\n    54→  'paid external service',\n    55→];\n    56→\n    57→// ─── Verifiability Classification ───────────────────────────────────────────\n    58→\n    59→/**\n    60→ * Classifies whether an AC can be verified in a CLI subprocess or requires\n    61→ * integration testing. Checks description against integration keywords\n    62→ * (case-insensitive). Falls back to 'cli-verifiable'.\n    63→ *\n    64→ * @deprecated Use `classifyTier()` instead. Will be removed in a future release.\n    65→ */\n    66→export function classifyVerifiability(description: string): Verifiability {\n    67→  const lower = description.toLowerCase();\n    68→\n    69→  for (const kw of INTEGRATION_KEYWORDS) {\n    70→    if (lower.includes(kw)) return 'integration-required';\n    71→  }\n    72→\n    73→  return 'cli-verifiable';\n    74→}\n    75→\n    76→// ─── Verification Strategy ─────────────────────────────────────────────────\n    77→\n    78→/**\n    79→ * Determines the best verification strategy for an AC.\n    80→ *\n    81→ * Docker is the DEFAULT — it's the safest approach because it runs in an\n    82→ * isolated container that can't corrupt the host environment.\n    83→ *\n    84→ * cli-direct is the fallback when Docker is unavailable (checked at runtime).\n    85→ * escalate is the last resort for things that truly can't be automated.\n    86→ *\n    87→ * @deprecated Use `classifyTier()` instead. Will be removed in a future release.\n    88→ */\n    89→export function classifyStrategy(description: string): VerificationStrategy {\n    90→  const lower = description.toLowerCase();\n    91→\n    92→  // Check for true escalation first (very rare)\n    93→  for (const kw of ESCALATE_KEYWORDS) {\n    94→    if (lower.includes(kw)) return 'escalate';\n    95→  }\n    96→\n    97→  // Default: Docker for everything\n    98→  return 'docker';\n    99→}\n   100→"}]},"parent_tool_use_id":"toolu_01XaLJCdGEA6WsjsGauAKPVu","session_id":"6d9d3799-5d0f-4ddf-a676-1dbe6fbfed55","uuid":"24a36099-f3c1-4331-bb0a-28b0e841dd4a","timestamp":"2026-03-27T10:25:33.130Z"}
