r === 'pip') throw new Error('pip not found');\n   450→      // pipx succeeds\n   451→      return Buffer.from('');\n   452→    });\n   453→\n   454→    configureAgent(testDir, 'python');\n   455→\n   456→    expect(mockExecFileSync).toHaveBeenCalledWith(\n   457→      'pipx',\n   458→      expect.arrayContaining(['install', 'traceloop-sdk']),\n   459→      expect.objectContaining({ cwd: testDir }),\n   460→    );\n   461→    const state = readState(testDir);\n   462→    expect(state.otlp!.agent_sdk).toBe('traceloop');\n   463→  });\n   464→\n   465→  it('does not fail when both pip and pipx fail for Python agent packages', () => {\n   466→    initStateWithOtlp('python');\n   467→    mockExecFileSync.mockImplementation(() => {\n   468→      throw new Error('command not found');\n   469→    });\n   470→\n   471→    // Should not throw\n   472→    configureAgent(testDir, 'python');\n   473→\n   474→    // State should still be updated\n   475→    const state = readState(testDir);\n   476→    expect(state.otlp!.agent_sdk).toBe('traceloop');\n   477→  });\n   478→\n   479→  it('does nothing for null stack', () => {\n   480→    initStateWithOtlp(null);\n   481→\n   482→    configureAgent(testDir, null);\n   483→\n   484→    const state = readState(testDir);\n   485→    expect(state.otlp!.agent_sdk).toBe('traceloop');\n   486→  });\n   487→});\n   488→\n   489→describe('instrumentProject', () => {\n   490→  it('instruments Node.js project end-to-end', () => {\n   491→    initState('nodejs');\n   492→    writeFileSync(\n   493→      join(testDir, 'package.json'),\n   494→      JSON.stringify({ name: 'test', scripts: { start: 'node server.js' } }),\n   495→    );\n   496→    mockExecFileSync.mockReturnValue(Buffer.from(''));\n   497→\n   498→    const result = instrumentProject(testDir, 'nodejs');\n   499→    expect(result.status).toBe('configured');\n   500→    expect(result.packages_installed).toBe(true);\n   501→    expect(result.start_script_patched).toBe(true);\n   502→    expect(result.env_vars_configured).toBe(true);\n   503→  });\n   504→\n   505→  it('instruments Python project end-to-end', () => {\n   506→    initState('python');\n   507→    mockExecFileSync.mockReturnValue(Buffer.from(''));\n   508→\n   509→    const result = instrumentProject(testDir, 'python');\n   510→    expect(result.status).toBe('configured');\n   511→    expect(result.packages_installed).toBe(true);\n   512→    expect(result.env_vars_configured).toBe(true);\n   513→  });\n   514→\n   515→  it('skips for unsupported stack', () => {\n   516→    initState(null);\n   517→\n   518→    const result = instrumentProject(testDir, null);\n   519→    expect(result.status).toBe('skipped');\n   520→    expect(result.packages_installed).toBe(false);\n   521→  });\n   522→\n   523→  it('handles Node.js install failure gracefully — env vars still configured', () => {\n   524→    initState('nodejs');\n   525→    mockExecFileSync.mockImplementation(() => {\n   526→      throw new Error('npm failed');\n   527→    });\n   528→\n   529→    const result = instrumentProject(testDir, 'nodejs');\n   530→    expect(result.status).toBe('failed');\n   531→    // Env vars are always configured even when package install fails\n   532→    expect(result.env_vars_configured).toBe(true);\n   533→\n   534→    // State should have node_require set\n   535→    const state = readState(testDir);\n   536→    expect(state.otlp).toBeDefined();\n   537→    expect(state.otlp!.node_require).toContain('--require');\n   538→  });\n   539→\n   540→  it('handles Python install failure gracefully — env vars still configured', () => {\n   541→    initState('python');\n   542→    mockExecFileSync.mockImplementation(() => {\n   543→      throw new Error('pip failed');\n   544→    });\n   545→\n   546→    const result = instrumentProject(testDir, 'python');\n   547→    expect(result.status).toBe('failed');\n   548→    // Env vars are always configured even when package install fails\n   549→    expect(result.env_vars_configured).toBe(true);\n   550→\n   551→    // State should have python_wrapper set\n   552→    const state = readState(testDir);\n   553→    expect(state.otlp).toBeDefined();\n   554→    expect(state.otlp!.python_wrapper).toBe('opentelemetry-instrument');\n   555→  });\n   556→\n   557→  it('prints messages in non-json mode for Node.js', () => {\n   558→    initState('nodejs');\n   559→    writeFileSync(\n   560→      join(testDir, 'package.json'),\n   561→      JSON.stringify({ name: 'test', scripts: { start: 'node server.js' } }),\n   562→    );\n   563→    mockExecFileSync.mockReturnValue(Buffer.from(''));\n   564→    const logSpy = vi.spyOn(console, 'log');\n   565→\n   566→    instrumentProject(testDir, 'nodejs', { json: false });\n   567→\n   568→    const calls = logSpy.mock.calls.map(c => String(c[0]));\n   569→    expect(calls.some(c => c.includes('OTLP: Node.js packages installed'))).toBe(true);\n   570→    expect(calls.some(c => c.includes('OTLP: start script patched'))).toBe(true);\n   571→    expect(calls.some(c => c.includes('OTLP: environment variables configured'))).toBe(true);\n   572→  });\n   573→\n   574→  it('prints info message when no start script to patch', () => {\n   575→    initState('nodejs');\n   576→    writeFileSync(\n   577→      join(testDir, 'package.json'),\n   578→      JSON.stringify({ name: 'test' }),\n   579→    );\n   580→    mockExecFileSync.mockReturnValue(Buffer.from(''));\n   581→    const logSpy = vi.spyOn(console, 'log');\n   582→\n   583→    instrumentProject(testDir, 'nodejs', { json: false });\n   584→\n   585→    const calls = logSpy.mock.calls.map(c => String(c[0]));\n   586→    expect(calls.some(c => c.includes('no start/dev script found or already patched'))).toBe(true);\n   587→  });\n   588→\n   589→  it('suppresses output in json mode', () => {\n   590→    initState('nodejs');\n   591→    mockExecFileSync.mockReturnValue(Buffer.from(''));\n   592→    const logSpy = vi.spyOn(console, 'log');\n   593→\n   594→    instrumentProject(testDir, 'nodejs', { json: true });\n   595→\n   596→    const calls = logSpy.mock.calls.map(c => String(c[0]));\n   597→    expect(calls.some(c => typeof c === 'string' && c.includes('[OK]'))).toBe(false);\n   598→  });\n   599→\n   600→  it('prints Python wrapper instruction in non-json mode', () => {\n   601→    initState('python');\n   602→    mockExecFileSync.mockReturnValue(Buffer.from(''));\n   603→    const logSpy = vi.spyOn(console, 'log');\n   604→\n   605→    instrumentProject(testDir, 'python', { json: false });\n   606→\n   607→    const calls = logSpy.mock.calls.map(c => String(c[0]));\n   608→    expect(calls.some(c => c.includes('opentelemetry-instrument'))).toBe(true);\n   609→  });\n   610→\n   611→  it('prints error info in non-json mode when install fails', () => {\n   612→    initState('nodejs');\n   613→    mockExecFileSync.mockImplementation(() => { throw new Error('fail'); });\n   614→    const logSpy = vi.spyOn(console, 'log');\n   615→\n   616→    instrumentProject(testDir, 'nodejs', { json: false });\n   617→\n   618→    const calls = logSpy.mock.calls.map(c => String(c[0]));\n   619→    expect(calls.some(c => c.includes('OTLP:'))).toBe(true);\n   620→  });\n   621→\n   622→  // --- App-type dispatch tests ---\n   623→\n   624→  it('dispatches to CLI configuration when appType is cli', () => {\n   625→    initState('nodejs');\n   626→    writeFileSync(join(testDir, 'package.json'), JSON.stringify({ name: 'test' }));\n   627→    mockExecFileSync.mockReturnValue(Buffer.from(''));\n   628→\n   629→    const result = instrumentProject(testDir, 'nodejs', { appType: 'cli' });\n   630→    expect(result.status).toBe('configured');\n   631→\n   632→    const state = readState(testDir);\n   633→    expect(state.otlp!.cli_env_vars).toBeDefined();\n   634→    expect(state.otlp!.cli_env_vars!.OTEL_BSP_SCHEDULE_DELAY).toBe('100');\n   635→  });\n   636→\n   637→  it('dispatches to web configuration when appType is web