{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016pwnEruKpeLxLmg2ipMP7q","type":"tool_result","content":"1\t/**\n2\t * Epic Flow Executor.\n3\t *\n4\t * Orchestrates sequential execution of epic_flow tasks (retro, merge,\n5\t * validate) when an epic completes. Delegates to existing modules for\n6\t * each step and drives epic state transitions via transitionEpicState().\n7\t *\n8\t * @see Story 19-2: Epic Flow Execution\n9\t */\n10\t\n11\timport type { SprintState } from '../types/state.js';\n12\timport type { TelemetryEntry } from './telemetry-writer.js';\n13\timport type { WorktreeManager, MergeStrategy, OnConflictCallback } from './worktree-manager.js';\n14\t\n15\timport { transitionEpicState, type EpicLifecycleStatus } from './epic-completion.js';\n16\timport { readTelemetryForEpic } from './telemetry-writer.js';\n17\timport { validateMerge } from './cross-worktree-validator.js';\n18\t\n19\t// --- Types ---\n20\t\n21\t/**\n22\t * Configuration for executing an epic flow.\n23\t */\n24\texport interface EpicFlowConfig {\n25\t  /** The epic identifier (numeric string). */\n26\t  readonly epicId: string;\n27\t  /** Ordered list of epic_flow step names from the workflow. */\n28\t  readonly epicFlow: string[];\n29\t  /** Worktree manager instance for merge operations. */\n30\t  readonly worktreeManager: WorktreeManager;\n31\t  /** Strategy for merging the epic branch. */\n32\t  readonly mergeStrategy: MergeStrategy;\n33\t  /** Command to run for test validation. */\n34\t  readonly testCommand: string;\n35\t  /** Project root directory. */\n36\t  readonly projectDir: string;\n37\t  /** Current sprint state (immutable — each transition produces a new state). */\n38\t  readonly initialState: SprintState;\n39\t  /** Optional callback for conflict resolution during merge. */\n40\t  readonly onConflict?: OnConflictCallback;\n41\t  /** Optional callback to dispatch the analyst agent for retro. */\n42\t  readonly dispatchRetro?: (epicId: string, telemetry: TelemetryEntry[]) => Promise<void>;\n43\t  /** Optional callback invoked on each state transition. */\n44\t  readonly onStateChange?: (state: SprintState) => void;\n45\t}\n46\t\n47\t/**\n48\t * Result of a single epic_flow step.\n49\t */\n50\texport interface EpicFlowStepResult {\n51\t  /** Step name. */\n52\t  readonly step: string;\n53\t  /** Whether the step succeeded. */\n54\t  readonly success: boolean;\n55\t  /** Wall-clock duration in milliseconds. */\n56\t  readonly durationMs: number;\n57\t  /** Error message if the step failed. */\n58\t  readonly error?: string;\n59\t}\n60\t\n61\t/**\n62\t * Result of executing the full epic flow.\n63\t */\n64\texport interface EpicFlowResult {\n65\t  /** Whether all steps completed successfully. */\n66\t  readonly success: boolean;\n67\t  /** The epic identifier. */\n68\t  readonly epicId: string;\n69\t  /** Names of steps that completed successfully. */\n70\t  readonly stepsCompleted: string[];\n71\t  /** Detailed results for each attempted step. */\n72\t  readonly stepResults: EpicFlowStepResult[];\n73\t  /** Name of the step that failed, or null if all succeeded. */\n74\t  readonly failedStep: string | null;\n75\t  /** Error message from the failed step, or null. */\n76\t  readonly error: string | null;\n77\t  /** Total wall-clock duration in milliseconds. */\n78\t  readonly durationMs: number;\n79\t}\n80\t\n81\t// --- Error ---\n82\t\n83\t/**\n84\t * Error thrown by epic flow step execution.\n85\t */\n86\texport class EpicFlowError extends Error {\n87\t  constructor(message: string) {\n88\t    super(message);\n89\t    this.name = 'EpicFlowError';\n90\t  }\n91\t}\n92\t\n93\t// --- Step-to-State Mapping ---\n94\t\n95\t/**\n96\t * Maps built-in epic_flow step names to the epic state they transition to\n97\t * BEFORE the step executes.\n98\t */\n99\tconst STEP_STATE_MAP: Record<string, EpicLifecycleStatus> = {\n100\t  'merge': 'merging',\n101\t  'validate': 'validating',\n102\t};\n103\t\n104\t// --- Step Execution ---\n105\t\n106\t/**\n107\t * Execute a single epic_flow step.\n108\t * Throws EpicFlowError on failure.\n109\t */\n110\tasync function executeStep(step: string, config: EpicFlowConfig): Promise<void> {\n111\t  switch (step) {\n112\t    case 'retro': {\n113\t      const telemetry = readTelemetryForEpic(config.epicId, config.projectDir);\n114\t      if (config.dispatchRetro) {\n115\t        await config.dispatchRetro(config.epicId, telemetry);\n116\t      }\n117\t      return;\n118\t    }\n119\t    case 'merge': {\n120\t      const result = await config.worktreeManager.mergeWorktree(\n121\t        config.epicId,\n122\t        config.mergeStrategy,\n123\t        config.testCommand,\n124\t        config.onConflict,\n125\t      );\n126\t      if (!result.success) {\n127\t        throw new EpicFlowError(`Merge failed: ${result.reason ?? 'unknown'}`);\n128\t      }\n129\t      return;\n130\t    }\n131\t    case 'validate': {\n132\t      const result = await validateMerge({\n133\t        testCommand: config.testCommand,\n134\t        cwd: config.projectDir,\n135\t        epicId: config.epicId,\n136\t        writeTelemetry: true,\n137\t      });\n138\t      if (!result.valid) {\n139\t        throw new EpicFlowError(`Validation failed: ${result.testResults.failed} test(s) failed`);\n140\t      }\n141\t      return;\n142\t    }\n143\t    default:\n144\t      throw new EpicFlowError(`Unknown epic_flow step: \"${step}\"`);\n145\t  }\n146\t}\n147\t\n148\t// --- Orchestrator ---\n149\t\n150\t/**\n151\t * Execute epic_flow tasks in strict sequence.\n152\t *\n153\t * Transitions epic state at each step boundary:\n154\t * - Before `merge`: completing → merging\n155\t * - Before `validate`: merging → validating\n156\t * - After all steps: → done\n157\t * - On failure: → failed\n158\t *\n159\t * @param config  Epic flow configuration including steps, managers, and callbacks.\n160\t * @returns Comprehensive result describing each step outcome.\n161\t */\n162\texport async function executeEpicFlow(config: EpicFlowConfig): Promise<EpicFlowResult> {\n163\t  const start = Date.now();\n164\t  let state = config.initialState;\n165\t  const stepResults: EpicFlowStepResult[] = [];\n166\t  const stepsCompleted: string[] = [];\n167\t\n168\t  // Empty flow — transition directly to done\n169\t  if (config.epicFlow.length === 0) {\n170\t    state = transitionEpicState(state, config.epicId, 'done');\n171\t    config.onStateChange?.(state);\n172\t    return {\n173\t      success: true,\n174\t      epicId: config.epicId,\n175\t      stepsCompleted: [],\n176\t      stepResults: [],\n177\t      failedStep: null,\n178\t      error: null,\n179\t      durationMs: Date.now() - start,\n180\t    };\n181\t  }\n182\t\n183\t  for (const step of config.epicFlow) {\n184\t    const stepStart = Date.now();\n185\t\n186\t    // Transition epic state before built-in steps\n187\t    const preTransition = STEP_STATE_MAP[step];\n188\t    if (preTransition) {\n189\t      state = transitionEpicState(state, config.epicId, preTransition);\n190\t      config.onStateChange?.(state);\n191\t    }\n192\t\n193\t    try {\n194\t      await executeStep(step, config);\n195\t      const stepResult: EpicFlowStepResult = {\n196\t        step,\n197\t        success: true,\n198\t        durationMs: Date.now() - stepStart,\n199\t      };\n200\t      stepResults.push(stepResult);\n201\t      stepsCompleted.push(step);\n202\t    } catch (err: unknown) {\n203\t      const errorMessage = err instanceof Error ? err.message : String(err);\n204\t      const stepResult: EpicFlowStepResult = {\n205\t        step,\n206\t        success: false,\n207\t        durationMs: Date.now() - stepStart,\n208\t        error: errorMessage,\n209\t      };\n210\t      stepResults.push(stepResult);\n211\t\n212\t      // Transition to failed\n213\t      state = transitionEpicState(state, config.epicId, 'failed');\n214\t      config.onStateChange?.(state);\n215\t\n216\t      return {\n217\t        success: false,\n218\t        epicId: config.epicId,\n219\t        stepsCompleted,\n220\t        stepResults,\n221\t        failedStep: step,\n222\t        error: errorMessage,\n223\t        durationMs: Date.now() - start,\n224\t      };\n225\t    }\n226\t  }\n227\t\n228\t  // All steps succeeded — transition to done\n229\t  state = transitionEpicState(state, config.epicId, 'done');\n230\t  config.onStateChange?.(state);\n231\t\n232\t  return {\n233\t    success: true,\n234\t    epicId: config.epicId,\n235\t    stepsCompleted,\n236\t    stepResults,\n237\t    failedStep: null,\n238\t    error: null,\n239\t    durationMs: Date.now() - start,\n240\t  };\n241\t}\n242\t"}]},"parent_tool_use_id":"toolu_012S3gEG5fgffqjQviRFDsvE","session_id":"d383a9e0-3bc4-4a94-aaff-6965a5cc223b","uuid":"ecdb1b9a-a340-48f5-a309-1591b55bc225","timestamp":"2026-04-03T23:27:28.724Z"}
