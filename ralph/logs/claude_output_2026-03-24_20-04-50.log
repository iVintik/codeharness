{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01T3MrX1qwBqzNbzCFi6yq1N","type":"tool_result","content":"     1→/**\n     2→ * RalphDriver — AgentDriver implementation for the Ralph autonomous loop.\n     3→ *\n     4→ * Wraps ralph.sh invocation behind the AgentDriver interface defined in types.ts.\n     5→ * Migrates ralph-specific parsing and spawning logic from run-helpers.ts.\n     6→ */\n     7→\n     8→import { spawn } from 'node:child_process';\n     9→import { dirname, join } from 'node:path';\n    10→import { fileURLToPath } from 'node:url';\n    11→import type { AgentDriver, SpawnOpts, AgentProcess, AgentEvent } from './types.js';\n    12→import { parseStreamLine } from './stream-parser.js';\n    13→\n    14→// --- Regex constants (migrated from run-helpers.ts) ---\n    15→\n    16→/** Strip ANSI color codes */\n    17→const ANSI_ESCAPE = /\\x1b\\[[0-9;]*m/g;\n    18→\n    19→/** Strip timestamp prefix from ralph output lines */\n    20→const TIMESTAMP_PREFIX = /^\\[[\\d-]+\\s[\\d:]+\\]\\s*/;\n    21→\n    22→/** Matches: [SUCCESS] Story {key}: DONE ... */\n    23→const SUCCESS_STORY = /\\[SUCCESS\\]\\s+Story\\s+([\\w-]+):\\s+DONE(.*)/;\n    24→\n    25→/** Matches: [WARN] Story {key} exceeded retry limit ... flagging */\n    26→const WARN_STORY_RETRY = /\\[WARN\\]\\s+Story\\s+([\\w-]+)\\s+exceeded retry limit/;\n    27→\n    28→/** Matches: [WARN] Story {key} ... retry N/M */\n    29→const WARN_STORY_RETRYING = /\\[WARN\\]\\s+Story\\s+([\\w-]+)\\s+.*retry\\s+(\\d+)\\/(\\d+)/;\n    30→\n    31→/** Matches: [LOOP] iteration N */\n    32→const LOOP_ITERATION = /\\[LOOP\\]\\s+iteration\\s+(\\d+)/;\n    33→\n    34→/** Matches: [ERROR] ... */\n    35→const ERROR_LINE = /\\[ERROR\\]\\s+(.+)/;\n    36→\n    37→// --- StoryMessage type (local, replaces import from ink-components) ---\n    38→\n    39→interface StoryMessage {\n    40→  type: 'ok' | 'fail' | 'warn';\n    41→  key: string;\n    42→  message: string;\n    43→}\n    44→\n    45→// --- Migrated functions ---\n    46→\n    47→/**\n    48→ * Parse a ralph output line and return a StoryMessage if it matches\n    49→ * a story completion, failure, or warning pattern.\n    50→ * Returns null for non-matching lines.\n    51→ */\n    52→export function parseRalphMessage(rawLine: string): StoryMessage | null {\n    53→  const clean = rawLine.replace(ANSI_ESCAPE, '').replace(TIMESTAMP_PREFIX, '').trim();\n    54→  if (clean.length === 0) return null;\n    55→\n    56→  // [SUCCESS] Story {key}: DONE ...\n    57→  const success = SUCCESS_STORY.exec(clean);\n    58→  if (success) {\n    59→    const key = success[1];\n    60→    const rest = success[2].trim().replace(/^—\\s*/, '');\n    61→    return {\n    62→      type: 'ok',\n    63→      key,\n    64→      message: rest ? `DONE — ${rest}` : 'DONE',\n    65→    };\n    66→  }\n    67→\n    68→  // [WARN] Story {key} exceeded retry limit\n    69→  const retryExceeded = WARN_STORY_RETRY.exec(clean);\n    70→  if (retryExceeded) {\n    71→    return {\n    72→      type: 'fail',\n    73→      key: retryExceeded[1],\n    74→      message: 'exceeded retry limit',\n    75→    };\n    76→  }\n    77→\n    78→  // [WARN] Story {key} — retry N/M\n    79→  const retrying = WARN_STORY_RETRYING.exec(clean);\n    80→  if (retrying) {\n    81→    return {\n    82→      type: 'warn',\n    83→      key: retrying[1],\n    84→      message: `retry ${retrying[2]}/${retrying[3]}`,\n    85→    };\n    86→  }\n    87→\n    88→  // [ERROR] ... — surface as a generic error message\n    89→  const errorMatch = ERROR_LINE.exec(clean);\n    90→  if (errorMatch) {\n    91→    // Try to extract story key from error message\n    92→    const keyMatch = errorMatch[1].match(/Story\\s+([\\w-]+)/);\n    93→    if (keyMatch) {\n    94→      return {\n    95→        type: 'fail',\n    96→        key: keyMatch[1],\n    97→        message: errorMatch[1].trim(),\n    98→      };\n    99→    }\n   100→    // Generic error without a story key — skip (no key to associate)\n   101→    return null;\n   102→  }\n   103→\n   104→  return null;\n   105→}\n   106→\n   107→/**\n   108→ * Parse a ralph stderr line for [LOOP] iteration messages.\n   109→ * Returns the iteration number if found, or null otherwise.\n   110→ */\n   111→export function parseIterationMessage(rawLine: string): number | null {\n   112→  const clean = rawLine.replace(ANSI_ESCAPE, '').replace(TIMESTAMP_PREFIX, '').trim();\n   113→  if (clean.length === 0) return null;\n   114→  const match = LOOP_ITERATION.exec(clean);\n   115→  if (match) {\n   116→    return parseInt(match[1], 10);\n   117→  }\n   118→  return null;\n   119→}\n   120→\n   121→/**\n   122→ * Builds the argument array for spawning Ralph.\n   123→ */\n   124→export function buildSpawnArgs(opts: {\n   125→  ralphPath: string;\n   126→  pluginDir: string;\n   127→  promptFile: string;\n   128→  maxIterations: number;\n   129→  timeout: number;\n   130→  iterationTimeout: number;\n   131→  calls: number;\n   132→  quiet: boolean;\n   133→  maxStoryRetries?: number;\n   134→  reset?: boolean;\n   135→}): string[] {\n   136→  const args = [\n   137→    opts.ralphPath,\n   138→    '--plugin-dir', opts.pluginDir,\n   139→    '--max-iterations', String(opts.maxIterations),\n   140→    '--timeout', String(opts.timeout),\n   141→    '--iteration-timeout', String(opts.iterationTimeout),\n   142→    '--calls', String(opts.calls),\n   143→    '--prompt', opts.promptFile,\n   144→  ];\n   145→\n   146→  // When not quiet, pass --live so ralph tees Claude's stream-json to stdout.\n   147→  if (!opts.quiet) {\n   148→    args.push('--live');\n   149→  }\n   150→\n   151→  if (opts.maxStoryRetries !== undefined) {\n   152→    args.push('--max-story-retries', String(opts.maxStoryRetries));\n   153→  }\n   154→\n   155→  if (opts.reset) {\n   156→    args.push('--reset');\n   157→  }\n   158→\n   159→  return args;\n   160→}\n   161→\n   162→/** Resolves the path to ralph/ralph.sh relative to the package root. */\n   163→export function resolveRalphPath(): string {\n   164→  const currentFile = fileURLToPath(import.meta.url);\n   165→  const currentDir = dirname(currentFile);\n   166→  // currentDir is src/lib/agents (or dist/lib/agents)\n   167→  let root = dirname(dirname(currentDir));\n   168→  if (root.endsWith('/src') || root.endsWith('\\\\src')) {\n   169→    root = dirname(root);\n   170→  }\n   171→  return join(root, 'ralph', 'ralph.sh');\n   172→}\n   173→\n   174→// --- RalphDriver class ---\n   175→\n   176→export class RalphDriver implements AgentDriver {\n   177→  readonly name = 'ralph';\n   178→\n   179→  spawn(opts: SpawnOpts): AgentProcess {\n   180→    const args = buildSpawnArgs({\n   181→      ralphPath: resolveRalphPath(),\n   182→      pluginDir: join(opts.workDir, '.claude'),\n   183→      promptFile: opts.prompt,\n   184→      maxIterations: 50,\n   185→      timeout: opts.timeout,\n   186→      iterationTimeout: 30,\n   187→      calls: 100,\n   188→      quiet: false,\n   189→    });\n   190→\n   191→    const child = spawn('bash', args, {\n   192→      cwd: opts.workDir,\n   193→      env: { ...process.env, ...opts.env },\n   194→      stdio: ['inherit', 'pipe', 'pipe'],\n   195→    });\n   196→\n   197→    return child as unknown as AgentProcess;\n   198→  }\n   199→\n   200→  parseOutput(line: string): AgentEvent | null {\n   201→    // 1. Try ralph stderr patterns\n   202→    const iteration = parseIterationMessage(line);\n   203→    if (iteration !== null) {\n   204→      return { type: 'iteration', count: iteration };\n   205→    }\n   206→\n   207→    const msg = parseRalphMessage(line);\n   208→    if (msg) {\n   209→      switch (msg.type) {\n   210→        case 'ok':\n   211→          return { type: 'story-complete', key: msg.key, details: msg.message };\n   212→        case 'fail':\n   213→          return { type: 'story-failed', key: msg.key, reason: msg.message };\n   214→        case 'warn': {\n   215→          // Parse retry N/M from message\n   216→          const retryMatch = msg.message.match(/retry\\s+(\\d+)\\/(\\d+)/);\n   217→          if (retryMatch) {\n   218→            return {\n   219→              type: 'retry',\n   220→              attempt: parseInt(retryMatch[1], 10),\n   221→              delay: 0,\n   222→            };\n   223→          }\n   224→          // Fallback: treat as story-failed\n   225→          return { type: 'story-failed', key: msg.key, reason: msg.message };\n   226→        }\n   227→      }\n   228→    }\n   229→\n   230→    // 2. Fall back to stream-json parser\n   231→    const streamEvent = parseStreamLine(line);\n   232→    if (streamEvent) {\n   233→      switch (streamEvent.type) {\n   234→        case 'tool-start':\n   235→          return { type: 'tool-start', name: streamEvent.name };\n   236→        case 'tool-complete':\n   237→          return { type: 'tool-complete' };\n   238→        case 'text':\n   239→          return { type: 'text', text: streamEvent.text };\n   240→        case 'retry':\n   241→          return { type: 'retry', attempt: streamEvent.attempt, delay: streamEvent.delay };\n   242→        case 'result':\n   243→          return { type: 'result', cost: streamEvent.cost, sessionId: streamEvent.sessionId };\n   244→        case 'tool-input':\n   245→          // tool-input deltas are not mapped to AgentEvent\n   246→          return null;\n   247→      }\n   248→    }\n   249→\n   250→    return null;\n   251→  }\n   252→\n   253→  getStatusFile(): string {\n   254→    return 'ralph/status.json';\n   255→  }\n   256→}\n   257→"}]},"parent_tool_use_id":"toolu_014LQotcmHZgHHY5F784aj9H","session_id":"110312c9-09eb-45d4-bc39-1124b22b5753","uuid":"9980ce07-15e8-4729-9218-bca90a769b2d","timestamp":"2026-03-24T16:15:07.813Z"}
