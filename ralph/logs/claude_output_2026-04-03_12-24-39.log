{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01D1mpRU8DbyXtLJu13SMAtH","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { join, resolve, dirname } from 'node:path';\n3\timport { fileURLToPath } from 'node:url';\n4\timport os from 'node:os';\n5\timport { parse } from 'yaml';\n6\timport { validateWorkflowSchema } from './schema-validate.js';\n7\t\n8\tconst __filename = fileURLToPath(import.meta.url);\n9\tconst __dirname = dirname(__filename);\n10\t\n11\tconst TEMPLATES_DIR = resolve(__dirname, '../../templates/workflows');\n12\t\n13\t// --- Interfaces ---\n14\t\n15\texport interface ResolvedTask {\n16\t  agent: string;\n17\t  scope: 'per-story' | 'per-run';\n18\t  session: 'fresh' | 'continue';\n19\t  source_access: boolean;\n20\t  prompt_template?: string;\n21\t  input_contract?: Record<string, unknown>;\n22\t  output_contract?: Record<string, unknown>;\n23\t  max_budget_usd?: number;\n24\t  driver?: string;\n25\t  model?: string;\n26\t  plugins?: string[];\n27\t}\n28\t\n29\texport interface LoopBlock {\n30\t  loop: string[];\n31\t}\n32\t\n33\texport type FlowStep = string | LoopBlock;\n34\t\n35\texport interface ResolvedWorkflow {\n36\t  tasks: Record<string, ResolvedTask>;\n37\t  flow: FlowStep[];\n38\t}\n39\t\n40\t// --- Error Class ---\n41\t\n42\texport class WorkflowParseError extends Error {\n43\t  public readonly errors: Array<{ path: string; message: string }>;\n44\t\n45\t  constructor(message: string, errors?: Array<{ path: string; message: string }>) {\n46\t    super(message);\n47\t    this.name = 'WorkflowParseError';\n48\t    this.errors = errors ?? [];\n49\t  }\n50\t}\n51\t\n52\t// --- Shared Validation & Resolution ---\n53\t\n54\t/**\n55\t * Validate parsed YAML against JSON schema, check referential integrity,\n56\t * apply defaults, and return a typed ResolvedWorkflow.\n57\t * Shared between parseWorkflow (direct file) and resolveWorkflow (patch chain).\n58\t */\n59\tfunction validateAndResolve(parsed: unknown): ResolvedWorkflow {\n60\t  // Validate against JSON schema\n61\t  const result = validateWorkflowSchema(parsed);\n62\t  if (!result.valid) {\n63\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n64\t    throw new WorkflowParseError(\n65\t      `Schema validation failed: ${details}`,\n66\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n67\t    );\n68\t  }\n69\t\n70\t  // At this point, parsed has passed schema validation — safe to cast\n71\t  const data = parsed as { tasks: Record<string, Record<string, unknown>>; flow: unknown[] };\n72\t\n73\t  // Referential integrity check\n74\t  const taskNames = new Set(Object.keys(data.tasks));\n75\t  const danglingRefs: Array<{ path: string; message: string }> = [];\n76\t\n77\t  for (let i = 0; i < data.flow.length; i++) {\n78\t    const step = data.flow[i];\n79\t    if (typeof step === 'string') {\n80\t      if (!taskNames.has(step)) {\n81\t        danglingRefs.push({\n82\t          path: `/flow/${i}`,\n83\t          message: `Task \"${step}\" referenced in flow but not defined in tasks`,\n84\t        });\n85\t      }\n86\t    } else if (typeof step === 'object' && step !== null && 'loop' in step) {\n87\t      const loopBlock = step as { loop: string[] };\n88\t      for (let j = 0; j < loopBlock.loop.length; j++) {\n89\t        const ref = loopBlock.loop[j];\n90\t        if (!taskNames.has(ref)) {\n91\t          danglingRefs.push({\n92\t            path: `/flow/${i}/loop/${j}`,\n93\t            message: `Task \"${ref}\" referenced in loop but not defined in tasks`,\n94\t          });\n95\t        }\n96\t      }\n97\t    }\n98\t  }\n99\t\n100\t  if (danglingRefs.length > 0) {\n101\t    const details = danglingRefs.map((e) => e.message).join('; ');\n102\t    throw new WorkflowParseError(`Dangling task references: ${details}`, danglingRefs);\n103\t  }\n104\t\n105\t  // Apply defaults and build resolved tasks\n106\t  const resolvedTasks: Record<string, ResolvedTask> = {};\n107\t  for (const [taskName, task] of Object.entries(data.tasks)) {\n108\t    const resolved: ResolvedTask = {\n109\t      agent: task.agent as string,\n110\t      scope: (task.scope as ResolvedTask['scope']) ?? 'per-story',\n111\t      session: (task.session as ResolvedTask['session']) ?? 'fresh',\n112\t      source_access: (task.source_access as boolean) ?? true,\n113\t    };\n114\t    if (task.prompt_template !== undefined) {\n115\t      resolved.prompt_template = task.prompt_template as string;\n116\t    }\n117\t    if (task.input_contract !== undefined) {\n118\t      resolved.input_contract = task.input_contract as Record<string, unknown>;\n119\t    }\n120\t    if (task.output_contract !== undefined) {\n121\t      resolved.output_contract = task.output_contract as Record<string, unknown>;\n122\t    }\n123\t    if (task.max_budget_usd !== undefined) {\n124\t      resolved.max_budget_usd = task.max_budget_usd as number;\n125\t    }\n126\t    if (task.driver !== undefined) {\n127\t      resolved.driver = task.driver as string;\n128\t    }\n129\t    if (task.model !== undefined) {\n130\t      resolved.model = task.model as string;\n131\t    }\n132\t    if (task.plugins !== undefined) {\n133\t      resolved.plugins = task.plugins as string[];\n134\t    }\n135\t    resolvedTasks[taskName] = resolved;\n136\t  }\n137\t\n138\t  // Build resolved flow\n139\t  const resolvedFlow: FlowStep[] = data.flow.map((step) => {\n140\t    if (typeof step === 'string') {\n141\t      return step;\n142\t    }\n143\t    return step as LoopBlock;\n144\t  });\n145\t\n146\t  return { tasks: resolvedTasks, flow: resolvedFlow };\n147\t}\n148\t\n149\t// --- Parser ---\n150\t\n151\t/**\n152\t * Parse a workflow YAML file from disk, validate it against the JSON schema,\n153\t * check referential integrity, apply defaults, and return a typed ResolvedWorkflow.\n154\t */\n155\texport function parseWorkflow(filePath: string): ResolvedWorkflow {\n156\t  // 1. Read file\n157\t  let raw: string;\n158\t  try {\n159\t    raw = readFileSync(filePath, 'utf-8');\n160\t  } catch (err: unknown) {\n161\t    const code = err instanceof Error && 'code' in err ? (err as NodeJS.ErrnoException).code : undefined;\n162\t    const detail = code === 'ENOENT'\n163\t      ? 'File not found'\n164\t      : code === 'EACCES'\n165\t        ? 'Permission denied'\n166\t        : code === 'EISDIR'\n167\t          ? 'Path is a directory'\n168\t          : 'File not found or unreadable';\n169\t    throw new WorkflowParseError(`${detail}: ${filePath}`, [\n170\t      { path: filePath, message: detail },\n171\t    ]);\n172\t  }\n173\t\n174\t  // 2. Parse YAML\n175\t  let parsed: unknown;\n176\t  try {\n177\t    parsed = parse(raw);\n178\t  } catch (err: unknown) {\n179\t    const yamlMsg = err instanceof Error ? err.message : String(err);\n180\t    throw new WorkflowParseError(`Invalid YAML syntax: ${yamlMsg}`, [\n181\t      { path: filePath, message: yamlMsg },\n182\t    ]);\n183\t  }\n184\t\n185\t  return validateAndResolve(parsed);\n186\t}\n187\t\n188\t// --- Patch Interfaces ---\n189\t\n190\t/**\n191\t * Patch file structure for workflow customization.\n192\t * `extends` identifies the base, `overrides` are deep-merged, `replace` sections wholly overwrite.\n193\t */\n194\texport interface WorkflowPatch {\n195\t  extends?: string;\n196\t  overrides?: Record<string, unknown>;\n197\t  replace?: Record<string, unknown>;\n198\t}\n199\t\n200\t// --- Deep Merge ---\n201\t\n202\t/**\n203\t * Deep merge strategy: objects merge recursively, arrays replace, scalars replace.\n204\t * Same semantics as agent-resolver deepMerge.\n205\t */\n206\tfunction deepMerge(base: Record<string, unknown>, patch: Record<string, unknown>): Record<string, unknown> {\n207\t  const result: Record<string, unknown> = { ...base };\n208\t\n209\t  for (const key of Object.keys(patch)) {\n210\t    const baseVal = base[key];\n211\t    const patchVal = patch[key];\n212\t\n213\t    if (\n214\t      patchVal !== null &&\n215\t      typeof patchVal === 'object' &&\n216\t      !Array.isArray(patchVal) &&\n217\t      baseVal !== null &&\n218\t      typeof baseVal === 'object' &&\n219\t      !Array.isArray(baseVal)\n220\t    ) {\n221\t      result[key] = deepMerge(\n222\t        baseVal as Record<string, unknown>,\n223\t        patchVal as Record<string, unknown>,\n224\t      );\n225\t    } else {\n226\t      result[key] = patchVal;\n227\t    }\n228\t  }\n229\t\n230\t  return result;\n231\t}\n232\t\n233\t// --- Patch Loading ---\n234\t\n235\t/**\n236\t * Load a workflow patch file. Returns null if the file does not exist (silent skip).\n237\t * Throws WorkflowParseError on malformed YAML.\n238\t */\n239\texport function loadWorkflowPatch(filePath: string): WorkflowPatch | null {\n240\t  if (!existsSync(filePath)) {\n241\t    return null;\n242\t  }\n243\t\n244\t  let raw: string;\n245\t  try {\n246\t    raw = readFileSync(filePath, 'utf-8');\n247\t  } catch (err: unknown) {\n248\t    const code = err instanceof Error && 'code' in err ? (err as NodeJS.ErrnoException).code : undefined;\n249\t    if (code === 'ENOENT') {\n250\t      return null; // File disappeared between existsSync and readFileSync — treat as missing\n251\t    }\n252\t    const detail = code === 'EACCES' ? 'Permission denied' : 'File unreadable';\n253\t    throw new WorkflowParseError(`${detail}: ${filePath}`, [\n254\t      { path: filePath, message: detail },\n255\t    ]);\n256\t  }\n257\t\n258\t  let parsed: unknown;\n259\t  try {\n260\t    parsed = parse(raw);\n261\t  } catch (err: unknown) {\n262\t    const msg = err instanceof Error ? err.message : String(err);\n263\t    throw new WorkflowParseError(`Invalid YAML in patch file ${filePath}: ${msg}`, [\n264\t      { path: filePath, message: msg },\n265\t    ]);\n266\t  }\n267\t\n268\t  if (parsed === null || typeof parsed !== 'object') {\n269\t    throw new WorkflowParseError(`Patch file is not a valid object: ${filePath}`, [\n270\t      { path: filePath, message: 'Patch must be a YAML object' },\n271\t    ]);\n272\t  }\n273\t\n274\t  return parsed as WorkflowPatch;\n275\t}\n276\t\n277\t// --- Patch Merging ---\n278\t\n279\t/**\n280\t * Merge a workflow patch onto a base config.\n281\t * Deep-merges `overrides`, then applies `replace` sections as full overwrites.\n282\t */\n283\texport function mergeWorkflowPatch(\n284\t  base: Record<string, unknown>,\n285\t  patch: WorkflowPatch,\n286\t): Record<string, unknown> {\n287\t  let result = { ...base };\n288\t\n289\t  // Deep-merge overrides\n290\t  if (patch.overrides) {\n291\t    result = deepMerge(result, patch.overrides);\n292\t  }\n293\t\n294\t  // Full replacement for replace sections\n295\t  if (patch.replace) {\n296\t    for (const key of Object.keys(patch.replace)) {\n297\t      result[key] = patch.replace[key];\n298\t    }\n299\t  }\n300\t\n301\t  return result;\n302\t}\n303\t\n304\t// --- Main Resolution ---\n305\t\n306\t/**\n307\t * Resolve a workflow through the embedded -> user -> project patch chain.\n308\t *\n309\t * 1. Load embedded workflow from templates/workflows/{name}.yaml\n310\t * 2. Apply user-level patch from ~/.codeharness/workflows/{name}.patch.yaml (if exists)\n311\t * 3. Apply project-level patch from .codeharness/workflows/{name}.patch.yaml (if exists)\n312\t * 4. Validate merged result against JSON schema + referential integrity\n313\t * 5. Apply defaults and return ResolvedWorkflow\n314\t *\n315\t * If a full custom workflow (no patch, no extends) exists at project level, it is loaded directly.\n316\t */\n317\texport function resolveWorkflow(options?: { cwd?: string; name?: string }): ResolvedWorkflow {\n318\t  const cwd = options?.cwd ?? process.cwd();\n319\t  const name = options?.name ?? 'default';\n320\t\n321\t  const userPatchPath = join(os.homedir(), '.codeharness', 'workflows', `${name}.patch.yaml`);\n322\t  const projectPatchPath = join(cwd, '.codeharness', 'workflows', `${name}.patch.yaml`);\n323\t\n324\t  // Check for full custom workflow at project level (not a patch — no extends)\n325\t  const projectCustomPath = join(cwd, '.codeharness', 'workflows', `${name}.yaml`);\n326\t  if (existsSync(projectCustomPath)) {\n327\t    const customPatch = loadWorkflowPatch(projectCustomPath);\n328\t    if (customPatch && !customPatch.extends) {\n329\t      // This is a full custom workflow, not a patch — parse directly\n330\t      return parseWorkflow(projectCustomPath);\n331\t    }\n332\t  }\n333\t\n334\t  // Load embedded base\n335\t  const embeddedPath = join(TEMPLATES_DIR, `${name}.yaml`);\n336\t  let raw: string;\n337\t  try {\n338\t    raw = readFileSync(embeddedPath, 'utf-8');\n339\t  } catch (err: unknown) {\n340\t    const detail = err instanceof Error ? err.message : `File not found: ${embeddedPath}`;\n341\t    throw new WorkflowParseError(`Embedded workflow not found: ${name}`, [\n342\t      { path: embeddedPath, message: detail },\n343\t    ]);\n344\t  }\n345\t\n346\t  let baseData: unknown;\n347\t  try {\n348\t    baseData = parse(raw);\n349\t  } catch (err: unknown) {\n350\t    const msg = err instanceof Error ? err.message : String(err);\n351\t    throw new WorkflowParseError(`Invalid YAML in embedded workflow ${name}: ${msg}`, [\n352\t      { path: embeddedPath, message: msg },\n353\t    ]);\n354\t  }\n355\t\n356\t  let merged = baseData as Record<string, unknown>;\n357\t\n358\t  // Apply user-level patch\n359\t  const userPatch = loadWorkflowPatch(userPatchPath);\n360\t  if (userPatch) {\n361\t    merged = mergeWorkflowPatch(merged, userPatch);\n362\t  }\n363\t\n364\t  // Apply project-level patch\n365\t  const projectPatch = loadWorkflowPatch(projectPatchPath);\n366\t  if (projectPatch) {\n367\t    merged = mergeWorkflowPatch(merged, projectPatch);\n368\t  }\n369\t\n370\t  // Validate, check referential integrity, apply defaults, and return\n371\t  return validateAndResolve(merged);\n372\t}\n373\t"}]},"parent_tool_use_id":"toolu_01K9WPLAQDFLLNWtkamPogoK","session_