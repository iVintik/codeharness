Info.runCommand;\n   190ŌåÆ}\n   191ŌåÆ\n   192ŌåÆexport function runCoverage(dir?: string): CoverageResult {\n   193ŌåÆ  const baseDir = dir ?? process.cwd();\n   194ŌåÆ  const toolInfo = detectCoverageTool(baseDir);\n   195ŌåÆ\n   196ŌåÆ  if (toolInfo.tool === 'unknown' || !toolInfo.runCommand) {\n   197ŌåÆ    return {\n   198ŌåÆ      success: false,\n   199ŌåÆ      testsPassed: false,\n   200ŌåÆ      passCount: 0,\n   201ŌåÆ      failCount: 0,\n   202ŌåÆ      coveragePercent: 0,\n   203ŌåÆ      rawOutput: 'No coverage tool detected. Ensure your project has a test runner configured.',\n   204ŌåÆ    };\n   205ŌåÆ  }\n   206ŌåÆ\n   207ŌåÆ  let rawOutput = '';\n   208ŌåÆ  let testsPassed = true;\n   209ŌåÆ\n   210ŌåÆ  try {\n   211ŌåÆ    rawOutput = execSync(toolInfo.runCommand, {\n   212ŌåÆ      cwd: baseDir,\n   213ŌåÆ      encoding: 'utf-8',\n   214ŌåÆ      stdio: ['pipe', 'pipe', 'pipe'],\n   215ŌåÆ      timeout: 300_000, // 5 minute timeout\n   216ŌåÆ    });\n   217ŌåÆ  } catch (err: unknown) {\n   218ŌåÆ    const execError = err as { status?: number; stdout?: string; stderr?: string };\n   219ŌåÆ    testsPassed = false;\n   220ŌåÆ    rawOutput = (execError.stdout ?? '') + (execError.stderr ?? '');\n   221ŌåÆ\n   222ŌåÆ    if (!rawOutput) {\n   223ŌåÆ      return {\n   224ŌåÆ        success: false,\n   225ŌåÆ        testsPassed: false,\n   226ŌåÆ        passCount: 0,\n   227ŌåÆ        failCount: 0,\n   228ŌåÆ        coveragePercent: 0,\n   229ŌåÆ        rawOutput: 'Test command failed with no output',\n   230ŌåÆ      };\n   231ŌåÆ    }\n   232ŌåÆ  }\n   233ŌåÆ\n   234ŌåÆ  const { passCount, failCount } = parseTestCounts(rawOutput);\n   235ŌåÆ  if (failCount > 0) {\n   236ŌåÆ    testsPassed = false;\n   237ŌåÆ  }\n   238ŌåÆ\n   239ŌåÆ  const coveragePercent = parseCoverageReport(baseDir, toolInfo.reportFormat);\n   240ŌåÆ\n   241ŌåÆ  return {\n   242ŌåÆ    success: true,\n   243ŌåÆ    testsPassed,\n   244ŌåÆ    passCount,\n   245ŌåÆ    failCount,\n   246ŌåÆ    coveragePercent,\n   247ŌåÆ    rawOutput,\n   248ŌåÆ  };\n   249ŌåÆ}"}]},"parent_tool_use_id":"toolu_013A1PTE3Sqig6Yi2KxMXRHR","session_id":"010b7052-acb2-4a98-9861-0b5f61bbdbf0","uuid":"c3e8bf05-ffab-41cb-8df1-a2f17c0fb2e4","timestamp":"2026-03-24T12:21:47.012Z"}
