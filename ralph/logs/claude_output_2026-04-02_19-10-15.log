{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Lnrvmv9PysqXVfvRb3xpo6","type":"tool_result","content":"1\t{\n2\t  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n3\t  \"$id\": \"https://codeharness.dev/schemas/agent.schema.json\",\n4\t  \"title\": \"Codeharness Agent\",\n5\t  \"description\": \"Schema for codeharness agent configuration YAML files\",\n6\t  \"type\": \"object\",\n7\t  \"required\": [\"name\", \"role\", \"persona\"],\n8\t  \"properties\": {\n9\t    \"name\": {\n10\t      \"type\": \"string\",\n11\t      \"description\": \"Agent identifier\"\n12\t    },\n13\t    \"role\": {\n14\t      \"type\": \"object\",\n15\t      \"required\": [\"title\", \"purpose\"],\n16\t      \"properties\": {\n17\t        \"title\": {\n18\t          \"type\": \"string\",\n19\t          \"description\": \"Agent's role title\"\n20\t        },\n21\t        \"purpose\": {\n22\t          \"type\": \"string\",\n23\t          \"description\": \"What this agent does\"\n24\t        }\n25\t      },\n26\t      \"additionalProperties\": false\n27\t    },\n28\t    \"persona\": {\n29\t      \"type\": \"object\",\n30\t      \"required\": [\"identity\", \"communication_style\", \"principles\"],\n31\t      \"properties\": {\n32\t        \"identity\": {\n33\t          \"type\": \"string\",\n34\t          \"description\": \"Who this agent is\"\n35\t        },\n36\t        \"communication_style\": {\n37\t          \"type\": \"string\",\n38\t          \"description\": \"How this agent communicates\"\n39\t        },\n40\t        \"principles\": {\n41\t          \"type\": \"array\",\n42\t          \"items\": {\n43\t            \"type\": \"string\"\n44\t          },\n45\t          \"description\": \"Behavioral principles\"\n46\t        }\n47\t      },\n48\t      \"additionalProperties\": false\n49\t    },\n50\t    \"personality\": {\n51\t      \"type\": \"object\",\n52\t      \"properties\": {\n53\t        \"traits\": {\n54\t          \"type\": \"object\",\n55\t          \"additionalProperties\": {\n56\t            \"type\": \"number\",\n57\t            \"minimum\": 0,\n58\t            \"maximum\": 1\n59\t          },\n60\t          \"description\": \"PersonaNexus-compatible traits with values constrained to 0-1\"\n61\t        }\n62\t      },\n63\t      \"additionalProperties\": false\n64\t    },\n65\t    \"disallowedTools\": {\n66\t      \"type\": \"array\",\n67\t      \"items\": {\n68\t        \"type\": \"string\"\n69\t      },\n70\t      \"description\": \"Tools this agent is not allowed to use\"\n71\t    }\n72\t  },\n73\t  \"additionalProperties\": false\n74\t}\n75\t"}]},"parent_tool_use_id":"toolu_01MZT1wf6WvCyJ5fZdoG3o3g","session_id":"fb9c1538-17c2-48c5-8d63-6a9f60fb8dd3","uuid":"e89865e9-2f61-4cc0-8461-56eb3e89b333","timestamp":"2026-04-02T15:18:35.669Z"}
