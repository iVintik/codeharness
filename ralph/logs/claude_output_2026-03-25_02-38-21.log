{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01211NkVgPeFzsZFVzNyRVQ2","type":"tool_result","content":"     1→/**\n     2→ * Docker container cleanup utilities.\n     3→ *\n     4→ * NOTE: Primary cleanup logic lives in src/modules/infra/container-cleanup.ts.\n     5→ * These stubs exist to satisfy the domain directory structure.\n     6→ * TODO: Consolidate cleanup logic here if container-cleanup.ts is refactored.\n     7→ */\n     8→\n     9→import { cleanupContainers } from '../../modules/infra/container-cleanup.js';\n    10→\n    11→/**\n    12→ * Cleans up orphaned containers left behind by previous codeharness runs.\n    13→ * Delegates to the infra module's cleanupContainers().\n    14→ * Returns the number of containers removed.\n    15→ */\n    16→export function cleanupOrphanedContainers(): number {\n    17→  const result = cleanupContainers();\n    18→  return result.success ? result.data.containersRemoved : 0;\n    19→}\n    20→\n    21→/**\n    22→ * Cleans up Docker artifacts created during verify-env runs.\n    23→ */\n    24→export function cleanupVerifyEnv(): void {\n    25→  // Placeholder — verify-env cleanup is handled inline in the verify module\n    26→}\n    27→"}]},"parent_tool_use_id":"toolu_01NrzDLhF9NNDZQrr8WemqQC","session_id":"174e0897-5fbc-4ae0-bbc6-8b881d5c7525","uuid":"4c1d049b-924d-473a-a1f8-fb6ce11d274d","timestamp":"2026-03-24T22:52:26.322Z"}
