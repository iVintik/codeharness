{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BrprbSkgkLFfdTD5S9jDJi","type":"tool_result","content":"     1→/**\n     2→ * Project initialization orchestrator.\n     3→ * Composes sub-steps: stack detection, deps, Docker, BMAD, beads, state, docs, OTLP.\n     4→ */\n     5→\n     6→import { existsSync } from 'node:fs';\n     7→import { basename } from 'node:path';\n     8→import { ok as okOutput, fail as failOutput, info, jsonOutput } from '../../lib/output.js';\n     9→import { detectStack, detectStacks, detectAppType } from '../../lib/stack-detect.js';\n    10→import { readState, writeState, getDefaultState, getStatePath } from '../../lib/state.js';\n    11→import type { HarnessState } from '../../lib/state.js';\n    12→import { instrumentProject } from '../../lib/otlp.js';\n    13→import type { Result } from '../../types/result.js';\n    14→import { ok, fail, isOk } from '../../types/result.js';\n    15→import type { InitOptions, InitResult } from './types.js';\n    16→import { checkDocker, setupDocker } from './docker-setup.js';\n    17→import { installDeps, verifyDeps } from './deps-install.js';\n    18→import { setupBmad, verifyBmadOnRerun } from './bmad-setup.js';\n    19→import { initializeBeads } from './beads-init.js';\n    20→import { scaffoldDocs, getCoverageTool, getStackLabel } from './docs-scaffold.js';\n    21→import { generateDockerfileTemplate } from './dockerfile-template.js';\n    22→\n    23→declare const __PKG_VERSION__: string;\n    24→const HARNESS_VERSION = typeof __PKG_VERSION__ !== 'undefined' ? __PKG_VERSION__ : '0.0.0-dev';\n    25→\n    26→/** Helper: build a fail-status InitResult for early returns */\n    27→function failResult(opts: InitOptions, error: string): InitResult {\n    28→  return {\n    29→    status: 'fail', stack: null, stacks: [], error,\n    30→    enforcement: { frontend: opts.frontend, database: opts.database, api: opts.api },\n    31→    documentation: { agents_md: 'skipped', docs_scaffold: 'skipped', readme: 'skipped' },\n    32→  };\n    33→}\n    34→\n    35→/** Output error and set exit code for validation/critical failures */\n    36→function emitError(error: string, isJson: boolean): void {\n    37→  if (isJson) { jsonOutput({ status: 'fail', error }); } else { failOutput(error); }\n    38→  process.exitCode = 1;\n    39→}\n    40→\n    41→/** Main project initialization orchestrator. Never throws — returns fail() on unexpected errors. */\n    42→export async function initProject(opts: InitOptions): Promise<Result<InitResult>> {\n    43→  try {\n    44→    return await initProjectInner(opts);\n    45→  } catch (err) {\n    46→    const message = err instanceof Error ? err.message : String(err);\n    47→    return fail(`Unexpected init error: ${message}`);\n    48→  }\n    49→}\n    50→\n    51→async function initProjectInner(opts: InitOptions): Promise<Result<InitResult>> {\n    52→  const { projectDir, json: isJson = false } = opts;\n    53→  const result: InitResult = {\n    54→    status: 'ok', stack: null, stacks: [],\n    55→    enforcement: { frontend: opts.frontend, database: opts.database, api: opts.api },\n    56→    documentation: { agents_md: 'skipped', docs_scaffold: 'skipped', readme: 'skipped' },\n    57→  };\n    58→\n    59→  // --- Idempotent re-run check ---\n    60→  const rerunResult = handleRerun(opts, result);\n    61→  if (rerunResult !== null) return rerunResult;\n    62→\n    63→  // --- Remote endpoint URL validation ---\n    64→  const urlError = validateRemoteUrls(opts);\n    65→  if (urlError !== null) { emitError(urlError, isJson); return ok(failResult(opts, urlError)); }\n    66→\n    67→  // --- Stack detection ---\n    68→  const stack = detectStack(projectDir);\n    69→  result.stack = stack;\n    70→  const allStacks = detectStacks(projectDir);\n    71→  result.stacks = [...new Set(allStacks.map(s => s.stack))];\n    72→  const appType = detectAppType(projectDir, stack);\n    73→  result.app_type = appType;\n    74→  if (!isJson) {\n    75→    if (stack) info(`Stack detected: ${getStackLabel(stack)}`);\n    76→    info(`App type: ${appType}`);\n    77→  }\n    78→\n    79→  // --- Dockerfile template generation ---\n    80→  const dfResult = generateDockerfileTemplate(projectDir, stack);\n    81→  if (isOk(dfResult)) {\n    82→    result.dockerfile = { generated: true, stack: dfResult.data.stack };\n    83→    if (!isJson) info(`Generated Dockerfile for ${dfResult.data.stack} project.`);\n    84→  } else {\n    85→    if (!isJson) info('Dockerfile already exists -- skipping template generation.');\n    86→  }\n    87→\n    88→  // --- Docker check ---\n    89→  const dockerCheck = checkDocker({ observability: opts.observability, otelEndpoint: opts.otelEndpoint, logsUrl: opts.logsUrl, opensearchUrl: opts.opensearchUrl, isJson });\n    90→  if (!isOk(dockerCheck)) return fail(dockerCheck.error);\n    91→  const { available: dockerAvailable, criticalFailure, dockerResult: criticalDockerResult } = dockerCheck.data;\n    92→  if (criticalFailure) {\n    93→    result.status = 'fail'; result.error = 'Docker not installed'; result.docker = criticalDockerResult;\n    94→    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); }\n    95→    else { failOutput('Docker not installed'); info('\\u2192 Install Docker: https://docs.docker.com/engine/install/'); info('\\u2192 Or skip observability: codeharness init --no-observability'); }\n    96→    process.exitCode = 1;\n    97→    return ok(result);\n    98→  }\n    99→\n   100→  // --- Dependency install ---\n   101→  const depResult = installDeps({ isJson });\n   102→  if (!isOk(depResult)) {\n   103→    result.status = 'fail'; result.error = depResult.error;\n   104→    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); } else { info('Critical dependency failed — aborting init'); }\n   105→    process.exitCode = 1;\n   106→    return ok(result);\n   107→  }\n   108→  result.dependencies = depResult.data;\n   109→\n   110→  // --- Beads initialization ---\n   111→  result.beads = initializeBeads(projectDir, isJson);\n   112→\n   113→  // --- BMAD installation ---\n   114→  const bmadResult = setupBmad({ projectDir, isJson });\n   115→  if (isOk(bmadResult)) result.bmad = bmadResult.data;\n   116→\n   117→  // --- State file creation ---\n   118→  let state: HarnessState = getDefaultState(stack);\n   119→  state.harness_version = HARNESS_VERSION;\n   120→  state.initialized = true;\n   121→  state.app_type = appType;\n   122→  state.enforcement = { frontend: opts.frontend, database: opts.database, api: opts.api };\n   123→  state.coverage.tool = getCoverageTool(stack);\n   124→  // Persist all detected stacks (not just the primary root stack)\n   125→  state.stacks = result.stacks as import('../../lib/stack-detect.js').StackName[];\n   126→  writeState(state, projectDir);\n   127→  if (!isJson) okOutput('State file: .claude/codeharness.local.md created');\n   128→\n   129→  // --- Documentation scaffold ---\n   130→  const docsResult = await scaffoldDocs({ projectDir, stack, isJson });\n   131→  if (isOk(docsResult)) result.documentation = docsResult.data;\n   132→\n   133→  // --- OTLP instrumentation ---\n   134→  if (!opts.observability) {\n   135→    result.otlp = { status: 'skipped', packages_installed: false, start_script_patched: false, env_vars_configured: false };\n   136→    if (!isJson) info('OTLP: skipped (--no-observability)');\n   137→  } else {\n   138→    result.otlp = instrumentProject(projectDir, stack, { json: isJson, appType });\n   139→  }\n   140→\n   141→  // Re-read state to pick up otlp changes written by instrumentProject\n   142→  try { const u = readState(projectDir); if (u.otlp) state.otlp = u.otlp; } catch { /* ignore */ }\n   143→  if (!state.otlp) {\n   144→    state.otlp = { enabled: true, endpoint: 'http://localhost:4318', service_name: basename(projectDir), mode: 'local-shared' };\n   145→  }\n   146→\n   147→  // --- Docker stack setup ---\n   148→  const dockerSetup = setupDocker({\n   149→    observability: opts.observability, otelEndpoint: opts.otelEndpoint,\n   150→    opensearchUrl: opts.opensearchUrl,\n   151→    logsUrl: opts.logsUrl, metricsUrl: opts.metricsUrl, tracesUrl: opts.tracesUrl,\n   152→    isJson, dockerAvailable, appType, state, projectDir,\n   153→  });\n   154→  if (isOk(dockerSetup)) result.docker = dockerSetup.data.docker;\n   155→\n   156→  // --- Enforcement summary ---\n   157→  if (!isJson) {\n   158→    const e = state.enforcement;\n   159→    const fmt = (v: boolean): string => v ? 'ON' : 'OFF';\n   160→    okOutput(`Enforcement: frontend:${fmt(e.frontend)} database:${fmt(e.database)} api:${fmt(e.api)} observability:ON`);\n   161→    info('Harness initialized. Run: codeharness bridge --epics <path>');\n   162→  }\n   163→  if (isJson) jsonOutput(result as unknown as Record<string, unknown>);\n   164→\n   165→  return ok(result);\n   166→}\n   167→\n   168→function handleRerun(opts: InitOptions, result: InitResult): Result<InitResult> | null {\n   169→  const { projectDir, json: isJson = false } = opts;\n   170→  if (!existsSync(getStatePath(projectDir))) return null;\n   171→\n   172→  try {\n   173→    const existingState = readState(projectDir);\n   174→    const legacyObsDisabled = (existingState.enforcement as Record<string, unknown>).observability === false;\n   175→    if (!existingState.initialized || legacyObsDisabled) {\n   176→      if (legacyObsDisabled && !isJson) info('Observability upgraded from disabled to enabled');\n   177→      return null;\n   178→    }\n   179→    result.stack = existingState.stack;\n   180→    result.stacks = existingState.stacks ?? [];\n   181→    result.enforcement = existingState.enforcement;\n   182→    result.documentation = { agents_md: 'exists', docs_scaffold: 'exists', readme: 'exists' };\n   183→    result.dependencies = verifyDeps(isJson);\n   184→    result.docker = existingState.docker\n   185→      ? { compose_file: existingState.docker.compose_file, stack_running: existingState.docker.stack_running, services: [], ports: existingState.docker.ports }\n   186→      : null;\n   187→    const bmadResult = verifyBmadOnRerun(projectDir, isJson);\n   188→    if (bmadResult) result.bmad = bmadResult;\n   189→    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); }\n   190→    else { info('Harness already initialized — verifying configuration'); okOutput('Configuration verified'); }\n   191→    return ok(result);\n   192→  } catch {\n   193→    return null;\n   194→  }\n   195→}\n   196→\n   197→/** Returns error message string if validation fails, null if OK */\n   198→function validateRemoteUrls(opts: InitOptions): string | null {\n   199→  const remoteUrls = [opts.otelEndpoint, opts.opensearchUrl, opts.logsUrl, opts.metricsUrl, opts.tracesUrl].filter(Boolean) as string[];\n   200→  for (const url of remoteUrls) {\n   201→    if (!/^https?:\\/\\//i.test(url)) return `Invalid URL: '${url}' \\u2014 must start with http:// or https://`;\n   202→  }\n   203→  if (opts.otelEndpoint && (opts.logsUrl || opts.metricsUrl || opts.tracesUrl)) {\n   204→    return 'Cannot combine --otel-endpoint with --logs-url/--metrics-url/--traces-url';\n   205→  }\n   206→  const hasAny = opts.logsUrl || opts.metricsUrl || opts.tracesUrl;\n   207→  if (hasAny && !(opts.logsUrl && opts.metricsUrl && opts.tracesUrl)) {\n   208→    return 'When using remote backends, all three are required: --logs-url, --metrics-url, --traces-url';\n   209→  }\n   210→  return null;\n   211→}\n   212→"}]},"parent_tool_use_id":"toolu_01GahX8iUoYR49K5t7MjQw49","session_id":"46c7b24e-5b3f-4eb1-bc5a-20f6a0336cfe","uuid":"8a242361-9117-4858-b6e1-b4671441a624","timestamp":"2026-03-23T14:51:12.654Z"}
