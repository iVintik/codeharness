{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014Gt1H76pY4EhBPSs2kfaEi","type":"tool_result","content":"1\timport { Command } from 'commander';\n2\timport { existsSync, readFileSync } from 'node:fs';\n3\timport { join } from 'node:path';\n4\timport { ok, fail, info, warn, jsonOutput } from '../lib/output.js';\n5\timport { parseRetroActionItems, classifyFinding, parseRetroSections, isDuplicate, derivePriority } from '../lib/retro-parser.js';\n6\timport { createIssue, readIssues } from '../lib/issue-tracker.js';\n7\timport { isGhAvailable, findExistingGhIssue, ghIssueCreate, ensureLabels, getRepoFromRemote } from '../lib/github.js';\n8\timport { readState, StateFileNotFoundError } from '../lib/state.js';\n9\timport type { Classification } from '../lib/retro-parser.js';\n10\timport type { RetroIssueTarget } from '../lib/github.js';\n11\t\n12\tconst STORY_DIR = '_bmad-output/implementation-artifacts';\n13\t\n14\t/** Maximum length for issue titles derived from action item descriptions. */\n15\tconst MAX_TITLE_LENGTH = 120;\n16\t\n17\tinterface ImportedIssue {\n18\t  number: string;\n19\t  title: string;\n20\t  gapId: string;\n21\t  classification: string;\n22\t  created: boolean;\n23\t  status: string;\n24\t  notes: string;\n25\t}\n26\t\n27\tinterface LocalImportResult {\n28\t  imported: number;\n29\t  skipped: number;\n30\t  duplicates: number;\n31\t  issues: Array<{ id: string; title: string; source: string; priority: string }>;\n32\t}\n33\t\n34\tinterface GitHubResult {\n35\t  created: number;\n36\t  skipped: number;\n37\t  errors: number;\n38\t}\n39\t\n40\tfunction classificationToString(c: Classification): string {\n41\t  if (c.type === 'tool') {\n42\t    return `tool:${c.name}`;\n43\t  }\n44\t  return c.type;\n45\t}\n46\t\n47\texport function registerRetroImportCommand(program: Command): void {\n48\t  program\n49\t    .command('retro-import')\n50\t    .description('Import retrospective action items as GitHub issues')\n51\t    .requiredOption('--epic <n>', 'Epic number to import action items from')\n52\t    .action((opts, cmd) => {\n53\t      const globalOpts = cmd.optsWithGlobals();\n54\t      const isJson = globalOpts.json === true;\n55\t      const root = process.cwd();\n56\t\n57\t      // Validate epic number\n58\t      const epicNum = parseInt(opts.epic, 10);\n59\t      if (isNaN(epicNum) || epicNum < 1) {\n60\t        fail(`Invalid epic number: ${opts.epic}`, { json: isJson });\n61\t        process.exitCode = 1;\n62\t        return;\n63\t      }\n64\t\n65\t      // Read retro file\n66\t      const retroFile = `epic-${epicNum}-retrospective.md`;\n67\t      const retroPath = join(root, STORY_DIR, retroFile);\n68\t\n69\t      if (!existsSync(retroPath)) {\n70\t        fail(`Retro file not found: ${retroFile}`, { json: isJson });\n71\t        process.exitCode = 1;\n72\t        return;\n73\t      }\n74\t\n75\t      let content: string;\n76\t      try {\n77\t        content = readFileSync(retroPath, 'utf-8');\n78\t      } catch (err: unknown) {\n79\t        const message = err instanceof Error ? err.message : String(err);\n80\t        fail(`Failed to read retro file: ${message}`, { json: isJson });\n81\t        process.exitCode = 1;\n82\t        return;\n83\t      }\n84\t\n85\t      // ─── Local issues.yaml import ──────────────────────────────────────\n86\t      let localResult: LocalImportResult;\n87\t      try {\n88\t        localResult = importToIssuesYaml(content, epicNum, root, isJson);\n89\t      } catch (err: unknown) {\n90\t        const message = err instanceof Error ? err.message : String(err);\n91\t        if (!isJson) {\n92\t          warn(`Local issues.yaml import failed: ${message}`);\n93\t        }\n94\t        localResult = { imported: 0, skipped: 0, duplicates: 0, issues: [] };\n95\t      }\n96\t\n97\t      // Parse table-based action items for GitHub phase\n98\t      const items = parseRetroActionItems(content);\n99\t\n100\t      // If both parsers found nothing, report and exit\n101\t      if (items.length === 0 && localResult.imported === 0 && localResult.skipped === 0 && localResult.duplicates === 0) {\n102\t        if (isJson) {\n103\t          jsonOutput({ imported: 0, skipped: 0, duplicates: 0, issues: [] });\n104\t        } else {\n105\t          info('No action items found in retro file');\n106\t        }\n107\t        return;\n108\t      }\n109\t\n110\t      const issues: ImportedIssue[] = [];\n111\t\n112\t      for (const item of items) {\n113\t        const classification = classifyFinding(item);\n114\t        const gapId = `[gap:retro:epic-${epicNum}-item-${item.number}]`;\n115\t\n116\t        // Truncate title to reasonable length\n117\t        const title =\n118\t          item.description.length > MAX_TITLE_LENGTH\n119\t            ? item.description.slice(0, MAX_TITLE_LENGTH - 3) + '...'\n120\t            : item.description;\n121\t\n122\t        const issueRecord: ImportedIssue = {\n123\t          number: item.number,\n124\t          title,\n125\t          gapId,\n126\t          classification: classificationToString(classification),\n127\t          created: false,\n128\t          status: item.status,\n129\t          notes: item.notes,\n130\t        };\n131\t\n132\t        issues.push(issueRecord);\n133\t\n134\t        if (!isJson) {\n135\t          info(`Parsed: ${title}`);\n136\t        }\n137\t      }\n138\t\n139\t      // ─── GitHub Issue Creation Phase ────────────────────────────────────\n140\t      const githubResult = createGitHubIssues(issues, epicNum, isJson);\n141\t\n142\t      if (isJson) {\n143\t        jsonOutput({\n144\t          imported: localResult.imported,\n145\t          skipped: localResult.skipped,\n146\t          duplicates: localResult.duplicates,\n147\t          issues: localResult.issues as unknown as Record<string, unknown>[],\n148\t          github: githubResult as unknown as Record<string, unknown>,\n149\t        });\n150\t      } else if (localResult.imported > 0 || localResult.duplicates > 0 || localResult.skipped > 0) {\n151\t        info(`Summary: ${localResult.imported} imported, ${localResult.skipped} skipped, ${localResult.duplicates} duplicates`);\n152\t      }\n153\t    });\n154\t}\n155\t\n156\t/**\n157\t * Import retro action items into `.codeharness/issues.yaml`.\n158\t * Tries section-based parsing first, falls back to table-based parsing.\n159\t */\n160\tfunction importToIssuesYaml(\n161\t  content: string,\n162\t  epicNum: number,\n163\t  dir: string,\n164\t  isJson: boolean,\n165\t): LocalImportResult {\n166\t  const source = `retro-epic-${epicNum}`;\n167\t  const result: LocalImportResult = { imported: 0, skipped: 0, duplicates: 0, issues: [] };\n168\t\n169\t  // Read existing issue titles for dedup\n170\t  const existingIssues = readIssues(dir);\n171\t  const existingTitles = existingIssues.issues.map(i => i.title);\n172\t\n173\t  // Strategy: try section-based first, fall back to table-based\n174\t  const sectionItems = parseRetroSections(content);\n175\t  const actionableSections = sectionItems.filter(i => i.section !== 'backlog');\n176\t  const backlogSections = sectionItems.filter(i => i.section === 'backlog');\n177\t\n178\t  if (actionableSections.length > 0 || backlogSections.length > 0) {\n179\t    // Section-based format found\n180\t    for (const item of backlogSections) {\n181\t      result.skipped++;\n182\t      if (!isJson) {\n183\t        info(`Skipped (backlog — non-actionable): ${item.text}`);\n184\t      }\n185\t    }\n186\t\n187\t    for (const item of actionableSections) {\n188\t      const priority = item.section === 'fix-now' ? 'high' : 'medium';\n189\t\n190\t      // Check for duplicates\n191\t      const dupCheck = isDuplicate(item.text, existingTitles);\n192\t      if (dupCheck.duplicate) {\n193\t        result.duplicates++;\n194\t        if (!isJson) {\n195\t          info(`Skipped (duplicate of \"${dupCheck.matchedTitle}\"): ${item.text}`);\n196\t        }\n197\t        continue;\n198\t      }\n199\t\n200\t      const issue = createIssue(item.text, { priority, source }, dir);\n201\t      existingTitles.push(issue.title);\n202\t      result.imported++;\n203\t      result.issues.push({ id: issue.id, title: issue.title, source: issue.source, priority: issue.priority });\n204\t\n205\t      if (!isJson) {\n206\t        ok(`Imported [${issue.id}] (${priority}): ${item.text}`);\n207\t      }\n208\t    }\n209\t\n210\t    return result;\n211\t  }\n212\t\n213\t  // Fall back to table-based parsing\n214\t  const tableItems = parseRetroActionItems(content);\n215\t\n216\t  if (tableItems.length === 0) {\n217\t    return result;\n218\t  }\n219\t\n220\t  for (const item of tableItems) {\n221\t    const priorityNum = derivePriority(item);\n222\t    const priority = priorityNum === 1 ? 'high' : 'medium';\n223\t\n224\t    // Check for duplicates\n225\t    const dupCheck = isDuplicate(item.description, existingTitles);\n226\t    if (dupCheck.duplicate) {\n227\t      result.duplicates++;\n228\t      if (!isJson) {\n229\t        info(`Skipped (duplicate of \"${dupCheck.matchedTitle}\"): ${item.description}`);\n230\t      }\n231\t      continue;\n232\t    }\n233\t\n234\t    const issue = createIssue(item.description, { priority, source }, dir);\n235\t    existingTitles.push(issue.title);\n236\t    result.imported++;\n237\t    result.issues.push({ id: issue.id, title: issue.title, source: issue.source, priority: issue.priority });\n238\t\n239\t    if (!isJson) {\n240\t      ok(`Imported [${issue.id}] (${priority}): ${item.description}`);\n241\t    }\n242\t  }\n243\t\n244\t  return result;\n245\t}\n246\t\n247\t/**\n248\t * Resolves the target repo for a classification based on retro_issue_targets config.\n249\t */\n250\tfunction resolveTargetRepo(\n251\t  classification: string,\n252\t  targets: RetroIssueTarget[],\n253\t): RetroIssueTarget | undefined {\n254\t  if (targets.length === 0) return undefined;\n255\t\n256\t  if (classification === 'harness') {\n257\t    // Prefer explicit codeharness repo, then first non-auto, then auto as fallback\n258\t    const explicit = targets.find(t => t.repo === 'iVintik/codeharness');\n259\t    if (explicit) return explicit;\n260\t    const nonAuto = targets.find(t => t.repo !== 'auto');\n261\t    if (nonAuto) return nonAuto;\n262\t    return targets[0];\n263\t  }\n264\t\n265\t  // project or tool:* → prefer auto, else first target\n266\t  const auto = targets.find(t => t.repo === 'auto');\n267\t  if (auto) return auto;\n268\t  return targets[0];\n269\t}\n270\t\n271\t/**\n272\t * Builds the GitHub issue body with retro context and gap-id for dedup.\n273\t */\n274\tfunction buildGitHubIssueBody(\n275\t  item: ImportedIssue,\n276\t  epicNum: number,\n277\t  projectName: string,\n278\t): string {\n279\t  return `## Retro Action Item ${item.number} — Epic ${epicNum}\n280\t\n281\t**Source project:** ${projectName}\n282\t**Classification:** ${item.classification}\n283\t**Original status:** ${item.status}\n284\t**Notes:** ${item.notes}\n285\t\n286\t${item.title}\n287\t\n288\t<!-- gap-id: ${item.gapId} -->`;\n289\t}\n290\t\n291\t/**\n292\t * GitHub issue creation phase.\n293\t */\n294\tfunction createGitHubIssues(\n295\t  issues: ImportedIssue[],\n296\t  epicNum: number,\n297\t  isJson: boolean,\n298\t): GitHubResult | undefined {\n299\t  // Read state to check for retro_issue_targets\n300\t  let targets: RetroIssueTarget[] | undefined;\n301\t  try {\n302\t    const state = readState();\n303\t    targets = state.retro_issue_targets;\n304\t  } catch (err: unknown) {\n305\t    if (err instanceof StateFileNotFoundError) {\n306\t      if (!isJson) {\n307\t        info('No state file found — skipping GitHub issues');\n308\t      }\n309\t      return undefined;\n310\t    }\n311\t    // Other state errors — skip GitHub phase gracefully\n312\t    if (!isJson) {\n313\t      info('Could not read state file — skipping GitHub issues');\n314\t    }\n315\t    return undefined;\n316\t  }\n317\t\n318\t  if (!targets || targets.length === 0) {\n319\t    if (!isJson) {\n320\t      info('No retro_issue_targets configured — skipping GitHub issues');\n321\t    }\n322\t    return undefined;\n323\t  }\n324\t\n325\t  // Check gh CLI availability\n326\t  if (!isGhAvailable()) {\n327\t    if (!isJson) {\n328\t      warn('gh CLI not available — skipping GitHub issue creation');\n329\t    }\n330\t    return undefined;\n331\t  }\n332\t\n333\t  // Resolve \"auto\" repos\n334\t  const resolvedAutoRepo = getRepoFromRemote();\n335\t\n336\t  const result: GitHubResult = { created: 0, skipped: 0, errors: 0 };\n337\t\n338\t  // Detect project name from git remote\n339\t  const projectName = resolvedAutoRepo ?? 'unknown';\n340\t\n341\t  for (const item of issues) {\n342\t    const target = resolveTargetRepo(item.classification, targets);\n343\t    if (!target) continue;\n344\t\n345\t    // Resolve actual repo name\n346\t    const repo = target.repo === 'auto' ? resolvedAutoRepo : target.repo;\n347\t    if (!repo) {\n348\t      if (!isJson) {\n349\t        warn(`Cannot resolve repo for ${item.number} — git remote not detected`);\n350\t      }\n351\t      result.errors++;\n352\t      continue;\n353\t    }\n354\t\n355\t    try {\n356\t      // Check for existing issue (dedup)\n357\t      const existing = findExistingGhIssue(repo, item.gapId);\n358\t      if (existing) {\n359\t        if (!isJson) {\n360\t          info(`GitHub issue exists: ${repo}#${existing.number}`);\n361\t        }\n362\t        result.skipped++;\n363\t        continue;\n364\t      }\n365\t\n366\t      // Ensure labels exist\n367\t      ensureLabels(repo, target.labels);\n368\t\n369\t      // Create the issue\n370\t      const body = buildGitHubIssueBody(item, epicNum, projectName);\n371\t      const created = ghIssueCreate(repo, item.title, body, target.labels);\n372\t      if (!isJson) {\n373\t        ok(`GitHub issue created: ${repo}#${created.number}`);\n374\t      }\n375\t      result.created++;\n376\t    } catch (err: unknown) {\n377\t      const message = err instanceof Error ? err.message : String(err);\n378\t      if (!isJson) {\n379\t        fail(`GitHub issue failed for ${item.number}: ${message}`);\n380\t      }\n381\t      result.errors++;\n382\t    }\n383\t  }\n384\t\n385\t  return result;\n386\t}\n387\t"}]},"parent_tool_use_id":"toolu_01Tbq8uvPR9dftszWB5nuigP","session_id":"3f15b50c-2c9b-40fa-9e63-9fad2199af43","uuid":"a95c26a6-fcbd-4bbe-aa53-a07dc0330e92","timestamp":"2026-04-03T02:32:18.043Z"}
