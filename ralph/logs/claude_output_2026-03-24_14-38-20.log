{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QuJmEHmZ2j5HQhQLVn1EDG","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';\n     2→import {\n     3→  readFileSync,\n     4→  writeFileSync,\n     5→  unlinkSync,\n     6→  existsSync,\n     7→  chmodSync,\n     8→} from 'node:fs';\n     9→import { join } from 'node:path';\n    10→import type { SprintState } from '../../../types/state.js';\n    11→\n    12→// Mock migration so state tests are isolated from real project files\n    13→vi.mock('../migration.js', () => ({\n    14→  migrateFromOldFormat: vi.fn(() => ({\n    15→    success: false,\n    16→    error: 'No old format files found for migration',\n    17→  })),\n    18→  migrateV1ToV2: vi.fn((v1: Record<string, unknown>) => ({\n    19→    ...v1,\n    20→    version: 2,\n    21→    retries: {},\n    22→    flagged: [],\n    23→    epics: {},\n    24→    session: { active: false, startedAt: null, iteration: 0, elapsedSeconds: 0 },\n    25→    observability: { statementCoverage: null, branchCoverage: null, functionCoverage: null, lineCoverage: null },\n    26→  })),\n    27→}));\n    28→\n    29→// Import after mock setup\n    30→const { getSprintState, updateStoryStatus, writeStateAtomic, defaultState, statePath } =\n    31→  await import('../state.js');\n    32→\n    33→const STATE_FILE = join(process.cwd(), 'sprint-state.json');\n    34→const TMP_FILE = join(process.cwd(), '.sprint-state.json.tmp');\n    35→\n    36→function cleanup(): void {\n    37→  for (const f of [STATE_FILE, TMP_FILE]) {\n    38→    try {\n    39→      chmodSync(f, 0o644);\n    40→    } catch {\n    41→      // ignore — file may not exist\n    42→    }\n    43→    try {\n    44→      unlinkSync(f);\n    45→    } catch {\n    46→      // ignore — file may not exist\n    47→    }\n    48→  }\n    49→}\n    50→\n    51→describe('defaultState', () => {\n    52→  it('returns version 2 with empty stories and v2 fields', () => {\n    53→    const state = defaultState();\n    54→    expect(state.version).toBe(2);\n    55→    expect(state.stories).toEqual({});\n    56→    expect(state.run.active).toBe(false);\n    57→    expect(state.run.iteration).toBe(0);\n    58→    expect(state.sprint.total).toBe(0);\n    59→    expect(state.actionItems).toEqual([]);\n    60→  });\n    61→});\n    62→\n    63→describe('statePath', () => {\n    64→  it('returns path ending in sprint-state.json', () => {\n    65→    expect(statePath()).toBe(STATE_FILE);\n    66→  });\n    67→});\n    68→\n    69→describe('writeStateAtomic', () => {\n    70→  beforeEach(cleanup);\n    71→  afterEach(cleanup);\n    72→\n    73→  it('writes valid JSON to sprint-state.json', () => {\n    74→    const state = defaultState();\n    75→    const result = writeStateAtomic(state);\n    76→    expect(result.success).toBe(true);\n    77→    expect(existsSync(STATE_FILE)).toBe(true);\n    78→\n    79→    const raw = readFileSync(STATE_FILE, 'utf-8');\n    80→    const parsed = JSON.parse(raw);\n    81→    expect(parsed.version).toBe(2);\n    82→  });\n    83→\n    84→  it('tmp file does not remain after successful write', () => {\n    85→    const result = writeStateAtomic(defaultState());\n    86→    expect(result.success).toBe(true);\n    87→    expect(existsSync(TMP_FILE)).toBe(false);\n    88→  });\n    89→});\n    90→\n    91→describe('getSprintState', () => {\n    92→  beforeEach(cleanup);\n    93→  afterEach(cleanup);\n    94→\n    95→  it('returns default state when no file exists', () => {\n    96→    const result = getSprintState();\n    97→    expect(result.success).toBe(true);\n    98→    if (result.success) {\n    99→      expect(result.data.version).toBe(2);\n   100→      expect(result.data.stories).toEqual({});\n   101→      expect(result.data.run.active).toBe(false);\n   102→      expect(result.data.sprint.inProgress).toBeNull();\n   103→      expect(result.data.actionItems).toEqual([]);\n   104→      expect(result.data.retries).toEqual({});\n   105→      expect(result.data.flagged).toEqual([]);\n   106→      expect(result.data.epics).toEqual({});\n   107→      expect(result.data.session.active).toBe(false);\n   108→      expect(result.data.observability.statementCoverage).toBeNull();\n   109→    }\n   110→  });\n   111→\n   112→  it('reads and parses existing sprint-state.json', () => {\n   113→    const state: SprintState = {\n   114→      ...defaultState(),\n   115→      stories: {\n   116→        'test-story': {\n   117→          status: 'done',\n   118→          attempts: 2,\n   119→          lastAttempt: '2026-01-01T00:00:00Z',\n   120→          lastError: null,\n   121→          proofPath: null,\n   122→          acResults: null,\n   123→        },\n   124→      },\n   125→    };\n   126→    writeFileSync(STATE_FILE, JSON.stringify(state, null, 2), 'utf-8');\n   127→\n   128→    const result = getSprintState();\n   129→    expect(result.success).toBe(true);\n   130→    if (result.success) {\n   131→      expect(result.data.stories['test-story'].status).toBe('done');\n   132→      expect(result.data.stories['test-story'].attempts).toBe(2);\n   133→    }\n   134→  });\n   135→\n   136→  it('returns fail on invalid JSON', () => {\n   137→    writeFileSync(STATE_FILE, '{not valid json', 'utf-8');\n   138→    const result = getSprintState();\n   139→    expect(result.success).toBe(false);\n   140→    if (!result.success) {\n   141→      expect(result.error).toContain('Failed to read sprint state');\n   142→    }\n   143→  });\n   144→\n   145→  it('parse time is under 100ms for 50 stories', () => {\n   146→    const stories: Record<string, SprintState['stories'][string]> = {};\n   147→    for (let i = 0; i < 50; i++) {\n   148→      stories[`story-${i}`] = {\n   149→        status: 'backlog',\n   150→        attempts: i,\n   151→        lastAttempt: new Date().toISOString(),\n   152→        lastError: `error ${i}`,\n   153→        proofPath: null,\n   154→        acResults: [\n   155→          { id: `ac-${i}-1`, verdict: 'pass' },\n   156→          { id: `ac-${i}-2`, verdict: 'fail' },\n   157→        ],\n   158→      };\n   159→    }\n   160→    const state: SprintState = { ...defaultState(), stories };\n   161→    writeFileSync(STATE_FILE, JSON.stringify(state, null, 2), 'utf-8');\n   162→\n   163→    const start = performance.now();\n   164→    const result = getSprintState();\n   165→    const elapsed = performance.now() - start;\n   166→\n   167→    expect(result.success).toBe(true);\n   168→    expect(elapsed).toBeLessThan(100);\n   169→  });\n   170→\n   171→  it('never throws — returns fail on fs error', () => {\n   172→    writeFileSync(STATE_FILE, '{}', 'utf-8');\n   173→    chmodSync(STATE_FILE, 0o000);\n   174→\n   175→    const result = getSprintState();\n   176→    expect(result).toBeDefined();\n   177→    expect(typeof result.success).toBe('boolean');\n   178→  });\n   179→});\n   180→\n   181→describe('updateStoryStatus', () => {\n   182→  beforeEach(cleanup);\n   183→  afterEach(cleanup);\n   184→\n   185→  it('creates file if missing and updates story', () => {\n   186→    const result = updateStoryStatus('story-1', 'in-progress');\n   187→    expect(result.success).toBe(true);\n   188→    expect(existsSync(STATE_FILE)).toBe(true);\n   189→\n   190→    const state = JSON.parse(readFileSync(STATE_FILE, 'utf-8')) as SprintState;\n   191→    expect(state.stories['story-1'].status).toBe('in-progress');\n   192→    expect(state.stories['story-1'].attempts).toBe(1);\n   193→    expect(state.sprint.inProgress).toBe('story-1');\n   194→  });\n   195→\n   196→  it('updates existing story preserving other stories', () => {\n   197→    updateStoryStatus('story-1', 'in-progress');\n   198→    updateStoryStatus('story-2', 'done');\n   199→\n   200→    const state = JSON.parse(readFileSync(STATE_FILE, 'utf-8')) as SprintState;\n   201→    expect(state.stories['story-1']).toBeDefined();\n   202→    expect(state.stories['story-2'].status).toBe('done');\n   203→    expect(state.sprint.done).toBe(1);\n   204→    expect(state.sprint.total).toBe(2);\n   205→  });\n   206→\n   207→  it('attaches error detail when provided', () => {\n   208→    updateStoryStatus('story-1', 'failed', { error: 'build broke' });\n   209→\n   210→    const state = JSON.parse(readFileSync(STATE_FILE, 'utf-8')) as SprintState;\n   211→    expect(state.stories['story-1'].lastError).toBe('build broke');\n   212→    expect(state.stories['story-1'].status).toBe('failed');\n   213→    expect(state.sprint.failed).toBe(1);\n   214→  });\n   215→\n   216→  it('attaches proofPath when provided', () => {\n   217→    updateStoryStatus('story-1', 'done', {\n   218→      proofPath: 'docs/proof.md',\n   219→    });\n   220→\n   221→    const state = JSON.parse(readFileSync(STATE_FILE, 'utf-8')) as SprintState;\n   222→    expect(state.stories['story-1'].proofPath).toBe('docs/proof.md');\n   223→  });\n   224→\n   225→  it('increments attempts only on in-progress transition', () => {\n   226→    updateStoryStatus('story-1', 'in-progress');\n   227→    updateStoryStatus('story-1', 'failed', { error: 'oops' });\n   228→    updateStoryStatus('story-1', 'in-progress');\n   229→\n   230→    const state = JSON.parse(readFileSync(STATE_FILE, 'utf-8')) as SprintState;\n   231→    expect(state.stories['story-1'].attempts).toBe(2);\n   232→  });\n   233→\n   234→  it('uses atomic write (tmp then rename)', () => {\n   235→    updateStoryStatus('story-1', 'done');\n   236→    expect(existsSync(TMP_FILE)).toBe(false);\n   237→    expect(existsSync(STATE_FILE)).toBe(true);\n   238→  });\n   239→\n   240→  it('round-trips state correctly (write then read)', () => {\n   241→    updateStoryStatus('roundtrip', 'verifying');\n   242→\n   243→    const result = getSprintState();\n   244→    expect(result.success).toBe(true);\n   245→    if (result.success) {\n   246→      expect(result.data.stories['roundtrip'].status).toBe('verifying');\n   247→    }\n   248→  });\n   249→});\n   250→\n   251→describe('lastAttempt semantics and error paths', () => {\n   252→  beforeEach(cleanup);\n   253→  afterEach(cleanup);\n   254→\n   255→  it('sets lastAttempt only on in-progress transitions', () => {\n   256→    updateStoryStatus('story-1', 'in-progress');\n   257→    const state1 = JSON.parse(readFileSync(STATE_FILE, 'utf-8')) as SprintState;\n   258→    const firstAttemptTime = state1.stories['story-1'].lastAttempt;\n   259→    expect(firstAttemptTime).not.toBeNull();\n   260→    updateStoryStatus('story-1', 'done');\n   261→    const state2 = JSON.parse(readFileSync(STATE_FILE, 'utf-8')) as SprintState;\n   262→    expect(state2.stories['story-1'].lastAttempt).toBe(firstAttemptTime);\n   263→  });\n   264→\n   265→  it('writeStateAtomic returns fail on serialization error', () => {\n   266→    const poison = {\n   267→      ...defaultState(),\n   268→      toJSON() { throw new Error('Serialization error'); },\n   269→    } as unknown as SprintState;\n   270→    const result = writeStateAtomic(poison);\n   271→    expect(result.success).toBe(false);\n   272→    if (!result.success) {\n   273→      expect(result.error).toContain('Failed to write sprint state');\n   274→    }\n   275→  });\n   276→\n   277→  it('computeSprintCounts counts all status types', async () => {\n   278→    const { computeSprintCounts } = await import('../state.js');\n   279→    const mk = (s: string) => ({ status: s as 'done', attempts: 0, lastAttempt: null, lastError: null, proofPath: null, acResults: null });\n   280→    const counts = computeSprintCounts({ a: mk('done'), b: mk('failed'), c: mk('blocked'), d: mk('in-progress'), e: mk('backlog') });\n   281→    expect(counts).toEqual({ total: 5, done: 1, failed: 1, blocked: 1, inProgress: 'd' });\n   282→  });\n   283→});\n   284→\n   285→describe('concurrent writes', () => {\n   286→  beforeEach(cleanup);\n   287→  afterEach(cleanup);\n   288→\n   289→  it('both writes produce valid JSON', () => {\n   290→    updateStoryStatus('concurrent-1', 'in-progress');\n   291→    updateStoryStatus('concurrent-2', 'done');\n   292→\n   293→    const raw = readFileSync(STATE_FILE, 'utf-8');\n   294→    expect(() => JSON.parse(raw)).not.toThrow();\n   295→\n   296→    const state = JSON.parse(raw) as SprintState;\n   297→    expect(state.stories['concurrent-1']).toBeDefined();\n   298→    expect(state.stories['concurrent-2']).toBeDefined();\n   299→    expect(state.stories['concurrent-2'].status).toBe('done');\n   300→  });\n   301→});\n   302→"}]},"parent_tool_use_id":"toolu_01CfvkxunN8dwVBkgTqCVyZN","session_id":"0e449f80-823c-4489-a784-b43b6c7039d6","uuid":"ece3041f-775c-46a1-b4e0-420ee65f9505","timestamp":"2026-03-24T10:39:39.647Z"}
