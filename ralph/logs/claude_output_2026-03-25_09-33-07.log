{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AoqsNwwrVKqhoBMkeacpxU","type":"tool_result","content":"     1→/**\n     2→ * README.md template for project documentation.\n     3→ * Uses static template from templates/docs/readme.md.tmpl with {{VAR}} interpolation.\n     4→ *\n     5→ * Generated by `codeharness init` when README.md does not exist.\n     6→ * Never overwrites an existing README.md.\n     7→ */\n     8→\n     9→import { renderTemplateFile } from '../lib/templates.js';\n    10→\n    11→export interface ReadmeTemplateConfig {\n    12→  /** Project name (from package.json name or directory basename) */\n    13→  projectName: string;\n    14→  /** Detected stack: 'nodejs', 'python', 'rust', array of stacks, or null */\n    15→  stack: string | string[] | null;\n    16→  /** Output of `codeharness --help` for CLI reference section */\n    17→  cliHelpOutput: string;\n    18→}\n    19→\n    20→/**\n    21→ * Generates README.md content from the template config.\n    22→ */\n    23→export function readmeTemplate(config: ReadmeTemplateConfig): string {\n    24→  const { projectName, stack, cliHelpOutput } = config;\n    25→\n    26→  const installCommand = getInstallCommand(stack);\n    27→\n    28→  return renderTemplateFile('templates/docs/readme.md.tmpl', {\n    29→    PROJECT_NAME: projectName,\n    30→    INSTALL_COMMAND: installCommand,\n    31→    CLI_HELP_OUTPUT: cliHelpOutput.trimEnd(),\n    32→  });\n    33→}\n    34→\n    35→export function getInstallCommand(stack: string | string[] | null): string {\n    36→  if (Array.isArray(stack)) {\n    37→    const commands = stack.map(s => getSingleInstallCommand(s));\n    38→    // Deduplicate in case multiple stacks share an install command\n    39→    return [...new Set(commands)].join('\\n');\n    40→  }\n    41→  return getSingleInstallCommand(stack);\n    42→}\n    43→\n    44→/** Per-stack install commands, keyed by stack name. */\n    45→const INSTALL_COMMANDS: Record<string, string> = {\n    46→  python: 'pip install codeharness',\n    47→  rust: 'cargo install codeharness',\n    48→};\n    49→\n    50→function getSingleInstallCommand(stack: string | null): string {\n    51→  if (stack && INSTALL_COMMANDS[stack]) return INSTALL_COMMANDS[stack];\n    52→  return 'npm install -g codeharness';\n    53→}\n    54→"}]},"parent_tool_use_id":"toolu_018nSD1tnZnk1PBoiosdiN8k","session_id":"f5f7e8e8-6408-46c1-8863-2380ea5a7335","uuid":"ec276e37-19bc-4e65-ba58-69110bec18da","timestamp":"2026-03-25T05:38:47.087Z"}
