ue, '.claude': true, '.flagged_stories': false });\n   432→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   433→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   434→\n   435→      const p = runCommand();\n   436→      await vi.waitFor(() => expect(spawnMock).toHaveBeenCalled());\n   437→      getChildOnHandlers()['close'](0);\n   438→      await p;\n   439→\n   440→      const promptPath = join(tmpDir, 'ralph', '.harness-prompt.md');\n   441→      expect(realExistsSync(promptPath)).toBe(true);\n   442→      expect(origReadFileSync(promptPath, 'utf-8')).toBe('mock prompt content');\n   443→    });\n   444→\n   445→    it('prints starting message with story counts', async () => {\n   446→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   447→      mockPaths({ 'ralph.sh': true, '.claude': true, '.flagged_stories': false });\n   448→      readSprintStatusMock.mockReturnValue({\n   449→        '1-1-a': 'backlog', '1-2-b': 'done', '1-3-c': 'in-progress',\n   450→      });\n   451→      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n   452→\n   453→      const p = runCommand();\n   454→      await vi.waitFor(() => expect(spawnMock).toHaveBeenCalled());\n   455→      getChildOnHandlers()['close'](0);\n   456→      await p;\n   457→\n   458→      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('1 ready'));\n   459→      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('1/3 done'));\n   460→    });\n   461→  });\n   462→\n   463→  describe('run command registration', () => {\n   464→    it('registers the run command with correct options', async () => {\n   465→      const { registerRunCommand } = await import('../run.js');\n   466→      const program = new Command();\n   467→      program.option('--json', 'JSON output');\n   468→      registerRunCommand(program);\n   469→\n   470→      const runCmd = program.commands.find(c => c.name() === 'run');\n   471→      expec