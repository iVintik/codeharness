{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01C1s3KFAkmhdtUHgMYjvfeg","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach, afterEach } from 'vitest';\n2\timport { mkdtempSync, rmSync, writeFileSync, readFileSync, mkdirSync } from 'node:fs';\n3\timport { tmpdir, homedir } from 'node:os';\n4\timport os from 'node:os';\n5\timport { join } from 'node:path';\n6\timport {\n7\t  parseWorkflow,\n8\t  resolveWorkflow,\n9\t  loadWorkflowPatch,\n10\t  mergeWorkflowPatch,\n11\t  WorkflowParseError,\n12\t  type ResolvedWorkflow,\n13\t  type ResolvedTask,\n14\t  type LoopBlock,\n15\t  type FlowStep,\n16\t  type WorkflowPatch,\n17\t} from '../workflow-parser.js';\n18\t\n19\tlet testDir: string;\n20\t\n21\tbeforeEach(() => {\n22\t  testDir = mkdtempSync(join(tmpdir(), 'ch-wfparser-test-'));\n23\t});\n24\t\n25\tafterEach(() => {\n26\t  rmSync(testDir, { recursive: true, force: true });\n27\t});\n28\t\n29\tfunction writeYaml(filename: string, content: string): string {\n30\t  const filePath = join(testDir, filename);\n31\t  writeFileSync(filePath, content, 'utf-8');\n32\t  return filePath;\n33\t}\n34\t\n35\t// --- Helpers: YAML content ---\n36\t\n37\tconst minimalYaml = `\n38\ttasks:\n39\t  implement:\n40\t    agent: dev\n41\tflow:\n42\t  - implement\n43\t`;\n44\t\n45\tconst fullYaml = `\n46\ttasks:\n47\t  implement:\n48\t    agent: dev\n49\t    scope: per-story\n50\t    session: fresh\n51\t    source_access: true\n52\t    prompt_template: \"Implement story {{story_key}}\"\n53\t    input_contract:\n54\t      type: object\n55\t    output_contract:\n56\t      type: object\n57\t    max_budget_usd: 5.0\n58\t  verify:\n59\t    agent: evaluator\n60\t    scope: per-run\n61\t    session: continue\n62\t    source_access: false\n63\tflow:\n64\t  - implement\n65\t  - verify\n66\t`;\n67\t\n68\tconst loopYaml = `\n69\ttasks:\n70\t  implement:\n71\t    agent: dev\n72\t  verify:\n73\t    agent: evaluator\n74\t  retry:\n75\t    agent: dev\n76\tflow:\n77\t  - implement\n78\t  - verify\n79\t  - loop:\n80\t      - retry\n81\t      - verify\n82\t`;\n83\t\n84\tconst emptyYaml = `\n85\ttasks: {}\n86\tflow: []\n87\t`;\n88\t\n89\t// --- Tests ---\n90\t\n91\tdescribe('parseWorkflow', () => {\n92\t  describe('valid workflows (AC #1)', () => {\n93\t    it('parses a minimal valid workflow and returns ResolvedWorkflow', () => {\n94\t      const filePath = writeYaml('minimal.yaml', minimalYaml);\n95\t      const result = parseWorkflow(filePath);\n96\t\n97\t      expect(result.tasks).toBeDefined();\n98\t      expect(result.flow).toBeDefined();\n99\t      expect(result.tasks.implement).toBeDefined();\n100\t      expect(result.tasks.implement.agent).toBe('dev');"}]},"parent_tool_use_id":"toolu_01K9WPLAQDFLLNWtkamPogoK","session_id":"4b1f7711-6ed7-4488-a0af-b261e761b450","uuid":"863e1cba-e89c-4aa1-aea8-40e0c8f5a606","timestamp":"2026-04-03T08:30:17.943Z"}
