{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014ddjK1DnKK2vWQT7DM5S7r","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { join, resolve, dirname } from 'node:path';\n3\timport { fileURLToPath } from 'node:url';\n4\timport os from 'node:os';\n5\timport { parse } from 'yaml';\n6\timport { validateWorkflowSchema } from './schema-validate.js';\n7\t\n8\tconst __filename = fileURLToPath(import.meta.url);\n9\tconst __dirname = dirname(__filename);\n10\t\n11\tconst TEMPLATES_DIR = resolve(__dirname, '../../templates/workflows');\n12\t\n13\t// --- Interfaces ---\n14\t\n15\texport interface ResolvedTask {\n16\t  agent: string;\n17\t  scope: 'per-story' | 'per-run';\n18\t  session: 'fresh' | 'continue';\n19\t  source_access: boolean;\n20\t  prompt_template?: string;\n21\t  input_contract?: Record<string, unknown>;\n22\t  output_contract?: Record<string, unknown>;\n23\t  max_budget_usd?: number;\n24\t}\n25\t\n26\texport interface LoopBlock {\n27\t  loop: string[];\n28\t}\n29\t\n30\texport type FlowStep = string | LoopBlock;\n31\t\n32\texport interface ResolvedWorkflow {\n33\t  tasks: Record<string, ResolvedTask>;\n34\t  flow: FlowStep[];\n35\t}\n36\t\n37\t// --- Error Class ---\n38\t\n39\texport class WorkflowParseError extends Error {\n40\t  public readonly errors: Array<{ path: string; message: string }>;\n41\t\n42\t  constructor(message: string, errors?: Array<{ path: string; message: string }>) {\n43\t    super(message);\n44\t    this.name = 'WorkflowParseError';\n45\t    this.errors = errors ?? [];\n46\t  }\n47\t}\n48\t\n49\t// --- Shared Validation & Resolution ---\n50\t\n51\t/**\n52\t * Validate parsed YAML against JSON schema, check referential integrity,\n53\t * apply defaults, and return a typed ResolvedWorkflow.\n54\t * Shared between parseWorkflow (direct file) and resolveWorkflow (patch chain).\n55\t */\n56\tfunction validateAndResolve(parsed: unknown): ResolvedWorkflow {\n57\t  // Validate against JSON schema\n58\t  const result = validateWorkflowSchema(parsed);\n59\t  if (!result.valid) {\n60\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n61\t    throw new WorkflowParseError(\n62\t      `Schema validation failed: ${details}`,\n63\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n64\t    );\n65\t  }\n66\t\n67\t  // At this point, parsed has passed schema validation — safe to cast\n68\t  const data = parsed as { tasks: Record<string, Record<string, unknown>>; flow: unknown[] };\n69\t\n70\t  // Referential integrity check\n71\t  const taskNames = new Set(Object.keys(data.tasks));\n72\t  const danglingRefs: Array<{ path: string; message: string }> = [];\n73\t\n74\t  for (let i = 0; i < data.flow.length; i++) {\n75\t    const step = data.flow[i];\n76\t    if (typeof step === 'string') {\n77\t      if (!taskNames.has(step)) {\n78\t        danglingRefs.push({\n79\t          path: `/flow/${i}`,\n80\t          message: `Task \"${step}\" referenced in flow but not defined in tasks`,\n81\t        });\n82\t      }\n83\t    } else if (typeof step === 'object' && step !== null && 'loop' in step) {\n84\t      const loopBlock = step as { loop: string[] };\n85\t      for (let j = 0; j < loopBlock.loop.length; j++) {\n86\t        const ref = loopBlock.loop[j];\n87\t        if (!taskNames.has(ref)) {\n88\t          danglingRefs.push({\n89\t            path: `/flow/${i}/loop/${j}`,\n90\t            message: `Task \"${ref}\" referenced in loop but not defined in tasks`,\n91\t          });\n92\t        }\n93\t      }\n94\t    }\n95\t  }\n96\t\n97\t  if (danglingRefs.length > 0) {\n98\t    const details = danglingRefs.map((e) => e.message).join('; ');\n99\t    throw new WorkflowParseError(`Dangling task references: ${details}`, danglingRefs);\n100\t  }\n101\t\n102\t  // Apply defaults and build resolved tasks\n103\t  const resolvedTasks: Record<string, ResolvedTask> = {};\n104\t  for (const [taskName, task] of Object.entries(data.tasks)) {\n105\t    const resolved: ResolvedTask = {\n106\t      agent: task.agent as string,\n107\t      scope: (task.scope as ResolvedTask['scope']) ?? 'per-story',\n108\t      session: (task.session as ResolvedTask['session']) ?? 'fresh',\n109\t      source_access: (task.source_access as boolean) ?? true,\n110\t    };\n111\t    if (task.prompt_template !== undefined) {\n112\t      resolved.prompt_template = task.prompt_template as string;\n113\t    }\n114\t    if (task.input_contract !== undefined) {\n115\t      resolved.input_contract = task.input_contract as Record<string, unknown>;\n116\t    }\n117\t    if (task.output_contract !== undefined) {\n118\t      resolved.output_contract = task.output_contract as Record<string, unknown>;\n119\t    }\n120\t    if (task.max_budget_usd !== undefined) {\n121\t      resolved.max_budget_usd = task.max_budget_usd as number;\n122\t    }\n123\t    resolvedTasks[taskName] = resolved;\n124\t  }\n125\t\n126\t  // Build resolved flow\n127\t  const resolvedFlow: FlowStep[] = data.flow.map((step) => {\n128\t    if (typeof step === 'string') {\n129\t      return step;\n130\t    }\n131\t    return step as LoopBlock;\n132\t  });\n133\t\n134\t  return { tasks: resolvedTasks, flow: resolvedFlow };\n135\t}\n136\t\n137\t// --- Parser ---\n138\t\n139\t/**\n140\t * Parse a workflow YAML file from disk, validate it against the JSON schema,\n141\t * check referential integrity, apply defaults, and return a typed ResolvedWorkflow.\n142\t */\n143\texport function parseWorkflow(filePath: string): ResolvedWorkflow {\n144\t  // 1. Read file\n145\t  let raw: string;\n146\t  try {\n147\t    raw = readFileSync(filePath, 'utf-8');\n148\t  } catch (err: unknown) {\n149\t    const code = err instanceof Error && 'code' in err ? (err as NodeJS.ErrnoException).code : undefined;\n150\t    const detail = code === 'ENOENT'\n151\t      ? 'File not found'\n152\t      : code === 'EACCES'\n153\t        ? 'Permission denied'\n154\t        : code === 'EISDIR'\n155\t          ? 'Path is a directory'\n156\t          : 'File not found or unreadable';\n157\t    throw new WorkflowParseError(`${detail}: ${filePath}`, [\n158\t      { path: filePath, message: detail },\n159\t    ]);\n160\t  }\n161\t\n162\t  // 2. Parse YAML\n163\t  let parsed: unknown;\n164\t  try {\n165\t    parsed = parse(raw);\n166\t  } catch (err: unknown) {\n167\t    const yamlMsg = err instanceof Error ? err.message : String(err);\n168\t    throw new WorkflowParseError(`Invalid YAML syntax: ${yamlMsg}`, [\n169\t      { path: filePath, message: yamlMsg },\n170\t    ]);\n171\t  }\n172\t\n173\t  return validateAndResolve(parsed);\n174\t}\n175\t\n176\t// --- Patch Interfaces ---\n177\t\n178\t/**\n179\t * Patch file structure for workflow customization.\n180\t * `extends` identifies the base, `overrides` are deep-merged, `replace` sections wholly overwrite.\n181\t */\n182\texport interface WorkflowPatch {\n183\t  extends?: string;\n184\t  overrides?: Record<string, unknown>;\n185\t  replace?: Record<string, unknown>;\n186\t}\n187\t\n188\t// --- Deep Merge ---\n189\t\n190\t/**\n191\t * Deep merge strategy: objects merge recursively, arrays replace, scalars replace.\n192\t * Same semantics as agent-resolver deepMerge.\n193\t */\n194\tfunction deepMerge(base: Record<string, unknown>, patch: Record<string, unknown>): Record<string, unknown> {\n195\t  const result: Record<string, unknown> = { ...base };\n196\t\n197\t  for (const key of Object.keys(patch)) {\n198\t    const baseVal = base[key];\n199\t    const patchVal = patch[key];\n200\t\n201\t    if (\n202\t      patchVal !== null &&\n203\t      typeof patchVal === 'object' &&\n204\t      !Array.isArray(patchVal) &&\n205\t      baseVal !== null &&\n206\t      typeof baseVal === 'object' &&\n207\t      !Array.isArray(baseVal)\n208\t    ) {\n209\t      result[key] = deepMerge(\n210\t        baseVal as Record<string, unknown>,\n211\t        patchVal as Record<string, unknown>,\n212\t      );\n213\t    } else {\n214\t      result[key] = patchVal;\n215\t    }\n216\t  }\n217\t\n218\t  return result;\n219\t}\n220\t\n221\t// --- Patch Loading ---\n222\t\n223\t/**\n224\t * Load a workflow patch file. Returns null if the file does not exist (silent skip).\n225\t * Throws WorkflowParseError on malformed YAML.\n226\t */\n227\texport function loadWorkflowPatch(filePath: string): WorkflowPatch | null {\n228\t  if (!existsSync(filePath)) {\n229\t    return null;\n230\t  }\n231\t\n232\t  let raw: string;\n233\t  try {\n234\t    raw = readFileSync(filePath, 'utf-8');\n235\t  } catch (err: unknown) {\n236\t    const code = err instanceof Error && 'code' in err ? (err as NodeJS.ErrnoException).code : undefined;\n237\t    if (code === 'ENOENT') {\n238\t      return null; // File disappeared between existsSync and readFileSync — treat as missing\n239\t    }\n240\t    const detail = code === 'EACCES' ? 'Permission denied' : 'File unreadable';\n241\t    throw new WorkflowParseError(`${detail}: ${filePath}`, [\n242\t      { path: filePath, message: detail },\n243\t    ]);\n244\t  }\n245\t\n246\t  let parsed: unknown;\n247\t  try {\n248\t    parsed = parse(raw);\n249\t  } catch (err: unknown) {\n250\t    const msg = err instanceof Error ? err.message : String(err);\n251\t    throw new WorkflowParseError(`Invalid YAML in patch file ${filePath}: ${msg}`, [\n252\t      { path: filePath, message: msg },\n253\t    ]);\n254\t  }\n255\t\n256\t  if (parsed === null || typeof parsed !== 'object') {\n257\t    throw new WorkflowParseError(`Patch file is not a valid object: ${filePath}`, [\n258\t      { path: filePath, message: 'Patch must be a YAML object' },\n259\t    ]);\n260\t  }\n261\t\n262\t  return parsed as WorkflowPatch;\n263\t}\n264\t\n265\t// --- Patch Merging ---\n266\t\n267\t/**\n268\t * Merge a workflow patch onto a base config.\n269\t * Deep-merges `overrides`, then applies `replace` sections as full overwrites.\n270\t */\n271\texport function mergeWorkflowPatch(\n272\t  base: Record<string, unknown>,\n273\t  patch: WorkflowPatch,\n274\t): Record<string, unknown> {\n275\t  let result = { ...base };\n276\t\n277\t  // Deep-merge overrides\n278\t  if (patch.overrides) {\n279\t    result = deepMerge(result, patch.overrides);\n280\t  }\n281\t\n282\t  // Full replacement for replace sections\n283\t  if (patch.replace) {\n284\t    for (const key of Object.keys(patch.replace)) {\n285\t      result[key] = patch.replace[key];\n286\t    }\n287\t  }\n288\t\n289\t  return result;\n290\t}\n291\t\n292\t// --- Main Resolution ---\n293\t\n294\t/**\n295\t * Resolve a workflow through the embedded -> user -> project patch chain.\n296\t *\n297\t * 1. Load embedded workflow from templates/workflows/{name}.yaml\n298\t * 2. Apply user-level patch from ~/.codeharness/workflows/{name}.patch.yaml (if exists)\n299\t * 3. Apply project-level patch from .codeharness/workflows/{name}.patch.yaml (if exists)\n300\t * 4. Validate merged result against JSON schema + referential integrity\n301\t * 5. Apply defaults and return ResolvedWorkflow\n302\t *\n303\t * If a full custom workflow (no patch, no extends) exists at project level, it is loaded directly.\n304\t */\n305\texport function resolveWorkflow(options?: { cwd?: string; name?: string }): ResolvedWorkflow {\n306\t  const cwd = options?.cwd ?? process.cwd();\n307\t  const name = options?.name ?? 'default';\n308\t\n309\t  const userPatchPath = join(os.homedir(), '.codeharness', 'workflows', `${name}.patch.yaml`);\n310\t  const projectPatchPath = join(cwd, '.codeharness', 'workflows', `${name}.patch.yaml`);\n311\t\n312\t  // Check for full custom workflow at project level (not a patch — no extends)\n313\t  const projectCustomPath = join(cwd, '.codeharness', 'workflows', `${name}.yaml`);\n314\t  if (existsSync(projectCustomPath)) {\n315\t    const customPatch = loadWorkflowPatch(projectCustomPath);\n316\t    if (customPatch && !customPatch.extends) {\n317\t      // This is a full custom workflow, not a patch — parse directly\n318\t      return parseWorkflow(projectCustomPath);\n319\t    }\n320\t  }\n321\t\n322\t  // Load embedded base\n323\t  const embeddedPath = join(TEMPLATES_DIR, `${name}.yaml`);\n324\t  let raw: string;\n325\t  try {\n326\t    raw = readFileSync(embeddedPath, 'utf-8');\n327\t  } catch (err: unknown) {\n328\t    const detail = err instanceof Error ? err.message : `File not found: ${embeddedPath}`;\n329\t    throw new WorkflowParseError(`Embedded workflow not found: ${name}`, [\n330\t      { path: embeddedPath, message: detail },\n331\t    ]);\n332\t  }\n333\t\n334\t  let baseData: unknown;\n335\t  try {\n336\t    baseData = parse(raw);\n337\t  } catch (err: unknown) {\n338\t    const msg = err instanceof Error ? err.message : String(err);\n339\t    throw new WorkflowParseError(`Invalid YAML in embedded workflow ${name}: ${msg}`, [\n340\t      { path: embeddedPath, message: msg },\n341\t    ]);\n342\t  }\n343\t\n344\t  let merged = baseData as Record<string, unknown>;\n345\t\n346\t  // Apply user-level patch\n347\t  const userPatch = loadWorkflowPatch(userPatchPath);\n348\t  if (userPatch) {\n349\t    merged = mergeWorkflowPatch(merged, userPatch);\n350\t  }\n351\t\n352\t  // Apply project-level patch\n353\t  const projectPatch = loadWorkflowPatch(projectPatchPath);\n354\t  if (projectPatch) {\n355\t    merged = mergeWorkflowPatch(merged, projectPatch);\n356\t  }\n357\t\n358\t  // Validate, check referential integrity, apply defaults, and return\n359\t  return validateAndResolve(merged);\n360\t}\n361\t"}]},"parent_tool_use_id":"toolu_01Rc1jZLz1bpJyVVhPKGgdgx","session_id":"c2800ecc-75a3-43b2-b3d8-396855aa3c3c","uuid":"9b2b8088-86bd-4d48-99a4-7c548c27f58d","timestamp":"2026-04-03T03:10:44.865Z"}
