{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01X5As4ZxTK7fLSNtXoEGkxo","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01FL3PWnKKRarB6kSj1n5BNQ","name":"Write","input":{"file_path":"/Users/ivintik/dev/personal/codeharness/src/modules/audit/dimensions.ts","content":"/**\n * Audit dimension checkers — each wraps an existing module and maps\n * its output to DimensionResult. Each checker catches its own errors\n * and never throws (AC #6).\n *\n * Dimensions: observability, testing, documentation, verification, infrastructure.\n */\n\nimport { existsSync, readFileSync } from 'node:fs';\nimport { join } from 'node:path';\nimport { ok, fail, isOk } from '../../types/result.js';\nimport type { Result } from '../../types/result.js';\nimport type { DimensionResult, AuditGap } from './types.js';\nimport { analyze, validateRuntime } from '../observability/index.js';\nimport type { AnalyzerResult, RuntimeValidationResult } from '../observability/index.js';\nimport { checkOnlyCoverage } from '../../lib/coverage.js';\nimport { scanDocHealth } from '../../lib/doc-health.js';\nimport { parseProof } from '../verify/index.js';\n\n// ─── Observability Dimension (Task 2.1) ─────────────────────────────────────\n\nexport async function checkObservability(projectDir: string): Promise<Result<DimensionResult>> {\n  try {\n    const gaps: AuditGap[] = [];\n\n    // Static analysis via Semgrep\n    let staticStatus: 'pass' | 'fail' | 'warn' = 'pass';\n    let staticMetric = '';\n    const staticResult = analyze(projectDir);\n\n    if (isOk(staticResult)) {\n      const data: AnalyzerResult = staticResult.data;\n      if (data.skipped) {\n        staticStatus = 'warn';\n        staticMetric = `static: skipped (${data.skipReason ?? 'unknown'})`;\n        gaps.push({\n          dimension: 'observability',\n          description: `Static analysis skipped: ${data.skipReason ?? 'Semgrep not installed'}`,\n          suggestedFix: 'Install Semgrep: pip install semgrep',\n        });\n      } else {\n        const gapCount = data.gaps.length;\n        staticMetric = `static: ${gapCount} gap${gapCount !== 1 ? 's' : ''}`;\n        if (gapCount > 0) {\n          staticStatus = 'warn';\n          for (const gap of data.gaps) {\n            gaps.push({\n              dimension: 'observability',\n              description: `${gap.file}:${gap.line} — ${gap.message}`,\n              suggestedFix: gap.fix ?? 'Add observability instrumentation',\n            });\n          }\n        }\n      }\n    } else {\n      staticStatus = 'warn';\n      staticMetric = 'static: skipped (analysis failed)';\n      gaps.push({\n        dimension: 'observability',\n        description: `Static analysis failed: ${staticResult.error}`,\n        suggestedFix: 'Check Semgrep installation and rules configuration',\n      });\n    }\n\n    // Runtime validation\n    let runtimeStatus: 'pass' | 'fail' | 'warn' = 'pass';\n    let runtimeMetric = '';\n    try {\n      const runtimeResult = await validateRuntime(projectDir);\n\n      if (isOk(runtimeResult)) {\n        const data: RuntimeValidationResult = runtimeResult.data;\n        if (data.skipped) {\n          runtimeStatus = 'warn';\n          runtimeMetric = `runtime: skipped (${data.skipReason ?? 'unknown'})`;\n          gaps.push({\n            dimension: 'observability',\n            description: `Runtime validation skipped: ${data.skipReason ?? 'backend unreachable'}`,\n            suggestedFix: 'Start the observability stack: codeharness stack up',\n          });\n        } else {\n          runtimeMetric = `runtime: ${data.coveragePercent}%`;\n          if (data.coveragePercent < 50) {\n            runtimeStatus = 'warn';\n            gaps.push({\n              dimension: 'observability',\n              description: `Runtime coverage low: ${data.coveragePercent}%`,\n              suggestedFix: 'Add telemetry instrumentation to more modules',\n            });\n          }\n        }\n      } else {\n        runtimeStatus = 'warn';\n        runtimeMetric = 'runtime: skipped (validation failed)';\n        gaps.push({\n          dimension: 'observability',\n          description: `Runtime validation failed: ${runtimeResult.error}`,\n          suggestedFix: 'Ensure observability backend is running',\n        });\n      }\n    } catch {\n      runtimeStatus = 'warn';\n      runtimeMetric = 'runtime: skipped (error)';\n      gaps.push({\n        dimension: 'observability',\n        description: 'Runtime validation threw an unexpected error',\n        suggestedFix: 'Check observability stack health',\n      });\n    }\n\n    // Combine statuses: worst of static and runtime\n    const status = combineStatuses(staticStatus, runtimeStatus);\n    const metric = `${staticMetric}, ${runtimeMetric}`;\n\n    return ok({ name: 'observability', status, metric, gaps });\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    return ok({\n      name: 'observability',\n      status: 'warn',\n      metric: 'skipped (error)',\n      gaps: [{\n        dimension: 'observability',\n        description: `Observability check failed: ${message}`,\n        suggestedFix: 'Check Semgrep and observability stack configuration',\n      }],\n    });\n  }\n}\n\n// ─── Testing Dimension (Task 2.2) ───────────────────────────────────────────\n\nexport function checkTesting(projectDir: string): Result<DimensionResult> {\n  try {\n    const result = checkOnlyCoverage(projectDir);\n    const gaps: AuditGap[] = [];\n\n    if (!result.success) {\n      return ok({\n        name: 'testing',\n        status: 'warn',\n        metric: 'no coverage data',\n        gaps: [{\n          dimension: 'testing',\n          description: 'No coverage tool detected or coverage data unavailable',\n          suggestedFix: 'Run tests with coverage: npm run test:coverage',\n        }],\n      });\n    }\n\n    const pct = result.coveragePercent;\n    let status: 'pass' | 'fail' | 'warn' = 'pass';\n\n    if (pct < 50) {\n      status = 'fail';\n      gaps.push({\n        dimension: 'testing',\n        description: `Test coverage critically low: ${pct}%`,\n        suggestedFix: 'Add unit tests to increase coverage above 50%',\n      });\n    } else if (pct < 80) {\n      status = 'warn';\n      gaps.push({\n        dimension: 'testing',\n        description: `Test coverage below target: ${pct}%`,\n        suggestedFix: 'Add tests to reach 80% coverage target',\n      });\n    }\n\n    return ok({ name: 'testing', status, metric: `${pct}%`, gaps });\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    return ok({\n      name: 'testing',\n      status: 'warn',\n      metric: 'error',\n      gaps: [{\n        dimension: 'testing',\n        description: `Testing check failed: ${message}`,\n        suggestedFix: 'Ensure test runner is configured',\n      }],\n    });\n  }\n}\n\n// ─── Documentation Dimension (Task 2.3) ─────────────────────────────────────\n\nexport function checkDocumentation(projectDir: string): Result<DimensionResult> {\n  try {\n    const report = scanDocHealth(projectDir);\n    const gaps: AuditGap[] = [];\n\n    const { fresh, stale, missing } = report.summary;\n    let status: 'pass' | 'fail' | 'warn' = 'pass';\n\n    if (missing > 0) {\n      status = 'fail';\n      for (const doc of report.documents) {\n        if (doc.grade === 'missing') {\n          gaps.push({\n            dimension: 'documentation',\n            description: `Missing: ${doc.path} — ${doc.reason}`,\n            suggestedFix: `Create ${doc.path}`,\n          });\n        }\n      }\n    }\n\n    if (stale > 0) {\n      if (status !== 'fail') status = 'warn';\n      for (const doc of report.documents) {\n        if (doc.grade === 'stale') {\n          gaps.push({\n            dimension: 'documentation',\n            description: `Stale: ${doc.path} — ${doc.reason}`,\n            suggestedFix: `Update ${doc.path} to reflect current code`,\n          });\n        }\n      }\n    }\n\n    const metric = `${fresh} fresh, ${stale} stale, ${missing} missing`;\n    return ok({ name: 'documentation', status, metric, gaps });\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    return ok({\n      name: 'documentation',\n      status: 'warn',\n      metric: 'error',\n      gaps: [{\n        dimension: 'documentation',\n        description: `Documentation check failed: ${message}`,\n        suggestedFix: 'Run codeharness doc-health for details',\n      }],\n    });\n  }\n}\n\n// ─── Verification Dimension (Task 2.4) ──────────────────────────────────────\n\nexport function checkVerification(projectDir: string): Result<DimensionResult> {\n  try {\n    const gaps: AuditGap[] = [];\n\n    // Try reading sprint-state.json for verification status\n    const sprintStatePath = join(projectDir, '_bmad-output', 'implementation-artifacts', 'sprint-status.yaml');\n    if (!existsSync(sprintStatePath)) {\n      return ok({\n        name: 'verification',\n        status: 'warn',\n        metric: 'no sprint data',\n        gaps: [{\n          dimension: 'verification',\n          description: 'No sprint-status.yaml found',\n          suggestedFix: 'Run sprint planning to create sprint status',\n        }],\n      });\n    }\n\n    // Check for proof documents in verification/ or docs/exec-plans/\n    const verificationDir = join(projectDir, 'verification');\n    const proofDir = join(projectDir, 'docs', 'exec-plans', 'active');\n    let proofCount = 0;\n    let totalChecked = 0;\n\n    // Scan proof documents\n    if (existsSync(verificationDir)) {\n      const files = readdirSafe(verificationDir);\n      for (const file of files) {\n        if (file.endsWith('-proof.md')) {\n          totalChecked++;\n          const proofPath = join(verificationDir, file);\n          const result = parseProof(proofPath);\n          if (isOk(result) && result.data.passed) {\n            proofCount++;\n          } else {\n            const storyKey = file.replace('-proof.md', '');\n            gaps.push({\n              dimension: 'verification',\n              description: `Story ${storyKey} proof incomplete or failing`,\n              suggestedFix: `Run codeharness verify ${storyKey}`,\n            });\n          }\n        }\n      }\n    }\n\n    let status: 'pass' | 'fail' | 'warn' = 'pass';\n    if (totalChecked === 0) {\n      status = 'warn';\n      gaps.push({\n        dimension: 'verification',\n        description: 'No verification proofs found',\n        suggestedFix: 'Run codeharness verify for completed stories',\n      });\n    } else if (proofCount < totalChecked) {\n      status = 'warn';\n    }\n\n    const metric = totalChecked > 0\n      ? `${proofCount}/${totalChecked} verified`\n      : 'no proofs';\n\n    return ok({ name: 'verification', status, metric, gaps });\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    return ok({\n      name: 'verification',\n      status: 'warn',\n      metric: 'error',\n      gaps: [{\n        dimension: 'verification',\n        description: `Verification check failed: ${message}`,\n        suggestedFix: 'Check verification configuration',\n      }],\n    });\n  }\n}\n\n// ─── Infrastructure Dimension (Task 2.5) ────────────────────────────────────\n\nexport function checkInfrastructure(projectDir: string): Result<DimensionResult> {\n  try {\n    const gaps: AuditGap[] = [];\n    const dockerfilePath = join(projectDir, 'Dockerfile');\n\n    if (!existsSync(dockerfilePath)) {\n      return ok({\n        name: 'infrastructure',\n        status: 'fail',\n        metric: 'no Dockerfile',\n        gaps: [{\n          dimension: 'infrastructure',\n          description: 'No Dockerfile found',\n          suggestedFix: 'Create a Dockerfile for containerized deployment',\n        }],\n      });\n    }\n\n    // Basic structural validation — check for pinned base image\n    let content: string;\n    try {\n      content = readFileSync(dockerfilePath, 'utf-8');\n    } catch {\n      return ok({\n        name: 'infrastructure',\n        status: 'warn',\n        metric: 'Dockerfile unreadable',\n        gaps: [{\n          dimension: 'infrastructure',\n          description: 'Dockerfile exists but could not be read',\n          suggestedFix: 'Check Dockerfile permissions',\n        }],\n      });\n    }\n\n    const fromLines = content\n      .split('\\n')\n      .filter(line => /^\\s*FROM\\s+/i.test(line));\n\n    if (fromLines.length === 0) {\n      gaps.push({\n        dimension: 'infrastructure',\n        description: 'Dockerfile has no FROM instruction',\n        suggestedFix: 'Add a FROM instruction with a pinned base image',\n      });\n      return ok({ name: 'infrastructure', status: 'fail', metric: 'invalid Dockerfile', gaps });\n    }\n\n    let hasUnpinned = false;\n    for (const line of fromLines) {\n      // Check for :latest or no tag at all (just image name)\n      const imageRef = line.replace(/^\\s*FROM\\s+/i, '').split(/\\s+/)[0];\n      if (imageRef.endsWith(':latest')) {\n        hasUnpinned = true;\n        gaps.push({\n          dimension: 'infrastructure',\n          description: `Unpinned base image: ${imageRef}`,\n          suggestedFix: `Pin ${imageRef} to a specific version tag`,\n        });\n      } else if (!imageRef.includes(':') && !imageRef.includes('@')) {\n        hasUnpinned = true;\n        gaps.push({\n          dimension: 'infrastructure',\n          description: `Unpinned base image (no tag): ${imageRef}`,\n          suggestedFix: `Pin ${imageRef} to a specific version tag (e.g., ${imageRef}:22-slim)`,\n        });\n      }\n    }\n\n    const status: 'pass' | 'fail' | 'warn' = hasUnpinned ? 'warn' : 'pass';\n    const metric = hasUnpinned\n      ? `Dockerfile exists (${gaps.length} issue${gaps.length !== 1 ? 's' : ''})`\n      : 'Dockerfile valid';\n\n    return ok({ name: 'infrastructure', status, metric, gaps });\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    return ok({\n      name: 'infrastructure',\n      status: 'warn',\n      metric: 'error',\n      gaps: [{\n        dimension: 'infrastructure',\n        description: `Infrastructure check failed: ${message}`,\n        suggestedFix: 'Check Dockerfile and project structure',\n      }],\n    });\n  }\n}\n\n// ─── Helpers ────────────────────────────────────────────────────────────────\n\nfunction combineStatuses(\n  ...statuses: Array<'pass' | 'fail' | 'warn'>\n): 'pass' | 'fail' | 'warn' {\n  if (statuses.includes('fail')) return 'fail';\n  if (statuses.includes('warn')) return 'warn';\n  return 'pass';\n}\n\nfunction readdirSafe(dir: string): string[] {\n  try {\n    const { readdirSync } = require('node:fs');\n    return readdirSync(dir) as string[];\n  } catch {\n    return [];\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":658,"cache_read_input_tokens":66687,"cache_creation":{"ephemeral_5m_input_tokens":658,"ephemeral_1h_input_tokens":0},"output_tokens":6,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01AdMUjsSRd2zQjpuDrBr3HX","session_id":"e1f3df9b-d919-466e-880e-1001c8652ee8","uuid":"8eb5bcdf-443d-4b47-a0f5-f527b9592a3c"}
