enCalledWith(expect.stringContaining('Runtime'));\n   322→    expect(fail).toHaveBeenCalledWith(expect.stringContaining('50%'));\n   323→  });\n   324→});\n   325→\n   326→// ============================================================\n   327→// Input validation\n   328→// ============================================================\n   329→\n   330→describe('observability-gate input validation', () => {\n   331→  it('rejects non-numeric --min-static', async () => {\n   332→    await runGateCmd(['--min-static', 'abc']);\n   333→\n   334→    expect(fail).toHaveBeenCalledWith(expect.stringContaining('--min-static must be a number'));\n   335→    expect(process.exitCode).toBe(1);\n   336→    expect(checkObservabilityCoverageGate).not.toHaveBeenCalled();\n   337→  });\n   338→\n   339→  it('rejects --min-static > 100', async () => {\n   340→    await runGateCmd(['--min-static', '150']);\n   341→\n   342→    expect(fail).toHaveBeenCalledWith(expect.stringContaining('--min-static must be a number'));\n   343→    expect(process.exitCode).toBe(1);\n   344→  });\n   345→\n   346→  it('rejects negative --min-static', async () => {\n   347→    await runGateCmd(['--min-static', '-5']);\n   348→\n   349→    expect(fail).toHaveBeenCalledWith(expect.stringContaining('--min-static must be a number'));\n   350→    expect(process.exitCode).toBe(1);\n   351→  });\n   352→\n   353→  it('rejects non-numeric --min-runtime', async () => {\n   354→    await runGateCmd(['--min-runtime', 'xyz']);\n   355→\n   356→    expect(fail).toHaveBeenCalledWith(expect.stringContaining('--min-runtime must be a number'));\n   357→    expect(process.exitCode).toBe(1);\n   358→    expect(checkObservabilityCoverageGate).not.toHaveBeenCalled();\n   359→  });\n   360→\n   361→  it('rejects invalid --min-static with --json flag', async () => {\n   362→    await runGateCmd(['--json', '--min-static', 'abc']);\n   363→\n   364→    expect(jsonOutput).toHaveBeenCalledWith(\n   365→      expect.objectContaining({ s