ess();\n   364→\n   365→    expect(result.success).toBe(false);\n   366→    if (!result.success) {\n   367→      expect(result.error).toContain('Failed to read sprint state');\n   368→    }\n   369→  });\n   370→});\n   371→\n   372→describe('atomic write guarantee for concurrent readers', () => {\n   373→  it('state is complete JSON immediately after write', () => {\n   374→    writeStateAtomic(defaultState());\n   375→\n   376→    updateRunProgress({\n   377→      currentStory: '1-2-user-auth',\n   378→      currentPhase: 'verify',\n   379→      lastAction: 'Running AC checks',\n   380→      acProgress: '3/7',\n   381→    });\n   382→\n   383→    // Simulate external reader\n   384→    const raw = readFileSync(stateFile(), 'utf-8');\n   385→    const parsed = JSON.parse(raw) as SprintState;\n   386→\n   387→    expect(parsed.version).toBe(2);\n   388→    expect(parsed.run.currentStory).toBe('1-2-user-auth');\n   389→    expect(parsed.run.currentPhase).toBe('verify');\n   390→    expect(parsed.run.lastAction).toBe('Running AC checks');\n   391→    expect(parsed.run.acProgress).toBe('3/7');\n   392→  });\n   393→\n   394→  it('rapid sequential updates produce valid JSON each time', () => {\n   395→    writeStateAtomic(defaultState());\n   396→\n   397→    for (let i = 1; i <= 10; i++) {\n   398→      updateRunProgress({ acProgress: `${i}/10` });\n   399→\n   400→      const raw = readFileSync(stateFile(), 'utf-8');\n   401→      expect(() => JSON.parse(raw)).not.toThrow();\n   402→\n   403→      const parsed = JSON.parse(raw) as SprintState;\n   404→      expect(parsed.run.acProgress).toBe(`${i}/10`);\n   405→    }\n   406→  });\n   407→});\n   408→\n   409→describe('backward compatibility', () => {\n   410→  it('getSprintState fills missing progress fields with null defaults on old state files', () => {\n   411→    // Simulate an old state file without the new progress fields\n   412→    const oldState = {\n   413→      version: 1,\n   414→      sprint: { total: 1, done: 0, failed: 0, blocked: 0, inProgress: null },\n   415→      stories: {},\n   416→      run: {\n   417→        active: false,\n   418→        startedAt: null,\n   419→        iteration: 0,\n   420→        cost: 0,\n   421→        completed: [],\n   422→        failed: [],\n   423→        // No currentStory, currentPhase, lastAction, acProgress\n   424→      },\n   425→      actionItems: [],\n   426→    };\n   427→    writeFileSync(\n   428→      join(process.cwd(), 'sprint-state.json'),\n   429→      JSON.stringify(oldState, null, 2),\n   430→      'utf-8',\n   431→    );\n   432→\n   433→    const result = getSprintState();\n   434→    expect(result.success).toBe(true);\n   435→    if (result.success) {\n   436→      expect(result.data.run.currentStory).toBeNull();\n   437→      expect(result.data.run.currentPhase).toBeNull();\n   438→      expect(result.data.run.lastAction).toBeNull();\n   439→      expect(result.data.run.acProgress).toBeNull();\n   440→    }\n   441→  });\n   442→});\n   443→"}]},"parent_tool_use_id":"toolu_01S1Fmwybv95nEtmZySwttre","session_id":"bd5543f6-f408-4218-88bd-6e3bcdc37563","uuid":"94f6a48f-c420-41e9-b096-3a2b952f8224","timestamp":"2026-03-24T11:13:27.561Z"}
