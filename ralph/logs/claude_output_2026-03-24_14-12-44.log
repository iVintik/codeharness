{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PYWWJDdbL8FPGvFDEivrux","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';\n     2→import {\n     3→  readFileSync,\n     4→  writeFileSync,\n     5→  unlinkSync,\n     6→  existsSync,\n     7→  chmodSync,\n     8→} from 'node:fs';\n     9→import { join } from 'node:path';\n    10→import type { SprintState } from '../../../types/state.js';\n    11→\n    12→// Mock migration so state tests are isolated from real project files\n    13→vi.mock('../migration.js', () => ({\n    14→  migrateFromOldFormat: vi.fn(() => ({\n    15→    success: false,\n    16→    error: 'No old format files found for migration',\n    17→  })),\n    18→}));\n    19→\n    20→// Import after mock setup\n    21→const { getSprintState, updateStoryStatus, writeStateAtomic, defaultState, statePath } =\n    22→  await import('../state.js');\n    23→\n    24→const STATE_FILE = join(process.cwd(), 'sprint-state.json');\n    25→const TMP_FILE = join(process.cwd(), '.sprint-state.json.tmp');\n    26→\n    27→function cleanup(): void {\n    28→  for (const f of [STATE_FILE, TMP_FILE]) {\n    29→    try {\n    30→      chmodSync(f, 0o644);\n    31→    } catch {\n    32→      // ignore — file may not exist\n    33→    }\n    34→    try {\n    35→      unlinkSync(f);\n    36→    } catch {\n    37→      // ignore — file may not exist\n    38→    }\n    39→  }\n    40→}\n    41→\n    42→describe('defaultState', () => {\n    43→  it('returns version 1 with empty stories', () => {\n    44→    const state = defaultState();\n    45→    expect(state.version).toBe(1);\n    46→    expect(state.stories).toEqual({});\n    47→    expect(state.run.active).toBe(false);\n    48→    expect(state.run.iteration).toBe(0);\n    49→    expect(state.sprint.total).toBe(0);\n    50→    expect(state.actionItems).toEqual([]);\n    51→  });\n    52→});\n    53→\n    54→describe('statePath', () => {\n    55→  it('returns path ending in sprint-state.json', () => {\n    56→    expect(statePath()).toBe(STATE_FILE);\n    57→  });\n    58→});\n    59→\n    60→describe('writeStateAtomic', () => {\n    61→  beforeEach(cleanup);\n    62→  afterEach(cleanup);\n    63→\n    64→  it('writes valid JSON to sprint-state.json', () => {\n    65→    const state = defaultState();\n    66→    const result = writeStateAtomic(state);\n    67→    expect(result.success).toBe(true);\n    68→    expect(existsSync(STATE_FILE)).toBe(true);\n    69→\n    70→    const raw = readFileSync(STATE_FILE, 'utf-8');\n    71→    const parsed = JSON.parse(raw);\n    72→    expect(parsed.version).toBe(1);\n    73→  });\n    74→\n    75→  it('tmp file does not remain after successful write', () => {\n    76→    const result = writeStateAtomic(defaultState());\n    77→    expect(result.success).toBe(true);\n    78→    expect(existsSync(TMP_FILE)).toBe(false);\n    79→  });\n    80→});\n    81→\n    82→describe('getSprintState', () => {\n    83→  beforeEach(cleanup);\n    84→  afterEach(cleanup);\n    85→\n    86→  it('returns default state when no file exists', () => {\n    87→    const result = getSprintState();\n    88→    expect(result.success).toBe(true);\n    89→    if (result.success) {\n    90→      expect(result.data.version).toBe(1);\n    91→      expect(result.data.stories).toEqual({});\n    92→      expect(result.data.run.active).toBe(false);\n    93→      expect(result.data.sprint.inProgress).toBeNull();\n    94→      expect(result.data.actionItems).toEqual([]);\n    95→    }\n    96→  });\n    97→\n    98→  it('reads and parses existing sprint-state.json', () => {\n    99→    const state: SprintState = {\n   100→      ...defaultState(),\n   101→      stories: {\n   102→        'test-story': {\n   103→          status: 'done',\n   104→          attempts: 2,\n   105→          lastAttempt: '2026-01-01T00:00:00Z',\n   106→          lastError: null,\n   107→          proofPath: null,\n   108→          acResults: null,\n   109→        },\n   110→      },\n   111→    };\n   112→    writeFileSync(STATE_FILE, JSON.stringify(state, null, 2), 'utf-8');\n   113→\n   114→    const result = getSprintState();\n   115→    expect(result.success).toBe(true);\n   116→    if (result.success) {\n   117→      expect(result.data.stories['test-story'].status).toBe('done');\n   118→      expect(result.data.stories['test-story'].attempts).toBe(2);\n   119→    }\n   120→  });\n   121→\n   122→  it('returns fail on invalid JSON', () => {\n   123→    writeFileSync(STATE_FILE, '{not valid json', 'utf-8');\n   124→    const result = getSprintState();\n   125→    expect(result.success).toBe(false);\n   126→    if (!result.success) {\n   127→      expect(result.error).toContain('Failed to read sprint state');\n   128→    }\n   129→  });\n   130→\n   131→  it('parse time is under 100ms for 50 stories', () => {\n   132→    const stories: Record<string, SprintState['stories'][string]> = {};\n   133→    for (let i = 0; i < 50; i++) {\n   134→      stories[`story-${i}`] = {\n   135→        status: 'backlog',\n   136→        attempts: i,\n   137→        lastAttempt: new Date().toISOString(),\n   138→        lastError: `error ${i}`,\n   139→        proofPath: null,\n   140→        acResults: [\n   141→          { id: `ac-${i}-1`, verdict: 'pass' },\n   142→          { id: `ac-${i}-2`, verdict: 'fail' },\n   143→        ],\n   144→      };\n   145→    }\n   146→    const state: SprintState = { ...defaultState(), stories };\n   147→    writeFileSync(STATE_FILE, JSON.stringify(state, null, 2), 'utf-8');\n   148→\n   149→    const start = performance.now();\n   150→    const result = getSprintState();\n   151→    const elapsed = performance.now() - start;\n   152→\n   153→    expect(result.success).toBe(true);\n   154→    expect(elapsed).toBeLessThan(100);\n   155→  });\n   156→\n   157→  it('never throws — returns fail on fs error', () => {\n   158→    writeFileSync(STATE_FILE, '{}', 'utf-8');\n   159→    chmodSync(STATE_FILE, 0o000);\n   160→\n   161→    const result = getSprintState();\n   162→    expect(result).toBeDefined();\n   163→    expect(typeof result.success).toBe('boolean');\n   164→  });\n   165→});\n   166→\n   167→describe('updateStoryStatus', () => {\n   168→  beforeEach(cleanup);\n   169→  afterEach(cleanup);\n   170→\n   171→  it('creates file if missing and updates story', () => {\n   172→    const result = updateStoryStatus('story-1', 'in-progress');\n   173→    expect(result.success).toBe(true);\n   174→    expect(existsSync(STATE_FILE)).toBe(true);\n   175→\n   176→    const state = JSON.parse(readFileSync(STATE_FILE, 'utf-8')) as SprintState;\n   177→    expect(state.stories['story-1'].status).toBe('in-progress');\n   178→    expect(state.stories['story-1'].attempts).toBe(1);\n   179→    expect(state.sprint.inProgress).toBe('story-1');\n   180→  });\n   181→\n   182→  it('updates existing story preserving other stories', () => {\n   183→    updateStoryStatus('story-1', 'in-progress');\n   184→    updateStoryStatus('story-2', 'done');\n   185→\n   186→    const state = JSON.parse(readFileSync(STATE_FILE, 'utf-8')) as SprintState;\n   187→    expect(state.stories['story-1']).toBeDefined();\n   188→    expect(state.stories['story-2'].status).toBe('done');\n   189→    expect(state.sprint.done).toBe(1);\n   190→    expect(state.sprint.total).toBe(2);\n   191→  });\n   192→\n   193→  it('attaches error detail when provided', () => {\n   194→    updateStoryStatus('story-1', 'failed', { error: 'build broke' });\n   195→\n   196→    const state = JSON.parse(readFileSync(STATE_FILE, 'utf-8')) as SprintState;\n   197→    expect(state.stories['story-1'].lastError).toBe('build broke');\n   198→    expect(state.stories['story-1'].status).toBe('failed');\n   199→    expect(state.sprint.failed).toBe(1);\n   200→  });\n   201→\n   202→  it('attaches proofPath when provided', () => {\n   203→    updateStoryStatus('story-1', 'done', {\n   204→      proofPath: 'docs/proof.md',\n   205→    });\n   206→\n   207→    const state = JSON.parse(readFileSync(STATE_FILE, 'utf-8')) as SprintState;\n   208→    expect(state.stories['story-1'].proofPath).toBe('docs/proof.md');\n   209→  });\n   210→\n   211→  it('increments attempts only on in-progress transition', () => {\n   212→    updateStoryStatus('story-1', 'in-progress');\n   213→    updateStoryStatus('story-1', 'failed', { error: 'oops' });\n   214→    updateStoryStatus('story-1', 'in-progress');\n   215→\n   216→    const state = JSON.parse(readFileSync(STATE_FILE, 'utf-8')) as SprintState;\n   217→    expect(state.stories['story-1'].attempts).toBe(2);\n   218→  });\n   219→\n   220→  it('uses atomic write (tmp then rename)', () => {\n   221→    updateStoryStatus('story-1', 'done');\n   222→    expect(existsSync(TMP_FILE)).toBe(false);\n   223→    expect(existsSync(STATE_FILE)).toBe(true);\n   224→  });\n   225→\n   226→  it('round-trips state correctly (write then read)', () => {\n   227→    updateStoryStatus('roundtrip', 'verifying');\n   228→\n   229→    const result = getSprintState();\n   230→    expect(result.success).toBe(true);\n   231→    if (result.success) {\n   232→      expect(result.data.stories['roundtrip'].status).toBe('verifying');\n   233→    }\n   234→  });\n   235→});\n   236→\n   237→describe('lastAttempt semantics and error paths', () => {\n   238→  beforeEach(cleanup);\n   239→  afterEach(cleanup);\n   240→\n   241→  it('sets lastAttempt only on in-progress transitions', () => {\n   242→    updateStoryStatus('story-1', 'in-progress');\n   243→    const state1 = JSON.parse(readFileSync(STATE_FILE, 'utf-8')) as SprintState;\n   244→    const firstAttemptTime = state1.stories['story-1'].lastAttempt;\n   245→    expect(firstAttemptTime).not.toBeNull();\n   246→    updateStoryStatus('story-1', 'done');\n   247→    const state2 = JSON.parse(readFileSync(STATE_FILE, 'utf-8')) as SprintState;\n   248→    expect(state2.stories['story-1'].lastAttempt).toBe(firstAttemptTime);\n   249→  });\n   250→\n   251→  it('writeStateAtomic returns fail on serialization error', () => {\n   252→    const poison = {\n   253→      ...defaultState(),\n   254→      toJSON() { throw new Error('Serialization error'); },\n   255→    } as unknown as SprintState;\n   256→    const result = writeStateAtomic(poison);\n   257→    expect(result.success).toBe(false);\n   258→    if (!result.success) {\n   259→      expect(result.error).toContain('Failed to write sprint state');\n   260→    }\n   261→  });\n   262→\n   263→  it('computeSprintCounts counts all status types', async () => {\n   264→    const { computeSprintCounts } = await import('../state.js');\n   265→    const mk = (s: string) => ({ status: s as 'done', attempts: 0, lastAttempt: null, lastError: null, proofPath: null, acResults: null });\n   266→    const counts = computeSprintCounts({ a: mk('done'), b: mk('failed'), c: mk('blocked'), d: mk('in-progress'), e: mk('backlog') });\n   267→    expect(counts).toEqual({ total: 5, done: 1, failed: 1, blocked: 1, inProgress: 'd' });\n   268→  });\n   269→});\n   270→\n   271→describe('concurrent writes', () => {\n   272→  beforeEach(cleanup);\n   273→  afterEach(cleanup);\n   274→\n   275→  it('both writes produce valid JSON', () => {\n   276→    updateStoryStatus('concurrent-1', 'in-progress');\n   277→    updateStoryStatus('concurrent-2', 'done');\n   278→\n   279→    const raw = readFileSync(STATE_FILE, 'utf-8');\n   280→    expect(() => JSON.parse(raw)).not.toThrow();\n   281→\n   282→    const state = JSON.parse(raw) as SprintState;\n   283→    expect(state.stories['concurrent-1']).toBeDefined();\n   284→    expect(state.stories['concurrent-2']).toBeDefined();\n   285→    expect(state.stories['concurrent-2'].status).toBe('done');\n   286→  });\n   287→});\n   288→"}]},"parent_tool_use_id":"toolu_01EPL4eJAP5W5qUxFXY5uuFc","session_id":"6707468c-554d-4568-9ea5-0d04d4a85f59","uuid":"0f7de2c5-7229-41ac-8eaf-0f103052f5ea","timestamp":