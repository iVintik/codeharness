{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0129LzFsYFvZQgHqL99i9jja","type":"tool_result","content":"     1→/**\n     2→ * Audit dimension checkers — each wraps an existing module and maps\n     3→ * its output to DimensionResult. Each checker catches its own errors\n     4→ * and never throws (AC #6).\n     5→ */\n     6→\n     7→import { existsSync, readFileSync, readdirSync } from 'node:fs';\n     8→import { join } from 'node:path';\n     9→import { ok, isOk } from '../../types/result.js';\n    10→import type { Result } from '../../types/result.js';\n    11→import type { DimensionResult, AuditGap } from './types.js';\n    12→import { analyze, validateRuntime } from '../observability/index.js';\n    13→import type { AnalyzerResult, RuntimeValidationResult } from '../observability/index.js';\n    14→import { checkOnlyCoverage } from '../../lib/coverage.js';\n    15→import { scanDocHealth } from '../../lib/doc-health.js';\n    16→import { parseProof } from '../verify/index.js';\n    17→\n    18→type Status = 'pass' | 'fail' | 'warn';\n    19→\n    20→function gap(dimension: string, description: string, suggestedFix: string): AuditGap {\n    21→  return { dimension, description, suggestedFix };\n    22→}\n    23→\n    24→function dimOk(name: string, status: Status, metric: string, gaps: AuditGap[] = []): Result<DimensionResult> {\n    25→  return ok({ name, status, metric, gaps });\n    26→}\n    27→\n    28→function dimCatch(name: string, err: unknown): Result<DimensionResult> {\n    29→  const msg = err instanceof Error ? err.message : String(err);\n    30→  return dimOk(name, 'warn', 'error', [gap(name, `${name} check failed: ${msg}`, `Check ${name} configuration`)]);\n    31→}\n    32→\n    33→function worstStatus(...statuses: Status[]): Status {\n    34→  if (statuses.includes('fail')) return 'fail';\n    35→  if (statuses.includes('warn')) return 'warn';\n    36→  return 'pass';\n    37→}\n    38→\n    39→// ─── Observability (Task 2.1) ───────────────────────────────────────────────\n    40→\n    41→export async function checkObservability(projectDir: string): Promise<Result<DimensionResult>> {\n    42→  try {\n    43→    const gaps: AuditGap[] = [];\n    44→    let sStatus: Status = 'pass', sMetric = '';\n    45→    const sr = analyze(projectDir);\n    46→\n    47→    if (isOk(sr)) {\n    48→      const d: AnalyzerResult = sr.data;\n    49→      if (d.skipped) {\n    50→        sStatus = 'warn';\n    51→        sMetric = `static: skipped (${d.skipReason ?? 'unknown'})`;\n    52→        gaps.push(gap('observability', `Static analysis skipped: ${d.skipReason ?? 'Semgrep not installed'}`, 'Install Semgrep: pip install semgrep'));\n    53→      } else {\n    54→        const n = d.gaps.length;\n    55→        sMetric = `static: ${n} gap${n !== 1 ? 's' : ''}`;\n    56→        if (n > 0) {\n    57→          sStatus = 'warn';\n    58→          for (const g of d.gaps) gaps.push(gap('observability', `${g.file}:${g.line} — ${g.message}`, g.fix ?? 'Add observability instrumentation'));\n    59→        }\n    60→      }\n    61→    } else {\n    62→      sStatus = 'warn';\n    63→      sMetric = 'static: skipped (analysis failed)';\n    64→      gaps.push(gap('observability', `Static analysis failed: ${sr.error}`, 'Check Semgrep installation and rules configuration'));\n    65→    }\n    66→\n    67→    let rStatus: Status = 'pass', rMetric = '';\n    68→    try {\n    69→      const rr = await validateRuntime(projectDir);\n    70→      if (isOk(rr)) {\n    71→        const d: RuntimeValidationResult = rr.data;\n    72→        if (d.skipped) {\n    73→          rStatus = 'warn';\n    74→          rMetric = `runtime: skipped (${d.skipReason ?? 'unknown'})`;\n    75→          gaps.push(gap('observability', `Runtime validation skipped: ${d.skipReason ?? 'backend unreachable'}`, 'Start the observability stack: codeharness stack up'));\n    76→        } else {\n    77→          rMetric = `runtime: ${d.coveragePercent}%`;\n    78→          if (d.coveragePercent < 50) {\n    79→            rStatus = 'warn';\n    80→            gaps.push(gap('observability', `Runtime coverage low: ${d.coveragePercent}%`, 'Add telemetry instrumentation to more modules'));\n    81→          }\n    82→        }\n    83→      } else {\n    84→        rStatus = 'warn';\n    85→        rMetric = 'runtime: skipped (validation failed)';\n    86→        gaps.push(gap('observability', `Runtime validation failed: ${rr.error}`, 'Ensure observability backend is running'));\n    87→      }\n    88→    } catch {\n    89→      rStatus = 'warn';\n    90→      rMetric = 'runtime: skipped (error)';\n    91→      gaps.push(gap('observability', 'Runtime validation threw an unexpected error', 'Check observability stack health'));\n    92→    }\n    93→\n    94→    return dimOk('observability', worstStatus(sStatus, rStatus), `${sMetric}, ${rMetric}`, gaps);\n    95→  } catch (err: unknown) { return dimCatch('observability', err); }\n    96→}\n    97→\n    98→// ─── Testing (Task 2.2) ────────────────────────────────────────────────────\n    99→\n   100→export function checkTesting(projectDir: string): Result<DimensionResult> {\n   101→  try {\n   102→    const r = checkOnlyCoverage(projectDir);\n   103→    if (!r.success) return dimOk('testing', 'warn', 'no coverage data', [gap('testing', 'No coverage tool detected or coverage data unavailable', 'Run tests with coverage: npm run test:coverage')]);\n   104→\n   105→    const pct = r.coveragePercent;\n   106→    const gaps: AuditGap[] = [];\n   107→    let status: Status = 'pass';\n   108→    if (pct < 50) { status = 'fail'; gaps.push(gap('testing', `Test coverage critically low: ${pct}%`, 'Add unit tests to increase coverage above 50%')); }\n   109→    else if (pct < 80) { status = 'warn'; gaps.push(gap('testing', `Test coverage below target: ${pct}%`, 'Add tests to reach 80% coverage target')); }\n   110→    return dimOk('testing', status, `${pct}%`, gaps);\n   111→  } catch (err: unknown) { return dimCatch('testing', err); }\n   112→}\n   113→\n   114→// ─── Documentation (Task 2.3) ──────────────────────────────────────────────\n   115→\n   116→export function checkDocumentation(projectDir: string): Result<DimensionResult> {\n   117→  try {\n   118→    const report = scanDocHealth(projectDir);\n   119→    const gaps: AuditGap[] = [];\n   120→    const { fresh, stale, missing } = report.summary;\n   121→    let status: Status = 'pass';\n   122→\n   123→    if (missing > 0) {\n   124→      status = 'fail';\n   125→      for (const doc of report.documents) if (doc.grade === 'missing') gaps.push(gap('documentation', `Missing: ${doc.path} — ${doc.reason}`, `Create ${doc.path}`));\n   126→    }\n   127→    if (stale > 0) {\n   128→      if (status !== 'fail') status = 'warn';\n   129→      for (const doc of report.documents) if (doc.grade === 'stale') gaps.push(gap('documentation', `Stale: ${doc.path} — ${doc.reason}`, `Update ${doc.path} to reflect current code`));\n   130→    }\n   131→    return dimOk('documentation', status, `${fresh} fresh, ${stale} stale, ${missing} missing`, gaps);\n   132→  } catch (err: unknown) { return dimCatch('documentation', err); }\n   133→}\n   134→\n   135→// ─── Verification (Task 2.4) ───────────────────────────────────────────────\n   136→\n   137→export function checkVerification(projectDir: string): Result<DimensionResult> {\n   138→  try {\n   139→    const gaps: AuditGap[] = [];\n   140→    const sprintPath = join(projectDir, '_bmad-output', 'implementation-artifacts', 'sprint-status.yaml');\n   141→    if (!existsSync(sprintPath)) return dimOk('verification', 'warn', 'no sprint data', [gap('verification', 'No sprint-status.yaml found', 'Run sprint planning to create sprint status')]);\n   142→\n   143→    const vDir = join(projectDir, 'verification');\n   144→    let proofCount = 0, totalChecked = 0;\n   145→\n   146→    if (existsSync(vDir)) {\n   147→      for (const file of readdirSafe(vDir)) {\n   148→        if (!file.endsWith('-proof.md')) continue;\n   149→        totalChecked++;\n   150→        const r = parseProof(join(vDir, file));\n   151→        if (isOk(r) && r.data.passed) { proofCount++; }\n   152→        else { gaps.push(gap('verification', `Story ${file.replace('-proof.md', '')} proof incomplete or failing`, `Run codeharness verify ${file.replace('-proof.md', '')}`)); }\n   153→      }\n   154→    }\n   155→\n   156→    let status: Status = 'pass';\n   157→    if (totalChecked === 0) { status = 'warn'; gaps.push(gap('verification', 'No verification proofs found', 'Run codeharness verify for completed stories')); }\n   158→    else if (proofCount < totalChecked) { status = 'warn'; }\n   159→\n   160→    return dimOk('verification', status, totalChecked > 0 ? `${proofCount}/${totalChecked} verified` : 'no proofs', gaps);\n   161→  } catch (err: unknown) { return dimCatch('verification', err); }\n   162→}\n   163→\n   164→// ─── Infrastructure (Task 2.5) ─────────────────────────────────────────────\n   165→\n   166→export function checkInfrastructure(projectDir: string): Result<DimensionResult> {\n   167→  try {\n   168→    const dfPath = join(projectDir, 'Dockerfile');\n   169→    if (!existsSync(dfPath)) return dimOk('infrastructure', 'fail', 'no Dockerfile', [gap('infrastructure', 'No Dockerfile found', 'Create a Dockerfile for containerized deployment')]);\n   170→\n   171→    let content: string;\n   172→    try { content = readFileSync(dfPath, 'utf-8'); }\n   173→    catch { return dimOk('infrastructure', 'warn', 'Dockerfile unreadable', [gap('infrastructure', 'Dockerfile exists but could not be read', 'Check Dockerfile permissions')]); }\n   174→\n   175→    const fromLines = content.split('\\n').filter(l => /^\\s*FROM\\s+/i.test(l));\n   176→    if (fromLines.length === 0) return dimOk('infrastructure', 'fail', 'invalid Dockerfile', [gap('infrastructure', 'Dockerfile has no FROM instruction', 'Add a FROM instruction with a pinned base image')]);\n   177→\n   178→    const gaps: AuditGap[] = [];\n   179→    let hasUnpinned = false;\n   180→    for (const line of fromLines) {\n   181→      const ref = line.replace(/^\\s*FROM\\s+/i, '').split(/\\s+/)[0];\n   182→      if (ref.endsWith(':latest')) { hasUnpinned = true; gaps.push(gap('infrastructure', `Unpinned base image: ${ref}`, `Pin ${ref} to a specific version tag`)); }\n   183→      else if (!ref.includes(':') && !ref.includes('@')) { hasUnpinned = true; gaps.push(gap('infrastructure', `Unpinned base image (no tag): ${ref}`, `Pin ${ref} to a specific version tag (e.g., ${ref}:22-slim)`)); }\n   184→    }\n   185→\n   186→    const status: Status = hasUnpinned ? 'warn' : 'pass';\n   187→    const metric = hasUnpinned ? `Dockerfile exists (${gaps.length} issue${gaps.length !== 1 ? 's' : ''})` : 'Dockerfile valid';\n   188→    return dimOk('infrastructure', status, metric, gaps);\n   189→  } catch (err: unknown) { return dimCatch('infrastructure', err); }\n   190→}\n   191→\n   192→// ─── Helpers ────────────────────────────────────────────────────────────────\n   193→\n   194→function readdirSafe(dir: string): string[] {\n   195→  try { return readdirSync(dir) as string[]; }\n   196→  catch { return []; }\n   197→}\n   198→"}]},"parent_tool_use_id":"toolu_01Em2XRw3Hi7aBBMc3mqbUYk","session_id":"d06dabce-ed3c-4abf-ad84-f2845532d39a","uuid":"460a2525-b11a-4f37-99be-5d0963bfcdda","timestamp":"2026-03-21T05:14:44.910Z"}
