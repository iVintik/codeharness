{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TQNrPYeLaBj5AVkCp2y4k3","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n     2→import { mkdtempSync, rmSync, readFileSync, writeFileSync, existsSync, unlinkSync } from 'node:fs';\n     3→import { tmpdir } from 'node:os';\n     4→import { join } from 'node:path';\n     5→import {\n     6→  readRetries,\n     7→  writeRetries,\n     8→  getRetryCount,\n     9→  setRetryCount,\n    10→  resetRetry,\n    11→  readFlaggedStories,\n    12→  writeFlaggedStories,\n    13→  removeFlaggedStory,\n    14→  retriesPath,\n    15→  flaggedPath,\n    16→} from '../retry-state.js';\n    17→\n    18→// retry-state now reads from sprint-state.json via getSprintState() / writeStateAtomic()\n    19→// which use process.cwd() to find the file. We chdir to a temp dir for isolation.\n    20→\n    21→let testDir: string;\n    22→let originalCwd: string;\n    23→let stateFile: string;\n    24→\n    25→function makeStateJson(overrides?: { retries?: Record<string, number>; flagged?: string[] }): string {\n    26→  return JSON.stringify({\n    27→    version: 2,\n    28→    sprint: { total: 0, done: 0, failed: 0, blocked: 0, inProgress: null },\n    29→    stories: {},\n    30→    retries: overrides?.retries ?? {},\n    31→    flagged: overrides?.flagged ?? [],\n    32→    epics: {},\n    33→    session: { active: false, startedAt: null, iteration: 0, elapsedSeconds: 0 },\n    34→    observability: { statementCoverage: null, branchCoverage: null, functionCoverage: null, lineCoverage: null },\n    35→    run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n    36→    actionItems: [],\n    37→  }, null, 2) + '\\n';\n    38→}\n    39→\n    40→function readState(): { retries: Record<string, number>; flagged: string[] } {\n    41→  const raw = readFileSync(stateFile, 'utf-8');\n    42→  const parsed = JSON.parse(raw);\n    43→  return { retries: parsed.retries, flagged: parsed.flagged };\n    44→}\n    45→\n    46→beforeEach(() => {\n    47→  testDir = mkdtempSync(join(tmpdir(), 'ch-retry-test-'));\n    48→  stateFile = join(testDir, 'sprint-state.json');\n    49→  originalCwd = process.cwd();\n    50→  process.chdir(testDir);\n    51→});\n    52→\n    53→afterEach(() => {\n    54→  process.chdir(originalCwd);\n    55→  rmSync(testDir, { recursive: true, force: true });\n    56→  vi.restoreAllMocks();\n    57→});\n    58→\n    59→// ─── readRetries ──────────────────────────────────────────────────────────────\n    60→\n    61→describe('readRetries', () => {\n    62→  it('returns empty map when sprint-state.json does not exist', () => {\n    63→    const result = readRetries(testDir);\n    64→    expect(result.size).toBe(0);\n    65→  });\n    66→\n    67→  it('reads retries from sprint-state.json', () => {\n    68→    writeFileSync(stateFile, makeStateJson({\n    69→      retries: { '2-1-dependency-auto-install': 4, '0-1-sprint-execution-skill': 3 },\n    70→    }));\n    71→    const result = readRetries(testDir);\n    72→    expect(result.get('2-1-dependency-auto-install')).toBe(4);\n    73→    expect(result.get('0-1-sprint-execution-skill')).toBe(3);\n    74→    expect(result.size).toBe(2);\n    75→  });\n    76→\n    77→  it('returns empty map when retries field is empty', () => {\n    78→    writeFileSync(stateFile, makeStateJson({ retries: {} }));\n    79→    const result = readRetries(testDir);\n    80→    expect(result.size).toBe(0);\n    81→  });\n    82→});\n    83→\n    84→// ─── writeRetries ─────────────────────────────────────────────────────────────\n    85→\n    86→describe('writeRetries', () => {\n    87→  it('writes retries to sprint-state.json', () => {\n    88→    writeFileSync(stateFile, makeStateJson());\n    89→    const map = new Map([['story-a', 3], ['story-b', 1]]);\n    90→    writeRetries(testDir, map);\n    91→    const state = readState();\n    92→    expect(state.retries).toEqual({ 'story-a': 3, 'story-b': 1 });\n    93→  });\n    94→\n    95→  it('writes empty retries for empty map', () => {\n    96→    writeFileSync(stateFile, makeStateJson({ retries: { old: 5 } }));\n    97→    writeRetries(testDir, new Map());\n    98→    const state = readState();\n    99→    expect(state.retries).toEqual({});\n   100→  });\n   101→\n   102→  it('overwrites existing retries', () => {\n   103→    writeFileSync(stateFile, makeStateJson({ retries: { 'old-story': 99 } }));\n   104→    writeRetries(testDir, new Map([['new-story', 1]]));\n   105→    const state = readState();\n   106→    expect(state.retries).toEqual({ 'new-story': 1 });\n   107→  });\n   108→});\n   109→\n   110→// ─── getRetryCount ────────────────────────────────────────────────────────────\n   111→\n   112→describe('getRetryCount', () => {\n   113→  it('returns 0 when sprint-state.json does not exist', () => {\n   114→    expect(getRetryCount(testDir, 'nonexistent')).toBe(0);\n   115→  });\n   116→\n   117→  it('returns 0 for unknown story key', () => {\n   118→    writeFileSync(stateFile, makeStateJson({ retries: { 'story-a': 3 } }));\n   119→    expect(getRetryCount(testDir, 'story-b')).toBe(0);\n   120→  });\n   121→\n   122→  it('returns count for known story key', () => {\n   123→    writeFileSync(stateFile, makeStateJson({ retries: { 'story-a': 7 } }));\n   124→    expect(getRetryCount(testDir, 'story-a')).toBe(7);\n   125→  });\n   126→});\n   127→\n   128→// ─── setRetryCount ────────────────────────────────────────────────────────────\n   129→\n   130→describe('setRetryCount', () => {\n   131→  it('creates entry in sprint-state.json', () => {\n   132→    writeFileSync(stateFile, makeStateJson());\n   133→    setRetryCount(testDir, 'story-a', 1);\n   134→    const state = readState();\n   135→    expect(state.retries['story-a']).toBe(1);\n   136→  });\n   137→\n   138→  it('adds entry to existing retries', () => {\n   139→    writeFileSync(stateFile, makeStateJson({ retries: { 'story-a': 2 } }));\n   140→    setRetryCount(testDir, 'story-b', 3);\n   141→    const state = readState();\n   142→    expect(state.retries['story-a']).toBe(2);\n   143→    expect(state.retries['story-b']).toBe(3);\n   144→  });\n   145→\n   146→  it('updates existing entry', () => {\n   147→    writeFileSync(stateFile, makeStateJson({ retries: { 'story-a': 2, 'story-b': 1 } }));\n   148→    setRetryCount(testDir, 'story-a', 5);\n   149→    const state = readState();\n   150→    expect(state.retries['story-a']).toBe(5);\n   151→    expect(state.retries['story-b']).toBe(1);\n   152→  });\n   153→});\n   154→\n   155→// ─── resetRetry ───────────────────────────────────────────────────────────────\n   156→\n   157→describe('resetRetry', () => {\n   158→  it('clears all entries when no storyKey provided', () => {\n   159→    writeFileSync(stateFile, makeStateJson({\n   160→      retries: { 'story-a': 2, 'story-b': 3 },\n   161→      flagged: ['story-a', 'story-b'],\n   162→    }));\n   163→    resetRetry(testDir);\n   164→    const state = readState();\n   165→    expect(state.retries).toEqual({});\n   166→    expect(state.flagged).toEqual([]);\n   167→  });\n   168→\n   169→  it('clears only specified story when storyKey provided', () => {\n   170→    writeFileSync(stateFile, makeStateJson({\n   171→      retries: { 'story-a': 2, 'story-b': 3 },\n   172→      flagged: ['story-a', 'story-b'],\n   173→    }));\n   174→    resetRetry(testDir, 'story-a');\n   175→    const state = readState();\n   176→    expect(state.retries['story-a']).toBeUndefined();\n   177→    expect(state.retries['story-b']).toBe(3);\n   178→    expect(state.flagged).not.toContain('story-a');\n   179→    expect(state.flagged).toContain('story-b');\n   180→  });\n   181→\n   182→  it('is a no-op when clearing a nonexistent story key', () => {\n   183→    writeFileSync(stateFile, makeStateJson({\n   184→      retries: { 'story-a': 2 },\n   185→      flagged: ['story-a'],\n   186→    }));\n   187→    resetRetry(testDir, 'nonexistent');\n   188→    const state = readState();\n   189→    expect(state.retries['story-a']).toBe(2);\n   190→    expect(state.flagged).toContain('story-a');\n   191→  });\n   192→\n   193→  it('works when sprint-state.json does not exist (uses defaults)', () => {\n   194→    // Should not throw — getSprintState returns default\n   195→    resetRetry(testDir);\n   196→    // After reset, a sprint-state.json should be created with empty retries/flagged\n   197→    expect(existsSync(stateFile)).toBe(true);\n   198→    const state = readState();\n   199→    expect(state.retries).toEqual({});\n   200→    expect(state.flagged).toEqual([]);\n   201→  });\n   202→\n   203→  it('works with storyKey when sprint-state.json does not exist', () => {\n   204→    resetRetry(testDir, 'story-a');\n   205→    expect(existsSync(stateFile)).toBe(true);\n   206→    const state = readState();\n   207→    expect(state.retries).toEqual({});\n   208→    expect(state.flagged).toEqual([]);\n   209→  });\n   210→});\n   211→\n   212→// ─── readFlaggedStories ───────────────────────────────────────────────────────\n   213→\n   214→describe('readFlaggedStories', () => {\n   215→  it('returns empty array when sprint-state.json does not exist', () => {\n   216→    expect(readFlaggedStories(testDir)).toEqual([]);\n   217→  });\n   218→\n   219→  it('returns flagged stories from sprint-state.json', () => {\n   220→    writeFileSync(stateFile, makeStateJson({ flagged: ['story-a', 'story-b'] }));\n   221→    expect(readFlaggedStories(testDir)).toEqual(['story-a', 'story-b']);\n   222→  });\n   223→\n   224→  it('returns empty array when flagged field is empty', () => {\n   225→    writeFileSync(stateFile, makeStateJson({ flagged: [] }));\n   226→    expect(readFlaggedStories(testDir)).toEqual([]);\n   227→  });\n   228→});\n   229→\n   230→// ─── writeFlaggedStories ──────────────────────────────────────────────────────\n   231→\n   232→describe('writeFlaggedStories', () => {\n   233→  it('writes flagged stories to sprint-state.json', () => {\n   234→    writeFileSync(stateFile, makeStateJson());\n   235→    writeFlaggedStories(testDir, ['story-a', 'story-b']);\n   236→    const state = readState();\n   237→    expect(state.flagged).toEqual(['story-a', 'story-b']);\n   238→  });\n   239→\n   240→  it('writes empty array for empty input', () => {\n   241→    writeFileSync(stateFile, makeStateJson({ flagged: ['old'] }));\n   242→    writeFlaggedStories(testDir, []);\n   243→    const state = readState();\n   244→    expect(state.flagged).toEqual([]);\n   245→  });\n   246→});\n   247→\n   248→// ─── removeFlaggedStory ───────────────────────────────────────────────────────\n   249→\n   250→describe('removeFlaggedStory', () => {\n   251→  it('removes a single story from flagged list', () => {\n   252→    writeFileSync(stateFile, makeStateJson({ flagged: ['story-a', 'story-b', 'story-c'] }));\n   253→    removeFlaggedStory(testDir, 'story-b');\n   254→    const state = readState();\n   255→    expect(state.flagged).toEqual(['story-a', 'story-c']);\n   256→  });\n   257→\n   258→  it('is a no-op when story is not in list', () => {\n   259→    writeFileSync(stateFile, makeStateJson({ flagged: ['story-a'] }));\n   260→    removeFlaggedStory(testDir, 'nonexistent');\n   261→    const state = readState();\n   262→    expect(state.flagged).toEqual(['story-a']);\n   263→  });\n   264→\n   265→  it('works when sprint-state.json does not exist', () => {\n   266→    removeFlaggedStory(testDir, 'story-a');\n   267→    // Should create sprint-state.json with empty flagged\n   268→    expect(existsSync(stateFile)).toBe(true);\n   269→    const state = readState();\n   270→    expect(state.flagged).toEqual([]);\n   271→  });\n   272→});\n   273→\n   274→// ─── path helpers ─────────────────────────────────────────────────────────────\n   275→\n   276