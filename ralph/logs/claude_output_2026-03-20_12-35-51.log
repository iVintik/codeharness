{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BK3qBxbm827tbQeoq96Vzx","type":"tool_result","content":"     1→import { describe, it, expect, vi } from 'vitest';\n     2→import { createProgram } from '../index.js';\n     3→\n     4→describe('CLI entry point', () => {\n     5→  it('has correct name and description', () => {\n     6→    const program = createProgram();\n     7→    expect(program.name()).toBe('codeharness');\n     8→    expect(program.description()).toContain('autonomous coding agents');\n     9→  });\n    10→\n    11→  it('reports a valid semver version', () => {\n    12→    const program = createProgram();\n    13→    expect(program.version()).toMatch(/^\\d+\\.\\d+\\.\\d+$/);\n    14→  });\n    15→\n    16→  it('has --json global option', () => {\n    17→    const program = createProgram();\n    18→    const jsonOpt = program.options.find(o => o.long === '--json');\n    19→    expect(jsonOpt).toBeDefined();\n    20→  });\n    21→\n    22→  it('registers all 23 commands', () => {\n    23→    const program = createProgram();\n    24→    const commands = program.commands.filter(\n    25→      (c) => c.name() !== 'help'\n    26→    );\n    27→    const names = commands.map(c => c.name()).sort();\n    28→    expect(names).toEqual([\n    29→      'audit', 'bridge', 'coverage', 'doc-health', 'github-import', 'init', 'observability-gate', 'onboard', 'progress', 'query', 'retro-import', 'retry', 'run', 'stack', 'state', 'status', 'sync', 'teardown', 'timeout-report', 'validate', 'validate-state', 'verify', 'verify-env',\n    30→    ]);\n    31→  });\n    32→\n    33→  it('registers stack command with subcommands', () => {\n    34→    const program = createProgram();\n    35→    const stackCmd = program.commands.find(c => c.name() === 'stack');\n    36→    expect(stackCmd).toBeDefined();\n    37→    const subNames = stackCmd!.commands.map(c => c.name()).sort();\n    38→    expect(subNames).toEqual(['start', 'status', 'stop']);\n    39→  });\n    40→\n    41→  it('registers state command with subcommands', () => {\n    42→    const program = createProgram();\n    43→    const stateCmd = program.commands.find(c => c.name() === 'state');\n    44→    expect(stateCmd).toBeDefined();\n    45→    const subNames = stateCmd!.commands.map(c => c.name()).sort();\n    46→    expect(subNames).toEqual(['get', 'reset-session', 'set', 'show']);\n    47→  });\n    48→\n    49→  it('--version outputs version string', async () => {\n    50→    const program = createProgram();\n    51→    program.exitOverride();\n    52→    const writeSpy = vi.spyOn(process.stdout, 'write').mockImplementation(() => true);\n    53→\n    54→    try {\n    55→      await program.parseAsync(['node', 'test', '--version']);\n    56→    } catch {\n    57→      // Commander throws on --version with exitOverride\n    58→    }\n    59→\n    60→    expect(writeSpy).toHaveBeenCalledWith(expect.stringMatching(/\\d+\\.\\d+\\.\\d+/));\n    61→    writeSpy.mockRestore();\n    62→  });\n    63→});\n    64→"}]},"parent_tool_use_id":"toolu_01UmDTVZ4iS72Xuw7ncmN4YZ","session_id":"e1f3df9b-d919-466e-880e-1001c8652ee8","uuid":"2d74dfe6-5d83-4abb-8c75-365230f96bda","timestamp":"2026-03-20T08:52:06.196Z"}
