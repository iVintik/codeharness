  59→  it('maps verifying to in-progress', () => {\n    60→    expect(mapSprintStatus('verifying')).toBe('in-progress');\n    61→  });\n    62→\n    63→  it('maps backlog to pending', () => {\n    64→    expect(mapSprintStatus('backlog')).toBe('pending');\n    65→  });\n    66→\n    67→  it('maps ready-for-dev to pending', () => {\n    68→    expect(mapSprintStatus('ready-for-dev')).toBe('pending');\n    69→  });\n    70→\n    71→  it('maps failed to failed', () => {\n    72→    expect(mapSprintStatus('failed')).toBe('failed');\n    73→  });\n    74→\n    75→  it('maps blocked to blocked', () => {\n    76→    expect(mapSprintStatus('blocked')).toBe('blocked');\n    77→  });\n    78→\n    79→  it('maps exhausted to blocked', () => {\n    80→    expect(mapSprintStatus('exhausted')).toBe('blocked');\n    81→  });\n    82→\n    83→  it('maps unknown statuses to pending', () => {\n    84→    expect(mapSprintStatus('some-unknown')).toBe('pending');\n    85→  });\n    86→});\n    87→\n    88→describe('mapSprintStatuses', () => {\n    89→  it('converts sprint-status entries to StoryStatusEntry[]', () => {\n    90→    const entries = mapSprintStatuses({\n    91→      'epic-1': 'done',\n    92→      '1-1-story-a': 'done',\n    93→      '1-2-story-b': 'in-progress',\n    94→      '1-3-story-c': 'backlog',\n    95→      'epic-1-retrospective': 'optional',\n    96→    });\n    97→    expect(entries).toEqual([\n    98→      { key: '1-1-story-a', status: 'done' },\n    99→      { key: '1-2-story-b', status: 'in-progress' },\n   100→      { key: '1-3-story-c', status: 'pending' },\n   101→    ]);\n   102→  });\n   103→\n   104→  it('filters out epic keys and optional entries', () => {\n   105→    const entries = mapSprintStatuses({\n   106→      'epic-5': 'in-progress',\n   107→      '5-1-foo': 'review',\n   108→      'epic-5-retrospective': 'optional',\n   109→    });\n   110→    expect(entries).toEqual([\n   111→      { key: '5-1-foo', status: 'in-progress' },\n   112→    ]);\n   113→  });\n   114→\n   115→  it('returns empty array for empty input', () => {\n   116→    expect(mapSprintStatuses({})).toEqual([]);\n   117→  });\n   118→\n   119→  it('handles all status types', () => {\n   120→    const entries = mapSprintStatuses({\n   121→      '1-1-a': 'done',\n   122→      '1-2-b': 'failed',\n   123→      '1-3-c': 'blocked',\n   124→      '1-4-d': 'exhausted',\n   125→      '1-5-e': 'verifying',\n   126→    });\n   127→    expect(entries).toEqual([\n   128→      { key: '1-1-a', status: 'done' },\n   129→      { key: '1-2-b', status: 'failed' },\n   130→      { key: '1-3-c', status: 'blocked' },\n   131→      { key: '1-4-d', status: 'blocked' },\n   132→      { key: '1-5-e', status: 'in-progress' },\n   133→    ]);\n   134→  });\n   135→});\n   136→\n   137→describe('parseRalphMessage', () => {\n   138→  it('parses [SUCCESS] Story completion', () => {\n   139→    const msg = parseRalphMessage('[SUCCESS] Story 1-1-foo: DONE — title here');\n   140→    expect(msg).toEqual({\n   141→      type: 'ok',\n   142→      key: '1-1-foo',\n   143→      message: 'DONE — title here',\n   144→    });\n   145→  });\n   146→\n   147→  it('parses [SUCCESS] Story completion without details', () => {\n   148→    const msg = parseRalphMessage('[SUCCESS] Story 2-3-bar: DONE');\n   149→    expect(msg).toEqual({\n   150→      type: 'ok',\n   151→      key: '2-3-bar',\n   152→      message: 'DONE',\n   153→    });\n   154→  });\n   155→\n   156→  it('parses [SUCCESS] with timestamp prefix', () => {\n   157→    const msg = parseRalphMessage('[2025-01-15 10:30:45] [SUCCESS] Story 1-1-foo: DONE — verified');\n   158→    expect(msg).toEqual({\n   159→      type: 'ok',\n   160→      key: '1-1-foo',\n   161→      message: 'DONE — verified',\n   162→    });\n   163→  });\n   164→\n   165→  it('parses [WARN] retry exceeded', () => {\n   166→    const msg = parseRalphMessage('[WARN] Story 3-2-baz exceeded retry limit');\n   167→    expect(msg).toEqual({\n   168→      type: 'fail',\n   169→      key: '3-2-baz',\n   170→      message: 'exceeded retry limit',\n   171→    });\n   172→  });\n   173→\n   174→  it('parses [WARN] retry N/M', () => {\n   175→    const msg = parseRalphMessage('[WARN] Story 1-1-foo — retry 2/5');\n   176→    expect(msg).toEqual({\n   177→      type: 'warn',\n   178→      key: '1-1-foo',\n   179→      message: 'retry 2/5',\n   180→    });\n   181→  });\n   182→\n   183→  it('parses [ERROR] with story key', () => {\n   184→    const msg = parseRalphMessage('[ERROR] Story 1-1-foo failed to verify');\n   185→    expect(msg).toEqual({\n   186→      type: 'fail',\n   187→      key: '1-1-foo',\n   188→      message: 'Story 1-1-foo failed to verify',\n   189→    });\n   190→  });\n   191→\n   192→  it('returns null for [ERROR] without story key', () => {\n   193→    const msg = parseRalphMessage('[ERROR] Connection timeout');\n   194→    expect(msg).toBeNull();\n   195→  });\n   196→\n   197→  it('returns null for unrecognized lines', () => {\n   198→    expect(parseRalphMessage('[INFO] Starting iteration 5')).toBeNull();\n   199→    expect(parseRalphMessage('[DEBUG] some debug info')).toBeNull();\n   200→    expect(parseRalphMessage('')).toBeNull();\n   201→    expect(parseRalphMessage('   ')).toBeNull();\n   202→  });\n   203→\n   204→  it('strips ANSI color codes', () => {\n   205→    const msg = parseRalphMessage('\\x1b[32m[SUCCESS] Story 1-1-foo: DONE\\x1b[0m');\n   206→    expect(msg).toEqual({\n   207→      type: 'ok',\n   208→      key: '1-1-foo',\n   209→      message: 'DONE',\n   210→    });\n   211→  });\n   212→\n   213→  it('handles retry exceeded before retry N/M (order matters)', () => {\n   214→    // \"exceeded retry limit\" should match retry exceeded, not retry N/M\n   215→    const msg = parseRalphMessage('[WARN] Story 1-1-foo exceeded retry limit...flagging');\n   216→    expect(msg?.type).toBe('fail');\n   217→    expect(msg?.message).toBe('exceeded retry limit');\n   218→  });\n   219→});\n   220→\n   221→describe('countStories', () => {\n   222→  it('counts stories by status correctly', () => {\n   223→    const counts = countStories({\n   224→      'epic-5': 'in-progress',\n   225→      '5-1-ralph-loop': 'ready-for-dev',\n   226→      '5-2-verification': 'backlog',\n   227→      '5-3-tracking': 'done',\n   228→      '5-4-another': 'in-progress',\n   229→      'epic-5-retrospective': 'optional',\n   230→    });\n   231→    expect(counts).toEqual({ total: 4, ready: 2, done: 1, inProgress: 1, verified: 0 });\n   232→  });\n   233→\n   234→  it('ignores epic keys and retrospective keys', () => {\n   235→    const counts = countStories({\n   236→      'epic-1': 'done', 'epic-1-retrospective': 'done',\n   237→      '1-1-story-one': 'done', '1-2-story-two': 'done',\n   238→    });\n   239→    expect(counts.total).toBe(2);\n   240→    expect(counts.done).toBe(2);\n   241→  });\n   242→\n   243→  it('returns zeros for empty statuses', () => {\n   244→    expect(countStories({})).toEqual({ total: 0, ready: 0, done: 0, inProgress: 0, verified: 0 });\n   245→  });\n   246→\n   247→  it('counts review status as inProgress', () => {\n   248→    expect(countStories({ '1-1-story': 'review' }).inProgress).toBe(1);\n   249→  });\n   250→\n   251→  it('counts verifying status separately', () => {\n   252→    const counts = countStories({\n   253→      '1-1-story': 'verifying',\n   254→      '1-2-story': 'verifying',\n   255→      '1-3-story': 'done',\n   256→    });\n   257→    expect(counts).toEqual({ total: 3, ready: 0, done: 1, inProgress: 0, verified: 2 });\n   258→  });\n   259→});\n   260→\n   261→describe('buildSpawnArgs', () => {\n   262→  const baseOpts = {\n   263→    ralphPath: '/path/to/ralph.sh',\n   264→    pluginDir: '/path/to/.claude',\n   265→    promptFile: '/path/to/prompt.md',\n   266→    maxIterations: 50,\n   267→    timeout: 14400,\n   268→    iterationTimeout: 15,\n   269→    calls: 100,\n   270→    quiet: false,\n   271→  };\n   272→\n   273→  it('bui