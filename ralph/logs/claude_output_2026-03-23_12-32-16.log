ror match arm without tracing — observability gap',\n   436→            severity: 'WARNING',\n   437→          },\n   438→        },\n   439→        {\n   440→          check_id: 'rust-error-path-no-tracing',\n   441→          path: 'src/handler.rs',\n   442→          start: { line: 88, col: 5 },\n   443→          end: { line: 91, col: 6 },\n   444→          extra: {\n   445→            message: 'Rust error-path closure without tracing — observability gap',\n   446→            severity: 'WARNING',\n   447→          },\n   448→        },\n   449→      ],\n   450→    };\n   451→\n   452→    const gaps = parseSemgrepOutput(mockOutput);\n   453→    expect(gaps).toHaveLength(3);\n   454→\n   455→    expect(gaps[0]).toEqual({\n   456→      file: 'src/main.rs',\n   457→      line: 10,\n   458→      type: 'rust-function-no-tracing',\n   459→      description: 'Rust function without tracing instrumentation — observability gap',\n   460→      severity: 'info',\n   461→    });\n   462→\n   463→    expect(gaps[1]).toEqual({\n   464→      file: 'src/lib.rs',\n   465→      line: 42,\n   466→      type: 'rust-catch-without-tracing',\n   467→      description: 'Rust error match arm without tracing — observability gap',\n   468→      severity: 'warning',\n   469→    });\n   470→\n   471→    expect(gaps[2]).toEqual({\n   472→      file: 'src/handler.rs',\n   473→      line: 88,\n   474→      type: 'rust-error-path-no-tracing',\n   475→      description: 'Rust error-path closure without tracing — observability gap',\n   476→      severity: 'warning',\n   477→    });\n   478→  });\n   479→\n   480→  it('computeSummary handles Rust rule IDs in level distribution', () => {\n   481→    const gaps = [\n   482→      {\n   483→        file: 'src/main.rs', line: 10,\n   484→        type: 'rust-function-no-tracing',\n   485→        description: 'fn', severity: 'info' as const,\n   486→      },\n   487→      {\n   488→        file: 'src/lib.rs', line: 42,\n   489→        type: 'rust-catch-witho