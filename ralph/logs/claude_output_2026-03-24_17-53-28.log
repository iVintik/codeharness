edSeconds: 0 },\n    41→    observability: { statementCoverage: null, branchCoverage: null, functionCoverage: null, lineCoverage: null },\n    42→    run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n    43→    actionItems: [],\n    44→  } as unknown as SprintState;\n    45→}\n    46→\n    47→describe('selectNextStory', () => {\n    48→  it('returns ok with null selected when stories map is empty', () => {\n    49→    const result = selectNextStory(makeState({}));\n    50→    expect(result.success).toBe(true);\n    51→    if (result.success) {\n    52→      expect(result.data.selected).toBeNull();\n    53→      expect(result.data.retryExhausted).toEqual([]);\n    54→    }\n    55→  });\n    56→\n    57→  it('returns ok with null selected when all stories are terminal', () => {\n    58→    const state = makeState({\n    59→      'story-a': { status: 'done' },\n    60→      'story-b': { status: 'failed' },\n    61→      'story-c': { status: 'blocked' },\n    62→    });\n    63→    const result = selectNextStory(state);\n    64→    expect(result.success).toBe(true);\n    65→    if (result.success) {\n    66→      expect(result.data.selected).toBeNull();\n    67→      expect(result.data.retryExhausted).toEqual([]);\n    68→    }\n    69→  });\n    70→\n    71→  it('reports retry-exhausted stories in retryExhausted array', () => {\n    72→    const state = makeState({\n    73→      'story-a': { status: 'backlog', attempts: 10 },\n    74→      'story-b': { status: 'backlog', attempts: 15 },\n    75→    });\n    76→    const result = selectNextStory(state);\n    77→    expect(result.success).toBe(true);\n    78→    if (result.success) {\n    79→      expect(result.data.selected).toBeNull();\n    80→      expect(result.data.retryExhausted).toHaveLength(2);\n    81→      const keys = result.data.retryExhausted.map((r) => r.key).sort();\n    82→      expect(keys).toEqual(['story-a', 'story-b']);\n    83→      for (const info of result.data.retryExhausted) {\n    84→        expect(info.reason).toBe('retry-exhausted');\n    85→      }\n    86→    }\n    87→  });\n    88→\n    89→  it('retry-exhausted stories report correct attempt counts', () => {\n    90→    const state = makeState({ 'story-x': { status: 'verifying', attempts: 12 } });\n    91→    const result = selectNextStory(state);\n    92→    expect(result.success).toBe(true);\n    93→    if (result.success) {\n    94→      expect(result.data.retryExhausted).toHaveLength(1);\n    95→      expect(result.data.retryExhausted[0]).toEqual({\n    96→        key: 'story-x', attempts: 12, reason: 'retry-exhausted',\n    97→      });\n    98→    }\n    99→  });\n   100→\n   101→  it('does not report terminal stories as retry-exhausted even with high attempts', () => {\n   102→    const state = makeState({\n   103→      'story-done': { status: 'done', attempts: 15 },\n   104→      'story-failed': { status: 'failed', attempts: 20 },\n   105→      'story-blocked': { status: 'blocked', attempts: 10 },\n   106→    });\n   107→    const result = selectNextStory(state);\n   108→    expect(result.success).toBe(true);\n   109→    if (result.success) {\n   110→      expect(result.data.selected).toBeNull();\n   111→      expect(result.data.retryExhausted).toEqual([]);\n   112→    }\n   113→  });\n   114→\n   115→  it('returns in-progress story before all others', () => {\n   116→    const state = makeState({\n   117→      'story-backlog': { status: 'backlog' },\n   118→      'story-verifying': { status: 'verifying' },\n   119→      'story-current': { status: 'in-progress', attempts: 3 },\n   120→    });\n   121→    const result = selectNextStory(state);\n   122→    expect(result.success).toBe(true);\n   123→    if (result.success) {\n   124→      expect(result.data.selected!.key).toBe('story-current');\n   125→      expect(result.data.selected!.priority).toBe(0);\n   126→    }\n   127→  });\n   128→\n   129→  it('returns verifying-with-proof before plain verifying', () => {\n   130→    const state = makeState({\n   131→      'story-no-proof': { status: 'verifying', proofPath: null },\n   132→      'story-has-proof': { status: 'verifying', proofPath: 'docs/proof.md' },\n   133→    });\n   134→    const result = selectNextStory(state);\n   135→    expect(result.success).toBe(true);\n   136→    if (result.success) {\n   137→      expect(result.data.selected!.key).toBe('story-has-proof');\n   138→      expect(result.data.selected!.priority).toBe(1);\n   139→    }\n   140→  });\n   141→\n   142→  it('returns verifying before backlog', () => {\n   143→    const state = makeState({\n   144→      'story-backlog': { status: 'backlog' },\n   145→      'story-verifying': { status: 'verifying' },\n   146→    });\n   147→    const result = selectNextStory(state);\n   148→    expect(result.success).toBe(true);\n   149→    if (result.success) {\n   150→      expect(result.data.selected!.key).toBe('story-verifying');\n   151→      expect(result.data.selected!.priority).toBe(2);\n   152→    }\n   153→  });\n   154→\n   155→  it('full priority ordering: in-progress > proof > verifying > backlog', () => {\n   156→    const state = makeState({\n   157→      'story-backlog': { status: 'backlog' },\n   158→      'story-verifying': { status: 'verifying' },\n   159→      'story-proof': { status: 'verifying', proofPath: 'proof.md' },\n   160→      'story-active': { status: 'in-progress' },\n   161→    });\n   162→    const result = selectNextStory(state);\n   163→    expect(result.success).toBe(true);\n   164→    if (result.success) {\n   165→      expect(result.data.selected!.key).toBe('story-active');\n   166→      expect(result.data.selected!.priority).toBe(0);\n   167→    }\n   168→  });\n   169→\n   170→  it('same-tier tiebreak: fewer attempts first', () => {\n   171→    const state = makeState({\n   172→      'story-a': { status: 'backlog', attempts: 5 },\n   173→      'story-b': { status: 'backlog', attempts: 2 },\n   174→      'story-c': { status: 'backlog', attempts: 8 },\n   175→    });\n   176→    const result = selectNextStory(state);\n   177→    expect(result.success).toBe(true);\n   178→    if (result.success) expect(result.data.selected!.key).toBe('story-b');\n   179→  });\n   180→\n   181→  it('same-tier same-attempts tiebreak: lexicographic key order', () => {\n   182→    const state = makeState({\n   183→      'story-charlie': { status: 'backlog', attempts: 0 },\n   184→      'story-alpha': { status: 'backlog', attempts: 0 },\n   185→      'story-bravo': { status: 'backlog', attempts: 0 },\n   186→    });\n   187→    const result = selectNextStory(state);\n   188→    expect(result.success).toBe(true);\n   189→    if (result.success) expect(result.data.selected!.key).toBe('story-alpha');\n   190→  });\n   191→\n   192→  it('cross-epic selection: considers stories from all epics equally', () => {\n   193→    const state = makeState({\n   194→      'epic-2-story-a': { status: 'backlog', attempts: 3 },\n   195→      'epic-3-story-b': { status: 'backlog', attempts: 1 },\n   196→      'epic-2-story-c': { status: 'verifying' },\n   197→    });\n   198→    const result = selectNextStory(state);\n   199→    expect(result.success).toBe(true);\n   200→    if (result.success) expect(result.data.selected!.key).toBe('epic-2-story-c');\n   201→  });\n   202→\n   203→  it.each([\n   204→    ['done', 'done' as const],\n   205→    ['failed', 'failed' as const],\n   206→    ['blocked', 'blocked' as const],\n   207→  ])('excludes %s stories from selection', (_label, status) => {\n   208→    const state = makeState({\n   209→      'story-terminal': { status },\n   210→      'story-backlog': { status: 'backlog' },\n   211→    });\n   212→    const result = selectNextStory(state);\n   213→    expect(result.success).toBe(true);\n   214→    if (result.success) expect(result.data.selected!.key).toBe('story-backlog');\n   215→  });\n   216→\n   217→  it('selects story with attempts < 10 but reports one with attempts >= 10', () => {\n   218→    const state = makeState({\n   219→      'story-exhausted': { status: 'backlog', attempts: 10 },\n   220→      'story-ok': { status: 'backlog', attempts: 9 },\n   221→    });\n   222→    const result = selectNextStory(state);\n   223→    expect(result.success).toBe(true);\n   224→    if (result.success) {\n   225→      expect(result.data.selected!.key).toBe('story-ok');\n   226→      expect(result.data.retryExhausted).toHaveLength(1);\n   227→      expect(result.data.retryExhausted[0].key).toBe('story-exhausted');\n   228→    }\n   229→  });\n   230→\n   231→  it('populates title from key', () => {\n   232→    const state = makeState({ 'my-cool-story': { status: 'backlog' } });\n   233→    const result = selectNextStory(state);\n   234→    expect(result.success).toBe(true);\n   235→    if (result.success) expect(result.data.selected!.title).toBe('My cool story');\n   236→  });\n   237→\n   238→  it('handles empty key in title generation', () => {\n   239→    const state = makeState({ '': { status: 'backlog' } });\n   240→    const result = selectNextStory(state);\n   241→    expect(result.success).toBe(true);\n   242→    if (result.success) expect(result.data.selected!.title).toBe('');\n   243→  });\n   244→\n   245→  it('returns fail() on Error throw', () => {\n   246→    const result = selectNextStory(makeBadState(new Error('corrupt state')));\n   247→    expect(result.success).toBe(false);\n   248→    if (!result.success) {\n   249→      expect(result.error).toContain('Story selection failed');\n   250→      expect(result.error).toContain('corrupt state');\n   251→    }\n   252→  });\n   253→\n   254→  it('returns fail() on non-Error throw', () => {\n   255→    const result = selectNextStory(makeBadState('string error'));\n   256→    expect(result.success).toBe(false);\n   257→    if (!result.success) expect(result.error).toContain('string error');\n   258→  });\n   259→\n   260→  it('handles ready and review statuses as backlog-tier', () => {\n   261→    const state = makeState({\n   262→      'story-ready': { status: 'ready' },\n   263→      'story-review': { status: 'review', attempts: 1 },\n   264→    });\n   265→    const result = selectNextStory(state);\n   266→    expect(result.success).toBe(true);\n   267→    if (result.success) {\n   268→      expect(result.data.selected!.key).toBe('story-ready');\n   269→      expect(result.data.selected!.priority).toBe(3);\n   270→    }\n   271→  });\n   272→\n   273→  it('MAX_STORY_ATTEMPTS is 10', () => {\n   274→    expect(MAX_STORY_ATTEMPTS).toBe(10);\n   275→  });\n   276→\n   277→  it('mixed scenario: selects actionable and reports exhausted', () => {\n   278→    const state = makeState({\n   279→      'story-done': { status: 'done' },\n   280→      'story-exhausted-1': { status: 'in-progress', attempts: 10 },\n   281→      'story-exhausted-2': { status: 'backlog', attempts: 11 },\n   282→      'story-good': { status: 'verifying', proofPath: 'p.md' },\n   283→      'story-blocked': { status: 'blocked' },\n   284→    });\n   285→    const result = selectNextStory(state);\n   286→    expect(result.success).toBe(true);\n   287→    if (result.success) {\n   288→      expect(result.data.selected!.key).toBe('story-good');\n   289→      expect(result.data.selected!.priority).toBe(1);\n   290→      expect(result.data.retryExhausted).toHaveLength(2);\n   291→      const exhaustedKeys = result.data.retryExhausted.map((r) => r.key).sort();\n   292→      expect(exhaustedKeys).toEqual(['story-exhausted-1', 'story-exhausted-2']);\n   293→    }\n   294→  });\n   295→});\n   296→"}]},"parent_tool_use_id":"toolu_01ApBdeVdWe8XvBt2HXWCWHK","session_id":"fecf2c57-a859-44f9-9426-67d9679ac1d8","uuid":"adf905f3-1a00-4d83-868b-a31c13a5c197","timestamp":"2026-03-24T14:08:38.306Z"}
