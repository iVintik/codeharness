tation(() => { throw new Error('Something completely unexpected'); });\n429\t\n430\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n431\t      expect((events[0] as ResultEvent).errorCategory).toBe('UNKNOWN');\n432\t    });\n433\t\n434\t    it('yields result event with error info instead of throwing', async () => {\n435\t      mockQuery.mockImplementation(() => { throw new Error('kaboom'); });\n436\t\n437\t      // Should NOT throw\n438\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n439\t      expect(events).toHaveLength(1);\n440\t      expect(events[0].type).toBe('result');\n441\t      expect((events[0] as ResultEvent).error).toBe('kaboom');\n442\t    });\n443\t  });\n444\t\n445\t  describe('dispatch always yields a result event (AC #2)', () => {\n446\t    it('yields result even when SDK throws', async () => {\n447\t      mockQuery.mockImplementation(() => { throw new Error('fail'); });\n448\t\n449\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n450\t      const resultEvents = events.filter((e) => e.type === 'result');\n451\t      expect(resultEvents).toHaveLength(1);\n452\t    });\n453\t\n454\t    it('yields result when SDK generator yields no messages', async () => {\n455\t      mockQuery.mockReturnValue(fakeStream([]));\n456\t\n457\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n458\t      const resultEvents = events.filter((e) => e.type === 'result');\n459\t      expect(resultEvents).toHaveLength(1);\n460\t    });\n461\t\n462\t    it('yields exactly one result from normal flow', async () => {\n463\t      mockQuery.mockReturnValue(fakeStream([makeResultMessage()]));\n464\t\n465\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n466\t      const resultEvents = events.filter((e) => e.type === 'result');\n467\t      expect(resultEvents).toHaveLength(1);\n468\t    });\n469\t  });\n470\t\n471\t  describe('plugins pass-through (AC #6)', () => {\n472\t    it('passes plugins to SDK options when provided', async () => {\n473\t      mockQuery.mockReturnValue(fakeStream([makeResultMessage()]));\n474\t\n475\t      await collectEvents(driver.dispatch(makeOpts({ plugins: ['gstack'] })));\n476\t\n477\t      const call = mockQuery.mock.calls[0][0];\n478\t      expect(call.options.plugins).toEqual(['gstack']);\n479\t    });\n480\t\n481\t    it('does not pass plugins when opts.plugins is undefined', async () => {\n482\t      mockQuery.mockReturnValue(fakeStream([makeResultMessage()]));\n483\t\n484\t      await collectEvents(driver.dispatch(makeOpts({ plugins: undefined })));\n485\t\n486\t      const call = mockQuery.mock.calls[0][0];\n487\t      expect(call.options.plugins).toBeUndefined();\n488\t    });\n489\t\n490\t    it('does not pass plugins when opts.plugins is empty array', async () => {\n491\t      mockQuery.mockReturnValue(fakeStream([makeResultMessage()]));\n492\t\n493\t      await collectEvents(driver.dispatch(makeOpts({ plugins: [] })));\n494\t\n495\t      const call = mockQuery.mock.calls[0][0];\n496\t      expect(call.options.plugins).toBeUndefined();\n497\t    });\n498\t  });\n499\t\n500\t  describe('timeout handling (AC #7)', () => {\n501\t    it('applies timeout via AbortController when opts.timeout is set', async () => {\n502\t      mockQuery.mockReturnValue(fakeStream([makeResultMessage()]));\n503\t\n504\t      await collectEvents(driver.dispatch(makeOpts({ timeout: 30000 })));\n505\t\n506\t      // Verify AbortController was passed\n507\t      const call = mockQuery.mock.calls[0][0];\n508\t      expect(call.abortController).toBeInstanceOf(AbortController);\n509\t    });\n510\t\n511\t    it('does not set AbortController when no timeout', async () => {\n512\t      mockQuery.mockReturnValue(fakeStream([makeResultMessage()]));\n513\t\n514\t      await collectEvents(driver.dispatch(makeOpts()));\n515\t\n516\t      const call = mockQuery.mock.calls[0][0];\n517\t      expect(call.abortController).toBeUndefined();\n518\t    });\n519\t\n520\t    it('classifies abort-triggered errors as TIMEOUT when timeout was set', async () => {\n521\t      // Simulate what happens when AbortController aborts during stream\n522\t      async function* abortingStream() {\n523\t        yield { type: 'system', subtype: 'init', tools: [] };\n524\t        const err = new Error('The operation was aborted');\n525\t        err.name = 'AbortError';\n526\t        throw err;\n527\t      }\n528\t\n529\t      mockQuery.mockReturnValue(abortingStream());\n530\t\n531\t      const events = await collectEvents(driver.dispatch(makeOpts({ timeout: 100 })));\n532\t      const resultEvent = events.find((e) => e.type === 'result');\n533\t      expect(resultEvent).toBeDefined();\n534\t      expect((resultEvent as ResultEvent).errorCategory).toBe('TIMEOUT');\n535\t    });\n536\t  });\n537\t\n538\t  describe('SDK call parameters', () => {\n539\t    it('passes prompt to query()', async () => {\n540\t      mockQuery.mockReturnValue(fakeStream([makeResultMessage()]));\n541\t\n542\t      await collectEvents(driver.dispatch(makeOpts({ prompt: 'Build a widget' })));\n543\t\n544\t      const call = mockQuery.mock.calls[0][0];\n545\t      expect(call.prompt).toBe('Build a widget');\n546\t    });\n547\t\n548\t    it('passes model from opts', async () => {\n549\t      mockQuery.mockReturnValue(fakeStream([makeResultMessage()]));\n550\t\n551\t      await collectEvents(driver.dispatch(makeOpts({ model: 'claude-opus-4-20250514' })));\n552\t\n553\t      const call = mockQuery.mock.calls[0][0];\n554\t      expect(call.options.model).toBe('claude-opus-4-20250514');\n555\t    });\n556\t\n557\t    it('passes cwd from opts', async () => {\n558\t      mockQuery.mockReturnValue(fakeStream([makeResultMessage()]));\n559\t\n560\t      await collectEvents(driver.dispatch(makeOpts({ cwd: '/my/project' })));\n561\t\n562\t      const call = mockQuery.mock.calls[0][0];\n563\t      expect(call.options.cwd).toBe('/my/project');\n564\t    });\n565\t\n566\t    it('sets bypassPermissions when sourceAccess is true', async () => {\n567\t      mockQuery.mockReturnValue(fakeStream([makeResultMessage()]));\n568\t\n569\t      await collectEvents(driver.dispatch(makeOpts({ sourceAccess: true })));\n570\t\n571\t      const call = mockQuery.mock.calls[0][0];\n572\t      expect(call.options.permissionMode).toBe('bypassPermissions');\n573\t      expect(call.options.allowDangerouslySkipPermissions).toBe(true);\n574\t    });\n575\t\n576\t    it('sets default permissionMode when sourceAccess is false', async () => {\n577\t      mockQuery.mockReturnValue(fakeStream([makeResultMessage()]));\n578\t\n579\t      await collectEvents(driver.dispatch(makeOpts({ sourceAccess: false })));\n580\t\n581\t      const call = mockQuery.mock.calls[0][0];\n582\t      expect(call.options.permissionMode).toBe('default');\n583\t      expect(call.options.allowDangerouslySkipPermissions).toBeUndefined();\n584\t    });\n585\t  });\n586\t\n587\t  describe('error during stream consumption', () => {\n588\t    it('classifies errors thrown mid-stream and yields result', async () => {\n589\t      async function* throwingStream() {\n590\t        yield {\n591\t          type: 'stream_event',\n592\t          event: {\n593\t            type: 'content_block_delta',\n594\t            delta: { type: 'text_delta', text: 'partial...' },\n595\t          },\n596\t        };\n597\t        throw Object.assign(new Error('connection reset'), { code: 'ECONNRESET' });\n598\t      }\n599\t\n600\t      mockQuery.mockReturnValue(throwingStream());\n601\t\n602\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n603\t      // Should have text event + result event\n604\t      expect(events).toHaveLength(2);\n605\t      expect(events[0].type).toBe('text');\n606\t      expect(events[1].type).toBe('result');\n607\t      expect((events[1] as ResultEvent).errorCategory).toBe('NETWORK');\n608\t    });\n609\t  });\n610\t});\n611\t"}]},"parent_tool_use_id":"to