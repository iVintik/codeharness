h();\n378\t    const health = getCollectorHealth(sharedComposeFile);\n379\t\n380\t    if (isJson) {\n381\t      jsonOutput({\n382\t        status: health.healthy ? 'ok' : 'fail',\n383\t        mode: 'remote-routed',\n384\t        docker: {\n385\t          healthy: health.healthy,\n386\t          services: health.services,\n387\t          remedy: health.remedy,\n388\t        },\n389\t        remote_endpoints: state?.docker?.remote_endpoints,\n390\t      });\n391\t    } else {\n392\t      if (health.healthy) {\n393\t        ok('OTel Collector: running');\n394\t      } else {\n395\t        fail('OTel Collector: not running');\n396\t        if (health.remedy) {\n397\t          info(`-> ${health.remedy}`);\n398\t        }\n399\t      }\n400\t      const re = state?.docker?.remote_endpoints;\n401\t      if (re) {\n402\t        info(`Remote backends: logs=${re.logs_url} metrics=${re.metrics_url} traces=${re.traces_url}`);\n403\t      }\n404\t    }\n405\t    return;\n406\t  }\n407\t\n408\t  // local-shared mode (default)\n409\t  let composeFile = 'docker-compose.harness.yml';\n410\t  let projectName: string | undefined;\n411\t\n412\t  if (state?.docker?.compose_file) {\n413\t    composeFile = state.docker.compose_file;\n414\t  }\n415\t\n416\t  const stackDir = getStackDir();\n417\t  if (composeFile.startsWith(stackDir)) {\n418\t    composeFile = resolveSharedCompose(backend);\n419\t    projectName = 'codeharness-shared';\n420\t  }\n421\t\n422\t  const health = getStackHealth(composeFile, projectName);\n423\t\n424\t  if (isJson) {\n425\t    jsonOutput({\n426\t      status: health.healthy ? 'ok' : 'fail',\n427\t      backend,\n428\t      ...(projectName ? { project_name: projectName } : {}),\n429\t      docker: {\n430\t        healthy: health.healthy,\n431\t        services: health.services,\n432\t        remedy: health.remedy,\n433\t      },\n434\t      ...(health.healthy ? { endpoints: getDefaultEndpointsForBackend(backend) } : {}),\n435\t    });\n436\t    return;\n437\t  }\n438\t\n439\t  const stackLabel = backend === 'elk' ? 'OpenSearch/ELK stack' : 'VictoriaMetrics stack';\n440\t  const ep = getDefaultEndpointsForBackend(backend);\n441\t\n442\t  if (health.healthy) {\n443\t    ok(`${stackLabel}: running${projectName ? ` (project: ${projectName})` : ''}`);\n444\t    for (const svc of health.services) {\n445\t      info(`  ${svc.name}: ${svc.running ? 'running' : 'stopped'}`);\n446\t    }\n447\t    info(`Endpoints: logs=${ep.logs} metrics=${ep.metrics} traces=${ep.traces}`);\n448\t  } else {\n449\t    fail(`${stackLabel}: not running${projectName ? ` (project: ${projectName})` : ''}`);\n450\t    for (const svc of health.services) {\n451\t      if (!svc.running) {\n452\t        info(`  ${svc.name}: down`);\n453\t      }\n454\t    }\n455\t    if (health.remedy) {\n456\t      info(`-> ${health.remedy}`);\n457\t    }\n458\t  }\n459\t}\n460\t\n461\t// ─── Workflow State Helpers ──────────────────────────────────────────────────\n462\t\n463\t/**\n464\t * Format elapsed milliseconds as human-readable duration.\n465\t */\n466\texport function formatElapsed(ms: number): string {\n467\t  const s = Math.floor(ms / 1000);\n468\t  const h = Math.floor(s / 3600);\n469\t  const m = Math.floor((s % 3600) / 60);\n470\t  if (h > 0) return `${h}h${m}m`;\n471\t  if (m > 0) return `${m}m${s % 60}s`;\n472\t  return `${s}s`;\n473\t}\n474\t\n475\tfunction printWorkflowState(): void {\n476\t  const state = readWorkflowState();\n477\t\n478\t  if (state.phase === 'idle' && state.started === '') {\n479\t    console.log('Workflow Engine: No active workflow run');\n480\t    return;\n481\t  }\n482\t\n483\t  console.log('── Workflow Engine ──────────────────────────────────────────────');\n484\t  console.log(`  Phase: ${state.phase}`);\n485\t  console.log(`  Iteration: ${state.iteration}`);\n486\t  console.log(`  Tasks completed: ${state.tasks_completed.length}`);\n487\t\n488\t  if (state.phase === 'executing' && state.started) {\n489\t    const elapsed = Date.now() - Date.parse(state.started);\n490\t    console.log(`  Elapsed: ${formatElapsed(elapsed)}`);\n491\t  }\n492\t\n493\t  if (state.evaluator_scores.length > 0) {\n494\t    const latest = state.evaluator_scores[state.evaluator_scores.length - 1];\n495\t    console.log(`  Evaluator: ${latest.passed}/${latest.total} passed, ${latest.failed} failed, ${latest.unknown} unknown`);\n496\t  }\n497\t\n498\t  console.log(`  Circuit breaker: ${state.circuit_breaker.triggered ? 'TRIGGERED' : 'no'}${state.circuit_breaker.triggered && state.circuit_breaker.reason ? ` — ${state.circuit_breaker.reason}` : ''}`);\n499\t  console.log('');\n500\t}\n501\t\n502\tfunction getWorkflowStateData(): Record<string, unknown> | null {\n503\t  const state = readWorkflowState();\n504\t\n505\t  if (state.phase === 'idle' && state.started === '') {\n506\t    return null;\n507\t  }\n508\t\n509\t  const data: Record<string, unknown> = {\n510\t    workflow_name: state.workflow_name,\n511\t    phase: state.phase,\n512\t    iteration: state.iteration,\n513\t    started: state.started,\n514\t    tasks_completed: state.tasks_completed.length,\n515\t    evaluator_scores: state.evaluator_scores,\n516\t    circuit_breaker: state.circuit_breaker,\n517\t  };\n518\t\n519\t  if (state.phase === 'executing' && state.started) {\n520\t    data.elapsed_ms = Date.now() - Date.parse(state.started);\n521\t    data.elapsed = formatElapsed(data.elapsed_ms as number);\n522\t  }\n523\t\n524\t  return data;\n525\t}\n526\t\n527\t// ─── Sprint State Helpers ────────────────────────────────────────────────────\n528\t\n529\tfunction printSprintState(): void {\n530\t  const reportResult = generateReport();\n531\t  if (!reportResult.success) {\n532\t    console.log('Sprint state: unavailable');\n533\t    return;\n534\t  }\n535\t\n536\t  const r = reportResult.data;\n537\t  console.log(`\\u2500\\u2500 Project State \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\