{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B5gPagr293LZLa882cY4gv","type":"tool_result","content":"     1→/**\n     2→ * Validation runner — sprint initialization, AC execution, fix story generation,\n     3→ * and result processing for the self-validation cycle.\n     4→ *\n     5→ * Orchestration (runValidationCycle, getValidationProgress) lives in\n     6→ * validation-orchestrator.ts to comply with NFR18 (300-line file limit).\n     7→ *\n     8→ * Story 10-2: Validation Infrastructure\n     9→ */\n    10→\n    11→import { execSync } from 'node:child_process';\n    12→import { writeFileSync, mkdirSync } from 'node:fs';\n    13→import { join, dirname } from 'node:path';\n    14→import { ok, fail } from '../../types/result.js';\n    15→import type { Result } from '../../types/result.js';\n    16→import type { SprintState, StoryState } from '../../types/state.js';\n    17→import { VALIDATION_ACS } from './validation-acs.js';\n    18→import type { ValidationAC } from './validation-ac-types.js';\n    19→import type {\n    20→  ValidationACResult,\n    21→  ValidationSprintResult,\n    22→} from './validation-runner-types.js';\n    23→import {\n    24→  getSprintState,\n    25→  writeStateAtomic,\n    26→  computeSprintCounts,\n    27→} from '../sprint/index.js';\n    28→\n    29→/** Maximum consecutive failures before marking an AC as blocked */\n    30→export const MAX_VALIDATION_ATTEMPTS = 10;\n    31→\n    32→/** Timeout for CLI AC command execution (30 seconds) */\n    33→const AC_COMMAND_TIMEOUT_MS = 30_000;\n    34→\n    35→/** Prefix for validation story keys to avoid collision with real stories */\n    36→export const VAL_KEY_PREFIX = 'val-';\n    37→\n    38→// ─── Task 1: Validation Sprint Initializer ───────────────────────────────────\n    39→\n    40→/**\n    41→ * Populate sprint-state.json with one story entry per validation AC.\n    42→ * Preserves any existing non-validation stories (AC 1, 5).\n    43→ */\n    44→export function createValidationSprint(): Result<ValidationSprintResult> {\n    45→  try {\n    46→    const stateResult = getSprintState();\n    47→    if (!stateResult.success) {\n    48→      return fail(stateResult.error);\n    49→    }\n    50→\n    51→    const current = stateResult.data;\n    52→    const updatedStories = { ...current.stories };\n    53→\n    54→    let existingPreserved = 0;\n    55→    for (const key of Object.keys(updatedStories)) {\n    56→      if (!key.startsWith(VAL_KEY_PREFIX)) {\n    57→        existingPreserved++;\n    58→      }\n    59→    }\n    60→\n    61→    let acsAdded = 0;\n    62→    for (const ac of VALIDATION_ACS) {\n    63→      const key = `${VAL_KEY_PREFIX}${ac.id}`;\n    64→      if (!(key in updatedStories)) {\n    65→        const initialState: StoryState = {\n    66→          status: 'backlog',\n    67→          attempts: 0,\n    68→          lastAttempt: null,\n    69→          lastError: null,\n    70→          proofPath: null,\n    71→          acResults: null,\n    72→        };\n    73→        updatedStories[key] = initialState;\n    74→        acsAdded++;\n    75→      }\n    76→    }\n    77→\n    78→    const updatedSprint = computeSprintCounts(updatedStories);\n    79→    const updatedState: SprintState = {\n    80→      ...current,\n    81→      sprint: updatedSprint,\n    82→      stories: updatedStories,\n    83→    };\n    84→\n    85→    const writeResult = writeStateAtomic(updatedState);\n    86→    if (!writeResult.success) {\n    87→      return fail(writeResult.error);\n    88→    }\n    89→\n    90→    return ok({ acsAdded, existingPreserved });\n    91→  } catch (err: unknown) {\n    92→    const msg = err instanceof Error ? err.message : String(err);\n    93→    return fail(`Failed to create validation sprint: ${msg}`);\n    94→  }\n    95→}\n    96→\n    97→// ─── Task 2: Validation AC Executor ──────────────────────────────────────────\n    98→\n    99→/**\n   100→ * Execute a single validation AC (AC 3, 6, 7).\n   101→ * CLI-verifiable: spawns command, captures output, checks exit code.\n   102→ * Integration-required: returns blocked immediately.\n   103→ */\n   104→export function executeValidationAC(ac: ValidationAC): Result<ValidationACResult> {\n   105→  try {\n   106→    if (ac.verificationMethod === 'integration') {\n   107→      return ok({\n   108→        acId: ac.id,\n   109→        verdict: 'blocked',\n   110→        output: '',\n   111→        durationMs: 0,\n   112→        reason: 'integration-required',\n   113→      });\n   114→    }\n   115→\n   116→    if (!ac.command) {\n   117→      return ok({\n   118→        acId: ac.id,\n   119→        verdict: 'blocked',\n   120→        output: '',\n   121→        durationMs: 0,\n   122→        reason: 'no-command',\n   123→      });\n   124→    }\n   125→\n   126→    const startTime = Date.now();\n   127→    try {\n   128→      const output = execSync(ac.command, {\n   129→        timeout: AC_COMMAND_TIMEOUT_MS,\n   130→        encoding: 'utf-8',\n   131→        stdio: ['pipe', 'pipe', 'pipe'],\n   132→      });\n   133→      const durationMs = Date.now() - startTime;\n   134→\n   135→      return ok({\n   136→        acId: ac.id,\n   137→        verdict: 'pass',\n   138→        output: output.trim(),\n   139→        durationMs,\n   140→      });\n   141→    } catch (execErr: unknown) {\n   142→      const durationMs = Date.now() - startTime;\n   143→      let output = '';\n   144→\n   145→      if (execErr && typeof execErr === 'object') {\n   146→        const e = execErr as { stdout?: string; stderr?: string; message?: string };\n   147→        const parts: string[] = [];\n   148→        if (e.stdout) parts.push(e.stdout);\n   149→        if (e.stderr) parts.push(e.stderr);\n   150→        output = parts.length > 0 ? parts.join('\\n').trim() : (e.message ?? '');\n   151→      }\n   152→\n   153→      return ok({\n   154→        acId: ac.id,\n   155→        verdict: 'fail',\n   156→        output,\n   157→        durationMs,\n   158→      });\n   159→    }\n   160→  } catch (err: unknown) {\n   161→    const msg = err instanceof Error ? err.message : String(err);\n   162→    return fail(`Failed to execute validation AC ${ac.id}: ${msg}`);\n   163→  }\n   164→}\n   165→\n   166→// ─── Task 3: Fix Story Generator ─────────────────────────────────────────────\n   167→\n   168→/**\n   169→ * Create a minimal fix story file for a failing validation AC (AC 2).\n   170→ * Writes to _bmad-output/implementation-artifacts/val-fix-{acId}.md.\n   171→ */\n   172→export function createFixStory(ac: ValidationAC, error: string): Result<string> {\n   173→  try {\n   174→    const storyKey = `val-fix-${ac.id}`;\n   175→    const storyPath = join(\n   176→      process.cwd(),\n   177→      '_bmad-output',\n   178→      'implementation-artifacts',\n   179→      `${storyKey}.md`,\n   180→    );\n   181→\n   182→    const markdown = [\n   183→      `# Fix: Validation AC ${ac.id} — ${ac.frRef}`,\n   184→      '',\n   185→      'Status: ready-for-dev',\n   186→      '',\n   187→      '## Story',\n   188→      '',\n   189→      `As a release manager, I need validation AC ${ac.id} to pass so that the self-validation suite confirms compliance with ${ac.frRef}.`,\n   190→      '',\n   191→      '## Acceptance Criteria',\n   192→      '',\n   193→      `1. **Given** AC ${ac.id} (${ac.frRef}), **When** the validation command runs, **Then** it exits with code 0.`,\n   194→      '',\n   195→      '## Failing AC Details',\n   196→      '',\n   197→      `**AC ID:** ${ac.id}`,\n   198→      `**Reference:** ${ac.frRef}`,\n   199→      `**Description:** ${ac.description}`,\n   200→      `**Verification Method:** ${ac.verificationMethod}`,\n   201→      ...(ac.command ? [`**Command:** \\`${ac.command}\\``] : []),\n   202→      '',\n   203→      '## Error Output',\n   204→      '',\n   205→      '```',\n   206→      error,\n   207→      '```',\n   208→      '',\n   209→      '## Suggested Fix',\n   210→      '',\n   211→      `Review the failing command and its expected behavior. The AC expects: ${ac.description}`,\n   212→      '',\n   213→      '## Dev Notes',\n   214→      '',\n   215→      'This is an auto-generated fix story created by the validation runner.',\n   216→      'Fix the root cause so the validation command passes.',\n   217→      '',\n   218→    ].join('\\n');\n   219→\n   220→    mkdirSync(dirname(storyPath), { recursive: true });\n   221→    writeFileSync(storyPath, markdown, 'utf-8');\n   222→\n   223→    return ok(storyKey);\n   224→  } catch (err: unknown) {\n   225→    const msg = err instanceof Error ? err.message : String(err);\n   226→    return fail(`Failed to create fix story for AC ${ac.id}: ${msg}`);\n   227→  }\n   228→}\n   229→\n   230→// ─── Task 4: Validation Result Processor ─────────────────────────────────────\n   231→\n   232→/**\n   233→ * Process a validation AC result: update sprint-state.json (AC 4).\n   234→ * Increments attempts, sets verdict, marks blocked after MAX_VALIDATION_ATTEMPTS.\n   235→ */\n   236→export function processValidationResult(\n   237→  acId: number,\n   238→  result: ValidationACResult,\n   239→): Result<void> {\n   240→  try {\n   241→    const stateResult = getSprintState();\n   242→    if (!stateResult.success) {\n   243→      return fail(stateResult.error);\n   244→    }\n   245→\n   246→    const current = stateResult.data;\n   247→    const key = `${VAL_KEY_PREFIX}${acId}`;\n   248→    const existing = current.stories[key];\n   249→\n   250→    if (!existing) {\n   251→      return fail(`Validation story ${key} not found in sprint state`);\n   252→    }\n   253→\n   254→    const newAttempts = existing.attempts + 1;\n   255→    const now = new Date().toISOString();\n   256→\n   257→    let newStatus: StoryState['status'];\n   258→    let newError: string | null = existing.lastError;\n   259→\n   260→    if (result.verdict === 'pass') {\n   261→      newStatus = 'done';\n   262→      newError = null;\n   263→    } else if (result.verdict === 'blocked') {\n   264→      newStatus = 'blocked';\n   265→      newError = result.reason ?? 'blocked';\n   266→    } else if (newAttempts >= MAX_VALIDATION_ATTEMPTS) {\n   267→      newStatus = 'blocked';\n   268→      newError = 'retry-exhausted';\n   269→    } else {\n   270→      newStatus = 'failed';\n   271→      newError = result.output || 'validation failed';\n   272→    }\n   273→\n   274→    const updatedStory: StoryState = {\n   275→      status: newStatus,\n   276→      attempts: newAttempts,\n   277→      lastAttempt: now,\n   278→      lastError: newError,\n   279→      proofPath: existing.proofPath,\n   280→      acResults: existing.acResults,\n   281→    };\n   282→\n   283→    const updatedStories = { ...current.stories, [key]: updatedStory };\n   284→    const updatedSprint = computeSprintCounts(updatedStories);\n   285→    const updatedState: SprintState = {\n   286→      ...current,\n   287→      sprint: updatedSprint,\n   288→      stories: updatedStories,\n   289→    };\n   290→\n   291→    return writeStateAtomic(updatedState);\n   292→  } catch (err: unknown) {\n   293→    const msg = err instanceof Error ? err.message : String(err);\n   294→    return fail(`Failed to process validation result for AC ${acId}: ${msg}`);\n   295→  }\n   296→}\n   297→"}]},"parent_tool_use_id":"toolu_01LnSVSQepuckZac7ZtmSt3a","session_id":"15a05376-1038-4ca0-9130-3347fd423c16","uuid":"494844e4-5463-4b9f-822c-ee7ea7fbdabd","timestamp":"2026-03-27T11:37:41.589Z"}
