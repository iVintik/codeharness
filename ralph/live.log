() => {\n    47→    expect(reviewPatch).toContain('passes silently');\n    48→  });\n    49→});\n    50→\n    51→describe('patches/dev/enforcement.md — observability section', () => {\n    52→  it('contains semgrep scan --config patches/observability/ instruction', () => {\n    53→    expect(devPatch).toContain(\n    54→      'semgrep scan --config patches/observability/',\n    55→    );\n    56→  });\n    57→\n    58→  it('instructs to run before committing', () => {\n    59→    expect(devPatch).toContain('before committing');\n    60→  });\n    61→});\n    62→\n    63→describe('Semgrep JSON output format contract', () => {\n    64→  const mockSemgrepOutput = {\n    65→    results: [\n    66→      {\n    67→        check_id: 'catch-without-logging',\n    68→        path: 'src/lib/docker.ts',\n    69→        start: { line: 42, col: 5 },\n    70→        end: { line: 44, col: 6 },\n    71→        extra: {\n    72→          message: 'catch block without logging',\n    73→          severity: 'WARNING',\n    74→        },\n    75→      },\n    76→      {\n    77→        check_id: 'function-no-debug-log',\n    78→        path: 'src/lib/state.ts',\n    79→        start: { line: 10, col: 1 },\n    80→        end: { line: 20, col: 2 },\n    81→        extra: {\n    82→          message: 'function lacks debug-level log statement',\n    83→          severity: 'INFO',\n    84→        },\n    85→      },\n    86→      {\n    87→        check_id: 'error-path-no-log',\n    88→        path: 'src/commands/init.ts',\n    89→        start: { line: 88, col: 3 },\n    90→        end: { line: 90, col: 4 },\n    91→        extra: {\n    92→          message: 'error path without logging',\n    93→          severity: 'WARNING',\n    94→        },\n    95→      },\n    96→    ],\n    97→  };\n    98→\n    99→  it('parseSemgrepOutput extracts gaps with file, line, type, description from raw JSON', () => {\n   100→    const gaps = parseSemgrepOutput(mockSemgrepOutput);\n   101→\n   102→    expect(gaps).toHaveLength(3);\n   103→    expect(gaps[0]).toEqual({\n   104→      file: 'src/lib/docker.ts',\n   105→      line: 42,\n   106→      type: 'catch-without-logging',\n   107→      description: 'catch block without logging',\n   108→      severity: 'warning',\n   109→    });\n   110→    expect(gaps[1]).toEqual({\n   111→      file: 'src/lib/state.ts',\n   112→      line: 10,\n   113→      type: 'function-no-debug-log',\n   114→      description: 'function lacks debug-level log statement',\n   115→      severity: 'info',\n   116→    });\n   117→    expect(gaps[2]).toEqual({\n   118→      file: 'src/commands/init.ts',\n   119→      line: 88,\n   120→      type: 'error-path-no-log',\n   121→      description: 'error path without logging',\n   122→      severity: 'warning',\n   123→    });\n   124→  });\n   125→\n   126→  it('parseSemgrepOutput returns empty array for empty results', () => {\n   127→    const gaps = parseSemgrepOutput({ results: [] });\n   128→    expect(gaps).toHaveLength(0);\n   129→  });\n   130→\n   131→  it('each raw result contains required review fields: check_id, path, start.line, extra.message', () => {\n   132→    for (const result of mockSemgrepOutput.results) {\n   133→      expect(result).toHaveProperty('check_id');\n   134→      expect(typeof result.check_id).toBe('string');\n   135→      expect(result).toHaveProperty('path');\n   136→      expect(typeof result.path).toBe('string');\n   137→      expect(result).toHaveProperty('start.line');\n   138→      expect(typeof result.start.line).toBe('number');\n   139→      expect(result).toHaveProperty('extra.message');\n   140→      expect(typeof result.extra.message).toBe('string');\n   141→    }\n   142→  });\n   143→});\n   144→"}]},"parent_tool_use_id":"toolu_01Eq5DgGLDuiHQZGj7XDd7Z5","session_id":"3048c8d1-1bef-4a7f-be36-bfe8009706ca","uuid":"870bb858-7b98-4bd0-96fa-e38007987622","timestamp":"2026-03-27T13:22:44.059Z"}
