{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013PNXbnkH8VMvzg3FTDZCWe","type":"tool_result","content":"     1→/**\n     2→ * Observability analyzer module — public API.\n     3→ *\n     4→ * All consumers should import from this barrel file only.\n     5→ * Internal implementation details are not re-exported.\n     6→ */\n     7→\n     8→export type {\n     9→  AnalyzerResult,\n    10→  AnalyzerConfig,\n    11→  AnalyzerSummary,\n    12→  ObservabilityGap,\n    13→  GapSeverity,\n    14→  ObservabilityCoverageState,\n    15→  CoverageHistoryEntry,\n    16→  StaticCoverageState,\n    17→  CoverageTargets,\n    18→  CoverageTrend,\n    19→  CoverageTargetResult,\n    20→  RuntimeCoverageEntry,\n    21→  RuntimeCoverageResult,\n    22→  RuntimeCoverageState,\n    23→} from './types.js';\n    24→\n    25→export { analyze } from './analyzer.js';\n    26→\n    27→export {\n    28→  saveCoverageResult,\n    29→  readCoverageState,\n    30→  getCoverageTrend,\n    31→  checkCoverageTarget,\n    32→} from './coverage.js';\n    33→\n    34→export {\n    35→  computeRuntimeCoverage,\n    36→  saveRuntimeCoverage,\n    37→} from './runtime-coverage.js';\n    38→"}]},"parent_tool_use_id":"toolu_01APL3Sm5JEakF5iK2mjDEd8","session_id":"f7a66acd-0cc1-40de-a592-d59e75273c0b","uuid":"9ac22376-0b48-482a-9d75-cb433b8c2bfd","timestamp":"2026-03-20T05:53:08.273Z"}
