:{\"input\":33,\"output\":9889,\"cacheRead\":1765560,\"cacheWrite\":17179,\"calls\":29},\"16-5-re\":{\"input\":14,\"output\":6271,\"cacheRead\":727499,\"cacheWrite\":26925,\"calls\":14},\"16-5-xxx\":{\"input\":8,\"output\":5909,\"cacheRead\":531156,\"cacheWrite\":5993,\"calls\":6},\"1-1-foo\":{\"input\":75,\"output\":20447,\"cacheRead\":5045899,\"cacheWrite\":41022,\"calls\":73}},\"byTool\":{\"Skill\":{\"input\":396,\"output\":12425,\"cacheRead\":1000820,\"cacheWrite\":2437133,\"calls\":132},\"Bash\":{\"input\":8115,\"output\":488759,\"cacheRead\":118902091,\"cacheWrite\":1868957,\"calls\":2032},\"Read\":{\"input\":1120,\"output\":174612,\"cacheRead\":51058259,\"cacheWrite\":2033726,\"calls\":959},\"Agent\":{\"input\":502,\"output\":204757,\"cacheRead\":24614089,\"cacheWrite\":289984,\"calls\":437},\"Grep\":{\"input\":850,\"output\":62884,\"cacheRead\":19378830,\"cacheWrite\":232411,\"calls\":325},\"Edit\":{\"input\":650,\"output\":217068,\"cacheRead\":37778651,\"cacheWrite\":504722,\"calls\":640},\"Glob\":{\"input\":217,\"output\":24805,\"cacheRead\":3353309,\"cacheWrite\":353446,\"calls\":87},\"Write\":{\"input\":233,\"output\":143128,\"cacheRead\":7016609,\"cacheWrite\":218378,\"calls\":138},\"ToolSearch\":{\"input\":27,\"output\":6882,\"cacheRead\":1198051,\"cacheWrite\":35825,\"calls\":27},\"TodoWrite\":{\"input\":139,\"output\":32626,\"cacheRead\":7242227,\"cacheWrite\":86265,\"calls\":109},\"TaskOutput\":{\"input\":8,\"output\":411,\"cacheRead\":245252,\"cacheWrite\":1205,\"calls\":4}},\"byDate\":{},\"tokenBreakdown\":{\"input\":12257,\"output\":1368357,\"cacheRead\":271788188,\"cacheWrite\":8062052,\"calls\":4890},\"avgCostPerStory\":3.3880070661290316,\"storiesTracked\":155}","is_error":false}]},"parent_tool_use_id":"toolu_01Qcu6hf3g4YB7b8H7MEmcGR","session_id":"2a44c687-0795-47af-a7f4-46576056f827","uuid":"d12a47ad-b47e-413e-951b-df8744d9d9f3","timestamp":"2026-03-27T15:17:09.976Z"}
