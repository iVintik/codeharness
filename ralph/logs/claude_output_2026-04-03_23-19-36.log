{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Y8eTAWf437bnzVW3TnYZJK","type":"tool_result","content":"130\t   *\n131\t   * @param epicId  The epic identifier.\n132\t   */\n133\t  cleanupWorktree(epicId: string): void {\n134\t    const worktreePath = `${WORKTREE_BASE}${epicId}`;\n135\t\n136\t    // Remove worktree (ignore errors if it doesn't exist)\n137\t    try {\n138\t      this.execGit(`git worktree remove ${worktreePath} --force`);\n139\t    } catch {\n140\t      // Worktree may not exist — that's fine (idempotent)\n141\t    }\n142\t\n143\t    // Find and delete the branch matching this epicId\n144\t    const branch = this.findBranchForEpic(epicId);\n145\t    if (branch) {\n146\t      try {\n147\t        this.execGit(`git branch -D ${branch}`);\n148\t      } catch {\n149\t        // Branch may not exist — that's fine (idempotent)\n150\t      }\n151\t    }\n152\t  }\n153\t\n154\t  /**\n155\t   * List all codeharness worktrees.\n156\t   *\n157\t   * @returns An array of `WorktreeInfo` objects sorted by epicId.\n158\t   *          Returns an empty array when no codeharness worktrees exist.\n159\t   */\n160\t  listWorktrees(): WorktreeInfo[] {\n161\t    let output: string;\n162\t    try {\n163\t      output = this.execGit('git worktree list --porcelain');\n164\t    } catch {\n165\t      return [];\n166\t    }\n167\t\n168\t    const entries = this.parsePorcelainOutput(output);\n169\t    return entries\n170\t      .filter((e) => e.branch.startsWith(`refs/heads/${BRANCH_PREFIX}`))\n171\t      .map((e) => {\n172\t        const branchName = e.branch.replace('refs/heads/', '');\n173\t        const epicId = this.extractEpicId(branchName);\n174\t        return {\n175\t          epicId,\n176\t          path: e.path,\n177\t          branch: branchName,\n178\t          createdAt: new Date(),\n179\t        };\n180\t      })\n181\t      .sort((a, b) => a.epicId.localeCompare(b.epicId, undefined, { numeric: true }));\n182\t  }\n183\t\n184\t  /**\n185\t   * Detect orphaned worktrees from previous crashed runs.\n186\t   *\n187\t   * A worktree is considered orphaned if its directory exists on disk\n188\t   * but has no `.codeharness/lane-state.json` file or the file has\n189\t   * no active PID.\n190\t   *\n191\t   * @returns An array of orphaned `WorktreeInfo` entries.\n192\t   */\n193\t  detectOrphans(): WorktreeInfo[] {\n194\t    const worktrees = this.listWorktrees();\n195\t    return worktrees.filter((wt) => this.isOrphaned(wt));\n196\t  }\n197\t\n198\t  // --- Private Helpers ---\n199\t\n200\t  /**\n201\t   * Sanitize a slug to contain only `[a-z0-9-]`.\n202\t   */\n203\t  private sanitizeSlug(slug: string): string {\n204\t    return slug\n205\t      .toLowerCase()\n206\t      .replace(/[^a-z0-9-]/g, '-')\n207\t      .replace(/-+/g, '-')\n208\t      .replace(/^-|-$/g, '');\n209\t  }\n210\t\n211\t  /**\n212\t   * Execute a git command and return its stdout.\n213\t   * Wraps errors in WorktreeError with captured stderr.\n214\t   */\n215\t  private execGit(cmd: string): string {\n216\t    try {\n217\t      const result = execSync(cmd, {\n218\t        cwd: this.cwd,\n219\t        stdio: ['pipe', 'pipe', 'pipe'],\n220\t        timeout: 30_000,\n221\t      });\n222\t      return result.toString().trim();\n223\t    } catch (err: unknown) {\n224\t      const stderr = (err as { stderr?: Buffer })?.stderr?.toString() ?? '';\n225\t      throw new WorktreeError(`Git command failed: ${cmd} — ${stderr}`, stderr);\n226\t    }\n227\t  }\n228\t\n229\t  /**\n230\t   * Clean up stale branch and worktree from a previous crash (AC #9).\n231\t   */\n232\t  private cleanupStale(epicId: string, branchName: string, worktreePath: string): void {\n233\t    // Check if worktree path exists on disk\n234\t    if (existsSync(worktreePath)) {\n235\t      try {\n236\t        this.execGit(`git worktree remove ${worktreePath} --force`);\n237\t      } catch {\n238\t        // If git worktree remove fails, try to prune\n239\t        try {\n240\t          this.execGit('git worktree prune');\n241\t        } catch {\n242\t          // Best effort\n243\t        }\n244\t      }\n245\t    }\n246\t\n247\t    // Check if branch already exists\n248\t    const existingBranch = this.findBranchForEpic(epicId);\n249\t    if (existingBranch) {\n250\t      try {\n251\t        this.execGit(`git branch -D ${existingBranch}`);\n252\t      } catch {\n253\t        // Best effort\n254\t      }\n255\t    }\n256\t  }\n257\t\n258\t  /**\n259\t   * Clean up partial state after a failed createWorktree (AC #10).\n260\t   */\n261\t  private cleanupPartial(branchCreated: boolean, branchName: string, worktreePath: string): void {\n262\t    // Try to remove worktree if it was partially created\n263\t    try {\n264\t      this.execGit(`git worktree remove ${worktreePath} --force`);\n265\t    } catch {\n266\t      // May not exist\n267\t    }\n268\t\n269\t    // Delete branch if it was created"}]},"parent_tool_use_id":"toolu_01HkThmW1eF3XHtUVHViMjeW","session_id":"187035da-d60e-40cf-8aef-09e6134be246","uuid":"0f5f9a1f-d5fb-4e3a-937a-a9cea1a9b999","timestamp":"2026-04-03T19:29:23.678Z"}
