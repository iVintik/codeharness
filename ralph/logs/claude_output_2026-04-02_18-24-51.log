{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014Pnbo9kKJQEX6rFqzarzFe","type":"tool_result","content":"1\t/**\n2\t * Project initialization orchestrator.\n3\t * Composes sub-steps: stack detection, deps, Docker, BMAD, beads, state, docs, OTLP.\n4\t */\n5\t\n6\timport { copyFileSync, existsSync, mkdirSync } from 'node:fs';\n7\timport { basename, dirname, join } from 'node:path';\n8\timport { ok as okOutput, fail as failOutput, info, warn, jsonOutput } from '../../lib/output.js';\n9\timport { detectStacks, detectAppType } from '../../lib/stacks/index.js';\n10\timport { readState, writeState, getDefaultState, getStatePath } from '../../lib/state.js';\n11\timport type { HarnessState } from '../../lib/state.js';\n12\timport { instrumentProject } from '../../lib/observability/index.js';\n13\timport type { Result } from '../../types/result.js';\n14\timport { ok, fail, isOk } from '../../types/result.js';\n15\timport type { InitOptions, InitResult } from './types.js';\n16\timport { checkDocker, setupDocker } from './docker-setup.js';\n17\timport { installDeps, verifyDeps } from './deps-install.js';\n18\timport { setupBmad, verifyBmadOnRerun } from './bmad-setup.js';\n19\timport { scaffoldDocs, getCoverageTool, getStackLabel } from './docs-scaffold.js';\n20\timport { generateDockerfileTemplate } from './dockerfile-template.js';\n21\timport { getPackageRoot } from '../../lib/templates.js';\n22\t\n23\tdeclare const __PKG_VERSION__: string;\n24\tconst HARNESS_VERSION = typeof __PKG_VERSION__ !== 'undefined' ? __PKG_VERSION__ : '0.0.0-dev';\n25\t\n26\t/** Helper: build a fail-status InitResult for early returns */\n27\tfunction failResult(opts: InitOptions, error: string): InitResult {\n28\t  return {\n29\t    status: 'fail', stack: null, stacks: [], error,\n30\t    enforcement: { frontend: opts.frontend, database: opts.database, api: opts.api },\n31\t    documentation: { agents_md: 'skipped', docs_scaffold: 'skipped', readme: 'skipped' },\n32\t  };\n33\t}\n34\t\n35\t/** Output error and set exit code for validation/critical failures */\n36\tfunction emitError(error: string, isJson: boolean): void {\n37\t  if (isJson) { jsonOutput({ status: 'fail', error }); } else { failOutput(error); }\n38\t  process.exitCode = 1;\n39\t}\n40\t\n41\t/** Main project initialization orchestrator. Never throws — returns fail() on unexpected errors. */\n42\texport async function initProject(opts: InitOptions): Promise<Result<InitResult>> {\n43\t  try {\n44\t    return await initProjectInner(opts);\n45\t  } catch (err) {\n46\t    const message = err instanceof Error ? err.message : String(err);\n47\t    return fail(`Unexpected init error: ${message}`);\n48\t  }\n49\t}\n50\t\n51\tasync function initProjectInner(opts: InitOptions): Promise<Result<InitResult>> {\n52\t  const { projectDir, json: isJson = false } = opts;\n53\t  const result: InitResult = {\n54\t    status: 'ok', stack: null, stacks: [],\n55\t    enforcement: { frontend: opts.frontend, database: opts.database, api: opts.api },\n56\t    documentation: { agents_md: 'skipped', docs_scaffold: 'skipped', readme: 'skipped' },\n57\t  };\n58\t\n59\t  // --- Idempotent re-run check ---\n60\t  const rerunResult = handleRerun(opts, result);\n61\t  if (rerunResult !== null) return rerunResult;\n62\t\n63\t  // --- Observability backend validation ---\n64\t  const validBackends = ['victoria', 'elk', 'none'] as const;\n65\t  if (opts.observabilityBackend !== undefined && !validBackends.includes(opts.observabilityBackend)) {\n66\t    const msg = `Invalid --observability-backend '${opts.observabilityBackend}'. Must be one of: ${validBackends.join(', ')}`;\n67\t    emitError(msg, isJson); return ok(failResult(opts, msg));\n68\t  }\n69\t\n70\t  // --- Remote endpoint URL validation ---\n71\t  const urlError = validateRemoteUrls(opts);\n72\t  if (urlError !== null) { emitError(urlError, isJson); return ok(failResult(opts, urlError)); }\n73\t\n74\t  // --- Stack detection ---\n75\t  // Call detectStacks() once; derive primary root stack from it to avoid double filesystem scan\n76\t  const allStacks = detectStacks(projectDir);\n77\t  const rootDetection = allStacks.find(s => s.dir === '.');\n78\t  const stack = rootDetection ? rootDetection.stack : null;\n79\t  if (!stack && !isJson) warn('No recognized stack detected');\n80\t  result.stack = stack;\n81\t  result.stacks = [...new Set(allStacks.map(s => s.stack))];\n82\t  const appType = detectAppType(projectDir, stack);\n83\t  result.app_type = appType;\n84\t  if (!isJson) {\n85\t    if (result.stacks.length > 0) {\n86\t      info(`Stack detected: ${getStackLabel(result.stacks)}`);\n87\t    } else if (stack) {\n88\t      info(`Stack detected: ${getStackLabel(stack)}`);\n89\t    }\n90\t    info(`App type: ${appType}`);\n91\t  }\n92\t\n93\t  // --- Workflow generation ---\n94\t  const workflowSrc = join(getPackageRoot(), 'templates/workflows/default.yaml');\n95\t  const workflowDest = join(projectDir, '.codeharness/workflows/default.yaml');\n96\t  const workflowRelPath = '.codeharness/workflows/default.yaml';\n97\t  if (existsSync(workflowDest) && !opts.force) {\n98\t    result.workflow = { status: 'exists', path: workflowRelPath };\n99\t    if (!isJson) info(`Workflow: ${workflowRelPath} already exists`);\n100\t  } else {\n101\t    const overwriting = existsSync(workflowDest);\n102\t    mkdirSync(dirname(workflowDest), { recursive: true });\n103\t    copyFileSync(workflowSrc, workflowDest);\n104\t    result.workflow = { status: overwriting ? 'overwritten' : 'created', path: workflowRelPath };\n105\t    if (!isJson) okOutput(`Workflow: ${workflowRelPath} ${overwriting ? 'overwritten' : 'created'}`);\n106\t  }\n107\t\n108\t  // --- Dockerfile template generation ---\n109\t  const dfResult = generateDockerfileTemplate(projectDir, allStacks);\n110\t  if (isOk(dfResult)) {\n111\t    result.dockerfile = { generated: true, stack: dfResult.data.stack, stacks: dfResult.data.stacks };\n112\t    if (!isJson) info(`Generated Dockerfile for ${dfResult.data.stacks.join('+') || dfResult.data.stack} project.`);\n113\t  } else {\n114\t    if (!isJson) info('Dockerfile already exists -- skipping template generation.');\n115\t  }\n116\t\n117\t  // --- Docker check ---\n118\t  const dockerCheck = checkDocker({ observability: opts.observability, otelEndpoint: opts.otelEndpoint, logsUrl: opts.logsUrl, opensearchUrl: opts.opensearchUrl, isJson });\n119\t  if (!isOk(dockerCheck)) return fail(dockerCheck.error);\n120\t  const { available: dockerAvailable, criticalFailure, dockerResult: criticalDockerResult } = dockerCheck.data;\n121\t  if (criticalFailure) {\n122\t    result.status = 'fail'; result.error = 'Docker not installed'; result.docker = criticalDockerResult;\n123\t    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); }\n124\t    else { failOutput('Docker not installed'); info('\\u2192 Install Docker: https://docs.docker.com/engine/install/'); info('\\u2192 Or skip observability: codeharness init --no-observability'); }\n125\t    process.exitCode = 1;\n126\t    return ok(result);\n127\t  }\n128\t\n129\t  // --- Dependency install ---\n130\t  const depResult = installDeps({ isJson });\n131\t  if (!isOk(depResult)) {\n132\t    result.status = 'fail'; result.error = depResult.error;\n133\t    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); } else { info('Critical dependency failed — aborting init'); }\n134\t    process.exitCode = 1;\n135\t    return ok(result);\n136\t  }\n137\t  result.dependencies = depResult.data;\n138\t\n139\t  // --- Beads initialization — removed (Epic 8 replacement pending) ---\n140\t  // TODO: v2 issue tracker (Epic 8)\n141\t  result.beads = { status: 'skipped' as const, message: 'beads removed' };\n142\t\n143\t  // --- BMAD installation ---\n144\t  const bmadResult = setupBmad({ projectDir, isJson });\n145\t  if (isOk(bmadResult)) result.bmad = bmadResult.data;\n146\t\n147\t  // --- State file creation ---\n148\t  let state: HarnessState = getDefaultState(stack);\n149\t  state.harness_version = HARNESS_VERSION;\n150\t  state.initialized = true;\n151\t  state.app_type = appType;\n152\t  state.enforcement = { frontend: opts.frontend, database: opts.database, api: opts.api };\n153\t  // Per-stack coverage detection: build tools map keyed by stack name, primary stack's tool for backward compat\n154\t  const coverageTools: Record<string, string> = {};\n155\t  for (const detection of allStacks) {\n156\t    coverageTools[detection.stack] = getCoverageTool(detection.stack);\n157\t  }\n158\t  state.coverage.tool = getCoverageTool(stack);\n159\t  state.coverage.tools = coverageTools;\n160\t  // Persist all detected stacks (not just the primary root stack)\n161\t  state.stacks = result.stacks as import('../../lib/stacks/index.js').StackName[];\n162\t  writeState(state, projectDir);\n163\t  if (!isJson) okOutput('State file: .claude/codeharness.local.md created');\n164\t\n165\t  // --- Documentation scaffold ---\n166\t  const docsResult = await scaffoldDocs({ projectDir, stack, stacks: allStacks, isJson });\n167\t  if (isOk(docsResult)) result.documentation = docsResult.data;\n168\t\n169\t  // --- Store observability backend choice ---\n170\t  const obsBackend = opts.observabilityBackend ?? 'victoria';\n171\t  if (obsBackend === 'none') {\n172\t    // 'none' backend: disable OTLP and skip Docker, similar to --no-observability but persisted\n173\t    state.otlp = { enabled: false, endpoint: '', service_name: basename(projectDir), mode: 'local-shared', backend: 'none' };\n174\t    writeState(state, projectDir);\n175\t    result.otlp = { status: 'skipped', packages_installed: false, start_script_patched: false, env_vars_configured: false };\n176\t    if (!isJson) info('Observability: disabled (--observability-backend none)');\n177\t    // Skip enforcement summary for 'none' — jump to end\n178\t    if (!isJson) {\n179\t      const e = state.enforcement;\n180\t      const fmt = (v: boolean): string => v ? 'ON' : 'OFF';\n181\t      okOutput(`Enforcement: frontend:${fmt(e.frontend)} database:${fmt(e.database)} api:${fmt(e.api)} observability:OFF`);\n182\t      info('Harness initialized. Run: codeharness bridge --epics <path>');\n183\t    }\n184\t    if (isJson) jsonOutput(result as unknown as Record<string, unknown>);\n185\t    return ok(result);\n186\t  }\n187\t\n188\t  // --- OTLP instrumentation ---\n189\t  if (!opts.observability) {\n190\t    result.otlp = { status: 'skipped', packages_installed: false, start_script_patched: false, env_vars_configured: false };\n191\t    if (!isJson) info('OTLP: skipped (--no-observability)');\n192\t  } else {\n193\t    // Per-stack OTLP instrumentation: instrument each detected stack in its directory\n194\t    for (const detection of allStacks) {\n195\t      const stackDir = detection.dir === '.' ? projectDir : join(projectDir, detection.dir);\n196\t      const stackOtlp = instrumentProject(stackDir, detection.stack, { json: isJson, appType });\n197\t      // Primary (root) stack's result goes to result.otlp for backward compat\n198\t      if (detection.dir === '.' && detection.stack === stack) {\n199\t        result.otlp = stackOtlp;\n200\t      }\n201\t    }\n202\t    // Fallback: if primary stack wasn't in allStacks (shouldn't happen), use single-stack call\n203\t    if (!result.otlp) {\n204\t      result.otlp = instrumentProject(projectDir, stack, { json: isJson, appType });\n205\t    }\n206\t  }\n207\t\n208\t  // Re-read state to pick up otlp changes written by instrumentProject\n209\t  try { const u = readState(projectDir); if (u.otlp) state.otlp = u.otlp; } catch { /* IGNORE: state re-read may fail during init */ }\n210\t  if (!state.otlp) {\n211\t    state.otlp = { enabled: true, endpoint: 'http://localhost:4318', service_name: basename(projectDir), mode: 'local-shared' };\n212\t  }\n213\t  state.otlp.backend = obsBackend;\n214\t  writeState(state, projectDir);\n215\t\n216\t  // --- Docker stack setup ---\n217\t  const dockerSetup = setupDocker({\n218\t    observability: opts.observability, otelEndpoint: opts.otelEndpoint,\n219\t    opensearchUrl: opts.opensearchUrl,\n220\t    logsUrl: opts.logsUrl, metricsUrl: opts.metricsUrl, tracesUrl: opts.tracesUrl,\n221\t    isJson, dockerAvailable, appType, state, projectDir,\n222\t  });\n223\t  if (isOk(dockerSetup)) result.docker = dockerSetup.data.docker;\n224\t\n225\t  // --- Enforcement summary ---\n226\t  if (!isJson) {\n227\t    const e = state.enforcement;\n228\t    const fmt = (v: boolean): string => v ? 'ON' : 'OFF';\n229\t    okOutput(`Enforcement: frontend:${fmt(e.frontend)} database:${fmt(e.database)} api:${fmt(e.api)} observability:ON`);\n230\t    info('Harness initialized. Run: codeharness bridge --epics <path>');\n231\t  }\n232\t  if (isJson) jsonOutput(result as unknown as Record<string, unknown>);\n233\t\n234\t  return ok(result);\n235\t}\n236\t\n237\tfunction handleRerun(opts: InitOptions, result: InitResult): Result<InitResult> | null {\n238\t  const { projectDir, json: isJson = false } = opts;\n239\t  if (!existsSync(getStatePath(projectDir))) return null;\n240\t\n241\t  try {\n242\t    const existingState = readState(projectDir);\n243\t    const legacyObsDisabled = (existingState.enforcement as Record<string, unknown>).observability === false;\n244\t    if (!existingState.initialized || legacyObsDisabled) {\n245\t      if (legacyObsDisabled && !isJson) info('Observability upgraded from disabled to enabled');\n246\t      return null;\n247\t    }\n248\t    result.stack = existingState.stack;\n249\t    result.stacks = existingState.stacks ?? [];\n250\t    result.enforcement = existingState.enforcement;\n251\t    result.documentation = { agents_md: 'exists', docs_scaffold: 'exists', readme: 'exists' };\n252\t    // Check workflow file status on re-run\n253\t    const workflowPath = join(projectDir, '.codeharness/workflows/default.yaml');\n254\t    if (existsSync(workflowPath)) {\n255\t      result.workflow = { status: 'exists', path: '.codeharness/workflows/default.yaml' };\n256\t    }\n257\t    result.dependencies = verifyDeps(isJson);\n258\t    result.docker = existingState.docker\n259\t      ? { compose_file: existingState.docker.compose_file, stack_running: existingState.docker.stack_running, services: [], ports: existingState.docker.ports }\n260\t      : null;\n261\t    const bmadResult = verifyBmadOnRerun(projectDir, isJson);\n262\t    if (bmadResult) result.bmad = bmadResult;\n263\t    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); }\n264\t    else { info('Harness already initialized — verifying configuration'); okOutput('Configuration verified'); }\n265\t    return ok(result);\n266\t  } catch {\n267\t    // IGNORE: re-init check may fail, non-fatal\n268\t    return null;\n269\t  }\n270\t}\n271\t\n272\t/** Returns error message string if validation fails, null if OK */\n273\tfunction validateRemoteUrls(opts: InitOptions): string | null {\n274\t  const remoteUrls = [opts.otelEndpoint, opts.opensearchUrl, opts.logsUrl, opts.metricsUrl, opts.tracesUrl].filter(Boolean) as string[];\n275\t  for (const url of remoteUrls) {\n276\t    if (!/^https?:\\/\\//i.test(url)) return `Invalid URL: '${url}' \\u2014 must start with http:// or https://`;\n277\t  }\n278\t  if (opts.otelEndpoint && (opts.logsUrl || opts.metricsUrl || opts.tracesUrl)) {\n279\t    return 'Cannot combine --otel-endpoint with --logs-url/--metrics-url/--traces-url';\n280\t  }\n281\t  const hasAny = opts.logsUrl || opts.metricsUrl || opts.tracesUrl;\n282\t  if (hasAny && !(opts.logsUrl && opts.metricsUrl && opts.tracesUrl)) {\n283\t    return 'When using remote backends, all three are required: --logs-url, --metrics-url, --traces-url';\n284\t  }\n285\t  return null;\n286\t}\n287\t"}]},"parent_tool_use_id":"toolu_01CCM5MwgB4Cmai7i1sHHZbw","session_id":"5e9a7eca-0e0b-47b2-8610-117311a6629c","uuid":"d514a8b6-d114-4c3d-922b-77755b2295ec","timestamp":"2026-04-02T14:35:03.383Z"}
