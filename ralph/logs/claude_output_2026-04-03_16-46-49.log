{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YBK9Ec7WjSVbrCQ6CDkqaM","type":"tool_result","content":"1\t/**\n2\t * Ink UI components — types and layout components (Header, Separator, StoryBreakdown).\n3\t *\n4\t * Renders a UX-spec-compliant live display with plain text header,\n5\t * ━━━ separators, and labeled story breakdown sections.\n6\t * Activity components (tools, thoughts, retry) are in ink-activity-components.tsx.\n7\t * The App root component is in ink-app.tsx to avoid circular imports.\n8\t */\n9\t\n10\timport React from 'react';\n11\timport { Text, Box } from 'ink';\n12\timport type { FlowStep } from './workflow-parser.js';\n13\t\n14\t// --- Types ---\n15\t\n16\texport interface SprintInfo {\n17\t  storyKey: string;\n18\t  phase: string;\n19\t  done: number;\n20\t  total: number;\n21\t  elapsed?: string;\n22\t  iterationCount?: number;\n23\t  totalCost?: number;\n24\t  acProgress?: string;\n25\t  currentCommand?: string;\n26\t}\n27\t\n28\texport interface CompletedToolEntry {\n29\t  name: string;\n30\t  args: string;\n31\t  driver?: string;\n32\t}\n33\t\n34\texport type StoryStatusValue = 'done' | 'in-progress' | 'pending' | 'failed' | 'blocked';\n35\t\n36\texport interface StoryStatusEntry {\n37\t  key: string;\n38\t  status: StoryStatusValue;\n39\t  retryCount?: number;\n40\t  maxRetries?: number;\n41\t}\n42\t\n43\texport interface RetryInfo {\n44\t  attempt: number;\n45\t  delay: number;\n46\t}\n47\t\n48\texport interface StoryMessage {\n49\t  type: 'ok' | 'warn' | 'fail';\n50\t  key: string;\n51\t  message: string;\n52\t  details?: string[];\n53\t}\n54\t\n55\texport type TaskNodeState = 'pending' | 'active' | 'done' | 'failed';\n56\t\n57\texport interface TaskNodeMeta {\n58\t  driver?: string;\n59\t  costUsd?: number | null;\n60\t  elapsedMs?: number | null;\n61\t}\n62\t\n63\texport interface RendererState {\n64\t  sprintInfo: SprintInfo | null;\n65\t  stories: StoryStatusEntry[];\n66\t  messages: StoryMessage[];\n67\t  completedTools: CompletedToolEntry[];\n68\t  activeTool: { name: string } | null;\n69\t  activeToolArgs: string;\n70\t  lastThought: string | null;\n71\t  retryInfo: RetryInfo | null;\n72\t  workflowFlow: FlowStep[];\n73\t  currentTaskName: string | null;\n74\t  taskStates: Record<string, TaskNodeState>;\n75\t  taskMeta: Record<string, TaskNodeMeta>;\n76\t  activeDriverName: string | null;\n77\t  driverCosts: Record<string, number>;\n78\t}\n79\t\n80\t// --- Layout Components ---\n81\t\n82\t/** Full-width separator using ━ characters. */\n83\texport function Separator() {\n84\t  const width = process.stdout.columns || 60;\n85\t  return <Text>{'━'.repeat(width)}</Text>;\n86\t}\n87\t\n88\tfunction shortKey(key: string): string {\n89\t  const m = key.match(/^(\\d+-\\d+)/);\n90\t  return m ? m[1] : key;\n91\t}\n92\t\n93\tfunction formatCost(cost: number): string {\n94\t  return `$${cost.toFixed(2)}`;\n95\t}\n96\t\n97\texport function Header({ info }: { info: SprintInfo | null }) {\n98\t  if (!info) return null;\n99\t\n100\t  const parts: string[] = ['codeharness run'];\n101\t  if (info.iterationCount != null) {\n102\t    parts.push(`iteration ${info.iterationCount}`);\n103\t  }\n104\t  if (info.elapsed) {\n105\t    parts.push(`${info.elapsed} elapsed`);\n106\t  }\n107\t  if (info.totalCost != null) {\n108\t    parts.push(`${formatCost(info.totalCost)} spent`);\n109\t  }\n110\t  const headerLine = parts.join(' | ');\n111\t\n112\t  let phaseLine = '';\n113\t  if (info.phase) {\n114\t    phaseLine = `Phase: ${info.phase}`;\n115\t    if (info.acProgress) {\n116\t      phaseLine += ` → AC ${info.acProgress}`;\n117\t    }\n118\t    if (info.currentCommand) {\n119\t      phaseLine += ` (${info.currentCommand})`;\n120\t    }\n121\t  }\n122\t\n123\t  return (\n124\t    <Box flexDirection=\"column\">\n125\t      <Text>{headerLine}</Text>\n126\t      <Separator />\n127\t      <Text>{`Story: ${info.storyKey || '(waiting)'}`}</Text>\n128\t      {phaseLine && <Text>{phaseLine}</Text>}\n129\t    </Box>\n130\t  );\n131\t}\n132\t\n133\texport function StoryBreakdown({ stories, sprintInfo }: { stories: StoryStatusEntry[]; sprintInfo?: SprintInfo | null }) {\n134\t  if (stories.length === 0) return null;\n135\t\n136\t  const done: StoryStatusEntry[] = [];\n137\t  const inProgress: StoryStatusEntry[] = [];\n138\t  const pending: StoryStatusEntry[] = [];\n139\t  const failed: StoryStatusEntry[] = [];\n140\t  const blocked: StoryStatusEntry[] = [];\n141\t\n142\t  for (const s of stories) {\n143\t    switch (s.status) {\n144\t      case 'done': done.push(s); break;\n145\t      case 'in-progress': inProgress.push(s); break;\n146\t      case 'pending': pending.push(s); break;\n147\t      case 'failed': failed.push(s); break;\n148\t      case 'blocked': blocked.push(s); break;\n149\t    }\n150\t  }\n151\t\n152\t  const lines: React.ReactNode[] = [];\n153\t\n154\t  if (done.length > 0) {\n155\t    const doneItems = done.map(s => `${shortKey(s.key)} ✓`).join('  ');\n156\t    lines.push(\n157\t      <Text key=\"done\"><Text color=\"green\">{'Done: '}</Text><Text color=\"green\">{doneItems}</Text></Text>\n158\t    );\n159\t  }\n160\t\n161\t  if (inProgress.length > 0) {\n162\t    for (const s of inProgress) {\n163\t      let thisText = `${shortKey(s.key)} ◆`;\n164\t      if (sprintInfo && sprintInfo.storyKey && shortKey(s.key) === shortKey(sprintInfo.storyKey)) {\n165\t        if (sprintInfo.phase) thisText += ` ${sprintInfo.phase}`;\n166\t        if (sprintInfo.acProgress) thisText += ` (${sprintInfo.acProgress} ACs)`;\n167\t      }\n168\t      lines.push(\n169\t        <Text key={`this-${s.key}`}><Text color=\"cyan\">{'This: '}</Text><Text color=\"cyan\">{thisText}</Text></Text>\n170\t      );\n171\t    }\n172\t  }\n173\t\n174\t  if (pending.length > 0) {\n175\t    lines.push(\n176\t      <Text key=\"next\">\n177\t        <Text>{'Next: '}</Text><Text>{shortKey(pending[0].key)}</Text>\n178\t        {pending.length > 1 && <Text dimColor>{` (+${pending.length - 1} more)`}</Text>}\n179\t      </Text>\n180\t    );\n181\t  }\n182\t\n183\t  if (blocked.length > 0) {\n184\t    const blockedItems = blocked.map(s => {\n185\t      let item = `${shortKey(s.key)} ✕`;\n186\t      if (s.retryCount != null && s.maxRetries != null) item += ` (${s.retryCount}/${s.maxRetries})`;\n187\t      return item;\n188\t    }).join('  ');\n189\t    lines.push(\n190\t      <Text key=\"blocked\"><Text color=\"yellow\">{'Blocked: '}</Text><Text color=\"yellow\">{blockedItems}</Text></Text>\n191\t    );\n192\t  }\n193\t\n194\t  if (failed.length > 0) {\n195\t    const failedItems = failed.map(s => {\n196\t      let item = `${shortKey(s.key)} ✗`;\n197\t      if (s.retryCount != null && s.maxRetries != null) item += ` (${s.retryCount}/${s.maxRetries})`;\n198\t      return item;\n199\t    }).join('  ');\n200\t    lines.push(\n201\t      <Text key=\"failed\"><Text color=\"red\">{'Failed: '}</Text><Text color=\"red\">{failedItems}</Text></Text>\n202\t    );\n203\t  }\n204\t\n205\t  return (\n206\t    <Box flexDirection=\"column\">\n207\t      {lines}\n208\t    </Box>\n209\t  );\n210\t}\n211\t\n212\t// Re-export activity components so existing consumers don't break\n213\texport { CompletedTool, CompletedTools, ActiveTool, LastThought, RetryNotice, StoryMessageLine, DriverCostSummary } from './ink-activity-components.js';\n214\t\n215\t// Re-export App from ink-app\n216\texport { App } from './ink-app.js';\n217\t"}]},"parent_tool_use_id":"toolu_01KuW1MjUdFwtjdSVSiFS3H5","session_id":"a0646c12-93c6-41a0-9c7a-50683cae7716","uuid":"41fba479-92c3-4d2e-a052-fd70d4174e39","timestamp":"2026-04-03T12:55:13.171Z"}
