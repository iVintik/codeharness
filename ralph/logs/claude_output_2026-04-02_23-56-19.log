{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UaABqNJBm9UkEdHkwQEjGj","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport {\n3\t  resolveSessionId,\n4\t  recordSessionId,\n5\t  getLastSessionId,\n6\t} from '../session-manager.js';\n7\timport type { SessionBoundary, SessionLookupKey } from '../session-manager.js';\n8\timport type { WorkflowState, TaskCheckpoint } from '../workflow-state.js';\n9\timport { getDefaultWorkflowState } from '../workflow-state.js';\n10\t\n11\t// --- Helpers ---\n12\t\n13\tfunction makeState(checkpoints: TaskCheckpoint[]): WorkflowState {\n14\t  return {\n15\t    ...getDefaultWorkflowState(),\n16\t    tasks_completed: checkpoints,\n17\t  };\n18\t}\n19\t\n20\tfunction makeCheckpoint(overrides?: Partial<TaskCheckpoint>): TaskCheckpoint {\n21\t  return {\n22\t    task_name: 'implement-feature',\n23\t    story_key: '4-2-session-boundary',\n24\t    completed_at: '2026-04-01T00:00:00.000Z',\n25\t    ...overrides,\n26\t  };\n27\t}\n28\t\n29\tfunction makeKey(overrides?: Partial<SessionLookupKey>): SessionLookupKey {\n30\t  return {\n31\t    taskName: 'implement-feature',\n32\t    storyKey: '4-2-session-boundary',\n33\t    ...overrides,\n34\t  };\n35\t}\n36\t\n37\t// --- Tests ---\n38\t\n39\tdescribe('session-manager', () => {\n40\t  describe('resolveSessionId', () => {\n41\t    it('returns undefined for fresh boundary regardless of state', () => {\n42\t      const state = makeState([\n43\t        makeCheckpoint({ session_id: 'sess-existing' }),\n44\t      ]);\n45\t\n46\t      const result = resolveSessionId('fresh', makeKey(), state);\n47\t\n48\t      expect(result).toBeUndefined();\n49\t    });\n50\t\n51\t    it('returns undefined for fresh boundary with empty state', () => {\n52\t      const state = makeState([]);\n53\t\n54\t      const result = resolveSessionId('fresh', makeKey(), state);\n55\t\n56\t      expect(result).toBeUndefined();\n57\t    });\n58\t\n59\t    it('returns undefined for continue boundary when no prior checkpoint exists', () => {\n60\t      const state = makeState([]);\n61\t\n62\t      const result = resolveSessionId('continue', makeKey(), state);\n63\t\n64\t      expect(result).toBeUndefined();\n65\t    });\n66\t\n67\t    it('returns undefined for continue boundary when checkpoints exist but none match', () => {\n68\t      const state = makeState([\n69\t        makeCheckpoint({\n70\t          task_name: 'other-task',\n71\t          story_key: 'other-story',\n72\t          session_id: 'sess-other',\n73\t        }),\n74\t      ]);\n75\t\n76\t      const result = resolveSessionId('continue', makeKey(), state);\n77\t\n78\t      expect(result).toBeUndefined();\n79\t    });\n80\t\n81\t    it('returns session ID from matching checkpoint for continue boundary', () => {\n82\t      const state = makeState([\n83\t        makeCheckpoint({ session_id: 'sess-abc-123' }),\n84\t      ]);\n85\t\n86\t      const result = resolveSessionId('continue', makeKey(), state);\n87\t\n88\t      expect(result).toBe('sess-abc-123');\n89\t    });\n90\t\n91\t    it('returns most recent session ID when multiple checkpoints exist (loop iterations)', () => {\n92\t      const state = makeState([\n93\t        makeCheckpoint({\n94\t          session_id: 'sess-iter-1',\n95\t          completed_at: '2026-04-01T00:00:00.000Z',\n96\t        }),\n97\t        makeCheckpoint({\n98\t          session_id: 'sess-iter-2',\n99\t          completed_at: '2026-04-01T01:00:00.000Z',\n100\t        }),\n101\t        makeCheckpoint({\n102\t          session_id: 'sess-iter-3',\n103\t          completed_at: '2026-04-01T02:00:00.000Z',\n104\t        }),\n105\t      ]);\n106\t\n107\t      const result = resolveSessionId('continue', makeKey(), state);\n108\t\n109\t      expect(result).toBe('sess-iter-3');\n110\t    });\n111\t\n112\t    it('skips checkpoints without session_id when looking for continue', () => {\n113\t      const state = makeState([\n114\t        makeCheckpoint({ session_id: 'sess-first' }),\n115\t        makeCheckpoint({ session_id: undefined }),\n116\t      ]);\n117\t\n118\t      const result = resolveSessionId('continue', makeKey(), state);\n119\t\n120\t      expect(result).toBe('sess-first');\n121\t    });\n122\t\n123\t    it('matches on both taskName and storyKey', () => {\n124\t      const state = makeState([\n125\t        makeCheckpoint({\n126\t          task_name: 'implement-feature',\n127\t          story_key: 'wrong-story',\n128\t          session_id: 'sess-wrong-story',\n129\t        }),\n130\t        makeCheckpoint({\n131\t          task_name: 'wrong-task',\n132\t          story_key: '4-2-session-boundary',\n133\t          session_id: 'sess-wrong-task',\n134\t        }),\n135\t        makeCheckpoint({\n136\t          task_name: 'implement-feature',\n137\t          story_key: '4-2-session-boundary',\n138\t          session_id: 'sess-correct',\n139\t        }),\n140\t      ]);\n141\t\n142\t      const result = resolveSessionId('continue', makeKey(), state);\n143\t\n144\t      expect(result).toBe('sess-correct');\n145\t    });\n146\t\n147\t    it('defaults to fresh behavior when boundary is fresh (schema default)', () => {\n148\t      // This test verifies that the default session value (fresh) produces no resume\n149\t      const boundary: SessionBoundary = 'fresh'; // workflow schema default\n150\t      const state = makeState([\n151\t        makeCheckpoint({ session_id: 'sess-should-not-use' }),\n152\t      ]);\n153\t\n154\t      const result = resolveSessionId(boundary, makeKey(), state);\n155\t\n156\t      expect(result).toBeUndefined();\n157\t    });\n158\t  });\n159\t\n160\t  describe('recordSessionId', () => {\n161\t    it('returns a new state with session_id on the checkpoint', () => {\n162\t      const originalState = makeState([]);\n163\t\n164\t      const newState = recordSessionId(makeKey(), 'sess-new-123', originalState);\n165\t\n166\t      expect(newState.tasks_completed).toHaveLength(1);\n167\t      expect(newState.tasks_completed[0].session_id).toBe('sess-new-123');\n168\t      expect(newState.tasks_completed[0].task_name).toBe('implement-feature');\n169\t      expect(newState.tasks_completed[0].story_key).toBe('4-2-session-boundary');\n170\t      expect(newState.tasks_completed[0].completed_at).toBeTruthy();\n171\t    });\n172\t\n173\t    it('does not mutate the original state', () => {\n174\t      const originalState = makeState([]);\n175\t      const originalLength = originalState.tasks_completed.length;\n176\t\n177\t      recordSessionId(makeKey(), 'sess-new', originalState);\n178\t\n179\t      expect(originalState.tasks_completed.length).toBe(originalLength);\n180\t    });\n181\t\n182\t    it('appends to existing checkpoints', () => {\n183\t      const existingCheckpoint = makeCheckpoint({ session_id: 'sess-existing' });\n184\t      const originalState = makeState([existingCheckpoint]);\n185\t\n186\t      const newState = recordSessionId(makeKey(), 'sess-appended', originalState);\n187\t\n188\t      expect(newState.tasks_completed).toHaveLength(2);\n189\t      expect(newState.tasks_completed[0].session_id).toBe('sess-existing');\n190\t      expect(newState.tasks_completed[1].session_id).toBe('sess-appended');\n191\t    });\n192\t\n193\t    it('preserves other state fields', () => {\n194\t      const originalState: WorkflowState = {\n195\t        ...getDefaultWorkflowState(),\n196\t        workflow_name: 'test-workflow',\n197\t        iteration: 5,\n198\t        phase: 'execute',\n199\t      };\n200\t\n201\t      const newState = recordSessionId(makeKey(), 'sess-new', originalState);\n202\t\n203\t      expect(newState.workflow_name).toBe('test-workflow');\n204\t      expect(newState.iteration).toBe(5);\n205\t      expect(newState.phase).toBe('execute');\n206\t    });\n207\t  });\n208\t\n209\t  describe('getLastSessionId', () => {\n210\t    it('returns undefined when no checkpoints exist', () => {\n211\t      const state = makeState([]);\n212\t\n213\t      const result = getLastSessionId(state, 'any-task', 'any-story');\n214\t\n215\t      expect(result).toBeUndefined();\n216\t    });\n217\t\n218\t    it('returns undefined when no matching checkpoint exists', () => {\n219\t      const state = makeState([\n220\t        makeCheckpoint({\n221\t          task_name: 'other-task',\n222\t          story_key: 'other-story',\n223\t          session_id: 'sess-other',\n224\t        }),\n225\t      ]);\n226\t\n227\t      const result = getLastSessionId(state, 'my-task', 'my-story');\n228\t\n229\t      expect(result).toBeUndefined();\n230\t    });\n231\t\n232\t    it('returns the most recent match (reverse order)', () => {\n233\t      const state = makeState([\n234\t        makeCheckpoint({ session_id: 'sess-old' }),\n235\t        makeCheckpoint({ session_id: 'sess-new' }),\n236\t      ]);\n237\t\n238\t      const result = getLastSessionId(state, 'implement-feature', '4-2-session-boundary');\n239\t\n240\t      expect(result).toBe('sess-new');\n241\t    });\n242\t\n243\t    it('skips checkpoints where session_id is undefined', () => {\n244\t      const state = makeState([\n245\t        makeCheckpoint({ session_id: 'sess-has-id' }),\n246\t        makeCheckpoint({ session_id: undefined }),\n247\t      ]);\n248\t\n249\t      const result = getLastSessionId(state, 'implement-feature', '4-2-session-boundary');\n250\t\n251\t      expect(result).toBe('sess-has-id');\n252\t    });\n253\t\n254\t    it('returns undefined when matching checkpoints have no session_id', () => {\n255\t      const state = makeState([\n256\t        makeCheckpoint({ session_id: undefined }),\n257\t      ]);\n258\t\n259\t      const result = getLastSessionId(state, 'implement-feature', '4-2-session-boundary');\n260\t\n261\t      expect(result).toBeUndefined();\n262\t    });\n263\t  });\n264\t\n265\t  describe('crash recovery scenario', () => {\n266\t    it('session ID retrieved from deserialized state (simulating disk round-trip)', () => {\n267\t      // Simulate a state that was previously persisted and then read back from disk.\n268\t      // The workflow-engine would call readWorkflowState() which returns a WorkflowState.\n269\t      // We verify that resolveSessionId works correctly with such deserialized state.\n270\t      const deserializedState: WorkflowState = {\n271\t        workflow_name: 'harness-run',\n272\t        started: '2026-04-01T00:00:00.000Z',\n273\t        iteration: 3,\n274\t        phase: 'execute',\n275\t        tasks_completed: [\n276\t          {\n277\t            task_name: 'implement-feature',\n278\t            story_key: '4-2-session-boundary',\n279\t            completed_at: '2026-04-01T01:00:00.000Z',\n280\t            session_id: 'sess-persisted-abc',\n281\t          },\n282\t          {\n283\t            task_name: 'write-tests',\n284\t            story_key: '4-2-session-boundary',\n285\t            completed_at: '2026-04-01T02:00:00.000Z',\n286\t            session_id: 'sess-persisted-def',\n287\t          },\n288\t        ],\n289\t        evaluator_scores: [],\n290\t        circuit_breaker: {\n291\t          triggered: false,\n292\t          reason: null,\n293\t          score_history: [],\n294\t        },\n295\t      };\n296\t\n297\t      // After crash recovery, the engine calls resolveSessionId with the persisted state\n298\t      const sessionId = resolveSessionId(\n299\t        'continue',\n300\t        { taskName: 'implement-feature', storyKey: '4-2-session-boundary' },\n301\t        deserializedState,\n302\t      );\n303\t\n304\t      expect(sessionId).toBe('sess-persisted-abc');\n305\t\n306\t      // Different task in the same story gets its own session\n307\t      const testSessionId = resolveSessionId(\n308\t        'continue',\n309\t        { taskName: 'write-tests', storyKey: '4-2-session-boundary' },\n310\t        deserializedState,\n311\t      );\n312\t\n313\t      expect(testSessionId).toBe('sess-persisted-def');\n314\t    });\n315\t  });\n316\t\n317\t  describe('loop iteration behavior', () => {\n318\t    it('fresh in loop: returns undefined for every iteration', () => {\n319\t      // Simulate a loop where previous iterations already recorded checkpoints\n320\t      const state = makeState([\n321\t        makeCheckpoint({ session_id: 'sess-loop-1' }),\n322\t        makeCheckpoint({ session_id: 'sess-loop-2' }),\n323\t      ]);\n324\t\n325\t      // Each loop iteration with session: fresh starts a new session\n326\t      const iter3 = resolveSessionId('fresh', makeKey(), state);\n327\t      expect(iter3).toBeUndefined();\n328\t    });\n329\t\n330\t    it('continue in loop: returns session ID from previous iteration', () => {\n331\t      // Simulate loop iteration 1 completed\n332\t      const stateAfterIter1 = makeState([\n333\t        makeCheckpoint({ session_id: 'sess-loop-iter-1' }),\n334\t      ]);\n335\t\n336\t      // Iteration 2 should continue from iteration 1\n337\t      const iter2SessionId = resolveSessionId('continue', makeKey(), stateAfterIter1);\n338\t      expect(iter2SessionId).toBe('sess-loop-iter-1');\n339\t\n340\t      // After iteration 2 completes, record its session\n341\t      const stateAfterIter2 = recordSessionId(makeKey(), 'sess-loop-iter-2', stateAfterIter1);\n342\t\n343\t      // Iteration 3 should continue from iteration 2 (most recent)\n344\t      const iter3SessionId = resolveSessionId('continue', makeKey(), stateAfterIter2);\n345\t      expect(iter3SessionId).toBe('sess-loop-iter-2');\n346\t    });\n347\t\n348\t    it('fresh in loop: each iteration session ID is independently recorded', () => {\n349\t      let state = makeState([]);\n350\t\n351\t      // Simulate 3 loop iterations, each recording independently\n352\t      state = recordSessionId(makeKey(), 'sess-fresh-1', state);\n353\t      state = recordSessionId(makeKey(), 'sess-fresh-2', state);\n354\t      state = recordSessionId(makeKey(), 'sess-fresh-3', state);\n355\t\n356\t      expect(state.tasks_completed).toHaveLength(3);\n357\t      expect(state.tasks_completed[0].session_id).toBe('sess-fresh-1');\n358\t      expect(state.tasks_completed[1].session_id).toBe('sess-fresh-2');\n359\t      expect(state.tasks_completed[2].session_id).toBe('sess-fresh-3');\n360\t    });\n361\t  });\n362\t});\n363\t"}]},"parent_tool_use_id":"toolu_01N6moxj4qqjLtwBuA4vgPGH","session_id":"45fbbef5-e9ca-4512-91b9-2760b179ad44","uuid":"9d138138-1cc0-4cfa-9d13-6ca7d3886c98","timestamp":"2026-04-02T20:17:03.832Z"}
