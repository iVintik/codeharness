{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XSZyWfUCGXWqcr1y4MWXXY","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n2\timport { mkdtempSync, rmSync, mkdirSync, writeFileSync, existsSync, readFileSync } from 'node:fs';\n3\timport { tmpdir } from 'node:os';\n4\timport { join } from 'node:path';\n5\timport { Command } from 'commander';\n6\timport { parse } from 'yaml';\n7\t\n8\t// Mock output module\n9\tvi.mock('../../lib/output.js', () => ({\n10\t  ok: vi.fn(),\n11\t  fail: vi.fn(),\n12\t  info: vi.fn(),\n13\t  warn: vi.fn(),\n14\t  jsonOutput: vi.fn(),\n15\t}));\n16\t\n17\t// Mock github module\n18\tvi.mock('../../lib/github.js', () => ({\n19\t  isGhAvailable: vi.fn(),\n20\t  findExistingGhIssue: vi.fn(),\n21\t  ghIssueCreate: vi.fn(),\n22\t  ensureLabels: vi.fn(),\n23\t  getRepoFromRemote: vi.fn(),\n24\t}));\n25\t\n26\t// Mock state module\n27\tvi.mock('../../lib/state.js', () => ({\n28\t  readState: vi.fn(),\n29\t  StateFileNotFoundError: class StateFileNotFoundError extends Error {\n30\t    constructor() {\n31\t      super('No state file found');\n32\t      this.name = 'StateFileNotFoundError';\n33\t    }\n34\t  },\n35\t}));\n36\t\n37\timport { registerRetroImportCommand } from '../retro-import.js';\n38\timport { ok, fail, info, warn, jsonOutput } from '../../lib/output.js';\n39\timport { isGhAvailable, findExistingGhIssue, ghIssueCreate, ensureLabels, getRepoFromRemote } from '../../lib/github.js';\n40\timport { readState, StateFileNotFoundError } from '../../lib/state.js';\n41\t\n42\tconst mockIsGhAvailable = vi.mocked(isGhAvailable);\n43\tconst mockFindExistingGhIssue = vi.mocked(findExistingGhIssue);\n44\tconst mockGhIssueCreate = vi.mocked(ghIssueCreate);\n45\tconst mockEnsureLabels = vi.mocked(ensureLabels);\n46\tconst mockGetRepoFromRemote = vi.mocked(getRepoFromRemote);\n47\tconst mockReadState = vi.mocked(readState);\n48\t\n49\tlet testDir: string;\n50\tlet originalCwd: string;\n51\t\n52\tconst RETRO_CONTENT = `\n53\t# Epic 9 Retrospective\n54\t\n55\t## Epic 8 Retro Action Item Status\n56\t\n57\t| # | Action | Status | Notes |\n58\t|---|--------|--------|-------|\n59\t| A1 | Cover run.ts action handler (lines 110-276) | Not done | Permanent technical debt. |\n60\t| A2 | Fix harness initialization bug | Not done | Needs attention. |\n61\t| A3 | Raise overall branch coverage | Regressed | Dropped below target. |\n62\t\n63\t**Summary:** 0 of 3 resolved.\n64\t`;\n65\t\n66\tconst SECTION_RETRO_CONTENT = `\n67\t# Epic 10 Retrospective\n68\t\n69\t## 6. Action Items\n70\t\n71\t### Fix Now (Before Next Session)\n72\t- Fix bare catch blocks in registry.ts\n73\t- Resolve flaky test in pipeline\n74\t\n75\t### Fix Soon (Next Sprint)\n76\t1. Add element type checking to isValidState()\n77\t2. Improve error messages in parser\n78\t\n79\t### Backlog (Track But Not Urgent)\n80\t- Remove StackDetection type duplication\n81\t- Consider migrating to new test runner\n82\t`;\n83\t\n84\tconst MIXED_RETRO_CONTENT_NO_SECTIONS = `\n85\t# Epic 7 Retrospective\n86\t\n87\t## Action Items\n88\t\n89\t| # | Action | Status | Notes |\n90\t|---|--------|--------|-------|\n91\t| A1 | Fix flaky CI pipeline | Regressed | Urgent fix needed. |\n92\t| A2 | Add integration tests for auth module | Not done | Carry forward. |\n93\t`;\n94\t\n95\tbeforeEach(() => {\n96\t  vi.clearAllMocks();\n97\t  testDir = mkdtempSync(join(tmpdir(), 'ch-retro-import-test-'));\n98\t  originalCwd = process.cwd();\n99\t  process.chdir(testDir);\n100\t  process.exitCode = undefined;\n101\t  // Default: no state file (skips GitHub phase)\n102\t  mockReadState.mockImplementation(() => {\n103\t    throw new StateFileNotFoundError();\n104\t  });\n105\t});\n106\t\n107\tafterEach(() => {\n108\t  process.chdir(originalCwd);\n109\t  process.exitCode = undefined;\n110\t  rmSync(testDir, { recursive: true, force: true });\n111\t});\n112\t\n113\tfunction createRetroFile(epicNum: number, content?: string): void {\n114\t  const storyDir = join(testDir, '_bmad-output', 'implementation-artifacts');\n115\t  mkdirSync(storyDir, { recursive: true });\n116\t  writeFileSync(\n117\t    join(storyDir, `epic-${epicNum}-retrospective.md`),\n118\t    content ?? RETRO_CONTENT,\n119\t  );\n120\t}\n121\t\n122\tasync function runRetroImport(args: string[]): Promise<void> {\n123\t  const program = new Command();\n124\t  program.exitOverride();\n125\t  program.option('--json', 'JSON output');\n126\t  registerRetroImportCommand(program);\n127\t  try {\n128\t    await program.parseAsync(['node', 'test', 'retro-import', ...args]);\n129\t  } catch {\n130\t    // Commander throws on exitOverride — ignore\n131\t  }\n132\t}\n133\t\n134\tdescribe('retro-import command', () => {\n135\t  it('parses action items from retro file and imports to issues.yaml', async () => {\n136\t    createRetroFile(9);\n137\t\n138\t    await runRetroImport(['--epic', '9']);\n139\t\n140\t    // Should import 3 items to issues.yaml (ok calls) + parse 3 items (info calls) + 1 skip-github message\n141\t    expect(vi.mocked(ok)).toHaveBeenCalledTimes(3);\n142\t    // Verify issues.yaml was created\n143\t    const issuesPath = join(testDir, '.codeharness', 'issues.yaml');\n144\t    expect(existsSync(issuesPath)).toBe(true);\n145\t    const data = parse(readFileSync(issuesPath, 'utf-8'));\n146\t    expect(data.issues).toHaveLength(3);\n147\t    expect(data.issues[0].source).toBe('retro-epic-9');\n148\t  });\n149\t\n150\t  it('fails with invalid epic number', async () => {\n151\t    await runRetroImport(['--epic', 'abc']);\n152\t\n153\t    expect(vi.mocked(fail)).toHaveBeenCalledWith(\n154\t      expect.stringContaining('Invalid epic number'),\n155\t      expect.any(Object),\n156\t    );\n157\t    expect(process.exitCode).toBe(1);\n158\t  });\n159\t\n160\t  it('fails when retro file does not exist', async () => {\n161\t    await runRetroImport(['--epic', '99']);\n162\t\n163\t    expect(vi.mocked(fail)).toHaveBeenCalledWith(\n164\t      expect.stringContaining('Retro file not found'),\n165\t      expect.any(Object),\n166\t    );\n167\t    expect(process.exitCode).toBe(1);\n168\t  });\n169\t\n170\t  it('handles empty retro file with no action items', async () => {\n171\t    createRetroFile(5, '# Epic 5 Retrospective\\n\\nNo action items.');\n172\t\n173\t    await runRetroImport(['--epic', '5']);\n174\t\n175\t    expect(vi.mocked(info)).toHaveBeenCalledWith('No action items found in retro file');\n176\t  });\n177\t\n178\t  it('outputs JSON when --json is set', async () => {\n179\t    createRetroFile(9);\n180\t\n181\t    await runRetroImport(['--epic', '9', '--json']);\n182\t\n183\t    expect(vi.mocked(jsonOutput)).toHaveBeenCalledTimes(1);\n184\t    const jsonCall = vi.mocked(jsonOutput).mock.calls[0][0];\n185\t    expect(jsonCall).toHaveProperty('imported', 3);\n186\t    expect(jsonCall).toHaveProperty('skipped', 0);\n187\t    expect(jsonCall).toHaveProperty('duplicates', 0);\n188\t    expect(jsonCall).toHaveProperty('issues');\n189\t    const issues = jsonCall['issues'] as unknown[];\n190\t    expect(issues).toHaveLength(3);\n191\t  });\n192\t\n193\t  it('skips GitHub phase when no state file exists', async () => {\n194\t    createRetroFile(9);\n195\t\n196\t    await runRetroImport(['--epic', '9']);\n197\t\n198\t    expect(vi.mocked(info)).toHaveBeenCalledWith('No state file found — skipping GitHub issues');\n199\t  });\n200\t\n201\t  describe('GitHub issue creation', () => {\n202\t    it('creates GitHub issues when state has retro_issue_targets', async () => {\n203\t      createRetroFile(9);\n204\t      mockReadState.mockReturnValue({\n205\t        retro_issue_targets: [{ repo: 'auto', labels: ['retro'] }],\n206\t      } as any);\n207\t      mockIsGhAvailable.mockReturnValue(true);\n208\t      mockGetRepoFromRemote.mockReturnValue('owner/repo');\n209\t      mockFindExistingGhIssue.mockReturnValue(undefined);\n210\t      mockGhIssueCreate.mockReturnValue({ number: 1, url: 'https://github.com/owner/repo/issues/1' });\n211\t\n212\t      await runRetroImport(['--epic', '9']);\n213\t\n214\t      expect(mockGhIssueCreate).toHaveBeenCalled();\n215\t    });\n216\t\n217\t    it('skips GitHub when gh CLI not available', async () => {\n218\t      createRetroFile(9);\n219\t      mockReadState.mockReturnValue({\n220\t        retro_issue_targets: [{ repo: 'auto', labels: ['retro'] }],\n221\t      } as any);\n222\t      mockIsGhAvailable.mockReturnValue(false);\n223\t\n224\t      await runRetroImport(['--epic', '9']);\n225\t\n226\t      expect(vi.mocked(warn)).toHaveBeenCalledWith('gh CLI not available — skipping GitHub issue creation');\n227\t    });\n228\t\n229\t    it('skips GitHub when no retro_issue_targets configured', async () => {\n230\t      createRetroFile(9);\n231\t      mockReadState.mockReturnValue({} as any);\n232\t      mockIsGhAvailable.mockReturnValue(true);\n233\t\n234\t      await runRetroImport(['--epic', '9']);\n235\t\n236\t      expect(vi.mocked(info)).toHaveBeenCalledWith('No retro_issue_targets configured — skipping GitHub issues');\n237\t    });\n238\t\n239\t    it('skips duplicate issues found on GitHub', async () => {\n240\t      createRetroFile(9);\n241\t      mockReadState.mockReturnValue({\n242\t        retro_issue_targets: [{ repo: 'auto', labels: ['retro'] }],\n243\t      } as any);\n244\t      mockIsGhAvailable.mockReturnValue(true);\n245\t      mockGetRepoFromRemote.mockReturnValue('owner/repo');\n246\t      mockFindExistingGhIssue.mockReturnValue({ number: 42, title: 'existing issue', body: '', url: 'https://github.com/owner/repo/issues/42' });\n247\t\n248\t      await runRetroImport(['--epic', '9']);\n249\t\n250\t      expect(mockGhIssueCreate).not.toHaveBeenCalled();\n251\t      expect(vi.mocked(info)).toHaveBeenCalledWith(expect.stringContaining('GitHub issue exists'));\n252\t    });\n253\t\n254\t    it('handles GitHub issue creation errors gracefully', async () => {\n255\t      createRetroFile(9);\n256\t      mockReadState.mockReturnValue({\n257\t        retro_issue_targets: [{ repo: 'auto', labels: ['retro'] }],\n258\t      } as any);\n259\t      mockIsGhAvailable.mockReturnValue(true);\n260\t      mockGetRepoFromRemote.mockReturnValue('owner/repo');\n261\t      mockFindExistingGhIssue.mockReturnValue(undefined);\n262\t      mockGhIssueCreate.mockImplementation(() => { throw new Error('API rate limit'); });\n263\t\n264\t      await runRetroImport(['--epic', '9']);\n265\t\n266\t      expect(vi.mocked(fail)).toHaveBeenCalledWith(expect.stringContaining('API rate limit'));\n267\t    });\n268\t\n269\t    it('skips when git remote cannot be resolved for auto repo', async () => {\n270\t      createRetroFile(9);\n271\t      mockReadState.mockReturnValue({\n272\t        retro_issue_targets: [{ repo: 'auto', labels: ['retro'] }],\n273\t      } as any);\n274\t      mockIsGhAvailable.mockReturnValue(true);\n275\t      mockGetRepoFromRemote.mockReturnValue(undefined);\n276\t\n277\t      await runRetroImport(['--epic', '9']);\n278\t\n279\t      expect(vi.mocked(warn)).toHaveBeenCalledWith(expect.stringContaining('Cannot resolve repo'));\n280\t    });\n281\t\n282\t    it('uses explicit repo when not auto', async () => {\n283\t      createRetroFile(9);\n284\t      mockReadState.mockReturnValue({\n285\t        retro_issue_targets: [{ repo: 'iVintik/codeharness', labels: ['retro'] }],\n286\t      } as any);\n287\t      mockIsGhAvailable.mockReturnValue(true);\n288\t      mockGetRepoFromRemote.mockReturnValue(undefined);\n289\t      mockFindExistingGhIssue.mockReturnValue(undefined);\n290\t      mockGhIssueCreate.mockReturnValue({ number: 10, url: 'https://github.com/iVintik/codeharness/issues/10' });\n291\t\n292\t      await runRetroImport(['--epic', '9']);\n293\t\n294\t      expect(mockGhIssueCreate).toHaveBeenCalled();\n295\t    });\n296\t\n297\t    it('handles state read errors gracefully', async () => {\n298\t      createRetroFile(9);\n299\t      mockReadState.mockImplementation(() => { throw new Error('corrupt state'); });\n300\t\n301\t      await runRetroImport(['--epic', '9']);\n302\t\n303\t      expect(vi.mocked(info)).toHaveBeenCalledWith('Could not read state file — skipping GitHub issues');\n304\t    });\n305\t\n306\t    it('outputs JSON with GitHub result when --json', async () => {\n307\t      createRetroFile(9);\n308\t      mockReadState.mockReturnValue({\n309\t        retro_issue_targets: [{ repo: 'auto', labels: ['retro'] }],\n310\t      } as any);\n311\t      mockIsGhAvailable.mockReturnValue(true);\n312\t      mockGetRepoFromRemote.mockReturnValue('owner/repo');\n313\t      mockFindExistingGhIssue.mockReturnValue(undefined);\n314\t      mockGhIssueCreate.mockReturnValue({ number: 1, url: 'https://github.com/owner/repo/issues/1' });\n315\t\n316\t      await runRetroImport(['--epic', '9', '--json']);\n317\t\n318\t      const jsonCall = vi.mocked(jsonOutput).mock.calls[0][0];\n319\t      expect(jsonCall).toHaveProperty('github');\n320\t      const github = jsonCall['github'] as Record<string, unknown>;\n321\t      expect(github.created).toBe(3);\n322\t    });\n323\t\n324\t    it('handles negative epic number', async () => {\n325\t      await runRetroImport(['--epic', '-1']);\n326\t\n327\t      expect(vi.mocked(fail)).toHaveBeenCalledWith(\n328\t        expect.stringContaining('Invalid epic number'),\n329\t        expect.any(Object),\n330\t      );\n331\t      expect(process.exitCode).toBe(1);\n332\t    });\n333\t\n334\t    it('handles zero epic number', async () => {\n335\t      await runRetroImport(['--epic', '0']);\n336\t\n337\t      expect(vi.mocked(fail)).toHaveBeenCalledWith(\n338\t        expect.stringContaining('Invalid epic number'),\n339\t        expect.any(Object),\n340\t      );\n341\t      expect(process.exitCode).toBe(1);\n342\t    });\n343\t\n344\t    it('handles file read error', async () => {\n345\t      // Create the directory but make the file unreadable\n346\t      const storyDir = join(testDir, '_bmad-output', 'implementation-artifacts');\n347\t      mkdirSync(storyDir, { recursive: true });\n348\t      // Create a directory with the same name as the expected file to cause read error\n349\t      mkdirSync(join(storyDir, 'epic-7-retrospective.md'), { recursive: true });\n350\t\n351\t      await runRetroImport(['--epic', '7']);\n352\t\n353\t      expect(vi.mocked(fail)).toHaveBeenCalledWith(\n354\t        expect.stringContaining('Failed to read retro file'),\n355\t        expect.any(Object),\n356\t      );\n357\t      expect(process.exitCode).toBe(1);\n358\t    });\n359\t\n360\t    it('outputs JSON for empty retro file', async () => {\n361\t      createRetroFile(5, '# Epic 5 Retrospective\\n\\nNo action items.');\n362\t\n363\t      await runRetroImport(['--epic', '5', '--json']);\n364\t\n365\t      expect(vi.mocked(jsonOutput)).toHaveBeenCalledWith(\n366\t        expect.objectContaining({ imported: 0, skipped: 0, issues: [] }),\n367\t      );\n368\t    });\n369\t\n370\t    it('truncates long action item titles', async () => {\n371\t      const longTitle = 'A'.repeat(200);\n372\t      createRetroFile(9, `# Epic 9 Retrospective\\n\\n## Action Items\\n\\n| # | Action | Status | Notes |\\n|---|--------|--------|-------|\\n| A1 | ${longTitle} | Not done | Note. |\\n`);\n373\t\n374\t      await runRetroImport(['--epic', '9']);\n375\t\n376\t      const infoCalls = vi.mocked(info).mock.calls.map(c => c[0]);\n377\t      const parsedCall = infoCalls.find(c => typeof c === 'string' && c.startsWith('Parsed:'));\n378\t      if (parsedCall) {\n379\t        // Title should be truncated to MAX_TITLE_LENGTH (120)\n380\t        expect(parsedCall.length).toBeLessThanOrEqual(200);\n381\t      }\n382\t    });\n383\t  });\n384\t\n385\t  describe('issues.yaml import — section-based', () => {\n386\t    it('imports Fix Now items with priority=high', async () => {\n387\t      createRetroFile(10, SECTION_RETRO_CONTENT);\n388\t\n389\t      await runRetroImport(['--epic', '10']);\n390\t\n391\t      const issuesPath = join(testDir, '.codeharness', 'issues.yaml');\n392\t      expect(existsSync(issuesPath)).toBe(true);\n393\t      const data = parse(readFileSync(issuesPath, 'utf-8'));\n394\t      const highItems = data.issues.filter((i: any) => i.priority === 'high');\n395\t      expect(highItems).toHaveLength(2);\n396\t      expect(highItems[0].title).toBe('Fix bare catch blocks in registry.ts');\n397\t      expect(highItems[1].title).toBe('Resolve flaky test in pipeline');\n398\t    });\n399\t\n400\t    it('imports Fix Soon items with priority=medium', async () => {\n401\t      createRetroFile(10, SECTION_RETRO_CONTENT);\n402\t\n403\t      await runRetroImport(['--epic', '10']);\n404\t\n405\t      const issuesPath = join(testDir, '.codeharness', 'issues.yaml');\n406\t      const data = parse(readFileSync(issuesPath, 'utf-8'));\n407\t      const mediumItems = data.issues.filter((i: any) => i.priority === 'medium');\n408\t      expect(mediumItems).toHaveLength(2);\n409\t      expect(mediumItems[0].title).toBe('Add element type checking to isValidState()');\n410\t    });\n411\t\n412\t    it('skips Backlog items (not imported)', async () => {\n413\t      createRetroFile(10, SECTION_RETRO_CONTENT);\n414\t\n415\t      await runRetroImport(['--epic', '10']);\n416\t\n417\t      const issuesPath = join(testDir, '.codeharness', 'issues.yaml');\n418\t      const data = parse(readFileSync(issuesPath, 'utf-8'));\n419\t      // Only 4 items (2 Fix Now + 2 Fix Soon), no Backlog\n420\t      expect(data.issues).toHaveLength(4);\n421\t      // Verify backlog items were logged as skipped\n422\t      expect(vi.mocked(info)).toHaveBeenCalledWith(\n423\t        expect.stringContaining('Skipped (backlog'),\n424\t      );\n425\t    });\n426\t\n427\t    it('sets source to retro-epic-<n> on all imported issues', async () => {\n428\t      createRetroFile(10, SECTION_RETRO_CONTENT);\n429\t\n430\t      await runRetroImport(['--epic', '10']);\n431\t\n432\t      const issuesPath = join(testDir, '.codeharness', 'issues.yaml');\n433\t      const data = parse(readFileSync(issuesPath, 'utf-8'));\n434\t      for (const issue of data.issues) {\n435\t        expect(issue.source).toBe('retro-epic-10');\n436\t      }\n437\t    });\n438\t  });\n439\t\n440\t  describe('issues.yaml import — table-based fallback', () => {\n441\t    it('falls back to table parser when no subsections found', async () => {\n442\t      createRetroFile(7, MIXED_RETRO_CONTENT_NO_SECTIONS);\n443\t\n444\t      await runRetroImport(['--epic', '7']);\n445\t\n446\t      const issuesPath = join(testDir, '.codeharness', 'issues.yaml');\n447\t      expect(existsSync(issuesPath)).toBe(true);\n448\t      const data = parse(readFileSync(issuesPath, 'utf-8'));\n449\t      expect(data.issues).toHaveLength(2);\n450\t      expect(data.issues[0].source).toBe('retro-epic-7');\n451\t    });\n452\t\n453\t    it('maps derivePriority=1 (regressed) to high', async () => {\n454\t      createRetroFile(7, MIXED_RETRO_CONTENT_NO_SECTIONS);\n455\t\n456\t      await runRetroImport(['--epic', '7']);\n457\t\n458\t      const issuesPath = join(testDir, '.codeharness', 'issues.yaml');\n459\t      const data = parse(readFileSync(issuesPath, 'utf-8'));\n460\t      // A1 is Regressed -> derivePriority returns 1 -> high\n461\t      const a1Issue = data.issues.find((i: any) => i.title === 'Fix flaky CI pipeline');\n462\t      expect(a1Issue.priority).toBe('high');\n463\t    });\n464\t\n465\t    it('maps derivePriority=2 (default) to medium', async () => {\n466\t      createRetroFile(7, MIXED_RETRO_CONTENT_NO_SECTIONS);\n467\t\n468\t      await runRetroImport(['--epic', '7']);\n469\t\n470\t      const issuesPath = join(testDir, '.codeharness', 'issues.yaml');\n471\t      const data = parse(readFileSync(issuesPath, 'utf-8'));\n472\t      // A2 is Not done, no urgency -> derivePriority returns 2 -> medium\n473\t      const a2Issue = data.issues.find((i: any) => i.title === 'Add integration tests for auth module');\n474\t      expect(a2Issue.priority).toBe('medium');\n475\t    });\n476\t  });\n477\t\n478\t  describe('issues.yaml import — duplicate detection', () => {\n479\t    it('skips duplicate items based on word overlap', async () => {\n480\t      // Pre-populate issues.yaml with an existing issue\n481\t      const codeharnessDir = join(testDir, '.codeharness');\n482\t      mkdirSync(codeharnessDir, { recursive: true });\n483\t      writeFileSync(\n484\t        join(codeharnessDir, 'issues.yaml'),\n485\t        'issues:\\n  - id: issue-001\\n    title: Fix bare catch blocks in registry.ts\\n    source: manual\\n    priority: medium\\n    status: backlog\\n    created_at: \"2026-01-01T00:00:00.000Z\"\\n',\n486\t      );\n487\t\n488\t      createRetroFile(10, SECTION_RETRO_CONTENT);\n489\t\n490\t      await runRetroImport(['--epic', '10']);\n491\t\n492\t      const data = parse(readFileSync(join(codeharnessDir, 'issues.yaml'), 'utf-8'));\n493\t      // One duplicate skipped, so 3 new + 1 existing = 4\n494\t      expect(data.issues).toHaveLength(4);\n495\t      // Verify duplicate message was logged\n496\t      expect(vi.mocked(info)).toHaveBeenCalledWith(\n497\t        expect.stringContaining('Skipped (duplicate'),\n498\t      );\n499\t    });\n500\t\n501\t    it('does not modify existing issues when duplicate found', async () => {\n502\t      const codeharnessDir = join(testDir, '.codeharness');\n503\t      mkdirSync(codeharnessDir, { recursive: true });\n504\t      writeFileSync(\n505\t        join(codeharnessDir, 'issues.yaml'),\n506\t        'issues:\\n  - id: issue-001\\n    title: Fix bare catch blocks in registry.ts\\n    source: manual\\n    priority: low\\n    status: in-progress\\n    created_at: \"2026-01-01T00:00:00.000Z\"\\n',\n507\t      );\n508\t\n509\t      createRetroFile(10, SECTION_RETRO_CONTENT);\n510\t\n511\t      await runRetroImport(['--epic', '10']);\n512\t\n513\t      const data = parse(readFileSync(join(codeharnessDir, 'issues.yaml'), 'utf-8'));\n514\t      // The existing issue should retain its original values\n515\t      const existing = data.issues.find((i: any) => i.id === 'issue-001');\n516\t      expect(existing.priority).toBe('low');\n517\t      expect(existing.status).toBe('in-progress');\n518\t    });\n519\t  });\n520\t\n521\t  describe('issues.yaml import — JSON output', () => {\n522\t    it('JSON output includes imported/skipped/duplicates counts and issues array', async () => {\n523\t      // Pre-populate one duplicate\n524\t      const codeharnessDir = join(testDir, '.codeharness');\n525\t      mkdirSync(codeharnessDir, { recursive: true });\n526\t      writeFileSync(\n527\t        join(codeharnessDir, 'issues.yaml'),\n528\t        'issues:\\n  - id: issue-001\\n    title: Fix bare catch blocks in registry.ts\\n    source: manual\\n    priority: medium\\n    status: backlog\\n    created_at: \"2026-01-01T00:00:00.000Z\"\\n',\n529\t      );\n530\t\n531\t      createRetroFile(10, SECTION_RETRO_CONTENT);\n532\t\n533\t      await runRetroImport(['--epic', '10', '--json']);\n534\t\n535\t      expect(vi.mocked(jsonOutput)).toHaveBeenCalledTimes(1);\n536\t      const jsonCall = vi.mocked(jsonOutput).mock.calls[0][0];\n537\t      expect(jsonCall).toHaveProperty('imported', 3);\n538\t      expect(jsonCall).toHaveProperty('skipped', 2); // 2 backlog items\n539\t      expect(jsonCall).toHaveProperty('duplicates', 1);\n540\t      const issues = jsonCall['issues'] as Array<Record<string, unknown>>;\n541\t      expect(issues).toHaveLength(3);\n542\t      // Each issue has id, title, source, priority\n543\t      for (const issue of issues) {\n544\t        expect(issue).toHaveProperty('id');\n545\t        expect(issue).toHaveProperty('title');\n546\t        expect(issue).toHaveProperty('source', 'retro-epic-10');\n547\t        expect(issue).toHaveProperty('priority');\n548\t      }\n549\t    });\n550\t  });\n551\t\n552\t  describe('issues.yaml import — creates file when missing', () => {\n553\t    it('creates issues.yaml when it does not exist', async () => {\n554\t      const issuesPath = join(testDir, '.codeharness', 'issues.yaml');\n555\t      expect(existsSync(issuesPath)).toBe(false);\n556\t\n557\t      createRetroFile(10, SECTION_RETRO_CONTENT);\n558\t\n559\t      await runRetroImport(['--epic', '10']);\n560\t\n561\t      expect(existsSync(issuesPath)).toBe(true);\n562\t      const data = parse(readFileSync(issuesPath, 'utf-8'));\n563\t      expect(data.issues).toHaveLength(4);\n564\t    });\n565\t  });\n566\t\n567\t  describe('issues.yaml import — error and edge cases', () => {\n568\t    it('missing retro file exits with code 1', async () => {\n569\t      await runRetroImport(['--epic', '99']);\n570\t\n571\t      expect(vi.mocked(fail)).toHaveBeenCalledWith(\n572\t        expect.stringContaining('Retro file not found'),\n573\t        expect.any(Object),\n574\t      );\n575\t      expect(process.exitCode).toBe(1);\n576\t    });\n577\t\n578\t    it('empty retro file with no action items exits with code 0', async () => {\n579\t      createRetroFile(5, '# Epic 5 Retrospective\\n\\nNo action items here.');\n580\t\n581\t      await runRetroImport(['--epic', '5']);\n582\t\n583\t      expect(vi.mocked(info)).toHaveBeenCalledWith('No action items found in retro file');\n584\t      expect(process.exitCode).toBeUndefined();\n585\t    });\n586\t  });\n587\t});\n588\t"}]},"parent_tool_use_id":"toolu_01U1QxzZy7C659GJM4oxEmEf","session_id":"3f15b50c-2c9b-40fa-9e63-9fad2199af43","uuid":"1c69f3c7-6a70-419a-948b-d0e56780d325","timestamp":"2026-04-03T02:27:42.266Z"}
