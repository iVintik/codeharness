a default StoryState */\n    57→function defaultStoryState(): StoryState {\n    58→  return {\n    59→    status: 'backlog',\n    60→    attempts: 0,\n    61→    lastAttempt: null,\n    62→    lastError: null,\n    63→    proofPath: null,\n    64→    acResults: null,\n    65→  };\n    66→}\n    67→\n    68→/**\n    69→ * Write state to disk atomically: write to tmp, then rename.\n    70→ */\n    71→export function writeStateAtomic(state: SprintState): Result<void> {\n    72→  try {\n    73→    const data = JSON.stringify(state, null, 2) + '\\n';\n    74→    const tmp = tmpPath();\n    75→    const final = statePath();\n    76→    writeFileSync(tmp, data, 'utf-8');\n    77→    renameSync(tmp, final);\n    78→    return ok(undefined);\n    79→  } catch (err: unknown) {\n    80→    const msg = err instanceof Error ? err.message : String(err);"}]},"parent_tool_use_id":"toolu_01GUR1dsNVzUTLzShG1rFUcD","session_id":"0deb1693-f450-4ee3-ba9f-130c7ba0aec5","uuid":"d9673841-46a6-459b-a18f-ba31e9ce429f","timestamp":"2026-03-20T09:12:15.529Z"}
