{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PBbAdGKZmTsobodYWH3Wt8","type":"tool_result","content":"     1→/**\n     2→ * Dockerfile validator — checks Dockerfiles against 6 required rule categories.\n     3→ * Returns structured gaps for audit integration.\n     4→ *\n     5→ * FR23 (formalized Dockerfile rules), FR24 (audit validates against rules).\n     6→ */\n     7→\n     8→import { existsSync, readFileSync } from 'node:fs';\n     9→import { join } from 'node:path';\n    10→import { ok, fail } from '../../types/result.js';\n    11→import type { Result } from '../../types/result.js';\n    12→\n    13→/** A single gap found during Dockerfile validation */\n    14→export interface DockerfileGap {\n    15→  readonly rule: string;\n    16→  readonly description: string;\n    17→  readonly suggestedFix: string;\n    18→  readonly line?: number;\n    19→}\n    20→\n    21→/** Result of validating a Dockerfile against all rules */\n    22→export interface DockerfileValidationResult {\n    23→  readonly passed: boolean;\n    24→  readonly gaps: DockerfileGap[];\n    25→  readonly warnings: string[];\n    26→}\n    27→\n    28→/** Internal rules structure */\n    29→interface DockerfileRules {\n    30→  readonly requirePinnedFrom: boolean;\n    31→  readonly requireBinaryOnPath: boolean;\n    32→  readonly verificationTools: string[];\n    33→  readonly forbidSourceCopy: boolean;\n    34→  readonly requireNonRootUser: boolean;\n    35→  readonly requireCacheCleanup: boolean;\n    36→}\n    37→\n    38→const DEFAULT_RULES: DockerfileRules = {\n    39→  requirePinnedFrom: true,\n    40→  requireBinaryOnPath: true,\n    41→  verificationTools: ['curl', 'jq'],\n    42→  forbidSourceCopy: true,\n    43→  requireNonRootUser: true,\n    44→  requireCacheCleanup: true,\n    45→};\n    46→\n    47→function dfGap(rule: string, description: string, suggestedFix: string, line?: number): DockerfileGap {\n    48→  const g: DockerfileGap = { rule, description, suggestedFix };\n    49→  if (line !== undefined) return { ...g, line };\n    50→  return g;\n    51→}\n    52→\n    53→/**\n    54→ * Load rules from patches/infra/dockerfile-rules.md or fall back to defaults.\n    55→ * The markdown is documentation — the actual rules are hardcoded defaults.\n    56→ * Returns rules + any warnings about missing file.\n    57→ */\n    58→export function loadRules(projectDir: string): { rules: DockerfileRules; warnings: string[] } {\n    59→  const rulesPath = join(projectDir, 'patches', 'infra', 'dockerfile-rules.md');\n    60→  if (!existsSync(rulesPath)) {\n    61→    return {\n    62→      rules: DEFAULT_RULES,\n    63→      warnings: ['dockerfile-rules.md not found -- using defaults.'],\n    64→    };\n    65→  }\n    66→  return { rules: DEFAULT_RULES, warnings: [] };\n    67→}\n    68→\n    69→// ─── Rule checkers ──────────────────────────────────────────────────────────\n    70→\n    71→function checkPinnedFrom(lines: string[]): DockerfileGap[] {\n    72→  const gaps: DockerfileGap[] = [];\n    73→  for (let i = 0; i < lines.length; i++) {\n    74→    if (!/^\\s*FROM\\s+/i.test(lines[i])) continue;\n    75→    const ref = lines[i].replace(/^\\s*FROM\\s+/i, '').split(/\\s+/)[0];\n    76→    if (ref.endsWith(':latest')) {\n    77→      gaps.push(dfGap('pinned-from', `unpinned base image -- use specific version.`, `Pin ${ref} to a specific version tag`, i + 1));\n    78→    } else if (!ref.includes(':') && !ref.includes('@')) {\n    79→      gaps.push(dfGap('pinned-from', `unpinned base image -- use specific version.`, `Pin ${ref} to a specific version tag (e.g., ${ref}:22-slim)`, i + 1));\n    80→    }\n    81→  }\n    82→  return gaps;\n    83→}\n    84→\n    85→function checkBinaryOnPath(lines: string[]): DockerfileGap[] {\n    86→  const content = lines.join('\\n');\n    87→  const hasBinary =\n    88→    /npm\\s+install\\s+(-g|--global)\\b/i.test(content) ||\n    89→    /pip\\s+install\\b/i.test(content) ||\n    90→    /COPY\\s+--from=/i.test(content);\n    91→  if (!hasBinary) {\n    92→    return [dfGap('binary-on-path', 'project binary not installed.', 'Add npm install -g, pip install, or COPY --from to install the project binary')];\n    93→  }\n    94→  return [];\n    95→}\n    96→\n    97→function checkVerificationTools(lines: string[], tools: string[]): DockerfileGap[] {\n    98→  const content = lines.join('\\n').toLowerCase();\n    99→  const gaps: DockerfileGap[] = [];\n   100→  const hasApt = content.includes('apt-get install');\n   101→  const hasApk = content.includes('apk add');\n   102→  for (const tool of tools) {\n   103→    const installed =\n   104→      (hasApt && content.includes(tool)) ||\n   105→      (hasApk && content.includes(tool));\n   106→    if (!installed) {\n   107→      gaps.push(dfGap('verification-tools', `verification tool missing: ${tool}`, `Install ${tool} via apt-get install or apk add`));\n   108→    }\n   109→  }\n   110→  return gaps;\n   111→}\n   112→\n   113→function checkNoSourceCopy(lines: string[]): DockerfileGap[] {\n   114→  const gaps: DockerfileGap[] = [];\n   115→  const sourcePatterns = [/COPY\\s+(?:--\\S+\\s+)*src\\//i, /COPY\\s+(?:--\\S+\\s+)*lib\\//i, /COPY\\s+(?:--\\S+\\s+)*test\\//i];\n   116→  for (let i = 0; i < lines.length; i++) {\n   117→    for (const pattern of sourcePatterns) {\n   118→      if (pattern.test(lines[i])) {\n   119→        gaps.push(dfGap('no-source-copy', 'source code copied into container -- use build artifact instead.', 'Use COPY --from=builder or COPY dist/ instead of copying source', i + 1));\n   120→      }\n   121→    }\n   122→  }\n   123→  return gaps;\n   124→}\n   125→\n   126→function checkNonRootUser(lines: string[]): DockerfileGap[] {\n   127→  const userLines = lines.filter(l => /^\\s*USER\\s+/i.test(l));\n   128→  if (userLines.length === 0) {\n   129→    return [dfGap('non-root-user', 'no non-root USER instruction found.', 'Add USER <non-root-user> instruction (e.g., USER node)')];\n   130→  }\n   131→  const hasNonRoot = userLines.some(l => {\n   132→    const user = l.replace(/^\\s*USER\\s+/i, '').trim().split(/\\s+/)[0];\n   133→    return user.toLowerCase() !== 'root';\n   134→  });\n   135→  if (!hasNonRoot) {\n   136→    return [dfGap('non-root-user', 'no non-root USER instruction found.', 'Add USER <non-root-user> instruction (e.g., USER node)')];\n   137→  }\n   138→  return [];\n   139→}\n   140→\n   141→function checkCacheCleanup(lines: string[]): DockerfileGap[] {\n   142→  const content = lines.join('\\n');\n   143→  const hasCleanup =\n   144→    /rm\\s+-rf\\s+\\/var\\/lib\\/apt\\/lists/i.test(content) ||\n   145→    /npm\\s+cache\\s+clean/i.test(content) ||\n   146→    /pip\\s+cache\\s+purge/i.test(content);\n   147→  if (!hasCleanup) {\n   148→    return [dfGap('cache-cleanup', 'no cache cleanup detected.', 'Add cache cleanup: rm -rf /var/lib/apt/lists/*, npm cache clean --force, or pip cache purge')];\n   149→  }\n   150→  return [];\n   151→}\n   152→\n   153→// ─── Main validator ─────────────────────────────────────────────────────────\n   154→\n   155→/**\n   156→ * Validate a Dockerfile against all 6 rule categories.\n   157→ * Returns Result<DockerfileValidationResult>.\n   158→ */\n   159→export function validateDockerfile(projectDir: string): Result<DockerfileValidationResult> {\n   160→  const dfPath = join(projectDir, 'Dockerfile');\n   161→\n   162→  if (!existsSync(dfPath)) {\n   163→    return fail('No Dockerfile found');\n   164→  }\n   165→\n   166→  let content: string;\n   167→  try {\n   168→    content = readFileSync(dfPath, 'utf-8');\n   169→  } catch {\n   170→    return fail('Dockerfile exists but could not be read');\n   171→  }\n   172→\n   173→  const lines = content.split('\\n');\n   174→  const fromLines = lines.filter(l => /^\\s*FROM\\s+/i.test(l));\n   175→  if (fromLines.length === 0) {\n   176→    return fail('Dockerfile has no FROM instruction');\n   177→  }\n   178→\n   179→  const { rules, warnings } = loadRules(projectDir);\n   180→  const gaps: DockerfileGap[] = [];\n   181→\n   182→  if (rules.requirePinnedFrom) gaps.push(...checkPinnedFrom(lines));\n   183→  if (rules.requireBinaryOnPath) gaps.push(...checkBinaryOnPath(lines));\n   184→  gaps.push(...checkVerificationTools(lines, rules.verificationTools));\n   185→  if (rules.forbidSourceCopy) gaps.push(...checkNoSourceCopy(lines));\n   186→  if (rules.requireNonRootUser) gaps.push(...checkNonRootUser(lines));\n   187→  if (rules.requireCacheCleanup) gaps.push(...checkCacheCleanup(lines));\n   188→\n   189→  return ok({\n   190→    passed: gaps.length === 0,\n   191→    gaps,\n   192→    warnings,\n   193→  });\n   194→}\n   195→"}]},"parent_tool_use_id":"toolu_0181DMH7MoNUmcSCK8CMK5EF","session_id":"ef2f2ce5-c013-4ad4-b6dd-a80c40f8ca85","uuid":"025dd3d8-f291-4bf2-9702-ae74855f9566","timestamp":"2026-03-21T05:26:00.028Z"}
