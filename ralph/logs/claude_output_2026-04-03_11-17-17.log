{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011vc5ExvfehGJSWxV9SqMaK","type":"tool_result","content":"1\t{\n2\t  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n3\t  \"$id\": \"https://codeharness.dev/schemas/agent.schema.json\",\n4\t  \"title\": \"Codeharness Agent\",\n5\t  \"description\": \"Schema for codeharness agent configuration YAML files\",\n6\t  \"type\": \"object\",\n7\t  \"required\": [\"name\", \"role\", \"persona\"],\n8\t  \"properties\": {\n9\t    \"name\": {\n10\t      \"type\": \"string\",\n11\t      \"minLength\": 1,\n12\t      \"description\": \"Agent identifier\"\n13\t    },\n14\t    \"role\": {\n15\t      \"type\": \"object\",\n16\t      \"required\": [\"title\", \"purpose\"],\n17\t      \"properties\": {\n18\t        \"title\": {\n19\t          \"type\": \"string\",\n20\t          \"minLength\": 1,\n21\t          \"description\": \"Agent's role title\"\n22\t        },\n23\t        \"purpose\": {\n24\t          \"type\": \"string\",\n25\t          \"minLength\": 1,\n26\t          \"description\": \"What this agent does\"\n27\t        }\n28\t      },\n29\t      \"additionalProperties\": false\n30\t    },\n31\t    \"persona\": {\n32\t      \"type\": \"object\",\n33\t      \"required\": [\"identity\", \"communication_style\", \"principles\"],\n34\t      \"properties\": {\n35\t        \"identity\": {\n36\t          \"type\": \"string\",\n37\t          \"minLength\": 1,\n38\t          \"description\": \"Who this agent is\"\n39\t        },\n40\t        \"communication_style\": {\n41\t          \"type\": \"string\",\n42\t          \"minLength\": 1,\n43\t          \"description\": \"How this agent communicates\"\n44\t        },\n45\t        \"principles\": {\n46\t          \"type\": \"array\",\n47\t          \"items\": {\n48\t            \"type\": \"string\",\n49\t            \"minLength\": 1\n50\t          },\n51\t          \"minItems\": 1,\n52\t          \"description\": \"Behavioral principles\"\n53\t        }\n54\t      },\n55\t      \"additionalProperties\": false\n56\t    },\n57\t    \"personality\": {\n58\t      \"type\": \"object\",\n59\t      \"required\": [\"traits\"],\n60\t      \"properties\": {\n61\t        \"traits\": {\n62\t          \"type\": \"object\",\n63\t          \"additionalProperties\": {\n64\t            \"type\": \"number\",\n65\t            \"minimum\": 0,\n66\t            \"maximum\": 1\n67\t          },\n68\t          \"description\": \"PersonaNexus-compatible traits with values constrained to 0-1\"\n69\t        }\n70\t      },\n71\t      \"additionalProperties\": false\n72\t    },\n73\t    \"disallowedTools\": {\n74\t      \"type\": \"array\",\n75\t      \"items\": {\n76\t        \"type\": \"string\"\n77\t      },\n78\t      \"description\": \"Tools this agent is not allowed to use\"\n79\t    },\n80\t    \"prompt_template\": {\n81\t      \"type\": \"string\",\n82\t      \"description\": \"Task-specific prompt template included in compiled instructions\"\n83\t    }\n84\t  },\n85\t  \"additionalProperties\": false\n86\t}\n87\t"}]},"parent_tool_use_id":"toolu_01SZLN4SkuoJ5YcT8ii8meqz","session_id":"2c102368-34ec-49f5-8d34-59f136ae42aa","uuid":"ff1a50ce-e987-41bf-b1c2-9f1eb7631751","timestamp":"2026-04-03T07:19:14.970Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01C4KFhYqZzXVZ1vxij6AR4Z","type":"tool_result","content":"1\t{\n2\t  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n3\t  \"$id\": \"https://codeharness.dev/schemas/workflow.schema.json\",\n4\t  \"title\": \"Codeharness Workflow\",\n5\t  \"description\": \"Schema for codeharness workflow YAML files\",\n6\t  \"type\": \"object\",\n7\t  \"required\": [\"tasks\", \"flow\"],\n8\t  \"properties\": {\n9\t    \"tasks\": {\n10\t      \"type\": \"object\",\n11\t      \"description\": \"Named task definitions\",\n12\t      \"additionalProperties\": {\n13\t        \"$ref\": \"#/definitions/task\"\n14\t      }\n15\t    },\n16\t    \"flow\": {\n17\t      \"type\": \"array\",\n18\t      \"description\": \"Ordered execution steps — task references or loop blocks\",\n19\t      \"items\": {\n20\t        \"oneOf\": [\n21\t          {\n22\t            \"type\": \"string\",\n23\t            \"description\": \"Task reference by name\"\n24\t          },\n25\t          {\n26\t            \"type\": \"object\",\n27\t            \"required\": [\"loop\"],\n28\t            \"properties\": {\n29\t              \"loop\": {\n30\t                \"type\": \"array\",\n31\t                \"items\": {\n32\t                  \"type\": \"string\"\n33\t                },\n34\t                \"minItems\": 1,\n35\t                \"description\": \"Task names to repeat in a loop\"\n36\t              }\n37\t            },\n38\t            \"additionalProperties\": false,\n39\t            \"description\": \"Loop block containing task references\"\n40\t          }\n41\t        ]\n42\t      }\n43\t    }\n44\t  },\n45\t  \"additionalProperties\": false,\n46\t  \"definitions\": {\n47\t    \"task\": {\n48\t      \"type\": \"object\",\n49\t      \"required\": [\"agent\"],\n50\t      \"properties\": {\n51\t        \"agent\": {\n52\t          \"type\": \"string\",\n53\t          \"description\": \"Agent identifier for this task\"\n54\t        },\n55\t        \"scope\": {\n56\t          \"type\": \"string\",\n57\t          \"enum\": [\"per-story\", \"per-run\"],\n58\t          \"default\": \"per-story\",\n59\t          \"description\": \"Execution scope — per-story or per-run\"\n60\t        },\n61\t        \"session\": {\n62\t          \"type\": \"string\",\n63\t          \"enum\": [\"fresh\", \"continue\"],\n64\t          \"default\": \"fresh\",\n65\t          \"description\": \"Session strategy — fresh or continue\"\n66\t        },\n67\t        \"source_access\": {\n68\t          \"type\": \"boolean\",\n69\t          \"default\": true,\n70\t          \"description\": \"Whether the agent has source code access\"\n71\t        },\n72\t        \"prompt_template\": {\n73\t          \"type\": \"string\",\n74\t          \"description\": \"Prompt template with {{variable}} placeholders\"\n75\t        },\n76\t        \"input_contract\": {\n77\t          \"type\": \"object\",\n78\t          \"description\": \"Input contract schema for this task\"\n79\t        },\n80\t        \"output_contract\": {\n81\t          \"type\": \"object\",\n82\t          \"description\": \"Output contract schema for this task\"\n83\t        },\n84\t        \"max_budget_usd\": {\n85\t          \"type\": \"number\",\n86\t          \"description\": \"Maximum budget in USD for this task execution\"\n87\t        }\n88\t      },\n89\t      \"additionalProperties\": false\n90\t    }\n91\t  }\n92\t}\n93\t"}]},"parent_tool_use_id":"toolu_01SZLN4SkuoJ5YcT8ii8meqz","session_id":"2c102368-34ec-49f5-8d34-59f136ae42aa","uuid":"01f36853-1890-4a13-abaf-8a420fccf478","timestamp":"2026-04-03T07:19:14.972Z"}
