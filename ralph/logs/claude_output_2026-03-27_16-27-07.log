ty stack');\n  });\n\n  it('includes multiple services as a criterion', () => {\n    const start = instructions.indexOf('VERIFICATION TIER TAGGING');\n    const end = instructions.indexOf('<!-- Developer context section');\n    const section = instructions.slice(start, end);\n    expect(section).toContain('multiple services');\n  });\n});\n\n// ─── AC9: escalate criteria ──────────────────────────────────────────────────\n\ndescribe('AC9: escalate criteria in decision tree', () => {\n  it('includes physical hardware as a criterion', () => {\n    const start = instructions.indexOf('VERIFICATION TIER TAGGING');\n    const end = instructions.indexOf('<!-- Developer context section');\n    const section = instructions.slice(start, end);\n    expect(section).toContain('physical hardware');\n  });\n\n  it('includes human visual judgment as a criterion', () => {\n    const start = instructions.indexOf('VERIFICATION TIER TAGGING');\n    const end = instructions.indexOf('<!-- Developer context section');\n    const section = instructions.slice(start, end);\n    expect(section).toContain('human visual judgment');\n  });\n\n  it('includes paid external services as a criterion', () => {\n    const start = instructions.indexOf('VERIFICATION TIER TAGGING');\n    const end = instructions.indexOf('<!-- Developer context section');\n    const section = instructions.slice(start, end);\n    expect(section).toContain('paid external services');\n  });\n\n  it('includes GPU as a criterion', () => {\n    const start = instructions.indexOf('VERIFICATION TIER TAGGING');\n    const end = instructions.indexOf('<!-- Developer context section');\n    const section = instructions.slice(start, end);\n    expect(section).toContain('GPU');\n  });\n});\n\n// ─── AC10: harness-run Step 3a regression check ──────────────────────────────\n\ndescribe('AC10: harness-run Step 3a regression check (read-only)', () => {\n  it('contains the four-tier decision tree in Step 3a', () => {\n    expect(harnessRun).