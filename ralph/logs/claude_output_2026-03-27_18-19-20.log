eRead\":112459,\"cacheWrite\":1612,\"calls\":2},\"15-4-fix-ts-compilation-errors\":{\"input\":49,\"output\":16279,\"cacheRead\":2839123,\"cacheWrite\":38514,\"calls\":47},\"15-5-lint-rule-bare-exception-swallowing\":{\"input\":79,\"output\":15036,\"cacheRead\":4579768,\"cacheWrite\":40796,\"calls\":79},\"14-4-observ\":{\"input\":2,\"output\":226,\"cacheRead\":122358,\"cacheWrite\":1198,\"calls\":2},\"14-4-observability-backend\":{\"input\":13,\"output\":4227,\"cacheRead\":530413,\"cacheWrite\":12243,\"calls\":13},\"14-4-observability-backend-\":{\"input\":1,\"output\":508,\"cacheRead\":35125,\"cacheWrite\":4521,\"calls\":1},\"16-1-verification-tier-type-and-utilities\":{\"input\":38,\"output\":9948,\"cacheRead\":1991939,\"cacheWrite\":16918,\"calls\":36},\"14-6-subag\":{\"input\":2,\"output\":1142,\"cacheRead\":112374,\"cacheWrite\":684,\"calls\":2},\"16-2-rewrite-parser\":{\"input\":7,\"output\":1369,\"cacheRead\":272160,\"cacheWrite\":2588,\"calls\":5},\"16-2-rewrite-parser-tier-classification\":{\"input\":27,\"output\":9122,\"cacheRead\":1558723,\"cacheWrite\":21556,\"calls\":27},\"16-3-update\":{\"input\":3,\"output\":205,\"cacheRead\":65314,\"cacheWrite\":1441,\"calls\":1},\"16-3-update-proof-validation-for-tiers\":{\"input\":18,\"output\":5890,\"cacheRead\":847817,\"cacheWrite\":10955,\"calls\":16},\"16-4-update-validation-acs-and-runner\":{\"input\":57,\"output\":13681,\"cacheRead\":2697349,\"cacheWrite\":33966,\"calls\":55},\"16-5-rewrite-harness-run-verification-dispatch\":{\"input\":103,\"output\":28745,\"cacheRead\":4741926,\"cacheWrite\":78171,\"calls\":103},\"16-7-update-knowledge-and-enforcement-docs\":{\"input\":43,\"output\":9897,\"cacheRead\":3119473,\"cacheWrite\":23814,\"calls\":43},\"16-6-update-create-story-tier-criteria\":{\"input\":50,\"output\":13081,\"cacheRead\":2643217,\"cacheWrite\":23382,\"calls\":48},\"16-5-rewrite-harness-run-\":{\"input\":9,\"output\":2023,\"cacheRead\":331029,\"cacheWrite\":6514,\"calls\":7},\"16-8-update-all-tests\"