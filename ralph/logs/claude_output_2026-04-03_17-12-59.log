{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MaLJ9mhq4Hj5hYaEZahhEX","type":"tool_result","content":"1\t/**\n2\t * Codex Driver — CLI-wrapped driver for OpenAI Codex.\n3\t *\n4\t * Spawns the `codex` CLI binary via child_process.spawn and parses\n5\t * its NDJSON stdout into StreamEvent objects.\n6\t *\n7\t * @see architecture-multi-framework.md — Decision 1: Driver Interface Design\n8\t * @see architecture-multi-framework.md — Decision 2: CLI-Wrapping Strategy\n9\t */\n10\t\n11\timport { spawn } from 'node:child_process';\n12\timport { execFile } from 'node:child_process';\n13\timport { createInterface } from 'node:readline';\n14\timport { promisify } from 'node:util';\n15\timport type {\n16\t  AgentDriver,\n17\t  DispatchOpts,\n18\t  DriverHealth,\n19\t  DriverCapabilities,\n20\t  ErrorCategory,\n21\t} from '../types.js';\n22\timport type { StreamEvent, ResultEvent } from '../stream-parser.js';\n23\t\n24\tconst execFileAsync = promisify(execFile);\n25\t\n26\t// --- Error Classification ---\n27\t\n28\tconst NETWORK_CODES = new Set([\n29\t  'ECONNREFUSED',\n30\t  'ETIMEDOUT',"}]},"parent_tool_use_id":"toolu_01FEeigjd5nRWkRCota9R2KA","session_id":"cf16e575-8267-4c58-a992-20b07458710f","uuid":"62b54217-c7b9-4171-88d4-574e71e26a9f","timestamp":"2026-04-03T13:15:01.445Z"}
