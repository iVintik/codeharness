{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GaYJAZDod6V9bPRX2Pd8XM","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach, vi } from 'vitest';\n2\timport { Command } from 'commander';\n3\timport { registerDriversCommand } from '../drivers.js';\n4\timport { resetDrivers } from '../../lib/agents/drivers/factory.js';\n5\t\n6\tbeforeEach(() => {\n7\t  resetDrivers();\n8\t});\n9\t\n10\tfunction createCli(): Command {\n11\t  const program = new Command();\n12\t  program.option('--json', 'JSON output');\n13\t  registerDriversCommand(program);\n14\t  return program;\n15\t}\n16\t\n17\tasync function runCli(args: string[]): Promise<{ stdout: string }> {\n18\t  const logs: string[] = [];\n19\t  const consoleSpy = vi.spyOn(console, 'log').mockImplementation((...a: unknown[]) => {\n20\t    logs.push(a.map(String).join(' '));\n21\t  });\n22\t\n23\t  const program = createCli();\n24\t  await program.parseAsync(['node', 'codeharness', ...args]);\n25\t\n26\t  consoleSpy.mockRestore();\n27\t  return { stdout: logs.join('\\n') };\n28\t}\n29\t\n30\tdescribe('codeharness drivers command', () => {\n31\t  it('outputs JSON with all registered drivers', async () => {\n32\t    const { stdout } = await runCli(['drivers']);\n33\t    const parsed = JSON.parse(stdout);\n34\t    expect(parsed).toHaveProperty('claude-code');\n35\t    expect(parsed).toHaveProperty('codex');\n36\t    expect(parsed).toHaveProperty('opencode');\n37\t  });\n38\t\n39\t  it('each driver entry has defaultModel, capabilities, and description', async () => {\n40\t    const { stdout } = await runCli(['drivers']);\n41\t    const parsed = JSON.parse(stdout);\n42\t    for (const name of ['claude-code', 'codex', 'opencode']) {\n43\t      expect(parsed[name]).toHaveProperty('defaultModel');\n44\t      expect(parsed[name]).toHaveProperty('capabilities');\n45\t      expect(parsed[name]).toHaveProperty('description');\n46\t      expect(typeof parsed[name].defaultModel).toBe('string');\n47\t      expect(typeof parsed[name].capabilities).toBe('object');\n48\t      expect(typeof parsed[name].description).toBe('string');\n49\t    }\n50\t  });\n51\t\n52\t  it('capabilities include costTier for all drivers', async () => {\n53\t    const { stdout } = await runCli(['drivers']);\n54\t    const parsed = JSON.parse(stdout);\n55\t    expect(parsed['claude-code'].capabilities.costTier).toBe(3);\n56\t    expect(parsed['codex'].capabilities.costTier).toBe(1);\n57\t    expect(parsed['opencode'].capabilities.costTier).toBe(2);\n58\t  });\n59\t\n60\t  it('--json flag produces parseable JSON', async () => {\n61\t    const { stdout } = await runCli(['--json', 'drivers']);\n62\t    expect(() => JSON.parse(stdout)).not.toThrow();\n63\t    const parsed = JSON.parse(stdout);\n64\t    expect(parsed).toHaveProperty('claude-code');\n65\t  });\n66\t\n67\t  it('exits with code 0', async () => {\n68\t    process.exitCode = undefined;\n69\t    await runCli(['drivers']);\n70\t    expect(process.exitCode).toBeUndefined();\n71\t  });\n72\t});\n73\t"}]},"parent_tool_use_id":"toolu_01WL7MCsNF3La2JHGCjnTeXK","session_id":"cf16e575-8267-4c58-a992-20b07458710f","uuid":"2c29c675-f476-422d-a551-dc2c4c292d79","timestamp":"2026-04-03T13:30:04.251Z"}
