{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MWo64GwCpv9rvwL1Pgvg18","type":"tool_result","content":"300\t  const sessionKey: SessionLookupKey = { taskName, storyKey };\n301\t  const sessionId = resolveSessionId(task.session, sessionKey, state);\n302\t\n303\t  // 4. Resolve driver\n304\t  const driverName = task.driver ?? 'claude-code';\n305\t  const driver = getDriver(driverName);\n306\t\n307\t  // 5. Resolve model via cascade: task → agent → driver\n308\t  const agentAsModelSource = { model: definition.model };\n309\t  const model = resolveModel(task, agentAsModelSource, driver);\n310\t\n311\t  // 6. Determine cwd based on source_access\n312\t  let cwd: string;\n313\t  let workspace: Awaited<ReturnType<typeof createIsolatedWorkspace>> | null = null;\n314\t\n315\t  if (task.source_access === false) {\n316\t    workspace = await createIsolatedWorkspace({ runId: config.runId, storyFiles: [] });\n317\t    cwd = workspace.toDispatchOptions().cwd ?? projectDir;\n318\t  } else {\n319\t    cwd = projectDir;\n320\t  }\n321\t\n322\t  // 7. Construct prompt\n323\t  const basePrompt = customPrompt\n324\t    ?? (storyKey === PER_RUN_SENTINEL\n325\t      ? `Execute task \"${taskName}\" for the current run.`\n326\t      : `Implement story ${storyKey}`);\n327\t\n328\t  // 7b. Inject previous task's output contract context into the prompt (story 13-2)\n329\t  const prompt = buildPromptWithContractContext(basePrompt, previousOutputContract ?? null);\n330\t\n331\t  // 8. Build DispatchOpts for the driver\n332\t  const dispatchOpts: DispatchOpts = {\n333\t    prompt,\n334\t    model,\n335\t    cwd,\n336\t    sourceAccess: task.source_access !== false,\n337\t    ...(sessionId ? { sessionId } : {}),\n338\t    ...(tracePrompt ? { appendSystemPrompt: tracePrompt } : {}),\n339\t    ...((task.plugins ?? definition.plugins) ? { plugins: task.plugins ?? definition.plugins } : {}),\n340\t    ...(task.max_budget_usd != null ? { timeout: task.max_budget_usd } : {}),\n341\t  };\n342\t\n343\t  // 9. Dispatch through the driver and consume AsyncIterable<StreamEvent>\n344\t  let output = '';\n345\t  let resultSessionId = '';\n346\t  let cost = 0;\n347\t  let errorEvent: { error: string; errorCategory?: string } | null = null;\n348\t\n349\t  // Track changed files from tool-start/tool-input/tool-complete events (Task 2)\n350\t  const changedFiles: string[] = [];\n351\t  let activeToolName: string | null = null;\n352\t  let activeToolInput = '';\n353\t\n354\t  // Timing measurement (Task 6)\n355\t  const startMs = Date.now();\n356\t\n357\t  try {\n358\t    for await (const event of driver.dispatch(dispatchOpts)) {\n359\t      if (event.type === 'text') {\n360\t        output += event.text;\n361\t      }\n362\t      if (event.type === 'tool-start') {\n363\t        const toolStart = event as ToolStartEvent;\n364\t        activeToolName = toolStart.name;\n365\t        activeToolInput = '';\n366\t      }\n367\t      if (event.type === 'tool-input') {\n368\t        activeToolInput += event.partial;\n369\t      }\n370\t      if (event.type === 'tool-complete') {\n371\t        // Extract file path from Write/Edit tool completions\n372\t        if (activeToolName && FILE_WRITE_TOOL_NAMES.has(activeToolName)) {\n373\t          try {\n374\t            const parsed = JSON.parse(activeToolInput) as Record<string, unknown>;\n375\t            const filePath = (parsed.file_path ?? parsed.path ?? parsed.filePath) as string | undefined;\n376\t            if (filePath && typeof filePath === 'string') {\n377\t              changedFiles.push(filePath);\n378\t            }\n379\t          } catch { // IGNORE: best-effort — tool input may not be valid JSON (partial accumulation)\n380\t          }\n381\t        }\n382\t        activeToolName = null;\n383\t        activeToolInput = '';\n384\t      }\n385\t      if (event.type === 'result') {\n386\t        const resultEvt = event as ResultEvent;\n387\t        resultSessionId = resultEvt.sessionId;\n388\t        cost = resultEvt.cost;\n389\t        if (resultEvt.error) {\n390\t          errorEvent = { error: resultEvt.error, errorCategory: resultEvt.errorCategory };\n391\t        }\n392\t      }\n393\t    }\n394\t  } finally {\n395\t    // Cleanup workspace regardless of dispatch success/failure\n396\t    if (workspace) {\n397\t      await workspace.cleanup();\n398\t    }\n399\t  }\n400\t\n401\t  // 10. If the driver reported an error in the result event, throw DispatchError\n402\t  if (errorEvent) {\n403\t    // Map ErrorCategory to DispatchErrorCode\n404\t    const categoryToCode: Record<string, string> = {\n405\t      RATE_LIMIT: 'RATE_LIMIT',\n406\t      NETWORK: 'NETWORK',\n407\t      SDK_INIT: 'SDK_INIT',\n408\t      AUTH: 'UNKNOWN',\n409\t      TIMEOUT: 'UNKNOWN',\n410\t      UNKNOWN: 'UNKNOWN',\n411\t    };\n412\t    const code = categoryToCode[errorEvent.errorCategory ?? 'UNKNOWN'] ?? 'UNKNOWN';\n413\t    throw new DispatchError(\n414\t      errorEvent.error,\n415\t      code as DispatchErrorCode,\n416\t      definition.name,\n417\t      errorEvent,\n418\t    );\n419\t  }\n420\t\n421\t  // 11. Record session ID (if dispatch returned one)\n422\t  let updatedState = state;\n423\t  if (resultSessionId) {\n424\t    updatedState = recordSessionId(sessionKey, resultSessionId, updatedState);\n425\t  } else {\n426\t    // Append checkpoint manually when no session ID is returned\n427\t    const checkpoint: TaskCheckpoint = {\n428\t      task_name: taskName,\n429\t      story_key: storyKey,\n430\t      completed_at: new Date().toISOString(),\n431\t    };\n432\t    updatedState = {\n433\t      ...updatedState,\n434\t      tasks_completed: [...updatedState.tasks_completed, checkpoint],\n435\t    };\n436\t  }\n437\t\n438\t  // 12. Record trace ID\n439\t  updatedState = recordTraceId(traceId, updatedState);\n440\t\n441\t  // 12b. Construct and write output contract (Task 1)\n442\t  const durationMs = Date.now() - startMs;\n443\t  let contract: OutputContract | null = null;\n444\t  try {\n445\t    contract = {\n446\t      version: 1,\n447\t      taskName,\n448\t      storyId: storyKey,\n449\t      driver: driverName,\n450\t      model,\n451\t      timestamp: new Date().toISOString(),\n452\t      cost_usd: cost > 0 ? cost : null,\n453\t      duration_ms: durationMs,\n454\t      changedFiles: [...new Set(changedFiles)],\n455\t      testResults: null,\n456\t      output,\n457\t      acceptanceCriteria: [],\n458\t    };\n459\t    writeOutputContract(contract, join(projectDir, '.codeharness', 'contracts'));\n460\t  } catch (err: unknown) {\n461\t    const message = err instanceof Error ? err.message : String(err);\n462\t    warn(`workflow-engine: failed to write output contract for ${taskName}/${storyKey}: ${message}`);\n463\t    contract = null;\n464\t  }\n465\t\n466\t  // 13. Write state to disk\n467\t  writeWorkflowState(updatedState, projectDir);\n468\t\n469\t  return { updatedState, output, contract };\n470\t}\n471\t\n472\t// --- Retry Prompt Construction (Task 3) ---\n473\t\n474\t/**\n475\t * Build a retry prompt with evaluator findings injected.\n476\t * Includes only failed/unknown findings.\n477\t */\n478\texport function buildRetryPrompt(storyKey: string, findings: EvaluatorVerdict['findings']): string {\n479\t  const failedFindings = findings.filter(\n480\t    (f) => f.status === 'fail' || f.status === 'unknown',\n481\t  );\n482\t\n483\t  if (failedFindings.length === 0) {\n484\t    return `Implement story ${storyKey}`;\n485\t  }\n486\t\n487\t  const formattedFindings = failedFindings\n488\t    .map((f) => {\n489\t      const status = f.status.toUpperCase();\n490\t      let entry = `AC #${f.ac} (${status}): ${f.description}`;\n491\t      if (f.evidence?.reasoning) {\n492\t        entry += `\\n  Evidence: ${f.evidence.reasoning}`;\n493\t      }\n494\t      return entry;\n495\t    })\n496\t    .join('\\n\\n');\n497\t\n498\t  return `Retry story ${storyKey}. Previous evaluator findings:\\n\\n${formattedFindings}\\n\\nFocus on fixing the failed criteria above.`;\n499\t}"}]},"parent_tool_use_id":"toolu_01E368mBox6AGS9E4aPFSS48","session_id":"8a461711-53e2-475a-88dd-c7013f6080c5","uuid":"7aea5394-aefe-449b-88c9-ad0efaa59e75","timestamp":"2026-04-03T17:13:14.455Z"}
