n    47→    mockExistsSync.mockReturnValue(false);\n    48→    generateDockerfileTemplate('/project', 'nodejs');\n    49→\n    50→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    51→    expect(written).toContain('curl');\n    52→    expect(written).toContain('jq');\n    53→  });\n    54→\n    55→  it('includes USER node for non-root execution', () => {\n    56→    mockExistsSync.mockReturnValue(false);\n    57→    generateDockerfileTemplate('/project', 'nodejs');\n    58→\n    59→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    60→    expect(written).toContain('USER node');\n    61→  });\n    62→\n    63→  it('includes cache cleanup', () => {\n    64→    mockExistsSync.mockReturnValue(false);\n    65→    generateDockerfileTemplate('/project', 'nodejs');\n    66→\n    67→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    68→    expect(written).toContain('rm -rf /var/lib/apt/lists/*');\n    69→  });\n    70→\n    71→  it('includes inline section comments', () => {\n    72→    mockExistsSync.mockReturnValue(false);\n    73→    generateDockerfileTemplate('/project', 'nodejs');\n    74→\n    75→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    76→    expect(written).toContain('# Base image');\n    77→    expect(written).toContain('# System utilities');\n    78→    expect(written).toContain('# Install project');\n    79→    expect(written).toContain('# Run as non-root');\n    80→  });\n    81→});\n    82→\n    83→// ─── Python template ────────────────────────────────────────────────────────\n    84→\n    85→describe('generateDockerfileTemplate — python', () => {\n    86→  it('generates Dockerfile with pinned FROM python:3.12-slim', () => {\n    87→    mockExistsSync.mockReturnValue(false);\n    88→\n    89→    const r = generateDockerfileTemplate('/project', 'python');\n    90→    expect(r.success).toBe(true);\n    91→    if (r.success) {\n    92→      expect(r.data.path).toBe(join('/project', 'Dockerfile'));\n    93→      expect(r.data.stack).toBe('python');\n    94→    }\n    95→\n    96→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    97→    expect(written).toContain('FROM python:3.12-slim');\n    98→  });\n    99→\n   100→  it('includes pip install for binary installation', () => {\n   101→    mockExistsSync.mockReturnValue(false);\n   102→    generateDockerfileTemplate('/project', 'python');\n   103→\n   104→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   105→    expect(written).toContain('pip install');\n   106→  });\n   107→\n   108→  it('includes curl and jq verification tools', () => {\n   109→    mockExistsSync.mockReturnValue(false);\n   110→    generateDockerfileTemplate('/project', 'python');\n   111→\n   112→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   113→    expect(written).toContain('curl');\n   114→    expect(written).toContain('jq');\n   115→  });\n   116→\n   117→  it('includes USER nobody for non-root execution', () => {\n   118→    mockExistsSync.mockReturnValue(false);\n   119→    generateDockerfileTemplate('/project', 'python');\n   120→\n   121→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   122→    expect(written).toContain('USER nobody');\n   123→  });\n   124→\n   125→  it('includes cache cleanup (apt + pip)', () => {\n   126→    mockExistsSync.mockReturnValue(false);\n   127→    generateDockerfileTemplate('/project', 'python');\n   128→\n   129→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   130→    expect(written).toContain('rm -rf /var/lib/apt/lists/*');\n   131→    expect(written).toContain('pip cache purge');\n   132→  });\n   133→\n   134→  it('includes inline section comments', () => {\n   135→    mockExistsSync.mockReturnValue(false);\n   136→    generateDockerfileTemplate('/project', 'python');\n   137→\n   138→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   139→    expect(written).toContain('# Base image');\n   140→    expect(written).toContain('# System utilities');\n   141→    expect(written).toContain('# Install project');\n   142→    expect(written).toContain('# Run as non-root');\n   143→  });\n   144→});\n   145→\n   146→// ─── Generic template ───────────────────────────────────────────────────────\n   147→\n   148→describe('generateDockerfileTemplate — generic/null', () => {\n   149→  it('generates generic Dockerfile when stack is null', () => {\n   150→    mockExistsSync.mockReturnValue(false);\n   151→\n   152→    const r = generateDockerfileTemplate('/project', null);\n   153→    expect(r.success).toBe(true);\n   154→    if (r.success) {\n   155→      expect(r.data.stack).toBe('generic');\n   156→    }\n   157→\n   158→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   159→    expect(written).toContain('FROM node:22-slim');\n   160→    expect(written).toContain('bash');\n   161→    expect(written).toContain('git');\n   162→  });\n   163→\n   164→  it('generates generic Dockerfile when stack is unknown', () => {\n   165→    mockExistsSync.mockReturnValue(false);\n   166→\n   167→    const r = generateDockerfileTemplate('/project', 'rust');\n   168→    expect(r.success).toBe(true);\n   169→    if (r.success) {\n   170→      expect(r.data.stack).toBe('generic');\n   171→    }\n   172→  });\n   173→\n   174→  it('includes curl and jq in generic template', () => {\n   175→    mockExistsSync.mockReturnValue(false);\n   176→    generateDockerfileTemplate('/project', null);\n   177→\n   178→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   179→    expect(written).toContain('curl');\n   180→    expect(written).toContain('jq');\n   181→  });\n   182→});\n   183→\n   184→// ─── Existing Dockerfile ────────────────────────────────────────────────────\n   185→\n   186→describe('generateDockerfileTemplate — existing Dockerfile', () => {\n   187→  it('returns fail when Dockerfile already exists', () => {\n   188→    mockExistsSync.mockReturnValue(true);\n   189→\n   190→    const r = generateDockerfileTemplate('/project', 'nodejs');\n   191→    expect(r.success).toBe(false);\n   192→    if (!r.success) {\n   193→      expect(r.error).toBe('Dockerfile already exists');\n   194→    }\n   195→  });\n   196→\n   197→  it('does not write any file when Dockerfile exists', () => {\n   198→    mockExistsSync.mockReturnValue(true);\n   199→\n   200→    generateDockerfileTemplate('/project', 'nodejs');\n   201→    expect(mockWriteFileSync).not.toHaveBeenCalled();\n   202→  });\n   203→});\n   204→\n   205→// ─── Error handling ─────────────────────────────────────────────────────────\n   206→\n   207→describe('generateDockerfileTemplate — error handling', () => {\n   208→  it('returns fail when projectDir is empty string', () => {\n   209→    const r = generateDockerfileTemplate('', 'nodejs');\n   210→    expect(r.success).toBe(false);\n   211→    if (!r.success) {\n   212→      expect(r.error).toBe('projectDir is required');\n   213→    }\n   214→  });\n   215→\n   216→  it('returns fail when writeFileSync throws', () => {\n   217→    mockExistsSync.mockReturnValue(false);\n   218→    mockWriteFileSync.mockImplementation(() => {\n   219→      throw new Error('EACCES: permission denied');\n   220→    });\n   221→\n   222→    const r = generateDockerfileTemplate('/project', 'nodejs');\n   223→    expect(r.success).toBe(false);\n   224→    if (!r.success) {\n   225→      expect(r.error).toContain('Failed to write Dockerfile');\n   226→      expect(r.error).toContain('EACCES');\n   227→    }\n   228→  });\n   229→\n   230→  it('returns fail with stringified error for non-Error throws', () => {\n   231→    mockExistsSync.mockReturnValue(false);\n   232→    mockWriteFileSync.mockImplementation(() => {\n   233→      throw 'disk full';\n   234→    });\n   235→\n   236→    const r = generateDockerfileTemplate('/project', 'nodejs');\n   237→    expect(r.success).toBe(false);\n   238→    if (!r.success) {\n   239→      expect(r.error).toContain('disk full');\n   240→    }\n   241→  });\n   242→});\n   243→\n   244→// ─── Result<T> return type ──────────────────────────────────────────────────\n   245→\n   246→describe('generateDockerfileTemplate — Result type', () => {\n   247→  it('returns Ok with path and stack on success', () => {\n   248→    mockExistsSync.mockReturnValue(false);\n   249→\n   250→    const r = generateDockerfileTemplate('/project', 'nodejs');\n   251→    expect(r.success).toBe(true);\n   252→    if (r.success) {\n   253→      expect(r.data).toHaveProperty('path');\n   254→      expect(r.data).toHaveProperty('stack');\n   255→      expect(typeof r.data.path).toBe('string');\n   256→      expect(typeof r.data.stack).toBe('string');\n   257→    }\n   258→  });\n   259→\n   260→  it('returns Fail with error string on failure', () => {\n   261→    mockExistsSync.mockReturnValue(true);\n   262→\n   263→    const r = generateDockerfileTemplate('/project', 'nodejs');\n   264→    expect(r.success).toBe(false);\n   265→    if (!r.success) {\n   266→      expect(typeof r.error).toBe('string');\n   267→    }\n   268→  });\n   269→});\n   270→\n   271→// ─── Validation compliance ──────────────────────────────────────────────────\n   272→\n   273→describe('generated Dockerfiles pass validateDockerfile()', () => {\n   274→  it('nodejs template passes all 6 rule categories', () => {\n   275→    mockExistsSync.mockReturnValue(false);\n   276→    generateDockerfileTemplate('/project', 'nodejs');\n   277→    const content = mockWriteFileSync.mock.calls[0][1] as string;\n   278→\n   279→    mockExistsSync.mockImplementation((p: unknown) => {\n   280→      const path = String(p);\n   281→      if (path.endsWith('Dockerfile')) return true;\n   282→      return false;\n   283→    });\n   284→    vi.mocked(readFileSync).mockReturnValue(content);\n   285→\n   286→    const r = validateDockerfile('/project');\n   287→    expect(r.success).toBe(true);\n   288→    if (r.success) {\n   289→      expect(r.data.passed).toBe(true);\n   290→      expect(r.data.gaps).toHaveLength(0);\n   291→    }\n   292→  });\n   293→\n   294→  it('python template passes all 6 rule categories', () => {\n   295→    mockExistsSync.mockReturnValue(false);\n   296→    generateDockerfileTemplate('/project', 'python');\n   297→    const content = mockWriteFileSync.mock.calls[0][1] as string;\n   298→\n   299→    mockExistsSync.mockImplementation((p: unknown) => {\n   300→      const path = String(p);\n   301→      if (path.endsWith('Dockerfile')) return true;\n   302→      return false;\n   303→    });\n   304→    vi.mocked(readFileSync).mockReturnValue(content);\n   305→\n   306→    const r = validateDockerfile('/project');\n   307→    expect(r.success).toBe(true);\n   308→    if (r.success) {\n   309→      expect(r.data.passed).toBe(true);\n   310→      expect(r.data.gaps).toHaveLength(0);\n   311→    }\n   312→  });\n   313→\n   314→  it('generic template passes all 6 rule categories', () => {\n   315→    mockExistsSync.mockReturnValue(false);\n   316→    generateDockerfileTemplate('/project', null);\n   317→    const content = mockWriteFileSync.mock.calls[0][1] as string;\n   318→\n   319→    mockExistsSync.mockImplementation((p: unknown) => {\n   320→      const path = String(p);\n   321→      if (path.endsWith('Dockerfile')) return true;\n   322→      return false;\n   323→    });\n   324→    vi.mocked(readFileSync).mockReturnValue(content);\n   325→\n   326→    const r = validateDockerfile('/project');\n   327→    expect(r.success).toBe(true);\n   328→    if (r.success) {\n   329→      expect(r.data.passed).toBe(true);\n   330→      expect(r.data.gaps).toHaveLength(0);\n   331→    }\n   332→  });\n   333→});\n   334→"}]},"parent_tool_use_id":"toolu_01Us1Yj6kDFpG5rzKPuwN5hF","session_id":"daf25720-e009-4a3c-8a3c-df9d68d99484","uuid":"4068fd0b-c876-4425-99ae-dd651bda5d07","timestamp":"2026-03-23T06:42:12.355Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PJbACb52jmEdM7Z5qNaqi1","type":"tool_result","content":"     1→# Black-box verification environment\n     2→# Installs the project as a user would (from tarball), plus verification tools.\n     3→# NO source code enters the image — only the built artifact.\n     4→FROM node:20-slim\n     5→\n     6→ARG TARBALL=package.tgz\n     7→\n     8→# System utilities + Python for Semgrep\n     9→RUN apt-get update && apt-get install -y --no-install-recommends \\\n    10→    curl \\\n    11→    jq \\\n    12→    python3 \\\n    13→    python3-pip \\\n    14→    pipx \\\n    15→  && rm -rf /var/lib/apt/lists/*\n    16→\n    17→# Semgrep for static analysis verification\n    18→RUN pipx install semgrep && pipx ensurepath\n    19→ENV PATH=\"/root/.local/bin:${PATH}\"\n    20→\n    21→# Verification tools + Claude Code CLI\n    22→RUN npm install -g showboat @anthropic-ai/claude-code\n    23→\n    24→# Install the project from tarball (same as a user would)\n    25→COPY ${TARBALL} /tmp/${TARBALL}\n    26→RUN npm install -g /tmp/${TARBALL} && rm /tmp/${TARBALL}\n    27→\n    28→# OTEL environment pointing to host observability stack\n    29→ENV OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4318\n    30→ENV OTEL_SERVICE_NAME=codeharness-verify\n    31→ENV OTEL_TRACES_EXPORTER=otlp\n    32→ENV OTEL_METRICS_EXPORTER=otlp\n    33→ENV OTEL_LOGS_EXPORTER=otlp\n    34→\n    35→WORKDIR /workspace\n    36→"}]},"parent_tool_use_id":"toolu_01Us1Yj6kDFpG5rzKPuwN5hF","session_id":"daf25720-e009-4a3c-8a3c-df9d68d99484","uuid":"fb21b1b9-83c0-497f-b91e-73ad2f9cd809","timestamp":"2026-03-23T06:42:12.352Z"}
