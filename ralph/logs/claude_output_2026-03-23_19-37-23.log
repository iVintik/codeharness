ge,\n    47→  detectProjectType,\n    48→  prepareVerifyWorkspace,\n    49→  checkVerifyEnv,\n    50→  cleanupVerifyEnv,\n    51→  cleanupStaleContainers,\n    52→} from '../env.js';\n    53→\n    54→const mockExecFileSync = vi.mocked(execFileSync);\n    55→const mockIsDockerAvailable = vi.mocked(isDockerAvailable);\n    56→const mockDetectStack = vi.mocked(detectStack);\n    57→const mockDetectStacks = vi.mocked(detectStacks);\n    58→const mockReadStateWithBody = vi.mocked(readStateWithBody);\n    59→const mockWriteState = vi.mocked(writeState);\n    60→\n    61→let testDir: string;\n    62→\n    63→beforeEach(() => {\n    64→  vi.clearAllMocks();\n    65→  testDir = mkdtempSync(join(tmpdir(), 'ch-verify-env-test-'));\n    66→  // Create templates/Dockerfile.verify so buildVerifyImage can find it\n    67→  mkdirSync(join(testDir, 'templates'), { recursive: true });\n    68→  writeFileSync(join(testDir, 'templates', 'Dockerfile.verify'), 'FROM node:20-slim\\nARG TARBALL=package.tgz\\nCOPY ${TARBALL} /tmp/\\n');\n    69→  writeFileSync(join(testDir, 'templates', 'Dockerfile.verify.generic'), 'FROM node:20-slim\\nRUN apt-get update\\n');\n    70→  // Reset default mock behaviors after clearAllMocks\n    71→  mockIsDockerAvailable.mockReturnValue(true);\n    72→  mockDetectStack.mockReturnValue('nodejs');\n    73→  mockDetectStacks.mockReturnValue([{ stack: 'nodejs', dir: '.' }]);\n    74→});\n    75→\n    76→afterEach(() => {\n    77→  rmSync(testDir, { recursive: true, force: true });\n    78→});\n    79→\n    80→// ─── isValidStoryKey ────────────────────────────────────────────────────────\n    81→\n    82→describe('isValidStoryKey', () => {\n    83→  it('accepts valid story keys', () => {\n    84→    expect(isValidStoryKey('13-1-verification-dockerfile-generator')).toBe(true);\n    85→    expect(isValidStoryKey('story_key_123')).toBe(true);\n    86→    expect(isValidStoryKey('abc')).toBe(true);\n    87→  });\n    88→\n    89→  it('rejects empty string', () => {\n    90→    expect(isValidStoryKey('')).toBe(false);\n    91→  });\n    92→\n    93→  it('rejects path traversal', () => {\n    94→    expect(isValidStoryKey('../etc/passwd')).toBe(false);\n    95→    expect(isValidStoryKey('foo/../bar')).toBe(false);\n    96→  });\n    97→\n    98→  it('rejects forward slashes', () => {\n    99→    expect(isValidStoryKey('foo/bar')).toBe(false);\n   100→  });\n   101→\n   102→  it('rejects backslashes', () => {\n   103→    expect(isValidStoryKey('foo\\\\bar')).toBe(false);\n   104→  });\n   105→\n   106→  it('rejects special characters', () => {\n   107→    expect(isValidStoryKey('foo bar')).toBe(false);\n   108→    expect(isValidStoryKey('foo$bar')).toBe(false);\n   109→    expect(isValidStoryKey('foo;bar')).toBe(false);\n   110→    expect(isValidStoryKey('foo|bar')).toBe(false);\n   111→  });\n   112→});\n   113→\n   114→// ─── computeDistHash ────────────────────────────────────────────────────────\n   115→\n   116→describe('computeDistHash', () => {\n   117→  it('returns null when dist/ does not exist', () => {\n   118→    expect(computeDistHash(testDir)).toBeNull();\n   119→  });\n   120→\n   121→  it('computes a hash for dist/ files', () => {\n   122→    const distDir = join(testDir, 'dist');\n   123→    mkdirSync(distDir);\n   124→    writeFileSync(join(distDir, 'index.js'), 'console.log(\"hello\")');\n   125→    writeFileSync(join(distDir, 'utils.js'), 'export function foo() {}');\n   126→\n   127→    const hash = computeDistHash(testDir);\n   128→    expect(hash).toBeTruthy();\n   129→    expect(typeof hash).toBe('string');\n   130→    expect(hash!.length).toBe(64); // SHA-256 hex\n   131→  });\n   132→\n   133→  it('produces different hashes for different content', () => {\n   134→    const distDir = join(testDir, 'dist');\n   135→    mkdirSync(distDir);\n   136→\n   137→    writeFileSync(join(distDir, 'index.js'), 'version 1');\n   138→    const hash1 = computeDistHash(testDir);\n   139→\n   140→    writeFileSync(join(dis