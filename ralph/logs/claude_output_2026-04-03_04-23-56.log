{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RT1ejH8M47TdWJRn2V62af","type":"tool_result","content":"1\timport type { SubagentDefinition } from './agent-resolver.js';\n2\timport type { DispatchResult } from './agent-dispatch.js';\n3\timport { dispatchAgent } from './agent-dispatch.js';\n4\timport { createIsolatedWorkspace } from './source-isolation.js';\n5\timport type { IsolatedWorkspace } from './source-isolation.js';\n6\timport { isDockerAvailable } from './docker/index.js';\n7\timport { formatTracePrompt } from './trace-id.js';\n8\t\n9\t// --- Interfaces ---\n10\t\n11\t/**\n12\t * Options for running the blind evaluator.\n13\t */\n14\texport interface EvaluatorOptions {\n15\t  /** Unique run identifier — used in workspace path and tracing. */\n16\t  runId: string;\n17\t  /** Absolute paths to story files containing acceptance criteria. */\n18\t  storyFiles: string[];\n19\t  /** Pre-compiled subagent definition for the evaluator agent. */\n20\t  agentDefinition: SubagentDefinition;\n21\t  /** Timeout in milliseconds for the evaluator dispatch. Default: 300000 (5 minutes). */\n22\t  timeoutMs?: number;\n23\t  /** Optional trace ID for correlation in logs/metrics. */\n24\t  traceId?: string;\n25\t}\n26\t\n27\t/**\n28\t * Result of an evaluator run.\n29\t */\n30\texport interface EvaluatorResult {\n31\t  /** Raw agent output (or synthesized JSON for fallback cases). */\n32\t  output: string;\n33\t  /** Whether the evaluator completed successfully. */\n34\t  success: boolean;\n35\t  /** Wall-clock duration of the evaluator run in milliseconds. */\n36\t  durationMs: number;\n37\t  /** Whether Docker was available at the time of the run. */\n38\t  dockerAvailable: boolean;\n39\t  /** Whether the evaluator timed out. */\n40\t  timedOut: boolean;\n41\t}\n42\t\n43\t// --- Constants ---\n44\t\n45\tconst DEFAULT_TIMEOUT_MS = 300_000; // 5 minutes\n46\t\n47\t/**\n48\t * Build the evaluator dispatch prompt from the compiled agent definition instructions.\n49\t * Falls back to a minimal prompt if the agent definition has no prompt_template content.\n50\t */\n51\tfunction buildEvaluatorPrompt(agentDefinition: SubagentDefinition): string {\n52\t  // The compiled instructions already include the prompt_template from evaluator.yaml.\n53\t  // We add context about story file location and output directory.\n54\t  const parts: string[] = [];\n55\t\n56\t  parts.push('Verify the acceptance criteria for this story.');\n57\t  parts.push('Story files are available in ./story-files/. Read each file to find the ACs.');\n58\t  parts.push('Write your verdict JSON output to ./verdict/.');\n59\t\n60\t  return parts.join('\\n');\n61\t}\n62\t\n63\t// --- Helpers ---\n64\t\n65\t/**\n66\t * Build a fallback output JSON string with all ACs scored UNKNOWN.\n67\t */\n68\tfunction buildUnknownOutput(storyFiles: string[], reasoning: string): string {\n69\t  // We don't know how many ACs each story file has, so we produce\n70\t  // a single finding per story file with status unknown.\n71\t  const findings = storyFiles.map((_, index) => ({\n72\t    ac: index + 1,\n73\t    description: `AC #${index + 1}`,\n74\t    status: 'unknown' as const,\n75\t    evidence: {\n76\t      commands_run: [],\n77\t      output_observed: '',\n78\t      reasoning,\n79\t    },\n80\t  }));\n81\t\n82\t  return JSON.stringify({\n83\t    verdict: 'fail',\n84\t    score: {\n85\t      passed: 0,\n86\t      failed: 0,\n87\t      unknown: findings.length,\n88\t      total: findings.length,\n89\t    },\n90\t    findings,\n91\t  });\n92\t}\n93\t\n94\t// --- Main Function ---\n95\t\n96\t/**\n97\t * Run the blind evaluator lifecycle:\n98\t *   1. Check Docker availability\n99\t *   2. Create isolated workspace\n100\t *   3. Dispatch evaluator agent (with timeout)\n101\t *   4. Collect result\n102\t *   5. Cleanup workspace\n103\t *\n104\t * Returns raw output for downstream parsing (story 6-2).\n105\t * Does NOT throw on Docker unavailability or timeout — returns graceful UNKNOWN results.\n106\t */\n107\texport async function runEvaluator(options: EvaluatorOptions): Promise<EvaluatorResult> {\n108\t  const startMs = Date.now();\n109\t  const timeoutMs = options.timeoutMs ?? DEFAULT_TIMEOUT_MS;\n110\t\n111\t  // Step 1: Check Docker availability\n112\t  const dockerAvailable = isDockerAvailable();\n113\t  if (!dockerAvailable) {\n114\t    return {\n115\t      output: buildUnknownOutput(\n116\t        options.storyFiles,\n117\t        'Docker is not available — cannot run verification commands.',\n118\t      ),\n119\t      success: false,\n120\t      durationMs: Date.now() - startMs,\n121\t      dockerAvailable: false,\n122\t      timedOut: false,\n123\t    };\n124\t  }\n125\t\n126\t  // Step 2: Create isolated workspace\n127\t  let workspace: IsolatedWorkspace | undefined;\n128\t  try {\n129\t    workspace = await createIsolatedWorkspace({\n130\t      runId: options.runId,\n131\t      storyFiles: options.storyFiles,\n132\t    });\n133\t\n134\t    // Step 3: Build dispatch options\n135\t    const dispatchOptions = workspace.toDispatchOptions();\n136\t    if (options.traceId) {\n137\t      dispatchOptions.appendSystemPrompt = formatTracePrompt(options.traceId);\n138\t    }\n139\t\n140\t    // Step 4: Race dispatch against timeout\n141\t    const evaluatorPrompt = buildEvaluatorPrompt(options.agentDefinition);\n142\t    const dispatchPromise = dispatchAgent(\n143\t      options.agentDefinition,\n144\t      evaluatorPrompt,\n145\t      dispatchOptions,\n146\t    );\n147\t\n148\t    let timeoutTimer: ReturnType<typeof setTimeout> | undefined;\n149\t    const timeoutPromise = new Promise<never>((_, reject) => {\n150\t      timeoutTimer = setTimeout(() => reject(new Error('Evaluator timeout')), timeoutMs);\n151\t    });\n152\t\n153\t    let result: DispatchResult;\n154\t    try {\n155\t      result = await Promise.race([dispatchPromise, timeoutPromise]);\n156\t    } catch (err: unknown) {\n157\t      const message = err instanceof Error ? err.message : String(err);\n158\t      if (message === 'Evaluator timeout') {\n159\t        return {\n160\t          output: buildUnknownOutput(\n161\t            options.storyFiles,\n162\t            `Evaluator timed out after ${timeoutMs}ms.`,\n163\t          ),\n164\t          success: false,\n165\t          durationMs: Date.now() - startMs,\n166\t          dockerAvailable: true,\n167\t          timedOut: true,\n168\t        };\n169\t      }\n170\t      // Re-throw non-timeout errors\n171\t      throw err;\n172\t    } finally {\n173\t      // Clear the timeout timer to prevent Node.js process from hanging\n174\t      if (timeoutTimer) {\n175\t        clearTimeout(timeoutTimer);\n176\t      }\n177\t    }\n178\t\n179\t    return {\n180\t      output: result.output,\n181\t      success: result.success,\n182\t      durationMs: Date.now() - startMs,\n183\t      dockerAvailable: true,\n184\t      timedOut: false,\n185\t    };\n186\t  } finally {\n187\t    // Step 5: Cleanup workspace (always)\n188\t    if (workspace) {\n189\t      await workspace.cleanup();\n190\t    }\n191\t  }\n192\t}\n193\t"}]},"parent_tool_use_id":"toolu_01WBGtD6t91yRv6Crn8gGaXn","session_id":"52ded6f4-857c-404a-a480-19bb12459ee1","uuid":"e77812f8-4ee8-4f4d-b402-3c315739793c","timestamp":"2026-04-03T00:38:43.543Z"}
