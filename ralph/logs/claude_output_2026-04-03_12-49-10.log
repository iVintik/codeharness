{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Lz783kpqFt3nF8M2m2V8Yv","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach } from 'vitest';\n2\t\n3\t// --- Mock the Agent SDK ---\n4\t\n5\tconst { mockQuery } = vi.hoisted(() => ({\n6\t  mockQuery: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock('@anthropic-ai/claude-agent-sdk', () => ({\n10\t  query: mockQuery,\n11\t}));\n12\t\n13\timport { ClaudeCodeDriver } from '../drivers/claude-code.js';\n14\timport type { DispatchOpts } from '../types.js';\n15\timport type { StreamEvent, ResultEvent } from '../stream-parser.js';\n16\t\n17\t// --- Helpers ---\n18\t\n19\tfunction makeOpts(overrides?: Partial<DispatchOpts>): DispatchOpts {\n20\t  return {\n21\t    prompt: 'Do the thing',\n22\t    model: 'claude-sonnet-4-20250514',\n23\t    cwd: '/tmp/test',\n24\t    sourceAccess: true,\n25\t    ...overrides,\n26\t  };\n27\t}\n28\t\n29\t/**\n30\t * Create an async generator that yields the given messages.\n31\t */\n32\tasync function* fakeStream(messages: Array<Record<string, unknown>>) {\n33\t  for (const msg of messages) {\n34\t    yield msg;\n35\t  }\n36\t}\n37\t\n38\tfunction makeResultMessage(overrides?: Record<string, unknown>) {\n39\t  return {\n40\t    type: 'result',\n41\t    subtype: 'success',\n42\t    result: 'Agent completed the task.',\n43\t    session_id: 'sess-abc-123',\n44\t    total_cost_usd: 0.05,\n45\t    ...overrides,\n46\t  };\n47\t}\n48\t\n49\t/**\n50\t * Collect all events from an AsyncIterable.\n51\t */\n52\tasync function collectEvents(iterable: AsyncIterable<StreamEvent>): Promise<StreamEvent[]> {\n53\t  const events: StreamEvent[] = [];\n54\t  for await (const event of iterable) {\n55\t    events.push(event);\n56\t  }\n57\t  return events;\n58\t}\n59\t\n60\t// --- Tests ---\n61\t\n62\tdescribe('ClaudeCodeDriver', () => {\n63\t  let driver: ClaudeCodeDriver;\n64\t\n65\t  beforeEach(() => {\n66\t    vi.clearAllMocks();\n67\t    driver = new ClaudeCodeDriver();\n68\t  });\n69\t\n70\t  describe('class properties (AC #1)', () => {\n71\t    it('has name \"claude-code\"', () => {\n72\t      expect(driver.name).toBe('claude-code');\n73\t    });\n74\t\n75\t    it('has defaultModel \"claude-sonnet-4-20250514\"', () => {\n76\t      expect(driver.defaultModel).toBe('claude-sonnet-4-20250514');\n77\t    });\n78\t\n79\t    it('has correct capabilities', () => {\n80\t      expect(driver.capabilities).toEqual({\n81\t        supportsPlugins: true,\n82\t        supportsStreaming: true,\n83\t        costReporting: true,\n84\t      });\n85\t    });\n86\t  });\n87\t\n88\t  describe('healthCheck (AC #4)', () => {\n89\t    it('returns available: true, authenticated: true, version: null', async () => {\n90\t      const health = await driver.healthCheck();\n91\t      expect(health).toEqual({\n92\t        available: true,\n93\t        authenticated: true,\n94\t        version: null,\n95\t      });\n96\t    });\n97\t  });\n98\t\n99\t  describe('dispatch — StreamEvent mapping (AC #2)', () => {\n100\t    it('maps tool_use content_block_start to tool-start event', async () => {\n101\t      mockQuery.mockReturnValue(\n102\t        fakeStream([\n103\t          {\n104\t            type: 'stream_event',\n105\t            event: {\n106\t              type: 'content_block_start',\n107\t              content_block: { type: 'tool_use', name: 'Edit', id: 'tool-1' },\n108\t            },\n109\t          },\n110\t          makeResultMessage(),\n111\t        ]),\n112\t      );\n113\t\n114\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n115\t      expect(events[0]).toEqual({ type: 'tool-start', name: 'Edit', id: 'tool-1' });\n116\t    });\n117\t\n118\t    it('maps input_json_delta to tool-input event', async () => {\n119\t      mockQuery.mockReturnValue(\n120\t        fakeStream([\n121\t          {\n122\t            type: 'stream_event',\n123\t            event: {\n124\t              type: 'content_block_delta',\n125\t              delta: { type: 'input_json_delta', partial_json: '{\"file\":' },\n126\t            },\n127\t          },\n128\t          makeResultMessage(),\n129\t        ]),\n130\t      );\n131\t\n132\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n133\t      expect(events[0]).toEqual({ type: 'tool-input', partial: '{\"file\":' });\n134\t    });\n135\t\n136\t    it('maps text_delta to text event', async () => {\n137\t      mockQuery.mockReturnValue(\n138\t        fakeStream([\n139\t          {\n140\t            type: 'stream_event',\n141\t            event: {\n142\t              type: 'content_block_delta',\n143\t              delta: { type: 'text_delta', text: 'Hello world' },\n144\t            },\n145\t          },\n146\t          makeResultMessage(),\n147\t        ]),\n148\t      );\n149\t\n150\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n151\t      expect(events[0]).toEqual({ type: 'text', text: 'Hello world' });\n152\t    });\n153\t\n154\t    it('maps content_block_stop to tool-complete event', async () => {\n155\t      mockQuery.mockReturnValue(\n156\t        fakeStream([\n157\t          {\n158\t            type: 'stream_event',\n159\t            event: { type: 'content_block_stop' },\n160\t          },\n161\t          makeResultMessage(),\n162\t        ]),\n163\t      );\n164\t\n165\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n166\t      expect(events[0]).toEqual({ type: 'tool-complete' });\n167\t    });\n168\t\n169\t    it('maps api_retry system event to retry event', async () => {\n170\t      mockQuery.mockReturnValue(\n171\t        fakeStream([\n172\t          {\n173\t            type: 'system',\n174\t            subtype: 'api_retry',\n175\t            attempt: 2,\n176\t            retry_delay_ms: 5000,\n177\t          },\n178\t          makeResultMessage(),\n179\t        ]),\n180\t      );\n181\t\n182\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n183\t      expect(events[0]).toEqual({ type: 'retry', attempt: 2, delay: 5000 });\n184\t    });\n185\t\n186\t    it('maps result message to result event with cost', async () => {\n187\t      mockQuery.mockReturnValue(\n188\t        fakeStream([makeResultMessage({ total_cost_usd: 0.123, session_id: 'sess-xyz' })]),\n189\t      );\n190\t\n191\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n192\t      expect(events).toHaveLength(1);\n193\t      expect(events[0]).toEqual(\n194\t        expect.objectContaining({\n195\t          type: 'result',\n196\t          cost: 0.123,\n197\t          sessionId: 'sess-xyz',\n198\t        }),\n199\t      );\n200\t    });\n201\t\n202\t    it('yields correct event sequence from mixed SDK messages', async () => {\n203\t      mockQuery.mockReturnValue(\n204\t        fakeStream([\n205\t          {\n206\t            type: 'stream_event',\n207\t            event: {\n208\t              type: 'content_block_start',\n209\t              content_block: { type: 'tool_use', name: 'Read', id: 'tool-2' },\n210\t            },\n211\t          },\n212\t          {\n213\t            type: 'stream_event',\n214\t            event: {\n215\t              type: 'content_block_delta',\n216\t              delta: { type: 'input_json_delta', partial_json: '{\"path\":\"/foo\"}' },\n217\t            },\n218\t          },\n219\t          {\n220\t            type: 'stream_event',\n221\t            event: { type: 'content_block_stop' },\n222\t          },\n223\t          {\n224\t            type: 'stream_event',\n225\t            event: {\n226\t              type: 'content_block_delta',\n227\t              delta: { type: 'text_delta', text: 'Done.' },\n228\t            },\n229\t          },\n230\t          makeResultMessage(),\n231\t        ]),\n232\t      );\n233\t\n234\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n235\t      expect(events.map((e) => e.type)).toEqual([\n236\t        'tool-start',\n237\t        'tool-input',\n238\t        'tool-complete',\n239\t        'text',\n240\t        'result',\n241\t      ]);\n242\t    });\n243\t\n244\t    it('skips unrecognized SDK messages', async () => {\n245\t      mockQuery.mockReturnValue(\n246\t        fakeStream([\n247\t          { type: 'system', subtype: 'init', tools: [] },\n248\t          { type: 'stream_event', event: { type: 'message_start' } },\n249\t          makeResultMessage(),\n250\t        ]),\n251\t      );\n252\t\n253\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n254\t      // Only the result event should be yielded\n255\t      expect(events).toHaveLength(1);\n256\t      expect(events[0].type).toBe('result');\n257\t    });\n258\t\n259\t    it('skips content_block_start with non-tool_use type (e.g., text block)', async () => {\n260\t      mockQuery.mockReturnValue(\n261\t        fakeStream([\n262\t          {\n263\t            type: 'stream_event',\n264\t            event: {\n265\t              type: 'content_block_start',\n266\t              content_block: { type: 'text' },\n267\t            },\n268\t          },\n269\t          makeResultMessage(),\n270\t        ]),\n271\t      );\n272\t\n273\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n274\t      // Only the result event, text block start is skipped\n275\t      expect(events).toHaveLength(1);\n276\t      expect(events[0].type).toBe('result');\n277\t    });\n278\t\n279\t    it('skips content_block_delta with unrecognized delta type', async () => {\n280\t      mockQuery.mockReturnValue(\n281\t        fakeStream([\n282\t          {\n283\t            type: 'stream_event',\n284\t            event: {\n285\t              type: 'content_block_delta',\n286\t              delta: { type: 'unknown_delta_type', data: 'foo' },\n287\t            },\n288\t          },\n289\t          makeResultMessage(),\n290\t        ]),\n291\t      );\n292\t\n293\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n294\t      expect(events).toHaveLength(1);\n295\t      expect(events[0].type).toBe('result');\n296\t    });\n297\t  });\n298\t\n299\t  describe('getLastCost (AC #3)', () => {\n300\t    it('returns null before any dispatch', () => {\n301\t      expect(driver.getLastCost()).toBeNull();\n302\t    });\n303\t\n304\t    it('returns cost from last result message', async () => {\n305\t      mockQuery.mockReturnValue(\n306\t        fakeStream([makeResultMessage({ total_cost_usd: 0.42 })]),\n307\t      );\n308\t\n309\t      await collectEvents(driver.dispatch(makeOpts()));\n310\t      expect(driver.getLastCost()).toBe(0.42);\n311\t    });\n312\t\n313\t    it('returns null when SDK reports no cost', async () => {\n314\t      mockQuery.mockReturnValue(\n315\t        fakeStream([makeResultMessage({ total_cost_usd: undefined })]),\n316\t      );\n317\t\n318\t      await collectEvents(driver.dispatch(makeOpts()));\n319\t      expect(driver.getLastCost()).toBeNull();\n320\t    });\n321\t\n322\t    it('updates cost on each new dispatch', async () => {\n323\t      mockQuery.mockReturnValue(\n324\t        fakeStream([makeResultMessage({ total_cost_usd: 0.10 })]),\n325\t      );\n326\t      await collectEvents(driver.dispatch(makeOpts()));\n327\t      expect(driver.getLastCost()).toBe(0.10);\n328\t\n329\t      mockQuery.mockReturnValue(\n330\t        fakeStream([makeResultMessage({ total_cost_usd: 0.25 })]),\n331\t      );\n332\t      await collectEvents(driver.dispatch(makeOpts()));\n333\t      expect(driver.getLastCost()).toBe(0.25);\n334\t    });\n335\t\n336\t    it('resets cost to null at start of dispatch even if previous had cost', async () => {\n337\t      mockQuery.mockReturnValue(\n338\t        fakeStream([makeResultMessage({ total_cost_usd: 0.10 })]),\n339\t      );\n340\t      await collectEvents(driver.dispatch(makeOpts()));\n341\t      expect(driver.getLastCost()).toBe(0.10);\n342\t\n343\t      // Dispatch that errors before result\n344\t      mockQuery.mockImplementation(() => {\n345\t        throw new Error('Something broke');\n346\t      });\n347\t      await collectEvents(driver.dispatch(makeOpts()));\n348\t      expect(driver.getLastCost()).toBeNull();\n349\t    });\n350\t  });\n351\t\n352\t  describe('error classification (AC #5)', () => {\n353\t    it('classifies HTTP 429 as RATE_LIMIT', async () => {\n354\t      const sdkError = Object.assign(new Error('Rate limit exceeded'), { status: 429 });\n355\t      mockQuery.mockImplementation(() => { throw sdkError; });\n356\t\n357\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n358\t      expect(events).toHaveLength(1);\n359\t      expect(events[0].type).toBe('result');\n360\t      expect((events[0] as ResultEvent).errorCategory).toBe('RATE_LIMIT');\n361\t    });\n362\t\n363\t    it('classifies \"rate limit\" in message as RATE_LIMIT', async () => {\n364\t      mockQuery.mockImplementation(() => { throw new Error('You have been rate limited'); });\n365\t\n366\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n367\t      expect((events[0] as ResultEvent).errorCategory).toBe('RATE_LIMIT');\n368\t    });\n369\t\n370\t    it('classifies ECONNREFUSED as NETWORK', async () => {\n371\t      mockQuery.mockImplementation(() => {\n372\t        throw Object.assign(new Error('connect ECONNREFUSED'), { code: 'ECONNREFUSED' });\n373\t      });\n374\t\n375\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n376\t      expect((events[0] as ResultEvent).errorCategory).toBe('NETWORK');\n377\t    });\n378\t\n379\t    it('classifies ETIMEDOUT as NETWORK', async () => {\n380\t      mockQuery.mockImplementation(() => {\n381\t        throw Object.assign(new Error('request timed out'), { code: 'ETIMEDOUT' });\n382\t      });\n383\t\n384\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n385\t      expect((events[0] as ResultEvent).errorCategory).toBe('NETWORK');\n386\t    });\n387\t\n388\t    it('classifies network fetch failure via message regex