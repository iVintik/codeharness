{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0171WHovwW5iNeSrW6T9WteC","type":"tool_result","content":"1\t/**\n2\t * Codex Driver — CLI-wrapped driver for OpenAI Codex.\n3\t *\n4\t * Spawns the `codex` CLI binary via child_process.spawn and parses\n5\t * its NDJSON stdout into StreamEvent objects.\n6\t *\n7\t * @see architecture-multi-framework.md — Decision 1: Driver Interface Design\n8\t * @see architecture-multi-framework.md — Decision 2: CLI-Wrapping Strategy\n9\t */\n10\t\n11\timport { spawn } from 'node:child_process';\n12\timport { execFile } from 'node:child_process';\n13\timport { createInterface } from 'node:readline';\n14\timport { promisify } from 'node:util';\n15\timport type {\n16\t  AgentDriver,\n17\t  DispatchOpts,\n18\t  DriverHealth,\n19\t  DriverCapabilities,\n20\t  ErrorCategory,\n21\t} from '../types.js';\n22\timport type { StreamEvent, ResultEvent } from '../stream-parser.js';\n23\t\n24\tconst execFileAsync = promisify(execFile);\n25\t\n26\t// --- Error Classification ---\n27\t\n28\tconst NETWORK_CODES = new Set([\n29\t  'ECONNREFUSED',\n30\t  'ETIMEDOUT',\n31\t  'ENOTFOUND',\n32\t  'ENETUNREACH',\n33\t  'ECONNRESET',\n34\t  'EPIPE',\n35\t]);\n36\t\n37\t/**\n38\t * Classify an error string or Error into a standard ErrorCategory.\n39\t *\n40\t * Priority order:\n41\t * 1. HTTP 429 or \"rate limit\" -> RATE_LIMIT\n42\t * 2. Known network error codes -> NETWORK\n43\t * 3. HTTP 401/403 or \"unauthorized\"/\"forbidden\" -> AUTH\n44\t * 4. Timeout -> TIMEOUT\n45\t * 5. Everything else -> UNKNOWN\n46\t */\n47\texport function classifyError(err: unknown): ErrorCategory {\n48\t  const message = err instanceof Error ? err.message : String(err);\n49\t  const code = (err as { code?: string })?.code;\n50\t  const status = (err as { status?: number })?.status;"}]},"parent_tool_use_id":"toolu_01NxoLQrDSbN8zX2VNmPKjEA","session_id":"8f19e005-5742-4a5a-a61f-d8a88dc16bec","uuid":"0282c469-aa2f-4c71-9122-b34ebe850c61","timestamp":"2026-04-03T10:25:24.671Z"}
