n    47→const baseState: HarnessState = {\n    48→  harness_version: '0.0.0-dev',\n    49→  initialized: true,\n    50→  stack: 'nodejs',\n    51→  stacks: ['nodejs'],\n    52→  enforcement: { frontend: true, database: true, api: true },\n    53→  coverage: { target: 90, baseline: null, current: null, tool: 'c8' },\n    54→  session_flags: { logs_queried: false, tests_passed: false, coverage_met: false, verification_run: false },\n    55→  verification_log: [],\n    56→  otlp: { enabled: true, endpoint: 'http://localhost:4318', service_name: 'test', mode: 'local-shared' },\n    57→};\n    58→\n    59→beforeEach(() => {\n    60→  vi.clearAllMocks();\n    61→  vi.spyOn(console, 'log').mockImplementation(() => {});\n    62→  mockIsDockerAvailable.mockReturnValue(true);\n    63→  mockIsSharedStackRunning.mockReturnValue(false);\n    64→  mockStartSharedStack.mockReturnValue({\n    65→    started: true,\n    66→    services: [\n    67→      { name: 'victoria-logs', status: 'running', port: '9428' },\n    68→      { name: 'otel-collector', status: 'running', port: '4317,4318' },\n    69→    ],\n    70→  });\n    71→  mockStartCollectorOnly.mockReturnValue({\n    72→    started: true,\n    73→    services: [{ name: 'otel-collector', status: 'running', port: '4317,4318' }],\n    74→  });\n    75→});\n    76→\n    77→describe('checkDocker', () => {\n    78→  it('returns available=true when Docker is available', () => {\n    79→    const result = checkDocker({ observability: true, isJson: false });\n    80→    expect(result.success).toBe(true);\n    81→    if (result.success) {\n    82→      expect(result.data.available).toBe(true);\n    83→      expect(result.data.criticalFailure).toBe(false);\n    84→    }\n    85→  });\n    86→\n    87→  it('returns critical failure when Docker missing and observability on', () => {\n    88→    mockIsDockerAvailable.mockReturnValue(false);\n    89→    const result = checkDocker({ observability: true, isJson: false });\n    90→    expect(result.success).toBe(true);\n    91→    if (result.success) {\n    92→      expect(result.data.available).toBe(false);\n    93→      expect(result.data.criticalFailure).toBe(true);\n    94→      expect(result.data.dockerResult).toBeDefined();\n    95→    }\n    96→  });\n    97→\n    98→  it('returns non-critical when Docker missing and observability off', () => {\n    99→    mockIsDockerAvailable.mockReturnValue(false);\n   100→    const result = checkDocker({ observability: false, isJson: false });\n   101→    expect(result.success).toBe(true);\n   102→    if (result.success) {\n   103→      expect(result.data.available).toBe(false);\n   104→      expect(result.data.criticalFailure).toBe(false);\n   105→    }\n   106→  });\n   107→\n   108→  it('skips Docker check for remote-direct mode', () => {\n   109→    mockIsDockerAvailable.mockReturnValue(false);\n   110→    const result = checkDocker({ observability: true, otelEndpoint: 'http://remote:4318', isJson: false });\n   111→    expect(result.success).toBe(true);\n   112→    if (result.success) {\n   113→      expect(result.data.available).toBe(true);\n   114→      expect(result.data.criticalFailure).toBe(false);\n   115→    }\n   116→  });\n   117→});\n   118→\n   119→describe('setupDocker', () => {\n   120→  it('skips Docker when observability off', () => {\n   121→    const result = setupDocker({\n   122→      observability: false,\n   123→      isJson: false,\n   124→      dockerAvailable: true,\n   125→      state: { ...baseState },\n   126→      projectDir: '/tmp/test',\n   127→    });\n   128→    expect(result.success).toBe(true);\n   129→    if (result.success) {\n   130→      expect(result.data.docker).toBeNull();\n   131→    }\n   132→  });\n   133→\n   134→  it('configures remote-direct mode', () => {\n   135→    const result = setupDocker({\n   136→      observability: true,\n   137→      otelEndpoint: 'http://remote:4318',\n   138→      isJson: false,\n   139→      dockerAvailable: false,\n   140→      state: { ...baseState },\n   141→      projectDir: '/tmp/test',\n   142→    });\n   143→    expect(result.success).toBe(true);\n   144→    if (result.success) {\n   145→      expect(result.data.docker).toBeNull();\n   146→      expect(result.data.state.otlp!.mode).toBe('remote-direct');\n   147→      expect(result.data.state.otlp!.endpoint).toBe('http://remote:4318');\n   148→    }\n   149→  });\n   150→\n   151→  it('configures remote-routed mode', () => {\n   152→    const result = setupDocker({\n   153→      observability: true,\n   154→      logsUrl: 'http://logs:9428',\n   155→      metricsUrl: 'http://metrics:8428',\n   156→      tracesUrl: 'http://traces:16686',\n   157→      isJson: false,\n   158→      dockerAvailable: true,\n   159→      state: { ...baseState },\n   160→      projectDir: '/tmp/test',\n   161→    });\n   162→    expect(result.success).toBe(true);\n   163→    if (result.success) {\n   164→      expect(result.data.docker!.stack_running).toBe(true);\n   165→      expect(result.data.state.otlp!.mode).toBe('remote-routed');\n   166→    }\n   167→    expect(mockStartCollectorOnly).toHaveBeenCalledWith(\n   168→      'http://logs:9428', 'http://metrics:8428', 'http://traces:16686',\n   169→    );\n   170→  });\n   171→\n   172→  it('starts local-shared stack', () => {\n   173→    const result = setupDocker({\n   174→      observability: true,\n   175→      isJson: false,\n   176→      dockerAvailable: true,\n   177→      state: { ...baseState },\n   178→      projectDir: '/tmp/test',\n   179→    });\n   180→    expect(result.success).toBe(true);\n   181→    if (result.success) {\n   182→      expect(result.data.docker!.stack_running).toBe(true);\n   183→      expect(result.data.state.otlp!.mode).toBe('local-shared');\n   184→    }\n   185→    expect(mockStartSharedStack).toHaveBeenCalled();\n   186→  });\n   187→\n   188→  it('detects already running shared stack', () => {\n   189→    mockIsSharedStackRunning.mockReturnValue(true);\n   190→    const result = setupDocker({\n   191→      observability: true,\n   192→      isJson: false,\n   193→      dockerAvailable: true,\n   194→      state: { ...baseState },\n   195→      projectDir: '/tmp/test',\n   196→    });\n   197→    expect(result.success).toBe(true);\n   198→    if (result.success) {\n   199→      expect(result.data.docker!.stack_running).toBe(true);\n   200→    }\n   201→    expect(mockStartSharedStack).not.toHaveBeenCalled();\n   202→  });\n   203→\n   204→  it('reports failure when stack fails to start', () => {\n   205→    mockStartSharedStack.mockReturnValue({ started: false, services: [], error: 'timeout' });\n   206→    const result = setupDocker({\n   207→      observability: true,\n   208→      isJson: false,\n   209→      dockerAvailable: true,\n   210→      state: { ...baseState },\n   211→      projectDir: '/tmp/test',\n   212→    });\n   213→    expect(result.success).toBe(true);\n   214→    if (result.success) {\n   215→      expect(result.data.docker!.stack_running).toBe(false);\n   216→    }\n   217→  });\n   218→\n   219→  it('handles Docker not available with deferred observability', () => {\n   220→    const result = setupDocker({\n   221→      observability: true,\n   222→      isJson: false,\n   223→      dockerAvailable: false,\n   224→      state: { ...baseState },\n   225→      projectDir: '/tmp/test',\n   226→    });\n   227→    expect(result.success).toBe(true);\n   228→    if (result.success) {\n   229→      expect(result.data.docker!.stack_running).toBe(false);\n   230→    }\n   231→  });\n   232→\n   233→  it('writes state to disk', () => {\n   234→    setupDocker({\n   235→      observability: true,\n   236→      isJson: false,\n   237→      dockerAvailable: true,\n   238→      state: { ...baseState },\n   239→      projectDir: '/tmp/test',\n   240→    });\n   241→    expect(writeState).toHaveBeenCalled();\n   242→  });\n   243→\n   244→  it('selects ELK compose file when backend is elk', () => {\n   245→    const elkState: HarnessState = {\n   246→      ...baseState,\n   247→      otlp: { ...baseState.otlp!, backend: 'elk' },\n   248→    };\n   249→    const result = setupDocker({\n   250→      observability: true,\n   251→      isJson: false,\n   252→      dockerAvailable: true,\n   253→      state: elkState,\n   254→      projectDir: '/tmp/test',\n   255→    });\n   256→    expect(result.success).toBe(true);\n   257→    if (result.success) {\n   258→      expect(result.data.docker!.compose_file).toContain('docker-compose.elk.yml');\n   259→    }\n   260→  });\n   261→\n   262→  it('selects Victoria compose file when backend is victoria (default)', () => {\n   263→    const result = setupDocker({\n   264→      observability: true,\n   265→      isJson: false,\n   266→      dockerAvailable: true,\n   267→      state: { ...baseState },\n   268→      projectDir: '/tmp/test',\n   269→    });\n   270→    expect(result.success).toBe(true);\n   271→    if (result.success) {\n   272→      expect(result.data.docker!.compose_file).toContain('docker-compose.harness.yml');\n   273→    }\n   274→  });\n   275→});\n   276→"}]},"parent_tool_use_id":"toolu_013rWcam9ZLGWy8y97T6yhWS","session_id":"790cd04c-5c91-45bb-998d-78a56b65af9a","uuid":"b504e6d4-c7af-490f-adb4-804172f2ded7","timestamp":"2026-03-24T23:17:08.340Z"}
