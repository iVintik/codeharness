   expect(frame).toContain('iteration 2');\n63\t    expect(frame).toContain('$5.50 spent');\n64\t    expect(frame).not.toContain('◆');\n65\t    expect(frame).not.toContain('│'); // No Ink Box border character\n66\t    // AC3: Story and Phase on separate lines\n67\t    expect(frame).toContain('Story: 0-5-3');\n68\t    expect(frame).toContain('Phase: dev');\n69\t  });\n70\t\n71\t  it('renders separator line with heavy bars', () => {\n72\t    const info: SprintInfo = {\n73\t      storyKey: '1-1',\n74\t      phase: 'dev',\n75\t      done: 0,\n76\t      total: 5,\n77\t    };\n78\t    const { lastFrame } = render(<Header info={info} />);\n79\t    const frame = lastFrame()!;\n80\t    // AC2: separator line\n81\t    expect(frame).toContain('━━━');\n82\t  });\n83\t\n84\t  it('renders nothing when info is null', () => {\n85\t    const { lastFrame } = render(<Header info={null} />);\n86\t    expect(lastFrame()).toBe('');\n87\t  });\n88\t\n89\t  it('renders Phase with AC progress and current command', () => {\n90\t    const info: SprintInfo = {\n91\t      storyKey: '3-2',\n92\t      phase: 'verify',\n93\t      done: 18,\n94\t      total: 65,\n95\t      acProgress: '8/12',\n96\t      currentCommand: 'docker exec ... codeharness init --json',\n97\t    };\n98\t    const { lastFrame } = render(<Header info={info} />);\n99\t    const frame = lastFrame()!;\n100\t    expect(frame).toContain('Phase: verify');\n101\t    expect(frame).toContain('AC 8/12');\n102\t    expect(frame).toContain('(docker exec ... codeharness init --json)');\n103\t  });\n104\t\n105\t  it('omits iteration and cost when not provided', () => {\n106\t    const info: SprintInfo = {\n107\t      storyKey: '1-1',\n108\t      phase: 'dev',\n109\t      done: 0,\n110\t      total: 5,\n111\t    };\n112\t    const { lastFrame } = render(<Header info={info} />);\n113\t    const frame = lastFrame()!;\n114\t    expect(frame).toContain('codeharness run');\n115\t    expect(frame).not.toContain('iteration');\n116\t    expect(frame).not.toContain('spent');\n117\t    expect(frame).not.toContain('undefined');\n118\t  });\n119\t});\n120\t\n121\tdescribe('Separator component', () => {\n122\t  it('renders a line of heavy bar characters', () => {\n123\t    const { lastFrame } = render(<Separator />);\n124\t    const frame = lastFrame()!;\n125\t    expect(frame).toContain('━━━');\n126\t    // Verify it uses only ━ characters\n127\t    expect(frame.trim()).toMatch(/^━+$/);\n128\t  });\n129\t});\n130\t\n131\tdescribe('Header with elapsed time (AC #3)', () => {\n132\t  it('renders elapsed time when provided', () => {\n133\t    const info: SprintInfo = {\n134\t      storyKey: '3-2',\n135\t      phase: 'verify',\n136\t      done: 18,\n137\t      total: 65,\n138\t      elapsed: '47m',\n139\t      iterationCount: 3,\n140\t      totalCost: 12.30,\n141\t    };\n142\t    const { lastFrame } = render(<Header info={info} />);\n143\t    const frame = lastFrame()!;\n144\t    expect(frame).toContain('codeharness run');\n145\t    expect(frame).toContain('iteration 3');\n146\t    expect(frame).toContain('47m elapsed');\n147\t    expect(frame).toContain('$12.30 spent');\n148\t    expect(frame).toContain('Story: 3-2');\n149\t    expect(frame).toContain('Phase: verify');\n150\t  });\n151\t\n152\t  it('omits elapsed when not provided', () => {\n153\t    const info: SprintInfo = {\n154\t      storyKey: '1-1',\n155\t      phase: 'dev',\n156\t      done: 0,\n157\t      total: 5,\n158\t    };\n159\t    const { lastFrame } = render(<Header info={info} />);\n160\t    const frame = lastFrame()!;\n161\t    expect(frame).toContain('Story: 1-1');\n162\t    expect(frame).not.toContain('undefined');\n163\t  });\n164\t});\n165\t\n166\tdescribe('StoryBreakdown component (AC #4)', () => {\n167\t  it('renders labeled sections: Done, This, Next, Blocked', () => {\n168\t    const stories: StoryStatusEntry[] = [\n169\t      { key: '3-1-some-story', status: 'done' },\n170\t      { key: '4-1-another', status: 'done' },\n171\t      { key: '3-2-current', status: 'in-progress' },\n172\t      { key: '3-3-next-one', status: 'pending' },\n173\t      { key: '0-1-stuck', status: 'blocked', retryCount: 10, maxRetries: 10 },\n174\t    ];\n175\t    const { lastFrame } = render(<StoryBreakdown stories={stories} />);\n176\t    const frame = lastFrame()!;\n177\t    // Done: individual short keys with checkmarks\n178\t    expect(frame).toContain('Done:');\n179\t    expect(frame).toContain('3-1 ✓');\n180\t    expect(frame).toContain('4-1 ✓');\n181\t    // This: current story with diamond\n182\t    expect(frame).toContain('This:');\n183\t    expect(frame).toContain('3-2 ◆');\n184\t    // Next: next pending story\n185\t    expect(frame).toContain('Next:');\n186\t    expect(frame).toContain('3-3');\n187\t    // Blocked: with ✕ and retry counts\n188\t    expect(frame).toContain('Blocked:');\n189\t    expect(frame).toContain('0-1 ✕');\n190\t    expect(frame).toContain('(10/10)');\n191\t  });\n192\t\n193\t  it('renders nothing when stories array is empty', () => {\n194\t    const { lastFrame } = render(<StoryBreakdown stories={[]} />);\n195\t    expect(lastFrame()).toBe('');\n196\t  });\n197\t\n198\t  it('renders failed stories with ✗', () => {\n199\t    const stories: StoryStatusEntry[] = [\n200\t      { key: '2-3-broken', status: 'failed', retryCount: 5, maxRetries: 10 },"}]},"parent_tool_use_id":"toolu_01FXbxFTW7bzJr4gL7DWdcAa","session_id":"a0646c12-93c6-41a0-9c7a-50683cae7716","uuid":"308779e4-d706-42dd-a353-e19d5d12ec1a","timestamp":"2026-04-03T13:00:59.399Z"}
