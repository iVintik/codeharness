  219→  });\n   220→});\n   221→\n   222→describe('countStories', () => {\n   223→  it('counts stories by status correctly', () => {\n   224→    const counts = countStories({\n   225→      'epic-5': 'in-progress',\n   226→      '5-1-ralph-loop': 'ready-for-dev',\n   227→      '5-2-verification': 'backlog',\n   228→      '5-3-tracking': 'done',\n   229→      '5-4-another': 'in-progress',\n   230→      'epic-5-retrospective': 'optional',\n   231→    });\n   232→    expect(counts).toEqual({ total: 4, ready: 2, done: 1, inProgress: 1, verified: 0 });\n   233→  });\n   234→\n   235→  it('ignores epic keys and retrospective keys', () => {\n   236→    const counts = countStories({\n   237→      'epic-1': 'done', 'epic-1-retrospective': 'done',\n   238→      '1-1-story-one': 'done', '1-2-story-two': 'done',\n   239→    });\n   240→    expect(counts.total).toBe(2);\n   241→    expect(counts.done).toBe(2);\n   242→  });\n   243→\n   244→  it('returns zeros for empty statuses', () => {\n   245→    expect(countStories({})).toEqual({ total: 0, ready: 0, done: 0, inProgress: 0, verified: 0 });\n   246→  });\n   247→\n   248→  it('counts review status as inProgress', () => {\n   249→    expect(countStories({ '1-1-story': 'review' }).inProgress).toBe(1);\n   250→  });\n   251→\n   252→  it('counts verifying status separately', () => {\n   253→    const counts = countStories({\n   254→      '1-1-story': 'verifying',\n   255→      '1-2-story': 'verifying',\n   256→      '1-3-story': 'done',\n   257→    });\n   258→    expect(counts).toEqual({ total: 3, ready: 0, done: 1, inProgress: 0, verified: 2 });\n   259→  });\n   260→});\n   261→\n   262→describe('buildSpawnArgs', () => {\n   263→  const baseOpts = {\n   264→    ralphPath: '/path/to/ralph.sh',\n   265→    pluginDir: '/path/to/.claude',\n   266→    promptFile: '/path/to/prompt.md',\n   267→    maxIterations: 50,\n   268→    timeout: 14400,\n   269→    iterationTimeout: 15,\n   270→    calls: 100,\n   271→    quiet: false,\n   27