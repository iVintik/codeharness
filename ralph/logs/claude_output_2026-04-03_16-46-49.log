{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UeEy4YTPjcYXs6XPDLggmk","type":"tool_result","content":"1\t/**\n2\t * Ink UI components — types and layout components (Header, Separator, StoryBreakdown).\n3\t *\n4\t * Renders a UX-spec-compliant live display with plain text header,\n5\t * ━━━ separators, and labeled story breakdown sections.\n6\t * Activity components (tools, thoughts, retry) are in ink-activity-components.tsx.\n7\t * The App root component is in ink-app.tsx to avoid circular imports.\n8\t */\n9\t\n10\timport React from 'react';\n11\timport { Text, Box } from 'ink';\n12\timport type { FlowStep } from './workflow-parser.js';\n13\t\n14\t// --- Types ---\n15\t\n16\texport interface SprintInfo {\n17\t  storyKey: string;\n18\t  phase: string;\n19\t  done: number;\n20\t  total: number;\n21\t  elapsed?: string;\n22\t  iterationCount?: number;\n23\t  totalCost?: number;\n24\t  acProgress?: string;\n25\t  currentCommand?: string;\n26\t}\n27\t\n28\texport interface CompletedToolEntry {\n29\t  name: string;\n30\t  args: string;\n31\t  driver?: string;\n32\t}\n33\t\n34\texport type StoryStatusValue = 'done' | 'in-progress' | 'pending' | 'failed' | 'blocked';\n35\t\n36\texport interface StoryStatusEntry {\n37\t  key: string;\n38\t  status: StoryStatusValue;\n39\t  retryCount?: number;\n40\t  maxRetries?: number;\n41\t  costByDriver?: Record<string, number>;\n42\t}\n43\t\n44\texport interface RetryInfo {\n45\t  attempt: number;\n46\t  delay: number;\n47\t}\n48\t\n49\texport interface StoryMessage {\n50\t  type: 'ok' | 'warn' | 'fail';\n51\t  key: string;\n52\t  message: string;\n53\t  details?: string[];\n54\t}\n55\t\n56\texport type TaskNodeState = 'pending' | 'active' | 'done' | 'failed';\n57\t\n58\texport interface TaskNodeMeta {\n59\t  driver?: string;\n60\t  costUsd?: number | null;\n61\t  elapsedMs?: number | null;\n62\t}\n63\t\n64\texport interface RendererState {\n65\t  sprintInfo: SprintInfo | null;\n66\t  stories: StoryStatusEntry[];\n67\t  messages: StoryMessage[];\n68\t  completedTools: CompletedToolEntry[];\n69\t  activeTool: { name: string } | null;\n70\t  activeToolArgs: string;\n71\t  lastThought: string | null;\n72\t  retryInfo: RetryInfo | null;\n73\t  workflowFlow: FlowStep[];\n74\t  currentTaskName: string | null;\n75\t  taskStates: Record<string, TaskNodeState>;\n76\t  taskMeta: Record<string, TaskNodeMeta>;\n77\t  activeDriverName: string | null;\n78\t  driverCosts: Record<string, number>;\n79\t}\n80\t\n81\t// --- Layout Components ---\n82\t\n83\t/** Full-width separator using ━ characters. */\n84\texport function Separator() {\n85\t  const width = process.stdout.columns || 60;\n86\t  return <Text>{'━'.repeat(width)}</Text>;\n87\t}\n88\t\n89\tfunction shortKey(key: string): string {\n90\t  const m = key.match(/^(\\d+-\\d+)/);\n91\t  return m ? m[1] : key;\n92\t}\n93\t\n94\tfunction formatCost(cost: number): string {\n95\t  return `$${cost.toFixed(2)}`;\n96\t}\n97\t\n98\texport function Header({ info }: { info: SprintInfo | null }) {\n99\t  if (!info) return null;\n100\t\n101\t  const parts: string[] = ['codeharness run'];\n102\t  if (info.iterationCount != null) {\n103\t    parts.push(`iteration ${info.iterationCount}`);\n104\t  }\n105\t  if (info.elapsed) {\n106\t    parts.push(`${info.elapsed} elapsed`);\n107\t  }\n108\t  if (info.totalCost != null) {\n109\t    parts.push(`${formatCost(info.totalCost)} spent`);\n110\t  }\n111\t  const headerLine = parts.join(' | ');\n112\t\n113\t  let phaseLine = '';\n114\t  if (info.phase) {\n115\t    phaseLine = `Phase: ${info.phase}`;\n116\t    if (info.acProgress) {\n117\t      phaseLine += ` → AC ${info.acProgress}`;\n118\t    }\n119\t    if (info.currentCommand) {\n120\t      phaseLine += ` (${info.currentCommand})`;\n121\t    }\n122\t  }\n123\t\n124\t  return (\n125\t    <Box flexDirection=\"column\">\n126\t      <Text>{headerLine}</Text>\n127\t      <Separator />\n128\t      <Text>{`Story: ${info.storyKey || '(waiting)'}`}</Text>\n129\t      {phaseLine && <Text>{phaseLine}</Text>}\n130\t    </Box>\n131\t  );\n132\t}\n133\t\n134\texport function StoryBreakdown({ stories, sprintInfo }: { stories: StoryStatusEntry[]; sprintInfo?: SprintInfo | null }) {\n135\t  if (stories.length === 0) return null;\n136\t\n137\t  const done: StoryStatusEntry[] = [];\n138\t  const inProgress: StoryStatusEntry[] = [];\n139\t  const pending: StoryStatusEntry[] = [];\n140\t  const failed: StoryStatusEntry[] = [];\n141\t  const blocked: StoryStatusEntry[] = [];\n142\t\n143\t  for (const s of stories) {\n144\t    switch (s.status) {\n145\t      case 'done': done.push(s); break;\n146\t      case 'in-progress': inProgress.push(s); break;\n147\t      case 'pending': pending.push(s); break;\n148\t      case 'failed': failed.push(s); break;\n149\t      case 'blocked': blocked.push(s); break;\n150\t    }\n151\t  }\n152\t\n153\t  const lines: React.ReactNode[] = [];\n154\t\n155\t  if (done.length > 0) {\n156\t    const doneItems = done.map(s => {\n157\t      let item = `${shortKey(s.key)} ✓`;\n158\t      if (s.costByDriver && Object.keys(s.costByDriver).length > 0) {\n159\t        const costParts = Object.keys(s.costByDriver).sort().map(\n160\t          driver => `${driver} ${formatCost(s.costByDriver![driver])}`\n161\t        );\n162\t        item += ` ${costParts.join(', ')}`;\n163\t      }\n164\t      return item;\n165\t    }).join('  ');\n166\t    lines.push(\n167\t      <Text key=\"done\"><Text color=\"green\">{'Done: '}</Text><Text color=\"green\">{doneItems}</Text></Text>\n168\t    );\n169\t  }\n170\t\n171\t  if (inProgress.length > 0) {\n172\t    for (const s of inProgress) {\n173\t      let thisText = `${shortKey(s.key)} ◆`;\n174\t      if (sprintInfo && sprintInfo.storyKey && shortKey(s.key) === shortKey(sprintInfo.storyKey)) {\n175\t        if (sprintInfo.phase) thisText += ` ${sprintInfo.phase}`;\n176\t        if (sprintInfo.acProgress) thisText += ` (${sprintInfo.acProgress} ACs)`;\n177\t      }\n178\t      lines.push(\n179\t        <Text key={`this-${s.key}`}><Text color=\"cyan\">{'This: '}</Text><Text color=\"cyan\">{thisText}</Text></Text>\n180\t      );\n181\t    }\n182\t  }\n183\t\n184\t  if (pending.length > 0) {\n185\t    lines.push(\n186\t      <Text key=\"next\">\n187\t        <Text>{'Next: '}</Text><Text>{shortKey(pending[0].key)}</Text>\n188\t        {pending.length > 1 && <Text dimColor>{` (+${pending.length - 1} more)`}</Text>}\n189\t      </Text>\n190\t    );\n191\t  }\n192\t\n193\t  if (blocked.length > 0) {\n194\t    const blockedItems = blocked.map(s => {\n195\t      let item = `${shortKey(s.key)} ✕`;\n196\t      if (s.retryCount != null && s.maxRetries != null) item += ` (${s.retryCount}/${s.maxRetries})`;\n197\t      return item;\n198\t    }).join('  ');\n199\t    lines.push(\n200\t      <Text key=\"blocked\"><Text color=\"yellow\">{'Blocked: '}</Text><Text color=\"yellow\">{blockedItems}</Text></Text>\n201\t    );\n202\t  }\n203\t\n204\t  if (failed.length > 0) {\n205\t    const failedItems = failed.map(s => {\n206\t      let item = `${shortKey(s.key)} ✗`;\n207\t      if (s.retryCount != null && s.maxRetries != null) item += ` (${s.retryCount}/${s.maxRetries})`;\n208\t      return item;\n209\t    }).join('  ');\n210\t    lines.push(\n211\t      <Text key=\"failed\"><Text color=\"red\">{'Failed: '}</Text><Text color=\"red\">{failedItems}</Text></Text>\n212\t    );\n213\t  }\n214\t\n215\t  return (\n216\t    <Box flexDirection=\"column\">\n217\t      {lines}\n218\t    </Box>\n219\t  );\n220\t}\n221\t\n222\t// Re-export activity components so existing consumers don't break\n223\texport { CompletedTool, CompletedTools, ActiveTool, LastThought, RetryNotice, StoryMessageLine, DriverCostSummary } from './ink-activity-components.js';\n224\t\n225\t// Re-export App from ink-app\n226\texport { App } from './ink-app.js';\n227\t"}]},"parent_tool_use_id":"toolu_01FXbxFTW7bzJr4gL7DWdcAa","session_id":"a0646c12-93c6-41a0-9c7a-50683cae7716","uuid":"e0e435fb-f3a7-4f85-a55d-260689cb09e9","timestamp":"2026-04-03T13:00:54.129Z"}
