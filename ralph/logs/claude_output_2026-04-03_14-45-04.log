, 'implement', '5-1-foo', definition, state, config);\n2695\t\n2696\t    // Session ID was extracted from result event and recorded\n2697\t    expect(mockRecordSessionId).toHaveBeenCalledWith(\n2698\t      { taskName: 'implement', storyKey: '5-1-foo' },\n2699\t      'sess-driver-1',\n2700\t      state,\n2701\t    );\n2702\t  });\n2703\t\n2704\t  it('maps error result events to DispatchError (AC #5)', async () => {\n2705\t    mockDriverDispatch.mockImplementation(() => {\n2706\t      return (async function* () {\n2707\t        yield { type: 'text', text: 'partial output' };\n2708\t        yield {\n2709\t          type: 'result',\n2710\t          cost: 0,\n2711\t          sessionId: 'sess-err',\n2712\t          error: 'Rate limit exceeded',\n2713\t          errorCategory: 'RATE_LIMIT',\n2714\t        };\n2715\t      })();\n2716\t    });\n2717\t\n2718\t    const task = makeTask();\n2719\t    const definition = makeDefinition();\n2720\t    const state = makeDefaultState();\n2721\t    const config = makeConfig();\n2722\t\n2723\t    await expect(\n2724\t      dispatchTask(task, 'implement', '5-1-foo', definition, state, config),\n2725\t    ).rejects.toThrow('Rate limit exceeded');\n2726\t\n2727\t    // Error should be a DispatchError with RATE_LIMIT code\n2728\t    try {\n2729\t      await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n2730\t    } catch (err: unknown) {\n2731\t      expect((err as { code: string }).code).toBe('RATE_LIMIT');\n2732\t    }\n2733\t  });\n2734\t\n2735\t  it('maps AUTH/TIMEOUT errorCategory to UNKNOWN DispatchErrorCode (AC #5)', async () => {\n2736\t    mockDriverDispatch.mockImplementation(() => {\n2737\t      return (async function* () {\n2738\t        yield {\n2739\t          type: 'result',\n2740\t          cost: 0,\n2741\t          sessionId: 'sess-err',\n2742\t          error: 'Authentication failed',\n2743\t          errorCategory: 'AUTH',\n2744\t        };\n2745\t      })();\n2746\t    });\n2747\t\n2748\t    con