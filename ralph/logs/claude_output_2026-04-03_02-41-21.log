fig({\n1053\t      workflow: {\n1054\t        tasks: { implement: makeTask() },\n1055\t        flow: ['nonexistent-task', 'implement'],\n1056\t      },\n1057\t    });\n1058\t\n1059\t    const result = await executeWorkflow(config);\n1060\t\n1061\t    expect(mockWarn).toHaveBeenCalledWith(\n1062\t      expect.stringContaining('task \"nonexistent-task\" not found'),\n1063\t    );\n1064\t    // implement should still run\n1065\t    expect(mockDispatchAgent).toHaveBeenCalledTimes(1);\n1066\t    expect(result.success).toBe(true);\n1067\t  });\n1068\t\n1069\t  it('halts on NETWORK dispatch errors for per-run tasks', async () => {\n1070\t    const { DispatchError } = await import('../agent-dispatch.js');\n1071\t    mockDispatchAgent.mockRejectedValue(\n1072\t      new DispatchError('network fail', 'NETWORK', 'dev', new Error('inner')),\n1073\t    );\n1074\t\n1075\t    mockParse.mockReturnValue({\n1076\t      development_status: { '3-1-foo': 'ready-for-dev' },\n1077\t    });\n1078\t\n1079\t    const config = makeConfig({\n1080\t      workflow: {\n1081\t        tasks: {\n1082\t          implement: makeTask(),\n1083\t          verify: makeTask({ scope: 'per-run' }),\n1084\t        },\n1085\t        flow: ['verify', 'implement'],\n1086\t      },\n1087\t    });\n1088\t\n1089\t    const result = await executeWorkflow(config);\n1090\t\n1091\t    expect(result.success).toBe(false);\n1092\t    // Should halt after verify fails — implement never runs\n1093\t    expect(mockDispatchAgent).toHaveBeenCalledTimes(1);\n1094\t  });\n1095\t});\n1096\t\n1097\t// --- Loop Block Tests (Story 5-2) ---\n1098\t\n1099\tdescribe('parseVerdict', () => {\n1100\t  it('parses valid verdict JSON', () => {\n1101\t    const verdict = parseVerdict(JSON.stringify({\n1102\t      verdict: 'pass',\n1103\t      score: { passed: 3, failed: 0, unknown: 0, total: 3 },\n1104\t      findings: [],\n1105\t    }));\n1106\t\n1107\t    expect(verdict).not.toBeNull();\n1108\t    expect(verdict!.verdict).toBe('pass');\n1109\t    expect(verdict!.score.passed).toBe(3);\n1110\t  });\n1111\t\n1112\t  it('parses verdict with findings', () => {\n1113\t    const input = {\n1114\t      verdict: 'fail',\n1115\t      score: { passed: 1, failed: 1, unknown: 1, total: 3 },\n1116\t      findings: [{\n1117\t        ac: 1,\n1118\t        description: 'Test AC',\n1119\t        status: 'fail',\n1120\t        evidence: {\n1121\t          commands_run: ['npm test'],\n1122\t          output_observed: 'FAIL',\n1123\t          reasoning: 'Tests failed',\n1124\t        },\n1125\t      }],\n1126\t    };\n1127\t\n1128\t    const verdict = parseVerdict(JSON.stringify(input));\n1129\t    expect(verdict).not.toBeNull();\n1130\t    expect(verdict!.findings).toHaveLength(1);\n1131\t    expect(verdict!.findings[0].ac).toBe(1);\n1132\t  });\n1133\t\n1134\t  it('returns null for invalid JSON', () => {\n1135\t    expect(parseVerdict('not json')).toBeNull();\n1136\t  });\n1137\t\n1138\t  it('returns null for missing verdict field', () => {\n1139\t    expect(parseVerdict(JSON.stringify({\n1140\t      score: { passed: 1, failed: 0, unknown: 0, total: 1 },\n1141\t      findings: [],\n1142\t    }))).toBeNull();\n1143\t  });\n1144\t\n1145\t  it('returns null for invalid verdict value', () => {\n1146\t    expect(parseVerdict(JSON.stringify({\n1147\t      verdict: 'maybe',\n1148\t      score: { passed: 1, failed: 0, unknown: 0, total: 1 },\n1149\t      findings: [],\n1150\t    }))).toBeNull();\n1151\t  });\n1152\t\n1153\t  it('returns null for missing score field', () => {\n1154\t    expect(parseVerdict(JSON.stringify({\n1155\t      verdict: 'pass',\n1156\t      findings: [],\n1157\t    }))).toBeNull();\n1158\t  });\n1159\t\n1160\t  it('returns null for missing findings field', () => {\n1161\t    expect(parseVerdict(JSON.stringify({\n1162\t      verdict: 'pass',\n1163\t      score: { passed: 1, failed: 0, unknown: 0, total: 1 },\n1164\t    }))).toBeNull();\n1165\t  });\n1166\t\n1167\t  it('returns null for non-object input', () => {\n1168\t    expect(parseVerdict('\"just a string\"')).toBeNull();\n1169\t    expect(parseVerdict('42')).toBeNull();\n1170\t    expect(parseVerdict('null')).toBeNull();\n1171\t  });\n1172\t\n1173\t  it('returns null when score fields are not numbers', () => {\n1174\t    expect(parseVerdict(JSON.stringify({\n1175\t      verdict: 'pass',\n1176\t      score: { passed: 'one', failed: 0, unknown: 0, total: 1 },\n1177\t      findings: [],\n1178\t    }))).toBeNull();\n1179\t  });\n1180\t});\n1181\t\n1182\tdescribe('buildRetryPrompt', () => {\n1183\t  it('builds prompt with failed findings', () => {\n1184\t    const findings: EvaluatorVerdict['findings'] = [\n1185\t      {\n1186\t        ac: 1,\n1187\t        description: 'Unit tests pass',\n1188\t        status: 'fail',\n1189\t        evidence: { commands_run: ['npm test'], output_observed: 'FAIL', reasoning: 'Tests failed' },\n1190\t      },\n1191\t      {\n1192\t        ac: 2,\n1193\t        description: 'Coverage above 80%',\n1194\t        status: 'pass',\n1195\t        evidence: { commands_run: ['npm test'], output_observed: '90%', reasoning: 'Good coverage' },\n1196\t      },\n1197\t      {\n1198\t        ac: 3,\n1199\t        description: 'Lint clean',"}]},"parent_tool_use_id":"toolu_01GD3dd86R9DYmBSHRKfrVV3","session_id":"8b4a1da7-9e18-4302-ad13-ce7f0aff0314","uuid":"140a2ac5-2a05-440e-8846-8a77e4aa1aa7","timestamp":"2026-04-02T22:53:47.282Z"}
