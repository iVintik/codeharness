{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012mz41wzBDrFB4EHsopN4Bv","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { generateReport, getStoryDrillDown } from '../reporter.js';\n     3→import type { SprintState, StoryState, AcResult } from '../../../types/state.js';\n     4→\n     5→const S_DEFAULTS: StoryState = {\n     6→  status: 'backlog', attempts: 0, lastAttempt: null,\n     7→  lastError: null, proofPath: null, acResults: null,\n     8→};\n     9→\n    10→function s(overrides?: Partial<StoryState>): StoryState {\n    11→  return { ...S_DEFAULTS, ...overrides };\n    12→}\n    13→\n    14→function makeState(overrides?: Partial<SprintState>): SprintState {\n    15→  return {\n    16→    version: 2,\n    17→    sprint: { total: 0, done: 0, failed: 0, blocked: 0, inProgress: null },\n    18→    stories: {},\n    19→    retries: {},\n    20→    flagged: [],\n    21→    epics: {},\n    22→    session: { active: false, startedAt: null, iteration: 0, elapsedSeconds: 0 },\n    23→    observability: { statementCoverage: null, branchCoverage: null, functionCoverage: null, lineCoverage: null },\n    24→    run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n    25→    actionItems: [],\n    26→    ...overrides,\n    27→  };\n    28→}\n    29→\n    30→const NOW = new Date('2026-03-18T12:00:00Z');\n    31→\n    32→describe('generateReport', () => {\n    33→  it('returns valid report with zero counts for empty state', () => {\n    34→    const result = generateReport(makeState(), NOW);\n    35→    expect(result.success).toBe(true);\n    36→    if (!result.success) return;\n    37→    expect(result.data.total).toBe(0);\n    38→    expect(result.data.done).toBe(0);\n    39→    expect(result.data.failed).toBe(0);\n    40→    expect(result.data.blocked).toBe(0);\n    41→    expect(result.data.inProgress).toBeNull();\n    42→    expect(result.data.storyStatuses).toEqual([]);\n    43→    expect(result.data.epicsTotal).toBe(0);\n    44→    expect(result.data.epicsDone).toBe(0);\n    45→    expect(result.data.sprintPercent).toBe(0);\n    46→    expect(result.data.activeRun).toBeNull();\n    47→    expect(result.data.lastRun).toBeNull();\n    48→    expect(result.data.failedDetails).toEqual([]);\n    49→    expect(result.data.actionItemsLabeled).toEqual([]);\n    50→  });\n    51→\n    52→  it('includes current story, iteration, cost, elapsed for active run', () => {\n    53→    const state = makeState({\n    54→      sprint: { total: 3, done: 1, failed: 0, blocked: 0, inProgress: '2-3-status' },\n    55→      stories: {\n    56→        '2-1-done': s({ status: 'done', attempts: 1 }),\n    57→        '2-2-wip': s({ status: 'in-progress', attempts: 2 }),\n    58→        '2-3-status': s(),\n    59→      },\n    60→      run: { active: true, startedAt: '2026-03-18T09:46:00Z', iteration: 7, cost: 23.40, completed: ['2-1-done'], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n    61→    });\n    62→    const result = generateReport(state, NOW);\n    63→    expect(result.success).toBe(true);\n    64→    if (!result.success) return;\n    65→    expect(result.data.activeRun).not.toBeNull();\n    66→    expect(result.data.activeRun!.iterations).toBe(7);\n    67→    expect(result.data.activeRun!.cost).toBe(23.40);\n    68→    expect(result.data.activeRun!.duration).toBe('2h14m');\n    69→    expect(result.data.inProgress).toBe('2-3-status');\n    70→    expect(result.data.lastRun).toBeNull();\n    71→  });\n    72→\n    73→  it('includes done, failed, blocked, skipped counts for completed run', () => {\n    74→    const state = makeState({\n    75→      sprint: { total: 5, done: 2, failed: 1, blocked: 1, inProgress: null },\n    76→      stories: {\n    77→        '1-1-a': s({ status: 'done', attempts: 1 }),\n    78→        '1-2-b': s({ status: 'done', attempts: 1 }),\n    79→        '2-1-c': s({ status: 'failed', attempts: 3, lastError: 'boom', acResults: [{ id: 'AC4', verdict: 'fail' }] }),\n    80→        '2-2-d': s({ status: 'blocked', attempts: 10, lastError: 'retry-exhausted' }),\n    81→        '3-1-e': s(),\n    82→      },\n    83→      run: { active: false, startedAt: '2026-03-18T09:46:00Z', iteration: 7, cost: 23.40, completed: ['1-1-a', '1-2-b'], failed: ['2-1-c'], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n    84→    });\n    85→    const result = generateReport(state, NOW);\n    86→    expect(result.success).toBe(true);\n    87→    if (!result.success) return;\n    88→    expect(result.data.lastRun).not.toBeNull();\n    89→    expect(result.data.lastRun!.completed).toEqual(['1-1-a', '1-2-b']);\n    90→    expect(result.data.lastRun!.failed).toEqual(['2-1-c']);\n    91→    expect(result.data.lastRun!.blocked).toEqual(['2-2-d']);\n    92→    expect(result.data.done).toBe(2);\n    93→    expect(result.data.failed).toBe(1);\n    94→    expect(result.data.blocked).toBe(1);\n    95→    expect(result.data.activeRun).toBeNull();\n    96→  });\n    97→\n    98→  it('shows story key, AC number, and one-line error for failed stories', () => {\n    99→    const acResults: AcResult[] = [{ id: 'AC1', verdict: 'pass' }, { id: 'AC4', verdict: 'fail' }];\n   100→    const state = makeState({\n   101→      stories: { '2-3-status': s({ status: 'failed', attempts: 3, lastError: 'exit 1', acResults }) },\n   102→    });\n   103→    const result = generateReport(state, NOW);\n   104→    expect(result.success).toBe(true);\n   105→    if (!result.success) return;\n   106→    expect(result.data.failedDetails).toHaveLength(1);\n   107→    const fd = result.data.failedDetails[0];\n   108→    expect(fd.key).toBe('2-3-status');\n   109→    expect(fd.acNumber).toBe(4);\n   110→    expect(fd.errorLine).toBe('exit 1');\n   111→    expect(fd.attempts).toBe(3);\n   112→    expect(fd.maxAttempts).toBe(10);\n   113→  });\n   114→\n   115→  it('labels action items as NEW or CARRIED', () => {\n   116→    const state = makeState({\n   117→      run: { active: false, startedAt: '2026-03-18T09:00:00Z', iteration: 3, cost: 10, completed: ['1-1-a'], failed: ['2-1-b'], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n   118→      actionItems: [\n   119→        { id: 'ai-1', story: '1-1-a', description: 'Fix test', source: 'verification', resolved: false },\n   120→        { id: 'ai-2', story: '2-1-b', description: 'Edge case', source: 'verification', resolved: false },\n   121→        { id: 'ai-3', story: '0-1-old', description: 'Old', source: 'verification', resolved: false },\n   122→        { id: 'ai-4', story: '1-1-a', description: 'Note', source: 'manual', resolved: false },\n   123→      ],\n   124→    });\n   125→    const result = generateReport(state, NOW);\n   126→    expect(result.success).toBe(true);\n   127→    if (!result.success) return;\n   128→    const labels = result.data.actionItemsLabeled;\n   129→    expect(labels).toHaveLength(4);\n   130→    expect(labels[0].label).toBe('NEW');   // verification + in run\n   131→    expect(labels[1].label).toBe('NEW');   // verification + in run\n   132→    expect(labels[2].label).toBe('CARRIED'); // verification but NOT in run\n   133→    expect(labels[3].label).toBe('CARRIED'); // manual source\n   134→  });\n   135→\n   136→  it('groups stories by epic prefix and counts completed epics', () => {\n   137→    const state = makeState({\n   138→      stories: {\n   139→        '1-1-a': s({ status: 'done' }), '1-2-b': s({ status: 'done' }),\n   140→        '2-1-c': s({ status: 'done' }), '2-2-d': s({ status: 'in-progress' }),\n   141→        '3-1-e': s(),\n   142→      },\n   143→    });\n   144→    const result = generateReport(state, NOW);\n   145→    expect(result.success).toBe(true);\n   146→    if (!result.success) return;\n   147→    expect(result.data.epicsTotal).toBe(3);\n   148→    expect(result.data.epicsDone).toBe(1); // only epic 1 fully done\n   149→    expect(result.data.sprintPercent).toBe(60); // 3/5\n   150→  });\n   151→\n   152→  it('returns fail() on malformed state (not throw)', () => {\n   153→    const result = generateReport(null as unknown as SprintState, NOW);\n   154→    expect(result.success).toBe(false);\n   155→    if (!result.success) expect(result.error).toContain('Failed to generate report');\n   156→  });\n   157→\n   158→  it('handles failed story with no acResults gracefully', () => {\n   159→    const state = makeState({\n   160→      stories: { '1-1-a': s({ status: 'failed', attempts: 2, lastError: 'some error' }) },\n   161→    });\n   162→    const result = generateReport(state, NOW);\n   163→    expect(result.success).toBe(true);\n   164→    if (!result.success) return;\n   165→    expect(result.data.failedDetails).toHaveLength(1);\n   166→    expect(result.data.failedDetails[0].acNumber).toBeNull();\n   167→    expect(result.data.failedDetails[0].errorLine).toBe('some error');\n   168→  });\n   169→\n   170→  it('handles failed story with no lastError', () => {\n   171→    const state = makeState({\n   172→      stories: { '1-1-a': s({ status: 'failed', attempts: 1 }) },\n   173→    });\n   174→    const result = generateReport(state, NOW);\n   175→    expect(result.success).toBe(true);\n   176→    if (!result.success) return;\n   177→    expect(result.data.failedDetails[0].errorLine).toBe('unknown error');\n   178→  });\n   179→\n   180→  it('JSON output includes all fields', () => {\n   181→    const state = makeState({\n   182→      sprint: { total: 2, done: 1, failed: 0, blocked: 0, inProgress: null },\n   183→      stories: { '1-1-a': s({ status: 'done', attempts: 1 }), '2-1-b': s() },\n   184→      run: { active: false, startedAt: '2026-03-18T10:00:00Z', iteration: 3, cost: 5.50, completed: ['1-1-a'], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n   185→    });\n   186→    const result = generateReport(state, NOW);\n   187→    expect(result.success).toBe(true);\n   188→    if (!result.success) return;\n   189→    const data = result.data;\n   190→    for (const field of ['total', 'done', 'failed', 'blocked', 'inProgress', 'storyStatuses',\n   191→      'epicsTotal', 'epicsDone', 'sprintPercent', 'activeRun', 'lastRun', 'failedDetails', 'actionItemsLabeled']) {\n   192→      expect(data).toHaveProperty(field);\n   193→    }\n   194→    const json = JSON.parse(JSON.stringify(data));\n   195→    expect(json.total).toBe(2);\n   196→    expect(json.done).toBe(1);\n   197→    expect(json.lastRun.cost).toBe(5.50);\n   198→    expect(json.storyStatuses).toHaveLength(2);\n   199→  });\n   200→\n   201→  it('computes duration correctly for short runs', () => {\n   202→    const state = makeState({\n   203→      run: { active: true, startedAt: '2026-03-18T11:55:00Z', iteration: 1, cost: 0.5, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n   204→    });\n   205→    const result = generateReport(state, NOW);\n   206→    expect(result.success).toBe(true);\n   207→    if (!result.success) return;\n   208→    expect(result.data.activeRun!.duration).toBe('5m');\n   209→  });\n   210→\n   211→  it('clamps negative elapsed duration to 0m', () => {\n   212→    const state = makeState({\n   213→      run: { active: true, startedAt: '2026-03-18T13:00:00Z', iteration: 1, cost: 0.5, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n   214→    });\n   215→    // NOW is 12:00, startedAt is 13:00 — clock skew\n   216→    const result = generateReport(state, NOW);\n   217→    expect(result.success).toBe(true);\n   218→    if (!result.success) return;\n   219→    expect(result.data.activeRun!.duration).toBe('0m');\n   220→  });\n   221→\n   222→  it('returns lastRun as null when no startedAt is