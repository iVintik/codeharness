{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QKKr5BquW3GPUffvK9jSf2","type":"tool_result","content":"1\t/**\n2\t * Builder factories for SprintState and related test data.\n3\t *\n4\t * Produces valid SprintStateV2 objects with sensible defaults.\n5\t * Use `buildSprintState(overrides)` for top-level state and\n6\t * `buildStoryEntry(overrides)` for individual story entries.\n7\t */\n8\t\n9\timport type {\n10\t  SprintState,\n11\t  StoryState,\n12\t  EpicState,\n13\t  SessionState,\n14\t  ObservabilityState,\n15\t  ActionItem,\n16\t} from '../../../types/state.js';\n17\t\n18\t/** Default story state with \"backlog\" status and zero attempts */\n19\tconst DEFAULT_STORY_STATE: StoryState = {\n20\t  status: 'backlog',\n21\t  attempts: 0,\n22\t  lastAttempt: null,\n23\t  lastError: null,\n24\t  proofPath: null,\n25\t  acResults: null,\n26\t};\n27\t\n28\t/** Default session state — inactive */\n29\tconst DEFAULT_SESSION_STATE: SessionState = {\n30\t  active: false,\n31\t  startedAt: null,\n32\t  iteration: 0,\n33\t  elapsedSeconds: 0,\n34\t};\n35\t\n36\t/** Default observability state — no coverage data */\n37\tconst DEFAULT_OBSERVABILITY_STATE: ObservabilityState = {\n38\t  statementCoverage: null,\n39\t  branchCoverage: null,\n40\t  functionCoverage: null,\n41\t  lineCoverage: null,\n42\t};\n43\t\n44\t/** Default run state — inactive */\n45\tconst DEFAULT_RUN_STATE: SprintState['run'] = {\n46\t  active: false,\n47\t  startedAt: null,\n48\t  iteration: 0,\n49\t  cost: 0,\n50\t  completed: [],\n51\t  failed: [],\n52\t  currentStory: null,\n53\t  currentPhase: null,\n54\t  lastAction: null,\n55\t  acProgress: null,\n56\t};\n57\t\n58\t/**\n59\t * Build a valid SprintStateV2 object with sensible defaults.\n60\t * Pass partial overrides to customize specific fields.\n61\t */\n62\texport function buildSprintState(overrides?: Partial<SprintState>): SprintState {\n63\t  return {\n64\t    version: 2,\n65\t    sprint: {\n66\t      total: 0,\n67\t      done: 0,\n68\t      failed: 0,\n69\t      blocked: 0,\n70\t      inProgress: null,\n71\t      ...overrides?.sprint,\n72\t    },\n73\t    stories: overrides?.stories ?? {},\n74\t    retries: overrides?.retries ?? {},\n75\t    flagged: overrides?.flagged ?? [],\n76\t    epics: overrides?.epics ?? {},\n77\t    session: { ...DEFAULT_SESSION_STATE, ...overrides?.session },\n78\t    observability: { ...DEFAULT_OBSERVABILITY_STATE, ...overrides?.observability },\n79\t    run: { ...DEFAULT_RUN_STATE, ...overrides?.run },\n80\t    actionItems: overrides?.actionItems ?? [],\n81\t  };\n82\t}\n83\t\n84\t/**\n85\t * Build a valid StoryState object with sensible defaults.\n86\t * Pass partial overrides to customize specific fields.\n87\t */\n88\texport function buildStoryEntry(overrides?: Partial<StoryState>): StoryState {\n89\t  return {\n90\t    ...DEFAULT_STORY_STATE,\n91\t    ...overrides,\n92\t  };\n93\t}\n94\t\n95\t/**\n96\t * Build a valid EpicState object with sensible defaults.\n97\t */\n98\texport function buildEpicState(overrides?: Partial<EpicState>): EpicState {\n99\t  return {\n100\t    status: 'in-progress',\n101\t    storiesTotal: 0,\n102\t    storiesDone: 0,\n103\t    ...overrides,\n104\t  };\n105\t}\n106\t\n107\t/**\n108\t * Build a valid ActionItem object.\n109\t */\n110\texport function buildActionItem(overrides?: Partial<ActionItem>): ActionItem {\n111\t  return {\n112\t    id: 'ai-1',\n113\t    story: '1-1-test',\n114\t    description: 'Test action item',\n115\t    source: 'manual',\n116\t    resolved: false,\n117\t    ...overrides,\n118\t  };\n119\t}\n120\t\n121\t/**\n122\t * Build a SprintState with a single story pre-populated.\n123\t * Convenience wrapper for the common test pattern.\n124\t */\n125\texport function buildSprintStateWithStory(\n126\t  storyKey: string,\n127\t  storyOverrides?: Partial<StoryState>,\n128\t  stateOverrides?: Partial<SprintState>,\n129\t): SprintState {\n130\t  return buildSprintState({\n131\t    ...stateOverrides,\n132\t    sprint: { total: 1, done: 0, failed: 0, blocked: 0, inProgress: null, ...stateOverrides?.sprint },\n133\t    stories: {\n134\t      [storyKey]: buildStoryEntry(storyOverrides),\n135\t      ...stateOverrides?.stories,\n136\t    },\n137\t  });\n138\t}\n139\t"}]},"parent_tool_use_id":"toolu_013PuCFdGqfY1KC97FqvkHNR","session_id":"d383a9e0-3bc4-4a94-aaff-6965a5cc223b","uuid":"9db3bdf3-850f-4807-a232-0d628d4202df","timestamp":"2026-04-03T23:18:45.355Z"}
