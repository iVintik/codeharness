{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SrdHJgN1PoUiyjaypdCq3Z","type":"tool_result","content":"1\t/**\n2\t * Public API for the docker subsystem.\n3\t */\n4\t\n5\t// Types\n6\texport type {\n7\t  DockerServiceStatus,\n8\t  DockerStartResult,\n9\t  DockerHealthService,\n10\t  DockerHealthResult,\n11\t  RemoteEndpointCheckResult,\n12\t} from './health.js';\n13\t\n14\t// Health checks\n15\texport {\n16\t  isDockerAvailable,\n17\t  isDockerComposeAvailable,\n18\t  getStackHealth,\n19\t  getCollectorHealth,\n20\t  checkRemoteEndpoint,\n21\t} from './health.js';\n22\t\n23\t// Compose operations\n24\texport {\n25\t  isStackRunning,\n26\t  isSharedStackRunning,\n27\t  startStack,\n28\t  startSharedStack,\n29\t  stopStack,\n30\t  stopSharedStack,\n31\t  startCollectorOnly,\n32\t  isCollectorRunning,\n33\t  stopCollectorOnly,\n34\t} from './compose.js';\n35\t\n36\t// Cleanup\n37\texport {\n38\t  cleanupOrphanedContainers,\n39\t  cleanupVerifyEnv,\n40\t} from './cleanup.js';\n41\t"}]},"parent_tool_use_id":"toolu_01Hsf3cdPfK7Go9jhFpuXGeq","session_id":"e9c90575-92e6-47e7-805a-c4ec47a0ac4f","uuid":"da1aa01e-5685-43a3-81bf-1bc883c89fc0","timestamp":"2026-04-02T23:46:59.904Z"}
