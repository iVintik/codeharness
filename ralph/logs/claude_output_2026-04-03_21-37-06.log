{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015JZ3vBEgvRV9DZ9k1iaKDq","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach, afterEach } from 'vitest';\n2\timport { existsSync, mkdirSync, readFileSync, rmSync, writeFileSync } from 'node:fs';\n3\timport { join } from 'node:path';\n4\timport { tmpdir } from 'node:os';\n5\timport {\n6\t  writeTelemetryEntry,\n7\t  readTelemetryForEpic,\n8\t} from '../telemetry-writer.js';\n9\timport type { TelemetryEntry } from '../telemetry-writer.js';\n10\timport type { TaskContext } from '../null-task-registry.js';\n11\timport { getNullTask, clearNullTaskRegistry, registerNullTask } from '../null-task-registry.js';\n12\timport { writeTelemetryEntry as realWriteTelemetryEntry } from '../telemetry-writer.js';\n13\t\n14\t// --- Helpers ---\n15\t\n16\tfunction makeTmpDir(): string {\n17\t  const dir = join(tmpdir(), `telemetry-test-${Date.now()}-${Math.random().toString(36).slice(2)}`);\n18\t  mkdirSync(dir, { recursive: true });\n19\t  return dir;\n20\t}\n21\t\n22\tfunction makeCtx(overrides: Partial<TaskContext> = {}): TaskContext {\n23\t  return {\n24\t    storyKey: '16-3-telemetry-writer',\n25\t    taskName: 'telemetry',\n26\t    cost: 0.42,\n27\t    durationMs: 12345,\n28\t    outputContract: null,\n29\t    projectDir: '/tmp/test',\n30\t    ...overrides,\n31\t  };\n32\t}\n33\t\n34\tfunction readTelemetryFile(projectDir: string): string {\n35\t  return readFileSync(join(projectDir, '.codeharness', 'telemetry.jsonl'), 'utf-8');\n36\t}\n37\t\n38\tdescribe('telemetry-writer', () => {\n39\t  let tmpDir: string;\n40\t\n41\t  beforeEach(() => {\n42\t    tmpDir = makeTmpDir();\n43\t  });\n44\t\n45\t  afterEach(() => {\n46\t    rmSync(tmpDir, { recursive: true, force: true });\n47\t  });\n48\t\n49\t  describe('writeTelemetryEntry', () => {\n50\t    it('creates .codeharness/ directory if missing', async () => {\n51\t      const ctx = makeCtx({ projectDir: tmpDir });\n52\t      await writeTelemetryEntry(ctx);\n53\t      expect(existsSync(join(tmpDir, '.codeharness'))).toBe(true);\n54\t    });\n55\t\n56\t    it('appends one valid NDJSON line per call', async () => {\n57\t      const ctx = makeCtx({ projectDir: tmpDir });\n58\t      await writeTelemetryEntry(ctx);\n59\t      const content = readTelemetryFile(tmpDir);\n60\t      const lines = content.split('\\n').filter((l) => l.trim() !== '');\n61\t      expect(lines).toHaveLength(1);\n62\t      // Verify it's valid JSON\n63\t      expect(() => JSON.parse(lines[0])).not.toThrow();\n64\t    });\n65\t\n66\t    it('entry contains all required fields with correct types', async () => {\n67\t      const ctx = makeCtx({\n68\t        projectDir: tmpDir,\n69\t        outputContract: {\n70\t          version: 1,\n71\t          taskName: 'implement',\n72\t          storyId: '16-3',\n73\t          driver: 'claude-code',\n74\t          model: 'claude-sonnet-4-20250514',\n75\t          timestamp: '2026-04-03T00:00:00.000Z',\n76\t          cost_usd: 0.10,\n77\t          duration_ms: 5000,\n78\t          changedFiles: ['src/lib/telemetry-writer.ts'],\n79\t          testResults: { passed: 10, failed: 0, coverage: 95.5 },\n80\t          output: 'done',\n81\t          acceptanceCriteria: [{ id: 'AC1', description: 'writes telemetry', status: 'passed' }],\n82\t        },\n83\t      });\n84\t\n85\t      await writeTelemetryEntry(ctx);\n86\t      const entry: TelemetryEntry = JSON.parse(readTelemetryFile(tmpDir).trim());\n87\t\n88\t      expect(entry.version).toBe(1);\n89\t      expect(typeof entry.timestamp).toBe('string');\n90\t      // Verify ISO 8601 format\n91\t      expect(new Date(entry.timestamp).toISOString()).toBe(entry.timestamp);\n92\t      expect(entry.storyKey).toBe('16-3-telemetry-writer');\n93\t      expect(entry.epicId).toBe('16');\n94\t      expect(typeof entry.duration_ms).toBe('number');\n95\t      expect(entry.duration_ms).toBe(12345);\n96\t      expect(entry.cost_usd).toBe(0.42);\n97\t      expect(entry.attempts).toBeNull();\n98\t      expect(Array.isArray(entry.acResults)).toBe(true);\n99\t      expect(entry.acResults).toHaveLength(1);\n100\t      expect(entry.acResults![0]).toEqual({ id: 'AC1', description: 'writes telemetry', status: 'passed' });\n101\t      expect(entry.filesChanged).toEqual(['src/lib/telemetry-writer.ts']);\n102\t      expect(entry.testResults).toEqual({ passed: 10, failed: 0, coverage: 95.5 });\n103\t      expect(Array.isArray(entry.errors)).toBe(true);\n104\t      expect(entry.errors).toHaveLength(0);\n105\t    });\n106\t\n107\t    it('version field is 1 in every entry', async () => {\n108\t      const ctx = makeCtx({ projectDir: tmpDir });\n109\t      await writeTelemetryEntry(ctx);\n110\t      await writeTelemetryEntry(ctx);\n111\t      const lines = readTelemetryFile(tmpDir).split('\\n').filter((l) => l.trim());\n112\t      for (const line of lines) {\n113\t        const entry = JSON.parse(line);\n114\t        expect(entry.version).toBe(1);\n115\t      }\n116\t    });\n117\t\n118\t    it('version is the first field in serialized JSON', async () => {\n119\t      const ctx = makeCtx({ projectDir: tmpDir });\n120\t      await writeTelemetryEntry(ctx);\n121\t      const line = readTelemetryFile(tmpDir).trim();\n122\t      expect(line.startsWith('{\"version\":1,')).toBe(true);\n123\t    });\n124\t\n125\t    it('unavailable fields are null when no output contract', async () => {\n126\t      const ctx = makeCtx({ projectDir: tmpDir, outputContract: null });\n127\t      await writeTelemetryEntry(ctx);\n128\t      const entry: TelemetryEntry = JSON.parse(readTelemetryFile(tmpDir).trim());\n129\t\n130\t      expect(entry.attempts).toBeNull();\n131\t      expect(entry.acResults).toBeNull();\n132\t      expect(entry.testResults).toBeNull();\n133\t      expect(entry.filesChanged).toEqual([]);\n134\t      expect(entry.errors).toEqual([]);\n135\t    });\n136\t\n137\t    it('returns success with correct output message', async () => {\n138\t      const ctx = makeCtx({ projectDir: tmpDir, storyKey: '16-3-telemetry-writer' });\n139\t      const result = await writeTelemetryEntry(ctx);\n140\t      expect(result.success).toBe(true);\n141\t      expect(result.output).toBe('telemetry: entry written for 16-3-telemetry-writer');\n142\t    });\n143\t\n144\t    it('extracts epicId from storyKey correctly', async () => {\n145\t      const ctx = makeCtx({ projectDir: tmpDir, storyKey: '20-1-some-feature' });\n146\t      await writeTelemetryEntry(ctx);\n147\t      const entry: TelemetryEntry = JSON.parse(readTelemetryFile(tmpDir).trim());\n148\t      expect(entry.epicId).toBe('20');\n149\t    });\n150\t\n151\t    it('handles __run__ sentinel storyKey', async () => {\n152\t      const ctx = makeCtx({ projectDir: tmpDir, storyKey: '__run__' });\n153\t      await writeTelemetryEntry(ctx);\n154\t      const entry: TelemetryEntry = JSON.parse(readTelemetryFile(tmpDir).trim());\n155\t      expect(entry.epicId).toBe('unknown');\n156\t    });\n157\t\n158\t    it('multiple sequential writes produce multiple lines', async () => {\n159\t      const ctx1 = makeCtx({ projectDir: tmpDir, storyKey: '16-1-first' });\n160\t      const ctx2 = makeCtx({ projectDir: tmpDir, storyKey: '16-2-second' });\n161\t      const ctx3 = makeCtx({ projectDir: tmpDir, storyKey: '16-3-third' });\n162\t\n163\t      await writeTelemetryEntry(ctx1);\n164\t      await writeTelemetryEntry(ctx2);\n165\t      await writeTelemetryEntry(ctx3);\n166\t\n167\t      const lines = readTelemetryFile(tmpDir).split('\\n').filter((l) => l.trim());\n168\t      expect(lines).toHaveLength(3);\n169\t\n170\t      const entries = lines.map((l) => JSON.parse(l) as TelemetryEntry);\n171\t      expect(entries[0].storyKey).toBe('16-1-first');\n172\t      expect(entries[1].storyKey).toBe('16-2-second');\n173\t      expect(entries[2].storyKey).toBe('16-3-third');\n174\t    });\n175\t\n176\t    it('completes in <10ms (performance, AC #8)', async () => {\n177\t      // Pre-create the directory so we only measure append time\n178\t      mkdirSync(join(tmpDir, '.codeharness'), { recursive: true });\n179\t      const ctx = makeCtx({ projectDir: tmpDir });\n180\t\n181\t      const start = performance.now();\n182\t      await writeTelemetryEntry(ctx);\n183\t      const elapsed = performance.now() - start;\n184\t\n185\t      expect(elapsed).toBeLessThan(10);\n186\t    });\n187\t  });\n188\t\n189\t  describe('readTelemetryForEpic', () => {\n190\t    it('filters entries by epicId', async () => {\n191\t      // Write entries for different epics\n192\t      await writeTelemetryEntry(makeCtx({ projectDir: tmpDir, storyKey: '16-1-first' }));\n193\t      await writeTelemetryEntry(makeCtx({ projectDir: tmpDir, storyKey: '17-1-other' }));\n194\t      await writeTelemetryEntry(makeCtx({ projectDir: tmpDir, storyKey: '16-2-second' }));\n195\t      await writeTelemetryEntry(makeCtx({ projectDir: tmpDir, storyKey: '18-1-another' }));\n196\t\n197\t      const entries = readTelemetryForEpic('16', tmpDir);\n198\t      expect(entries).toHaveLength(2);\n199\t      expect(entries[0].storyKey).toBe('16-1-first');\n200\t      expect(entries[1].storyKey).toBe('16-2-second');\n201\t    });\n202\t\n203\t    it('returns [] when file does not exist', () => {\n204\t      const entries = readTelemetryForEpic('16', tmpDir);\n205\t      expect(entries).toEqual([]);\n206\t    });\n207\t\n208\t    it('returns [] when no entries match the epicId', async () => {\n209\t      await writeTelemetryEntry(makeCtx({ projectDir: tmpDir, storyKey: '17-1-other' }));\n210\t      const entries = readTelemetryForEpic('99', tmpDir);\n211\t      expect(entries).toEqual([]);\n212\t    });\n213\t\n214\t    it('skips corrupted JSON lines', async () => {\n215\t      // Write a valid entry, a corrupted line, and another valid entry\n216\t      await writeTelemetryEntry(makeCtx({ projectDir: tmpDir, storyKey: '16-1-first' }));\n217\t      const filePath = join(tmpDir, '.codeharness', 'telemetry.jsonl');\n218\t      const { appendFileSync } = await import('node:fs');\n219\t      appendFileSync(filePath, 'this is not valid json\\n');\n220\t      appendFileSync(filePath, '{broken json\\n');\n221\t      await writeTelemetryEntry(makeCtx({ projectDir: tmpDir, storyKey: '16-2-second' }));\n222\t\n223\t      const entries = readTelemetryForEpic('16', tmpDir);\n224\t      expect(entries).toHaveLength(2);\n225\t      expect(entries[0].storyKey).toBe('16-1-first');\n226\t      expect(entries[1].storyKey).toBe('16-2-second');\n227\t    });\n228\t\n229\t    it('preserves insertion order', async () => {\n230\t      await writeTelemetryEntry(makeCtx({ projectDir: tmpDir, storyKey: '16-3-third' }));\n231\t      await writeTelemetryEntry(makeCtx({ projectDir: tmpDir, storyKey: '16-1-first' }));\n232\t      await writeTelemetryEntry(makeCtx({ projectDir: tmpDir, storyKey: '16-2-second' }));\n233\t\n234\t      const entries = readTelemetryForEpic('16', tmpDir);\n235\t      expect(entries).toHaveLength(3);\n236\t      expect(entries[0].storyKey).toBe('16-3-third');\n237\t      expect(entries[1].storyKey).toBe('16-1-first');\n238\t      expect(entries[2].storyKey).toBe('16-2-second');\n239\t    });\n240\t  });\n241\t\n242\t  describe('null-task-registry integration', () => {\n243\t    it('registered telemetry handler calls writeTelemetryEntry (not no-op)', async () => {\n244\t      const handler = getNullTask('telemetry');\n245\t      expect(handler).toBeDefined();\n246\t\n247\t      const ctx = makeCtx({ projectDir: tmpDir });\n248\t      const result = await handler!(ctx);\n249\t\n250\t      expect(result.success).toBe(true);\n251\t      expect(result.output).toBe('telemetry: entry written for 16-3-telemetry-writer');\n252\t\n253\t      // Verify the file was actually written (not a no-op)\n254\t      expect(existsSync(join(tmpDir, '.codeharness', 'telemetry.jsonl'))).toBe(true);\n255\t      const entry: TelemetryEntry = JSON.parse(readTelemetryFile(tmpDir).trim());\n256\t      expect(entry.storyKey).toBe('16-3-telemetry-writer');\n257\t    });\n258\t\n259\t    it('registered handler is the real writeTelemetryEntry function', () => {\n260\t      const handler = getNullTask('telemetry');\n261\t      expect(handler).toBe(realWriteTelemetryEntry);\n262\t    });\n263\t  });\n264\t});\n265\t"}]},"parent_tool_use_id":"toolu_01EThU22wRDbXmvukgem8PY8","session_id":"3330d992-072a-4898-af8b-5f3f7e12cbac","uuid":"dc9de1a1-376f-4acb-874c-af1e953721d4","timestamp":"2026-04-03T17:45:18.046Z"}
