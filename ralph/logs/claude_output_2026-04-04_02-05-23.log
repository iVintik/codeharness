{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013yzmrMKb73xwpNzT8BJAHW","type":"tool_result","content":"1\t/**\n2\t * Cross-Worktree Validator.\n3\t *\n4\t * Encapsulates the test-run-after-merge logic extracted from\n5\t * worktree-manager.ts and merge-agent.ts. Both modules delegate\n6\t * to validateMerge() instead of maintaining their own runTestSuite\n7\t * and parseTestOutput implementations.\n8\t *\n9\t * @see Story 18-3: Cross-Worktree Test Validation\n10\t */\n11\t\n12\timport { exec } from 'node:child_process';\n13\timport { appendFileSync, mkdirSync } from 'node:fs';\n14\timport { join } from 'node:path';\n15\timport { promisify } from 'node:util';\n16\t\n17\tconst execAsync = promisify(exec);\n18\t\n19\t// --- Interfaces ---\n20\t\n21\t/**\n22\t * Options for running post-merge test validation.\n23\t */\n24\texport interface ValidateMergeOptions {\n25\t  /** Command to run for test validation. */\n26\t  readonly testCommand: string;\n27\t  /** Working directory to run the test command in. */\n28\t  readonly cwd: string;\n29\t  /** Epic identifier for telemetry. */\n30\t  readonly epicId: string;\n31\t  /** Optional story key override for telemetry (defaults to `merge-{epicId}`). */\n32\t  readonly storyKey?: string;\n33\t  /** Whether to write a telemetry entry after the test suite completes. */\n34\t  readonly writeTelemetry: boolean;\n35\t}\n36\t\n37\t/**\n38\t * Result of a post-merge test validation.\n39\t */\n40\texport interface ValidationResult {\n41\t  /** Whether all tests passed (passed > 0 and failed === 0). */\n42\t  readonly valid: boolean;\n43\t  /** Parsed test results: pass/fail counts and optional coverage. */\n44\t  readonly testResults: { passed: number; failed: number; coverage?: number };\n45\t  /** Raw test command stdout for retry context. */\n46\t  readonly output: string;\n47\t  /** Wall-clock duration of the test run in milliseconds. */\n48\t  readonly durationMs: number;\n49\t}\n50\t\n51\t// --- Constants ---\n52\t\n53\tconst TELEMETRY_DIR = '.codeharness';\n54\tconst TELEMETRY_FILE = 'telemetry.jsonl';\n55\tconst TEST_TIMEOUT_MS = 300_000; // 5 minutes\n56\t\n57\t// --- Test Output Parsing ---\n58\t\n59\t/**\n60\t * Parse test output to extract pass/fail counts and optional coverage.\n61\t * Supports vitest/jest output patterns.\n62\t */\n63\texport function parseTestOutput(stdout: string): { passed: number; failed: number; coverage?: number } {\n64\t  let passed = 0;\n65\t  let failed = 0;\n66\t  let coverage: number | undefined;\n67\t\n68\t  const passMatch = stdout.match(/(\\d+)\\s+passed/);\n69\t  const failMatch = stdout.match(/(\\d+)\\s+failed/);\n70\t  if (passMatch) passed = parseInt(passMatch[1], 10);\n71\t  if (failMatch) failed = parseInt(failMatch[1], 10);\n72\t\n73\t  const covMatch = stdout.match(/All files[^|]*\\|\\s*([\\d.]+)/);\n74\t  if (covMatch) coverage = parseFloat(covMatch[1]);\n75\t\n76\t  return { passed, failed, ...(coverage !== undefined && { coverage }) };\n77\t}\n78\t\n79\t// --- Telemetry ---\n80\t\n81\t/**\n82\t * Write a merge validation telemetry entry to the NDJSON telemetry file.\n83\t * Failures are silently caught — telemetry must never break validation.\n84\t *\n85\t * Exported so callers (e.g., merge-agent) can defer telemetry writes\n86\t * until they know whether the validation is final (success or last attempt).\n87\t */\n88\texport function writeMergeTelemetry(opts: ValidateMergeOptions, result: ValidationResult): void {\n89\t  try {\n90\t    const entry = {\n91\t      version: 1,\n92\t      timestamp: new Date().toISOString(),\n93\t      storyKey: opts.storyKey ?? `merge-${opts.epicId}`,\n94\t      epicId: opts.epicId,\n95\t      duration_ms: result.durationMs,\n96\t      cost_usd: null,\n97\t      attempts: null,\n98\t      acResults: null,\n99\t      filesChanged: [],\n100\t      testResults: result.testResults,\n101\t      errors: result.valid ? [] : ['Test suite failed after merge'],\n102\t    };\n103\t\n104\t    const dir = join(opts.cwd, TELEMETRY_DIR);\n105\t    mkdirSync(dir, { recursive: true });\n106\t    appendFileSync(join(dir, TELEMETRY_FILE), JSON.stringify(entry) + '\\n');\n107\t  } catch { // IGNORE: telemetry write failure must not break validation\n108\t  }\n109\t}\n110\t\n111\t// --- Main Entry Point ---\n112\t\n113\t/**\n114\t * Run test validation after a merge and optionally write telemetry.\n115\t *\n116\t * Executes the configured test command, parses the output for\n117\t * pass/fail/coverage, and returns a ValidationResult. When\n118\t * writeTelemetry is true, appends an NDJSON entry to the\n119\t * telemetry file.\n120\t *\n121\t * @param opts  Validation options including test command and cwd.\n122\t * @returns Validation result with test results and raw output.\n123\t */\n124\texport async function validateMerge(opts: ValidateMergeOptions): Promise<ValidationResult> {\n125\t  const start = Date.now();\n126\t\n127\t  try {\n128\t    const { stdout } = await execAsync(opts.testCommand, {\n129\t      cwd: opts.cwd,\n130\t      timeout: TEST_TIMEOUT_MS,\n131\t    });\n132\t\n133\t    const testResults = parseTestOutput(stdout);\n134\t    const result: ValidationResult = {\n135\t      valid: testResults.failed === 0 && testResults.passed > 0,\n136\t      testResults,\n137\t      output: stdout,\n138\t      durationMs: Date.now() - start,\n139\t    };\n140\t\n141\t    if (opts.writeTelemetry) {\n142\t      writeMergeTelemetry(opts, result);\n143\t    }\n144\t\n145\t    return result;\n146\t  } catch (err: unknown) {\n147\t    const stdout = (err as { stdout?: string })?.stdout ?? '';\n148\t    const testResults = parseTestOutput(stdout);\n149\t\n150\t    // If we couldn't parse anything, report 1 failure\n151\t    if (testResults.passed === 0 && testResults.failed === 0) {\n152\t      const result: ValidationResult = {\n153\t        valid: false,\n154\t        testResults: { passed: 0, failed: 1 },\n155\t        output: stdout || 'Test command failed with no output',\n156\t        durationMs: Date.now() - start,\n157\t      };\n158\t\n159\t      if (opts.writeTelemetry) {\n160\t        writeMergeTelemetry(opts, result);\n161\t      }\n162\t\n163\t      return result;\n164\t    }\n165\t\n166\t    const result: ValidationResult = {\n167\t      valid: false,\n168\t      testResults,\n169\t      output: stdout,\n170\t      durationMs: Date.now() - start,\n171\t    };\n172\t\n173\t    if (opts.writeTelemetry) {\n174\t      writeMergeTelemetry(opts, result);\n175\t    }\n176\t\n177\t    return result;\n178\t  }\n179\t}\n180\t"}]},"parent_tool_use_id":"toolu_01KN13KxQzTPDh38EUNUPmae","session_id":"22206bba-5847-41b1-b510-883e1dd8c0da","uuid":"a68d0ea8-f455-4865-9099-56c13c49e54e","timestamp":"2026-04-03T22:22:21.673Z"}
