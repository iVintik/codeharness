{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WuiB9nSbJxCAghqmiSNQ5D","type":"tool_result","content":"     1→import { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n     2→import { join } from 'node:path';\n     3→import { parse, stringify } from 'yaml';\n     4→import { warn } from './output.js';\n     5→import { detectStack, detectStacks, type StackName } from './stacks/index.js';\n     6→\n     7→export interface HarnessState {\n     8→  harness_version: string;\n     9→  initialized: boolean;\n    10→  stack: string | null;\n    11→  stacks: StackName[];\n    12→  app_type?: 'server' | 'cli' | 'web' | 'agent' | 'generic';\n    13→  enforcement: {\n    14→    frontend: boolean;\n    15→    database: boolean;\n    16→    api: boolean;\n    17→  };\n    18→  coverage: {\n    19→    target: number;\n    20→    baseline: number | null;\n    21→    current: number | null;\n    22→    tool: 'c8' | 'coverage.py' | 'cargo-tarpaulin' | 'unknown';\n    23→    /** Per-stack coverage tools map (stack name -> tool) for multi-stack projects */\n    24→    tools?: Record<string, string>;\n    25→  };\n    26→  session_flags: {\n    27→    logs_queried: boolean;\n    28→    tests_passed: boolean;\n    29→    coverage_met: boolean;\n    30→    verification_run: boolean;\n    31→  };\n    32→  verification_log: string[];\n    33→  otlp?: {\n    34→    enabled: boolean;\n    35→    endpoint: string;\n    36→    service_name: string;\n    37→    mode: 'local-shared' | 'remote-direct' | 'remote-routed';\n    38→    backend?: 'victoria' | 'elk' | 'none';\n    39→    node_require?: string;\n    40→    python_wrapper?: string;\n    41→    cli_env_vars?: Record<string, string>;\n    42→    web_snippet_path?: string;\n    43→    resource_attributes?: string;\n    44→    agent_sdk?: string;\n    45→    rust_env_hint?: string;\n    46→  };\n    47→  retro_issue_targets?: Array<{ repo: string; labels: string[] }>;\n    48→  docker?: {\n    49→    compose_file: string;\n    50→    stack_running: boolean;\n    51→    remote_endpoints?: {\n    52→      logs_url?: string;\n    53→      metrics_url?: string;\n    54→      traces_url?: string;\n    55→    };\n    56→    ports: {\n    57→      logs: number;\n    58→      metrics: number;\n    59→      traces: number;\n    60→      otel_grpc: number;\n    61→      otel_http: number;\n    62→    };\n    63→  };\n    64→}\n    65→\n    66→function migrateState(state: HarnessState): HarnessState {\n    67→  const raw = state as unknown as Record<string, unknown>;\n    68→\n    69→  // Backfill otlp.backend for states created before backend choice was added\n    70→  if (state.otlp && !state.otlp.backend) {\n    71→    state.otlp.backend = 'victoria';\n    72→  }\n    73→\n    74→  // New format: stacks array already present\n    75→  if (Array.isArray(raw.stacks) && raw.stacks.length > 0) {\n    76→    state.stacks = raw.stacks as StackName[];\n    77→    state.stack = state.stacks[0] ?? null;\n    78→    return state;\n    79→  }\n    80→\n    81→  // Old format: has stack string but no stacks array\n    82→  if (typeof raw.stack === 'string' && raw.stack) {\n    83→    state.stacks = [raw.stack as StackName];\n    84→    return state;\n    85→  }\n    86→\n    87→  // Neither present\n    88→  state.stacks = [];\n    89→  state.stack = null;\n    90→  return state;\n    91→}\n    92→\n    93→const STATE_DIR = '.claude';\n    94→const STATE_FILE = 'codeharness.local.md';\n    95→const DEFAULT_BODY = '\\n# Codeharness State\\n\\nThis file is managed by the codeharness CLI. Do not edit manually.\\n';\n    96→\n    97→/** Default coverage tool names keyed by stack. */\n    98→const COVERAGE_TOOL_DEFAULTS: Record<string, HarnessState['coverage']['tool']> = {\n    99→  python: 'coverage.py',\n   100→  rust: 'cargo-tarpaulin',\n   101→};\n   102→\n   103→export function getDefaultCoverageTool(stack?: string | null): HarnessState['coverage']['tool'] {\n   104→  if (stack && COVERAGE_TOOL_DEFAULTS[stack]) return COVERAGE_TOOL_DEFAULTS[stack];\n   105→  return 'c8';\n   106→}\n   107→\n   108→export function getDefaultState(stack?: string | null): HarnessState {\n   109→  return {\n   110→    harness_version: '0.1.0',\n   111→    initialized: false,\n   112→    stack: stack ?? null,\n   113→    stacks: stack ? [stack as StackName] : [],\n   114→    enforcement: {\n   115→      frontend: true,\n   116→      database: true,\n   117→      api: true,\n   118→    },\n   119→    coverage: {\n   120→      target: 90,\n   121→      baseline: null,\n   122→      current: null,\n   123→      tool: getDefaultCoverageTool(stack),\n   124→    },\n   125→    session_flags: {\n   126→      logs_queried: false,\n   127→      tests_passed: false,\n   128→      coverage_met: false,\n   129→      verification_run: false,\n   130→    },\n   131→    verification_log: [],\n   132→  };\n   133→}\n   134→\n   135→export function getStatePath(dir: string): string {\n   136→  return join(dir, STATE_DIR, STATE_FILE);\n   137→}\n   138→\n   139→export function writeState(state: HarnessState, dir?: string, body?: string): void {\n   140→  const baseDir = dir ?? process.cwd();\n   141→  const claudeDir = join(baseDir, STATE_DIR);\n   142→  mkdirSync(claudeDir, { recursive: true });\n   143→\n   144→  // Sync stack from stacks[0] for backward compat (shallow copy to avoid mutating caller's object)\n   145→  const toWrite = { ...state };\n   146→  if (toWrite.stacks && toWrite.stacks.length > 0) {\n   147→    toWrite.stack = toWrite.stacks[0];\n   148→  }\n   149→\n   150→  const yamlContent = stringify(toWrite, { nullStr: 'null' });\n   151→  const markdownBody = body ?? DEFAULT_BODY;\n   152→  const fileContent = `---\\n${yamlContent}---\\n${markdownBody}`;\n   153→\n   154→  writeFileSync(join(claudeDir, STATE_FILE), fileContent, 'utf-8');\n   155→}\n   156→\n   157→export function readState(dir?: string): HarnessState {\n   158→  const baseDir = dir ?? process.cwd();\n   159→  const filePath = getStatePath(baseDir);\n   160→\n   161→  if (!existsSync(filePath)) {\n   162→    throw new StateFileNotFoundError();\n   163→  }\n   164→\n   165→  const raw = readFileSync(filePath, 'utf-8');\n   166→  const parts = raw.split('---');\n   167→\n   168→  // parts[0] is empty (before first ---), parts[1] is YAML, rest is body\n   169→  if (parts.length < 3) {\n   170→    return recoverCorruptedState(baseDir);\n   171→  }\n   172→\n   173→  try {\n   174→    const state = parse(parts[1]) as HarnessState;\n   175→    if (!isValidState(state)) {\n   176→      return recoverCorruptedState(baseDir);\n   177→    }\n   178→    return migrateState(state);\n   179→  } catch {\n   180→    // IGNORE: corrupted state file, recover gracefully\n   181→    return recoverCorruptedState(baseDir);\n   182→  }\n   183→}\n   184→\n   185→export function readStateWithBody(dir?: string): { state: HarnessState; body: string } {\n   186→  const baseDir = dir ?? process.cwd();\n   187→  const filePath = getStatePath(baseDir);\n   188→\n   189→  if (!existsSync(filePath)) {\n   190→    throw new StateFileNotFoundError();\n   191→  }\n   192→\n   193→  const raw = readFileSync(filePath, 'utf-8');\n   194→  const parts = raw.split('---');\n   195→\n   196→  if (parts.length < 3) {\n   197→    const state = recoverCorruptedState(baseDir);\n   198→    return { state, body: DEFAULT_BODY };\n   199→  }\n   200→\n   201→  try {\n   202→    const state = parse(parts[1]) as HarnessState;\n   203→    if (!isValidState(state)) {\n   204→      const recovered = recoverCorruptedState(baseDir);\n   205→      return { state: recovered, body: DEFAULT_BODY };\n   206→    }\n   207→    // Everything after the second --- is the body\n   208→    const body = parts.slice(2).join('---');\n   209→    return { state: migrateState(state), body: body || DEFAULT_BODY };\n   210→  } catch {\n   211→    // IGNORE: corrupted state YAML, recover with defaults\n   212→    const state = recoverCorruptedState(baseDir);\n   213→    return { state, body: DEFAULT_BODY };\n   214→  }\n   215→}\n   216→\n   217→function isValidState(state: unknown): state is HarnessState {\n   218→  if (!state || typeof state !== 'object') return false;\n   219→  const s = state as Record<string, unknown>;\n   220→  if (typeof s.harness_version !== 'string') return false;\n   221→  if (typeof s.initialized !== 'boolean') return false;\n   222→  if (s.stack !== null && typeof s.stack !== 'string') return false;\n   223→  if (!s.enforcement || typeof s.enforcement !== 'object') return false;\n   224→  if (!s.coverage || typeof s.coverage !== 'object') return false;\n   225→  if (!s.session_flags || typeof s.session_flags !== 'object') return false;\n   226→  if (!Array.isArray(s.verification_log)) return false;\n   227→  // Accept old format (no stacks) and new format (stacks is array of strings)\n   228→  if (s.stacks !== undefined && !Array.isArray(s.stacks)) return false;\n   229→  if (Array.isArray(s.stacks) && s.stacks.some((v: unknown) => typeof v !== 'string')) return false;\n   230→  return true;\n   231→}\n   232→\n   233→function recoverCorruptedState(dir: string): HarnessState {\n   234→  warn('State file corrupted — recreating from detected config');\n   235→  const stack = detectStack(dir);\n   236→  const allStacks = detectStacks(dir);\n   237→  const state = getDefaultState(stack);\n   238→  // Dedupe: detectStacks may return same stack from multiple dirs\n   239→  const uniqueStackNames = [...new Set(allStacks.map(s => s.stack))];\n   240→  state.stacks = uniqueStackNames;\n   241→  // Sync stack from stacks[0] if stacks were detected but root stack was null\n   242→  if (state.stack === null && uniqueStackNames.length > 0) {\n   243→    state.stack = uniqueStackNames[0];\n   244→  }\n   245→  writeState(state, dir);\n   246→  return state;\n   247→}\n   248→\n   249→export class StateFileNotFoundError extends Error {\n   250→  constructor() {\n   251→    super('No state file found. Run \\'codeharness init\\' first.');\n   252→    this.name = 'StateFileNotFoundError';\n   253→  }\n   254→}\n   255→\n   256→const DANGEROUS_KEYS = new Set(['__proto__', 'constructor', 'prototype']);\n   257→\n   258→function validateKeyPath(keyPath: string): void {\n   259→  const keys = keyPath.split('.');\n   260→  for (const key of keys) {\n   261→    if (DANGEROUS_KEYS.has(key)) {\n   262→      throw new Error(`Invalid key path: '${key}' is not allowed`);\n   263→    }\n   264→  }\n   265→}\n   266→\n   267→export function getNestedValue(obj: Record<string, unknown>, keyPath: string): unknown {\n   268→  validateKeyPath(keyPath);\n   269→  const keys = keyPath.split('.');\n   270→  let current: unknown = obj;\n   271→  for (const key of keys) {\n   272→    if (current === null || current === undefined || typeof current !== 'object') {\n   273→      return undefined;\n   274→    }\n   275→    current = (current as Record<string, unknown>)[key];\n   276→  }\n   277→  return current;\n   278→}\n   279→\n   280→export function setNestedValue(obj: Record<string, unknown>, keyPath: string, value: unknown): void {\n   281→  validateKeyPath(keyPath);\n   282→  const keys = keyPath.split('.');\n   283→  let current: Record<string, unknown> = obj;\n   284→  for (let i = 0; i < keys.length - 1; i++) {\n   285→    const key = keys[i];\n   286→    if (current[key] === undefined || current[key] === null || typeof current[key] !== 'object') {\n   287→      current[key] = {};\n   288→    }\n   289→    current = current[key] as Record<string, unknown>;\n   290→  }\n   291→  current[keys[keys.length - 1]] = value;\n   292→}\n   293→\n   294→export function parseValue(raw: string): unknown {\n   295→  if (raw === 'true') return true;\n   296→  if (raw === 'false') return false;\n   297→  if (raw === 'null') return null;\n   298→  const num = Number(raw);\n   299→  if (!Number.isNaN(num) && raw.trim() !== '') return num;\n   300→  return raw;\n   301→}\n   302→"}]},"parent_tool_use_id":"toolu_01MwzbgNwEhenGxNXV9UQBeX","session_id":"507a8d0b-20bb-4c55-954f-5f817ca0f972","uuid":"ee568908-d0d1-498e-86ec-1749868759f3","timestamp":"2026-03-27T07:03:57.353Z"}
