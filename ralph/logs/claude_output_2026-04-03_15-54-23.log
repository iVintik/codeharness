{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Gjm6vvSrdHJuSyVdrh8mwU","type":"tool_result","content":"900\t      durationMs: 0,\n901\t    };\n902\t  }\n903\t\n904\t  state = {\n905\t    ...state,\n906\t    phase: 'executing',\n907\t    started: state.started || new Date().toISOString(),\n908\t    workflow_name: config.workflow.flow.filter((s) => typeof s === 'string').join(' -> '),\n909\t  };\n910\t  writeWorkflowState(state, projectDir);\n911\t\n912\t  // 1b. Pre-flight driver health check\n913\t  try {\n914\t    await checkDriverHealth(config.workflow);\n915\t  } catch (err: unknown) { // IGNORE: health check failure — record and abort\n916\t    const message = err instanceof Error ? err.message : String(err);\n917\t    state = { ...state, phase: 'failed' };\n918\t    const engineError: EngineError = {\n919\t      taskName: '__health_check__',\n920\t      storyKey: '__health_check__',\n921\t      code: 'HEALTH_CHECK',\n922\t      message,\n923\t    };\n924\t    errors.push(engineError);\n925\t    writeWorkflowState(state, projectDir);\n926\t    return {\n927\t      success: false,\n928\t      tasksCompleted: 0,\n929\t      storiesProcessed: 0,\n930\t      errors,\n931\t      durationMs: Date.now() - startMs,\n932\t    };\n933\t  }\n934\t\n935\t  // 2. Load work items\n936\t  const workItems = loadWorkItems(config.sprintStatusPath, config.issuesPath);\n937\t\n938\t  // 3. Iterate through flow steps\n939\t  let halted = false;\n940\t  let lastOutputContract: OutputContract | null = null;\n941\t  for (const step of config.workflow.flow) {\n942\t    if (halted) break;\n943\t\n944\t    // Execute loop blocks\n945\t    if (isLoopBlock(step)) {\n946\t      const loopResult = await executeLoopBlock(step, state, config, workItems, lastOutputContract);\n947\t      state = loopResult.state;\n948\t      errors.push(...loopResult.errors);\n949\t      tasksCompleted += loopResult.tasksCompleted;\n950\t      lastOutputContract = loopResult.lastContract;\n951\t\n952\t      // Track processed stories from loop\n953\t      for (const item of workItems) {\n954\t        processedStories.add(item.key);\n955\t      }\n956\t\n957\t      if (loopResult.halted) {\n958\t        halted = true;\n959\t      }\n960\t\n961\t      // If loop ended with max-iterations or circuit-breaker, treat as failure\n962\t      if (state.phase === 'max-iterations' || state.phase === 'circuit-breaker') {\n963\t        halted = true;\n964\t      }\n965\t      continue;\n966\t    }\n967\t\n968\t    // step is a string task name\n969\t    const taskName = step;\n970\t    const task = config.workflow.tasks[taskName];\n971\t\n972\t    if (!task) {\n973\t      warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n974\t      continue;\n975\t    }\n976\t\n977\t    // Look up the agent definition\n978\t    const definition = config.agents[task.agent];\n979\t    if (!definition) {\n980\t      warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n981\t      continue;\n982\t    }\n983\t\n984\t    if (task.scope === 'per-run') {\n985\t      // Skip if already completed (crash recovery — AC #3)\n986\t      if (isTaskCompleted(state, taskName, PER_RUN_SENTINEL)) {\n987\t        warn(`workflow-engine: skipping completed task ${taskName} for ${PER_RUN_SENTINEL}`);\n988\t        continue;\n989\t      }\n990\t\n991\t      // Per-run: dispatch once with sentinel key\n992\t      try {\n993\t        const dispatchResult = await dispatchTaskWithResult(\n994\t          task, taskName, PER_RUN_SENTINEL, definition, state, config, undefined, lastOutputContract ?? undefined,\n995\t        );\n996\t        state = dispatchResult.updatedState;\n997\t        lastOutputContract = dispatchResult.contract;\n998\t        tasksCompleted++;\n999\t      } catch (err: unknown) {\n1000\t        const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n1001\t        errors.push(engineError);\n1002\t\n1003\t        // Record error checkpoint in state (AC #13)\n1004\t        state = recordErrorInState(state, taskName, PER_RUN_SENTINEL, engineError);\n1005\t        writeWorkflowState(state, projectDir);\n1006\t\n1007\t        // Halt on critical errors\n1008\t        if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n1009\t          halted = true;\n1010\t        }\n1011\t      }\n1012\t    } else {\n1013\t      // Per-story: dispatch once per work item\n1014\t      for (const item of workItems) {\n1015\t        processedStories.add(item.key);\n1016\t\n1017\t        // Skip if already completed (crash recovery — AC #1, #2, #7)\n1018\t        if (isTaskCompleted(state, taskName, item.key)) {\n1019\t          warn(`workflow-engine: skipping completed task ${taskName} for ${item.key}`);\n1020\t          continue;\n1021\t        }\n1022\t\n1023\t        try {\n1024\t          const dispatchResult = await dispatchTaskWithResult(\n1025\t            task, taskName, item.key, definition, state, config, undefined, lastOutputContract ?? undefined,\n1026\t          );\n1027\t          state = dispatchResult.updatedState;\n1028\t          lastOutputContract = dispatchResult.contract;\n1029\t          tasksCompleted++;\n1030\t        } catch (err: unknown) {\n1031\t          const engineError = handleDispatchError(err, taskName, item.key);\n1032\t          errors.push(engineError);\n1033\t\n1034\t          // Record error checkpoint in state (AC #13)\n1035\t          state = recordErrorInState(state, taskName, item.key, engineError);\n1036\t          writeWorkflowState(state, projectDir);\n1037\t\n1038\t          // Halt on critical errors, continue on UNKNOWN\n1039\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n1040\t            halted = true;\n1041\t            break;\n1042\t          }\n1043\t          // UNKNOWN errors: record and continue to next story\n1044\t          continue;\n1045\t        }\n1046\t      }\n1047\t    }\n1048\t  }\n1049\t\n1050\t  // 4. Set final phase if no errors and phase not already set by loop termination\n1051\t  if (errors.length === 0 && state.phase !== 'max-iterations' && state.phase !== 'circuit-breaker') {\n1052\t    state = { ...state, phase: 'completed' };\n1053\t    writeWorkflowState(state, projectDir);\n1054\t  }\n1055\t\n1056\t  // 5. Return result\n1057\t  const loopTerminated = state.phase === 'max-iterations' || state.phase === 'circuit-breaker';\n1058\t  return {\n1059\t    success: errors.length === 0 && !loopTerminated,\n1060\t    tasksCompleted,\n1061\t    storiesProcessed: processedStories.size,\n1062\t    errors,\n1063\t    durationMs: Date.now() - startMs,\n1064\t  };\n1065\t}\n1066\t\n1067\t// --- Error Handling ---\n1068\t\n1069\t/**\n1070\t * Record a dispatch error in workflow state: set phase to \"error\" and append\n1071\t * a TaskCheckpoint with the error details (AC #13).\n1072\t */\n1073\tfunction recordErrorInState(\n1074\t  state: WorkflowState,\n1075\t  taskName: string,\n1076\t  storyKey: string,\n1077\t  error: EngineError,\n1078\t): WorkflowState {\n1079\t  const errorCheckpoint: TaskCheckpoint = {\n1080\t    task_name: taskName,\n1081\t    story_key: storyKey,\n1082\t    completed_at: new Date().toISOString(),\n1083\t    error: true,\n1084\t  };\n1085\t  return {\n1086\t    ...state,\n1087\t    phase: 'error',\n1088\t    tasks_completed: [...state.tasks_completed, errorCheckpoint],\n1089\t  };\n1090\t}\n1091\t\n1092\tfunction handleDispatchError(err: unknown, taskName: string, storyKey: string): EngineError {\n1093\t  if (err instanceof DispatchError) {\n1094\t    return {\n1095\t      taskName,\n1096\t      storyKey,\n1097\t      code: err.code,\n1098\t      message: err.message,\n1099\t    };"}]},"parent_tool_use_id":"toolu_01UsAm2qXT84D1u4sW8gSAmJ","session_id":"a29ee53b-c2b0-4802-9455-7215112648b1","uuid":"70e8988e-60f9-47c4-873c-5655d7277c3f","timestamp":"2026-04-03T11:58:45.683Z"}
