{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WPrvqQqvcPPsPGxuPQaNsT","type":"tool_result","content":"     1→/**\n     2→ * Observability coverage gate — checks if coverage meets targets for commit gating.\n     3→ *\n     4→ * Implements Story 2.2: reads cached coverage from sprint-state.json and compares\n     5→ * against targets. Does NOT re-run Semgrep — uses cached results for performance.\n     6→ * Static coverage is always required; runtime is only checked when data exists.\n     7→ */\n     8→\n     9→import { ok, fail } from '../../types/result.js';\n    10→import type { Result } from '../../types/result.js';\n    11→import { readCoverageState } from './coverage.js';\n    12→import type {\n    13→  ObservabilityCoverageGateResult,\n    14→  CoverageTargetResult,\n    15→} from './types.js';\n    16→\n    17→const DEFAULT_STATIC_TARGET = 80;\n    18→const DEFAULT_RUNTIME_TARGET = 60;\n    19→\n    20→/**\n    21→ * Check observability coverage against targets for commit gating.\n    22→ *\n    23→ * Reads static and runtime coverage from sprint-state.json. Static coverage\n    24→ * is always checked. Runtime coverage is only checked when runtime data exists\n    25→ * in the state file (i.e., after at least one verification run).\n    26→ *\n    27→ * @param projectDir - Project root directory\n    28→ * @param overrides - Optional target overrides\n    29→ * @returns Gate result with pass/fail, per-dimension results, and gap summary\n    30→ */\n    31→export function checkObservabilityCoverageGate(\n    32→  projectDir: string,\n    33→  overrides?: { staticTarget?: number; runtimeTarget?: number },\n    34→): Result<ObservabilityCoverageGateResult> {\n    35→  if (!projectDir || typeof projectDir !== 'string') {\n    36→    return fail('projectDir is required and must be a non-empty string');\n    37→  }\n    38→\n    39→  const stateResult = readCoverageState(projectDir);\n    40→  if (!stateResult.success) {\n    41→    return fail(stateResult.error);\n    42→  }\n    43→\n    44→  const state = stateResult.data;\n    45→  const staticTarget =\n    46→    overrides?.staticTarget ?? state.targets.staticTarget ?? DEFAULT_STATIC_TARGET;\n    47→  const runtimeTarget =\n    48→    overrides?.runtimeTarget ?? state.targets.runtimeTarget ?? DEFAULT_RUNTIME_TARGET;\n    49→\n    50→  // Static coverage check (always required)\n    51→  const staticCurrent = state.static.coveragePercent;\n    52→  const staticMet = staticCurrent >= staticTarget;\n    53→  const staticResult: CoverageTargetResult = {\n    54→    met: staticMet,\n    55→    current: staticCurrent,\n    56→    target: staticTarget,\n    57→    gap: staticMet ? 0 : staticTarget - staticCurrent,\n    58→  };\n    59→\n    60→  // Runtime coverage check (only when runtime data exists)\n    61→  let runtimeResult: CoverageTargetResult | null = null;\n    62→  if (state.runtime) {\n    63→    const runtimeCurrent = state.runtime.coveragePercent;\n    64→    const runtimeMet = runtimeCurrent >= runtimeTarget;\n    65→    runtimeResult = {\n    66→      met: runtimeMet,\n    67→      current: runtimeCurrent,\n    68→      target: runtimeTarget,\n    69→      gap: runtimeMet ? 0 : runtimeTarget - runtimeCurrent,\n    70→    };\n    71→  }\n    72→\n    73→  // Gate passes only when all checked dimensions pass\n    74→  const passed = staticResult.met && (runtimeResult === null || runtimeResult.met);\n    75→\n    76→  // Use cached gaps from the already-parsed state (no second file read)\n    77→  const gapSummary = state.static.gaps ? [...state.static.gaps] : [];\n    78→\n    79→  return ok({ passed, staticResult, runtimeResult, gapSummary });\n    80→}\n    81→"}]},"parent_tool_use_id":"toolu_01X8HPzdvjqKbRcjmtsWDTRD","session_id":"c5eaf6a6-ac7c-4707-b82c-6220d711aa9c","uuid":"277cbd03-5c15-46f4-ae2f-14c8228bb64b","timestamp":"2026-03-20T06:44:54.133Z"}
