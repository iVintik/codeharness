{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ed4qGMLEKxBqrBYRLXV71P","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach } from 'vitest';\n2\t\n3\t// --- Hoisted Mocks ---\n4\t\n5\tconst {\n6\t  mockDispatchAgent,\n7\t  mockReadWorkflowState,\n8\t  mockWriteWorkflowState,\n9\t  mockCreateIsolatedWorkspace,\n10\t  mockGenerateTraceId,\n11\t  mockFormatTracePrompt,\n12\t  mockRecordTraceId,\n13\t  mockResolveSessionId,\n14\t  mockRecordSessionId,\n15\t  mockWarn,\n16\t  mockReadFileSync,\n17\t  mockExistsSync,\n18\t  mockParse,\n19\t} = vi.hoisted(() => ({\n20\t  mockDispatchAgent: vi.fn(),\n21\t  mockReadWorkflowState: vi.fn(),\n22\t  mockWriteWorkflowState: vi.fn(),\n23\t  mockCreateIsolatedWorkspace: vi.fn(),\n24\t  mockGenerateTraceId: vi.fn(),\n25\t  mockFormatTracePrompt: vi.fn(),\n26\t  mockRecordTraceId: vi.fn(),\n27\t  mockResolveSessionId: vi.fn(),\n28\t  mockRecordSessionId: vi.fn(),\n29\t  mockWarn: vi.fn(),\n30\t  mockReadFileSync: vi.fn(),\n31\t  mockExistsSync: vi.fn(),\n32\t  mockParse: vi.fn(),\n33\t}));\n34\t\n35\tvi.mock('../agent-dispatch.js', () => ({\n36\t  dispatchAgent: mockDispatchAgent,\n37\t  DispatchError: class DispatchError extends Error {\n38\t    public readonly code: string;\n39\t    public readonly agentName: string;\n40\t    public readonly cause: unknown;\n41\t    constructor(message: string, code: string, agentName: string, cause: unknown) {\n42\t      super(message);\n43\t      this.name = 'DispatchError';\n44\t      this.code = code;\n45\t      this.agentName = agentName;\n46\t      this.cause = cause;\n47\t    }\n48\t  },\n49\t}));\n50\t\n51\tvi.mock('../workflow-state.js', () => ({\n52\t  readWorkflowState: mockReadWorkflowState,\n53\t  writeWorkflowState: mockWriteWorkflowState,\n54\t  getDefaultWorkflowState: () => ({\n55\t    workflow_name: '',\n56\t    started: '',\n57\t    iteration: 0,\n58\t    phase: 'idle',\n59\t    tasks_completed: [],\n60\t    evaluator_scores: [],\n61\t    circuit_breaker: { triggered: false, reason: null, score_history: [] },\n62\t    trace_ids: [],\n63\t  }),\n64\t}));\n65\t\n66\tvi.mock('../source-isolation.js', () => ({\n67\t  createIsolatedWorkspace: mockCreateIsolatedWorkspace,\n68\t}));\n69\t\n70\tvi.mock('../trace-id.js', () => ({\n71\t  generateTraceId: mockGenerateTraceId,\n72\t  formatTracePrompt: mockFormatTracePrompt,\n73\t  recordTraceId: mockRecordTraceId,\n74\t}));\n75\t\n76\tvi.mock('../session-manager.js', () => ({\n77\t  resolveSessionId: mockResolveSessionId,\n78\t  recordSessionId: mockRecordSessionId,\n79\t}));\n80\t"}]},"parent_tool_use_id":"toolu_01AgrEwqjtjzQsRkNtrmWZM7","session_id":"7447df8e-50f4-441a-b8fe-e85605fee72e","uuid":"3331e9ff-75a3-4081-ae08-e7da8a46ac49","timestamp":"2026-04-02T22:14:22.508Z"}
