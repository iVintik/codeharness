{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FB88BJN5ckiA587v4evdmF","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach } from 'vitest';\n2\timport { readFileSync } from 'node:fs';\n3\timport { resolve } from 'node:path';\n4\timport type { AgentDriver, DispatchOpts, DriverHealth } from '../types.js';\n5\timport type { StreamEvent } from '../stream-parser.js';\n6\timport {\n7\t  registerDriver,\n8\t  getDriver,\n9\t  listDrivers,\n10\t  resetDrivers,\n11\t} from '../drivers/factory.js';\n12\t\n13\t// --- Helpers ---\n14\t\n15\t/** Creates a minimal mock AgentDriver for testing. */\n16\tfunction createMockDriver(name: string): AgentDriver {\n17\t  return {\n18\t    name,\n19\t    defaultModel: 'mock-model',\n20\t    capabilities: {\n21\t      supportsPlugins: false,\n22\t      supportsStreaming: true,\n23\t      costReporting: false,\n24\t    },\n25\t    async healthCheck(): Promise<DriverHealth> {\n26\t      return { available: true, authenticated: true, version: '1.0.0' };\n27\t    },\n28\t    async *dispatch(_opts: DispatchOpts): AsyncIterable<StreamEvent> {\n29\t      yield { type: 'text', text: 'mock' };\n30\t    },\n31\t    getLastCost(): number | null {\n32\t      return null;\n33\t    },\n34\t  };\n35\t}\n36\t\n37\t// --- Tests ---\n38\t\n39\tdescribe('agents/drivers/factory — Driver Factory & Registry', () => {\n40\t  beforeEach(() => {\n41\t    resetDrivers();\n42\t  });\n43\t\n44\t  describe('registerDriver + getDriver', () => {\n45\t    it('registers a driver and retrieves it by name (same reference)', () => {\n46\t      const driver = createMockDriver('claude-code');\n47\t      registerDriver(driver);\n48\t      const retrieved = getDriver('claude-code');\n49\t      expect(retrieved).toBe(driver); // same reference\n50\t    });\n51\t\n52\t    it('registers multiple drivers and retrieves each by name', () => {\n53\t      const d1 = createMockDriver('claude-code');\n54\t      const d2 = createMockDriver('codex');\n55\t      registerDriver(d1);\n56\t      registerDriver(d2);\n57\t      expect(getDriver('claude-code')).toBe(d1);\n58\t      expect(getDriver('codex')).toBe(d2);\n59\t    });\n60\t  });\n61\t\n62\t  describe('getDriver — unknown name', () => {\n63\t    it('throws when no drivers are registered', () => {\n64\t      expect(() => getDriver('unknown')).toThrow(\"Driver 'unknown' not found\");\n65\t    });\n66\t\n67\t    it('includes the unknown name in the error message', () => {\n68\t      expect(() => getDriver('nonexistent')).toThrow('nonexistent');\n69\t    });\n70\t\n71\t    it('lists registered driver names in the error message', () => {\n72\t      registerDriver(createMockDriver('claude-code'));\n73\t      registerDriver(createMockDriver('opencode'));\n74\t      expect(() => getDriver('codex')).toThrow('claude-code');\n75\t      expect(() => getDriver('codex')).toThrow('opencode');\n76\t    });\n77\t\n78\t    it('shows \"(none)\" when no drivers are registered', () => {\n79\t      expect(() => getDriver('x')).toThrow('(none)');\n80\t    });\n81\t  });\n82\t\n83\t  describe('registerDriver — duplicate', () => {\n84\t    it('throws when registering a driver with an already-registered name', () => {\n85\t      registerDriver(createMockDriver('claude-code'));\n86\t      expect(() => registerDriver(createMockDriver('claude-code'))).toThrow(\n87\t        \"Driver 'claude-code' is already registered\",\n88\t      );\n89\t    });\n90\t\n91\t    it('includes the duplicate name in the error message', () => {\n92\t      registerDriver(createMockDriver('opencode'));\n93\t      expect(() => registerDriver(createMockDriver('opencode'))).toThrow(\n94\t        'opencode',\n95\t      );\n96\t    });\n97\t  });\n98\t\n99\t  describe('listDrivers', () => {\n100\t    it('returns empty array when no drivers are registered', () => {\n101\t      expect(listDrivers()).toEqual([]);\n102\t    });\n103\t\n104\t    it('returns all registered driver names', () => {\n105\t      registerDriver(createMockDriver('claude-code'));\n106\t      registerDriver(createMockDriver('codex'));\n107\t      registerDriver(createMockDriver('opencode'));\n108\t      expect(listDrivers()).toEqual(['claude-code', 'codex', 'opencode']);\n109\t    });\n110\t\n111\t    it('returns a copy — mutating the result does not affect registry', () => {\n112\t      registerDriver(createMockDriver('claude-code'));\n113\t      const list = listDrivers();\n114\t      list.push('injected');\n115\t      expect(listDrivers()).toEqual(['claude-code']);\n116\t      expect(listDrivers()).not.toContain('injected');\n117\t    });\n118\t  });\n119\t\n120\t  describe('resetDrivers', () => {\n121\t    it('clears all registered drivers', () => {\n122\t      registerDriver(createMockDriver('claude-code'));\n123\t      registerDriver(createMockDriver('codex'));\n124\t      expect(listDrivers()).toHaveLength(2);\n125\t\n126\t      resetDrivers();\n127\t\n128\t      expect(listDrivers()).toEqual([]);\n129\t      expect(() => getDriver('claude-code')).toThrow();\n130\t      expect(() => getDriver('codex')).toThrow();\n131\t    });\n132\t  });\n133\t\n134\t  describe('no auto-discovery', () => {\n135\t    it('factory.ts source has no dynamic import(), readdir, glob, or require() calls', () => {\n136\t      const factoryPath = resolve(\n137\t        import.meta.dirname ?? __dirname,\n138\t        '..',\n139\t        'drivers',\n140\t        'factory.ts',\n141\t      );\n142\t      const source = readFileSync(factoryPath, 'utf-8');\n143\t\n144\t      // Forbidden patterns that would indicate auto-discovery\n145\t      expect(source).not.toMatch(/\\bimport\\s*\\(/);\n146\t      expect(source).not.toMatch(/\\breaddir/i);\n147\t      expect(source).not.toMatch(/\\bglob\\b/i);\n148\t      expect(source).not.toMatch(/\\brequire\\s*\\(/);\n149\t    });\n150\t  });\n151\t\n152\t  describe('barrel re-exports', () => {\n153\t    it('drivers/index.ts re-exports all factory functions', async () => {\n154\t      const barrel = await import('../drivers/index.js');\n155\t      expect(typeof barrel.getDriver).toBe('function');\n156\t      expect(typeof barrel.registerDriver).toBe('function');\n157\t      expect(typeof barrel.listDrivers).toBe('function');\n158\t      expect(typeof barrel.resetDrivers).toBe('function');\n159\t    });\n160\t\n161\t    it('agents/index.ts re-exports factory functions', async () => {\n162\t      const agents = await import('../index.js');\n163\t      expect(typeof agents.getDriver).toBe('function');\n164\t      expect(typeof agents.registerDriver).toBe('function');\n165\t      expect(typeof agents.listDrivers).toBe('function');\n166\t      expect(typeof agents.resetDrivers).toBe('function');\n167\t    });\n168\t  });\n169\t});\n170\t"}]},"parent_tool_use_id":"toolu_017Urm7EPd5KhakJiz43kv21","session_id":"61d40628-eabe-45b5-b544-2f5989944a22","uuid":"f0adb51b-4bdb-40d0-b890-4ae22721f5e9","timestamp":"2026-04-03T06:45:11.884Z"}
