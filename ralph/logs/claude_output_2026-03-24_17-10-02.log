{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QK12K9pqrkguc1H6zpJuVt","type":"tool_result","content":"     1→import { readdirSync, statSync } from 'node:fs';\n     2→import { join } from 'node:path';\n     3→\n     4→export interface DocHealthResult {\n     5→  path: string;\n     6→  grade: 'fresh' | 'stale' | 'missing';\n     7→  lastModified: Date | null;\n     8→  codeLastModified: Date | null;\n     9→  reason: string;\n    10→}\n    11→\n    12→export interface DocHealthReport {\n    13→  documents: DocHealthResult[];\n    14→  summary: { fresh: number; stale: number; missing: number; total: number };\n    15→  passed: boolean;\n    16→  scanDurationMs: number;\n    17→}\n    18→\n    19→// ─── Shared Utilities ────────────────────────────────────────────────────────\n    20→// These live here to avoid circular dependencies between scanner.ts and staleness.ts.\n    21→\n    22→const SOURCE_EXTENSIONS = new Set(['.ts', '.js', '.py']);\n    23→\n    24→export function getExtension(filename: string): string {\n    25→  const dot = filename.lastIndexOf('.');\n    26→  return dot >= 0 ? filename.slice(dot) : '';\n    27→}\n    28→\n    29→export function isTestFile(filename: string): boolean {\n    30→  return (\n    31→    filename.includes('.test.') ||\n    32→    filename.includes('.spec.') ||\n    33→    filename.includes('__tests__') ||\n    34→    filename.startsWith('test_')\n    35→  );\n    36→}\n    37→\n    38→export function getNewestSourceMtime(dir: string): Date | null {\n    39→  let newest: Date | null = null;\n    40→\n    41→  function walk(current: string): void {\n    42→    let entries: string[];\n    43→    try {\n    44→      entries = readdirSync(current);\n    45→    } catch {\n    46→      return;\n    47→    }\n    48→\n    49→    const dirName = current.split('/').pop() ?? '';\n    50→    if (dirName === 'node_modules' || dirName === '.git') return;\n    51→\n    52→    for (const entry of entries) {\n    53→      const fullPath = join(current, entry);\n    54→      let stat;\n    55→      try {\n    56→        stat = statSync(fullPath);\n    57→      } catch {\n    58→        continue;\n    59→      }\n    60→\n    61→      if (stat.isDirectory()) {\n    62→        if (entry !== '__tests__') {\n    63→          walk(fullPath);\n    64→        }\n    65→      } else if (stat.isFile()) {\n    66→        const ext = getExtension(entry);\n    67→        if (SOURCE_EXTENSIONS.has(ext) && !isTestFile(entry)) {\n    68→          if (newest === null || stat.mtime.getTime() > newest.getTime()) {\n    69→            newest = stat.mtime;\n    70→          }\n    71→        }\n    72→      }\n    73→    }\n    74→  }\n    75→\n    76→  walk(dir);\n    77→  return newest;\n    78→}\n    79→"}]},"parent_tool_use_id":"toolu_01WxJciqSN2EMLLyK1wQ7yug","session_id":"6831c0a8-772d-4704-bc72-4469c7d7a986","uuid":"917cb1c5-da9d-4cc1-b3e8-c778d8fe6cc2","timestamp":"2026-03-24T13:14:03.148Z"}
