{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01T2aP7ZigesDQk92yD6FeqN","type":"tool_result","content":"     1→import { execFileSync } from 'node:child_process';\n     2→import { readFileSync, writeFileSync, existsSync } from 'node:fs';\n     3→import { join, basename } from 'node:path';\n     4→import { ok, info } from './output.js';\n     5→import { readState, writeState, readStateWithBody } from './state.js';\n     6→import type { HarnessState } from './state.js';\n     7→import type { AppType } from './stacks/index.js';\n     8→\n     9→export interface OtlpResult {\n    10→  status: 'configured' | 'skipped' | 'failed';\n    11→  packages_installed: boolean;\n    12→  start_script_patched: boolean;\n    13→  env_vars_configured: boolean;\n    14→  error?: string;\n    15→}\n    16→\n    17→const NODE_OTLP_PACKAGES = [\n    18→  '@opentelemetry/auto-instrumentations-node',\n    19→  '@opentelemetry/sdk-node',\n    20→  '@opentelemetry/exporter-trace-otlp-http',\n    21→  '@opentelemetry/exporter-metrics-otlp-http',\n    22→];\n    23→\n    24→const PYTHON_OTLP_PACKAGES = [\n    25→  'opentelemetry-distro',\n    26→  'opentelemetry-exporter-otlp',\n    27→];\n    28→\n    29→const RUST_OTLP_PACKAGES = [\n    30→  'opentelemetry',\n    31→  'opentelemetry-otlp',\n    32→  'tracing-opentelemetry',\n    33→  'tracing-subscriber',\n    34→];\n    35→\n    36→export const WEB_OTLP_PACKAGES = [\n    37→  '@opentelemetry/sdk-trace-web',\n    38→  '@opentelemetry/instrumentation-fetch',\n    39→  '@opentelemetry/instrumentation-xml-http-request',\n    40→];\n    41→\n    42→export const AGENT_OTLP_PACKAGES_NODE = ['@traceloop/node-server-sdk'];\n    43→export const AGENT_OTLP_PACKAGES_PYTHON = ['traceloop-sdk'];\n    44→\n    45→export const NODE_REQUIRE_FLAG = '--require @opentelemetry/auto-instrumentations-node/register';\n    46→\n    47→/** Truncate error messages from execFileSync that include full stderr output */\n    48→function truncateError(message: string, maxLength = 200): string {\n    49→  if (message.length <= maxLength) return message;\n    50→  return message.slice(0, maxLength) + '... (truncated)';\n    51→}\n    52→\n    53→export function installNodeOtlp(projectDir: string): OtlpResult {\n    54→  try {\n    55→    execFileSync('npm', ['install', ...NODE_OTLP_PACKAGES], { cwd: projectDir, stdio: 'pipe', timeout: 300_000 });\n    56→    return {\n    57→      status: 'configured',\n    58→      packages_installed: true,\n    59→      start_script_patched: false,\n    60→      env_vars_configured: false,\n    61→    };\n    62→  } catch (err) {\n    63→    const message = err instanceof Error ? err.message : 'Unknown error';\n    64→    return {\n    65→      status: 'failed',\n    66→      packages_installed: false,\n    67→      start_script_patched: false,\n    68→      env_vars_configured: false,\n    69→      error: `Failed to install Node.js OTLP packages: ${truncateError(message)}`,\n    70→    };\n    71→  }\n    72→}\n    73→\n    74→export function patchNodeStartScript(projectDir: string): boolean {\n    75→  const pkgPath = join(projectDir, 'package.json');\n    76→  if (!existsSync(pkgPath)) {\n    77→    return false;\n    78→  }\n    79→\n    80→  let raw: string;\n    81→  let pkg: Record<string, unknown>;\n    82→  try {\n    83→    raw = readFileSync(pkgPath, 'utf-8');\n    84→    pkg = JSON.parse(raw) as Record<string, unknown>;\n    85→  } catch {\n    86→    // Malformed package.json — skip patching\n    87→    return false;\n    88→  }\n    89→  const scripts = pkg['scripts'] as Record<string, string> | undefined;\n    90→\n    91→  if (!scripts) {\n    92→    return false;\n    93→  }\n    94→\n    95→  const targetKey = scripts['start'] ? 'start' : scripts['dev'] ? 'dev' : null;\n    96→  if (!targetKey) {\n    97→    return false;\n    98→  }\n    99→\n   100→  const instrumentedKey = `${targetKey}:instrumented`;\n   101→\n   102→  // Check if already patched — the instrumented key already exists\n   103→  if (scripts[instrumentedKey]?.includes(NODE_REQUIRE_FLAG)) {\n   104→    return false;\n   105→  }\n   106→  scripts[instrumentedKey] = `NODE_OPTIONS='${NODE_REQUIRE_FLAG}' ${scripts[targetKey]}`;\n   107→\n   108→  writeFileSync(pkgPath, JSON.stringify(pkg, null, 2) + '\\n', 'utf-8');\n   109→  return true;\n   110→}\n   111→\n   112→export function installPythonOtlp(projectDir: string): OtlpResult {\n   113→  const installChains: { cmd: string; args: string[] }[][] = [\n   114→    // Primary: pip install both packages in one command\n   115→    [{ cmd: 'pip', args: ['install', ...PYTHON_OTLP_PACKAGES] }],\n   116→    // Fallback: pipx install each package individually (pipx only accepts one package at a time)\n   117→    PYTHON_OTLP_PACKAGES.map(pkg => ({ cmd: 'pipx', args: ['install', pkg] })),\n   118→  ];\n   119→\n   120→  for (const chain of installChains) {\n   121→    try {\n   122→      for (const step of chain) {\n   123→        execFileSync(step.cmd, step.args, { cwd: projectDir, stdio: 'pipe', timeout: 300_000 });\n   124→      }\n   125→      return {\n   126→        status: 'configured',\n   127→        packages_installed: true,\n   128→        start_script_patched: false,\n   129→        env_vars_configured: false,\n   130→      };\n   131→    } catch {\n   132→      continue;\n   133→    }\n   134→  }\n   135→\n   136→  return {\n   137→    status: 'failed',\n   138→    packages_installed: false,\n   139→    start_script_patched: false,\n   140→    env_vars_configured: false,\n   141→    error: 'Failed to install Python OTLP packages',\n   142→  };\n   143→}\n   144→\n   145→export function installRustOtlp(projectDir: string): OtlpResult {\n   146→  try {\n   147→    execFileSync('cargo', ['add', ...RUST_OTLP_PACKAGES], { cwd: projectDir, stdio: 'pipe', timeout: 300_000 });\n   148→    return {\n   149→      status: 'configured',\n   150→      packages_installed: true,\n   151→      start_script_patched: false,\n   152→      env_vars_configured: false,\n   153→    };\n   154→  } catch (err) {\n   155→    const message = err instanceof Error ? err.message : 'Unknown error';\n   156→    return {\n   157→      status: 'failed',\n   158→      packages_installed: false,\n   159→      start_script_patched: false,\n   160→      env_vars_configured: false,\n   161→      error: `Failed to install Rust OTLP packages: ${truncateError(message)}`,\n   162→    };\n   163→  }\n   164→}\n   165→\n   166→export function configureCli(projectDir: string): void {\n   167→  const { state, body } = readStateWithBody(projectDir);\n   168→\n   169→  if (!state.otlp) return;\n   170→\n   171→  state.otlp.cli_env_vars = {\n   172→    OTEL_BSP_SCHEDULE_DELAY: '100',\n   173→    OTEL_TRACES_SAMPLER: 'always_on',\n   174→    OTEL_BLRP_SCHEDULE_DELAY: '100',\n   175→  };\n   176→\n   177→  writeState(state, projectDir, body);\n   178→}\n   179→\n   180→export function configureWeb(projectDir: string, stack: string | null): void {\n   181→  // Web OTLP packages are only applicable to Node.js — install via npm if the stack is nodejs\n   182→  const webInstaller: Record<string, () => void> = {\n   183→    nodejs: () => {\n   184→      try {\n   185→        execFileSync('npm', ['install', ...WEB_OTLP_PACKAGES], { cwd: projectDir, stdio: 'pipe', timeout: 300_000 });\n   186→      } catch {\n   187→        // Web packages are supplementary; failure is non-fatal\n   188→      }\n   189→    },\n   190→  };\n   191→  if (stack && webInstaller[stack]) {\n   192→    webInstaller[stack]();\n   193→  }\n   194→\n   195→  // Read endpoint from state (may have been set by configureOtlpEnvVars)\n   196→  let endpoint = 'http://localhost:4318';\n   197→  try {\n   198→    const currentState = readState(projectDir);\n   199→    if (currentState.otlp?.endpoint) {\n   200→      endpoint = currentState.otlp.endpoint;\n   201→    }\n   202→  } catch {\n   203→    // State not readable — use default endpoint\n   204→  }\n   205→\n   206→  // Generate otel-web-init.js snippet\n   207→  const snippet = `// OpenTelemetry Web SDK initialization — generated by codeharness\n   208→import { WebTracerProvider } from '@opentelemetry/sdk-trace-web';\n   209→import { BatchSpanProcessor } from '@opentelemetry/sdk-trace-base';\n   210→import { OTLPTraceExporter } from '@opentelemetry/exporter-trace-otlp-http';\n   211→import { FetchInstrumentation } from '@opentelemetry/instrumentation-fetch';\n   212→import { XMLHttpRequestInstrumentation } from '@opentelemetry/instrumentation-xml-http-request';\n   213→import { registerInstrumentations } from '@opentelemetry/instrumentation';\n   214→\n   215→const exporter = new OTLPTraceExporter({\n   216→  url: '${endpoint}/v1/traces',\n   217→});\n   218→\n   219→const provider = new WebTracerProvider();\n   220→provider.addSpanProcessor(new BatchSpanProcessor(exporter));\n   221→provider.register();\n   222→\n   223→registerInstrumentations({\n   224→  instrumentations: [\n   225→    new FetchInstrumentation(),\n   226→    new XMLHttpRequestInstrumentation(),\n   227→  ],\n   228→});\n   229→`;\n   230→\n   231→  const snippetPath = join(projectDir, 'otel-web-init.js');\n   232→  writeFileSync(snippetPath, snippet, 'utf-8');\n   233→\n   234→  const { state, body } = readStateWithBody(projectDir);\n   235→  if (state.otlp) {\n   236→    state.otlp.web_snippet_path = 'otel-web-init.js';\n   237→  }\n   238→  writeState(state, projectDir, body);\n   239→}\n   240→\n   241→export function configureAgent(projectDir: string, stack: string | null): void {\n   242→  /** Per-stack agent package installation (no stack string comparisons). */\n   243→  const agentInstallers: Record<string, () => boolean> = {\n   244→    nodejs: () => {\n   245→      try {\n   246→        execFileSync('npm', ['install', ...AGENT_OTLP_PACKAGES_NODE], { cwd: projectDir, stdio: 'pipe', timeout: 300_000 });\n   247→      } catch {\n   248→        // Agent packages are supplementary; failure is non-fatal\n   249→      }\n   250→      return true;\n   251→    },\n   252→    python: () => {\n   253→      try {\n   254→        execFileSync('pip', ['install', ...AGENT_OTLP_PACKAGES_PYTHON], { cwd: projectDir, stdio: 'pipe', timeout: 300_000 });\n   255→      } catch {\n   256→        // Try pipx fallback\n   257→        try {\n   258→          for (const pkg of AGENT_OTLP_PACKAGES_PYTHON) {\n   259→            execFileSync('pipx', ['install', pkg], { cwd: projectDir, stdio: 'pipe', timeout: 300_000 });\n   260→          }\n   261→        } catch {\n   262→          // Agent packages are supplementary; failure is non-fatal\n   263→        }\n   264→      }\n   265→      return true;\n   266→    },\n   267→    rust: () => {\n   268→      info('Rust agent SDK not yet supported — skipping agent configuration');\n   269→      return false;\n   270→    },\n   271→  };\n   272→\n   273→  if (stack) {\n   274→    const installer = agentInstallers[stack];\n   275→    if (installer) {\n   276→      const proceed = installer();\n   277→      if (!proceed) return;\n   278→    }\n   279→  }\n   280→\n   281→  const { state, body } = readStateWithBody(projectDir);\n   282→  if (state.otlp) {\n   283→    state.otlp.agent_sdk = 'traceloop';\n   284→  }\n   285→  writeState(state, projectDir, body);\n   286→}\n   287→\n   288→export function ensureServiceNameEnvVar(projectDir: string, serviceName: string): void {\n   289→  const envFilePath = join(projectDir, '.env.codeharness');\n   290→  // Sanitize service name: replace characters unsafe for env values and URLs\n   291→  const sanitized = serviceName.replace(/[^a-zA-Z0-9._-]/g, '-');\n   292→  const envLine = `OTEL_SERVICE_NAME=${sanitized}`;\n   293→\n   294→  if (existsSync(envFilePath)) {\n   295→    const content = readFileSync(envFilePath, 'utf-8');\n   296→    // Split and remove trailing empty lines from the split result\n   297→    const lines = content.split('\\n').filter((l, i, arr) => i < arr.length - 1 || l.trim() !== '');\n   298→    const idx = lines.findIndex(l => l.startsWith('OTEL_SERVICE_NAME='));\n   299→    if (idx !== -1) {\n   300→      lines[idx] = envLine;\n   301→    } else {\n   302→      lines.push(envLine);\n   303→    }\n   304→    writeFileSync(envFilePath, lines.join('\\n') + '\\n', 'utf-8');\n   305→  } else {\n   306→    writeFileSync(envFilePath, envLine + '\\n', 'utf-8');\n   307→  }\n   308→}\n   309→\n   310→export function ensureEndpointEnvVar(projectDir: string, endpoint: string): void {\n   311→  const envFilePath = join(projectDir, '.env.codeharness');\n   312→  const envLine = `OTEL_EXPORTER_OTLP_ENDPOINT=${endpoint}`;\n   313→\n   314→  if (existsSync(envFilePath)) {\n   315→    const content = readFileSync(envFilePath, 'utf-8');\n   316→    const lines = content.split('\\n').filter((l, i, arr) => i < arr.length - 1 || l.trim() !== '');\n   317→    const idx = lines.findIndex(l => l.startsWith('OTEL_EXPORTER_OTLP_ENDPOINT='));\n   318→    if (idx !== -1) {\n   319→      lines[idx] = envLine;\n   320→    } else {\n   321→      lines.push(envLine);\n   322→    }\n   323→    writeFileSync(envFilePath, lines.join('\\n') + '\\n', 'utf-8');\n   324→  } else {\n   325→    writeFileSync(envFilePath, envLine + '\\n', 'utf-8');\n   326→  }\n   327→}\n   328→\n   329→export function configureOtlpEnvVars(projectDir: string, stack: string | null, opts?: { endpoint?: string; appType?: AppType }): void {\n   330→  const projectName = basename(projectDir);\n   331→\n   332→  const { state, body } = readStateWithBody(projectDir);\n   333→\n   334→  /** Per-stack OTLP state fields (no stack string comparisons). */\n   335→  const stackOtlpFields: Record<string, Record<string, string>> = {\n   336→    nodejs: { node_require: NODE_REQUIRE_FLAG },\n   337→    python: { python_wrapper: 'opentelemetry-instrument' },\n   338→    rust: { rust_env_hint: 'OTEL_EXPORTER_OTLP_ENDPOINT' },\n   339→  };\n   340→\n   341→  state.otlp = {\n   342→    enabled: true,\n   343→    endpoint: opts?.endpoint ?? 'http://localhost:4318',\n   344→    service_name: projectName,\n   345→    mode: state.otlp?.mode ?? 'local-shared',\n   346→    ...(stack && stackOtlpFields[stack] ? stackOtlpFields[stack] : {}),\n   347→  };\n   348→\n   349→  // Resource attributes (Task 6)\n   350→  state.otlp.resource_attributes = 'service.instance.id=$(hostname)-$$';\n   351→\n   352→  writeState(state, projectDir, body);\n   353→\n   354→  // Write OTEL_SERVICE_NAME to .env.codeharness file\n   355→  ensureServiceNameEnvVar(projectDir, projectName);\n   356→\n   357→  // Stacks that read env vars directly need the endpoint written to .env.codeharness\n   358→  const needsEndpointEnv = new Set(['rust']);\n   359→  if (stack && needsEndpointEnv.has(stack)) {\n   360→    ensureEndpointEnvVar(projectDir, state.otlp.endpoint);\n   361→  }\n   362→}\n   363→\n   364→export function instrumentProject(\n   365→  projectDir: string,\n   366→  stack: string | null,\n   367→  opts?: { json?: boolean; appType?: AppType },\n   368→): OtlpResult {\n   369→  const isJson = opts?.json === true;\n   370→  const appType = opts?.appType;\n   371→\n   372→  /** Per-stack OTLP install+message handlers (no stack string comparisons). */\n   373→  const stackInstallers: Record<string, () => OtlpResult> = {\n   374→    nodejs: () => {\n   375→      const r = installNodeOtlp(projectDir);\n   376→      if (r.status === 'configured') {\n   377→        const patched = patchNodeStartScript(projectDir);\n   378→        r.start_script_patched = patched;\n   379→        if (!isJson) {\n   380→          ok('OTLP: Node.js packages installed');\n   381→          if (patched) {\n   382→            ok('OTLP: start script patched with --require flag');\n   383→          } else {\n   384→            info('OTLP: no start/dev script found or already patched');\n   385→          }\n   386→        }\n   387→      }\n   388→      return r;\n   389→    },\n   390→    python: () => {\n   391→      const r = installPythonOtlp(projectDir);\n   392→      if (r.status === 'configured' && !isJson) {\n   393→        ok('OTLP: Python packages installed');\n   394→        info('OTLP: wrap your command with: opentelemetry-instrument <command>');\n   395→      }\n   396→      return r;\n   397→    },\n   398→    rust: () => {\n   399→      const r = installRustOtlp(projectDir);\n   400→      if (r.status === 'configured' && !isJson) {\n   401→        ok('OTLP: Rust packages installed');\n   402→      }\n   403→      return r;\n   404→    },\n   405→  };\n   406→\n   407→  if (!stack || !stackInstallers[stack]) {\n   408→    return {\n   409→      status: 'skipped',\n   410→      packages_installed: false,\n   411→      start_script_patched: false,\n   412→      env_vars_configured: false,\n   413→      error: 'Unsupported stack for OTLP instrumentation',\n   414→    };\n   415→  }\n   416→\n   417→  const result = stackInstallers[stack]();\n   418→\n   419→  // Always configure OTLP env vars and state, even when package install fails.\n   420→  // The env vars and python_wrapper/node_require fields are useful regardless\n   421→  // of whether the packages are installed (the user can install them manually).\n   422→  configureOtlpEnvVars(projectDir, stack, { appType });\n   423→  result.env_vars_configured = true;\n   424→  if (!isJson) {\n   425→    ok('OTLP: environment variables configured');\n   426→  }\n   427→\n   428→  if (result.status === 'configured') {\n   429→    // Dispatch to app-type-specific configuration (Task 7)\n   430→    if (appType === 'cli') {\n   431→      configureCli(projectDir);\n   432→      if (!isJson) {\n   433→        ok('OTLP: CLI instrumentation configured (fast flush, always_on sampler)');\n   434→      }\n   435→    } else if (appType === 'web') {\n   436→      configureWeb(projectDir, stack);\n   437→      if (!isJson) {\n   438→        ok('OTLP: Web instrumentation configured (browser SDK + CORS)');\n   439→      }\n   440→    } else if (appType === 'agent') {\n   441→      configureAgent(projectDir, stack);\n   442→      if (!isJson) {\n   443→        ok('OTLP: Agent/LLM instrumentation configured (OpenLLMetry/Traceloop)');\n   444→      }\n   445→    } else if (appType === 'generic' && !isJson) {\n   446→      info('App type: generic (manual OTLP setup may be needed)');\n   447→    }\n   448→  } else if (!isJson && result.error) {\n   449→    info(`OTLP: ${result.error}`);\n   450→  }\n   451→\n   452→  return result;\n   453→}\n   454→"}]},"parent_tool_use_id":"toolu_01NQFJhfdisZwxGgfMvJomZh","session_id":"01d3be87-3cff-45e1-920c-7390a9e4093c","uuid":"bf5d8646-0f53-4298-aef8-5b59d9d33a28","timestamp":"2026-03-24T09:58:17.690Z"}
