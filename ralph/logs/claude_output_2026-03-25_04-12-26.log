{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TmPB3fCQgo5hAeHQYjmif3","type":"tool_result","content":"     1→import { execFileSync } from 'node:child_process';\n     2→import { existsSync, readdirSync } from 'node:fs';\n     3→import { join } from 'node:path';\n     4→\n     5→export class BeadsError extends Error {\n     6→  constructor(\n     7→    public readonly command: string,\n     8→    public readonly originalMessage: string,\n     9→  ) {\n    10→    super(`Beads failed: ${originalMessage}. Command: ${command}`);\n    11→    this.name = 'BeadsError';\n    12→  }\n    13→}\n    14→\n    15→export interface BeadsCreateOpts {\n    16→  type?: string;\n    17→  priority?: number;\n    18→  description?: string;\n    19→  deps?: string[];\n    20→}\n    21→\n    22→export interface BeadsIssue {\n    23→  id: string;\n    24→  title: string;\n    25→  status: string;\n    26→  type: string;\n    27→  priority: number;\n    28→  description?: string;\n    29→}\n    30→\n    31→export interface BeadsHookDetection {\n    32→  hasHooks: boolean;\n    33→  hookTypes: string[];\n    34→}\n    35→\n    36→/**\n    37→ * Runs a `bd` command with the given args, appends `--json` when needed,\n    38→ * parses JSON output, and wraps errors with context.\n    39→ */\n    40→export function bdCommand(args: string[]): unknown {\n    41→  const cmdStr = `bd ${args.join(' ')}`;\n    42→  let text: string;\n    43→  try {\n    44→    const output = execFileSync('bd', args, {\n    45→      stdio: 'pipe',\n    46→      timeout: 30_000,\n    47→    });\n    48→    text = output.toString().trim();\n    49→  } catch (err) {\n    50→    const message = err instanceof Error ? err.message : String(err);\n    51→    throw new BeadsError(cmdStr, message);\n    52→  }\n    53→  if (!text) return undefined;\n    54→  try {\n    55→    return JSON.parse(text) as unknown;\n    56→  } catch {\n    57→    throw new BeadsError(cmdStr, `Invalid JSON output from bd: ${text}`);\n    58→  }\n    59→}\n    60→\n    61→export function createIssue(title: string, opts?: BeadsCreateOpts): BeadsIssue {\n    62→  const args = ['create', title, '--json'];\n    63→  if (opts?.type) {\n    64→    args.push('--type', opts.type);\n    65→  }\n    66→  if (opts?.priority !== undefined) {\n    67→    args.push('--priority', String(opts.priority));\n    68→  }\n    69→  if (opts?.description) {\n    70→    args.push('--description', opts.description);\n    71→  }\n    72→  if (opts?.deps && opts.deps.length > 0) {\n    73→    for (const dep of opts.deps) {\n    74→      args.push('--dep', dep);\n    75→    }\n    76→  }\n    77→  return bdCommand(args) as BeadsIssue;\n    78→}\n    79→\n    80→export function getReady(): BeadsIssue[] {\n    81→  return bdCommand(['ready', '--json']) as BeadsIssue[];\n    82→}\n    83→\n    84→export function closeIssue(id: string): void {\n    85→  bdCommand(['close', id, '--json']);\n    86→}\n    87→\n    88→export function updateIssue(id: string, opts: { status?: string; priority?: number }): void {\n    89→  const args = ['update', id, '--json'];\n    90→  if (opts.status !== undefined) {\n    91→    args.push('--status', opts.status);\n    92→  }\n    93→  if (opts.priority !== undefined) {\n    94→    args.push('--priority', String(opts.priority));\n    95→  }\n    96→  bdCommand(args);\n    97→}\n    98→\n    99→export function listIssues(): BeadsIssue[] {\n   100→  return bdCommand(['list', '--json']) as BeadsIssue[];\n   101→}\n   102→\n   103→export function isBeadsInitialized(dir?: string): boolean {\n   104→  const beadsDir = join(dir ?? process.cwd(), '.beads');\n   105→  return existsSync(beadsDir);\n   106→}\n   107→\n   108→export function initBeads(dir?: string): void {\n   109→  if (isBeadsInitialized(dir)) {\n   110→    return;\n   111→  }\n   112→  const cmdStr = 'bd init';\n   113→  try {\n   114→    execFileSync('bd', ['init'], {\n   115→      stdio: 'pipe',\n   116→      timeout: 30_000,\n   117→      cwd: dir ?? process.cwd(),\n   118→    });\n   119→  } catch (err) {\n   120→    const message = err instanceof Error ? err.message : String(err);\n   121→    throw new BeadsError(cmdStr, message);\n   122→  }\n   123→}\n   124→\n   125→export function detectBeadsHooks(dir?: string): BeadsHookDetection {\n   126→  const hooksDir = join(dir ?? process.cwd(), '.beads', 'hooks');\n   127→  if (!existsSync(hooksDir)) {\n   128→    return { hasHooks: false, hookTypes: [] };\n   129→  }\n   130→\n   131→  try {\n   132→    const entries = readdirSync(hooksDir);\n   133→    const hookTypes = entries.filter(e => !e.startsWith('.'));\n   134→    return {\n   135→      hasHooks: hookTypes.length > 0,\n   136→      hookTypes,\n   137→    };\n   138→  } catch {\n   139→    return { hasHooks: false, hookTypes: [] };\n   140→  }\n   141→}\n   142→\n   143→/**\n   144→ * Builds a gap-id tag string in the format `[gap:<category>:<identifier>]`.\n   145→ * Categories: coverage, docs, verification, bridge, test-failure.\n   146→ */\n   147→export function buildGapId(category: string, identifier: string): string {\n   148→  return `[gap:${category}:${identifier}]`;\n   149→}\n   150→\n   151→/**\n   152→ * Scans an array of beads issues and returns the first non-done issue\n   153→ * whose description contains the given gap-id tag.\n   154→ */\n   155→export function findExistingByGapId(gapId: string, issues: BeadsIssue[]): BeadsIssue | undefined {\n   156→  return issues.find(\n   157→    issue => issue.status !== 'done' && issue.description?.includes(gapId),\n   158→  );\n   159→}\n   160→\n   161→/**\n   162→ * Appends a gap-id tag to an existing description.\n   163→ * If description is empty/undefined, returns just the tag.\n   164→ * Uses newline separator.\n   165→ */\n   166→export function appendGapId(existingDescription: string | undefined, gapId: string): string {\n   167→  if (!existingDescription) {\n   168→    return gapId;\n   169→  }\n   170→  return `${existingDescription}\\n${gapId}`;\n   171→}\n   172→\n   173→/**\n   174→ * Creates a new beads issue or finds an existing one by gap-id.\n   175→ * Returns the issue and whether it was newly created.\n   176→ */\n   177→export function createOrFindIssue(\n   178→  title: string,\n   179→  gapId: string,\n   180→  opts?: BeadsCreateOpts,\n   181→): { issue: BeadsIssue; created: boolean } {\n   182→  const issues = listIssues();\n   183→  const existing = findExistingByGapId(gapId, issues);\n   184→  if (existing) {\n   185→    return { issue: existing, created: false };\n   186→  }\n   187→  const issue = createIssue(title, {\n   188→    ...opts,\n   189→    description: appendGapId(opts?.description, gapId),\n   190→  });\n   191→  return { issue, created: true };\n   192→}\n   193→\n   194→export function configureHookCoexistence(dir?: string): void {\n   195→  const detection = detectBeadsHooks(dir);\n   196→  if (!detection.hasHooks) {\n   197→    return;\n   198→  }\n   199→\n   200→  // Check if there are existing git hooks that might conflict\n   201→  const gitHooksDir = join(dir ?? process.cwd(), '.git', 'hooks');\n   202→  if (!existsSync(gitHooksDir)) {\n   203→    return;\n   204→  }\n   205→\n   206→  // For now, detection and logging is the priority.\n   207→  // The actual chaining mechanism is a stretch goal per story notes.\n   208→  // The init command handles the logging via output utilities.\n   209→}\n   210→"}]},"parent_tool_use_id":"toolu_01KNQnUKBFtzFzrosUg6K7qd","session_id":"7d2c764f-deb1-4354-ad31-e0a846d19ae3","uuid":"9a90781c-99e4-4fcf-b9dc-474014675c61","timestamp":"2026-03-25T00:16:57.831Z"}
