{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XNBJ3jM9JWkPS35sxouoDQ","type":"tool_result","content":"     1→/**\n     2→ * Standalone runtime validator — validates telemetry outside Docker verification.\n     3→ *\n     4→ * Implements Story 2.3: runs `npm test` with OTLP enabled, queries the\n     5→ * observability backend for telemetry events, and reports per-module coverage.\n     6→ * Results are persisted to sprint-state.json under `observability.runtime`.\n     7→ */\n     8→\n     9→import { execSync } from 'node:child_process';\n    10→import { readdirSync, statSync } from 'node:fs';\n    11→import { join } from 'node:path';\n    12→import { ok, fail } from '../../types/result.js';\n    13→import type { Result } from '../../types/result.js';\n    14→import type {\n    15→  RuntimeValidationConfig,\n    16→  RuntimeValidationResult,\n    17→  ModuleTelemetryEntry,\n    18→  TelemetryEvent,\n    19→} from './types.js';\n    20→\n    21→const DEFAULT_CONFIG: RuntimeValidationConfig = {\n    22→  testCommand: 'npm test',\n    23→  otlpEndpoint: 'http://localhost:4318',\n    24→  queryEndpoint: 'http://localhost:9428',\n    25→  timeoutMs: 120_000,\n    26→};\n    27→\n    28→const HEALTH_TIMEOUT_MS = 3_000;\n    29→\n    30→/**\n    31→ * Validate runtime observability by running tests with OTLP and querying the backend.\n    32→ *\n    33→ * 1. Checks backend health; returns skipped result if unreachable.\n    34→ * 2. Records start timestamp, spawns test command with OTEL env var.\n    35→ * 3. Queries backend for telemetry events in the test window.\n    36→ * 4. Maps events to project modules and computes coverage.\n    37→ */\n    38→export async function validateRuntime(\n    39→  projectDir: string,\n    40→  config?: Partial<RuntimeValidationConfig>,\n    41→): Promise<Result<RuntimeValidationResult>> {\n    42→  if (!projectDir || typeof projectDir !== 'string') {\n    43→    return fail('projectDir is required and must be a non-empty string');\n    44→  }\n    45→\n    46→  const cfg: RuntimeValidationConfig = { ...DEFAULT_CONFIG, ...config };\n    47→\n    48→  // Step 1: Check backend health\n    49→  const healthy = await checkBackendHealth(cfg.queryEndpoint);\n    50→  if (!healthy) {\n    51→    const modules = discoverModules(projectDir);\n    52→    const entries: ModuleTelemetryEntry[] = modules.map((m) => ({\n    53→      moduleName: m,\n    54→      telemetryDetected: false,\n    55→      eventCount: 0,\n    56→    }));\n    57→    return ok({\n    58→      entries,\n    59→      totalModules: modules.length,\n    60→      modulesWithTelemetry: 0,\n    61→      coveragePercent: 0,\n    62→      skipped: true,\n    63→      skipReason: 'runtime validation skipped -- observability stack not available',\n    64→    });\n    65→  }\n    66→\n    67→  // Step 2: Record start time and run tests\n    68→  const startTime = new Date().toISOString();\n    69→  try {\n    70→    execSync(cfg.testCommand, {\n    71→      cwd: projectDir,\n    72→      timeout: cfg.timeoutMs,\n    73→      env: {\n    74→        ...process.env,\n    75→        OTEL_EXPORTER_OTLP_ENDPOINT: cfg.otlpEndpoint,\n    76→      },\n    77→      stdio: 'pipe',\n    78→    });\n    79→  } catch (err: unknown) {\n    80→    const msg = err instanceof Error ? err.message : String(err);\n    81→    return fail(`Test command failed: ${msg}`);\n    82→  }\n    83→  const endTime = new Date().toISOString();\n    84→\n    85→  // Step 3: Query telemetry events\n    86→  const eventsResult = await queryTelemetryEvents(cfg.queryEndpoint, startTime, endTime);\n    87→  if (!eventsResult.success) {\n    88→    return fail(eventsResult.error);\n    89→  }\n    90→\n    91→  // Step 4: Map events to modules and compute coverage\n    92→  const modules = discoverModules(projectDir);\n    93→  const entries = mapEventsToModules(eventsResult.data, projectDir, modules);\n    94→  const modulesWithTelemetry = entries.filter((e) => e.telemetryDetected).length;\n    95→  const totalModules = entries.length;\n    96→  const coveragePercent = totalModules === 0 ? 0 : (modulesWithTelemetry / totalModules) * 100;\n    97→\n    98→  return ok({\n    99→    entries,\n   100→    totalModules,\n   101→    modulesWithTelemetry,\n   102→    coveragePercent,\n   103→    skipped: false,\n   104→  });\n   105→}\n   106→\n   107→/**\n   108→ * Check if the observability backend is reachable.\n   109→ * Returns true if the health endpoint responds with 2xx within 3 seconds.\n   110→ */\n   111→export async function checkBackendHealth(queryEndpoint: string): Promise<boolean> {\n   112→  try {\n   113→    const response = await fetch(`${queryEndpoint}/health`, {\n   114→      signal: AbortSignal.timeout(HEALTH_TIMEOUT_MS),\n   115→    });\n   116→    return response.ok;\n   117→  } catch {\n   118→    return false;\n   119→  }\n   120→}\n   121→\n   122→/**\n   123→ * Query VictoriaLogs for telemetry events within a time window.\n   124→ */\n   125→export async function queryTelemetryEvents(\n   126→  queryEndpoint: string,\n   127→  startTime: string,\n   128→  endTime: string,\n   129→): Promise<Result<TelemetryEvent[]>> {\n   130→  const url = new URL('/select/logsql/query', queryEndpoint);\n   131→  url.searchParams.set('query', '_stream_id:*');\n   132→  url.searchParams.set('start', startTime);\n   133→  url.searchParams.set('end', endTime);\n   134→  url.searchParams.set('limit', '1000');\n   135→\n   136→  try {\n   137→    const response = await fetch(url.toString(), {\n   138→      signal: AbortSignal.timeout(HEALTH_TIMEOUT_MS),\n   139→    });\n   140→    if (!response.ok) {\n   141→      return fail(`VictoriaLogs returned ${response.status}`);\n   142→    }\n   143→    const text = await response.text();\n   144→    const events = parseLogEvents(text);\n   145→    return ok(events);\n   146→  } catch (err: unknown) {\n   147→    const msg = err instanceof Error ? err.message : String(err);\n   148→    return fail(`Failed to query telemetry events: ${msg}`);\n   149→  }\n   150→}\n   151→\n   152→/**\n   153→ * Map telemetry events to project modules by matching source paths.\n   154→ */\n   155→export function mapEventsToModules(\n   156→  events: TelemetryEvent[],\n   157→  _projectDir: string,\n   158→  modules?: string[],\n   159→): ModuleTelemetryEntry[] {\n   160→  const moduleList = modules ?? [];\n   161→  const moduleCounts = new Map<string, number>();\n   162→  for (const mod of moduleList) {\n   163→    moduleCounts.set(mod, 0);\n   164→  }\n   165→\n   166→  for (const event of events) {\n   167→    for (const mod of moduleList) {\n   168→      if (event.source.includes(mod) || event.message.includes(mod)) {\n   169→        moduleCounts.set(mod, (moduleCounts.get(mod) ?? 0) + 1);\n   170→      }\n   171→    }\n   172→  }\n   173→\n   174→  return moduleList.map((mod) => {\n   175→    const count = moduleCounts.get(mod) ?? 0;\n   176→    return {\n   177→      moduleName: mod,\n   178→      telemetryDetected: count > 0,\n   179→      eventCount: count,\n   180→    };\n   181→  });\n   182→}\n   183→\n   184→/** Discover top-level module directories under src/ */\n   185→function discoverModules(projectDir: string): string[] {\n   186→  const srcDir = join(projectDir, 'src');\n   187→  try {\n   188→    return readdirSync(srcDir).filter((name) => {\n   189→      try {\n   190→        return statSync(join(srcDir, name)).isDirectory();\n   191→      } catch {\n   192→        return false;\n   193→      }\n   194→    });\n   195→  } catch {\n   196→    return [];\n   197→  }\n   198→}\n   199→\n   200→/** Parse newline-delimited JSON from VictoriaLogs into TelemetryEvent[] */\n   201→function parseLogEvents(text: string): TelemetryEvent[] {\n   202→  if (!text.trim()) return [];\n   203→  const lines = text.trim().split('\\n');\n   204→  const events: TelemetryEvent[] = [];\n   205→  for (const line of lines) {\n   206→    try {\n   207→      const raw = JSON.parse(line) as Record<string, unknown>;\n   208→      events.push({\n   209→        timestamp: String(raw._time ?? raw.timestamp ?? ''),\n   210→        message: String(raw._msg ?? raw.message ?? ''),\n   211→        source: String(raw.source ?? raw._source ?? raw.service ?? ''),\n   212→      });\n   213→    } catch {\n   214→      // skip malformed lines\n   215→    }\n   216→  }\n   217→  return events;\n   218→}\n   219→"}]},"parent_tool_use_id":"toolu_014QEC8wgRDzeoWECp9trCxd","session_id":"c5eaf6a6-ac7c-4707-b82c-6220d711aa9c","uuid":"a5f669f5-dbdf-4c3e-b59b-c49789636921","timestamp":"2026-03-20T06:39:08.840Z"}
