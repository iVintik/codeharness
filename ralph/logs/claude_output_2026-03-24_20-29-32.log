{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XeoLqaYtCkredX32Vbf9GN","type":"tool_result","content":"     1→import { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n     2→import { join, dirname } from 'node:path';\n     3→import { StringDecoder } from 'node:string_decoder';\n     4→import { Command } from 'commander';\n     5→import { fail, info, jsonOutput } from '../lib/output.js';\n     6→import { readSprintStatusFromState, reconcileState } from '../modules/sprint/index.js';\n     7→import { generateRalphPrompt } from '../lib/agents/ralph-prompt.js';\n     8→import { startRenderer, type SprintInfo } from '../lib/ink-renderer.js';\n     9→import { getSprintState } from '../modules/sprint/index.js';\n    10→import { formatElapsed, mapSprintStatuses, countStories } from '../lib/run-helpers.js';\n    11→import { getDriver } from '../lib/agents/index.js';\n    12→import type { AgentDriver, AgentEvent } from '../lib/agents/types.js';\n    13→import type { RendererHandle } from '../lib/ink-renderer.js';\n    14→\n    15→/** Resolves the plugin directory path (.claude/ in project root). */\n    16→export function resolvePluginDir(): string {\n    17→  return join(process.cwd(), '.claude');\n    18→}\n    19→\n    20→// Re-export helpers that tests import from run.ts\n    21→export { countStories } from '../lib/run-helpers.js';\n    22→\n    23→/** Dispatches an AgentEvent to the appropriate renderer method. */\n    24→function handleAgentEvent(\n    25→  event: AgentEvent,\n    26→  rendererHandle: RendererHandle,\n    27→  state: { currentIterationCount: number },\n    28→): void {\n    29→  switch (event.type) {\n    30→    case 'tool-start':\n    31→    case 'tool-complete':\n    32→    case 'text':\n    33→    case 'result':\n    34→    case 'retry':\n    35→      // These AgentEvent types match StreamEvent shapes — pass through to renderer\n    36→      rendererHandle.update(event as Parameters<RendererHandle['update']>[0]);\n    37→      break;\n    38→    case 'story-complete':\n    39→      rendererHandle.addMessage({ type: 'ok', key: event.key, message: event.details });\n    40→      break;\n    41→    case 'story-failed':\n    42→      rendererHandle.addMessage({ type: 'fail', key: event.key, message: event.reason });\n    43→      break;\n    44→    case 'iteration':\n    45→      state.currentIterationCount = event.count;\n    46→      break;\n    47→  }\n    48→}\n    49→\n    50→/** Line splitter: buffers partial lines, calls driver.parseOutput(), dispatches via handleAgentEvent(). */\n    51→function createDriverLineHandler(\n    52→  driver: AgentDriver,\n    53→  rendererHandle: RendererHandle,\n    54→  state: { currentIterationCount: number },\n    55→): (data: Buffer) => void {\n    56→  let partial = '';\n    57→  const decoder = new StringDecoder('utf8');\n    58→  return (data: Buffer): void => {\n    59→    const text = partial + decoder.write(data);\n    60→    const parts = text.split('\\n');\n    61→    partial = parts.pop() ?? '';\n    62→    for (const line of parts) {\n    63→      if (line.trim().length === 0) continue;\n    64→      const event = driver.parseOutput(line);\n    65→      if (event) {\n    66→        handleAgentEvent(event, rendererHandle, state);\n    67→      }\n    68→    }\n    69→  };\n    70→}\n    71→\n    72→export function registerRunCommand(program: Command): void {\n    73→  program\n    74→    .command('run')\n    75→    .description('Execute the autonomous coding loop')\n    76→    .option('--max-iterations <n>', 'Maximum loop iterations', '50')\n    77→    .option('--timeout <seconds>', 'Total loop timeout in seconds', '43200')\n    78→    .option('--iteration-timeout <minutes>', 'Per-iteration timeout in minutes', '30')\n    79→    .option('--quiet', 'Suppress terminal output (background mode)', false)\n    80→    .option('--calls <n>', 'Max API calls per hour', '100')\n    81→    .option('--max-story-retries <n>', 'Max retries per story before flagging', '10')\n    82→    .option('--reset', 'Clear retry counters, flagged stories, and circuit breaker before starting', false)\n    83→    .action(async (options, cmd) => {\n    84→      const globalOpts = cmd.optsWithGlobals();\n    85→      const isJson = !!globalOpts.json;\n    86→      const outputOpts = { json: isJson };\n    87→\n    88→      // 1. Resolve plugin directory\n    89→      const pluginDir = resolvePluginDir();\n    90→      if (!existsSync(pluginDir)) {\n    91→        fail('Plugin directory not found — run codeharness init first', outputOpts);\n    92→        process.exitCode = 1;\n    93→        return;\n    94→      }\n    95→\n    96→      // 1b. Reconcile state (best-effort — failures warn but don't abort)\n    97→      const reconciliation = reconcileState();\n    98→      if (reconciliation.success && reconciliation.data.corrections.length > 0) {\n    99→        for (const correction of reconciliation.data.corrections) {\n   100→          info(`[INFO] Reconciled: ${correction}`, outputOpts);\n   101→        }\n   102→      } else if (!reconciliation.success) {\n   103→        info(`[WARN] State reconciliation failed: ${reconciliation.error}`, outputOpts);\n   104→      }\n   105→\n   106→      // 2. Read sprint status for story count (from sprint-state.json)\n   107→      const projectDir = process.cwd();\n   108→      const sprintStatusPath = join(projectDir, '_bmad-output', 'implementation-artifacts', 'sprint-status.yaml');\n   109→      const statuses = readSprintStatusFromState();\n   110→      const counts = countStories(statuses);\n   111→\n   112→      if (counts.total === 0) {\n   113→        fail('No stories found in sprint-state.json — nothing to execute', outputOpts);\n   114→        process.exitCode = 1;\n   115→        return;\n   116→      }\n   117→\n   118→      info(`Starting autonomous execution — ${counts.ready} ready, ${counts.inProgress} in progress, ${counts.verified} verified, ${counts.done}/${counts.total} done`, outputOpts);\n   119→\n   120→      // 3. Parse and validate numeric options\n   121→      const maxIterations = parseInt(options.maxIterations, 10);\n   122→      const timeout = parseInt(options.timeout, 10);\n   123→      const iterationTimeout = parseInt(options.iterationTimeout, 10);\n   124→      const calls = parseInt(options.calls, 10);\n   125→      const maxStoryRetries = parseInt(options.maxStoryRetries, 10);\n   126→\n   127→      if (isNaN(maxIterations) || isNaN(timeout) || isNaN(iterationTimeout) || isNaN(calls) || isNaN(maxStoryRetries)) {\n   128→        fail('Invalid numeric option — --max-iterations, --timeout, --iteration-timeout, --calls, and --max-story-retries must be numbers', outputOpts);\n   129→        process.exitCode = 1;\n   130→        return;\n   131→      }\n   132→\n   133→      // 4. Generate prompt file (with flagged stories context if available)\n   134→      const promptFile = join(projectDir, 'ralph', '.harness-prompt.md');\n   135→      let flaggedStories: string[] | undefined;\n   136→      const flaggedState = getSprintState();\n   137→      if (flaggedState.success && flaggedState.data.flagged?.length > 0) {\n   138→        flaggedStories = flaggedState.data.flagged;\n   139→      }\n   140→      const promptContent = generateRalphPrompt({\n   141→        projectDir,\n   142→        sprintStatusPath,\n   143→        flaggedStories,\n   144→      });\n   145→      try {\n   146→        mkdirSync(dirname(promptFile), { recursive: true });\n   147→        writeFileSync(promptFile, promptContent, 'utf-8');\n   148→      } catch (err) {\n   149→        const message = err instanceof Error ? err.message : String(err);\n   150→        fail(`Failed to write prompt file: ${message}`, outputOpts);\n   151→        process.exitCode = 1;\n   152→        return;\n   153→      }\n   154→\n   155→      // 5. Create driver with ralph-specific configuration\n   156→      const quiet = options.quiet;\n   157→      const driver = getDriver('ralph', {\n   158→        pluginDir,\n   159→        maxIterations,\n   160→        iterationTimeout,\n   161→        calls,\n   162→        quiet,\n   163→        maxStoryRetries,\n   164→        reset: options.reset,\n   165→      });\n   166→\n   167→      // 6. Set environment — stream-json is always the output format\n   168→      const env: Record<string, string> = {};\n   169→      if (isJson) {\n   170→        env.CLAUDE_OUTPUT_FORMAT = 'stream-json';\n   171→      }\n   172→\n   173→      // 7. Spawn agent — pipe stdout/stderr through driver.parseOutput() → Ink renderer\n   174→      const rendererHandle = startRenderer({ quiet });\n   175→      let sprintStateInterval: ReturnType<typeof setInterval> | null = null;\n   176→      const sessionStartTime = Date.now();\n   177→      const eventState = { currentIterationCount: 0 };\n   178→\n   179→      try {\n   180→        // Read initial sprint state for the renderer header\n   181→        const initialState = getSprintState();\n   182→        if (initialState.success) {\n   183→          const s = initialState.data;\n   184→          const sprintInfo: SprintInfo = {\n   185→            storyKey: s.run.currentStory ?? '',\n   186→            phase: s.run.currentPhase ?? '',\n   187→            done: s.sprint.done,\n   188→            total: s.sprint.total,\n   189→            elapsed: formatElapsed(Date.now() - sessionStartTime),\n   190→            iterationCount: eventState.currentIterationCount,\n   191→          };\n   192→          rendererHandle.updateSprintState(sprintInfo);\n   193→        }\n   194→\n   195→        // Feed initial per-story statuses to the renderer\n   196→        const initialStatuses = readSprintStatusFromState();\n   197→        const initialStories = mapSprintStatuses(initialStatuses);\n   198→        if (initialStories.length > 0) {\n   199→          rendererHandle.updateStories(initialStories);\n   200→        }\n   201→\n   202→        const child = driver.spawn({\n   203→          storyKey: '',\n   204→          prompt: promptFile,\n   205→          workDir: projectDir,\n   206→          timeout,\n   207→          env,\n   208→        });\n   209→\n   210→        if (!quiet && child.stdout && child.stderr) {\n   211→          const lineHandler = createDriverLineHandler(driver, rendererHandle, eventState);\n   212→          child.stdout.on('data', lineHandler);\n   213→          child.stderr.on('data', lineHandler);\n   214→\n   215→          // Periodically refresh sprint state for the header display\n   216→          sprintStateInterval = setInterval(() => {\n   217→            try {\n   218→              const stateResult = getSprintState();\n   219→              if (stateResult.success) {\n   220→                const s = stateResult.data;\n   221→                const sprintInfo: SprintInfo = {\n   222→                  storyKey: s.run.currentStory ?? '',\n   223→                  phase: s.run.currentPhase ?? '',\n   224→                  done: s.sprint.done,\n   225→                  total: s.sprint.total,\n   226→                  elapsed: formatElapsed(Date.now() - sessionStartTime),\n   227→                  iterationCount: eventState.currentIterationCount,\n   228→                };\n   229→                rendererHandle.updateSprintState(sprintInfo);\n   230→              }\n   231→              // Refresh per-story statuses\n   232→              const currentStatuses = readSprintStatusFromState();\n   233→              const storyEntries = mapSprintStatuses(currentStatuses);\n   234→              rendererHandle.updateStories(storyEntries);\n   235→            } catch {\n   236→              // Ignore read errors during polling\n   237→            }\n   238→          }, 5_000);\n   239→        }\n   240→\n   241→        const exitCode = await new Promise<number>((resolve, reject) => {\n   242→          child.on('error', (err) => {\n   243→            if (sprintStateInterval) clearInterval(sprintStateInterval);\n   244→            rendererHandle.cleanup();\n   245→            reject(err);\n   246→          });\n   247→          child.on('close', (code) => {\n   248→            if (sprintStateInterval) clearInterval(sprintStateInterval);\n   249→            rendererHandle.cleanup();\n   250→            resolve(code ?? 1);\n   251→          });\n   252→        });\n   253→\n   254→        // 8. Handle JSON output on exit\n   255→        if (isJson) {\n   256→          const statusFile = join(projectDir, driver.getStatusFile());\n   257→          let statusData: Record<string, unknown> | null = null;\n   258→          let exitReason = 'status_file_missing';\n   259→          if (existsSync(statusFile)) {\n   260→            try {\n   261→              statusData = JSON.parse(readFileSync(statusFile, 'utf-8'));\n   262→              exitReason = '';\n   263→            } catch { exitReason = 'status_file_unreadable'; }\n   264→          }\n   265→          const fc = statusData ? countStories(readSprintStatusFromState()) : counts;\n   266→          jsonOutput({\n   267→            status: statusData?.status ?? (exitCode === 0 ? 'completed' : 'stopped'),\n   268→            iterations: (statusData?.loop_count as number) ?? 0,\n   269→            storiesCompleted: statusData ? fc.done : 0,\n   270→            storiesTotal: fc.total,\n   271→            storiesRemaining: statusData ? fc.total - fc.done : fc.total,\n   272→            elapsedSeconds: (statusData?.elapsed_seconds as number) ?? 0,\n   273→            flaggedStories: (statusData?.flagged_stories as string[]) ?? [],\n   274→            exitReason: (statusData?.exit_reason as string) ?? exitReason,\n   275→          });\n   276→        }\n   277→\n   278→        process.exitCode = exitCode;\n   279→      } catch (err) {\n   280→        if (sprintStateInterval) clearInterval(sprintStateInterval);\n   281→        rendererHandle.cleanup();\n   282→        const message = err instanceof Error ? err.message : String(err);\n   283→        fail(`Failed to start Ralph: ${message}`, outputOpts);\n   284→        process.exitCode = 1;\n   285→      }\n   286→    });\n   287→}\n   288→"}]},"parent_tool_use_id":"toolu_01AeYymucNLjmuqL83DiV485","session_id":"a5a043ae-cfd1-4d51-82dd-d0069edc63ef","uuid":"cc48812d-4951-4b0e-8b3f-63a99471dcc1","timestamp":"2026-03-24T16:30:22.704Z"}
