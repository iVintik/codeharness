{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PzzKX8w6orzrV9smapfBwE","type":"tool_result","content":"     1→/**\n     2→ * Dockerfile validator — checks Dockerfiles against 6 required rule categories.\n     3→ * Returns structured gaps for audit integration.\n     4→ *\n     5→ * FR23 (formalized Dockerfile rules), FR24 (audit validates against rules).\n     6→ */\n     7→\n     8→import { existsSync, readFileSync } from 'node:fs';\n     9→import { join } from 'node:path';\n    10→import { ok, fail } from '../../types/result.js';\n    11→import type { Result } from '../../types/result.js';\n    12→\n    13→/** A single gap found during Dockerfile validation */\n    14→export interface DockerfileGap {\n    15→  readonly rule: string;\n    16→  readonly description: string;\n    17→  readonly suggestedFix: string;\n    18→  readonly line?: number;\n    19→}\n    20→\n    21→/** Result of validating a Dockerfile against all rules */\n    22→export interface DockerfileValidationResult {\n    23→  readonly passed: boolean;\n    24→  readonly gaps: DockerfileGap[];\n    25→  readonly warnings: string[];\n    26→}\n    27→\n    28→/** Internal rules structure */\n    29→interface DockerfileRules {\n    30→  readonly requirePinnedFrom: boolean;\n    31→  readonly requireBinaryOnPath: boolean;\n    32→  readonly verificationTools: string[];\n    33→  readonly forbidSourceCopy: boolean;\n    34→  readonly requireNonRootUser: boolean;\n    35→  readonly requireCacheCleanup: boolean;\n    36→}\n    37→\n    38→const DEFAULT_RULES: DockerfileRules = {\n    39→  requirePinnedFrom: true,\n    40→  requireBinaryOnPath: true,\n    41→  verificationTools: ['curl', 'jq'],\n    42→  forbidSourceCopy: true,\n    43→  requireNonRootUser: true,\n    44→  requireCacheCleanup: true,\n    45→};\n    46→\n    47→function dfGap(rule: string, description: string, suggestedFix: string, line?: number): DockerfileGap {\n    48→  const g: DockerfileGap = { rule, description, suggestedFix };\n    49→  if (line !== undefined) return { ...g, line };\n    50→  return g;\n    51→}\n    52→\n    53→/**\n    54→ * Load rules from patches/infra/dockerfile-rules.md or fall back to defaults.\n    55→ * The markdown is documentation — the actual rules are hardcoded defaults.\n    56→ * Returns rules + any warnings about missing file.\n    57→ */\n    58→export function loadRules(projectDir: string): { rules: DockerfileRules; warnings: string[] } {\n    59→  const rulesPath = join(projectDir, 'patches', 'infra', 'dockerfile-rules.md');\n    60→  if (!existsSync(rulesPath)) {\n    61→    return {\n    62→      rules: DEFAULT_RULES,\n    63→      warnings: ['dockerfile-rules.md not found -- using defaults.'],\n    64→    };\n    65→  }\n    66→  return { rules: DEFAULT_RULES, warnings: [] };\n    67→}\n    68→\n    69→// ─── Rule checkers ──────────────────────────────────────────────────────────\n    70→\n    71→function checkPinnedFrom(lines: string[]): DockerfileGap[] {\n    72→  const gaps: DockerfileGap[] = [];\n    73→  for (let i = 0; i < lines.length; i++) {\n    74→    if (!/^\\s*FROM\\s+/i.test(lines[i])) continue;\n    75→    const ref = lines[i].replace(/^\\s*FROM\\s+/i, '').split(/\\s+/)[0];\n    76→    if (ref.endsWith(':latest')) {\n    77→      gaps.push(dfGap('pinned-from', `unpinned base image -- use specific version.`, `Pin ${ref} to a specific version tag`, i + 1));\n    78→    } else if (!ref.includes(':') && !ref.includes('@')) {\n    79→      gaps.push(dfGap('pinned-from', `unpinned base image -- use specific version.`, `Pin ${ref} to a specific version tag (e.g., ${ref}:22-slim)`, i + 1));\n    80→    }\n    81→  }\n    82→  return gaps;\n    83→}\n    84→\n    85→function checkBinaryOnPath(lines: string[]): DockerfileGap[] {\n    86→  const content = lines.join('\\n');\n    87→  const hasBinary =\n    88→    /npm\\s+install\\s+(-g|--global)\\b/i.test(content) ||\n    89→    /pip\\s+install\\b/i.test(content) ||\n    90→    /COPY\\s+--from=/i.test(content);\n    91→  if (!hasBinary) {\n    92→    return [dfGap('binary-on-path', 'project binary not installed.', 'Add npm install -g, pip install, or COPY --from to install the project binary')];\n    93→  }\n    94→  return [];\n    95→}\n    96→\n    97→function checkVerificationTools(lines: string[], tools: string[]): DockerfileGap[] {\n    98→  const gaps: DockerfileGap[] = [];\n    99→  for (const tool of tools) {\n   100→    let found = false;\n   101→    for (const line of lines) {\n   102→      const lower = line.toLowerCase();\n   103→      const isInstallLine = lower.includes('apt-get install') || lower.includes('apk add');\n   104→      if (isInstallLine && new RegExp(`\\\\b${tool.toLowerCase()}\\\\b`).test(lower)) {\n   105→        found = true;\n   106→        break;\n   107→      }\n   108→    }\n   109→    if (!found) {\n   110→      gaps.push(dfGap('verification-tools', `verification tool missing: ${tool}`, `Install ${tool} via apt-get install or apk add`));\n   111→    }\n   112→  }\n   113→  return gaps;\n   114→}\n   115→\n   116→function checkNoSourceCopy(lines: string[]): DockerfileGap[] {\n   117→  const gaps: DockerfileGap[] = [];\n   118→  const sourcePatterns = [/COPY\\s+(?:--\\S+\\s+)*src\\//i, /COPY\\s+(?:--\\S+\\s+)*lib\\//i, /COPY\\s+(?:--\\S+\\s+)*test\\//i];\n   119→  for (let i = 0; i < lines.length; i++) {\n   120→    for (const pattern of sourcePatterns) {\n   121→      if (pattern.test(lines[i])) {\n   122→        gaps.push(dfGap('no-source-copy', 'source code copied into container -- use build artifact instead.', 'Use COPY --from=builder or COPY dist/ instead of copying source', i + 1));\n   123→      }\n   124→    }\n   125→  }\n   126→  return gaps;\n   127→}\n   128→\n   129→function checkNonRootUser(lines: string[]): DockerfileGap[] {\n   130→  const userLines = lines.filter(l => /^\\s*USER\\s+/i.test(l));\n   131→  if (userLines.length === 0) {\n   132→    return [dfGap('non-root-user', 'no non-root USER instruction found.', 'Add USER <non-root-user> instruction (e.g., USER node)')];\n   133→  }\n   134→  const hasNonRoot = userLines.some(l => {\n   135→    const user = l.replace(/^\\s*USER\\s+/i, '').trim().split(/\\s+/)[0];\n   136→    return user.toLowerCase() !== 'root';\n   137→  });\n   138→  if (!hasNonRoot) {\n   139→    return [dfGap('non-root-user', 'no non-root USER instruction found.', 'Add USER <non-root-user> instruction (e.g., USER node)')];\n   140→  }\n   141→  return [];\n   142→}\n   143→\n   144→function checkCacheCleanup(lines: string[]): DockerfileGap[] {\n   145→  const content = lines.join('\\n');\n   146→  const hasCleanup =\n   147→    /rm\\s+-rf\\s+\\/var\\/lib\\/apt\\/lists/i.test(content) ||\n   148→    /rm\\s+-rf\\s+\\/var\\/cache\\/apk/i.test(content) ||\n   149→    /npm\\s+cache\\s+clean/i.test(content) ||\n   150→    /pip\\s+cache\\s+purge/i.test(content);\n   151→  if (!hasCleanup) {\n   152→    return [dfGap('cache-cleanup', 'no cache cleanup detected.', 'Add cache cleanup: rm -rf /var/lib/apt/lists/*, npm cache clean --force, or pip cache purge')];\n   153→  }\n   154→  return [];\n   155→}\n   156→\n   157→// ─── Main validator ─────────────────────────────────────────────────────────\n   158→\n   159→/**\n   160→ * Validate a Dockerfile against all 6 rule categories.\n   161→ * Returns Result<DockerfileValidationResult>.\n   162→ */\n   163→export function validateDockerfile(projectDir: string): Result<DockerfileValidationResult> {\n   164→  const dfPath = join(projectDir, 'Dockerfile');\n   165→\n   166→  if (!existsSync(dfPath)) {\n   167→    return fail('No Dockerfile found');\n   168→  }\n   169→\n   170→  let content: string;\n   171→  try {\n   172→    content = readFileSync(dfPath, 'utf-8');\n   173→  } catch {\n   174→    return fail('Dockerfile exists but could not be read');\n   175→  }\n   176→\n   177→  const lines = content.split('\\n');\n   178→  const fromLines = lines.filter(l => /^\\s*FROM\\s+/i.test(l));\n   179→  if (fromLines.length === 0) {\n   180→    return fail('Dockerfile has no FROM instruction');\n   181→  }\n   182→\n   183→  const { rules, warnings } = loadRules(projectDir);\n   184→  const gaps: DockerfileGap[] = [];\n   185→\n   186→  if (rules.requirePinnedFrom) gaps.push(...checkPinnedFrom(lines));\n   187→  if (rules.requireBinaryOnPath) gaps.push(...checkBinaryOnPath(lines));\n   188→  gaps.push(...checkVerificationTools(lines, rules.verificationTools));\n   189→  if (rules.forbidSourceCopy) gaps.push(...checkNoSourceCopy(lines));\n   190→  if (rules.requireNonRootUser) gaps.push(...checkNonRootUser(lines));\n   191→  if (rules.requireCacheCleanup) gaps.push(...checkCacheCleanup(lines));\n   192→\n   193→  return ok({\n   194→    passed: gaps.length === 0,\n   195→    gaps,\n   196→    warnings,\n   197→  });\n   198→}\n   199→"}]},"parent_tool_use_id":"toolu_01QPLvTF7hH7ZEy1LqPE8PcP","session_id":"daf25720-e009-4a3c-8a3c-df9d68d99484","uuid":"3bcc8d6d-aad0-4a71-bc68-3d7a069013fc","timestamp":"2026-03-23T06:48:08.017Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PUB45fbW9hg5DwmeLhYE8D","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→\n     3→vi.mock('node:fs', () => ({\n     4→  existsSync: vi.fn(),\n     5→  writeFileSync: vi.fn(),\n     6→  readFileSync: vi.fn(),\n     7→}));\n     8→\n     9→import { existsSync, writeFileSync, readFileSync } from 'node:fs';\n    10→import { join } from 'node:path';\n    11→import { generateDockerfileTemplate } from '../dockerfile-template.js';\n    12→import { validateDockerfile } from '../dockerfile-validator.js';\n    13→\n    14→const mockExistsSync = vi.mocked(existsSync);\n    15→const mockWriteFileSync = vi.mocked(writeFileSync);\n    16→\n    17→beforeEach(() => {\n    18→  vi.resetAllMocks();\n    19→});\n    20→\n    21→// ─── Node.js template ───────────────────────────────────────────────────────\n    22→\n    23→describe('generateDockerfileTemplate — nodejs', () => {\n    24→  it('generates Dockerfile with pinned FROM node:22-slim', () => {\n    25→    mockExistsSync.mockReturnValue(false);\n    26→\n    27→    const r = generateDockerfileTemplate('/project', 'nodejs');\n    28→    expect(r.success).toBe(true);\n    29→    if (r.success) {\n    30→      expect(r.data.path).toBe(join('/project', 'Dockerfile'));\n    31→      expect(r.data.stack).toBe('nodejs');\n    32→    }\n    33→\n    34→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    35→    expect(written).toContain('FROM node:22-slim');\n    36→  });\n    37→\n    38→  it('includes npm install -g for binary installation', () => {\n    39→    mockExistsSync.mockReturnValue(false);\n    40→    generateDockerfileTemplate('/project', 'nodejs');\n    41→\n    42→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    43→    expect(written).toContain('npm install -g');\n    44→  });\n    45→\n    46→  it('includes curl and jq verification tools', () => {\n    47→    mockExistsSync.mockReturnValue(false);\n    48→    generateDockerfileTemplate('/project', 'nodejs');\n    49→\n    50→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    51→    expect(written).toContain('curl');\n    52→    expect(written).toContain('jq');\n    53→  });\n    54→\n    55→  it('includes USER node for non-root execution', () => {\n    56→    mockExistsSync.mockReturnValue(false);\n    57→    generateDockerfileTemplate('/project', 'nodejs');\n    58→\n    59→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    60→    expect(written).toContain('USER node');\n    61→  });\n    62→\n    63→  it('includes cache cleanup', () => {\n    64→    mockExistsSync.mockReturnValue(false);\n    65→    generateDockerfileTemplate('/project', 'nodejs');\n    66→\n    67→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    68→    expect(written).toContain('rm -rf /var/lib/apt/lists/*');\n    69→  });\n    70→\n    71→  it('includes inline section comments', () => {\n    72→    mockExistsSync.mockReturnValue(false);\n    73→    generateDockerfileTemplate('/project', 'nodejs');\n    74→\n    75→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    76→    expect(written).toContain('# Base image');\n    77→    expect(written).toContain('# System utilities');\n    78→    expect(written).toContain('# Install project');\n    79→    expect(written).toContain('# Run as non-root');\n    80→  });\n    81→});\n    82→\n    83→// ─── Python template ────────────────────────────────────────────────────────\n    84→\n    85→describe('generateDockerfileTemplate — python', () => {\n    86→  it('generates Dockerfile with pinned FROM python:3.12-slim', () => {\n    87→    mockExistsSync.mockReturnValue(false);\n    88→\n    89→    const r = generateDockerfileTemplate('/project', 'python');\n    90→    expect(r.success).toBe(true);\n    91→    if (r.success) {\n    92→      expect(r.data.path).toBe(join('/project', 'Dockerfile'));\n    93→      expect(r.data.stack).toBe('python');\n    94→    }\n    95→\n    96→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    97→    expect(written).toContain('FROM python:3.12-slim');\n    98→  });\n    99→\n   100→  it('includes pip install for binary installation', () => {\n   101→    mockExistsSync.mockReturnValue(false);\n   102→    generateDockerfileTemplate('/project', 'python');\n   103→\n   104→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   105→    expect(written).toContain('pip install');\n   106→  });\n   107→\n   108→  it('includes curl and jq verification tools', () => {\n   109→    mockExistsSync.mockReturnValue(false);\n   110→    generateDockerfileTemplate('/project', 'python');\n   111→\n   112→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   113→    expect(written).toContain('curl');\n   114→    expect(written).toContain('jq');\n   115→  });\n   116→\n   117→  it('includes USER nobody for non-root execution', () => {\n   118→    mockExistsSync.mockReturnValue(false);\n   119→    generateDockerfileTemplate('/project', 'python');\n   120→\n   121→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   122→    expect(written).toContain('USER nobody');\n   123→  });\n   124→\n   125→  it('includes cache cleanup (apt + pip)', () => {\n   126→    mockExistsSync.mockReturnValue(false);\n   127→    generateDockerfileTemplate('/project', 'python');\n   128→\n   129→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   130→    expect(written).toContain('rm -rf /var/lib/apt/lists/*');\n   131→    expect(written).toContain('pip cache purge');\n   132→  });\n   133→\n   134→  it('includes inline section comments', () => {\n   135→    mockExistsSync.mockReturnValue(false);\n   136→    generateDockerfileTemplate('/project', 'python');\n   137→\n   138→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   139→    expect(written).toContain('# Base image');\n   140→    expect(written).toContain('# System utilities');\n   141→    expect(written).toContain('# Install project');\n   142→    expect(written).toContain('# Run as non-root');\n   143→  });\n   144→});\n   145→\n   146→// ─── Generic template ───────────────────────────────────────────────────────\n   147→\n   148→describe('generateDockerfileTemplate — generic/null', () => {\n   149→  it('generates generic Dockerfile when stack is null', () => {\n   150→    mockExistsSync.mockReturnValue(false);\n   151→\n   152→    const r = generateDockerfileTemplate('/project', null);\n   153→    expect(r.success).toBe(true);\n   154→    if (r.success) {\n   155→      expect(r.data.stack).toBe('generic');\n   156→    }\n   157→\n   158→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   159→    expect(written).toContain('FROM node:22-slim');\n   160→    expect(written).toContain('bash');\n   161→    expect(written).toContain('git');\n   162→  });\n   163→\n   164→  it('generates generic Dockerfile when stack is unknown', () => {\n   165→    mockExistsSync.mockReturnValue(false);\n   166→\n   167→    const r = generateDockerfileTemplate('/project', 'java');\n   168→    expect(r.success).toBe(true);\n   169→    if (r.success) {\n   170→      expect(r.data.stack).toBe('generic');\n   171→    }\n   172→  });\n   173→\n   174→  it('includes curl and jq in generic template', () => {\n   175→    mockExistsSync.mockReturnValue(false);\n   176→    generateDockerfileTemplate('/project', null);\n   177→\n   178→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   179→    expect(written).toContain('curl');\n   180→    expect(written).toContain('jq');\n   181→  });\n   182→});\n   183→\n   184→// ─── Rust template ──────────────────────────────────────────────────────────\n   185→\n   186→describe('generateDockerfileTemplate — rust', () => {\n   187→  it('returns stack: rust and correct path', () => {\n   188→    mockExistsSync.mockReturnValue(false);\n   189→\n   190→    const r = generateDockerfileTemplate('/project', 'rust');\n   191→    expect(r.success).toBe(true);\n   192→    if (r.success) {\n   193→      expect(r.data.path).toBe(join('/project', 'Dockerfile'));\n   194→      expect(r.data.stack).toBe('rust');\n   195→    }\n   196→  });\n   197→\n   198→  it('contains FROM rust:1.82-slim AS builder and FROM debian:bookworm-slim', () => {\n   199→    mockExistsSync.mockReturnValue(false);\n   200→    generateDockerfileTemplate('/project', 'rust');\n   201→\n   202→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   203→    expect(written).toContain('FROM rust:1.82-slim AS builder');\n   204→    expect(written).toContain('FROM debian:bookworm-slim');\n   205→  });\n   206→\n   207→  it('includes cargo build --release in builder stage', () => {\n   208→    mockExistsSync.mockReturnValue(false);\n   209→    generateDockerfileTemplate('/project', 'rust');\n   210→\n   211→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   212→    expect(written).toContain('cargo build --release');\n   213→  });\n   214→\n   215→  it('includes COPY --from=builder to copy compiled binary', () => {\n   216→    mockExistsSync.mockReturnValue(false);\n   217→    generateDockerfileTemplate('/project', 'rust');\n   218→\n   219→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   220→    expect(written).toContain('COPY --from=builder');\n   221→  });\n   222→\n   223→  it('includes curl and jq verification tools', () => {\n   224→    mockExistsSync.mockReturnValue(false);\n   225→    generateDockerfileTemplate('/project', 'rust');\n   226→\n   227→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   228→    expect(written).toContain('curl');\n   229→    expect(written).toContain('jq');\n   230→  });\n   231→\n   232→  it('includes USER nobody for non-root execution', () => {\n   233→    mockExistsSync.mockReturnValue(false);\n   234→    generateDockerfileTemplate('/project', 'rust');\n   235→\n   236→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   237→    expect(written).toContain('USER nobody');\n   238→  });\n   239→\n   240→  it('includes apt cache cleanup', () => {\n   241→    mockExistsSync.mockReturnValue(false);\n   242→    generateDockerfileTemplate('/project', 'rust');\n   243→\n   244→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   245→    expect(written).toContain('rm -rf /var/lib/apt/lists/*');\n   246→  });\n   247→\n   248→  it('includes inline section comments', () => {\n   249→    mockExistsSync.mockReturnValue(false);\n   250→    generateDockerfileTemplate('/project', 'rust');\n   251→\n   252→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   253→    expect(written).toContain('# Build');\n   254→    expect(written).toContain('# System utilities');\n   255→    expect(written).toContain('# Install');\n   256→    expect(written).toContain('# Run as non-root');\n   257→  });\n   258→});\n   259→\n   260→// ─── Existing Dockerfile ────────────────────────────────────────────────────\n   261→\n   262→describe('generateDockerfileTemplate — existing Dockerfile', () => {\n   263→  it('returns fail when Dockerfile already exists', () => {\n   264→    mockExistsSync.mockReturnValue(true);\n   265→\n   266→    const r = generateDockerfileTemplate('/project', 'nodejs');\n   267→    expect(r.success).toBe(false);\n   268→    if (!r.success) {\n   269→      expect(r.error).toBe('Dockerfile already exists');\n   270→    }\n   271→  });\n   272→\n   273→  it('does not write any file when Dockerfile exists', () => {\n   274→    mockExistsSync.mockReturnValue(true);\n   275→\n   276→    generateDockerfileTemplate('/project', 'nodejs');\n   277→    expect(mockWriteFileSync).not.toHaveBeenCalled();\n   278→  });\n   279→});\n   280→\n   281→// ─── Error handling ─────────────────────────────────────────────────────────\n   282→\n   283→describe('generateDockerfileTemplate — error handling', () => {\n   284→  it('returns fail when projectDir is empty string', () => {\n   285→    const r = generateDockerfileTemplate('', 'nodejs');\n   286→    expect(r.success).toBe(false);\n   287→    if (!r.success) {\n   288→      expect(r.error).toBe('projectDir is required');\n   289→    }\n   290→  });\n   291→\n   292→  it('returns fail when writeFileSync throws', () => {\n   293→    mockExistsSync.mockReturnValue(false);\n   294→    mockWriteFileSync.mockImplementation(() => {\n   295→      throw new Error('EACCES: permission denied');\n   296→    });\n   297→\n   298→    const r = generateDockerfileTemplate('/project', 'nodejs');\n   299→    expect(r.success).toBe(false);\n   300→    if (!r.success) {\n   301→      expect(r.error).toContain('Failed to write Dockerfile');\n   302→      expect(r.error).toContain('EACCES');\n   303→    }\n   304→  });\n   305→\n   306→  it('returns fail with stringified error for non-Error throws', () => {\n   307→    mockExistsSync.mockReturnValue(false);\n   308→    mockWriteFileSync.mockImplementation(() => {\n   309→      throw 'disk full';\n   310→    });\n   311→\n   312→    const r = generateDockerfileTemplate('/project', 'nodejs');\n   313→    expect(r.success).toBe(false);\n   314→    if (!r.success) {\n   315→      expect(r.error).toContain('disk full');\n   316→    }\n   317→  });\n   318→});\n   319→\n   320→// ─── Result<T> return type ──────────────────────────────────────────────────\n   321→\n   322→describe('generateDockerfileTemplate — Result type', () => {\n   323→  it('returns Ok with path and stack on success', () => {\n   324→    mockExistsSync.mockReturnValue(false);\n   325→\n   326→    const r = generateDockerfileTemplate('/project', 'nodejs');\n   327→    expect(r.success).toBe(true);\n   328→    if (r.success) {\n   329→      expect(r.data).toHaveProperty('path');\n   330→      expect(r.data).toHaveProperty('stack');\n   331→      expect(typeof r.data.path).toBe('string');\n   332→      expect(typeof r.data.stack).toBe('string');\n   333→    }\n   334→  });\n   335→\n   336→  it('returns Fail with error string on failure', () => {\n   337→    mockExistsSync.mockReturnValue(true);\n   338→\n   339→    const r = generateDockerfileTemplate('/project', 'nodejs');\n   340→    expect(r.success).toBe(false);\n   341→    if (!r.success) {\n   342→      expect(typeof r.error).toBe('string');\n   343→    }\n   344→  });\n   345→});\n   346→\n   347→// ─── Validation compliance ──────────────────────────────────────────────────\n   348→\n   349→describe('generated Dockerfiles pass validateDockerfile()', () => {\n   350→  it('nodejs template passes all 6 rule categories', () => {\n   351→    mockExistsSync.mockReturnValue(false);\n   352→    generateDockerfileTemplate('/project', 'nodejs');\n   353→    const content = mockWriteFileSync.mock.calls[0][1] as string;\n   354→\n   355→    mockExistsSync.mockImplementation((p: unknown) => {\n   356→      const path = String(p);\n   357→      if (path.endsWith('Dockerfile')) return true;\n   358→      return false;\n   359→    });\n   360→    vi.mocked(readFileSync).mockReturnValue(content);\n   361→\n   362→    const r = validateDockerfile('/project');\n   363→    expect(r.success).toBe(true);\n   364→    if (r.success) {\n   365→      expect(r.data.passed).toBe(true);\n   366→      expect(r.data.gaps).toHaveLength(0);\n   367→    }\n   368→  });\n   369→\n   370→  it('python template passes all 6 rule categories', () => {\n   371→    mockExistsSync.mockReturnValue(false);\n   372→    generateDockerfileTemplate('/project', 'python');\n   373→    const content = mockWriteFileSync.mock.calls[0][1] as string;\n   374→\n   375→    mockExistsSync.mockImplementation((p: unknown) => {\n   376→      const path = String(p);\n   377→      if (path.endsWith('Dockerfile')) return true;\n   378→      return false;\n   379→    });\n   380→    vi.mocked(readFileSync).mockReturnValue(content);\n   381→\n   382→    const r = validateDockerfile('/project');\n   383→    expect(r.success).toBe(true);\n   384→    if (r.success) {\n   385→      expect(r.data.passed).toBe(true);\n   386→      expect(r.data.gaps).toHaveLength(0);\n   387→    }\n   388→  });\n   389→\n   390→  it('rust template passes all 6 rule categories', () => {\n   391→    mockExistsSync.mockReturnValue(false);\n   392→    generateDockerfileTemplate('/project', 'rust');\n   393→    const content = mockWriteFileSync.mock.calls[0][1] as string;\n   394→\n   395→    mockExistsSync.mockImplementation((p: unknown) => {\n   396→      const path = String(p);\n   397→      if (path.endsWith('Dockerfile')) return true;\n   398→      return false;\n   399→    });\n   400→    vi.mocked(readFileSync).mockReturnValue(content);\n   401→\n   402→    const r = validateDockerfile('/project');\n   403→    expect(r.success).toBe(true);\n   404→    if (r.success) {\n   405→      expect(r.data.passed).toBe(true);\n   406→      expect(r.data.gaps).toHaveLength(0);\n   407→    }\n   408→  });\n   409→\n   410→  it('generic template passes all 6 rule categories', () => {\n   411→    mockExistsSync.mockReturnValue(false);\n   412→    generateDockerfileTemplate('/project', null);\n   413→    const content = mockWriteFileSync.mock.calls[0][1] as string;\n   414→\n   415→    mockExistsSync.mockImplementation((p: unknown) => {\n   416→      const path = String(p);\n   417→      if (path.endsWith('Dockerfile')) return true;\n   418→      return false;\n   419→    });\n   420→    vi.mocked(readFileSync).mockReturnValue(content);\n   421→\n   422→    const r = validateDockerfile('/project');\n   423→    expect(r.success).toBe(true);\n   424→    if (r.success) {\n   425→      expect(r.data.passed).toBe(true);\n   426→      expect(r.data.gaps).toHaveLength(0);\n   427→    }\n   428→  });\n   429→});\n   430→"}]},"parent_tool_use_id":"toolu_01QPLvTF7hH7ZEy1LqPE8PcP","session_id":"daf25720-e009-4a3c-8a3c-df9d68d99484","uuid":"1f5