{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PnqFzcmtrRxtYzQ8VBYbL7","type":"tool_result","content":"     1→/**\n     2→ * Template migration tests — verify that static template files produce\n     3→ * identical output to the old TypeScript string literals.\n     4→ *\n     5→ * Story 15-3: Template Migration — All Templates to Static Files.\n     6→ * AC3: renderTemplateFile() returns the same content as the former inline functions.\n     7→ */\n     8→\n     9→import { describe, it, expect } from 'vitest';\n    10→import { readFileSync } from 'node:fs';\n    11→import { resolve, dirname } from 'node:path';\n    12→import { fileURLToPath } from 'node:url';\n    13→import { renderTemplate, renderTemplateFile } from '../../lib/templates.js';\n    14→\n    15→const __dirname = dirname(fileURLToPath(import.meta.url));\n    16→const packageRoot = resolve(__dirname, '..', '..', '..');\n    17→\n    18→// ─── renderTemplate() ────────────────────────────────────────────────────────\n    19→\n    20→describe('renderTemplate', () => {\n    21→  it('interpolates simple {{VAR}} placeholders', () => {\n    22→    const result = renderTemplate('Hello {{NAME}}!', { NAME: 'World' });\n    23→    expect(result).toBe('Hello World!');\n    24→  });\n    25→\n    26→  it('leaves unmatched placeholders intact', () => {\n    27→    const result = renderTemplate('{{KNOWN}} and {{UNKNOWN}}', { KNOWN: 'yes' });\n    28→    expect(result).toBe('yes and {{UNKNOWN}}');\n    29→  });\n    30→\n    31→  it('replaces multiple occurrences of same var', () => {\n    32→    const result = renderTemplate('{{X}} + {{X}}', { X: '1' });\n    33→    expect(result).toBe('1 + 1');\n    34→  });\n    35→\n    36→  it('handles empty vars object', () => {\n    37→    const result = renderTemplate('no vars {{HERE}}', {});\n    38→    expect(result).toBe('no vars {{HERE}}');\n    39→  });\n    40→});\n    41→\n    42→// ─── renderTemplateFile() ────────────────────────────────────────────────────\n    43→\n    44→describe('renderTemplateFile', () => {\n    45→  it('reads and returns a template file without interpolation', () => {\n    46→    const content = renderTemplateFile('templates/dockerfiles/Dockerfile.nodejs');\n    47→    expect(content).toContain('FROM node:22-slim');\n    48→    expect(content).toContain('npm install -g');\n    49→  });\n    50→\n    51→  it('reads and interpolates {{VAR}} placeholders from file', () => {\n    52→    const content = renderTemplateFile('templates/compose/otel-collector-remote.yaml', {\n    53→      LOGS_URL: 'http://logs.example.com',\n    54→      METRICS_URL: 'http://metrics.example.com',\n    55→      TRACES_URL: 'http://traces.example.com',\n    56→    });\n    57→    expect(content).toContain('http://logs.example.com/insert/opentelemetry');\n    58→    expect(content).toContain('http://metrics.example.com/api/v1/write');\n    59→    expect(content).toContain('http://traces.example.com');\n    60→    expect(content).not.toContain('{{LOGS_URL}}');\n    61→    expect(content).not.toContain('{{METRICS_URL}}');\n    62→    expect(content).not.toContain('{{TRACES_URL}}');\n    63→  });\n    64→\n    65→  it('throws for non-existent template file', () => {\n    66→    expect(() => renderTemplateFile('templates/does-not-exist.txt')).toThrow();\n    67→  });\n    68→});\n    69→\n    70→// ─── Dockerfile template equivalence ─────────────────────────────────────────\n    71→\n    72→describe('Dockerfile static files match old inline templates', () => {\n    73→  it('Dockerfile.nodejs matches old nodejsTemplate() output', () => {\n    74→    const content = renderTemplateFile('templates/dockerfiles/Dockerfile.nodejs');\n    75→    expect(content).toContain('FROM node:22-slim');\n    76→    expect(content).toContain('ARG TARBALL=package.tgz');\n    77→    expect(content).toContain('npm install -g');\n    78→    expect(content).toContain('USER node');\n    79→    expect(content).toContain('WORKDIR /workspace');\n    80→  });\n    81→\n    82→  it('Dockerfile.python matches old pythonTemplate() output', () => {\n    83→    const content = renderTemplateFile('templates/dockerfiles/Dockerfile.python');\n    84→    expect(content).toContain('FROM python:3.12-slim');\n    85→    expect(content).toContain('pip install');\n    86→    expect(content).toContain('pip cache purge');\n    87→    expect(content).toContain('USER nobody');\n    88→  });\n    89→\n    90→  it('Dockerfile.rust matches old rustTemplate() output', () => {\n    91→    const content = renderTemplateFile('templates/dockerfiles/Dockerfile.rust');\n    92→    expect(content).toContain('FROM rust:1.82-slim AS builder');\n    93→    expect(content).toContain('cargo build --release');\n    94→    expect(content).toContain('FROM debian:bookworm-slim');\n    95→    expect(content).toContain('COPY --from=builder');\n    96→    expect(content).toContain('USER nobody');\n    97→  });\n    98→\n    99→  it('Dockerfile.generic matches old genericTemplate() output', () => {\n   100→    const content = renderTemplateFile('templates/dockerfiles/Dockerfile.generic');\n   101→    expect(content).toContain('FROM node:22-slim');\n   102→    expect(content).toContain('bash');\n   103→    expect(content).toContain('git');\n   104→    expect(content).toContain('placeholder');\n   105→    expect(content).toContain('USER node');\n   106→  });\n   107→\n   108→  it('Dockerfile.multi-stage.tmpl has {{BUILD_STAGES}} and {{COPY_DIRECTIVES}} placeholders', () => {\n   109→    const raw = readFileSync(resolve(packageRoot, 'templates/dockerfiles/Dockerfile.multi-stage.tmpl'), 'utf-8');\n   110→    expect(raw).toContain('{{BUILD_STAGES}}');\n   111→    expect(raw).toContain('{{COPY_DIRECTIVES}}');\n   112→  });\n   113→\n   114→  it('Dockerfile.multi-stage.tmpl renders with provided build stages and copy directives', () => {\n   115→    const content = renderTemplateFile('templates/dockerfiles/Dockerfile.multi-stage.tmpl', {\n   116→      BUILD_STAGES: '# === Build stage: nodejs ===\\nFROM node:22-slim AS build-nodejs',\n   117→      COPY_DIRECTIVES: 'COPY --from=build-nodejs /build/node_modules ./node_modules',\n   118→    });\n   119→    expect(content).toContain('FROM node:22-slim AS build-nodejs');\n   120→    expect(content).toContain('COPY --from=build-nodejs');\n   121→    expect(content).toContain('FROM debian:bookworm-slim');\n   122→  });\n   123→});\n   124→\n   125→// ─── Docker Compose template equivalence ─────────────────────────────────────\n   126→\n   127→describe('Docker Compose static files match old inline templates', () => {\n   128→  it('victoria.yml matches old dockerComposeTemplate() output', () => {\n   129→    const content = renderTemplateFile('templates/compose/victoria.yml');\n   130→    expect(content).toContain('name: codeharness-shared');\n   131→    expect(content).toContain('victoria-logs');\n   132→    expect(content).toContain('victoria-metrics');\n   133→    expect(content).toContain('victoria-traces');\n   134→    expect(content).toContain('otel-collector');\n   135→    expect(content).toContain('codeharness-shared-net');\n   136→  });\n   137→\n   138→  it('collector-only.yml matches old dockerComposeCollectorOnlyTemplate() output', () => {\n   139→    const content = renderTemplateFile('templates/compose/collector-only.yml');\n   140→    expect(content).toContain('name: codeharness-collector');\n   141→    expect(content).toContain('otel-collector');\n   142→    expect(content).toContain('codeharness-collector-net');\n   143→    expect(content).not.toContain('victoria-logs');\n   144→    expect(content).not.toContain('victoria-metrics');\n   145→  });\n   146→});\n   147→\n   148→// ─── OTel Collector config template equivalence ──────────────────────────────\n   149→\n   150→describe('OTel Collector config static files match old inline templates', () => {\n   151→  it('otel-collector-base.yaml matches old otelCollectorConfigTemplate() output', () => {\n   152→    const content = renderTemplateFile('templates/compose/otel-collector-base.yaml');\n   153→    expect(content).toContain('endpoint: 0.0.0.0:4317');\n   154→    expect(content).toContain('endpoint: 0.0.0.0:4318');\n   155→    expect(content).toContain('http://victoria-logs:9428/insert/opentelemetry');\n   156→    expect(content).toContain('http://victoria-metrics:8428/api/v1/write');\n   157→    expect(content).toContain('http://victoria-traces:4318');\n   158→    expect(content).toContain('resource/default');\n   159→  });\n   160→\n   161→  it('otel-collector-remote.yaml renders with URLs matching old otelCollectorRemoteTemplate()', () => {\n   162→    const content = renderTemplateFile('templates/compose/otel-collector-remote.yaml', {\n   163→      LOGS_URL: 'https://logs.company.com',\n   164→      METRICS_URL: 'https://metrics.company.com',\n   165→      TRACES_URL: 'https://traces.company.com:4317',\n   166→    });\n   167→    expect(content).toContain('https://logs.company.com/insert/opentelemetry');\n   168→    expect(content).toContain('https://metrics.company.com/api/v1/write');\n   169→    expect(content).toContain('https://traces.company.com:4317');\n   170→    expect(content).toContain('resource/default');\n   171→  });\n   172→});\n   173→\n   174→// ─── Ralph prompt template equivalence ───────────────────────────────────────\n   175→\n   176→describe('Ralph prompt static file matches old PROMPT_TEMPLATE', () => {\n   177→  it('ralph-prompt.md contains the expected sections', () => {\n   178→    const content = renderTemplateFile('templates/prompts/ralph-prompt.md');\n   179→    expect(content).toContain('You are an autonomous coding agent');\n   180→    expect(content).toContain('/harness-run');\n   181→    expect(content).toContain('{{sprintStatusPath}}');\n   182→    expect(content).toContain('{{projectDir}}');\n   183→  });\n   184→\n   185→  it('ralph-prompt.md renders with interpolated paths', () => {\n   186→    const content = renderTemplateFile('templates/prompts/ralph-prompt.md', {\n   187→      projectDir: '/home/user/project',\n   188→      sprintStatusPath: '/home/user/project/sprint-status.yaml',\n   189→    });\n   190→    expect(content).toContain('/home/user/project');\n   191→    expect(content).toContain('/home/user/project/sprint-status.yaml');\n   192→    expect(content).not.toContain('{{projectDir}}');\n   193→    expect(content).not.toContain('{{sprintStatusPath}}');\n   194→  });\n   195→});\n   196→\n   197→// ─── README template equivalence ─────────────────────────────────────────────\n   198→\n   199→describe('README static file matches old readmeTemplate() structure', () => {\n   200→  it('readme.md.tmpl contains expected placeholders', () => {\n   201→    const raw = readFileSync(resolve(packageRoot, 'templates/docs/readme.md.tmpl'), 'utf-8');\n   202→    expect(raw).toContain('{{PROJECT_NAME}}');\n   203→    expect(raw).toContain('{{INSTALL_COMMAND}}');\n   204→    expect(raw).toContain('{{CLI_HELP_OUTPUT}}');\n   205→  });\n   206→\n   207→  it('readme.md.tmpl renders with project values', () => {\n   208→    const content = renderTemplateFile('templates/docs/readme.md.tmpl', {\n   209→      PROJECT_NAME: 'my-app',\n   210→      INSTALL_COMMAND: 'npm install -g codeharness',\n   211→      CLI_HELP_OUTPUT: 'Usage: codeharness [options]',\n   212→    });\n   213→    expect(content).toContain('# my-app');\n   214→    expect(content).toContain('npm install -g codeharness');\n   215→    expect(content).toContain('Usage: codeharness [options]');\n   216→  });\n   217→});\n   218→\n   219→// ─── Template directory structure ────────────────────────────────────────────\n   220→\n   221→describe('Template directory structure (AC1)', () => {\n   222→  const templateDir = resolve(packageRoot, 'templates');\n   223→\n   224→  it('templates/dockerfiles/ contains all Dockerfile templates', () => {\n   225→    const files = ['Dockerfile.nodejs', 'Dockerfile.python', 'Dockerfile.rust', 'Dockerfile.generic', 'Dockerfile.multi-stage.tmpl'];\n   226→    for (const file of files) {\n   227→      const content = readFileSync(resolve(templateDir, 'dockerfiles', file), 'utf-8');\n   228→      expect(content.length).toBeGreaterThan(0);\n   229→    }\n   230→  });\n   231→\n   232→  it('templates/compose/ contains compose and otel config templates', () => {\n   233→    const files = ['victoria.yml', 'collector-only.yml', 'otel-collector-base.yaml', 'otel-collector-remote.yaml'];\n   234→    for (const file of files) {\n   235→      const content = readFileSync(resolve(templateDir, 'compose', file), 'utf-8');\n   236→      expect(content.length).toBeGreaterThan(0);\n   237→    }\n   238→  });\n   239→\n   240→  it('templates/prompts/ contains ralph-prompt.md', () => {\n   241→    const content = readFileSync(resolve(templateDir, 'prompts', 'ralph-prompt.md'), 'utf-8');\n   242→    expect(content.length).toBeGreaterThan(0);\n   243→  });\n   244→\n   245→  it('templates/docs/ contains readme.md.tmpl', () => {\n   246→    const content = readFileSync(resolve(templateDir, 'docs', 'readme.md.tmpl'), 'utf-8');\n   247→    expect(content.length).toBeGreaterThan(0);\n   248→  });\n   249→\n   250→  it('templates/otlp/ contains per-stack OTLP docs', () => {\n   251→    const files = ['nodejs.md', 'python.md', 'rust.md'];\n   252→    for (const file of files) {\n   253→      const content = readFileSync(resolve(templateDir, 'otlp', file), 'utf-8');\n   254→      expect(content.length).toBeGreaterThan(0);\n   255→    }\n   256→  });\n   257→});\n   258→\n   259→// ─── AC2: TypeScript generators replaced with renderTemplateFile() ───────────\n   260→\n   261→describe('TypeScript generators use renderTemplateFile() (AC2)', () => {\n   262→  it('dockerComposeTemplate returns static file content', async () => {\n   263→    const { dockerComposeTemplate } = await import('../docker-compose.js');\n   264→    const result = dockerComposeTemplate({ shared: true });\n   265→    const fileContent = renderTemplateFile('templates/compose/victoria.yml');\n   266→    expect(result).toBe(fileContent);\n   267→  });\n   268→\n   269→  it('dockerComposeCollectorOnlyTemplate returns static file content', async () => {\n   270→    const { dockerComposeCollectorOnlyTemplate } = await import('../docker-compose.js');\n   271→    const result = dockerComposeCollectorOnlyTemplate();\n   272→    const fileContent = renderTemplateFile('templates/compose/collector-only.yml');\n   273→    expect(result).toBe(fileContent);\n   274→  });\n   275→\n   276→  it('otelCollectorConfigTemplate returns static file content', async () => {\n   277→    const { otelCollectorConfigTemplate } = await import('../otel-config.js');\n   278→    const result = otelCollectorConfigTemplate();\n   279→    const fileContent = renderTemplateFile('templates/compose/otel-collector-base.yaml');\n   280→    expect(result).toBe(fileContent);\n   281→  });\n   282→\n   283→  it('otelCollectorRemoteTemplate returns interpolated file content', async () => {\n   284→    const { otelCollectorRemoteTemplate } = await import('../otel-config.js');\n   285→    const config = {\n   286→      logsUrl: 'https://logs.example.com',\n   287→      metricsUrl: 'https://metrics.example.com',\n   288→      tracesUrl: 'https://traces.example.com',\n   289→    };\n   290→    const result = otelCollectorRemoteTemplate(config);\n   291→    const fileContent = renderTemplateFile('templates/compose/otel-collector-remote.yaml', {\n   292→      LOGS_URL: 'https://logs.example.com',\n   293→      METRICS_URL: 'https://metrics.example.com',\n   294→      TRACES_URL: 'https://traces.example.com',\n   295→    });\n   296→    expect(result).toBe(fileContent);\n   297→  });\n   298→\n   299→  it('readmeTemplate uses static file with interpolation', async () => {\n   300→    const { readmeTemplate } = await import('../readme.js');\n   301→    const result = readmeTemplate({\n   302→      projectName: 'test-app',\n   303→      stack: 'nodejs',\n   304→      cliHelpOutput: 'Usage: codeharness [options]',\n   305→    });\n   306→    expect(result).toContain('# test-app');\n   307→    expect(result).toContain('npm install -g codeharness');\n   308→    expect(result).toContain('Usage: codeharness [options]');\n   309→  });\n   310→});\n   311→"}]},"parent_tool_use_id":"toolu_01XDjxyLwkaMXpxX2UKGshtf","session_id":"f5f7e8e8-6408-46c1-8863-2380ea5a7335","uuid":"49ac9889-4970-478b-8f76-7572c7507d86","timestamp":"2026-03-25T05:36:37.675Z"}
