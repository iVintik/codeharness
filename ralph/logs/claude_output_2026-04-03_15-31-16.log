{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01C5p2dtx7MJAnCZnFSS85Jn","type":"tool_result","content":"1\t/**\n2\t * Ink UI components ã types and layout components (Header, Separator, StoryBreakdown).\n3\t *\n4\t * Renders a UX-spec-compliant live display with plain text header,\n5\t * ããã separators, and labeled story breakdown sections.\n6\t * Activity components (tools, thoughts, retry) are in ink-activity-components.tsx.\n7\t * The App root component is in ink-app.tsx to avoid circular imports.\n8\t */\n9\t\n10\timport React from 'react';\n11\timport { Text, Box } from 'ink';\n12\timport type { FlowStep } from './workflow-parser.js';\n13\t\n14\t// --- Types ---\n15\t\n16\texport interface SprintInfo {\n17\t  storyKey: string;\n18\t  phase: string;\n19\t  done: number;\n20\t  total: number;\n21\t  elapsed?: string;\n22\t  iterationCount?: number;\n23\t  totalCost?: number;\n24\t  acProgress?: string;\n25\t  currentCommand?: string;\n26\t}\n27\t\n28\texport interface CompletedToolEntry {\n29\t  name: string;\n30\t  args: string;\n31\t}\n32\t\n33\texport type StoryStatusValue = 'done' | 'in-progress' | 'pending' | 'failed' | 'blocked';\n34\t\n35\texport interface StoryStatusEntry {\n36\t  key: string;\n37\t  status: StoryStatusValue;\n38\t  retryCount?: number;\n39\t  maxRetries?: number;\n40\t}\n41\t\n42\texport interface RetryInfo {\n43\t  attempt: number;\n44\t  delay: number;\n45\t}\n46\t\n47\texport interface StoryMessage {\n48\t  type: 'ok' | 'warn' | 'fail';\n49\t  key: string;\n50\t  message: string;\n51\t  details?: string[];\n52\t}\n53\t\n54\texport type TaskNodeState = 'pending' | 'active' | 'done' | 'failed';\n55\t\n56\texport interface TaskNodeMeta {\n57\t  driver?: string;\n58\t  costUsd?: number | null;\n59\t  elapsedMs?: number | null;\n60\t}\n61\t\n62\texport interface RendererState {\n63\t  sprintInfo: SprintInfo | null;\n64\t  stories: StoryStatusEntry[];\n65\t  messages: StoryMessage[];\n66\t  completedTools: CompletedToolEntry[];\n67\t  activeTool: { name: string } | null;\n68\t  activeToolArgs: string;\n69\t  lastThought: string | null;\n70\t  retryInfo: RetryInfo | null;\n71\t  workflowFlow: FlowStep[];\n72\t  currentTaskName: string | null;\n73\t  taskStates: Record<string, TaskNodeState>;\n74\t  taskMeta: Record<string, TaskNodeMeta>;\n75\t}\n76\t\n77\t// --- Layout Components ---\n78\t\n79\t/** Full-width separator using ã characters. */\n80\texport function Separator() {\n81\t  const width = process.stdout.columns || 60;\n82\t  return <Text>{'ã'.repeat(width)}</Text>;\n83\t}\n84\t\n85\tfunction shortKey(key: string): string {\n86\t  const m = key.match(/^(\\d+-\\d+)/);\n87\t  return m ? m[1] : key;\n88\t}\n89\t\n90\tfunction formatCost(cost: number): string {\n91\t  return `$${cost.toFixed(2)}`;\n92\t}\n93\t\n94\texport function Header({ info }: { info: SprintInfo | null }) {\n95\t  if (!info) return null;\n96\t\n97\t  const parts: string[] = ['codeharness run'];\n98\t  if (info.iterationCount != null) {\n99\t    parts.push(`iteration ${info.iterationCount}`);\n100\t  }\n101\t  if (info.elapsed) {\n102\t    parts.push(`${info.elapsed} elapsed`);\n103\t  }\n104\t  if (info.totalCost != null) {\n105\t    parts.push(`${formatCost(info.totalCost)} spent`);\n106\t  }\n107\t  const headerLine = parts.join(' | ');\n108\t\n109\t  let phaseLine = '';\n110\t  if (info.phase) {\n111\t    phaseLine = `Phase: ${info.phase}`;\n112\t    if (info.acProgress) {\n113\t      phaseLine += ` ã AC ${info.acProgress}`;\n114\t    }\n115\t    if (info.currentCommand) {\n116\t      phaseLine += ` (${info.currentCommand})`;\n117\t    }\n118\t  }\n119\t\n120\t  return (\n121\t    <Box flexDirection=\"column\">\n122\t      <Text>{headerLine}</Text>\n123\t      <Separator />\n124\t      <Text>{`Story: ${info.storyKey || '(waiting)'}`}</Text>\n125\t      {phaseLine && <Text>{phaseLine}</Text>}\n126\t    </Box>\n127\t  );\n128\t}\n129\t\n130\texport function StoryBreakdown({ stories, sprintInfo }: { stories: StoryStatusEntry[]; sprintInfo?: SprintInfo | null }) {\n131\t  if (stories.length === 0) return null;\n132\t\n133\t  const done: StoryStatusEntry[] = [];\n134\t  const inProgress: StoryStatusEntry[] = [];\n135\t  const pending: StoryStatusEntry[] = [];\n136\t  const failed: StoryStatusEntry[] = [];\n137\t  const blocked: StoryStatusEntry[] = [];\n138\t\n139\t  for (const s of stories) {\n140\t    switch (s.status) {\n141\t      case 'done': done.push(s); break;\n142\t      case 'in-progress': inProgress.push(s); break;\n143\t      case 'pending': pending.push(s); break;\n144\t      case 'failed': failed.push(s); break;\n145\t      case 'blocked': blocked.push(s); break;\n146\t    }\n147\t  }\n148\t\n149\t  const lines: React.ReactNode[] = [];\n150\t\n151\t  if (done.length > 0) {\n152\t    const doneItems = done.map(s => `${shortKey(s.key)} ã`).join('  ');\n153\t    lines.push(\n154\t      <Text key=\"done\"><Text color=\"green\">{'Done: '}</Text><Text color=\"green\">{doneItems}</Text></Text>\n155\t    );\n156\t  }\n157\t\n158\t  if (inProgress.length > 0) {\n159\t    for (const s of inProgress) {\n160\t      let thisText = `${shortKey(s.key)} ã`;\n161\t      if (sprintInfo && sprintInfo.storyKey && shortKey(s.key) === shortKey(sprintInfo.storyKey)) {\n162\t        if (sprintInfo.phase) thisText += ` ${sprintInfo.phase}`;\n163\t        if (sprintInfo.acProgress) thisText += ` (${sprintInfo.acProgress} ACs)`;\n164\t      }\n165\t      lines.push(\n166\t        <Text key={`this-${s.key}`}><Text color=\"cyan\">{'This: '}</Text><Text color=\"cyan\">{thisText}</Text></Text>\n167\t      );\n168\t    }\n169\t  }\n170\t\n171\t  if (pending.length > 0) {\n172\t    lines.push(\n173\t      <Text key=\"next\">\n174\t        <Text>{'Next: '}</Text><Text>{shortKey(pending[0].key)}</Text>\n175\t        {pending.length > 1 && <Text dimColor>{` (+${pending.length - 1} more)`}</Text>}\n176\t      </Text>\n177\t    );\n178\t  }\n179\t\n180\t  if (blocked.length > 0) {\n181\t    const blockedItems = blocked.map(s => {\n182\t      let item = `${shortKey(s.key)} ã`;\n183\t      if (s.retryCount != null && s.maxRetries != null) item += ` (${s.retryCount}/${s.maxRetries})`;\n184\t      return item;\n185\t    }).join('  ');\n186\t    lines.push(\n187\t      <Text key=\"blocked\"><Text color=\"yellow\">{'Blocked: '}</Text><Text color=\"yellow\">{blockedItems}</Text></Text>\n188\t    );\n189\t  }\n190\t\n191\t  if (failed.length > 0) {\n192\t    const failedItems = failed.map(s => {\n193\t      let item = `${shortKey(s.key)} ã`;\n194\t      if (s.retryCount != null && s.maxRetries != null) item += ` (${s.retryCount}/${s.maxRetries})`;\n195\t      return item;\n196\t    }).join('  ');\n197\t    lines.push(\n198\t      <Text key=\"failed\"><Text color=\"red\">{'Failed: '}</Text><Text color=\"red\">{failedItems}</Text></Text>\n199\t    );\n200\t  }\n201\t\n202\t  return (\n203\t    <Box flexDirection=\"column\">\n204\t      {lines}\n205\t    </Box>\n206\t  );\n207\t}\n208\t\n209\t// Re-export activity components so existing consumers don't break\n210\texport { CompletedTool, CompletedTools, ActiveTool, LastThought, RetryNotice, StoryMessageLine } from './ink-activity-components.js';\n211\t\n212\t// Re-export App from ink-app\n213\texport { App } from './ink-app.js';\n214\t"}]},"parent_tool_use_id":"toolu_01HHjA9k9oUqnMe2NSedRNzY","session_id":"87203133-5cdd-4288-8e5c-bcff0e178735","uuid":"18b59c80-85da-479a-81a6-4418c5f2b54a","timestamp":"2026-04-03T11:44:54.464Z"}
