{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MSfdRiyTWwk1GftkpQwrvs","type":"tool_result","content":"     1→import { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n     2→import { join } from 'node:path';\n     3→import { parse, stringify } from 'yaml';\n     4→import { warn } from './output.js';\n     5→import { detectStack } from './stack-detect.js';\n     6→\n     7→export interface HarnessState {\n     8→  harness_version: string;\n     9→  initialized: boolean;\n    10→  stack: string | null;\n    11→  app_type?: 'server' | 'cli' | 'web' | 'agent' | 'generic';\n    12→  enforcement: {\n    13→    frontend: boolean;\n    14→    database: boolean;\n    15→    api: boolean;\n    16→  };\n    17→  coverage: {\n    18→    target: number;\n    19→    baseline: number | null;\n    20→    current: number | null;\n    21→    tool: 'c8' | 'coverage.py' | 'cargo-tarpaulin' | 'unknown';\n    22→  };\n    23→  session_flags: {\n    24→    logs_queried: boolean;\n    25→    tests_passed: boolean;\n    26→    coverage_met: boolean;\n    27→    verification_run: boolean;\n    28→  };\n    29→  verification_log: string[];\n    30→  otlp?: {\n    31→    enabled: boolean;\n    32→    endpoint: string;\n    33→    service_name: string;\n    34→    mode: 'local-shared' | 'remote-direct' | 'remote-routed';\n    35→    node_require?: string;\n    36→    python_wrapper?: string;\n    37→    cli_env_vars?: Record<string, string>;\n    38→    web_snippet_path?: string;\n    39→    resource_attributes?: string;\n    40→    agent_sdk?: string;\n    41→    rust_env_hint?: string;\n    42→  };\n    43→  retro_issue_targets?: Array<{ repo: string; labels: string[] }>;\n    44→  docker?: {\n    45→    compose_file: string;\n    46→    stack_running: boolean;\n    47→    remote_endpoints?: {\n    48→      logs_url?: string;\n    49→      metrics_url?: string;\n    50→      traces_url?: string;\n    51→    };\n    52→    ports: {\n    53→      logs: number;\n    54→      metrics: number;\n    55→      traces: number;\n    56→      otel_grpc: number;\n    57→      otel_http: number;\n    58→    };\n    59→  };\n    60→}\n    61→\n    62→const STATE_DIR = '.claude';\n    63→const STATE_FILE = 'codeharness.local.md';\n    64→const DEFAULT_BODY = '\\n# Codeharness State\\n\\nThis file is managed by the codeharness CLI. Do not edit manually.\\n';\n    65→\n    66→export function getDefaultState(stack?: string | null): HarnessState {\n    67→  return {\n    68→    harness_version: '0.1.0',\n    69→    initialized: false,\n    70→    stack: stack ?? null,\n    71→    enforcement: {\n    72→      frontend: true,\n    73→      database: true,\n    74→      api: true,\n    75→    },\n    76→    coverage: {\n    77→      target: 90,\n    78→      baseline: null,\n    79→      current: null,\n    80→      tool: 'c8',\n    81→    },\n    82→    session_flags: {\n    83→      logs_queried: false,\n    84→      tests_passed: false,\n    85→      coverage_met: false,\n    86→      verification_run: false,\n    87→    },\n    88→    verification_log: [],\n    89→  };\n    90→}\n    91→\n    92→export function getStatePath(dir: string): string {\n    93→  return join(dir, STATE_DIR, STATE_FILE);\n    94→}\n    95→\n    96→export function writeState(state: HarnessState, dir?: string, body?: string): void {\n    97→  const baseDir = dir ?? process.cwd();\n    98→  const claudeDir = join(baseDir, STATE_DIR);\n    99→  mkdirSync(claudeDir, { recursive: true });\n   100→\n   101→  const yamlContent = stringify(state, { nullStr: 'null' });\n   102→  const markdownBody = body ?? DEFAULT_BODY;\n   103→  const fileContent = `---\\n${yamlContent}---\\n${markdownBody}`;\n   104→\n   105→  writeFileSync(join(claudeDir, STATE_FILE), fileContent, 'utf-8');\n   106→}\n   107→\n   108→export function readState(dir?: string): HarnessState {\n   109→  const baseDir = dir ?? process.cwd();\n   110→  const filePath = getStatePath(baseDir);\n   111→\n   112→  if (!existsSync(filePath)) {\n   113→    throw new StateFileNotFoundError();\n   114→  }\n   115→\n   116→  const raw = readFileSync(filePath, 'utf-8');\n   117→  const parts = raw.split('---');\n   118→\n   119→  // parts[0] is empty (before first ---), parts[1] is YAML, rest is body\n   120→  if (parts.length < 3) {\n   121→    return recoverCorruptedState(baseDir);\n   122→  }\n   123→\n   124→  try {\n   125→    const state = parse(parts[1]) as HarnessState;\n   126→    if (!isValidState(state)) {\n   127→      return recoverCorruptedState(baseDir);\n   128→    }\n   129→    return state;\n   130→  } catch {\n   131→    return recoverCorruptedState(baseDir);\n   132→  }\n   133→}\n   134→\n   135→export function readStateWithBody(dir?: string): { state: HarnessState; body: string } {\n   136→  const baseDir = dir ?? process.cwd();\n   137→  const filePath = getStatePath(baseDir);\n   138→\n   139→  if (!existsSync(filePath)) {\n   140→    throw new StateFileNotFoundError();\n   141→  }\n   142→\n   143→  const raw = readFileSync(filePath, 'utf-8');\n   144→  const parts = raw.split('---');\n   145→\n   146→  if (parts.length < 3) {\n   147→    const state = recoverCorruptedState(baseDir);\n   148→    return { state, body: DEFAULT_BODY };\n   149→  }\n   150→\n   151→  try {\n   152→    const state = parse(parts[1]) as HarnessState;\n   153→    if (!isValidState(state)) {\n   154→      const recovered = recoverCorruptedState(baseDir);\n   155→      return { state: recovered, body: DEFAULT_BODY };\n   156→    }\n   157→    // Everything after the second --- is the body\n   158→    const body = parts.slice(2).join('---');\n   159→    return { state, body: body || DEFAULT_BODY };\n   160→  } catch {\n   161→    const state = recoverCorruptedState(baseDir);\n   162→    return { state, body: DEFAULT_BODY };\n   163→  }\n   164→}\n   165→\n   166→function isValidState(state: unknown): state is HarnessState {\n   167→  if (!state || typeof state !== 'object') return false;\n   168→  const s = state as Record<string, unknown>;\n   169→  if (typeof s.harness_version !== 'string') return false;\n   170→  if (typeof s.initialized !== 'boolean') return false;\n   171→  if (s.stack !== null && typeof s.stack !== 'string') return false;\n   172→  if (!s.enforcement || typeof s.enforcement !== 'object') return false;\n   173→  if (!s.coverage || typeof s.coverage !== 'object') return false;\n   174→  if (!s.session_flags || typeof s.session_flags !== 'object') return false;\n   175→  if (!Array.isArray(s.verification_log)) return false;\n   176→  return true;\n   177→}\n   178→\n   179→function recoverCorruptedState(dir: string): HarnessState {\n   180→  warn('State file corrupted — recreating from detected config');\n   181→  const stack = detectStack(dir);\n   182→  const state = getDefaultState(stack);\n   183→  writeState(state, dir);\n   184→  return state;\n   185→}\n   186→\n   187→export class StateFileNotFoundError extends Error {\n   188→  constructor() {\n   189→    super('No state file found. Run \\'codeharness init\\' first.');\n   190→    this.name = 'StateFileNotFoundError';\n   191→  }\n   192→}\n   193→\n   194→const DANGEROUS_KEYS = new Set(['__proto__', 'constructor', 'prototype']);\n   195→\n   196→function validateKeyPath(keyPath: string): void {\n   197→  const keys = keyPath.split('.');\n   198→  for (const key of keys) {\n   199→    if (DANGEROUS_KEYS.has(key)) {\n   200→      throw new Error(`Invalid key path: '${key}' is not allowed`);\n   201→    }\n   202→  }\n   203→}\n   204→\n   205→export function getNestedValue(obj: Record<string, unknown>, keyPath: string): unknown {\n   206→  validateKeyPath(keyPath);\n   207→  const keys = keyPath.split('.');\n   208→  let current: unknown = obj;\n   209→  for (const key of keys) {\n   210→    if (current === null || current === undefined || typeof current !== 'object') {\n   211→      return undefined;\n   212→    }\n   213→    current = (current as Record<string, unknown>)[key];\n   214→  }\n   215→  return current;\n   216→}\n   217→\n   218→export function setNestedValue(obj: Record<string, unknown>, keyPath: string, value: unknown): void {\n   219→  validateKeyPath(keyPath);\n   220→  const keys = keyPath.split('.');\n   221→  let current: Record<string, unknown> = obj;\n   222→  for (let i = 0; i < keys.length - 1; i++) {\n   223→    const key = keys[i];\n   224→    if (current[key] === undefined || current[key] === null || typeof current[key] !== 'object') {\n   225→      current[key] = {};\n   226→    }\n   227→    current = current[key] as Record<string, unknown>;\n   228→  }\n   229→  current[keys[keys.length - 1]] = value;\n   230→}\n   231→\n   232→export function parseValue(raw: string): unknown {\n   233→  if (raw === 'true') return true;\n   234→  if (raw === 'false') return false;\n   235→  if (raw === 'null') return null;\n   236→  const num = Number(raw);\n   237→  if (!Number.isNaN(num) && raw.trim() !== '') return num;\n   238→  return raw;\n   239→}\n   240→"}]},"parent_tool_use_id":"toolu_01CGkWizVB7CtGCqwFm5rfNr","session_id":"6b184f1a-3a3f-4307-8da0-d8cf52066851","uuid":"3654a684-dcd8-4a0e-9f5a-6bfca6e9f794","timestamp":"2026-03-23T05:23:02.450Z"}
