{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011Ssh8PgtexgRa6b6Jk14Dr","type":"tool_result","content":"1\t/**\n2\t * Ink Terminal Renderer — live terminal UI for Claude activity display.\n3\t * Exports startRenderer() which returns a RendererHandle for feeding events.\n4\t */\n5\t\n6\timport React from 'react';\n7\timport { render as inkRender } from 'ink';\n8\timport type { StreamEvent } from './agents/stream-parser.js';\n9\timport {\n10\t  App,\n11\t  type SprintInfo,\n12\t  type CompletedToolEntry,\n13\t  type RetryInfo,\n14\t  type RendererState,\n15\t  type StoryStatusEntry,\n16\t  type StoryMessage,\n17\t  type TaskNodeState,\n18\t  type TaskNodeMeta,\n19\t} from './ink-components.js';\n20\timport type { FlowStep } from './workflow-parser.js';\n21\t\n22\t// --- Public Types ---\n23\t\n24\texport interface RendererOptions {\n25\t  quiet?: boolean;\n26\t  sprintState?: SprintInfo;\n27\t  /** @internal Force TTY mode for testing. Not part of the public API. */\n28\t  _forceTTY?: boolean;\n29\t}\n30\t\n31\texport interface RendererHandle {\n32\t  update(event: StreamEvent, driverName?: string): void;\n33\t  updateSprintState(state: SprintInfo | undefined): void;\n34\t  updateStories(stories: StoryStatusEntry[]): void;\n35\t  addMessage(msg: StoryMessage): void;\n36\t  updateWorkflowState(flow: FlowStep[], currentTask: string | null, taskStates: Record<string, TaskNodeState>, taskMeta?: Record<string, TaskNodeMeta>): void;\n37\t  cleanup(): void;\n38\t  /** @internal Expose state for testing. Not part of the public API. */\n39\t  _getState?(): RendererState;\n40\t}\n41\t\n42\t// --- No-op handle for quiet mode ---\n43\t\n44\tconst noopHandle: RendererHandle = {\n45\t  update(_event: StreamEvent, _driverName?: string) {},\n46\t  updateSprintState() {},\n47\t  updateStories() {},\n48\t  addMessage() {},\n49\t  updateWorkflowState() {},\n50\t  cleanup() {},\n51\t};\n52\t\n53\t/** Maximum number of completed tools to retain in the display list. */\n54\tconst MAX_COMPLETED_TOOLS = 50;\n55\t\n56\t// --- Controller ---\n57\t\n58\t/**\n59\t * Start the Ink terminal renderer.\n60\t *\n61\t * If `quiet` is true or stdout is not a TTY, returns a no-op handle\n62\t * (no Ink instance created).\n63\t * Otherwise, mounts the component tree and returns a handle for feeding events.\n64\t */\n65\texport function startRenderer(options?: RendererOptions): RendererHandle {\n66\t  if (options?.quiet || (!process.stdout.isTTY && !options?._forceTTY)) {\n67\t    return noopHandle;\n68\t  }\n69\t\n70\t  // Mutable state that drives re-renders\n71\t  let state: RendererState = {\n72\t    sprintInfo: options?.sprintState ?? null,\n73\t    stories: [],\n74\t    messages: [],\n75\t    completedTools: [],\n76\t    activeTool: null,\n77\t    activeToolArgs: '',\n78\t    lastThought: null,\n79\t    retryInfo: null,\n80\t    workflowFlow: [],\n81\t    currentTaskName: null,\n82\t    taskStates: {},\n83\t    taskMeta: {},\n84\t    activeDriverName: null,\n85\t    driverCosts: {},\n86\t  };\n87\t\n88\t  // Per-story cost tracking (not part of RendererState — internal to controller)\n89\t  let currentStoryCosts: Record<string, number> = {};\n90\t  let lastStoryKey: string | null = state.sprintInfo?.storyKey ?? null;\n91\t  // Costs finalized for completed stories, awaiting snapshot into StoryStatusEntry\n92\t  const pendingStoryCosts: Map<string, Record<string, number>> = new Map();\n93\t\n94\t  let cleaned = false;\n95\t\n96\t  // Mount Ink with performance options\n97\t  const inkInstance = inkRender(<App state={state} />, {\n98\t    exitOnCtrlC: false,\n99\t    patchConsole: !options?._forceTTY,\n100\t    maxFps: 15,\n101\t  });\n102\t\n103\t  function rerender() {\n104\t    if (!cleaned) {\n105\t      // Create a new state object reference to trigger React re-render\n106\t      state = { ...state };\n107\t      inkInstance.rerender(<App state={state} />);\n108\t    }\n109\t  }\n110\t\n111\t  function cleanup() {\n112\t    if (cleaned) return;\n113\t    cleaned = true;\n114\t    try { inkInstance.unmount(); } catch { /* may already be unmounted */ }\n115\t    try { inkInstance.cleanup(); } catch { /* ignore */ }\n116\t    process.removeListener('SIGINT', onSigint);\n117\t    process.removeListener('SIGTERM', onSigterm);\n118\t  }\n119\t\n120\t  function onSigint() { cleanup(); process.kill(process.pid, 'SIGINT'); }\n121\t  function onSigterm() { cleanup(); process.kill(process.pid, 'SIGTERM'); }\n122\t  process.on('SIGINT', onSigint);\n123\t  process.on('SIGTERM', onSigterm);\n124\t\n125\t  /** Promote active tool to completed list, bounded to MAX_COMPLETED_TOOLS. */\n126\t  function promoteActiveTool(clearActive: boolean) {\n127\t    if (!state.activeTool) return;\n128\t    const entry: CompletedToolEntry = {\n129\t      name: state.activeTool.name, args: state.activeToolArgs,\n130\t      driver: state.activeDriverName ?? undefined,\n131\t    };\n132\t    const updated = [...state.completedTools, entry];\n133\t    state.completedTools = updated.length > MAX_COMPLETED_TOOLS\n134\t      ? updated.slice(updated.length - MAX_COMPLETED_TOOLS) : updated;\n135\t    if (clearActive) { state.activeTool = null; state.activeToolArgs = ''; state.activeDriverName = null; }\n136\t  }\n137\t\n138\t  function update(event: StreamEvent, driverName?: string): void {\n139\t    if (cleaned) return;\n140\t\n141\t    switch (event.type) {\n142\t      case 'tool-start':\n143\t        promoteActiveTool(false); // promote any lingering long-running tool\n144\t        state.activeTool = { name: event.name };\n145\t        state.activeToolArgs = '';\n146\t        state.activeDriverName = driverName ?? null;\n147\t        state.lastThought = null;\n148\t        state.retryInfo = null;\n149\t        break;\n150\t\n151\t      case 'tool-input':\n152\t        state.activeToolArgs += event.partial;\n153\t        return; // Skip rerender — args only shown on completion\n154\t\n155\t      case 'tool-complete':\n156\t        // Only promote if there's an active tool (parser emits tool-complete for text blocks too).\n157\t        // Long-running tools (Agent, Skill) stay active until next tool-start.\n158\t        if (state.activeTool) {\n159\t          if (['Agent', 'Skill'].includes(state.activeTool.name)) break;\n160\t          promoteActiveTool(true);\n161\t        }\n162\t        break;\n163\t\n164\t      case 'text':\n165\t        state.lastThought = event.text;\n166\t        state.retryInfo = null;\n167\t        break;\n168\t\n169\t      case 'retry':\n170\t        state.retryInfo = { attempt: event.attempt, delay: event.delay };\n171\t        break;\n172\t\n173\t      case 'result':\n174\t        // Accumulate cost from result events (AC #7)\n175\t        if (event.cost > 0 && state.sprintInfo) {\n176\t          state.sprintInfo = {\n177\t            ...state.sprintInfo,\n178\t            totalCost: (state.sprintInfo.totalCost ?? 0) + event.cost,\n179\t          };\n180\t        }\n181\t        // Accumulate per-driver cost (run-level)\n182\t        if (event.cost > 0 && driverName) {\n183\t          state.driverCosts = {\n184\t            ...state.driverCosts,\n185\t            [driverName]: (state.driverCosts[driverName] ?? 0) + event.cost,\n186\t          };\n187\t          // Accumulate per-story cost\n188\t          currentStoryCosts = {\n189\t            ...currentStoryCosts,\n190\t            [driverName]: (currentStoryCosts[driverName] ?? 0) + event.cost,\n191\t          };\n192\t        }\n193\t        break;\n194\t    }\n195\t\n196\t    rerender();\n197\t  }\n198\t\n199\t  function updateSprintState(sprintState: SprintInfo | undefined): void {\n200\t    if (cleaned) return;\n201\t    if (sprintState && state.sprintInfo) {\n202\t      // Preserve accumulated fields (totalCost, acProgress, currentCommand)\n203\t      // that are set by event handlers but not by the polling caller.\n204\t      state.sprintInfo = {\n205\t        ...sprintState,\n206\t        totalCost: sprintState.totalCost ?? state.sprintInfo.totalCost,\n207\t        acProgress: sprintState.acProgress ?? state.sprintInfo.acProgress,\n208\t        currentCommand: sprintState.currentCommand ?? state.sprintInfo.currentCommand,\n209\t      };\n210\t    } else {\n211\t      state.sprintInfo = sprintState ?? null;\n212\t    }\n213\t\n214\t    // When story key changes, freeze current costs for the old story\n215\t    const newKey = state.sprintInfo?.storyKey ?? null;\n216\t    if (newKey && lastStoryKey && newKey !== lastStoryKey) {\n217\t      if (Object.keys(currentStoryCosts).length > 0) {\n218\t        pendingStoryCosts.set(lastStoryKey, { ...currentStoryCosts });\n219\t      }\n220\t      currentStoryCosts = {};\n221\t      lastStoryKey = newKey;\n222\t    } else if (newKey && !lastStoryKey) {\n223\t      lastStoryKey = newKey;\n224\t    }\n225\t\n226\t    rerender();\n227\t  }\n228\t\n229\t  function updateStories(stories: StoryStatusEntry[]): void {\n230\t    if (cleaned) return;\n231\t    const currentKey = state.sprintInfo?.storyKey ?? null;\n232\t    // Snapshot per-story costs onto done stories (immutable — don't mutate caller objects).\n233\t    // Check both pendingStoryCosts (from prior stories) and currentStoryCosts (active story).\n234\t    const hasCurrentCosts = Object.keys(currentStoryCosts).length > 0;\n235\t    const updatedStories = stories.map(s => {\n236\t      if (s.status !== 'done' || s.costByDriver) return s;\n237\t      // Check pending costs first (costs frozen when story key changed)\n238\t      const pending = pendingStoryCosts.get(s.key);\n239\t      if (pending) {\n240\t        pendingStoryCosts.delete(s.key);\n241\t        return { ...s, costByDriver: pending };\n242\t      }\n243\t      // Check current costs (story completing without key change)\n244\t      if (hasCurrentCosts && s.key === (lastStoryKey ?? currentKey)) {\n245\t        const snap = { ...currentStoryCosts };\n246\t        currentStoryCosts = {};\n247\t        return { ...s, costByDriver: snap };\n248\t      }\n249\t      return s;\n250\t    });\n251\t    // Track story key changes for per-story cost reset\n252\t    if (currentKey && currentKey !== lastStoryKey) {\n253\t      if (lastStoryKey && Object.keys(currentStoryCosts).length > 0) {\n254\t        pendingStoryCosts.set(lastStoryKey, { ...currentStoryCosts });\n255\t      }\n256\t      currentStoryCosts = {};\n257\t      lastStoryKey = currentKey;\n258\t    } else if (currentKey && !lastStoryKey) {\n259\t      lastStoryKey = currentKey;\n260\t    }\n261\t    state.stories = updatedStories;\n262\t    rerender();\n263\t  }\n264\t\n265\t  function addMessage(msg: StoryMessage): void {\n266\t    if (cleaned) return;\n267\t    state.messages = [...state.messages, msg];\n268\t    rerender();\n269\t  }\n270\t\n271\t  function updateWorkflowState(flow: FlowStep[], currentTask: string | null, taskStates: Record<string, TaskNodeState>, taskMeta?: Record<string, TaskNodeMeta>): void {\n272\t    if (cleaned) return;\n273\t    state.workflowFlow = flow;\n274\t    state.currentTaskName = currentTask;\n275\t    state.taskStates = { ...taskStates };\n276\t    state.taskMeta = taskMeta ? { ...taskMeta } : state.taskMeta;\n277\t    rerender();\n278\t  }\n279\t\n280\t  return { update, updateSprintState, updateStories, addMessage, updateWorkflowState, cleanup, _getState: () => state };\n281\t}\n282\t\n283\t// Re-export types that consumers may need\n284\texport type { SprintInfo, CompletedToolEntry, RetryInfo, RendererState, StoryStatusEntry, StoryStatusValue, StoryMessage, TaskNodeState, TaskNodeMeta } from './ink-components.js';\n285\t"}]},"parent_tool_use_id":"toolu_01NegsqtPRQ2T1bc3NRcgCgq","session_id":"568bb8a3-7cec-4d55-8fe6-c91654e95e9c","uuid":"3d24d615-6ade-4562-bca2-6be6835a139c","timestamp":"2026-04-03T23:49:31.350Z"}
