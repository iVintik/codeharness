{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VF2qLRN9ovUMds2967vYJb","type":"tool_result","content":"1\timport { existsSync } from 'node:fs';\n2\timport { join } from 'node:path';\n3\timport { Command } from 'commander';\n4\timport { fail, info, ok } from '../lib/output.js';\n5\timport { isDockerAvailable } from '../lib/docker/index.js';\n6\timport { cleanupContainers } from '../modules/infra/index.js';\n7\timport { readSprintStatusFromState, reconcileState } from '../modules/sprint/index.js';\n8\timport { countStories, formatElapsed } from '../lib/run-helpers.js';\n9\timport { parseWorkflow, resolveWorkflow } from '../lib/workflow-parser.js';\n10\timport { resolveAgent, compileSubagentDefinition } from '../lib/agent-resolver.js';\n11\timport { executeWorkflow } from '../lib/workflow-engine.js';\n12\timport { readWorkflowState, writeWorkflowState } from '../lib/workflow-state.js';\n13\timport type { EngineConfig } from '../lib/workflow-engine.js';\n14\timport type { SubagentDefinition } from '../lib/agent-resolver.js';\n15\t\n16\t/** Resolves the plugin directory path (.claude/ in project root). */\n17\texport function resolvePluginDir(): string {\n18\t  return join(process.cwd(), '.claude');\n19\t}\n20\t\n21\t// Re-export helpers that tests import from run.ts\n22\texport { countStories } from '../lib/run-helpers.js';\n23\t\n24\texport function registerRunCommand(program: Command): void {\n25\t  program\n26\t    .command('run')\n27\t    .description('Execute the autonomous coding loop')\n28\t    .option('--max-iterations <n>', 'Maximum loop iterations', '50')\n29\t    .option('--timeout <seconds>', 'Total loop timeout in seconds', '43200')\n30\t    .option('--iteration-timeout <minutes>', 'Per-iteration timeout in minutes', '30')\n31\t    .option('--quiet', 'Suppress terminal output (background mode)', false)\n32\t    .option('--calls <n>', 'Max API calls per hour', '100')\n33\t    .option('--max-story-retries <n>', 'Max retries per story before flagging', '10')\n34\t    .option('--reset', 'Clear retry counters, flagged stories, and circuit breaker before starting', false)\n35\t    .option('--resume', 'Resume from last checkpoint (engine resumes by default)', false)\n36\t    .action(async (options, cmd) => {\n37\t      const globalOpts = cmd.optsWithGlobals();\n38\t      const isJson = !!globalOpts.json;\n39\t      const outputOpts = { json: isJson };\n40\t\n41\t      // 1. Resolve plugin directory\n42\t      const pluginDir = resolvePluginDir();\n43\t      if (!existsSync(pluginDir)) {\n44\t        fail('Plugin directory not found — run codeharness init first', outputOpts);\n45\t        process.exitCode = 1;\n46\t        return;\n47\t      }\n48\t\n49\t      // 1b. Reconcile state (best-effort — failures warn but don't abort)\n50\t      const reconciliation = reconcileState();\n51\t      if (reconciliation.success && reconciliation.data.corrections.length > 0) {\n52\t        for (const correction of reconciliation.data.corrections) {\n53\t          info(`[INFO] Reconciled: ${correction}`, outputOpts);\n54\t        }\n55\t      } else if (!reconciliation.success) {\n56\t        info(`[WARN] State reconciliation failed: ${reconciliation.error}`, outputOpts);\n57\t      }\n58\t\n59\t      // 1c. Docker pre-flight: fail fast if Docker unavailable\n60\t      if (!isDockerAvailable()) {\n61\t        fail('[FAIL] Docker not available — install Docker or start the daemon', outputOpts);\n62\t        process.exitCode = 1;\n63\t        return;\n64\t      }\n65\t      // 1d. Orphan container cleanup (best-effort — failures warn but don't abort)\n66\t      const cleanup = cleanupContainers();\n67\t      if (cleanup.success && cleanup.data.containersRemoved > 0) {\n68\t        info(`[INFO] Cleaned up ${cleanup.data.containersRemoved} orphaned container(s): ${cleanup.data.names.join(', ')}`, outputOpts);\n69\t      } else if (!cleanup.success) {\n70\t        info(`[WARN] Container cleanup failed: ${cleanup.error}`, outputOpts);\n71\t      }\n72\t      // 2. Read sprint status for story count (from sprint-state.json)\n73\t      const statuses = readSprintStatusFromState();\n74\t      const counts = countStories(statuses);\n75\t\n76\t      if (counts.total === 0) {\n77\t        fail('No stories found in sprint-state.json — nothing to execute', outputOpts);\n78\t        process.exitCode = 1;\n79\t        return;\n80\t      }\n81\t\n82\t      if (counts.ready === 0) {\n83\t        fail('No stories ready for execution', outputOpts);\n84\t        process.exitCode = 1;\n85\t        return;\n86\t      }\n87\t\n88\t      info(`Starting autonomous execution — ${counts.ready} ready, ${counts.inProgress} in progress, ${counts.verified} verified, ${counts.done}/${counts.total} done`, outputOpts);\n89\t      // 3. Parse and validate numeric options\n90\t      const maxIterations = parseInt(options.maxIterations, 10);\n91\t      const timeout = parseInt(options.timeout, 10);\n92\t      const iterationTimeout = parseInt(options.iterationTimeout, 10);\n93\t      const calls = parseInt(options.calls, 10);\n94\t      const maxStoryRetries = parseInt(options.maxStoryRetries, 10);\n95\t      if (isNaN(maxIterations) || isNaN(timeout) || isNaN(iterationTimeout) || isNaN(calls) || isNaN(maxStoryRetries)) {\n96\t        fail('Invalid numeric option — --max-iterations, --timeout, --iteration-timeout, --calls, and --max-story-retries must be numbers', outputOpts);\n97\t        process.exitCode = 1;\n98\t        return;\n99\t      }\n100\t\n101\t      // 4. Resolve workflow (embedded -> user patch -> project patch)\n102\t      const projectDir = process.cwd();\n103\t\n104\t      let parsedWorkflow;\n105\t      try {\n106\t        parsedWorkflow = resolveWorkflow({ cwd: projectDir });\n107\t      } catch (err: unknown) {\n108\t        // Fallback: try direct file parsing for backward compatibility\n109\t        const projectWorkflowPath = join(projectDir, '.codeharness', 'workflows', 'default.yaml');\n110\t        const templateWorkflowPath = join(projectDir, 'templates', 'workflows', 'default.yaml');\n111\t        const workflowPath = existsSync(projectWorkflowPath) ? projectWorkflowPath : templateWorkflowPath;\n112\t        try {\n113\t          parsedWorkflow = parseWorkflow(workflowPath);\n114\t        } catch (fallbackErr: unknown) {\n115\t          const msg = err instanceof Error ? err.message : String(err);\n116\t          fail(`Failed to resolve workflow: ${msg}`, outputOpts);\n117\t          process.exitCode = 1;\n118\t          return;\n119\t        }\n120\t      }\n121\t\n122\t      // 5. Resolve agents referenced in workflow\n123\t      const agents: Record<string, SubagentDefinition> = {};\n124\t      try {\n125\t        for (const [, task] of Object.entries(parsedWorkflow.tasks)) {\n126\t          if (!agents[task.agent]) {\n127\t            const resolved = resolveAgent(task.agent, { cwd: projectDir });\n128\t            agents[task.agent] = compileSubagentDefinition(resolved);\n129\t          }\n130\t        }\n131\t      } catch (err: unknown) {\n132\t        const msg = err instanceof Error ? err.message : String(err);\n133\t        fail(`Failed to resolve agents: ${msg}`, outputOpts);\n134\t        process.exitCode = 1;\n135\t        return;\n136\t      }\n137\t\n138\t      // 6. Handle --resume: reset completed or circuit-breaker state so the engine re-enters execution\n139\t      if (options.resume) {\n140\t        const currentState = readWorkflowState(projectDir);\n141\t        if (currentState.phase === 'completed') {\n142\t          writeWorkflowState({ ...currentState, phase: 'idle' }, projectDir);\n143\t          info('Resuming from completed state — phase reset to idle', outputOpts);\n144\t        } else if (currentState.phase === 'circuit-breaker') {\n145\t          writeWorkflowState({\n146\t            ...currentState,\n147\t            phase: 'idle',\n148\t            circuit_breaker: {\n149\t              ...currentState.circuit_breaker,\n150\t              triggered: false,\n151\t              reason: null,\n152\t              // score_history is PRESERVED\n153\t            },\n154\t          }, projectDir);\n155\t          info('Resuming after circuit breaker — previous findings preserved', outputOpts);\n156\t        }\n157\t      }\n158\t\n159\t      // 7. Build EngineConfig and execute\n160\t      const config: EngineConfig = {\n161\t        workflow: parsedWorkflow,\n162\t        agents,\n163\t        sprintStatusPath: join(projectDir, '_bmad-output', 'implementation-artifacts', 'sprint-status.yaml'),\n164\t        issuesPath: join(projectDir, '.codeharness', 'issues.yaml'),\n165\t        runId: `run-${Date.now()}`,\n166\t        projectDir,\n167\t        maxIterations,\n168\t      };\n169\t\n170\t      try {\n171\t        const result = await executeWorkflow(config);\n172\t\n173\t        if (result.success) {\n174\t          ok(`Workflow completed — ${result.storiesProcessed} stories processed, ${result.tasksCompleted} tasks completed in ${formatElapsed(result.durationMs)}`, outputOpts);\n175\t        } else {\n176\t          fail(`Workflow failed — ${result.storiesProcessed} stories processed, ${result.tasksCompleted} tasks completed, ${result.errors.length} error(s) in ${formatElapsed(result.durationMs)}`, outputOpts);\n177\t          for (const err of result.errors) {\n178\t            info(`  ${err.taskName}/${err.storyKey}: [${err.code}] ${err.message}`, outputOpts);\n179\t          }\n180\t          process.exitCode = 1;\n181\t        }\n182\t      } catch (err: unknown) {\n183\t        const msg = err instanceof Error ? err.message : String(err);\n184\t        fail(`Workflow engine error: ${msg}`, outputOpts);\n185\t        process.exitCode = 1;\n186\t      }\n187\t    });\n188\t}\n189\t"}]},"parent_tool_use_id":"toolu_01VzsYX8Z6EUQXQkK3QsLHTB","session_id":"b82e0b02-3413-404d-8b3c-c5e48f86089c","uuid":"eba412cf-40be-468c-b07f-b3a60c8c3892","timestamp":"2026-04-03T02:50:30.775Z"}
