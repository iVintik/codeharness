{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AyfZoCScqRq4f9D8QBLvtX","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, type Mock } from 'vitest';\n2\timport { WorktreeManager, WorktreeError, BRANCH_PREFIX, WORKTREE_BASE, AsyncMutex, mergeMutex } from '../worktree-manager.js';\n3\timport type { WorktreeInfo, MergeResult, MergeStrategy } from '../worktree-manager.js';\n4\t\n5\t// Create a mock execAsync that we can control — must use vi.hoisted so it's\n6\t// available when vi.mock factory runs (vi.mock calls are hoisted above imports)\n7\tconst { mockExecAsync } = vi.hoisted(() => ({\n8\t  mockExecAsync: vi.fn(),\n9\t}));\n10\t\n11\t// Mock child_process\n12\tvi.mock('node:child_process', () => ({\n13\t  execSync: vi.fn(),\n14\t  exec: vi.fn(),\n15\t}));\n16\t\n17\t// Mock node:util to return our controllable mockExecAsync\n18\tvi.mock('node:util', () => ({\n19\t  promisify: () => mockExecAsync,\n20\t}));\n21\t\n22\t// Mock node:fs\n23\tvi.mock('node:fs', () => ({\n24\t  existsSync: vi.fn(),\n25\t  readFileSync: vi.fn(),\n26\t  statSync: vi.fn(),\n27\t}));\n28\t\n29\timport { execSync } from 'node:child_process';\n30\timport { existsSync, readFileSync, statSync } from 'node:fs';\n31\t\n32\tconst mockExecSync = execSync as Mock;\n33\tconst mockExistsSync = existsSync as Mock;\n34\tconst mockReadFileSync = readFileSync as Mock;\n35\tconst mockStatSync = statSync as Mock;\n36\t\n37\tdescribe('worktree-manager', () => {\n38\t  let manager: WorktreeManager;\n39\t\n40\t  beforeEach(() => {\n41\t    vi.clearAllMocks();\n42\t    manager = new WorktreeManager('main', '/repo');\n43\t    // Default: no stale state exists\n44\t    mockExistsSync.mockReturnValue(false);\n45\t    // Default: no existing branches\n46\t    mockExecSync.mockReturnValue(Buffer.from(''));\n47\t    // Default: statSync returns a fixed birthtime\n48\t    mockStatSync.mockReturnValue({ birthtime: new Date('2026-01-15T10:00:00Z') });\n49\t  });\n50\t\n51\t  describe('WorktreeError', () => {\n52\t    it('includes stderr in the error (AC #11)', () => {\n53\t      const err = new WorktreeError('something failed', 'fatal: not a git repo');\n54\t      expect(err).toBeInstanceOf(Error);\n55\t      expect(err.name).toBe('WorktreeError');\n56\t      expect(err.message).toBe('something failed');\n57\t      expect(err.stderr).toBe('fatal: not a git repo');\n58\t    });\n59\t  });\n60\t\n61\t  describe('constants', () => {\n62\t    it('branch prefix uses codeharness/ namespace (NFR12)', () => {\n63\t      expect(BRANCH_PREFIX).toBe('codeharness/epic-');\n64\t      expect(BRANCH_PREFIX.startsWith('codeharness/')).toBe(true);\n65\t    });\n66\t\n67\t    it('worktree base is in /tmp', () => {\n68\t      expect(WORKTREE_BASE).toBe('/tmp/codeharness-wt-epic-');\n69\t    });\n70\t  });\n71\t\n72\t  describe('createWorktree', () => {\n73\t    it('creates branch and worktree, returns path (AC #1, #2)', () => {\n74\t      // No stale state\n75\t      mockExecSync.mockImplementation((cmd: string) => {\n76\t        if (cmd.includes('branch --list')) return Buffer.from('');\n77\t        return Buffer.from('');\n78\t      });\n79\t\n80\t      const path = manager.createWorktree('17', 'worktree-manager');\n81\t\n82\t      expect(path).toBe('/tmp/codeharness-wt-epic-17');\n83\t\n84\t      // Verify git commands were called\n85\t      const calls = mockExecSync.mock.calls.map((c: unknown[]) => c[0] as string);\n86\t      expect(calls).toContainEqual(\n87\t        expect.stringContaining('git branch codeharness/epic-17-worktree-manager main'),\n88\t      );\n89\t      expect(calls).toContainEqual(\n90\t        expect.stringContaining('git worktree add /tmp/codeharness-wt-epic-17 codeharness/epic-17-worktree-manager'),\n91\t      );\n92\t    });\n93\t\n94\t    it('uses codeharness/ prefix for branch names (AC #11, NFR12)', () => {\n95\t      mockExecSync.mockReturnValue(Buffer.from(''));\n96\t\n97\t      manager.createWorktree('42', 'my-epic');\n98\t\n99\t      const calls = mockExecSync.mock.calls.map((c: unknown[]) => c[0] as string);\n100\t      const branchCmd = calls.find((c) => c.includes('git branch codeharness/'));\n101\t      expect(branchCmd).toContain('codeharness/epic-42-my-epic');\n102\t    });\n103\t\n104\t    it('sanitizes slug to [a-z0-9-] (edge case)', () => {\n105\t      mockExecSync.mockReturnValue(Buffer.from(''));\n106\t\n107\t      manager.createWorktree('1', 'My Epic With CAPS & Symbols!');\n108\t\n109\t      const calls = mockExecSync.mock.calls.map((c: unknown[]) => c[0] as string);\n110\t      const branchCmd = calls.find((c) => c.startsWith('git branch codeharness/'));\n111\t      expect(branchCmd).toContain('codeharness/epic-1-my-epic-with-caps-symbols');\n112\t    });\n113\t\n114\t    it('cleans up stale branch before re-creating (AC #9)', () => {\n115\t      // Simulate stale branch existing\n116\t      let callCount = 0;\n117\t      mockExecSync.mockImplementation((cmd: string) => {\n118\t        if (cmd.includes('branch --list')) {\n119\t          // First call during cleanup: stale branch exists\n120\t          if (callCount === 0) {\n121\t            callCount++;\n122\t            return Buffer.from('  codeharness/epic-17-old-slug\\n');\n123\t          }\n124\t          return Buffer.from('');\n125\t        }\n126\t        return Buffer.from('');\n127\t      });\n128\t\n129\t      const path = manager.createWorktree('17', 'new-slug');\n130\t      expect(path).toBe('/tmp/codeharness-wt-epic-17');\n131\t\n132\t      // Should have cleaned up the stale branch\n133\t      const calls = mockExecSync.mock.calls.map((c: unknown[]) => c[0] as string);\n134\t      expect(calls).toContainEqual(\n135\t        expect.stringContaining('git branch -D codeharness/epic-17-old-slug'),\n136\t      );\n137\t    });\n138\t\n139\t    it('cleans up stale worktree directory before re-creating (AC #9)', () => {\n140\t      // Simulate worktree directory existing on disk\n141\t      mockExistsSync.mockImplementation((p: string) => {\n142\t        return p === '/tmp/codeharness-wt-epic-17';\n143\t      });\n144\t      mockExecSync.mockReturnValue(Buffer.from(''));\n145\t\n146\t      const path = manager.createWorktree('17', 'slug');\n147\t      expect(path).toBe('/tmp/codeharness-wt-epic-17');\n148\t\n149\t      // Should have tried to remove the stale worktree\n150\t      const calls = mockExecSync.mock.calls.map((c: unknown[]) => c[0] as string);\n151\t      expect(calls).toContainEqual(\n152\t        expect.stringContaining('git worktree remove /tmp/codeharness-wt-epic-17 --force'),\n153\t      );\n154\t    });\n155\t\n156\t    it('throws WorktreeError with stderr on git failure (AC #10)', () => {\n157\t      const gitError = new Error('Command failed');\n158\t      (gitError as unknown as { stderr: Buffer }).stderr = Buffer.from('fatal: not a git repository');\n159\t      mockExecSync.mockImplementation((cmd: string) => {\n160\t        if (cmd.includes('branch --list')) return Buffer.from('');\n161\t        if (cmd.startsWith('git branch codeharness/')) throw gitError;\n162\t        return Buffer.from('');\n163\t      });\n164\t\n165\t      expect(() => manager.createWorktree('17', 'slug')).toThrow(WorktreeError);\n166\t      try {\n167\t        manager.createWorktree('17', 'slug');\n168\t      } catch (err) {\n169\t        expect(err).toBeInstanceOf(WorktreeError);\n170\t        expect((err as WorktreeError).stderr).toContain('fatal: not a git repository');\n171\t        expect((err as WorktreeError).message).toContain('fatal: not a git repository');\n172\t      }\n173\t    });\n174\t\n175\t    it('cleans up partial state on failure — branch created but worktree fails (AC #10)', () => {\n176\t      let branchCreated = false;\n177\t      mockExecSync.mockImplementation((cmd: string) => {\n178\t        if (cmd.includes('branch --list')) return Buffer.from('');\n179\t        if (cmd.startsWith('git branch codeharness/') && !cmd.includes('-D')) {\