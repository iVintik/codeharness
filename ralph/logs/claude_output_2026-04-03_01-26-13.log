{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FsCfPvroAnrFzU5bJpz7GZ","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach } from 'vitest';\n2\timport fs from 'node:fs';\n3\timport path from 'node:path';\n4\t\n5\t// --- Mock the Agent SDK ---\n6\t\n7\tconst { mockQuery } = vi.hoisted(() => ({\n8\t  mockQuery: vi.fn(),\n9\t}));\n10\t\n11\tvi.mock('@anthropic-ai/claude-agent-sdk', () => ({\n12\t  query: mockQuery,\n13\t}));\n14\t\n15\timport {\n16\t  dispatchAgent,\n17\t  DispatchError,\n18\t} from '../agent-dispatch.js';\n19\timport type {\n20\t  DispatchOptions,\n21\t  DispatchResult,\n22\t  DispatchErrorCode,\n23\t} from '../agent-dispatch.js';\n24\timport type { SubagentDefinition } from '../agent-resolver.js';\n25\t\n26\t// --- Helpers ---\n27\t\n28\tfunction makeDefinition(overrides?: Partial<SubagentDefinition>): SubagentDefinition {\n29\t  return {\n30\t    name: 'test-agent',\n31\t    model: 'claude-sonnet-4-20250514',\n32\t    instructions: 'You are a test agent.',\n33\t    disallowedTools: [],\n34\t    bare: true,\n35\t    ...overrides,\n36\t  };\n37\t}\n38\t\n39\t/**\n40\t * Create an async generator that yields the given messages.\n41\t */\n42\tasync function* fakeStream(messages: Array<Record<string, unknown>>) {\n43\t  for (const msg of messages) {\n44\t    yield msg;\n45\t  }\n46\t}\n47\t\n48\tfunction makeSuccessResult(overrides?: Record<string, unknown>) {\n49\t  return {\n50\t    type: 'result',\n51\t    subtype: 'success',\n52\t    result: 'Agent completed the task.',\n53\t    session_id: 'sess-abc-123',\n54\t    duration_ms: 1234,\n55\t    duration_api_ms: 1000,\n56\t    is_error: false,\n57\t    num_turns: 3,\n58\t    total_cost_usd: 0.05,\n59\t    usage: { input_tokens: 100, output_tokens: 200 },\n60\t    modelUsage: {},"}]},"parent_tool_use_id":"toolu_01WdSxiK3fbCWnfhSGLhUtia","session_id":"02876edc-b40e-4eff-87e1-ceab09778e92","uuid":"3a57347f-2901-4174-980f-45901f5a0b94","timestamp":"20