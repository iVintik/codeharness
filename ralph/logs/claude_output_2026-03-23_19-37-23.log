{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012T3MBody5YrQMmUdef7GYv","type":"tool_result","content":"     1→/**\n     2→ * Verification environment management: Docker image lifecycle, clean workspace,\n     3→ * and environment checks for black-box verification.\n     4→ */\n     5→import { execFileSync } from 'node:child_process';\n     6→import { existsSync, mkdirSync, readdirSync, readFileSync, cpSync, rmSync, statSync } from 'node:fs';\n     7→import { join, basename } from 'node:path';\n     8→import { createHash } from 'node:crypto';\n     9→import { info } from '../../lib/output.js';\n    10→import { detectStacks } from '../../lib/stack-detect.js';\n    11→import { readStateWithBody, writeState } from '../../lib/state.js';\n    12→import { isDockerAvailable } from '../../lib/docker.js';\n    13→import type { BuildOptions, BuildResult, CheckResult, ProjectType } from './types.js';\n    14→\n    15→const IMAGE_TAG = 'codeharness-verify';\n    16→const STORY_DIR = '_bmad-output/implementation-artifacts';\n    17→const TEMP_PREFIX = '/tmp/codeharness-verify-';\n    18→const STATE_KEY_DIST_HASH = 'verify_env_dist_hash';\n    19→\n    20→/** Validates that a story key is safe for file paths and container names. */\n    21→export function isValidStoryKey(storyKey: string): boolean {\n    22→  if (!storyKey || storyKey.includes('..') || storyKey.includes('/') || storyKey.includes('\\\\')) {\n    23→    return false;\n    24→  }\n    25→  return /^[a-zA-Z0-9_-]+$/.test(storyKey);\n    26→}\n    27→\n    28→/** Computes a SHA-256 hash of all files in dist/ for cache invalidation. */\n    29→export function computeDistHash(projectDir: string): string | null {\n    30→  const distDir = join(projectDir, 'dist');\n    31→  if (!existsSync(distDir)) return null;\n    32→  const hash = createHash('sha256');\n    33→  const files = collectFiles(distDir).sort();\n    34→  for (const file of files) {\n    35→    hash.update(file.slice(distDir.length));\n    36→    hash.update(readFileSync(file));\n    37→  }\n    38→  return hash.digest('hex');\n    39→}\n    40→\n    41→function collectFiles(dir: string): string[] {\n    42→  const results: string[] = [];\n    43→  for (const entry of readdirSync(dir, { withFileTypes: true })) {\n    44→    const fullPath = join(dir, entry.name);\n    45→    if (entry.isDirectory()) { results.push(...collectFiles(fullPath)); }\n    46→    else { results.push(fullPath); }\n    47→  }\n    48→  return results;\n    49→}\n    50→\n    51→function getStoredDistHash(projectDir: string): string | null {\n    52→  try {\n    53→    const { state } = readStateWithBody(projectDir);\n    54→    return ((state as unknown as Record<string, unknown>)[STATE_KEY_DIST_HASH] as string) ?? null;\n    55→  } catch { return null; }\n    56→}\n    57→\n    58→function storeDistHash(projectDir: string, hash: string): void {\n    59→  try {\n    60→    const { state, body } = readStateWithBody(projectDir);\n    61→    (state as unknown as Record<string, unknown>)[STATE_KEY_DIST_HASH] = hash;\n    62→    writeState(state, projectDir, body);\n    63→  } catch {\n    64→    info('Could not persist dist hash to state file — cache will not be available until state is initialized');\n    65→  }\n    66→}\n    67→\n    68→/** Detects the project type for verification strategy selection. */\n    69→export function detectProjectType(projectDir: string): ProjectType {\n    70→  // Use detectStacks() (plural) for multi-stack awareness; derive primary from root detection\n    71→  const allStacks = detectStacks(projectDir);\n    72→  const rootDetection = allStacks.find(s => s.dir === '.');\n    73→  const stack = rootDetection ? rootDetection.stack : null;\n    74→  // Prefer nodejs/python when the project has a buildable package — the npm tarball\n    75→  // or Python wheel includes all distributable files. Plugin-only detection is the\n    76→  // fallback for projects that are purely Claude Code plugins with no build artifact.\n    77→  if (stack === 'nodejs') return 'nodejs';\n    78→  if (stack === 'python') return 'python';\n    79→  if (stack === 'rust') return 'rust';\n    80→  if (existsSync(join(projectDir, '.claude-plugin', 'plugin.json'))) return 'plugin';\n    81→  return 'generic';\n    82→}\n    83→\n    84→/** Builds the verification Docker image with cache invalidation. */\n    85→export function buildVerifyImage(options: BuildOptions = {}): BuildResult {\n    86→  const projectDir = options.projectDir ?? process.cwd();\n    87→  if (!isDockerAvailable()) {\n    88→    throw new Error('Docker is not available. Install Docker and ensure the daemon is running.');\n    89→  }\n    90→  const projectType = detectProjectType(projectDir);\n    91→  const currentHash = computeDistHash(projectDir);\n    92→  if (projectType === 'generic' || projectType === 'plugin' || projectType === 'rust') {\n    93→    // Generic, plugin, and Rust projects may not have dist/ — skip hash check\n    94→  } else if (!currentHash) {\n    95→    throw new Error('No dist/ directory found. Run your build command first (e.g., npm run build).');\n    96→  }\n    97→  if (currentHash) {\n    98→    const storedHash = getStoredDistHash(projectDir);\n    99→    if (storedHash === currentHash && dockerImageExists(IMAGE_TAG)) {\n   100→      return { imageTag: IMAGE_TAG, imageSize: getImageSize(IMAGE_TAG), buildTimeMs: 0, cached: true };\n   101→    }\n   102→  }\n   103→  const startTime = Date.now();\n   104→  if (projectType === 'nodejs') { buildNodeImage(projectDir); }\n   105→  else if (projectType === 'python') { buildPythonImage(projectDir); }\n   106→  else if (projectType === 'rust') { buildSimpleImage(projectDir, 'rust', 300_000); }\n   107→  else if (projectType === 'plugin') { buildPluginImage(projectDir); }\n   108→  else { buildSimpleImage(projectDir, 'generic'); }\n   109→  if (currentHash) { storeDistHash(projectDir, currentHash); }\n   110→  return { imageTag: IMAGE_TAG, imageSize: getImageSize(IMAGE_TAG), buildTimeMs: Date.now() - startTime, cached: false };\n   111→}\n   112→\n   113→function buildNodeImage(projectDir: string): void {\n   114→  const packOutput = execFileSync('npm', ['pack', '--pack-destination', '/tmp'], {\n   115→    cwd: projectDir, stdio: 'pipe', timeout: 60_000,\n   116→  }).toString().trim();\n   117→  const lastLine = packOutput.split('\\n').pop()?.trim();\n   118→  if (!lastLine) throw new Error('npm pack produced no output — cannot determine tarball filename.');\n   119→  const tarballName = basename(lastLine);\n   120→  const tarballPath = join('/tmp', tarballName);\n   121→  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   122→  mkdirSync(buildContext, { recursive: true });\n   123→  try {\n   124→    cpSync(tarballPath, join(buildContext, tarballName));\n   125→    cpSync(resolveDockerfileTemplate(projectDir), join(buildContext, 'Dockerfile'));\n   126→    execFileSync('docker', ['build', '-t', IMAGE_TAG, '--build-arg', `TARBALL=${tarballName}`, '.'], {\n   127→      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   128→    });\n   129→  } finally {\n   130→    rmSync(buildContext, { recursive: true, force: true });\n   131→    rmSync(tarballPath, { force: true });\n   132→  }\n   133→}\n   134→\n   135→function buildPythonImage(projectDir: string): void {\n   136→  const distDir = join(projectDir, 'dist');\n   137→  const distFiles = readdirSync(distDir).filter(f => f.endsWith('.tar.gz') || f.endsWith('.whl'));\n   138→  if (distFiles.length === 0) {\n   139→    throw new Error('No distribution files found in dist/. Run your build command first (e.g., python -m build).');\n   140→  }\n   141→  const distFile = distFiles.filter(f => f.endsWith('.tar.gz'))[0] ?? distFiles[0];\n   142→  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   143→  mkdirSync(buildContext, { recursive: true });\n   144→  try {\n   145→    cpSync(join(distDir, distFile), join(buildContext, distFile));\n   146→    cpSync(resolveDockerfileTemplate(projectDir), join(buildContext, 'Dockerfile'));\n   147→    execFileSync('docker', ['build', '-t', IMAGE_TAG, '--build-arg', `TARBALL=${distFile}`, '.'], {\n   148→      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   149→    });\n   150→  } finally {\n   151→    rmSync(buildContext, { recursive: true, force: true });\n   152→  }\n   153→}\n   154→\n   155→/** Creates a clean temp workspace for verification (no src/, tests/, .git/). */\n   156→export function prepareVerifyWorkspace(storyKey: string, projectDir?: string): string {\n   157→  const root = projectDir ?? process.cwd();\n   158→  if (!isValidStoryKey(storyKey)) {\n   159→    throw new Error(`Invalid story key: ${storyKey}. Keys must contain only alphanumeric characters, hyphens, and underscores.`);\n   160→  }\n   161→  const storyFile = join(root, STORY_DIR, `${storyKey}.md`);\n   162→  if (!existsSync(storyFile)) throw new Error(`Story file not found: ${storyFile}`);\n   163→  const workspace = `${TEMP_PREFIX}${storyKey}`;\n   164→  if (existsSync(workspace)) rmSync(workspace, { recursive: true, force: true });\n   165→  mkdirSync(workspace, { recursive: true });\n   166→  cpSync(storyFile, join(workspace, 'story.md'));\n   167→  const readmePath = join(root, 'README.md');\n   168→  if (existsSync(readmePath)) cpSync(readmePath, join(workspace, 'README.md'));\n   169→  const docsDir = join(root, 'docs');\n   170→  if (existsSync(docsDir) && statSync(docsDir).isDirectory()) {\n   171→    cpSync(docsDir, join(workspace, 'docs'), { recursive: true });\n   172→  }\n   173→  mkdirSync(join(workspace, 'verification'), { recursive: true });\n   174→  return workspace;\n   175→}\n   176→\n   177→/** Validates verification environment: image, CLI, observability. */\n   178→export function checkVerifyEnv(): CheckResult {\n   179→  let imageExists = false;\n   180→  let cliWorks = false;\n   181→  let otelReachable = false;\n   182→\n   183→  imageExists = dockerImageExists(IMAGE_TAG);\n   184→  if (!imageExists) return { imageExists, cliWorks, otelReachable };\n   185→  try {\n   186→    execFileSync('docker', ['run', '--rm', IMAGE_TAG, 'codeharness', '--help'], {\n   187→      stdio: 'pipe', timeout: 30_000,\n   188→    });\n   189→    cliWorks = true;\n   190→  } catch { cliWorks = false; }\n   191→  try {\n   192→    execFileSync('docker', [\n   193→      'run', '--rm', '--add-host=host.docker.internal:host-gateway', IMAGE_TAG,\n   194→      'curl', '-sf', '--max-time', '5', 'http://host.docker.internal:4318/v1/status',\n   195→    ], { stdio: 'pipe', timeout: 30_000 });\n   196→    otelReachable = true;\n   197→  } catch { otelReachable = false; }\n   198→  return { imageExists, cliWorks, otelReachable };\n   199→}\n   200→\n   201→/** Cleans up all stale containers matching `codeharness-verify-*` pattern. Idempotent. */\n   202→export function cleanupStaleContainers(): void {\n   203→  try {\n   204→    const output = execFileSync(\n   205→      'docker', ['ps', '-a', '--filter', 'name=codeharness-verify-', '--format', '{{.Names}}'],\n   206→      { stdio: 'pipe', timeout: 15_000 },\n   207→    ).toString('utf-8').trim();\n   208→    if (output.length === 0) return;\n   209→    const containers = output.split('\\n').filter(name => name.length > 0);\n   210→    for (const name of containers) {\n   211→      try {\n   212→        execFileSync('docker', ['rm', '-f', name], { stdio: 'pipe', timeout: 15_000 });\n   213→      } catch { /* container may already be removed */ }\n   214→    }\n   215→  } catch { /* docker not available or no containers — ignore */ }\n   216→}\n   217→\n   218→/** Removes temp workspace and stops/removes the container. Idempotent. */\n   219→export function cleanupVerifyEnv(storyKey: string): void {\n   220→  if (!isValidStoryKey(storyKey)) {\n   221→    throw new Error(`Invalid story key: ${storyKey}. Keys must contain only alphanumeric characters, hyphens, and underscores.`);\n   222→  }\n   223→  const workspace = `${TEMP_PREFIX}${storyKey}`;\n   224→  const containerName = `codeharness-verify-${storyKey}`;\n   225→  if (existsSync(workspace)) rmSync(workspace, { recursive: true, force: true });\n   226→  try { execFileSync('docker', ['stop', containerName], { stdio: 'pipe', timeout: 15_000 }); }\n   227→  catch { /* container may not exist */ }\n   228→  try { execFileSync('docker', ['rm', '-f', containerName], { stdio: 'pipe', timeout: 15_000 }); }\n   229→  catch { /* container may not exist */ }\n   230→}\n   231→\n   232→function buildPluginImage(projectDir: string): void {\n   233→  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   234→  mkdirSync(buildContext, { recursive: true });\n   235→  try {\n   236→    // Copy plugin source into build context\n   237→    const pluginDir = join(projectDir, '.claude-plugin');\n   238→    cpSync(pluginDir, join(buildContext, '.claude-plugin'), { recursive: true });\n   239→    // Copy any commands, hooks, knowledge, skills directories if they exist\n   240→    for (const dir of ['commands', 'hooks', 'knowledge', 'skills']) {\n   241→      const src = join(projectDir, dir);\n   242→      if (existsSync(src) && statSync(src).isDirectory()) {\n   243→        cpSync(src, join(buildContext, dir), { recursive: true });\n   244→      }\n   245→    }\n   246→    cpSync(resolveDockerfileTemplate(projectDir, 'generic'), join(buildContext, 'Dockerfile'));\n   247→    execFileSync('docker', ['build', '-t', IMAGE_TAG, '.'], {\n   248→      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   249→    });\n   250→  } finally {\n   251→    rmSync(buildContext, { recursive: true, force: true });\n   252→  }\n   253→}\n   254→\n   255→function buildSimpleImage(projectDir: string, variant: string, timeout = 120_000): void {\n   256→  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   257→  mkdirSync(buildContext, { recursive: true });\n   258→  try {\n   259→    cpSync(resolveDockerfileTemplate(projectDir, variant), join(buildContext, 'Dockerfile'));\n   260→    execFileSync('docker', ['build', '-t', IMAGE_TAG, '.'], {\n   261→      cwd: buildContext, stdio: 'pipe', timeout,\n   262→    });\n   263→  } finally {\n   264→    rmSync(buildContext, { recursive: true, force: true });\n   265→  }\n   266→}\n   267→\n   268→const DOCKERFILE_VARIANTS: Record<string, string> = {\n   269→  generic: 'Dockerfile.verify.generic',\n   270→  rust: 'Dockerfile.verify.rust',\n   271→};\n   272→\n   273→function resolveDockerfileTemplate(projectDir: string, variant?: string): string {\n   274→  const filename = (variant && DOCKERFILE_VARIANTS[variant]) ?? 'Dockerfile.verify';\n   275→  const local = join(projectDir, 'templates', filename);\n   276→  if (existsSync(local)) return local;\n   277→  const pkgDir = new URL('../../', import.meta.url).pathname;\n   278→  const pkg = join(pkgDir, 'templates', filename);\n   279→  if (existsSync(pkg)) return pkg;\n   280→  throw new Error(`${filename} not found. Ensure templates/${filename} exists.`);\n   281→}\n   282→\n   283→function dockerImageExists(tag: string): boolean {\n   284→  try {\n   285→    execFileSync('docker', ['image', 'inspect', tag], { stdio: 'pipe', timeout: 10_000 });\n   286→    return true;\n   287→  } catch { return false; }\n   288→}\n   289→\n   290→function getImageSize(tag: string): string {\n   291→  try {\n   292→    const output = execFileSync('docker', ['image', 'inspect', tag, '--format', '{{.Size}}'], {\n   293→      stdio: 'pipe', timeout: 10_000,\n   294→    }).toString().trim();\n   295→    const bytes = parseInt(output, 10);\n   296→    if (isNaN(bytes)) return output;\n   297→    if (bytes >= 1_000_000_000) return `${(bytes / 1_000_000_000).toFixed(1)}GB`;\n   298→    if (bytes >= 1_000_000) return `${(bytes / 1_000_000).toFixed(1)}MB`;\n   299→    if (bytes >= 1_000) return `${(bytes / 1_000).toFixed(1)}KB`;\n   300→    return `${bytes}B`;\n   301→  } catch { return 'unknown'; }\n   302→}\n   303→"}]},"parent_tool_use_id":"toolu_017stQocDjYtQWzyiuCXnw1e","session_id":"58ae4f51-bff6-4a66-807a-d4f10c8bdaa3","uuid":"90443971-a9dd-43b8-8fed-b7c2605b4f1d","timestamp":"2026-03-23T15:51:41.604Z"}
