{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q6R4wHJMTGZSU2KvJPyvic","type":"tool_result","content":"     1→/**\n     2→ * Project initialization orchestrator.\n     3→ * Composes sub-steps: stack detection, deps, Docker, BMAD, beads, state, docs, OTLP.\n     4→ */\n     5→\n     6→import { existsSync } from 'node:fs';\n     7→import { basename, join } from 'node:path';\n     8→import { ok as okOutput, fail as failOutput, info, warn, jsonOutput } from '../../lib/output.js';\n     9→import { detectStacks, detectAppType } from '../../lib/stacks/index.js';\n    10→import { readState, writeState, getDefaultState, getStatePath } from '../../lib/state.js';\n    11→import type { HarnessState } from '../../lib/state.js';\n    12→import { instrumentProject } from '../../lib/otlp.js';\n    13→import type { Result } from '../../types/result.js';\n    14→import { ok, fail, isOk } from '../../types/result.js';\n    15→import type { InitOptions, InitResult } from './types.js';\n    16→import { checkDocker, setupDocker } from './docker-setup.js';\n    17→import { installDeps, verifyDeps } from './deps-install.js';\n    18→import { setupBmad, verifyBmadOnRerun } from './bmad-setup.js';\n    19→import { initializeBeads } from './beads-init.js';\n    20→import { scaffoldDocs, getCoverageTool, getStackLabel } from './docs-scaffold.js';\n    21→import { generateDockerfileTemplate } from './dockerfile-template.js';\n    22→\n    23→declare const __PKG_VERSION__: string;\n    24→const HARNESS_VERSION = typeof __PKG_VERSION__ !== 'undefined' ? __PKG_VERSION__ : '0.0.0-dev';\n    25→\n    26→/** Helper: build a fail-status InitResult for early returns */\n    27→function failResult(opts: InitOptions, error: string): InitResult {\n    28→  return {\n    29→    status: 'fail', stack: null, stacks: [], error,\n    30→    enforcement: { frontend: opts.frontend, database: opts.database, api: opts.api },\n    31→    documentation: { agents_md: 'skipped', docs_scaffold: 'skipped', readme: 'skipped' },\n    32→  };\n    33→}\n    34→\n    35→/** Output error and set exit code for validation/critical failures */\n    36→function emitError(error: string, isJson: boolean): void {\n    37→  if (isJson) { jsonOutput({ status: 'fail', error }); } else { failOutput(error); }\n    38→  process.exitCode = 1;\n    39→}\n    40→\n    41→/** Main project initialization orchestrator. Never throws — returns fail() on unexpected errors. */\n    42→export async function initProject(opts: InitOptions): Promise<Result<InitResult>> {\n    43→  try {\n    44→    return await initProjectInner(opts);\n    45→  } catch (err) {\n    46→    const message = err instanceof Error ? err.message : String(err);\n    47→    return fail(`Unexpected init error: ${message}`);\n    48→  }\n    49→}\n    50→\n    51→async function initProjectInner(opts: InitOptions): Promise<Result<InitResult>> {\n    52→  const { projectDir, json: isJson = false } = opts;\n    53→  const result: InitResult = {\n    54→    status: 'ok', stack: null, stacks: [],\n    55→    enforcement: { frontend: opts.frontend, database: opts.database, api: opts.api },\n    56→    documentation: { agents_md: 'skipped', docs_scaffold: 'skipped', readme: 'skipped' },\n    57→  };\n    58→\n    59→  // --- Idempotent re-run check ---\n    60→  const rerunResult = handleRerun(opts, result);\n    61→  if (rerunResult !== null) return rerunResult;\n    62→\n    63→  // --- Remote endpoint URL validation ---\n    64→  const urlError = validateRemoteUrls(opts);\n    65→  if (urlError !== null) { emitError(urlError, isJson); return ok(failResult(opts, urlError)); }\n    66→\n    67→  // --- Stack detection ---\n    68→  // Call detectStacks() once; derive primary root stack from it to avoid double filesystem scan\n    69→  const allStacks = detectStacks(projectDir);\n    70→  const rootDetection = allStacks.find(s => s.dir === '.');\n    71→  const stack = rootDetection ? rootDetection.stack : null;\n    72→  if (!stack && !isJson) warn('No recognized stack detected');\n    73→  result.stack = stack;\n    74→  result.stacks = [...new Set(allStacks.map(s => s.stack))];\n    75→  const appType = detectAppType(projectDir, stack);\n    76→  result.app_type = appType;\n    77→  if (!isJson) {\n    78→    if (result.stacks.length > 0) {\n    79→      info(`Stack detected: ${getStackLabel(result.stacks)}`);\n    80→    } else if (stack) {\n    81→      info(`Stack detected: ${getStackLabel(stack)}`);\n    82→    }\n    83→    info(`App type: ${appType}`);\n    84→  }\n    85→\n    86→  // --- Dockerfile template generation ---\n    87→  const dfResult = generateDockerfileTemplate(projectDir, allStacks);\n    88→  if (isOk(dfResult)) {\n    89→    result.dockerfile = { generated: true, stack: dfResult.data.stack, stacks: dfResult.data.stacks };\n    90→    if (!isJson) info(`Generated Dockerfile for ${dfResult.data.stacks.join('+') || dfResult.data.stack} project.`);\n    91→  } else {\n    92→    if (!isJson) info('Dockerfile already exists -- skipping template generation.');\n    93→  }\n    94→\n    95→  // --- Docker check ---\n    96→  const dockerCheck = checkDocker({ observability: opts.observability, otelEndpoint: opts.otelEndpoint, logsUrl: opts.logsUrl, opensearchUrl: opts.opensearchUrl, isJson });\n    97→  if (!isOk(dockerCheck)) return fail(dockerCheck.error);\n    98→  const { available: dockerAvailable, criticalFailure, dockerResult: criticalDockerResult } = dockerCheck.data;\n    99→  if (criticalFailure) {\n   100→    result.status = 'fail'; result.error = 'Docker not installed'; result.docker = criticalDockerResult;\n   101→    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); }\n   102→    else { failOutput('Docker not installed'); info('\\u2192 Install Docker: https://docs.docker.com/engine/install/'); info('\\u2192 Or skip observability: codeharness init --no-observability'); }\n   103→    process.exitCode = 1;\n   104→    return ok(result);\n   105→  }\n   106→\n   107→  // --- Dependency install ---\n   108→  const depResult = installDeps({ isJson });\n   109→  if (!isOk(depResult)) {\n   110→    result.status = 'fail'; result.error = depResult.error;\n   111→    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); } else { info('Critical dependency failed — aborting init'); }\n   112→    process.exitCode = 1;\n   113→    return ok(result);\n   114→  }\n   115→  result.dependencies = depResult.data;\n   116→\n   117→  // --- Beads initialization ---\n   118→  result.beads = initializeBeads(projectDir, isJson);\n   119→\n   120→  // --- BMAD installation ---\n   121→  const bmadResult = setupBmad({ projectDir, isJson });\n   122→  if (isOk(bmadResult)) result.bmad = bmadResult.data;\n   123→\n   124→  // --- State file creation ---\n   125→  let state: HarnessState = getDefaultState(stack);\n   126→  state.harness_version = HARNESS_VERSION;\n   127→  state.initialized = true;\n   128→  state.app_type = appType;\n   129→  state.enforcement = { frontend: opts.frontend, database: opts.database, api: opts.api };\n   130→  // Per-stack coverage detection: build tools map keyed by stack name, primary stack's tool for backward compat\n   131→  const coverageTools: Record<string, string> = {};\n   132→  for (const detection of allStacks) {\n   133→    coverageTools[detection.stack] = getCoverageTool(detection.stack);\n   134→  }\n   135→  state.coverage.tool = getCoverageTool(stack);\n   136→  state.coverage.tools = coverageTools;\n   137→  // Persist all detected stacks (not just the primary root stack)\n   138→  state.stacks = result.stacks as import('../../lib/stacks/index.js').StackName[];\n   139→  writeState(state, projectDir);\n   140→  if (!isJson) okOutput('State file: .claude/codeharness.local.md created');\n   141→\n   142→  // --- Documentation scaffold ---\n   143→  const docsResult = await scaffoldDocs({ projectDir, stack, stacks: allStacks, isJson });\n   144→  if (isOk(docsResult)) result.documentation = docsResult.data;\n   145→\n   146→  // --- OTLP instrumentation ---\n   147→  if (!opts.observability) {\n   148→    result.otlp = { status: 'skipped', packages_installed: false, start_script_patched: false, env_vars_configured: false };\n   149→    if (!isJson) info('OTLP: skipped (--no-observability)');\n   150→  } else {\n   151→    // Per-stack OTLP instrumentation: instrument each detected stack in its directory\n   152→    for (const detection of allStacks) {\n   153→      const stackDir = detection.dir === '.' ? projectDir : join(projectDir, detection.dir);\n   154→      const stackOtlp = instrumentProject(stackDir, detection.stack, { json: isJson, appType });\n   155→      // Primary (root) stack's result goes to result.otlp for backward compat\n   156→      if (detection.dir === '.' && detection.stack === stack) {\n   157→        result.otlp = stackOtlp;\n   158→      }\n   159→    }\n   160→    // Fallback: if primary stack wasn't in allStacks (shouldn't happen), use single-stack call\n   161→    if (!result.otlp) {\n   162→      result.otlp = instrumentProject(projectDir, stack, { json: isJson, appType });\n   163→    }\n   164→  }\n   165→\n   166→  // Re-read state to pick up otlp changes written by instrumentProject\n   167→  try { const u = readState(projectDir); if (u.otlp) state.otlp = u.otlp; } catch { /* ignore */ }\n   168→  if (!state.otlp) {\n   169→    state.otlp = { enabled: true, endpoint: 'http://localhost:4318', service_name: basename(projectDir), mode: 'local-shared' };\n   170→  }\n   171→\n   172→  // --- Docker stack setup ---\n   173→  const dockerSetup = setupDocker({\n   174→    observability: opts.observability, otelEndpoint: opts.otelEndpoint,\n   175→    opensearchUrl: opts.opensearchUrl,\n   176→    logsUrl: opts.logsUrl, metricsUrl: opts.metricsUrl, tracesUrl: opts.tracesUrl,\n   177→    isJson, dockerAvailable, appType, state, projectDir,\n   178→  });\n   179→  if (isOk(dockerSetup)) result.docker = dockerSetup.data.docker;\n   180→\n   181→  // --- Enforcement summary ---\n   182→  if (!isJson) {\n   183→    const e = state.enforcement;\n   184→    const fmt = (v: boolean): string => v ? 'ON' : 'OFF';\n   185→    okOutput(`Enforcement: frontend:${fmt(e.frontend)} database:${fmt(e.database)} api:${fmt(e.api)} observability:ON`);\n   186→    info('Harness initialized. Run: codeharness bridge --epics <path>');\n   187→  }\n   188→  if (isJson) jsonOutput(result as unknown as Record<string, unknown>);\n   189→\n   190→  return ok(result);\n   191→}\n   192→\n   193→function handleRerun(opts: InitOptions, result: InitResult): Result<InitResult> | null {\n   194→  const { projectDir, json: isJson = false } = opts;\n   195→  if (!existsSync(getStatePath(projectDir))) return null;\n   196→\n   197→  try {\n   198→    const existingState = readState(projectDir);\n   199→    const legacyObsDisabled = (existingState.enforcement as Record<string, unknown>).observability === false;\n   200→    if (!existingState.initialized || legacyObsDisabled) {\n   201→      if (legacyObsDisabled && !isJson) info('Observability upgraded from disabled to enabled');\n   202→      return null;\n   203→    }\n   204→    result.stack = existingState.stack;\n   205→    result.stacks = existingState.stacks ?? [];\n   206→    result.enforcement = existingState.enforcement;\n   207→    result.documentation = { agents_md: 'exists', docs_scaffold: 'exists', readme: 'exists' };\n   208→    result.dependencies = verifyDeps(isJson);\n   209→    result.docker = existingState.docker\n   210→      ? { compose_file: existingState.docker.compose_file, stack_running: existingState.docker.stack_running, services: [], ports: existingState.docker.ports }\n   211→      : null;\n   212→    const bmadResult = verifyBmadOnRerun(projectDir, isJson);\n   213→    if (bmadResult) result.bmad = bmadResult;\n   214→    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); }\n   215→    else { info('Harness already initialized — verifying configuration'); okOutput('Configuration verified'); }\n   216→    return ok(result);\n   217→  } catch {\n   218→    return null;\n   219→  }\n   220→}\n   221→\n   222→/** Returns error message string if validation fails, null if OK */\n   223→function validateRemoteUrls(opts: InitOptions): string | null {\n   224→  const remoteUrls = [opts.otelEndpoint, opts.opensearchUrl, opts.logsUrl, opts.metricsUrl, opts.tracesUrl].filter(Boolean) as string[];\n   225→  for (const url of remoteUrls) {\n   226→    if (!/^https?:\\/\\//i.test(url)) return `Invalid URL: '${url}' \\u2014 must start with http:// or https://`;\n   227→  }\n   228→  if (opts.otelEndpoint && (opts.logsUrl || opts.metricsUrl || opts.tracesUrl)) {\n   229→    return 'Cannot combine --otel-endpoint with --logs-url/--metrics-url/--traces-url';\n   230→  }\n   231→  const hasAny = opts.logsUrl || opts.metricsUrl || opts.tracesUrl;\n   232→  if (hasAny && !(opts.logsUrl && opts.metricsUrl && opts.tracesUrl)) {\n   233→    return 'When using remote backends, all three are required: --logs-url, --metrics-url, --traces-url';\n   234→  }\n   235→  return null;\n   236→}\n   237→"}]},"parent_tool_use_id":"toolu_01NQFJhfdisZwxGgfMvJomZh","session_id":"01d3be87-3cff-45e1-920c-7390a9e4093c","uuid":"86ce326a-69dd-4b8c-a634-03a00ffead86","timestamp":"2026-03-24T09:58:27.572Z"}
