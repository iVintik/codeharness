{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013mT6z5SFUMeHHfvaDc1MTR","type":"tool_result","content":"     1→#!/bin/bash\n     2→# codeharness: PostToolUse hook for Bash tool\n     3→# After test runs, prompts agent to query VictoriaLogs for errors.\n     4→# Must complete within 500ms (NFR1).\n     5→# Canonical pattern: valid JSON output always, fail open on errors.\n     6→\n     7→# Error trap: fail open on script errors\n     8→trap 'exit 0' ERR\n     9→\n    10→STATE_FILE=\".claude/codeharness.local.md\"\n    11→\n    12→# Fail open: if harness not initialized, allow silently\n    13→if [ ! -f \"$STATE_FILE\" ]; then\n    14→  echo \"[WARN] State file not found — skipping post-test check\" >&2\n    15→  exit 0\n    16→fi\n    17→\n    18→# Read hook input to check what command was run\n    19→HOOK_INPUT=$(cat)\n    20→# Extract command value; if extraction fails, allow silently (fail open)\n    21→COMMAND=$(echo \"$HOOK_INPUT\" | grep -o '\"command\"[[:space:]]*:[[:space:]]*\"[^\"]*\"' 2>/dev/null | head -1 | sed 's/.*\"command\"[[:space:]]*:[[:space:]]*\"//' | sed 's/\"$//' || true)\n    22→\n    23→if [ -z \"$COMMAND\" ]; then\n    24→  # Could not parse command from hook input — fail open\n    25→  exit 0\n    26→fi\n    27→\n    28→# Only act on test commands\n    29→case \"$COMMAND\" in\n    30→  *\"npm test\"*|*\"npm run test\"*|*\"pytest\"*|*\"jest\"*|*\"vitest\"*|*\"cargo test\"*|*\"go test\"*|*\"bats \"*)\n    31→    ;;\n    32→  *)\n    33→    # Not a test command, allow silently\n    34→    exit 0\n    35→    ;;\n    36→esac\n    37→\n    38→# Create beads issue if bd is available and test output suggests failures\n    39→if command -v bd >/dev/null 2>&1; then\n    40→  # Check if hook input contains failure indicators\n    41→  TEST_OUTPUT=$(echo \"$HOOK_INPUT\" | grep -o '\"output\"[[:space:]]*:[[:space:]]*\"[^\"]*\"' 2>/dev/null | head -1 || true)\n    42→  if echo \"$TEST_OUTPUT\" | grep -qiE '(fail|error|FAIL|ERROR)' 2>/dev/null; then\n    43→    GAP_ID=\"[gap:test-failure:$(date +%Y-%m-%d)]\"\n    44→    # Dedup check: skip if issue with this gap-id already exists (fail open on slow bd list)\n    45→    # Timeout ensures hook stays within 500ms NFR — if bd list is slow, skip dedup and create\n    46→    if timeout 0.3 bd list --json 2>/dev/null | grep -qF \"$GAP_ID\" 2>/dev/null; then\n    47→      : # Issue already exists, skip creation\n    48→    else\n    49→      bd create \"Test failures detected in session $(date +%Y-%m-%d)\" --type bug --description \"$GAP_ID\" 2>/dev/null || true\n    50→    fi\n    51→  fi\n    52→fi\n    53→\n    54→# Observability is ON — prompt agent to query logs\n    55→if [ -n \"${CLAUDE_PLUGIN_ROOT:-}\" ] && [ -x \"${CLAUDE_PLUGIN_ROOT}/bin/codeharness\" ]; then\n    56→  HARNESS_CLI=\"${CLAUDE_PLUGIN_ROOT}/bin/codeharness\"\n    57→else\n    58→  HARNESS_CLI=\"codeharness\"\n    59→fi\n    60→\n    61→# Read service_name directly from state file for scoped queries (fail open if unavailable)\n    62→# Avoids Node.js CLI startup latency to stay within 500ms NFR\n    63→SERVICE_NAME=$(grep 'service_name:' \"$STATE_FILE\" 2>/dev/null | head -1 | sed 's/.*service_name:[[:space:]]*//' | tr -d '\"' || true)\n    64→if [ -n \"$SERVICE_NAME\" ]; then\n    65→  QUERY=\"level:error%20AND%20service_name:${SERVICE_NAME}\"\n    66→else\n    67→  QUERY=\"level:error\"\n    68→fi\n    69→\n    70→echo \"{\\\"message\\\": \\\"Tests complete. Query VictoriaLogs for errors:\\\\n-> curl 'http://localhost:9428/select/logsql/query?query=${QUERY}&start=5m'\\\\n-> Then run: ${HARNESS_CLI} state set session_flags.logs_queried true\\\"}\"\n    71→exit 0\n    72→"}]},"parent_tool_use_id":"toolu_01HT5DTtnKuNpCvNvjzkcPm4","session_id":"f7a66acd-0cc1-40de-a592-d59e75273c0b","uuid":"7aac09d0-e0ad-4d0f-83d3-a9e88628a543","timestamp":"2026-03-20T05:50:39.505Z"}
