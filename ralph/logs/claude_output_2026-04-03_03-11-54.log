{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018U4mzzpbFHpQdJqFtAnCDz","type":"tool_result","content":"1\t/**\n2\t * Status command — thin wrapper that delegates to src/modules/status/.\n3\t * Handles only CLI arg parsing and dispatching; all logic lives in the module.\n4\t */\n5\t\n6\timport { Command } from 'commander';\n7\timport {\n8\t  handleFullStatus,\n9\t  handleDockerCheck,\n10\t  handleHealthCheck,\n11\t  handleStoryDrillDown,\n12\t} from '../modules/status/index.js';\n13\t\n14\t// Re-export public types and utilities for backward compatibility\n15\texport {\n16\t  buildScopedEndpoints,\n17\t  resolveEndpoints,\n18\t  DEFAULT_ENDPOINTS,\n19\t} from '../modules/status/index.js';\n20\texport type { EndpointUrls, ScopedEndpointUrls } from '../modules/status/index.js';\n21\t\n22\tinterface StatusOptions {\n23\t  checkDocker?: boolean;\n24\t  check?: boolean;\n25\t  story?: string;\n26\t}\n27\t\n28\texport function registerStatusCommand(program: Command): void {\n29\t  program\n30\t    .command('status')\n31\t    .description('Show current harness status and health')\n32\t    .option('--check-docker', 'Check Docker stack health')\n33\t    .option('--check', 'Run health checks with pass/fail exit code')\n34\t    .option('--story <id>', 'Show detailed status for a specific story')\n35\t    .action(async (options: StatusOptions, cmd: Command) => {\n36\t      const opts = cmd.optsWithGlobals() as { json?: boolean };\n37\t      const isJson = opts.json === true;\n38\t\n39\t      if (options.story) {\n40\t        handleStoryDrillDown(options.story, isJson);\n41\t        return;\n42\t      }\n43\t\n44\t      if (options.checkDocker) {\n45\t        await handleDockerCheck(isJson);\n46\t        return;\n47\t      }\n48\t\n49\t      if (options.check) {\n50\t        await handleHealthCheck(isJson);\n51\t        return;\n52\t      }\n53\t\n54\t      handleFullStatus(isJson);\n55\t    });\n56\t}\n57\t"}]},"parent_tool_use_id":"toolu_01ELiUhcroCmkW9Cb6Be3ouH","session_id":"452c48b4-eed2-4c96-83e9-8c71df0bbdac","uuid":"b5c2a9b7-e68f-42cd-9c3c-8ac2a3e2d15e","timestamp":"2026-04-02T23:18:03.074Z"}
