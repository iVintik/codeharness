{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012aUcPpkMWuJJtK8NSiYuE1","type":"tool_result","content":"1\timport { existsSync } from 'node:fs';\n2\timport { join } from 'node:path';\n3\timport { Command } from 'commander';\n4\timport { fail, info, ok } from '../lib/output.js';\n5\timport { isDockerAvailable } from '../lib/docker/index.js';\n6\timport { cleanupContainers } from '../modules/infra/index.js';\n7\timport { getSprintState, readSprintStatusFromState, reconcileState } from '../modules/sprint/index.js';\n8\timport { countStories, formatElapsed } from '../lib/run-helpers.js';\n9\timport { parseWorkflow, resolveWorkflow } from '../lib/workflow-parser.js';\n10\timport { resolveAgent, compileSubagentDefinition } from '../lib/agent-resolver.js';\n11\timport { executeWorkflow } from '../lib/workflow-engine.js';\n12\timport { readWorkflowState, writeWorkflowState } from '../lib/workflow-state.js';\n13\timport { WorktreeManager } from '../lib/worktree-manager.js';\n14\timport { LanePool } from '../lib/lane-pool.js';\n15\timport type { EpicDescriptor, ExecuteEpicFn, LaneEvent } from '../lib/lane-pool.js';\n16\timport type { EngineConfig } from '../lib/workflow-engine.js';\n17\timport type { SubagentDefinition } from '../lib/agent-resolver.js';\n18\timport type { SprintState } from '../types/state.js';\n19\t\n20\t/** Resolves the plugin directory path (.claude/ in project root). */\n21\texport function resolvePluginDir(): string {\n22\t  return join(process.cwd(), '.claude');\n23\t}\n24\t\n25\t// Re-export helpers that tests import from run.ts\n26\texport { countStories } from '../lib/run-helpers.js';\n27\t\n28\t/**\n29\t * Extract the epic ID from a story key.\n30\t * Story keys follow the pattern `{epicId}-{storyNum}-{slug}`,\n31\t * e.g. `17-1-foo` -> epic `17`, `17-2-bar` -> epic `17`.\n32\t */\n33\texport function extractEpicId(storyKey: string): string {\n34\t  const match = storyKey.match(/^(\\d+)-/);\n35\t  return match ? match[1] : storyKey;\n36\t}\n37\t\n38\t/**\n39\t * Build EpicDescriptor[] from sprint state.\n40\t * Groups stories by epic ID, filters out epics with status 'done',\n41\t * and returns descriptors sorted by epic ID.\n42\t */\n43\texport function buildEpicDescriptors(state: SprintState): EpicDescriptor[] {\n44\t  const epicMap = new Map<string, string[]>();\n45\t  for (const storyKey of Object.keys(state.stories)) {\n46\t    const epicId = extractEpicId(storyKey);\n47\t    if (!epicMap.has(epicId)) epicMap.set(epicId, []);\n48\t    epicMap.get(epicId)!.push(storyKey);\n49\t  }\n50\t\n51\t  return [...epicMap.entries()]\n52\t    .filter(([epicId]) => {\n53\t      const epicState = state.epics[`epic-${epicId}`];\n54\t      return !epicState || epicState.status !== 'done';\n55\t    })\n56\t    .map(([epicId, stories]) => ({\n57\t      id: epicId,\n58\t      slug: `epic-${epicId}`,\n59\t      stories,\n60\t    }));\n61\t}\n62\t\n63\texport function registerRunCommand(program: Command): void {\n64\t  program\n65\t    .command('run')\n66\t    .description('Execute the autonomous coding loop')\n67\t    .option('--max-iterations <n>', 'Maximum loop iterations', '50')\n68\t    .option('--timeout <seconds>', 'Total loop timeout in seconds', '43200')\n69\t    .option('--iteration-timeout <minutes>', 'Per-iteration timeout in minutes', '30')\n70\t    .option('--quiet', 'Suppress terminal output (background mode)', false)\n71\t    .option('--calls <n>', 'Max API calls per hour', '100')\n72\t    .option('--max-story-retries <n>', 'Max retries per story before flagging', '10')\n73\t    .option('--reset', 'Clear retry counters, flagged stories, and circuit breaker before starting', false)\n74\t    .option('--resume', 'Resume from last checkpoint (engine resumes by default)', false)\n75\t    .option('--workflow <name>', 'Workflow name to load (default: \"default\")')\n76\t    .action(async (options, cmd) => {\n77\t      const globalOpts = cmd.optsWithGlobals();\n78\t      const isJson = !!globalOpts.json;\n79\t      const outputOpts = { json: isJson };\n80\t\n81\t      // 1. Resolve plugin directory\n82\t      const pluginDir = resolvePluginDir();\n83\t      if (!existsSync(pluginDir)) {\n84\t        fail('Plugin directory not found — run codeharness init first', outputOpts);\n85\t        process.exitCode = 1;\n86\t        return;\n87\t      }\n88\t\n89\t      // 1b. Reconcile state (best-effort — failures warn but don't abort)\n90\t      const reconciliation = reconcileState();\n91\t      if (reconciliation.success && reconciliation.data.corrections.length > 0) {\n92\t        for (const correction of reconciliation.data.corrections) {\n93\t          info(`[INFO] Reconciled: ${correction}`, outputOpts);\n94\t        }\n95\t      } else if (!reconciliation.success) {\n96\t        info(`[WARN] State reconciliation failed: ${reconciliation.error}`, outputOpts);\n97\t      }\n98\t\n99\t      // 1c. Docker pre-flight: fail fast if Docker unavailable\n100\t      if (!isDockerAvailable()) {\n101\t        fail('[FAIL] Docker not available — install Docker or start the daemon', outputOpts);\n102\t        process.exitCode = 1;\n103\t        return;\n104\t      }\n105\t      // 1d. Orphan container cleanup (best-effort — failures warn but don't abort)\n106\t      const cleanup = cleanupContainers();\n107\t      if (cleanup.success && cleanup.data.containersRemoved > 0) {\n108\t        info(`[INFO] Cleaned up ${cleanup.data.containersRemoved} orphaned container(s): ${cleanup.data.names.join(', ')}`, outputOpts);\n109\t      } else if (!cleanup.success) {\n110\t        info(`[WARN] Container cleanup failed: ${cleanup.error}`, outputOpts);\n111\t      }\n112\t      // 2. Read sprint status for story count (from sprint-state.json)\n113\t      const statuses = readSprintStatusFromState();\n114\t      const counts = countStories(statuses);\n115\t\n116\t      if (counts.total === 0) {\n117\t        fail('No stories found in sprint-state.json — nothing to execute', outputOpts);\n118\t        process.exitCode = 1;\n119\t        return;\n120\t      }\n121\t\n122\t      if (counts.ready === 0) {\n123\t        fail('No stories ready for execution', outputOpts);\n124\t        process.exitCode = 1;\n125\t        return;\n126\t      }\n127\t\n128\t      info(`Starting autonomous execution — ${counts.ready} ready, ${counts.inProgress} in progress, ${counts.verified} verified, ${counts.done}/${counts.total} done`, outputOpts);\n129\t      // 3. Parse and validate numeric options\n130\t      const maxIterations = parseInt(options.maxIterations, 10);\n131\t      const timeout = parseInt(options.timeout, 10);\n132\t      const iterationTimeout = parseInt(options.iterationTimeout, 10);\n133\t      const calls = parseInt(options.calls, 10);\n134\t      const maxStoryRetries = parseInt(options.maxStoryRetries, 10);\n135\t      if (isNaN(maxIterations) || isNaN(timeout) || isNaN(iterationTimeout) || isNaN(calls) || isNaN(maxStoryRetries)) {\n136\t        fail('Invalid numeric option — --max-iterations, --timeout, --iteration-timeout, --calls, and --max-story-retries must be numbers', outputOpts);\n137\t        process.exitCode = 1;\n138\t        return;\n139\t      }\n140\t\n141\t      // 4. Resolve workflow (embedded -> user patch -> project patch)\n142\t      const projectDir = process.cwd();\n143\t      const workflowName = options.workflow ?? 'default';\n144\t\n145\t      // Validate workflow name: only alphanumeric, hyphens, underscores allowed\n146\t      if (!/^[a-zA-Z0-9_-]+$/.test(workflowName)) {\n147\t        fail(`Invalid workflow name \"${workflowName}\" — only alphanumeric characters, hyphens, and underscores are allowed`, outputOpts);\n148\t        process.exitCode = 1;\n149\t        return;\n150\t      }\n151\t\n152\t      let parsedWorkflow;\n153\t      try {\n154\t        parsedWorkflow = resolveWorkflow({ cwd: projectDir, name: workflowName });\n155\t      } catch (err: unknown) {\n156\t        // Fallback: try direct file parsing for backward compatibility (only for default)\n157\t        if (workflowName !== 'default') {\n158\t          const msg = err instanceof Error ? err.message : String(err);\n159\t          fail(`Failed to resolve workflow: ${msg}`, outputOpts);\n160\t          process.exitCode = 1;\n161\t          return;\n162\t        }\n163\t        const projectWorkflowPath = join(projectDir, '.codeharness', 'workflows', 'default.yaml');\n164\t        const templateWorkflowPath = join(projectDir, 'templates', 'workflows', 'default.yaml');\n165\t        const workflowPath = existsSync(projectWorkflowPath) ? projectWorkflowPath : templateWorkflowPath;\n166\t        try {\n167\t          parsedWorkflow = parseWorkflow(workflowPath);\n168\t        } catch (fallbackErr: unknown) {\n169\t          const msg = fallbackErr instanceof Error ? fallbackErr.message : String(fallbackErr);\n170\t          fail(`Failed to resolve workflow: ${msg}`, outputOpts);\n171\t          process.exitCode = 1;\n172\t          return;\n173\t        }\n174\t      }\n175\t\n176\t      // 5. Resolve agents referenced in workflow\n177\t      const agents: Record<string, SubagentDefinition> = {};\n178\t      try {\n179\t        for (const [, task] of Object.entries(parsedWorkflow.tasks)) {\n180\t          if (task.agent != null && !agents[task.agent]) {\n181\t            const resolved = resolveAgent(task.agent, { cwd: projectDir });\n182\t            agents[task.agent] = compileSubagentDefinition(resolved);\n183\t          }\n184\t        }\n185\t      } catch (err: unknown) {\n186\t        const msg = err instanceof Error ? err.message : String(err);\n187\t        fail(`Failed to resolve agents: ${msg}`, outputOpts);\n188\t        process.exitCode = 1;\n189\t        return;\n190\t      }\n191\t\n192\t      // 6. Handle --resume: reset completed or circuit-breaker state so the engine re-enters execution\n193\t      if (options.resume) {\n194\t        const currentState = readWorkflowState(projectDir);\n195\t        if (currentState.phase === 'completed') {\n196\t          writeWorkflowState({ ...currentState, phase: 'idle' }, projectDir);\n197\t          info('Resuming from completed state — phase reset to idle', outputOpts);\n198\t        } else if (currentState.phase === 'circuit-breaker') {\n199\t          writeWorkflowState({\n200\t            ...currentState,\n201\t            phase: 'idle',\n202\t            circuit_breaker: {\n203\t              ...currentState.circuit_breaker,\n204\t              triggered: false,\n205\t              reason: null,\n206\t              // score_history is PRESERVED\n207\t            },\n208\t          }, projectDir);\n209\t          info('Resuming after circuit breaker — previous findings preserved', outputOpts);\n210\t        }\n211\t      }\n212\t\n213\t      // 7. Build EngineConfig and execute\n214\t      const config: EngineConfig = {\n215\t        workflow: parsedWorkflow,\n216\t        agents,\n217\t        sprintStatusPath: join(projectDir, '_bmad-output', 'implementation-artifacts', 'sprint-status.yaml'),\n218\t        issuesPath: join(projectDir, '.codeharness', 'issues.yaml'),\n219\t        runId: `run-${Date.now()}`,\n220\t        projectDir,\n221\t        maxIterations,\n222\t      };\n223\t\n224\t      // 8. Branch: parallel vs sequential execution\n225\t      const execution = parsedWorkflow.execution;\n226\t      const isParallel = execution?.epic_strategy === 'parallel';\n227\t\n228\t      if (isParallel) {\n229\t        // --- Parallel execution path (AC #1, #2, #4, #5, #9, #12) ---\n230\t        try {\n231\t          const maxParallel = execution.max_parallel ?? 1;\n232\t\n233\t          // Get sprint state for epic discovery (AC #3)\n234\t          const stateResult = getSprintState();\n235\t          if (!stateResult.success) {\n236\t            fail(`Failed to read sprint state for epic discovery: ${stateResult.error}`, outputOpts);\n237\t            process.exitCode = 1;\n238\t            return;\n239\t          }\n240\t\n241\t          const epics = buildEpicDescriptors(stateResult.data);\n242\t          if (epics.length === 0) {\n243\t            info('No pending epics found — nothing to execute in parallel mode', outputOpts);\n244\t            return;\n245\t          }\n246\t\n247\t          // Create worktree manager and lane pool (AC #2, #12)\n248\t          // Parallel mode always uses worktree isolation regardless of execution.isolation\n249\t          const worktreeManager = new WorktreeManager();\n250\t          const pool = new LanePool(worktreeManager, maxParallel);\n251\t\n252\t          // Register lane event logging (AC #10)\n253\t          pool.onEvent((event: LaneEvent) => {\n254\t            switch (event.type) {\n255\t              case 'lane-started':\n256\t                info(`[LANE] Started epic ${event.epicId} in lane ${event.laneIndex}`, outputOpts);\n257\t                break;\n258\t              case 'lane-completed':\n259\t                ok(`[LANE] Epic ${event.epicId} completed in lane ${event.laneIndex}`, outputOpts);\n260\t                break;\n261\t              case 'lane-failed':\n262\t                fail(`[LANE] Epic ${event.epicId} failed in lane ${event.laneIndex}: ${event.error}`, outputOpts);\n263\t                break;\n264\t              case 'epic-queued':\n265\t                info(`[LANE] Epic ${event.epicId} queued for execution`, outputOpts);\n266\t                break;\n267\t            }\n268\t          });\n269\t\n270\t          // Define executeFn: runs engine in worktree (AC #4, #5)\n271\t          const executeFn: ExecuteEpicFn = async (_epicId: string, worktreePath: string) => {\n272\t            const epicConfig: EngineConfig = {\n273\t              ...config,\n274\t              projectDir: worktreePath,\n275\t            };\n276\t            return executeWorkflow(epicConfig);\n277\t          };\n278\t\n279\t          // Start the pool (AC #9: max_parallel=1 still runs through pool)\n280\t          const poolResult = await pool.startPool(epics, executeFn);\n281\t\n282\t          // Safety net: check for remaining worktrees (AC #11)\n283\t          const remainingWorktrees = worktreeManager.listWorktrees();\n284\t          if (remainingWorktrees.length > 0) {\n285\t            info(`[WARN] ${remainingWorktrees.length} worktree(s) still exist after pool completion`, outputOpts);\n286\t            for (const wt of remainingWorktrees) {\n287\t              info(`  - ${wt.path} (epic ${wt.epicId})`, outputOpts);\n288\t            }\n289\t          }\n290\t\n291\t          // Report results (AC #7)\n292\t          let totalStories = 0;\n293\t          for (const [, epicResult] of poolResult.epicResults) {\n294\t            if (epicResult.engineResult) {\n295\t              totalStories += epicResult.engineResult.storiesProcessed;\n296\t            }\n297\t          }\n298\t\n299\t          const succeeded = [...poolResult.epicResults.values()].filter(r => r.status === 'completed').length;\n300\t          const failed = [...poolResult.epicResults.values()].filter(r => r.status === 'failed').length;\n301\t\n302\t          if (poolResult.success) {\n303\t            ok(`Parallel execution completed — ${poolResult.epicsProcessed} epics (${succeeded} succeeded), ${totalStories} stories processed in ${formatElapsed(poolResult.durationMs)}`, outputOpts);\n304\t          } else {\n305\t            fail(`Parallel execution failed — ${poolResult.epicsProcessed} epics (${succeeded} succeeded, ${failed} failed), ${totalStories} stories processed in ${formatElapsed(poolResult.durationMs)}`, outputOpts);\n306\t            for (const [epicId, epicResult] of poolResult.epicResults) {\n307\t              if (epicResult.status === 'failed') {\n308\t                info(`  Epic ${epicId}: ${epicResult.error}`, outputOpts);\n309\t              }\n310\t            }\n311\t            process.exitCode = 1;\n312\t          }\n313\t        } catch (err: unknown) {\n314\t          const msg = err instanceof Error ? err.message : String(err);\n315\t          fail(`Parallel execution error: ${msg}`, outputOpts);\n316\t          process.exitCode = 1;\n317\t        }\n318\t      } else {\n319\t        // --- Sequential execution path (AC #8) — existing single-engine behavior ---\n320\t        try {\n321\t          const result = await executeWorkflow(config);\n322\t\n323\t          if (result.success) {\n324\t            ok(`Workflow completed — ${result.storiesProcessed} stories processed, ${result.tasksCompleted} tasks completed in ${formatElapsed(result.durationMs)}`, outputOpts);\n325\t          } else {\n326\t            fail(`Workflow failed — ${result.storiesProcessed} stories processed, ${result.tasksCompleted} tasks completed, ${result.errors.length} error(s) in ${formatElapsed(result.durationMs)}`, outputOpts);\n327\t            for (const err of result.errors) {\n328\t              info(`  ${err.taskName}/${err.storyKey}: [${err.code}] ${err.message}`, outputOpts);\n329\t            }\n330\t            process.exitCode = 1;\n331\t          }\n332\t        } catch (err: unknown) {\n333\t          const msg = err instanceof Error ? err.message : String(err);\n334\t          fail(`Workflow engine error: ${msg}`, outputOpts);\n335\t          process.exitCode = 1;\n336\t        }\n337\t      }\n338\t    });\n339\t}\n340\t"}]},"parent_tool_use_id":"toolu_01C74KKbCgdZj2LDCG8nDBR2","session_id":"80ecde4e-3ccc-44de-925d-a2036bf845d1","uuid":"79c49deb-1645-4162-8aae-e207b4fb7db6","timestamp":"2026-04-03T21:23:03.321Z"}
