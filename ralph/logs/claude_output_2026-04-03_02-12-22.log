agent.',\n128\t    disallowedTools: [],\n129\t    bare: true,\n130\t    ...overrides,\n131\t  };\n132\t}\n133\t\n134\tfunction makeTask(overrides?: Partial<ResolvedTask>): ResolvedTask {\n135\t  return {\n136\t    agent: 'dev',\n137\t    scope: 'per-story',\n138\t    session: 'fresh',\n139\t    source_access: true,\n140\t    ...overrides,\n141\t  };\n142\t}\n143\t\n144\tfunction makeConfig(overrides?: Partial<EngineConfig>): EngineConfig {\n145\t  return {\n146\t    workflow: {\n147\t      tasks: {\n148\t        implement: makeTask(),\n149\t        verify: makeTask({ scope: 'per-run', source_access: false }),\n150\t      },\n151\t      flow: ['implement', 'verify'],\n152\t    },\n153\t    agents: {\n154\t      dev: makeDefinition(),\n155\t    },\n156\t    sprintStatusPath: '/project/sprint-status.yaml',\n157\t    runId: 'run-001',\n158\t    projectDir: '/project',\n159\t    ...overrides,\n160\t  };\n161\t}\n162\t\n163\tfunction setupDefaultMocks() {\n164\t  mockReadWorkflowState.mockReturnValue(makeDefaultState());\n165\t  mockWriteWorkflowState.mockImplementation(() => {});\n166\t\n167\t  mockGenerateTraceId.mockReturnValue('ch-run-001-0-implement');\n168\t  mockFormatTracePrompt.mockReturnValue('[TRACE] trace_id=ch-run-001-0-implement');\n169\t  mockRecordTraceId.mockImplementation((traceId: string, state: WorkflowState) => ({\n170\t    ...state,\n171\t    trace_ids: [...(state.trace_ids ?? []), traceId],\n172\t  }));\n173\t\n174\t  mockResolveSessionId.mockReturnValue(undefined);\n175\t  mockRecordSessionId.mockImplementation(\n176\t    (key: { taskName: string; storyKey: string }, sessionId: string, state: WorkflowState) => ({\n177\t      ...state,\n178\t      tasks_completed: [\n179\t        ...state.tasks_completed,\n180\t        {\n181\t          task_name: key.taskName,\n182\t          story_key: key.storyKey,\n183\t          completed_at: '2026-04-03T00:00:00.000Z',\n184\t          session_id: sessionId,\n185\t        },\n186\t      ],\n187\t    }),\n188\t 