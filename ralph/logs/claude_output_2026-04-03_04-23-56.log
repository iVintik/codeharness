{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SpAQmMpmR2sAVSs8S8oGNh","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n2\timport fs from 'node:fs';\n3\timport path from 'node:path';\n4\timport os from 'node:os';\n5\timport YAML from 'yaml';\n6\timport {\n7\t  loadEmbeddedAgent,\n8\t  loadPatch,\n9\t  mergePatch,\n10\t  resolveAgent,\n11\t  compileSubagentDefinition,\n12\t  AgentResolveError,\n13\t} from '../agent-resolver.js';\n14\timport type { ResolvedAgent, AgentPatch } from '../agent-resolver.js';\n15\t\n16\tconst TEMPLATES_DIR = path.resolve(__dirname, '../../../templates/agents');\n17\t\n18\tconst EXPECTED_AGENTS = [\n19\t  'dev', 'qa', 'architect', 'pm', 'sm',\n20\t  'analyst', 'ux-designer', 'tech-writer', 'evaluator',\n21\t];\n22\t\n23\t// --- Helpers ---\n24\t\n25\tfunction makeMinimalAgent(overrides?: Partial<ResolvedAgent>): ResolvedAgent {\n26\t  return {\n27\t    name: 'test-agent',\n28\t    role: { title: 'Test Agent', purpose: 'Testing' },\n29\t    persona: {\n30\t      identity: 'A test agent for unit tests',\n31\t      communication_style: 'Direct and clear',\n32\t      principles: ['Be thorough', 'Be honest'],\n33\t    },\n34\t    ...overrides,\n35\t  };\n36\t}\n37\t\n38\tfunction writeTempYaml(dir: string, relativePath: string, content: unknown): string {\n39\t  const filePath = path.join(dir, relativePath);\n40\t  const dirPath = path.dirname(filePath);\n41\t  fs.mkdirSync(dirPath, { recursive: true });\n42\t  fs.writeFileSync(filePath, YAML.stringify(content), 'utf-8');\n43\t  return filePath;\n44\t}\n45\t\n46\t// --- Tests ---\n47\t\n48\tdescribe('agent-resolver', () => {\n49\t  describe('loadEmbeddedAgent', () => {\n50\t    it('loads dev.yaml and returns valid ResolvedAgent (AC #1)', () => {\n51\t      const agent = loadEmbeddedAgent('dev');\n52\t      expect(agent.name).toBe('dev');\n53\t      expect(agent.role.title).toBeDefined();\n54\t      expect(agent.persona.identity).toBeDefined();\n55\t      expect(agent.persona.communication_style).toBeDefined();\n56\t      expect(Array.isArray(agent.persona.principles)).toBe(true);\n57\t    });\n58\t\n59\t    it('loads evaluator.yaml with disallowedTools (AC #7)', () => {\n60\t      const agent = loadEmbeddedAgent('evaluator');\n61\t      expect(agent.name).toBe('evaluator');\n62\t      expect(agent.disallowedTools).toContain('Edit');\n63\t      expect(agent.disallowedTools).toContain('Write');\n64\t    });\n65\t\n66\t    it('throws AgentResolveError for non-existent embedded agent', () => {\n67\t      expect(() => loadEmbeddedAgent('nonexistent-agent')).toThrow(AgentResolveError);\n68\t      try {\n69\t        loadEmbeddedAgent('nonexistent-agent');\n70\t      } catch (err) {\n71\t        const e = err as AgentResolveError;\n72\t        expect(e.filePath).toContain('nonexistent-agent.yaml');\n73\t        expect(e.errors.length).toBeGreaterThan(0);\n74\t      }\n75\t    });\n76\t\n77\t    it.each(EXPECTED_AGENTS)('loads %s.yaml successfully', (name) => {\n78\t      const agent = loadEmbeddedAgent(name);\n79\t      expect(agent.name).toBe(name);\n80\t    });\n81\t\n82\t    it('throws AgentResolveError with details when schema validation would fail', () => {\n83\t      // Embedded agents in templates/ are always valid, so we test the error constructor\n84\t      // to ensure the schema validation error branch produces the right shape\n85\t      const err = new AgentResolveError(\n86\t        'Schema validation failed for embedded agent test: /name: must be string',\n87\t        '/tmp/test.yaml',\n88\t        [{ path: '/name', message: 'must be string' }],\n89\t      );\n90\t      expect(err.name).toBe('AgentResolveError');\n91\t      expect(err.filePath).toBe('/tmp/test.yaml');\n92\t      expect(err.errors).toHaveLength(1);\n93\t      expect(err.errors[0].path).toBe('/name');\n94\t    });\n95\t\n96\t    it('throws AgentResolveError for path-traversal agent names', () => {\n97\t      expect(() => loadEmbeddedAgent('../../../etc/passwd')).toThrow(AgentResolveError);\n98\t      expect(() => loadEmbeddedAgent('')).toThrow(AgentResolveError);\n99\t      expect(() => loadEmbeddedAgent('foo bar')).toThrow(AgentResolveError);\n100\t    });\n101\t\n102\t    it('covers the YAML parse error path via corrupted embedded file', () => {\n103\t      // We test that the YAML parse error branch is reachable by constructing\n104\t      // the error path directly, since mocking named imports requires module-level vi.mock.\n105\t      // The loadEmbeddedAgent function's YAML parse error branch (lines 135-136) is\n106\t      // defensive code for corrupted template files. We verify the error shape is correct.\n107\t      const err = new AgentResolveError(\n108\t        'Invalid YAML in embedded agent dev: unexpected token',\n109\t        '/templates/agents/dev.yaml',\n110\t        [{ path: '/templates/agents/dev.yaml', message: 'unexpected token' }],\n111\t      );\n112\t      expect(err.name).toBe('AgentResolveError');\n113\t      expect(err.message).toContain('Invalid YAML');\n114\t      expect(err.filePath).toContain('dev.yaml');\n115\t    });\n116\t\n117\t    it('covers the schema validation error path via corrupted embedded file', () => {\n118\t      // The schema validation failure branch (lines 145-149) is defensive code\n119\t      // for corrupted template files that parse as valid YAML but fail schema validation.\n120\t      // We verify the error shape is correct.\n121\t      const err = new AgentResolveError(\n122\t        'Schema validation failed for embedded agent dev: /name: must be string',\n123\t        '/templates/agents/dev.yaml',\n124\t        [{ path: '/name', message: 'must be string' }],\n125\t      );\n126\t      expect(err.name).toBe('AgentResolveError');\n127\t      expect(err.message).toContain('Schema validation failed');\n128\t      expect(err.errors[0].message).toBe('must be string');\n129\t    });\n130\t  });\n131\t\n132\t  describe('loadPatch', () => {\n133\t    it('returns null for non-existent file (silent skip, AC #4)', () => {\n134\t      const result = loadPatch('/tmp/nonexistent-patch-file-xyz.yaml');\n135\t      expect(result).toBeNull();\n136\t    });\n137\t\n138\t    it('loads a valid patch file', () => {\n139\t      const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'agent-resolver-'));\n140\t      try {\n141\t        const patchContent = {\n142\t          extends: 'embedded://dev',\n143\t          overrides: { personality: { traits: { rigor: 0.9 } } },\n144\t        };\n145\t        const patchPath = writeTempYaml(tmpDir, 'dev.patch.yaml', patchContent);\n146\t        const result = loadPatch(patchPath);\n147\t        expect(result).not.toBeNull();\n148\t        expect(result!.extends).toBe('embedded://dev');\n149\t        expect(result!.overrides).toEqual({ personality: { traits: { rigor: 0.9 } } });\n150\t      } finally {\n151\t        fs.rmSync(tmpDir, { recursive: true, force: true });\n152\t      }\n153\t    });\n154\t\n155\t    it('throws AgentResolveError on malformed YAML (AC #5)', () => {\n156\t      const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'agent-resolver-'));\n157\t      try {\n158\t        const patchPath = path.join(tmpDir, 'bad.patch.yaml');\n159\t        fs.writeFileSync(patchPath, '{ invalid yaml: [unterminated', 'utf-8');\n160\t        expect(() => loadPatch(patchPath)).toThrow(AgentResolveError);\n161\t        try {\n162\t          loadPatch(patchPath);\n163\t        } catch (err) {\n164\t          const e = err as AgentResolveError;\n165\t          expect(e.filePath).toBe(patchPath);\n166\t          expect(e.errors.length).toBeGreaterThan(0);\n167\t        }\n168\t      } finally {\n169\t        fs.rmSync(tmpDir, { recursive: true, force: true });\n170\t      }\n171\t    });\n172\t\n173\t    it('throws AgentResolveError when patch file is a scalar (not an object)', () => {\n174\t      const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'agent-resolver-'));\n175\t      try {\n176\t        const patchPath = path.join(tmpDir, 'scalar.patch.yaml');\n177\t        fs.writeFileSync(patchPath, 'just a string', 'utf-8');\n178\t        expect(() => loadPatch(patchPath)).toThrow(AgentResolveError);\n179\t        try {\n180\t          loadPatch(patchPath);\n181\t        } catch (err) {\n182\t          const e = err as AgentResolveError;\n183\t          expect(e.filePath).toBe(patchPath);\n184\t          expect(e.message).toContain('not a valid object');\n185\t        }\n186\t      } finally {\n187\t        fs.rmSync(tmpDir, { recursive: true, force: true });\n188\t      }\n189\t    });\n190\t\n191\t    it('returns null when file exists but is unreadable', () => {\n192\t      const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'agent-resolver-'));\n193\t      try {\n194\t        const patchPath = path.join(tmpDir, 'unreadable.patch.yaml');\n195\t        fs.writeFileSync(patchPath, 'name: test', 'utf-8');\n196\t        // Make file unreadable (mode 0o000)\n197\t        fs.chmodSync(patchPath, 0o000);\n198\t        // On some systems (macOS root), chmod doesn't prevent reading\n199\t        // so this test may not hit the branch; that's acceptable\n200\t        const result = loadPatch(patchPath);\n201\t        // Either null (unreadable) or a valid patch (if chmod didn't work)\n202\t        expect(result === null || (typeof result === 'object')).toBe(true);\n203\t      } finally {\n204\t        // Restore permissions for cleanup\n205\t        try {\n206\t          fs.chmodSync(path.join(tmpDir, 'unreadable.patch.yaml'), 0o644);\n207\t        } catch { /* ignore */ }\n208\t        fs.rmSync(tmpDir, { recursive: true, force: true });\n209\t      }\n210\t    });\n211\t  });\n212\t\n213\t  describe('mergePatch', () => {\n214\t    it('deep-merges overrides onto base (AC #2)', () => {\n215\t      const base: Record<string, unknown> = {\n216\t        name: 'dev',\n217\t        persona: {\n218\t          identity: 'A developer',\n219\t          communication_style: 'Direct',\n220\t          principles: ['Be thorough'],\n221\t        },\n222\t      };\n223\t      const patch: AgentPatch = {\n224\t        extends: 'embedded://dev',\n225\t        overrides: {\n226\t          personality: { traits: { rigor: 0.9 } },\n227\t        },\n228\t      };\n229\t      const result = mergePatch(base, patch);\n230\t      expect(result.name).toBe('dev');\n231\t      expect((result.personality as Record<string, unknown>)).toEqual({ traits: { rigor: 0.9 } });\n232\t      // Original fields preserved\n233\t      expect((result.persona as Record<string, unknown>)).toEqual(base.persona);\n234\t    });\n235\t\n236\t    it('arrays replace entirely (not concatenate)', () => {\n237\t      const base: Record<string, unknown> = {\n238\t        name: 'dev',\n239\t        persona: {\n240\t          identity: 'A developer',\n241\t          communication_style: 'Direct',\n242\t          principles: ['Original principle 1', 'Original principle 2'],\n243\t        },\n244\t      };\n245\t      const patch: AgentPatch = {\n246\t        overrides: {\n247\t          persona: {\n248\t            principles: ['New principle only'],\n249\t          },\n250\t        },\n251\t      };\n252\t      const result = mergePatch(base, patch);\n253\t      const persona = result.persona as Record<string, unknown>;\n254\t      expect(persona.principles).toEqual(['New principle only']);\n255\t    });\n256\t\n257\t    it('scalars replace', () => {\n258\t      const base: Record<string, unknown> = {\n259\t        name: 'dev',\n260\t        role: { title: 'Original', purpose: 'Original purpose' },\n261\t      };\n262\t      const patch: AgentPatch = {\n263\t        overrides: {\n264\t          role: { title: 'Patched' },\n265\t        },\n266\t      };\n267\t      const result = mergePatch(base, patch);\n268\t      const role = result.role as Record<string, unknown>;\n269\t      expect(role.title).toBe('Patched');\n270\t      expect(role.purpose).toBe('Original purpose');\n271\t    });\n272\t\n273\t    it('preserves prompt_patches separately (AC #3)', () => {\n274\t      const base: Record<string, unknown> = { name: 'dev' };\n275\t      const patch: AgentPatch = {\n276\t        prompt_patches: { append: 'Extra instructions here.' },\n277\t      };\n278\t      const result = mergePatch(base, patch);\n279\t      expect(result.prompt_patches).toEqual({ append: 'Extra instructions here.' });\n280\t    });\n281\t\n282\t    it('concatenates prompt_patches.append from multiple patches', () => {\n283\t      const base: Record<string, unknown> = {\n284\t        name: 'dev',\n285\t        prompt_patches: { append: 'First instruction.' },\n286\t      };\n287\t      const patch: AgentPatch = {\n288\t        prompt_patches: { append: 'Second instruction.' },\n289\t      };\n290\t      const result = mergePatch(base, patch);\n291\t      const pp = result.prompt_patches as { append: string };\n292\t      expect(pp.append).toContain('First instruction.');\n293\t      expect(pp.append).toContain('Second instruction.');\n294\t    });\n295\t  });\n296\t\n297\t  describe('resolveAgent', () => {\n298\t    let tmpDir: string;\n299\t\n300\t    beforeEach(() => {\n301\t      tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'agent-resolver-'));\n302\t    });\n303\t\n304\t    afterEach(() => {\n305\t      fs.rmSync(tmpDir, { recursive: true, force: true });\n306\t      vi.restoreAllMocks();\n307\t    });\n308\t\n309\t    it('loads embedded dev.yaml with no patches and returns unchanged (AC #1, #4)', () => {\n310\t      // Point to a cwd with no patches\n311\t      const agent = resolveAgent('dev', { cwd: tmpDir });\n312\t      expect(agent.name).toBe('dev');\n313\t      expect(agent.role.title).toBe('Developer Agent');\n314\t      expect(agent.persona.identity).toBeDefined();\n315\t    });\n316\t\n317\t    it('missing user and project patches are silently skipped (AC #4)', () => {\n318\t      // No patches exist in tmpDir or mocked homedir\n319\t      vi.spyOn(os, 'homedir').mockReturnValue(tmpDir);\n320\t      const agent = resolveAgent('dev', { cwd: tmpDir });\n321\t      expect(agent.name).toBe('dev');\n322\t    });\n323\t\n324\t    it('applies user patch with overrides (AC #2)', () => {\n325\t      const userHome = path.join(tmpDir, 'home');\n326\t      vi.spyOn(os, 'homedir').mockReturnValue(userHome);\n327\t\n328\t      writeTempYaml(userHome, '.codeharness/agents/dev.patch.yaml', {\n329\t        extends: 'embedded://dev',\n330\t        overrides: {\n331\t          personality: { traits: { rigor: 0.9 } },\n332\t        },\n333\t      });\n334\t\n335\t      const agent = resolveAgent('dev', { cwd: tmpDir });\n336\t      expect(agent.name).toBe('dev');\n337\t      expect(agent.personality?.traits.rigor).toBe(0.9);\n338\t    });\n339\t\n340\t    it('applies project patch on top of user patch (AC #3)', () => {\n341\t      const userHome = path.join(tmpDir, 'home');\n342\t      const projectDir = path.join(tmpDir, 'project');\n343\t      vi.spyOn(os, 'homedir').mockReturnValue(userHome);\n344\t\n345\t      writeTempYaml(userHome, '.codeharness/agents/dev.patch.yaml', {\n346\t        extends: 'embedded://dev',\n347\t        overrides: {\n348\t          personality: { traits: { rigor: 0.9 } },\n349\t        },\n350\t      });\n351\t\n352\t      writeTempYaml(projectDir, '.codeharness/agents/dev.patch.yaml', {\n353\t        extends: 'embedded://dev',\n354\t        prompt_patches: { append: 'Use React + Vite.' },\n355\t      });\n356\t\n357\t      const agent = resolveAgent('dev', { cwd: projectDir });\n358\t      expect(agent.name).toBe('dev');\n359\t      expect(agent.personality?.traits.rigor).toBe(0.9);\n360\t      expect(agent.prompt_patches?.append).toBe('Use React + Vite.');\n361\t    });\n362\t\n363\t    it('full 3-layer chain: embedded + user + project (AC #2, #3)', () => {\n364\t      const userHome = path.join(tmpDir, 'home');\n365\t      const projectDir = path.join(tmpDir, 'project');\n366\t      vi.spyOn(os, 'homedir').mockReturnValue(userHome);\n367\t\n368\t      writeTempYaml(userHome, '.codeharness/agents/dev.patch.yaml', {\n369\t        extends: 'embedded://dev',\n370\t        overrides: {\n371\t          personality: { traits: { rigor: 0.85 } },\n372\t        },\n373\t        prompt_patches: { append: 'User-level instruction.' },\n374\t      });\n375\t\n376\t      writeTempYaml(projectDir, '.codeharness/agents/dev.patch.yaml', {\n377\t        extends: 'embedded://dev',\n378\t        overrides: {\n379\t          personality: { traits: { directness: 0.7 } },\n380\t        },\n381\t        prompt_patches: { append: 'Project-level instruction.' },\n382\t      });\n383\t\n384\t      const agent = resolveAgent('dev', { cwd: projectDir });\n385\t      expect(agent.personality?.traits.rigor).toBe(0.85);\n386\t      expect(agent.personality?.traits.directness).toBe(0.7);\n387\t      expect(agent.prompt_patches?.append).toContain('User-level instruction.');\n388\t      expect(agent.prompt_patches?.append).toContain('Project-level instruction.');\n389\t    });\n390\t\n391\t    it('throws AgentResolveError for malformed patch (AC #5)', () => {\n392\t      const userHome = path.join(tmpDir, 'home');\n393\t      vi.spyOn(os, 'homedir').mockReturnValue(userHome);\n394\t\n395\t      const patchDir = path.join(userHome, '.codeharness', 'agents');\n396\t      fs.mkdirSync(patchDir, { recursive: true });\n397\t      fs.writeFileSync(path.join(patchDir, 'dev.patch.yaml'), '{ bad yaml [[[', 'utf-8');\n398\t\n399\t      expect(() => resolveAgent('dev', { cwd: tmpDir })).toThrow(AgentResolveError);\n400\t    });\n401\t\n402\t    it('throws AgentResolveError when patch produces schema-invalid result (AC #5)', () => {\n403\t      const userHome = path.join(tmpDir, 'home');\n404\t      vi.spyOn(os, 'homedir').mockReturnValue(userHome);\n405\t\n406\t      // Patch that adds an invalid field (additionalProperties: false in schema)\n407\t      writeTempYaml(userHome, '.codeharness/agents/dev.patch.yaml', {\n408\t        extends: 'embedded://dev',\n409\t        overrides: {\n410\t          unknownTopLevelField: 'this should fail validation',\n411\t        },\n412\t      });\n413\t\n414\t      expect(() => resolveAgent('dev', { cwd: tmpDir })).toThrow(AgentResolveError);\n415\t    });\n416\t\n417\t    it('loads custom agent directly without patch chain (AC #8)', () => {\n418\t      const projectDir = path.join(tmpDir, 'project');\n419\t      vi.spyOn(os, 'homedir').mockReturnValue(path.join(tmpDir, 'home'));\n420\t\n421\t      const customAgent = makeMinimalAgent({ name: 'my-agent' });\n422\t      writeTempYaml(projectDir, '.codeharness/agents/my-agent.yaml', customAgent);\n423\t\n424\t      const agent = resolveAgent('my-agent', { cwd: projectDir });\n425\t      expect(agent.name).toBe('my-agent');\n426\t      expect(agent.role.title).toBe('Test Agent');\n427\t    });\n428\t\n429\t    it('throws AgentResolveError for invalid custom agent (AC #8, #5)', () => {\n430\t      const projectDir = path.join(tmpDir, 'project');\n431\t      vi.spyOn(os, 'homedir').mockReturnValue(path.join(tmpDir, 'home'));\n432\t\n433\t      // Custom agent missing required fields\n434\t      writeTempYaml(projectDir, '.codeharness/agents/bad-agent.yaml', {\n435\t        name: 'bad-agent',\n436\t        // missing role and persona\n437\t      });\n438\t\n439\t      expect(() => resolveAgent('bad-agent', { cwd: projectDir })).toThrow(AgentResolveError);\n440\t    });\n441\t\n442\t    it('throws AgentResolveError for path-traversal names in resolveAgent', () => {\n443\t      expect(() => resolveAgent('../../etc/passwd', { cwd: tmpDir })).toThrow(AgentResolveError);\n444\t      expect(() => resolveAgent('foo bar', { cwd: tmpDir })).toThrow(AgentResolveError);\n445\t    });\n446\t\n447\t    it('loads custom agent with prompt_patches (stripped before validation)', () => {\n448\t      const projectDir = path.join(tmpDir, 'project');\n449\t      vi.spyOn(os, 'homedir').mockReturnValue(path.join(tmpDir, 'home'));\n450\t\n451\t      const customAgent = {\n452\t        ...makeMinimalAgent({ name: 'custom-pp' }),\n453\t        prompt_patches: { append: 'Custom prompt patch.' },\n454\t      };\n455\t      writeTempYaml(projectDir, '.codeharness/agents/custom-pp.yaml', customAgent);\n456\t\n457\t      const agent = resolveAgent('custom-pp', { cwd: projectDir });\n458\t      expect(agent.name).toBe('custom-pp');\n459\t      expect(agent.prompt_patches?.append).toBe('Custom prompt patch.');\n460\t    });\n461\t\n462\t    it('resolving all 9 embedded agents completes in <200ms (AC #9)', () => {\n463\t      vi.spyOn(os, 'homedir').mockReturnValue(path.join(tmpDir, 'home'));\n464\t\n465\t      const start = performance.now();\n466\t      for (const name of EXPECTED_AGENTS) {\n467\t        resolveAgent(name, { cwd: tmpDir });\n468\t      }\n469\t      const elapsed = performance.now() - start;\n470\t      expect(elapsed).toBeLessThan(200);\n471\t    });\n472\t  });\n473\t\n474\t  describe('compileSubagentDefinition', () => {\n475\t    it('produces correct instructions string (AC #6)', () => {\n476\t      const agent = makeMinimalAgent();\n477\t      const result = compileSubagentDefinition(agent);\n478\t\n479\t      expect(result.name).toBe('test-agent');\n480\t      expect(result.model).toBe('claude-sonnet-4-20250514');\n481\t      expect(result.bare).toBe(true);\n482\t      expect(result.instructions).toContain('You are A test agent for unit tests');\n483\t      expect(result.instructions).toContain('Communication style: Direct and clear');\n484\t      expect(result.instructions).toContain('Principles:');\n485\t      expect(result.instructions).toContain('- Be thorough');\n486\t      expect(result.instructions).toContain('- Be honest');\n487\t    });\n488\t\n489\t    it('includes prompt_patches.append in instructions (AC #6)', () => {\n490\t      const agent = makeMinimalAgent({\n491\t        prompt_patches: { append: 'Run npm build first.' },\n492\t      });\n493\t      const result = compileSubagentDefinition(agent);\n494\t      expect(result.instructions).toContain('Run npm build first.');\n495\t    });\n496\t\n497\t    it('preserves disallowedTools for evaluator (AC #7)', () => {\n498\t      const agent = loadEmbeddedAgent('evaluator');\n499\t      const result = compileSubagentDefinition(agent);\n500\t      expect(result.disallowedTools).toContain('Edit');\n501\t      expect(result.disallowedTools).toContain('Write');\n502\t      expect(result.disallowedTools).toHaveLength(2);\n503\t    });\n504\t\n505\t    it('returns empty disallowedTools when not present', () => {\n506\t      const agent = makeMinimalAgent();\n507\t      const result = compileSubagentDefinition(agent);\n508\t      expect(result.disallowedTools).toEqual([]);\n509\t    });\n510\t\n511\t    it('sets bare: true always (AD2)', () => {\n512\t      const agent = makeMinimalAgent();\n513\t      const result = compileSubagentDefinition(agent);\n514\t      expect(result.bare).toBe(true);\n515\t    });\n516\t\n517\t    it('sets default model', () => {\n518\t      const agent = makeMinimalAgent();\n519\t      const result = compileSubagentDefinition(agent);\n520\t      expect(result.model).toBe('claude-sonnet-4-20250514');\n521\t    });\n522\t\n523\t    it('compiles real embedded dev agent correctly', () => {\n524\t      const agent = loadEmbeddedAgent('dev');\n525\t      const result = compileSubagentDefinition(agent);\n526\t      expect(result.name).toBe('dev');\n527\t      expect(result.instructions).toContain('You are');\n528\t      expect(result.instructions).toContain('Communication style:');\n529\t      expect(result.instructions).toContain('Principles:');\n530\t      expect(result.disallowedTools).toEqual([]);\n531\t    });\n532\t  });\n533\t\n534\t  describe('AgentResolveError', () => {\n535\t    it('has correct name, filePath, and errors', () => {\n536\t      const err = new AgentResolveError('test error', '/tmp/test.yaml', [\n537\t        { path: '/name', message: 'missing' },\n538\t      ]);\n539\t      expect(err.name).toBe('AgentResolveError');\n540\t      expect(err.filePath).toBe('/tmp/test.yaml');\n541\t      expect(err.errors).toHaveLength(1);\n542\t      expect(err.message).toBe('test error');\n543\t    });\n544\t\n545\t    it('defaults errors to empty array', () => {\n546\t      const err = new AgentResolveError('test', '/tmp/x.yaml');\n547\t      expect(err.errors).toEqual([]);\n548\t    });\n549\t  });\n550\t\n551\t  describe('no regressions', () => {\n552\t    it('existing schema validation still works', async () => {\n553\t      const { validateAgentSchema } = await import('../schema-validate.js');\n554\t      const result = validateAgentSchema(makeMinimalAgent());\n555\t      expect(result.valid).toBe(true);\n556\t    });\n557\t\n558\t    it('existing workflow parser still works', async () => {\n559\t      const { parseWorkflow } = await import('../workflow-parser.js');\n560\t      expect(typeof parseWorkflow).toBe('function');\n561\t    });\n562\t  });\n563\t});\n564\t"}]},"parent_tool_use_id":"toolu_01X7ZCkNrtprTmX6J7uq9WM7","session_id":"52ded6f4-857c-404a-a480-19bb12459ee1","uuid":"552a3674-8712-49d3-a292-ccdd7db80525","timestamp":"2026-04-03T00:34:14.798Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011t6v1LNp6ftkNteQ8MyJTj","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach } from 'vitest';\n2\t\n3\t// --- Mocks (must be before imports) ---\n4\t\n5\tvi.mock('../docker/index.js', () => ({\n6\t  isDockerAvailable: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock('../source-isolation.js', () => ({\n10\t  createIsolatedWorkspace: vi.fn(),\n11\t}));\n12\t\n13\tvi.mock('../agent-dispatch.js', () => ({\n14\t  dispatchAgent: vi.fn(),\n15\t}));\n16\t\n17\tvi.mock('../trace-id.js', () => ({\n18\t  formatTracePrompt: vi.fn(),\n19\t}));\n20\t\n21\t// --- Imports ---\n22\t\n23\timport { runEvaluator } from '../evaluator.js';\n24\timport type { EvaluatorOptions, EvaluatorResult } from '../evaluator.js';\n25\timport { isDockerAvailable } from '../docker/index.js';\n26\timport { createIsolatedWorkspace } from '../source-isolation.js';\n27\timport { dispatchAgent } from '../agent-dispatch.js';\n28\timport { formatTracePrompt } from '../trace-id.js';\n29\timport type { SubagentDefinition } from '../agent-resolver.js';\n30\timport type { IsolatedWorkspace } from '../source-isolation.js';\n31\timport type { DispatchResult } from '../agent-dispatch.js';\n32\t\n33\t// --- Helpers ---\n34\t\n35\tfunction makeAgentDef(overrides?: Partial<SubagentDefinition>): SubagentDefinition {\n36\t  return {\n37\t    name: 'evaluator',\n38\t    model: 'claude-sonnet-4-20250514',\n39\t    instructions: 'You are the evaluator.',\n40\t    disallowedTools: ['Edit', 'Write'],\n41\t    bare: true,\n42\t    ...overrides,\n43\t  };\n44\t}\n45\t\n46\tfunction makeMockWorkspace(): IsolatedWorkspace {\n47\t  return {\n48\t    dir: '/tmp/codeharness-verify-test-run',\n49\t    storyFilesDir: '/tmp/codeharness-verify-test-run/story-files',\n50\t    verdictDir: '/tmp/codeharness-verify-test-run/verdict',\n51\t    toDispatchOptions: vi.fn().mockReturnValue({ cwd: '/tmp/codeharness-verify-test-run' }),\n52\t    cleanup: vi.fn().mockResolvedValue(undefined),\n53\t  };\n54\t}\n55\t\n56\tfunction makeOptions(overrides?: Partial<EvaluatorOptions>): EvaluatorOptions {\n57\t  return {\n58\t    runId: 'test-run',\n59\t    storyFiles: ['/path/to/story-1.md', '/path/to/story-2.md'],\n60\t    agentDefinition: makeAgentDef(),\n61\t    ...overrides,\n62\t  };\n63\t}\n64\t\n65\tfunction makeDispatchResult(overrides?: Partial<DispatchResult>): DispatchResult {\n66\t  return {\n67\t    sessionId: 'session-123',\n68\t    success: true,\n69\t    durationMs: 5000,\n70\t    output: '{\"verdict\":\"pass\",\"score\":{\"passed\":2,\"failed\":0,\"unknown\":0,\"total\":2},\"findings\":[]}',\n71\t    ...overrides,\n72\t  };\n73\t}\n74\t\n75\t// --- Tests ---\n76\t\n77\tbeforeEach(() => {\n78\t  vi.clearAllMocks();\n79\t  vi.useRealTimers();\n80\t});\n81\t\n82\tdescribe('runEvaluator', () => {\n83\t  describe('Docker unavailable', () => {\n84\t    it('returns all-UNKNOWN result without throwing when Docker is unavailable', async () => {\n85\t      vi.mocked(isDockerAvailable).mockReturnValue(false);\n86\t\n87\t      const result = await runEvaluator(makeOptions());\n88\t\n89\t      expect(result.dockerAvailable).toBe(false);\n90\t      expect(result.success).toBe(false);\n91\t      expect(result.timedOut).toBe(false);\n92\t      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n93\t\n94\t      const parsed = JSON.parse(result.output);\n95\t      expect(parsed.verdict).toBe('fail');\n96\t      expect(parsed.score.unknown).toBe(2);\n97\t      expect(parsed.score.total).toBe(2);\n98\t      expect(parsed.findings).toHaveLength(2);\n99\t      expect(parsed.findings[0].status).toBe('unknown');\n100\t      expect(parsed.findings[0].evidence.reasoning).toContain('Docker');\n101\t    });\n102\t\n103\t    it('does not create workspace when Docker is unavailable', async () => {\n104\t      vi.mocked(isDockerAvailable).mockReturnValue(false);\n105\t\n106\t      await runEvaluator(makeOptions());\n107\t\n108\t      expect(createIsolatedWorkspace).not.toHaveBeenCalled();\n109\t      expect(dispatchAgent).not.toHaveBeenCalled();\n110\t    });\n111\t  });\n112\t\n113\t  describe('workspace creation', () => {\n114\t    it('creates workspace with correct runId and storyFiles', async () => {\n115\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n116\t      const mockWorkspace = makeMockWorkspace();\n117\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n118\t      vi.mocked(dispatchAgent).mockResolvedValue(makeDispatchResult());\n119\t\n120\t      await runEvaluator(makeOptions({\n121\t        runId: 'my-run-123',\n122\t        storyFiles: ['/a.md', '/b.md'],\n123\t      }));\n124\t\n125\t      expect(createIsolatedWorkspace).toHaveBeenCalledWith({\n126\t        runId: 'my-run-123',\n127\t        storyFiles: ['/a.md', '/b.md'],\n128\t      });\n129\t    });\n130\t  });\n131\t\n132\t  describe('successful dispatch', () => {\n133\t    it('returns agent output and success on successful dispatch', async () => {\n134\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n135\t      const mockWorkspace = makeMockWorkspace();\n136\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n137\t      const dispatchResult = makeDispatchResult({ output: '{\"verdict\":\"pass\"}', success: true });\n138\t      vi.mocked(dispatchAgent).mockResolvedValue(dispatchResult);\n139\t\n140\t      const result = await runEvaluator(makeOptions());\n141\t\n142\t      expect(result.success).toBe(true);\n143\t      expect(result.output).toBe('{\"verdict\":\"pass\"}');\n144\t      expect(result.dockerAvailable).toBe(true);\n145\t      expect(result.timedOut).toBe(false);\n146\t      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n147\t    });\n148\t\n149\t    it('dispatches agent with workspace cwd', async () => {\n150\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n151\t      const mockWorkspace = makeMockWorkspace();\n152\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n153\t      vi.mocked(dispatchAgent).mockResolvedValue(makeDispatchResult());\n154\t\n155\t      await runEvaluator(makeOptions());\n156\t\n157\t      expect(dispatchAgent).toHaveBeenCalledWith(\n158\t        expect.objectContaining({ name: 'evaluator' }),\n159\t        expect.stringContaining('story-files'),\n160\t        expect.objectContaining({ cwd: '/tmp/codeharness-verify-test-run' }),\n161\t      );\n162\t    });\n163\t  });\n164\t\n165\t  describe('trace ID injection', () => {\n166\t    it('appends trace prompt when traceId is provided', async () => {\n167\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n168\t      const mockWorkspace = makeMockWorkspace();\n169\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n170\t      vi.mocked(dispatchAgent).mockResolvedValue(makeDispatchResult());\n171\t      vi.mocked(formatTracePrompt).mockReturnValue('[TRACE] trace_id=ch-run-0-verify');\n172\t\n173\t      await runEvaluator(makeOptions({ traceId: 'ch-run-0-verify' }));\n174\t\n175\t      expect(formatTracePrompt).toHaveBeenCalledWith('ch-run-0-verify');\n176\t      expect(dispatchAgent).toHaveBeenCalledWith(\n177\t        expect.anything(),\n178\t        expect.anything(),\n179\t        expect.objectContaining({\n180\t          appendSystemPrompt: '[TRACE] trace_id=ch-run-0-verify',\n181\t        }),\n182\t      );\n183\t    });\n184\t\n185\t    it('does not set appendSystemPrompt when no traceId', async () => {\n186\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n187\t      const mockWorkspace = makeMockWorkspace();\n188\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n189\t      vi.mocked(dispatchAgent).mockResolvedValue(makeDispatchResult());\n190\t\n191\t      await runEvaluator(makeOptions({ traceId: undefined }));\n192\t\n193\t      expect(formatTracePrompt).not.toHaveBeenCalled();\n194\t      const callArgs = vi.mocked(dispatchAgent).mock.calls[0][2];\n195\t      expect(callArgs?.appendSystemPrompt).toBeUndefined();\n196\t    });\n197\t  });\n198\t\n199\t  describe('timeout handling', () => {\n200\t    it('returns UNKNOWN result with timedOut=true on timeout', async () => {\n201\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n202\t      const mockWorkspace = makeMockWorkspace();\n203\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n204\t\n205\t      // dispatchAgent never resolves\n206\t      vi.mocked(dispatchAgent).mockReturnValue(new Promise(() => {}));\n207\t\n208\t      vi.useFakeTimers();\n209\t\n210\t      const resultPromise = runEvaluator(makeOptions({ timeoutMs: 1000 }));\n211\t\n212\t      // Advance time past the timeout\n213\t      await vi.advanceTimersByTimeAsync(1001);\n214\t\n215\t      const result = await resultPromise;\n216\t\n217\t      expect(result.timedOut).toBe(true);\n218\t      expect(result.success).toBe(false);\n219\t      expect(result.dockerAvailable).toBe(true);\n220\t\n221\t      const parsed = JSON.parse(result.output);\n222\t      expect(parsed.verdict).toBe('fail');\n223\t      expect(parsed.findings[0].status).toBe('unknown');\n224\t      expect(parsed.findings[0].evidence.reasoning).toContain('timed out');\n225\t    });\n226\t\n227\t    it('uses default timeout of 300000ms when timeoutMs not specified', async () => {\n228\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n229\t      const mockWorkspace = makeMockWorkspace();\n230\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n231\t      vi.mocked(dispatchAgent).mockReturnValue(new Promise(() => {}));\n232\t\n233\t      vi.useFakeTimers();\n234\t\n235\t      const resultPromise = runEvaluator(makeOptions());\n236\t\n237\t      // Should not have timed out at 299999ms\n238\t      await vi.advanceTimersByTimeAsync(299_999);\n239\t      // Verify still pending — we can't directly check, but advancing past 300000 should resolve it\n240\t      await vi.advanceTimersByTimeAsync(2);\n241\t\n242\t      const result = await resultPromise;\n243\t      expect(result.timedOut).toBe(true);\n244\t    });\n245\t  });\n246\t\n247\t  describe('cleanup', () => {\n248\t    it('calls cleanup on successful dispatch', async () => {\n249\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n250\t      const mockWorkspace = makeMockWorkspace();\n251\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n252\t      vi.mocked(dispatchAgent).mockResolvedValue(makeDispatchResult());\n253\t\n254\t      await runEvaluator(makeOptions());\n255\t\n256\t      expect(mockWorkspace.cleanup).toHaveBeenCalledTimes(1);\n257\t    });\n258\t\n259\t    it('calls cleanup on dispatch failure', async () => {\n260\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n261\t      const mockWorkspace = makeMockWorkspace();\n262\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n263\t      vi.mocked(dispatchAgent).mockRejectedValue(new Error('SDK crash'));\n264\t\n265\t      await expect(runEvaluator(makeOptions())).rejects.toThrow('SDK crash');\n266\t\n267\t      expect(mockWorkspace.cleanup).toHaveBeenCalledTimes(1);\n268\t    });\n269\t\n270\t    it('calls cleanup on timeout', async () => {\n271\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n272\t      const mockWorkspace = makeMockWorkspace();\n273\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n274\t      vi.mocked(dispatchAgent).mockReturnValue(new Promise(() => {}));\n275\t\n276\t      vi.useFakeTimers();\n277\t\n278\t      const resultPromise = runEvaluator(makeOptions({ timeoutMs: 100 }));\n279\t      await vi.advanceTimersByTimeAsync(101);\n280\t      await resultPromise;\n281\t\n282\t      expect(mockWorkspace.cleanup).toHaveBeenCalledTimes(1);\n283\t    });\n284\t  });\n285\t\n286\t  describe('disallowedTools inherited from agent definition', () => {\n287\t    it('passes agent definition with disallowedTools to dispatchAgent', async () => {\n288\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n289\t      const mockWorkspace = makeMockWorkspace();\n290\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n291\t      vi.mocked(dispatchAgent).mockResolvedValue(makeDispatchResult());\n292\t\n293\t      const agentDef = makeAgentDef({ disallowedTools: ['Edit', 'Write'] });\n294\t      await runEvaluator(makeOptions({ agentDefinition: agentDef }));\n295\t\n296\t      expect(vi.mocked(dispatchAgent).mock.calls[0][0]).toEqual(\n297\t        expect.objectContaining({ disallowedTools: ['Edit', 'Write'] }),\n298\t      );\n299\t    });\n300\t  });\n301\t\n302\t  describe('interface shapes', () => {\n303\t    it('EvaluatorOptions has required fields', () => {\n304\t      // Compile-time check: this would fail to compile if the interface is wrong\n305\t      const opts: EvaluatorOptions = {\n306\t        runId: 'r',\n307\t        storyFiles: [],\n308\t        agentDefinition: makeAgentDef(),\n309\t      };\n310\t      expect(opts.runId).toBe('r');\n311\t      expect(opts.storyFiles).toEqual([]);\n312\t      expect(opts.agentDefinition).toBeDefined();\n313\t      expect(opts.timeoutMs).toBeUndefined();\n314\t      expect(opts.traceId).toBeUndefined();\n315\t    });\n316\t\n317\t    it('EvaluatorResult has required fields', () => {\n318\t      const result: EvaluatorResult = {\n319\t        output: '',\n320\t        success: false,\n321\t        durationMs: 0,\n322\t        dockerAvailable: false,\n323\t        timedOut: false,\n324\t      };\n325\t      expect(result).toHaveProperty('output');\n326\t      expect(result).toHaveProperty('success');\n327\t      expect(result).toHaveProperty('durationMs');\n328\t      expect(result).toHaveProperty('dockerAvailable');\n329\t      expect(result).toHaveProperty('timedOut');\n330\t    });\n331\t  });\n332\t\n333\t  describe('Docker check happens before workspace creation', () => {\n334\t    it('checks Docker before creating workspace', async () => {\n335\t      const callOrder: string[] = [];\n336\t\n337\t      vi.mocked(isDockerAvailable).mockImplementation(() => {\n338\t        callOrder.push('docker-check');\n339\t        return true;\n340\t      });\n341\t\n342\t      vi.mocked(createIsolatedWorkspace).mockImplementation(async () => {\n343\t        callOrder.push('create-workspace');\n344\t        return makeMockWorkspace();\n345\t      });\n346\t\n347\t      vi.mocked(dispatchAgent).mockResolvedValue(makeDispatchResult());\n348\t\n349\t      await runEvaluator(makeOptions());\n350\t\n351\t      expect(callOrder[0]).toBe('docker-check');\n352\t      expect(callOrder[1]).toBe('create-workspace');\n353\t    });\n354\t  });\n355\t\n356\t  describe('dispatch error propagation', () => {\n357\t    it('re-throws non-timeout dispatch errors', async () => {\n358\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n359\t      const mockWorkspace = makeMockWorkspace();\n360\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n361\t      vi.mocked(dispatchAgent).mockRejectedValue(new Error('Network failure'));\n362\t\n363\t      await expect(runEvaluator(makeOptions())).rejects.toThrow('Network failure');\n364\t    });\n365\t\n366\t    it('handles non-Error thrown by dispatch (string)', async () => {\n367\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n368\t      const mockWorkspace = makeMockWorkspace();\n369\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n370\t      vi.mocked(dispatchAgent).mockRejectedValue('string error');\n371\t\n372\t      await expect(runEvaluator(makeOptions())).rejects.toBe('string error');\n373\t      expect(mockWorkspace.cleanup).toHaveBeenCalledTimes(1);\n374\t    });\n375\t  });\n376\t\n377\t  describe('workspace creation failure', () => {\n378\t    it('does not call cleanup when workspace creation throws', async () => {\n379\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n380\t      vi.mocked(createIsolatedWorkspace).mockRejectedValue(new Error('disk full'));\n381\t\n382\t      await expect(runEvaluator(makeOptions())).rejects.toThrow('disk full');\n383\t      // dispatchAgent should not have been called\n384\t      expect(dispatchAgent).not.toHaveBeenCalled();\n385\t    });\n386\t  });\n387\t\n388\t  describe('timer cleanup', () => {\n389\t    it('clears timeout timer on successful dispatch to prevent process hang', async () => {\n390\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n391\t      const mockWorkspace = makeMockWorkspace();\n392\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n393\t      vi.mocked(dispatchAgent).mockResolvedValue(makeDispatchResult());\n394\t\n395\t      const clearTimeoutSpy = vi.spyOn(globalThis, 'clearTimeout');\n396\t\n397\t      await runEvaluator(makeOptions({ timeoutMs: 60000 }));\n398\t\n399\t      // clearTimeout should have been called at least once (for the race timer)\n400\t      expect(clearTimeoutSpy).toHaveBeenCalled();\n401\t      clearTimeoutSpy.mockRestore();\n402\t    });\n403\t  });\n404\t});\n405\t"}]},"parent_tool_use_id":"toolu_01X7ZCkNrtprTmX6J7uq9WM7","session_id":"52ded6f4-857c-404a-a480-19bb12459ee1","uuid":"42806fe9-5390-4054-90a0-eb82c919d8fd","timestamp":"2026-04-03T00:34:15.439Z"}
