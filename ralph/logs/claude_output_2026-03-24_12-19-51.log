{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0116xNBdCFZK5PpsHG7ZSSSZ","type":"tool_result","content":"     1→/**\n     2→ * Python stack provider — encapsulates all Python-specific behavior.\n     3→ * Implements every StackProvider method for the python stack.\n     4→ *\n     5→ * Story 10-3: full implementation following NodejsProvider pattern from story 10-2.\n     6→ */\n     7→\n     8→import { execFileSync } from 'node:child_process';\n     9→import { existsSync, readFileSync } from 'node:fs';\n    10→import { join } from 'node:path';\n    11→\n    12→import type {\n    13→  AppType,\n    14→  CoverageToolInfo,\n    15→  CoverageToolName,\n    16→  OtlpResult,\n    17→  StackProvider,\n    18→  TestCounts,\n    19→} from './types.js';\n    20→import { readTextSafe, getPythonDepsContent, hasPythonDep } from './utils.js';\n    21→\n    22→/** Dependency names that signal an AI/agent project. */\n    23→const AGENT_DEPS = [\n    24→  'anthropic',\n    25→  'openai',\n    26→  'langchain',\n    27→  'llama-index',\n    28→  'traceloop-sdk',\n    29→];\n    30→\n    31→/** Dependency names that signal a web framework project. */\n    32→const WEB_FRAMEWORK_DEPS = ['flask', 'django', 'fastapi', 'streamlit'];\n    33→\n    34→/** OTLP packages required for Python instrumentation. */\n    35→const PYTHON_OTLP_PACKAGES = [\n    36→  'opentelemetry-distro',\n    37→  'opentelemetry-exporter-otlp',\n    38→];\n    39→\n    40→export class PythonProvider implements StackProvider {\n    41→  readonly name = 'python' as const;\n    42→  readonly markers = ['requirements.txt', 'pyproject.toml', 'setup.py'];\n    43→  readonly displayName = 'Python';\n    44→\n    45→  // ── Task 2: detectAppType ──────────────────────────────────────────────\n    46→\n    47→  detectAppType(dir: string): AppType {\n    48→    const content = getPythonDepsContent(dir);\n    49→\n    50→    // Priority 1: Agent detection\n    51→    if (AGENT_DEPS.some((d) => hasPythonDep(content, d))) {\n    52→      return 'agent';\n    53→    }\n    54→\n    55→    // Priority 2: Web detection (framework + templates/static dirs)\n    56→    const hasWebFramework = WEB_FRAMEWORK_DEPS.some((d) => hasPythonDep(content, d));\n    57→    if (hasWebFramework) {\n    58→      const hasTemplates = existsSync(join(dir, 'templates'));\n    59→      const hasStatic = existsSync(join(dir, 'static'));\n    60→      if (hasTemplates || hasStatic) {\n    61→        return 'web';\n    62→      }\n    63→      // Bare Flask/Django/FastAPI without templates => server\n    64→      return 'server';\n    65→    }\n    66→\n    67→    // Priority 3: Server detection (has main entry point)\n    68→    if (\n    69→      existsSync(join(dir, 'app.py')) ||\n    70→      existsSync(join(dir, 'main.py')) ||\n    71→      existsSync(join(dir, 'manage.py'))\n    72→    ) {\n    73→      return 'server';\n    74→    }\n    75→\n    76→    return 'generic';\n    77→  }\n    78→\n    79→  // ── Task 4: getCoverageTool ────────────────────────────────────────────\n    80→\n    81→  getCoverageTool(): CoverageToolName {\n    82→    return 'coverage-py';\n    83→  }\n    84→\n    85→  // ── Task 5: detectCoverageConfig ───────────────────────────────────────\n    86→\n    87→  detectCoverageConfig(dir: string): CoverageToolInfo {\n    88→    // Check requirements.txt\n    89→    const reqPath = join(dir, 'requirements.txt');\n    90→    if (existsSync(reqPath)) {\n    91→      try {\n    92→        const content = readFileSync(reqPath, 'utf-8');\n    93→        if (content.includes('pytest-cov') || content.includes('coverage')) {\n    94→          return { tool: 'coverage-py', configFile: reqPath };\n    95→        }\n    96→      } catch {\n    97→        // Continue checking\n    98→      }\n    99→    }\n   100→\n   101→    // Check pyproject.toml\n   102→    const pyprojectPath = join(dir, 'pyproject.toml');\n   103→    if (existsSync(pyprojectPath)) {\n   104→      try {\n   105→        const content = readFileSync(pyprojectPath, 'utf-8');\n   106→        if (content.includes('pytest-cov') || content.includes('coverage')) {\n   107→          return { tool: 'coverage-py', configFile: pyprojectPath };\n   108→        }\n   109→      } catch {\n   110→        // Continue checking\n   111→      }\n   112→    }\n   113→\n   114→    return { tool: 'none' };\n   115→  }\n   116→\n   117→  // ── Task 6: getOtlpPackages ────────────────────────────────────────────\n   118→\n   119→  getOtlpPackages(): string[] {\n   120→    return [...PYTHON_OTLP_PACKAGES];\n   121→  }\n   122→\n   123→  // ── Task 7: installOtlp ───────────────────────────────────────────────\n   124→\n   125→  installOtlp(dir: string): OtlpResult {\n   126→    // Primary: pip install both packages in one command\n   127→    try {\n   128→      execFileSync('pip', ['install', ...PYTHON_OTLP_PACKAGES], {\n   129→        cwd: dir,\n   130→        stdio: 'pipe',\n   131→        timeout: 300_000,\n   132→      });\n   133→      return {\n   134→        success: true,\n   135→        packagesInstalled: [...PYTHON_OTLP_PACKAGES],\n   136→      };\n   137→    } catch {\n   138→      // Fallback: pipx install each package individually\n   139→    }\n   140→\n   141→    try {\n   142→      for (const pkg of PYTHON_OTLP_PACKAGES) {\n   143→        execFileSync('pipx', ['install', pkg], {\n   144→          cwd: dir,\n   145→          stdio: 'pipe',\n   146→          timeout: 300_000,\n   147→        });\n   148→      }\n   149→      return {\n   150→        success: true,\n   151→        packagesInstalled: [...PYTHON_OTLP_PACKAGES],\n   152→      };\n   153→    } catch (err) {\n   154→      const message = err instanceof Error ? err.message : 'Unknown error';\n   155→      return {\n   156→        success: false,\n   157→        packagesInstalled: [],\n   158→        error: `Failed to install Python OTLP packages: ${message.length > 200 ? message.slice(0, 200) + '... (truncated)' : message}`,\n   159→      };\n   160→    }\n   161→  }\n   162→\n   163→  // ── Task 8: getDockerfileTemplate ─────────────────────────────────────\n   164→\n   165→  getDockerfileTemplate(): string {\n   166→    return `# Base image — pinned version for reproducibility\n   167→FROM python:3.12-slim\n   168→\n   169→# System utilities for verification\n   170→RUN apt-get update && apt-get install -y --no-install-recommends curl jq && rm -rf /var/lib/apt/lists/*\n   171→\n   172→# Install project from wheel or sdist\n   173→COPY dist/ /tmp/dist/\n   174→RUN pip install /tmp/dist/*.whl && rm -rf /tmp/dist/ && pip cache purge\n   175→\n   176→# Run as non-root user\n   177→USER nobody\n   178→\n   179→WORKDIR /workspace\n   180→`;\n   181→  }\n   182→\n   183→  // ── Task 9: getDockerBuildStage ───────────────────────────────────────\n   184→\n   185→  getDockerBuildStage(): string {\n   186→    return `# === Build stage: python ===\n   187→FROM python:3.12-slim AS build-python\n   188→WORKDIR /build\n   189→COPY . .\n   190→RUN pip install --target=/build/dist .\n   191→`;\n   192→  }\n   193→\n   194→  // ── Task 10: getRuntimeCopyDirectives ──────────────────────────────────\n   195→\n   196→  getRuntimeCopyDirectives(): string {\n   197→    return 'COPY --from=build-python /build/dist /opt/app/python/';\n   198→  }\n   199→\n   200→  // ── Task 11: getBuildCommands ──────────────────────────────────────────\n   201→\n   202→  getBuildCommands(): string[] {\n   203→    return ['pip install -r requirements.txt'];\n   204→  }\n   205→\n   206→  // ── Task 12: getTestCommands ──────────────────────────────────────────\n   207→\n   208→  getTestCommands(): string[] {\n   209→    return ['python -m pytest'];\n   210→  }\n   211→\n   212→  // ── Task 13: getSemgrepLanguages ──────────────────────────────────────\n   213→\n   214→  getSemgrepLanguages(): string[] {\n   215→    return ['python'];\n   216→  }\n   217→\n   218→  // ── Task 14: parseTestOutput ──────────────────────────────────────────\n   219→\n   220→  parseTestOutput(output: string): TestCounts {\n   221→    // Pytest format: \"12 passed, 3 failed\" or \"5 passed\" or \"12 passed, 3 failed, 1 skipped\"\n   222→    const passedMatch = /(\\d+)\\s+passed/i.exec(output);\n   223→    if (passedMatch) {\n   224→      const passed = parseInt(passedMatch[1], 10);\n   225→      const failedMatch = /(\\d+)\\s+failed/i.exec(output);\n   226→      const skippedMatch = /(\\d+)\\s+skipped/i.exec(output);\n   227→      const failed = failedMatch ? parseInt(failedMatch[1], 10) : 0;\n   228→      const skipped = skippedMatch ? parseInt(skippedMatch[1], 10) : 0;\n   229→      return { passed, failed, skipped, total: passed + failed + skipped };\n   230→    }\n   231→\n   232→    return { passed: 0, failed: 0, skipped: 0, total: 0 };\n   233→  }\n   234→\n   235→  // ── Task 15: parseCoverageReport ──────────────────────────────────────\n   236→\n   237→  parseCoverageReport(dir: string): number {\n   238→    const reportPath = join(dir, 'coverage.json');\n   239→    if (!existsSync(reportPath)) return 0;\n   240→\n   241→    try {\n   242→      const report = JSON.parse(readFileSync(reportPath, 'utf-8')) as {\n   243→        totals?: { percent_covered?: number };\n   244→      };\n   245→      return report.totals?.percent_covered ?? 0;\n   246→    } catch {\n   247→      return 0;\n   248→    }\n   249→  }\n   250→\n   251→  // ── Task 16: getProjectName ───────────────────────────────────────────\n   252→\n   253→  getProjectName(dir: string): string | null {\n   254→    // Try pyproject.toml first\n   255→    const pyprojectContent = readTextSafe(join(dir, 'pyproject.toml'));\n   256→    if (pyprojectContent) {\n   257→      // Match [project]\\n...name = \"...\" pattern\n   258→      const match = /\\[project\\]\\s*\\n(?:.*\\n)*?\\s*name\\s*=\\s*\"([^\"]+)\"/m.exec(pyprojectContent);\n   259→      if (match) return match[1];\n   260→      // Also try single-quoted variant\n   261→      const matchSingle = /\\[project\\]\\s*\\n(?:.*\\n)*?\\s*name\\s*=\\s*'([^']+)'/m.exec(pyprojectContent);\n   262→      if (matchSingle) return matchSingle[1];\n   263→    }\n   264→\n   265→    // Try setup.py\n   266→    const setupContent = readTextSafe(join(dir, 'setup.py'));\n   267→    if (setupContent) {\n   268→      const match = /name\\s*=\\s*['\"]([^'\"]+)['\"]/m.exec(setupContent);\n   269→      if (match) return match[1];\n   270→    }\n   271→\n   272→    return null;\n   273→  }\n   274→}\n   275→"}]},"parent_tool_use_id":"toolu_01XXdV3K3gysdv7HwBLXK2M3","session_id":"e39a20db-e648-4f8f-85ec-e4fa22cf8d05","uuid":"82925455-cd93-4410-b953-141951a73b97","timestamp":"2026-03-24T08:29:08.063Z"}
