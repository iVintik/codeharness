{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NCcmUNhpm6TMW4pusEbuv2","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { Readable } from 'node:stream';\n3\timport type {\n4\t  AgentDriver,\n5\t  DispatchOpts,\n6\t  DriverHealth,\n7\t  DriverCapabilities,\n8\t  ErrorCategory,\n9\t  OutputContract,\n10\t  TestResults,\n11\t  ACStatus,\n12\t  // Deprecated types — must still compile\n13\t  AgentProcess,\n14\t  AgentEvent,\n15\t  SpawnOpts,\n16\t} from '../types.js';\n17\timport type { StreamEvent, ResultEvent } from '../stream-parser.js';\n18\timport type {\n19\t  // Barrel re-exports — new types\n20\t  AgentDriver as BarrelAgentDriver,\n21\t  DriverHealth as BarrelDriverHealth,\n22\t  DriverCapabilities as BarrelDriverCapabilities,\n23\t  DispatchOpts as BarrelDispatchOpts,\n24\t  ErrorCategory as BarrelErrorCategory,\n25\t  OutputContract as BarrelOutputContract,\n26\t  TestResults as BarrelTestResults,\n27\t  ACStatus as BarrelACStatus,\n28\t  // Barrel re-exports — deprecated types\n29\t  AgentProcess as BarrelAgentProcess,\n30\t  AgentEvent as BarrelAgentEvent,\n31\t  SpawnOpts as BarrelSpawnOpts,\n32\t} from '../index.js';\n33\t\n34\t// --- Helpers ---\n35\t\n36\t/** Creates a mock AgentDriver implementing the new interface. */\n37\tfunction createMockDriver(): AgentDriver {\n38\t  return {\n39\t    name: 'mock-driver',\n40\t    defaultModel: 'mock-model-v1',\n41\t    capabilities: {\n42\t      supportsPlugins: true,\n43\t      supportsStreaming: true,\n44\t      costReporting: true,\n45\t      costTier: 1,\n46\t    },\n47\t    async healthCheck(): Promise<DriverHealth> {\n48\t      return { available: true, authenticated: true, version: '1.0.0' };\n49\t    },\n50\t    async *dispatch(_opts: DispatchOpts): AsyncIterable<StreamEvent> {\n51\t      yield { type: 'text', text: 'hello' };\n52\t      yield { type: 'result', cost: 0.01, sessionId: 'mock-session' };\n53\t    },\n54\t    getLastCost(): number | null {\n55\t      return 0.01;\n56\t    },\n57\t  };\n58\t}\n59\t\n60\t/** Creates a minimal mock AgentProcess for deprecated type tests. */\n61\tfunction createMockProcess(): AgentProcess {\n62\t  const handlers: Record<string, Function> = {};\n63\t  return {\n64\t    stdout: new Readable({ read() {} }),\n65\t    stderr: new Readable({ read() {} }),\n66\t    on(event: string, handler: Function) {\n67\t      handlers[event] = handler;\n68\t    },\n69\t    kill() {},\n70\t  };\n71\t}\n72\t\n73\t// --- New Interface Tests ---\n74\t\n75\tdescribe('agents/types — new AgentDriver interface (Epic 10)', () => {\n76\t  describe('AgentDriver interface', () => {\n77\t    it('satisfies interface with mock implementation', () => {\n78\t      const driver = createMockDriver();\n79\t      expect(driver.name).toBe('mock-driver');\n80\t      expect(driver.defaultModel).toBe('mock-model-v1');\n81\t      expect(driver.capabilities).toBeDefined();\n82\t      expect(typeof driver.healthCheck).toBe('function');\n83\t      expect(typeof driver.dispatch).toBe('function');\n84\t      expect(typeof driver.getLastCost).toBe('function');\n85\t    });\n86\t\n87\t    it('has readonly name and defaultModel', () => {\n88\t      const driver = createMockDriver();\n89\t      expect(driver.name).toBe('mock-driver');\n90\t      expect(driver.defaultModel).toBe('mock-model-v1');\n91\t    });\n92\t\n93\t    it('has readonly capabilities', () => {\n94\t      const driver = createMockDriver();\n95\t      expect(driver.capabilities.supportsPlugins).toBe(true);\n96\t      expect(driver.capabilities.supportsStreaming).toBe(true);\n97\t      expect(driver.capabilities.costReporting).toBe(true);\n98\t    });\n99\t\n100\t    it('healthCheck returns Promise<DriverHealth>', async () => {\n101\t      const driver = createMockDriver();\n102\t      const health = await driver.healthCheck();\n103\t      expect(health.available).toBe(true);\n104\t      expect(health.authenticated).toBe(true);\n105\t      expect(health.version).toBe('1.0.0');\n106\t    });\n107\t\n108\t    it('dispatch returns AsyncIterable<StreamEvent>', async () => {\n109\t      const driver = createMockDriver();\n110\t      const opts: DispatchOpts = {\n111\t        prompt: 'test',\n112\t        model: 'mock-model-v1',\n113\t        cwd: '/tmp',\n114\t        sourceAccess: true,\n115\t      };\n116\t      const events: StreamEvent[] = [];\n117\t      for await (const event of driver.dispatch(opts)) {\n118\t        events.push(event);\n119\t      }\n120\t      expect(events).toHaveLength(2);\n121\t      expect(events[0].type).toBe('text');\n122\t      expect(events[1].type).toBe('result');\n123\t    });\n124\t\n125\t    it('getLastCost returns number or null', () => {\n126\t      const driver = createMockDriver();\n127\t      const cost = driver.getLastCost();\n128\t      expect(cost).toBe(0.01);\n129\t    });\n130\t\n131\t    it('getLastCost can return null', () => {\n132\t      const driver: AgentDriver = {\n133\t        ...createMockDriver(),\n134\t        getLastCost: () => null,\n135\t      };\n136\t      expect(driver.getLastCost()).toBeNull();\n137\t    });\n138\t  });\n139\t\n140\t  describe('DispatchOpts', () => {\n141\t    it('accepts all required fields', () => {\n142\t      const opts: DispatchOpts = {\n143\t        prompt: 'implement story',\n144\t        model: 'claude-sonnet-4-20250514',\n145\t        cwd: '/home/project',\n146\t        sourceAccess: true,\n147\t      };\n148\t      expect(opts.prompt).toBe('implement story');\n149\t      expect(opts.model).toBe('claude-sonnet-4-20250514');\n150\t      expect(opts.cwd).toBe('/home/project');\n151\t      expect(opts.sourceAccess).toBe(true);\n152\t    });\n153\t\n154\t    it('accepts all optional fields', () => {\n155\t      const contract: OutputContract = {\n156\t        version: 1,\n157\t        taskName: 'implement',\n158\t        storyId: '10-1',\n159\t        driver: 'claude-code',\n160\t        model: 'claude-sonnet-4-20250514',\n161\t        timestamp: '2026-04-03T10:00:00Z',\n162\t        cost_usd: null,\n163\t        duration_ms: 0,\n164\t        changedFiles: [],\n165\t        testResults: null,\n166\t        output: '',\n167\t        acceptanceCriteria: [],\n168\t      };\n169\t      const opts: DispatchOpts = {\n170\t        prompt: 'test',\n171\t        model: 'model',\n172\t        cwd: '/tmp',\n173\t        sourceAccess: false,\n174\t        plugins: ['plugin-a', 'plugin-b'],\n175\t        timeout: 30000,\n176\t        outputContract: contract,\n177\t      };\n178\t      expect(opts.plugins).toEqual(['plugin-a', 'plugin-b']);\n179\t      expect(opts.timeout).toBe(30000);\n180\t      expect(opts.outputContract).toBeDefined();\n181\t    });\n182\t\n183\t    it('optional fields are undefined when not provided', () => {\n184\t      const opts: DispatchOpts = {\n185\t        prompt: 'x',\n186\t        model: 'm',\n187\t        cwd: '/',\n188\t        sourceAccess: false,\n189\t      };\n190\t      expect(opts.plugins).toBeUndefined();\n191\t      expect(opts.timeout).toBeUndefined();\n192\t      expect(opts.outputContract).toBeUndefined();\n193\t    });\n194\t  });\n195\t\n196\t  describe('DriverHealth', () => {\n197\t    it('accepts a healthy status', () => {\n198\t      const health: DriverHealth = {\n199\t        available: true,\n200\t        authenticated: true,\n201\t        version: '2.1.0',\n202\t      };\n203\t      expect(health.available).toBe(true);\n204\t      expect(health.authenticated).toBe(true);\n205\t      expect(health.version).toBe('2.1.0');\n206\t      expect(health.error).toBeUndefined();\n207\t    });\n208\t\n209\t    it('accepts an unhealthy status with error', () => {\n210\t      const health: DriverHealth = {\n211\t        available: false,\n212\t        authenticated: false,\n213\t        version: null,\n214\t        error: 'CLI not found on PATH',\n215\t      };\n216\t      expect(health.available).toBe(false);\n217\t      expect(health.version).toBeNull();\n218\t      expect(health.error).toBe('CLI not found on PATH');\n219\t    });\n220\t\n221\t    it('error field is optional', () => {\n222\t      const health: DriverHealth = {\n223\t        available: true,\n224\t        authenticated: true,\n225\t        version: '1.0.0',\n226\t      };\n227\t      expect(health.error).toBeUndefined();\n228\t    });\n229\t  });\n230\t\n231\t  describe('DriverCapabilities', () => {\n232\t    it('accepts capability flags including costTier', () => {\n233\t      const caps: DriverCapabilities = {\n234\t        supportsPlugins: true,\n235\t        supportsStreaming: false,\n236\t        costReporting: true,\n237\t        costTier: 3,\n238\t      };\n239\t      expect(caps.supportsPlugins).toBe(true);\n240\t      expect(caps.supportsStreaming).toBe(false);\n241\t      expect(caps.costReporting).toBe(true);\n242\t      expect(caps.costTier).toBe(3);\n243\t    });\n244\t\n245\t    it('all-false capabilities are valid with costTier 1', () => {\n246\t      const caps: DriverCapabilities = {\n247\t        supportsPlugins: false,\n248\t        supportsStreaming: false,\n249\t        costReporting: false,\n250\t        costTier: 1,\n251\t      };\n252\t      expect(caps.supportsPlugins).toBe(false);\n253\t      expect(caps.supportsStreaming).toBe(false);\n254\t      expect(caps.costReporting).toBe(false);\n255\t      expect(caps.costTier).toBe(1);\n256\t    });\n257\t  });\n258\t\n259\t  describe('ErrorCategory', () => {\n260\t    it('covers exactly 5 values', () => {\n261\t      const categories: ErrorCategory[] = [\n262\t        'RATE_LIMIT',\n263\t        'NETWORK',\n264\t        'AUTH',\n265\t        'TIMEOUT',\n266\t        'UNKNOWN',\n267\t      ];\n268\t      expect(categories).toHaveLength(5);\n269\t      // Verify each is a valid ErrorCategory (compile-time check)\n270\t      categories.forEach((cat) => {\n271\t        expect(typeof cat).toBe('string');\n272\t      });\n273\t    });\n274\t\n275\t    it('each value is assignable to E