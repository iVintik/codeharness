{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01W41rET17j9Q69KNaerAWrs","type":"tool_result","content":"     1→/**\n     2→ * Node.js stack provider — encapsulates all Node.js-specific behavior.\n     3→ * Implements every StackProvider method for the nodejs stack.\n     4→ *\n     5→ * Story 10-2: full implementation replacing stubs from story 10-1.\n     6→ */\n     7→\n     8→import { execFileSync } from 'node:child_process';\n     9→import { existsSync, readFileSync, writeFileSync } from 'node:fs';\n    10→import { join } from 'node:path';\n    11→\n    12→import type {\n    13→  AppType,\n    14→  CoverageToolInfo,\n    15→  CoverageToolName,\n    16→  OtlpResult,\n    17→  StackProvider,\n    18→  TestCounts,\n    19→} from './types.js';\n    20→import { readJsonSafe, getNodeDeps } from './utils.js';\n    21→\n    22→/** Dependency names that signal an AI/agent project. */\n    23→const AGENT_DEPS = [\n    24→  'anthropic',\n    25→  '@anthropic-ai/sdk',\n    26→  'openai',\n    27→  'langchain',\n    28→  '@langchain/core',\n    29→  'llamaindex',\n    30→];\n    31→\n    32→/** Dependency names that signal a web frontend project. */\n    33→const WEB_FRAMEWORK_DEPS = [\n    34→  'react',\n    35→  'vue',\n    36→  'svelte',\n    37→  'angular',\n    38→  '@angular/core',\n    39→  'next',\n    40→  'nuxt',\n    41→  'vite',\n    42→  'webpack',\n    43→];\n    44→\n    45→/** OTLP packages required for Node.js instrumentation. */\n    46→const NODE_OTLP_PACKAGES = [\n    47→  '@opentelemetry/auto-instrumentations-node',\n    48→  '@opentelemetry/sdk-node',\n    49→  '@opentelemetry/exporter-trace-otlp-http',\n    50→  '@opentelemetry/exporter-metrics-otlp-http',\n    51→];\n    52→\n    53→const NODE_REQUIRE_FLAG = '--require @opentelemetry/auto-instrumentations-node/register';\n    54→\n    55→export class NodejsProvider implements StackProvider {\n    56→  readonly name = 'nodejs' as const;\n    57→  readonly markers = ['package.json'];\n    58→  readonly displayName = 'Node.js (package.json)';\n    59→\n    60→  // ── Task 1: detectAppType ──────────────────────────────────────────────\n    61→\n    62→  detectAppType(dir: string): AppType {\n    63→    const pkg = readJsonSafe(join(dir, 'package.json'));\n    64→    if (!pkg) return 'generic';\n    65→\n    66→    const deps = getNodeDeps(pkg);\n    67→\n    68→    // Priority 1: Agent detection\n    69→    if (AGENT_DEPS.some((d) => deps.has(d))) {\n    70→      return 'agent';\n    71→    }\n    72→\n    73→    // Priority 2: Web detection\n    74→    if (WEB_FRAMEWORK_DEPS.some((d) => deps.has(d))) {\n    75→      return 'web';\n    76→    }\n    77→    if (\n    78→      existsSync(join(dir, 'index.html')) ||\n    79→      existsSync(join(dir, 'public', 'index.html')) ||\n    80→      existsSync(join(dir, 'src', 'index.html'))\n    81→    ) {\n    82→      return 'web';\n    83→    }\n    84→\n    85→    // Priority 3: CLI detection\n    86→    const bin = pkg['bin'];\n    87→    const scripts = pkg['scripts'] as Record<string, string> | undefined;\n    88→    const hasStart = scripts?.['start'] !== undefined;\n    89→    if (bin && !hasStart) {\n    90→      return 'cli';\n    91→    }\n    92→\n    93→    // Priority 4: Server detection\n    94→    if (hasStart) {\n    95→      return 'server';\n    96→    }\n    97→\n    98→    return 'generic';\n    99→  }\n   100→\n   101→  // ── Task 2: getCoverageTool ────────────────────────────────────────────\n   102→\n   103→  getCoverageTool(): CoverageToolName {\n   104→    return 'c8';\n   105→  }\n   106→\n   107→  // ── Task 3: detectCoverageConfig ───────────────────────────────────────\n   108→\n   109→  detectCoverageConfig(dir: string): CoverageToolInfo {\n   110→    // Check for Vitest config files\n   111→    const vitestConfigTs = join(dir, 'vitest.config.ts');\n   112→    const vitestConfigJs = join(dir, 'vitest.config.js');\n   113→    const hasVitestConfig = existsSync(vitestConfigTs) || existsSync(vitestConfigJs);\n   114→\n   115→    // Check package.json devDependencies\n   116→    const pkg = readJsonSafe(join(dir, 'package.json'));\n   117→    let hasVitestCoverageV8 = false;\n   118→    let hasVitestCoverageIstanbul = false;\n   119→    let hasC8 = false;\n   120→    let hasJest = false;\n   121→\n   122→    if (pkg) {\n   123→      const allDeps = getNodeDeps(pkg);\n   124→      hasVitestCoverageV8 = allDeps.has('@vitest/coverage-v8');\n   125→      hasVitestCoverageIstanbul = allDeps.has('@vitest/coverage-istanbul');\n   126→      hasC8 = allDeps.has('c8');\n   127→      hasJest = allDeps.has('jest');\n   128→    }\n   129→\n   130→    // Vitest detection\n   131→    if (hasVitestConfig || hasVitestCoverageV8 || hasVitestCoverageIstanbul) {\n   132→      const configFile = existsSync(vitestConfigTs)\n   133→        ? vitestConfigTs\n   134→        : existsSync(vitestConfigJs)\n   135→          ? vitestConfigJs\n   136→          : undefined;\n   137→      return { tool: 'c8', configFile };\n   138→    }\n   139→\n   140→    // Standalone c8\n   141→    if (hasC8) {\n   142→      return { tool: 'c8' };\n   143→    }\n   144→\n   145→    // Jest (uses c8/istanbul underneath)\n   146→    if (hasJest) {\n   147→      return { tool: 'c8' };\n   148→    }\n   149→\n   150→    return { tool: 'none' };\n   151→  }\n   152→\n   153→  // ── Task 4: getOtlpPackages ────────────────────────────────────────────\n   154→\n   155→  getOtlpPackages(): string[] {\n   156→    return [...NODE_OTLP_PACKAGES];\n   157→  }\n   158→\n   159→  // ── Task 5: installOtlp ───────────────────────────────────────────────\n   160→\n   161→  installOtlp(dir: string): OtlpResult {\n   162→    try {\n   163→      execFileSync('npm', ['install', ...NODE_OTLP_PACKAGES], {\n   164→        cwd: dir,\n   165→        stdio: 'pipe',\n   166→        timeout: 300_000,\n   167→      });\n   168→      return {\n   169→        success: true,\n   170→        packagesInstalled: [...NODE_OTLP_PACKAGES],\n   171→      };\n   172→    } catch (err) {\n   173→      const message = err instanceof Error ? err.message : 'Unknown error';\n   174→      return {\n   175→        success: false,\n   176→        packagesInstalled: [],\n   177→        error: `Failed to install Node.js OTLP packages: ${message.length > 200 ? message.slice(0, 200) + '... (truncated)' : message}`,\n   178→      };\n   179→    }\n   180→  }\n   181→\n   182→  // ── Task 6: patchStartScript ──────────────────────────────────────────\n   183→\n   184→  patchStartScript(dir: string): boolean {\n   185→    const pkgPath = join(dir, 'package.json');\n   186→    if (!existsSync(pkgPath)) return false;\n   187→\n   188→    let raw: string;\n   189→    let pkg: Record<string, unknown>;\n   190→    try {\n   191→      raw = readFileSync(pkgPath, 'utf-8');\n   192→      pkg = JSON.parse(raw) as Record<string, unknown>;\n   193→    } catch {\n   194→      return false;\n   195→    }\n   196→\n   197→    const scripts = pkg['scripts'] as Record<string, string> | undefined;\n   198→    if (!scripts) return false;\n   199→\n   200→    const targetKey = scripts['start'] ? 'start' : scripts['dev'] ? 'dev' : null;\n   201→    if (!targetKey) return false;\n   202→\n   203→    const instrumentedKey = `${targetKey}:instrumented`;\n   204→\n   205→    // Already patched\n   206→    if (scripts[instrumentedKey]?.includes(NODE_REQUIRE_FLAG)) {\n   207→      return false;\n   208→    }\n   209→\n   210→    scripts[instrumentedKey] = `NODE_OPTIONS='${NODE_REQUIRE_FLAG}' ${scripts[targetKey]}`;\n   211→\n   212→    writeFileSync(pkgPath, JSON.stringify(pkg, null, 2) + '\\n', 'utf-8');\n   213→    return true;\n   214→  }\n   215→\n   216→  // ── Task 7: getDockerfileTemplate ─────────────────────────────────────\n   217→\n   218→  getDockerfileTemplate(): string {\n   219→    return `# Base image — pinned version for reproducibility\n   220→FROM node:22-slim\n   221→\n   222→ARG TARBALL=package.tgz\n   223→\n   224→# System utilities for verification\n   225→RUN apt-get update && apt-get install -y --no-install-recommends curl jq && rm -rf /var/lib/apt/lists/*\n   226→\n   227→# Install project from tarball (black-box: no source code)\n   228→COPY \\${TARBALL} /tmp/\\${TARBALL}\n   229→RUN npm install -g /tmp/\\${TARBALL} && rm /tmp/\\${TARBALL}\n   230→\n   231→# Run as non-root user\n   232→USER node\n   233→\n   234→WORKDIR /workspace\n   235→`;\n   236→  }\n   237→\n   238→  // ── Task 8: getDockerBuildStage ───────────────────────────────────────\n   239→\n   240→  getDockerBuildStage(): string {\n   241→    return `# === Build stage: nodejs ===\n   242→FROM node:22-slim AS build-nodejs\n   243→WORKDIR /build\n   244→COPY package*.json ./\n   245→RUN npm ci --production\n   246→COPY . .\n   247→`;\n   248→  }\n   249→\n   250→  // ── Task 9: getRuntimeCopyDirectives ──────────────────────────────────\n   251→\n   252→  getRuntimeCopyDirectives(): string {\n   253→    return [\n   254→      'COPY --from=build-nodejs /build/node_modules ./node_modules',\n   255→      'COPY --from=build-nodejs /build/ ./app/',\n   256→    ].join('\\n');\n   257→  }\n   258→\n   259→  // ── Task 10: getBuildCommands ──────────────────────────────────────────\n   260→\n   261→  getBuildCommands(): string[] {\n   262→    return ['npm install', 'npm run build'];\n   263→  }\n   264→\n   265→  // ── Task 11: getTestCommands ──────────────────────────────────────────\n   266→\n   267→  getTestCommands(): string[] {\n   268→    return ['npm test'];\n   269→  }\n   270→\n   271→  // ── Task 12: getSemgrepLanguages ──────────────────────────────────────\n   272→\n   273→  getSemgrepLanguages(): string[] {\n   274→    return ['javascript', 'typescript'];\n   275→  }\n   276→\n   277→  // ── Task 13: parseTestOutput ──────────────────────────────────────────\n   278→\n   279→  parseTestOutput(output: string): TestCounts {\n   280→    // Vitest format: \"Tests  12 passed | 3 failed\"\n   281→    const vitestMatch = /Tests\\s+(\\d+)\\s+passed(?:\\s*\\|\\s*(\\d+)\\s+failed)?/i.exec(output);\n   282→    if (vitestMatch) {\n   283→      const passed = parseInt(vitestMatch[1], 10);\n   284→      const failed = vitestMatch[2] ? parseInt(vitestMatch[2], 10) : 0;\n   285→      return { passed, failed, skipped: 0, total: passed + failed };\n   286→    }\n   287→\n   288→    // Jest format: \"Tests:  3 failed, 12 passed, 15 total\"\n   289→    const jestMatch = /Tests:\\s*(?:(\\d+)\\s+failed,\\s*)?(\\d+)\\s+passed(?:,\\s*(\\d+)\\s+total)?/i.exec(output);\n   290→    if (jestMatch) {\n   291→      const passed = parseInt(jestMatch[2], 10);\n   292→      const failed = jestMatch[1] ? parseInt(jestMatch[1], 10) : 0;\n   293→      const total = jestMatch[3] ? parseInt(jestMatch[3], 10) : passed + failed;\n   294→      return { passed, failed, skipped: total - passed - failed, total };\n   295→    }\n   296→\n   297→    return { passed: 0, failed: 0, skipped: 0, total: 0 };\n   298→  }\n   299→\n   300→  // ── Task 14: parseCoverageReport ──────────────────────────────────────\n   301→\n   302→  parseCoverageReport(dir: string): number {\n   303→    const candidates = [\n   304→      join(dir, 'coverage', 'coverage-summary.json'),\n   305→      join(dir, 'src', 'coverage', 'coverage-summary.json'),\n   306→    ];\n   307→\n   308→    let reportPath: string | null = null;\n   309→    for (const p of candidates) {\n   310→      if (existsSync(p)) {\n   311→        reportPath = p;\n   312→        break;\n   313→      }\n   314→    }\n   315→\n   316→    if (!reportPath) return 0;\n   317→\n   318→    try {\n   319→      const report = JSON.parse(readFileSync(reportPath, 'utf-8')) as {\n   320→        total?: {\n   321→          statements?: { pct?: number };\n   322→        };\n   323→      };\n   324→      return report.total?.statements?.pct ?? 0;\n   325→    } catch {\n   326→      return 0;\n   327→    }\n   328→  }\n   329→\n   330→  // ── Task 15: getProjectName ───────────────────────────────────────────\n   331→\n   332→  getProjectName(dir: string): string | null {\n   333→    const pkg = readJsonSafe(join(dir, 'package.json'));\n   334→    if (pkg && typeof pkg.name === 'string') {\n   335→      return pkg.name;\n   336→    }\n   337→    return null;\n   338→  }\n   339→}\n   340→"}]},"parent_tool_use_id":"toolu_01AYUK9c5QWsnPVHthUcsHao","session_id":"ec2bf7d9-1cd3-4665-9804-65790a3eadb3","uuid":"525f58ea-7810-470a-b902-1be9466c8ac2","timestamp":"2026-03-24T08:05:26.162Z"}
