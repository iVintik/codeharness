{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GGhPivguyGMsrCeiyyYRbj","type":"tool_result","content":"60\t    Object.setPrototypeOf(this, VerdictParseError.prototype);\n61\t    this.name = 'VerdictParseError';\n62\t    this.retryable = retryable;\n63\t    this.rawOutput = rawOutput;\n64\t    this.validationErrors = validationErrors;\n65\t  }\n66\t}\n67\t\n68\t// --- Schema Validator (compiled once at module load) ---\n69\t\n70\tconst ajv = new Ajv({ allErrors: true });\n71\tconst validateSchema = ajv.compile(verdictSchema);\n72\t\n73\t// --- Functions ---\n74\t\n75\t/**\n76\t * Validate an unknown value against the verdict JSON schema.\n77\t * Returns a VerdictValidationResult with typed verdict on success,\n78\t * or error messages on failure.\n79\t */\n80\texport function validateVerdict(data: unknown): VerdictValidationResult {\n81\t  const valid = validateSchema(data);\n82\t\n83\t  if (valid) {\n84\t    // Return a deep copy to prevent callers from mutating the original input\n85\t    const verdict = JSON.parse(JSON.stringify(data)) as EvaluatorVerdict;\n86\t    return { valid: true, verdict };\n87\t  }\n88\t\n89\t  const errors = (validateSchema.errors ?? []).map((err) => {\n90\t    const path = err.instancePath || '/';\n91\t    return `${path}: ${err.message ?? 'unknown error'}`;\n92\t  });\n93\t\n94\t  return { valid: false, errors };\n95\t}\n96\t\n97\t/**\n98\t * Parse raw evaluator output into a typed EvaluatorVerdict.\n99\t *\n100\t * On success: returns a fully typed EvaluatorVerdict with PASS-evidence\n101\t * invariant enforced (PASS findings without commands_run are downgraded\n102\t * to UNKNOWN).\n103\t *\n104\t * On failure: throws VerdictParseError with `retryable: true`.\n105\t * The caller (workflow engine) decides whether to retry. On a second\n106\t * failure, the caller should catch and generate an all-UNKNOWN verdict.\n107\t */\n108\texport function parseVerdict(output: string): EvaluatorVerdict {\n109\t  // Step 1: JSON.parse\n110\t  let parsed: unknown;\n111\t  try {\n112\t    parsed = JSON.parse(output);\n113\t  } catch { // IGNORE: invalid JSON — rethrow as VerdictParseError\n114\t    throw new VerdictParseError(\n115\t      'Failed to parse verdict: invalid JSON',\n116\t      true,\n117\t      output,\n118\t    );\n119\t  }"}]},"parent_tool_use_id":"toolu_01QNNr4yQoQQfPTTg7FsQuMG","session_id":"e648a229-0e5b-4ea4-9861-593afdfcccd5","uuid":"b1814a37-fc2c-4167-8c8a-765031a20def","timestamp":"2026-04-03T19:05:26.947Z"}
