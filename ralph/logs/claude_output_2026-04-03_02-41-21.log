{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Jycsut5CiZMUeSEgDKgC4f","type":"tool_result","content":"820\t * a TaskCheckpoint with the error details (AC #13).\n821\t */\n822\tfunction recordErrorInState(\n823\t  state: WorkflowState,\n824\t  taskName: string,\n825\t  storyKey: string,\n826\t  error: EngineError,\n827\t): WorkflowState {\n828\t  const errorCheckpoint: TaskCheckpoint = {\n829\t    task_name: taskName,\n830\t    story_key: storyKey,\n831\t    completed_at: new Date().toISOString(),\n832\t  };\n833\t  return {\n834\t    ...state,\n835\t    phase: 'error',\n836\t    tasks_completed: [...state.tasks_completed, errorCheckpoint],\n837\t  };\n838\t}\n839\t\n840\tfunction handleDispatchError(err: unknown, taskName: string, storyKey: string): EngineError {\n841\t  if (err instanceof DispatchError) {\n842\t    return {\n843\t      taskName,\n844\t      storyKey,\n845\t      code: err.code,\n846\t      message: err.message,\n847\t    };\n848\t  }\n849\t\n850\t  const message = err instanceof Error ? err.message : String(err);\n851\t  return {\n852\t    taskName,\n853\t    storyKey,\n854\t    code: 'UNKNOWN',\n855\t    message,\n856\t  };\n857\t}\n858\t"}]},"parent_tool_use_id":"toolu_01GD3dd86R9DYmBSHRKfrVV3","session_id":"8b4a1da7-9e18-4302-ad13-ce7f0aff0314","uuid":"d6447c79-bd2e-40db-8020-07890c239c38","timestamp":"2026-04-02T22:55:07.057Z"}
