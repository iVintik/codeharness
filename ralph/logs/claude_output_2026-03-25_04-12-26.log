ain('2-2-add-test-coverage-for-src-lib: backlog');\n   761→    expect(content).toContain('epic-2-retrospective: optional');\n   762→  });\n   763→\n   764→  it('returns epicNumber 0 when no existing epics', () => {\n   765→    createSprintStatusFile(`development_status:\n   766→`);\n   767→\n   768→    const result = appendOnboardingEpicToSprint(\n   769→      [{ title: 'Create ARCHITECTURE.md' }],\n   770→      testDir,\n   771→    );\n   772→\n   773→    expect(result.epicNumber).toBe(0);\n   774→    expect(result.storyKeys[0]).toMatch(/^0-1-create-architecture-md/);\n   775→  });\n   776→\n   777→  it('returns -1 when sprint-status.yaml missing', () => {\n   778→    const result = appendOnboardingEpicToSprint(\n   779→      [{ title: 'Test' }],\n   780→      testDir,\n   781→    );\n   782→\n   783→    expect(result.epicNumber).toBe(-1);\n   784→    expect(result.storyKeys).toHaveLength(0);\n   785→  });\n   786→\n   787→  it('preserves existing content when appending', () => {\n   788→    createSprintStatusFile(`# project header\n   789→development_status:\n   790→  epic-0: done\n   791→  0-1-first-story: done\n   792→  epic-0-retrospective: done\n   793→`);\n   794→\n   795→    appendOnboardingEpicToSprint(\n   796→      [{ title: 'New Story' }],\n   797→      testDir,\n   798→    );\n   799→\n   800→    const content = readFileSync(\n   801→      join(testDir, '_bmad-output', 'implementation-artifacts', 'sprint-status.yaml'),\n   802→      'utf-8',\n   803→    );\n   804→    // Existing content preserved\n   805→    expect(content).toContain('# project header');\n   806→    expect(content).toContain('epic-0: done');\n   807→    expect(content).toContain('0-1-first-story: done');\n   808→    // New content appended\n   809→    expect(content).toContain('epic-1: backlog');\n   810→  });\n   811→\n   812→  it('slugifies story titles correctly', () => {\n   813→    createSprintStatusFile(`development_status:\n   814→`);\n   815→\n   816→    const result = appendOn