{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016ae4hvWw3rLDnr8xL36Dhr","type":"tool_result","content":"     1→import { join } from 'node:path';\n     2→import { Command } from 'commander';\n     3→import { ok, warn, jsonOutput } from '../lib/output.js';\n     4→import {\n     5→  readRetries,\n     6→  readFlaggedStories,\n     7→  resetRetry,\n     8→} from '../lib/retry-state.js';\n     9→\n    10→const RALPH_SUBDIR = 'ralph';\n    11→\n    12→/**\n    13→ * Validates that a story key is safe (no path traversal, only alphanumeric/hyphens/underscores).\n    14→ */\n    15→function isValidStoryKey(key: string): boolean {\n    16→  if (!key || key.includes('..') || key.includes('/') || key.includes('\\\\')) {\n    17→    return false;\n    18→  }\n    19→  return /^[a-zA-Z0-9_-]+$/.test(key);\n    20→}\n    21→\n    22→interface RetryOptions {\n    23→  reset?: boolean;\n    24→  story?: string;\n    25→  status?: boolean;\n    26→}\n    27→\n    28→export function registerRetryCommand(program: Command): void {\n    29→  program\n    30→    .command('retry')\n    31→    .description('Manage retry state for stories')\n    32→    .option('--reset', 'Clear retry counters and flagged stories')\n    33→    .option('--story <key>', 'Target a specific story key (used with --reset or --status)')\n    34→    .option('--status', 'Show retry status for all stories')\n    35→    .action((_options: RetryOptions, cmd: Command) => {\n    36→      const opts = cmd.optsWithGlobals() as RetryOptions & { json?: boolean };\n    37→      const isJson = opts.json === true;\n    38→      const dir = join(process.cwd(), RALPH_SUBDIR);\n    39→\n    40→      // Validate story key if provided\n    41→      if (opts.story && !isValidStoryKey(opts.story)) {\n    42→        if (isJson) {\n    43→          jsonOutput({ status: 'fail', message: `Invalid story key: ${opts.story}` });\n    44→        } else {\n    45→          warn(`Invalid story key: ${opts.story}`);\n    46→        }\n    47→        process.exitCode = 1;\n    48→        return;\n    49→      }\n    50→\n    51→      if (opts.reset) {\n    52→        handleReset(dir, opts.story, isJson);\n    53→        return;\n    54→      }\n    55→\n    56→      if (opts.story && !opts.status) {\n    57→        // --story without --reset or --status: warn and show status for that story\n    58→        warn('--story without --reset or --status; showing status for that story');\n    59→      }\n    60→\n    61→      handleStatus(dir, isJson, opts.story);\n    62→    });\n    63→}\n    64→\n    65→function handleReset(dir: string, storyKey: string | undefined, isJson: boolean): void {\n    66→  if (storyKey) {\n    67→    resetRetry(dir, storyKey);\n    68→    if (isJson) {\n    69→      jsonOutput({ status: 'ok', action: 'reset', story: storyKey });\n    70→    } else {\n    71→      ok(`Retry counter and flagged status cleared for ${storyKey}`);\n    72→    }\n    73→  } else {\n    74→    resetRetry(dir);\n    75→    if (isJson) {\n    76→      jsonOutput({ status: 'ok', action: 'reset_all' });\n    77→    } else {\n    78→      ok('All retry counters and flagged stories cleared');\n    79→    }\n    80→  }\n    81→}\n    82→\n    83→function handleStatus(dir: string, isJson: boolean, filterStory?: string): void {\n    84→  const retries = readRetries(dir);\n    85→  const flagged = new Set(readFlaggedStories(dir));\n    86→\n    87→  if (isJson) {\n    88→    const entries: Record<string, { count: number; flagged: boolean }> = {};\n    89→    for (const [key, count] of retries) {\n    90→      if (filterStory && key !== filterStory) continue;\n    91→      entries[key] = { count, flagged: flagged.has(key) };\n    92→    }\n    93→    // Include flagged stories that have no retry entry\n    94→    for (const key of flagged) {\n    95→      if (filterStory && key !== filterStory) continue;\n    96→      if (!entries[key]) {\n    97→        entries[key] = { count: 0, flagged: true };\n    98→      }\n    99→    }\n   100→    jsonOutput({ status: 'ok', entries });\n   101→    return;\n   102→  }\n   103→\n   104→  // Merge keys from both sources\n   105→  const allKeys = new Set([...retries.keys(), ...flagged]);\n   106→  const displayKeys = filterStory\n   107→    ? [...allKeys].filter(k => k === filterStory)\n   108→    : [...allKeys];\n   109→\n   110→  if (displayKeys.length === 0) {\n   111→    console.log('No retry entries.');\n   112→    return;\n   113→  }\n   114→\n   115→  console.log('Story                                  Retries  Flagged');\n   116→  console.log('─'.repeat(55));\n   117→\n   118→  for (const key of displayKeys) {\n   119→    const count = retries.get(key) ?? 0;\n   120→    const isFlagged = flagged.has(key);\n   121→    const paddedKey = key.padEnd(38);\n   122→    const paddedCount = String(count).padStart(4);\n   123→    const flagStr = isFlagged ? '  yes' : '  no';\n   124→    console.log(`${paddedKey} ${paddedCount}${flagStr}`);\n   125→  }\n   126→}\n   127→"}]},"parent_tool_use_id":"toolu_01EPL4eJAP5W5qUxFXY5uuFc","session_id":"6707468c-554d-4568-9ea5-0d04d4a85f59","uuid":"3704e0a9-1f78-4518-bca3-4099fe7e2142","timestamp":"2026-03-24T10:20:59.160Z"}
