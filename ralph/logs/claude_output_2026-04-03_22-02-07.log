y.js';\n30\t\n31\t// Re-export EvaluatorVerdict for downstream consumers that import from workflow-engine\n32\texport type { EvaluatorVerdict } from './verdict-parser.js';\n33\texport { parseVerdict } from './verdict-parser.js';\n34\t\n35\t// --- Interfaces ---\n36\t\n37\t/**\n38\t * Configuration for the workflow engine.\n39\t */\n40\texport interface EngineConfig {\n41\t  /** The resolved workflow with tasks and flow steps. */\n42\t  workflow: ResolvedWorkflow;\n43\t  /** Pre-compiled agent definitions keyed by agent name. */\n44\t  agents: Record<string, SubagentDefinition>;\n45\t  /** Path to sprint-status.yaml for work item discovery. */\n46\t  sprintStatusPath: string;\n47\t  /** Optional path to issues.yaml for additional work items. */\n48\t  issuesPath?: string;\n49\t  /** Unique identifier for this engine run. */\n50\t  runId: string;\n51\t  /** Project root directory. Defaults to process.cwd(). */\n52\t  projectDir?: string;\n53\t  /** Maximum loop iterations before termination. Defaults to 5. */\n54\t  maxIterations?: number;\n55\t}\n56\t\n57\t/**\n58\t * Result returned by executeWorkflow().\n59\t */\n60\texport interface EngineResult {\n61\t  /** Whether the workflow completed without errors. */\n62\t  success: boolean;\n63\t  /** Number of task dispatches completed. */\n64\t  tasksCompleted: number;\n65\t  /** Number of work items (stories/issues) processed. */\n66\t  storiesProcessed: number;\n67\t  /** Errors encountered during execution. */\n68\t  errors: EngineError[];\n69\t  /** Wall-clock duration of the entire workflow in milliseconds. */\n70\t  durationMs: number;\n71\t}\n72\t\n73\t/**\n74\t * Structured error recorded during workflow execution.\n75\t */\n76\texport interface EngineError {\n77\t  taskName: string;\n78\t  storyKey: string;\n79\t  code: string;\n80\t  message: string;\n81\t}\n82\t\n83\t/**\n84\t * A work item (story or issue) ready for execution.\n85\t */\n86\texport interface WorkItem {\n87\t  key: string;\n88\t  title?: string;\n89\t  source: 'sprint' | 'issues';\n90\t}\n91\t\n92\t// --- Constants ---\n93\t\n94\t/** Sentinel story key for per-run tasks. */\n95\texport const PER_RUN_SENTINEL = '__run__';\n96\t\n97\t/** DispatchError codes that should halt execution immediately. */\n98\tconst HALT_ERROR_CODES = new Set(['RATE_LIMIT', 'NETWORK', 'SDK_INIT']);\n99\t\n100\t/** Default maximum loop iterations before termination. */"}]},"parent_tool_use_id":"toolu_017cqb76qurL8ij6LsD8qadk","session_id":"9476bbd2-ee0a-4a5e-ac2a-0ed5228c47bf","uuid":"ed08f094-f5a3-4ebc-b7a7-6a34468fbad0","timestamp":"2026-04-03T18:06:54.290Z"}
