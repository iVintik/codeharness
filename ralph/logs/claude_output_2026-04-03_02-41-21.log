orkflow(config);\n1356\t\n1357\t    expect(result.success).toBe(false);\n1358\t    // 3 iterations × 2 tasks per iteration = 6\n1359\t    expect(mockDispatchAgent).toHaveBeenCalledTimes(6);\n1360\t\n1361\t    // State should have phase=max-iterations\n1362\t    const lastWriteCall = mockWriteWorkflowState.mock.calls[mockWriteWorkflowState.mock.calls.length - 1];\n1363\t    const finalState = lastWriteCall[0] as WorkflowState;\n1364\t    expect(finalState.phase).toBe('max-iterations');\n1365\t  });\n1366\t\n1367\t  it('terminates loop when circuit_breaker.triggered is true (AC #4)', async () => {\n1368\t    let dispatchCount = 0;\n1369\t    mockDispatchAgent.mockImplementation(\n1370\t      async (_def: SubagentDefinition, prompt: string) => {\n1371\t        dispatchCount++;\n1372\t        if (prompt.includes('Execute task')) {\n1373\t          return { sessionId: 'sess-v', success: true, durationMs: 100, output: makeFailVerdict() };\n1374\t        }\n1375\t        return { sessionId: 'sess-r', success: true, durationMs: 100, output: 'ok' };\n1376\t      },\n1377\t    );\n1378\t\n1379\t    // Simulate external circuit breaker trigger: after first iteration completes,\n1380\t    // the writeWorkflowState mock mutates the circuit_breaker object on the state.\n1381\t    // This works because executeLoopBlock uses shallow spread ({ ...currentState }),\n1382\t    // which preserves the circuit_breaker object reference.\n1383\t    mockWriteWorkflowState.mockImplementation((state: WorkflowState) => {\n1384\t      if (dispatchCount >= 2) {\n1385\t        state.circuit_breaker.triggered = true;\n1386\t        state.circuit_breaker.reason = 'score plateau';\n1387\t      }\n1388\t    });\n1389\t\n1390\t    mockParse.mockReturnValue({\n1391\t      development_status: { '3-1-foo': 'ready-for-dev' },\n1392\t    });\n1393\t\n1394\t    const config = makeConfig({\n1395\t      workflow: {\n1396\t        tasks: {\n1397\t          retry: makeTask({ scope: 'per-story' }),\n1398\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n1399\t        },"}]},"parent_tool_use_id":"toolu_01GD3dd86R9DYmBSHRKfrVV3","session_id":"8b4a1da7-9e18-4302-ad13-ce7f0aff0314","uuid":"232d27a1-81f3-40d4-ba92-4f166b56d61b","timestamp":"2026-04-02T22:53:47.810Z"}
