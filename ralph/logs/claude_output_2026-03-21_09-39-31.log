{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Dsv8wJ36waNdi3ShDT57rg","type":"tool_result","content":"     1→/**\n     2→ * Project initialization orchestrator.\n     3→ * Composes sub-steps: stack detection, deps, Docker, BMAD, beads, state, docs, OTLP.\n     4→ */\n     5→\n     6→import { existsSync } from 'node:fs';\n     7→import { basename } from 'node:path';\n     8→import { ok as okOutput, fail as failOutput, info, jsonOutput } from '../../lib/output.js';\n     9→import { detectStack, detectAppType } from '../../lib/stack-detect.js';\n    10→import { readState, writeState, getDefaultState, getStatePath } from '../../lib/state.js';\n    11→import type { HarnessState } from '../../lib/state.js';\n    12→import { instrumentProject } from '../../lib/otlp.js';\n    13→import type { Result } from '../../types/result.js';\n    14→import { ok, fail, isOk } from '../../types/result.js';\n    15→import type { InitOptions, InitResult } from './types.js';\n    16→import { checkDocker, setupDocker } from './docker-setup.js';\n    17→import { installDeps, verifyDeps } from './deps-install.js';\n    18→import { setupBmad, verifyBmadOnRerun } from './bmad-setup.js';\n    19→import { initializeBeads } from './beads-init.js';\n    20→import { scaffoldDocs, getCoverageTool, getStackLabel } from './docs-scaffold.js';\n    21→\n    22→declare const __PKG_VERSION__: string;\n    23→const HARNESS_VERSION = typeof __PKG_VERSION__ !== 'undefined' ? __PKG_VERSION__ : '0.0.0-dev';\n    24→\n    25→/** Helper: build a fail-status InitResult for early returns */\n    26→function failResult(opts: InitOptions, error: string): InitResult {\n    27→  return {\n    28→    status: 'fail', stack: null, error,\n    29→    enforcement: { frontend: opts.frontend, database: opts.database, api: opts.api },\n    30→    documentation: { agents_md: 'skipped', docs_scaffold: 'skipped', readme: 'skipped' },\n    31→  };\n    32→}\n    33→\n    34→/** Output error and set exit code for validation/critical failures */\n    35→function emitError(error: string, isJson: boolean): void {\n    36→  if (isJson) { jsonOutput({ status: 'fail', error }); } else { failOutput(error); }\n    37→  process.exitCode = 1;\n    38→}\n    39→\n    40→/** Main project initialization orchestrator. Never throws — returns fail() on unexpected errors. */\n    41→export async function initProject(opts: InitOptions): Promise<Result<InitResult>> {\n    42→  try {\n    43→    return await initProjectInner(opts);\n    44→  } catch (err) {\n    45→    const message = err instanceof Error ? err.message : String(err);\n    46→    return fail(`Unexpected init error: ${message}`);\n    47→  }\n    48→}\n    49→\n    50→async function initProjectInner(opts: InitOptions): Promise<Result<InitResult>> {\n    51→  const { projectDir, json: isJson = false } = opts;\n    52→  const result: InitResult = {\n    53→    status: 'ok', stack: null,\n    54→    enforcement: { frontend: opts.frontend, database: opts.database, api: opts.api },\n    55→    documentation: { agents_md: 'skipped', docs_scaffold: 'skipped', readme: 'skipped' },\n    56→  };\n    57→\n    58→  // --- Idempotent re-run check ---\n    59→  const rerunResult = handleRerun(opts, result);\n    60→  if (rerunResult !== null) return rerunResult;\n    61→\n    62→  // --- Remote endpoint URL validation ---\n    63→  const urlError = validateRemoteUrls(opts);\n    64→  if (urlError !== null) { emitError(urlError, isJson); return ok(failResult(opts, urlError)); }\n    65→\n    66→  // --- Stack detection ---\n    67→  const stack = detectStack(projectDir);\n    68→  result.stack = stack;\n    69→  const appType = detectAppType(projectDir, stack);\n    70→  result.app_type = appType;\n    71→  if (!isJson) {\n    72→    if (stack) info(`Stack detected: ${getStackLabel(stack)}`);\n    73→    info(`App type: ${appType}`);\n    74→  }\n    75→\n    76→  // --- Docker check ---\n    77→  const dockerCheck = checkDocker({ observability: opts.observability, otelEndpoint: opts.otelEndpoint, logsUrl: opts.logsUrl, opensearchUrl: opts.opensearchUrl, isJson });\n    78→  if (!isOk(dockerCheck)) return fail(dockerCheck.error);\n    79→  const { available: dockerAvailable, criticalFailure, dockerResult: criticalDockerResult } = dockerCheck.data;\n    80→  if (criticalFailure) {\n    81→    result.status = 'fail'; result.error = 'Docker not installed'; result.docker = criticalDockerResult;\n    82→    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); }\n    83→    else { failOutput('Docker not installed'); info('\\u2192 Install Docker: https://docs.docker.com/engine/install/'); info('\\u2192 Or skip observability: codeharness init --no-observability'); }\n    84→    process.exitCode = 1;\n    85→    return ok(result);\n    86→  }\n    87→\n    88→  // --- Dependency install ---\n    89→  const depResult = installDeps({ isJson });\n    90→  if (!isOk(depResult)) {\n    91→    result.status = 'fail'; result.error = depResult.error;\n    92→    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); } else { info('Critical dependency failed — aborting init'); }\n    93→    process.exitCode = 1;\n    94→    return ok(result);\n    95→  }\n    96→  result.dependencies = depResult.data;\n    97→\n    98→  // --- Beads initialization ---\n    99→  result.beads = initializeBeads(projectDir, isJson);\n   100→\n   101→  // --- BMAD installation ---\n   102→  const bmadResult = setupBmad({ projectDir, isJson });\n   103→  if (isOk(bmadResult)) result.bmad = bmadResult.data;\n   104→\n   105→  // --- State file creation ---\n   106→  let state: HarnessState = getDefaultState(stack);\n   107→  state.harness_version = HARNESS_VERSION;\n   108→  state.initialized = true;\n   109→  state.app_type = appType;\n   110→  state.enforcement = { frontend: opts.frontend, database: opts.database, api: opts.api };\n   111→  state.coverage.tool = getCoverageTool(stack);\n   112→  writeState(state, projectDir);\n   113→  if (!isJson) okOutput('State file: .claude/codeharness.local.md created');\n   114→\n   115→  // --- Documentation scaffold ---\n   116→  const docsResult = await scaffoldDocs({ projectDir, stack, isJson });\n   117→  if (isOk(docsResult)) result.documentation = docsResult.data;\n   118→\n   119→  // --- OTLP instrumentation ---\n   120→  if (!opts.observability) {\n   121→    result.otlp = { status: 'skipped', packages_installed: false, start_script_patched: false, env_vars_configured: false };\n   122→    if (!isJson) info('OTLP: skipped (--no-observability)');\n   123→  } else {\n   124→    result.otlp = instrumentProject(projectDir, stack, { json: isJson, appType });\n   125→  }\n   126→\n   127→  // Re-read state to pick up otlp changes written by instrumentProject\n   128→  try { const u = readState(projectDir); if (u.otlp) state.otlp = u.otlp; } catch { /* ignore */ }\n   129→  if (!state.otlp) {\n   130→    state.otlp = { enabled: true, endpoint: 'http://localhost:4318', service_name: basename(projectDir), mode: 'local-shared' };\n   131→  }\n   132→\n   133→  // --- Docker stack setup ---\n   134→  const dockerSetup = setupDocker({\n   135→    observability: opts.observability, otelEndpoint: opts.otelEndpoint,\n   136→    opensearchUrl: opts.opensearchUrl,\n   137→    logsUrl: opts.logsUrl, metricsUrl: opts.metricsUrl, tracesUrl: opts.tracesUrl,\n   138→    isJson, dockerAvailable, appType, state, projectDir,\n   139→  });\n   140→  if (isOk(dockerSetup)) result.docker = dockerSetup.data.docker;\n   141→\n   142→  // --- Enforcement summary ---\n   143→  if (!isJson) {\n   144→    const e = state.enforcement;\n   145→    const fmt = (v: boolean): string => v ? 'ON' : 'OFF';\n   146→    okOutput(`Enforcement: frontend:${fmt(e.frontend)} database:${fmt(e.database)} api:${fmt(e.api)} observability:ON`);\n   147→    info('Harness initialized. Run: codeharness bridge --epics <path>');\n   148→  }\n   149→  if (isJson) jsonOutput(result as unknown as Record<string, unknown>);\n   150→\n   151→  return ok(result);\n   152→}\n   153→\n   154→function handleRerun(opts: InitOptions, result: InitResult): Result<InitResult> | null {\n   155→  const { projectDir, json: isJson = false } = opts;\n   156→  if (!existsSync(getStatePath(projectDir))) return null;\n   157→\n   158→  try {\n   159→    const existingState = readState(projectDir);\n   160→    const legacyObsDisabled = (existingState.enforcement as Record<string, unknown>).observability === false;\n   161→    if (!existingState.initialized || legacyObsDisabled) {\n   162→      if (legacyObsDisabled && !isJson) info('Observability upgraded from disabled to enabled');\n   163→      return null;\n   164→    }\n   165→    result.stack = existingState.stack;\n   166→    result.enforcement = existingState.enforcement;\n   167→    result.documentation = { agents_md: 'exists', docs_scaffold: 'exists', readme: 'exists' };\n   168→    result.dependencies = verifyDeps(isJson);\n   169→    result.docker = existingState.docker\n   170→      ? { compose_file: existingState.docker.compose_file, stack_running: existingState.docker.stack_running, services: [], ports: existingState.docker.ports }\n   171→      : null;\n   172→    const bmadResult = verifyBmadOnRerun(projectDir, isJson);\n   173→    if (bmadResult) result.bmad = bmadResult;\n   174→    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); }\n   175→    else { info('Harness already initialized — verifying configuration'); okOutput('Configuration verified'); }\n   176→    return ok(result);\n   177→  } catch {\n   178→    return null;\n   179→  }\n   180→}\n   181→\n   182→/** Returns error message string if validation fails, null if OK */\n   183→function validateRemoteUrls(opts: InitOptions): string | null {\n   184→  const remoteUrls = [opts.otelEndpoint, opts.opensearchUrl, opts.logsUrl, opts.metricsUrl, opts.tracesUrl].filter(Boolean) as string[];\n   185→  for (const url of remoteUrls) {\n   186→    if (!/^https?:\\/\\//i.test(url)) return `Invalid URL: '${url}' \\u2014 must start with http:// or https://`;\n   187→  }\n   188→  if (opts.otelEndpoint && (opts.logsUrl || opts.metricsUrl || opts.tracesUrl)) {\n   189→    return 'Cannot combine --otel-endpoint with --logs-url/--metrics-url/--traces-url';\n   190→  }\n   191→  const hasAny = opts.logsUrl || opts.metricsUrl || opts.tracesUrl;\n   192→  if (hasAny && !(opts.logsUrl && opts.metricsUrl && opts.tracesUrl)) {\n   193→    return 'When using remote backends, all three are required: --logs-url, --metrics-url, --traces-url';\n   194→  }\n   195→  return null;\n   196→}\n   197→"}]},"parent_tool_use_id":"toolu_01MfXggqZdC7KtDFQHUh8K9V","session_id":"44e99ebb-e385-42dc-a684-d204e4d10303","uuid":"b5e246fd-dcc7-48f6-a4e3-117f693d0e45","timestamp":"2026-03-21T05:44:44.738Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CS5v4oq4ZiZteBpjw2uVSx","type":"tool_result","content":"     1→/**\n     2→ * Discriminated union Result type for consistent error handling.\n     3→ * All module functions return Result<T> instead of throwing exceptions.\n     4→ */\n     5→\n     6→/** Successful result carrying data of type T */\n     7→export interface Ok<T> {\n     8→  readonly success: true;\n     9→  readonly data: T;\n    10→}\n    11→\n    12→/** Failed result carrying an error message and optional context */\n    13→export interface Fail {\n    14→  readonly success: false;\n    15→  readonly error: string;\n    16→  readonly context?: Record<string, unknown>;\n    17→}\n    18→\n    19→/** Discriminated union: success field is the discriminant */\n    20→export type Result<T> = Ok<T> | Fail;\n    21→\n    22→/** Construct a successful Result */\n    23→export function ok<T>(data: T): Result<T> {\n    24→  return { success: true, data };\n    25→}\n    26→\n    27→/** Construct a failed Result, assignable to any Result<T> */\n    28→export function fail(error: string, context?: Record<string, unknown>): Result<never> {\n    29→  if (context !== undefined) {\n    30→    return { success: false, error, context };\n    31→  }\n    32→  return { success: false, error };\n    33→}\n    34→\n    35→/** Type guard: narrows Result<T> to Ok<T> */\n    36→export function isOk<T>(result: Result<T>): result is Ok<T> {\n    37→  return result.success === true;\n    38→}\n    39→\n    40→/** Type guard: narrows Result<T> to Fail */\n    41→export function isFail<T>(result: Result<T>): result is Fail {\n    42→  return result.success === false;\n    43→}\n    44→"}]},"parent_tool_use_id":"toolu_01MfXggqZdC7KtDFQHUh8K9V","session_id":"44e99ebb-e385-42dc-a684-d204e4d10303","uuid":"0ac6e2cf-ef97-4b14-bb61-f7721fd1c78b","timestamp":"2026-03-21T05:44:44.736Z"}
