{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LBiJMqYyBgmuePRz9Rrepd","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach } from 'vitest';\n2\timport type { AgentDriver, DispatchOpts, DriverHealth } from '../types.js';\n3\timport type { StreamEvent } from '../stream-parser.js';\n4\timport type { ResolvedWorkflow } from '../../workflow-parser.js';\n5\timport { registerDriver, resetDrivers } from '../drivers/factory.js';\n6\timport { checkCapabilityConflicts } from '../capability-check.js';\n7\t\n8\t// --- Helpers ---\n9\t\n10\tfunction createMockDriver(\n11\t  name: string,\n12\t  opts: { supportsPlugins?: boolean; costTier?: number } = {},\n13\t): AgentDriver {\n14\t  return {\n15\t    name,\n16\t    defaultModel: 'mock-model',\n17\t    capabilities: {\n18\t      supportsPlugins: opts.supportsPlugins ?? true,\n19\t      supportsStreaming: true,\n20\t      costReporting: true,\n21\t      costTier: opts.costTier ?? 1,\n22\t    },\n23\t    async healthCheck(): Promise<DriverHealth> {\n24\t      return { available: true, authenticated: true, version: '1.0.0' };\n25\t    },\n26\t    async *dispatch(_opts: DispatchOpts): AsyncIterable<StreamEvent> {\n27\t      yield { type: 'text', text: 'mock' };\n28\t    },\n29\t    getLastCost: () => null,\n30\t  };\n31\t}\n32\t\n33\tfunction makeWorkflow(\n34\t  tasks: Record<string, { driver?: string; plugins?: string[] }>,\n35\t): ResolvedWorkflow {\n36\t  const resolved: Record<string, {\n37\t    agent: string;\n38\t    scope: 'per-story' | 'per-run';\n39\t    session: 'fresh' | 'continue';\n40\t    source_access: boolean;\n41\t    driver?: string;\n42\t    plugins?: string[];\n43\t  }> = {};\n44\t  for (const [name, task] of Object.entries(tasks)) {\n45\t    resolved[name] = {\n46\t      agent: 'mock',\n47\t      scope: 'per-story',\n48\t      session: 'fresh',\n49\t      source_access: true,\n50\t      driver: task.driver,\n51\t      plugins: task.plugins,\n52\t    };\n53\t  }\n54\t  return { tasks: resolved, flow: Object.keys(tasks) };\n55\t}\n56\t\n57\t// --- Tests ---\n58\t\n59\tdescribe('capability-check — checkCapabilityConflicts', () => {\n60\t  beforeEach(() => {\n61\t    resetDrivers();\n62\t  });\n63\t\n64\t  it('returns empty array when all capabilities match', () => {\n65\t    registerDriver(createMockDriver('claude-code', { supportsPlugins: true, costTier: 3 }));\n66\t    const workflow = makeWorkflow({\n67\t      implement: { driver: 'claude-code', plugins: ['gstack'] },\n68\t    });\n69\t    const warnings = checkCapabilityConflicts(workflow);\n70\t    // No conflict because claude-code supports plugins; but may have cost advisory\n71\t    const conflicts = warnings.filter(w => w.capability === 'supportsPlugins');\n72\t    expect(conflicts).toHaveLength(0);\n73\t  });\n74\t\n75\t  it('warns when task uses plugins on a driver without supportsPlugins', () => {\n76\t    registerDriver(createMockDriver('codex', { supportsPlugins: false, costTier: 1 }));\n77\t    const workflow = makeWorkflow({\n78\t      implement: { driver: 'codex', plugins: ['gstack'] },\n79\t    });\n80\t    const warnings = checkCapabilityConflicts(workflow);\n81\t    const conflicts = warnings.filter(w => w.capability === 'supportsPlugins');\n82\t    expect(conflicts).toHaveLength(1);\n83\t    expect(conflicts[0].taskName).toBe('implement');\n84\t    expect(conflicts[0].driverName).toBe('codex');\n85\t    expect(conflicts[0].message).toContain('supportsPlugins');\n86\t  });\n87\t\n88\t  it('no conflict when task has no plugins', () => {\n89\t    registerDriver(createMockDriver('codex', { supportsPlugins: false, costTier: 1 }));\n90\t    const workflow = makeWorkflow({\n91\t      implement: { driver: 'codex' },\n92\t    });\n93\t    const warnings = checkCapabilityConflicts(workflow);\n94\t    expect(warnings).toHaveLength(0);\n95\t  });\n96\t\n97\t  it('no conflict when task has empty plugins array', () => {\n98\t    registerDriver(createMockDriver('codex', { supportsPlugins: false, costTier: 1 }));\n99\t    const workflow = makeWorkflow({\n100\t      implement: { driver: 'codex', plugins: [] },\n101\t    });\n102\t    const warnings = checkCapabilityConflicts(workflow);\n103\t    expect(warnings).toHaveLength(0);\n104\t  });\n105\t\n106\t  it('generates routing hint when driver costs >2x cheapest capable', () => {\n107\t    registerDriver(createMockDriver('codex', { supportsPlugins: false, costTier: 1 }));\n108\t    registerDriver(createMockDriver('claude-code', { supportsPlugins: true, costTier: 3 }));\n109\t    // Task with no plugins — codex can handle it, and costs 3x less\n110\t    const workflow = makeWorkflow({\n111\t      implement: { driver: 'claude-code' },\n112\t    });\n113\t    const warnings = checkCapabilityConflicts(workflow);\n114\t    const advisories = warnings.filter(w => w.capability === 'costTier');\n115\t    expect(advisories).toHaveLength(1);\n116\t    expect(advisories[0].message).toContain('Advisory');\n117\t    expect(advisories[0].message).toContain('codex');\n118\t    expect(advisories[0].message).toContain('lower cost');\n119\t  });\n120\t\n121\t  it('no routing hint when driver is cheapest capable', () => {\n122\t    registerDriver(createMockDriver('codex', { supportsPlugins: false, costTier: 1 }));\n123\t    registerDriver(createMockDriver('claude-code', { supportsPlugins: true, costTier: 3 }));\n124\t    const workflow = makeWorkflow({\n125\t      implement: { driver: 'codex' },\n126\t    });\n127\t    const warnings = checkCapabilityConflicts(workflow);\n128\t    const advisories = warnings.filter(w => w.capability === 'costTier');\n129\t    expect(advisories).toHaveLength(0);\n130\t  });\n131\t\n132\t  it('no routing hint when cost difference is not >2x', () => {\n133\t    registerDriver(createMockDriver('opencode', { supportsPlugins: true, costTier: 2 }));\n134\t    registerDriver(createMockDriver('codex', { supportsPlugins: false, costTier: 1 }));\n135\t    // opencode costTier 2, codex costTier 1: 2 > 2*1 is false\n136\t    const workflow = makeWorkflow({\n137\t      implement: { driver: 'opencode', plugins: ['gstack'] },\n138\t    });\n139\t    const warnings = checkCapabilityConflicts(workflow);\n140\t    const advisories = warnings.filter(w => w.capability === 'costTier');\n141\t    expect(advisories).toHaveLength(0);\n142\t  });\n143\t\n144\t  it('returns CapabilityWarning objects with all required fields', () => {\n145\t    registerDriver(createMockDriver('codex', { supportsPlugins: false, costTier: 1 }));\n146\t    const workflow = makeWorkflow({\n147\t      implement: { driver: 'codex', plugins: ['gstack'] },\n148\t    });\n149\t    const warnings = checkCapabilityConflicts(workflow);\n150\t    expect(warnings.length).toBeGreaterThan(0);\n151\t    for (const w of warnings) {\n152\t      expect(w).toHaveProperty('taskName');\n153\t      expect(w).toHaveProperty('driverName');\n154\t      expect(w).toHaveProperty('capability');\n155\t      expect(w).toHaveProperty('message');\n156\t      expect(typeof w.taskName).toBe('string');\n157\t      expect(typeof w.driverName).toBe('string');\n158\t      expect(typeof w.capability).toBe('string');\n159\t      expect(typeof w.message).toBe('string');\n160\t    }\n161\t  });\n162\t\n163\t  it('is a pure query — does not throw', () => {\n164\t    registerDriver(createMockDriver('codex', { supportsPlugins: false, costTier: 1 }));\n165\t    const workflow = makeWorkflow({\n166\t      implement: { driver: 'codex', plugins: ['gstack'] },\n167\t    });\n168\t    expect(() => checkCapabilityConflicts(workflow)).not.toThrow();\n169\t  });\n170\t\n171\t  it('skips tasks with unregistered drivers (no crash)', () => {\n172\t    const workflow = makeWorkflow({\n173\t      implement: { driver: 'nonexistent', plugins: ['gstack'] },\n174\t    });\n175\t    expect(() => checkCapabilityConflicts(workflow)).not.toThrow();\n176\t    expect(checkCapabilityConflicts(workflow)).toEqual([]);\n177\t  });\n178\t\n179\t  it('defaults driver to claude-code when task.driver is undefined', () => {\n180\t    registerDriver(createMockDriver('claude-code', { supportsPlugins: true, costTier: 3 }));\n181\t    registerDriver(createMockDriver('codex', { supportsPlugins: false, costTier: 1 }));\n182\t    const workflow = makeWorkflow({\n183\t      implement: { plugins: ['gstack'] }, // no driver specified\n184\t    });\n185\t    const warnings = checkCapabilityConflicts(workflow);\n186\t    // Should not have supportsPlugins conflict (claude-code supports plugins)\n187\t    const conflicts = warnings.filter(w => w.capability === 'supportsPlugins');\n188\t    expect(conflicts).toHaveLength(0);\n189\t  });\n190\t\n191\t  it('handles multiple tasks with different issues', () => {\n192\t    registerDriver(createMockDriver('codex', { supportsPlugins: false, costTier: 1 }));\n193\t    registerDriver(createMockDriver('claude-code', { supportsPlugins: true, costTier: 3 }));\n194\t    const workflow = makeWorkflow({\n195\t      task1: { driver: 'codex', plugins: ['gstack'] },\n196\t      task2: { driver: 'claude-code' },\n197\t    });\n198\t    const warnings = checkCapabilityConflicts(workflow);\n199\t    // task1: plugin conflict on codex\n200\t    // task2: cost advisory (claude-code costTier 3 > 2*1)\n201\t    expect(warnings.length).toBeGreaterThanOrEqual(2);\n202\t    expect(warnings.some(w => w.taskName === 'task1' && w.capability === 'supportsPlugins')).toBe(true);\n203\t    expect(warnings.some(w => w.taskName === 'task2' && w.capability === 'costTier')).toBe(true);\n204\t  });\n205\t});\n206\t"}]},"parent_tool_use_id":"toolu_01WL7MCsNF3La2JHGCjnTeXK","session_id":"cf16e575-8267-4c58-a992-20b07458710f","uuid":"12d2513f-25a9-4140-859e-be3745751a55","timestamp":"2026-04-03T13:30:03.633Z"}
