{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JHVY1HhauPfGe3DqjkbAoc","type":"tool_result","content":"     1→/**\n     2→ * Coverage state persistence — tracks observability coverage in sprint-state.json.\n     3→ *\n     4→ * Implements Story 1.3: read/write/trend/target comparison for static analysis coverage.\n     5→ * Only the `static` section is managed here; `runtime` is deferred to Epic 2.\n     6→ */\n     7→\n     8→import { readFileSync, writeFileSync, renameSync, existsSync } from 'node:fs';\n     9→import { join } from 'node:path';\n    10→import { ok, fail } from '../../types/result.js';\n    11→import type { Result } from '../../types/result.js';\n    12→import type {\n    13→  AnalyzerResult,\n    14→  ObservabilityCoverageState,\n    15→  CoverageTrend,\n    16→  CoverageTargetResult,\n    17→  RuntimeCoverageState,\n    18→} from './types.js';\n    19→\n    20→const STATE_FILE = 'sprint-state.json';\n    21→const TMP_FILE = '.sprint-state.json.tmp';\n    22→const DEFAULT_STATIC_TARGET = 80;\n    23→const MAX_HISTORY_ENTRIES = 100;\n    24→\n    25→/**\n    26→ * Default observability coverage state when none exists.\n    27→ */\n    28→function defaultCoverageState(): ObservabilityCoverageState {\n    29→  return {\n    30→    static: {\n    31→      coveragePercent: 0,\n    32→      lastScanTimestamp: '',\n    33→      history: [],\n    34→    },\n    35→    targets: {\n    36→      staticTarget: DEFAULT_STATIC_TARGET,\n    37→    },\n    38→  };\n    39→}\n    40→\n    41→/**\n    42→ * Read the full sprint-state.json as a generic record.\n    43→ */\n    44→function readStateFile(projectDir: string): Result<Record<string, unknown>> {\n    45→  const fp = join(projectDir, STATE_FILE);\n    46→  if (!existsSync(fp)) {\n    47→    return ok({});\n    48→  }\n    49→  try {\n    50→    const raw = readFileSync(fp, 'utf-8');\n    51→    const parsed = JSON.parse(raw) as Record<string, unknown>;\n    52→    return ok(parsed);\n    53→  } catch (err: unknown) {\n    54→    const msg = err instanceof Error ? err.message : String(err);\n    55→    return fail(`Failed to read ${STATE_FILE}: ${msg}`);\n    56→  }\n    57→}\n    58→\n    59→/**\n    60→ * Write sprint-state.json atomically (write to temp, then rename).\n    61→ */\n    62→function writeStateAtomic(\n    63→  projectDir: string,\n    64→  state: Record<string, unknown>,\n    65→): Result<void> {\n    66→  try {\n    67→    const data = JSON.stringify(state, null, 2) + '\\n';\n    68→    const tmp = join(projectDir, TMP_FILE);\n    69→    const final = join(projectDir, STATE_FILE);\n    70→    writeFileSync(tmp, data, 'utf-8');\n    71→    renameSync(tmp, final);\n    72→    return ok(undefined);\n    73→  } catch (err: unknown) {\n    74→    const msg = err instanceof Error ? err.message : String(err);\n    75→    return fail(`Failed to write ${STATE_FILE}: ${msg}`);\n    76→  }\n    77→}\n    78→\n    79→/**\n    80→ * Save coverage result from an analysis run into sprint-state.json.\n    81→ *\n    82→ * Updates `observability.static.coveragePercent`, `observability.static.lastScanTimestamp`,\n    83→ * and appends to `observability.static.history`. Preserves all other state fields.\n    84→ */\n    85→export function saveCoverageResult(\n    86→  projectDir: string,\n    87→  result: AnalyzerResult,\n    88→): Result<void> {\n    89→  if (!projectDir || typeof projectDir !== 'string') {\n    90→    return fail('projectDir is required and must be a non-empty string');\n    91→  }\n    92→\n    93→  const stateResult = readStateFile(projectDir);\n    94→  if (!stateResult.success) {\n    95→    return fail(stateResult.error);\n    96→  }\n    97→\n    98→  const state = stateResult.data;\n    99→  const existing = extractCoverageState(state);\n   100→  const timestamp = new Date().toISOString();\n   101→\n   102→  const fullHistory = [\n   103→    ...existing.static.history,\n   104→    { coveragePercent: result.summary.coveragePercent, timestamp },\n   105→  ];\n   106→  // Keep only the most recent entries to prevent unbounded growth\n   107→  const trimmedHistory =\n   108→    fullHistory.length > MAX_HISTORY_ENTRIES\n   109→      ? fullHistory.slice(fullHistory.length - MAX_HISTORY_ENTRIES)\n   110→      : fullHistory;\n   111→\n   112→  const updatedStatic = {\n   113→    coveragePercent: result.summary.coveragePercent,\n   114→    lastScanTimestamp: timestamp,\n   115→    history: trimmedHistory,\n   116→    gaps: result.gaps.map(({ file, line, type, description, severity }) =>\n   117→      ({ file, line, type, description, severity })),\n   118→  };\n   119→\n   120→  const updatedObservability: ObservabilityCoverageState = {\n   121→    static: updatedStatic,\n   122→    targets: existing.targets,\n   123→    ...(existing.runtime ? { runtime: existing.runtime } : {}),\n   124→  };\n   125→\n   126→  const updatedState = {\n   127→    ...state,\n   128→    observability: updatedObservability,\n   129→  };\n   130→\n   131→  return writeStateAtomic(projectDir, updatedState);\n   132→}\n   133→\n   134→/**\n   135→ * Read the observability coverage state from sprint-state.json.\n   136→ *\n   137→ * Returns the typed `ObservabilityCoverageState` from the `observability` key.\n   138→ * If no observability section exists, returns default state.\n   139→ */\n   140→export function readCoverageState(\n   141→  projectDir: string,\n   142→): Result<ObservabilityCoverageState> {\n   143→  if (!projectDir || typeof projectDir !== 'string') {\n   144→    return fail('projectDir is required and must be a non-empty string');\n   145→  }\n   146→\n   147→  const stateResult = readStateFile(projectDir);\n   148→  if (!stateResult.success) {\n   149→    return fail(stateResult.error);\n   150→  }\n   151→\n   152→  return ok(extractCoverageState(stateResult.data));\n   153→}\n   154→\n   155→/**\n   156→ * Get coverage trend by comparing latest vs previous history entries.\n   157→ */\n   158→export function getCoverageTrend(projectDir: string): Result<CoverageTrend> {\n   159→  if (!projectDir || typeof projectDir !== 'string') {\n   160→    return fail('projectDir is required and must be a non-empty string');\n   161→  }\n   162→\n   163→  const stateResult = readCoverageState(projectDir);\n   164→  if (!stateResult.success) {\n   165→    return fail(stateResult.error);\n   166→  }\n   167→\n   168→  const { history } = stateResult.data.static;\n   169→\n   170→  if (history.length === 0) {\n   171→    return ok({\n   172→      current: 0,\n   173→      previous: null,\n   174→      delta: null,\n   175→      currentTimestamp: '',\n   176→      previousTimestamp: null,\n   177→    });\n   178→  }\n   179→\n   180→  const latest = history[history.length - 1];\n   181→\n   182→  if (history.length === 1) {\n   183→    return ok({\n   184→      current: latest.coveragePercent,\n   185→      previous: null,\n   186→      delta: null,\n   187→      currentTimestamp: latest.timestamp,\n   188→      previousTimestamp: null,\n   189→    });\n   190→  }\n   191→\n   192→  const prev = history[history.length - 2];\n   193→  return ok({\n   194→    current: latest.coveragePercent,\n   195→    previous: prev.coveragePercent,\n   196→    delta: latest.coveragePercent - prev.coveragePercent,\n   197→    currentTimestamp: latest.timestamp,\n   198→    previousTimestamp: prev.timestamp,\n   199→  });\n   200→}\n   201→\n   202→/**\n   203→ * Check current coverage against a target threshold.\n   204→ *\n   205→ * @param projectDir - Project root directory\n   206→ * @param target - Target percentage (default 80%)\n   207→ * @returns Structured result indicating whether coverage meets the target\n   208→ */\n   209→export function checkCoverageTarget(\n   210→  projectDir: string,\n   211→  target?: number,\n   212→): Result<CoverageTargetResult> {\n   213→  if (!projectDir || typeof projectDir !== 'string') {\n   214→    return fail('projectDir is required and must be a non-empty string');\n   215→  }\n   216→\n   217→  const stateResult = readCoverageState(projectDir);\n   218→  if (!stateResult.success) {\n   219→    return fail(stateResult.error);\n   220→  }\n   221→\n   222→  const effectiveTarget = target ?? stateResult.data.targets.staticTarget;\n   223→  const current = stateResult.data.static.coveragePercent;\n   224→  const met = current >= effectiveTarget;\n   225→  const gap = met ? 0 : effectiveTarget - current;\n   226→\n   227→  return ok({ met, current, target: effectiveTarget, gap });\n   228→}\n   229→\n   230→/**\n   231→ * Extract typed ObservabilityCoverageState from raw sprint-state.json data.\n   232→ * Returns defaults when the observability section doesn't exist.\n   233→ */\n   234→function extractCoverageState(\n   235→  state: Record<string, unknown>,\n   236→): ObservabilityCoverageState {\n   237→  const obs = state.observability as Record<string, unknown> | undefined;\n   238→  if (!obs) {\n   239→    return defaultCoverageState();\n   240→  }\n   241→\n   242→  const staticSection = obs.static as Record<string, unknown> | undefined;\n   243→  const targets = obs.targets as Record<string, unknown> | undefined;\n   244→  const runtimeSection = obs.runtime as Record<string, unknown> | undefined;\n   245→\n   246→  const runtime: RuntimeCoverageState | undefined =\n   247→    runtimeSection && typeof runtimeSection.coveragePercent === 'number'\n   248→      ? {\n   249→          coveragePercent: runtimeSection.coveragePercent,\n   250→          lastValidationTimestamp:\n   251→            typeof runtimeSection.lastValidationTimestamp === 'string'\n   252→              ? runtimeSection.lastValidationTimestamp : '',\n   253→          modulesWithTelemetry:\n   254→            typeof runtimeSection.modulesWithTelemetry === 'number'\n   255→              ? runtimeSection.modulesWithTelemetry : 0,\n   256→          totalModules:\n   257→            typeof runtimeSection.totalModules === 'number'\n   258→              ? runtimeSection.totalModules : 0,\n   259→          telemetryDetected:\n   260→            typeof runtimeSection.telemetryDetected === 'boolean'\n   261→              ? runtimeSection.telemetryDetected : false,\n   262→        }\n   263→      : undefined;\n   264→\n   265→  const result: ObservabilityCoverageState = {\n   266→    static: {\n   267→      coveragePercent:\n   268→        typeof staticSection?.coveragePercent === 'number'\n   269→          ? staticSection.coveragePercent\n   270→          : 0,\n   271→      lastScanTimestamp:\n   272→        typeof staticSection?.lastScanTimestamp === 'string'\n   273→          ? staticSection.lastScanTimestamp\n   274→          : '',\n   275→      history: Array.isArray(staticSection?.history)\n   276→        ? (staticSection.history as unknown[]).filter(\n   277→            (entry): entry is { coveragePercent: number; timestamp: string } =>\n   278→              typeof entry === 'object' &&\n   279→              entry !== null &&\n   280→              typeof (entry as Record<string, unknown>).coveragePercent ===\n   281→                'number' &&\n   282→              typeof (entry as Record<string, unknown>).timestamp === 'string',\n   283→          )\n   284→        : [],\n   285→    },\n   286→    targets: {\n   287→      staticTarget:\n   288→        typeof targets?.staticTarget === 'number'\n   289→          ? targets.staticTarget\n   290→          : DEFAULT_STATIC_TARGET,\n   291→      ...(typeof targets?.runtimeTarget === 'number'\n   292→        ? { runtimeTarget: targets.runtimeTarget }\n   293→        : {}),\n   294→    },\n   295→    ...(runtime ? { runtime } : {}),\n   296→  };\n   297→\n   298→  return result;\n   299→}\n   300→"}]},"parent_tool_use_id":"toolu_01KDp23Ghg12YdfCMhs2iDP9","session_id":"2fa32674-558d-4231-8eb7-1997dc535a41","uuid":"0733d793-c5be-42e7-8156-39d596c55d7c","timestamp":"2026-03-20T06:20:03.871Z"}
