{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PgKeZuJzBa1XxA2PqN8xrS","type":"tool_result","content":"1\t/**\n2\t * Output contract serialization and deserialization.\n3\t *\n4\t * Provides atomic write/read for OutputContract JSON files.\n5\t * Written atomically: first to a .tmp file, then renamed to final path.\n6\t * See architecture-multi-framework.md Decision 3.\n7\t */\n8\t\n9\timport { writeFileSync, readFileSync, renameSync, mkdirSync, existsSync } from 'node:fs';\n10\timport { join, resolve } from 'node:path';\n11\timport type { OutputContract } from './types.js';\n12\t\n13\t/**\n14\t * Validate that a string is a safe filename component (no path separators, not empty).\n15\t */\n16\tfunction assertSafeComponent(value: string, label: string): void {\n17\t  if (!value || value.trim().length === 0) {\n18\t    throw new Error(`${label} must be a non-empty string`);\n19\t  }\n20\t  if (value.includes('/') || value.includes('\\\\') || value.includes('..')) {\n21\t    throw new Error(`${label} contains invalid path characters: ${value}`);\n22\t  }\n23\t}\n24\t\n25\t/**\n26\t * Compute the file path for a contract.\n27\t * Validates that taskName and storyId are safe filename components.\n28\t */\n29\tfunction contractFilePath(taskName: string, storyId: string, contractDir: string): string {\n30\t  assertSafeComponent(taskName, 'taskName');\n31\t  assertSafeComponent(storyId, 'storyId');\n32\t  const filePath = join(contractDir, `${taskName}-${storyId}.json`);\n33\t  // Ensure the resolved path is inside the contract directory\n34\t  const resolvedDir = resolve(contractDir);\n35\t  const resolvedFile = resolve(filePath);\n36\t  if (!resolvedFile.startsWith(resolvedDir)) {\n37\t    throw new Error(`Path traversal detected: ${filePath} escapes ${contractDir}`);\n38\t  }\n39\t  return filePath;\n40\t}\n41\t\n42\t/**\n43\t * Write an OutputContract to disk atomically.\n44\t *\n45\t * Creates the target directory if it does not exist.\n46\t * Writes to a .tmp file first, then renames to the final path.\n47\t * On failure, throws an error with a descriptive message including the file path.\n48\t */\n49\texport function writeOutputContract(contract: OutputContract, contractDir: string): void {\n50\t  const finalPath = contractFilePath(contract.taskName, contract.storyId, contractDir);\n51\t  const tmpPath = finalPath + '.tmp';\n52\t\n53\t  try {\n54\t    mkdirSync(contractDir, { recursive: true });\n55\t    writeFileSync(tmpPath, JSON.stringify(contract, null, 2) + '\\n', 'utf-8');\n56\t    renameSync(tmpPath, finalPath);\n57\t  } catch (err) {\n58\t    const message = err instanceof Error ? err.message : String(err);\n59\t    throw new Error(`Failed to write output contract to ${finalPath}: ${message}`);\n60\t  }\n61\t}\n62\t\n63\t/**\n64\t * Read an OutputContract from disk.\n65\t *\n66\t * Returns null if the file does not exist.\n67\t */\n68\texport function readOutputContract(\n69\t  taskName: string,\n70\t  storyId: string,\n71\t  contractDir: string,\n72\t): OutputContract | null {\n73\t  const filePath = contractFilePath(taskName, storyId, contractDir);\n74\t\n75\t  if (!existsSync(filePath)) {\n76\t    return null;\n77\t  }\n78\t\n79\t  try {\n80\t    const raw = readFileSync(filePath, 'utf-8');\n81\t    return JSON.parse(raw) as OutputContract;\n82\t  } catch (err) {\n83\t    const message = err instanceof Error ? err.message : String(err);\n84\t    throw new Error(`Failed to read output contract from ${filePath}: ${message}`);\n85\t  }\n86\t}\n87\t"}]},"parent_tool_use_id":"toolu_017MrrsWsE9mo9fwEmkkmV2k","session_id":"be33ba5d-0e81-49c4-ae53-e69ac56cd1fb","uuid":"94e906ac-ac6c-431f-9bb3-961f0d2b6963","timestamp":"2026-04-03T10:15:34.692Z"}
