{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KygL7vbW4v92E7ioeyeU5p","type":"tool_result","content":"     1→import { Command } from 'commander';\n     2→import { ok, fail, info, jsonOutput } from '../lib/output.js';\n     3→import {\n     4→  buildVerifyImage,\n     5→  prepareVerifyWorkspace,\n     6→  checkVerifyEnv,\n     7→  cleanupVerifyEnv,\n     8→  isValidStoryKey,\n     9→} from '../modules/verify/index.js';\n    10→\n    11→export function registerVerifyEnvCommand(program: Command): void {\n    12→  const verifyEnv = program\n    13→    .command('verify-env')\n    14→    .description('Manage verification environment (Docker image + clean workspace)');\n    15→\n    16→  // ─── build ──────────────────────────────────────────────────────────\n    17→  verifyEnv\n    18→    .command('build')\n    19→    .description('Build the verification Docker image from project artifacts')\n    20→    .action((_opts: unknown, cmd: Command) => {\n    21→      const globalOpts = cmd.optsWithGlobals() as { json?: boolean };\n    22→      const isJson = globalOpts.json === true;\n    23→\n    24→      try {\n    25→        const result = buildVerifyImage();\n    26→\n    27→        if (isJson) {\n    28→          jsonOutput({\n    29→            status: 'ok',\n    30→            imageTag: result.imageTag,\n    31→            imageSize: result.imageSize,\n    32→            buildTimeMs: result.buildTimeMs,\n    33→            cached: result.cached,\n    34→          });\n    35→        } else {\n    36→          if (result.cached) {\n    37→            ok(`Image ${result.imageTag}: up to date (cached)`);\n    38→          } else {\n    39→            ok(`Image ${result.imageTag}: built in ${result.buildTimeMs}ms (${result.imageSize})`);\n    40→          }\n    41→        }\n    42→      } catch (err) {\n    43→        const message = err instanceof Error ? err.message : String(err);\n    44→        if (isJson) {\n    45→          jsonOutput({ status: 'fail', message });\n    46→        } else {\n    47→          fail(message);\n    48→        }\n    49→        process.exitCode = 1;\n    50→      }\n    51→    });\n    52→\n    53→  // ─── prepare ────────────────────────────────────────────────────────\n    54→  verifyEnv\n    55→    .command('prepare')\n    56→    .description('Create a clean temp workspace for verification')\n    57→    .requiredOption('--story <key>', 'Story key (e.g., 13-1-verification-dockerfile-generator)')\n    58→    .action((opts: { story: string }, cmd: Command) => {\n    59→      const globalOpts = cmd.optsWithGlobals() as { json?: boolean };\n    60→      const isJson = globalOpts.json === true;\n    61→\n    62→      try {\n    63→        const workspace = prepareVerifyWorkspace(opts.story);\n    64→\n    65→        if (isJson) {\n    66→          jsonOutput({ status: 'ok', workspace, storyKey: opts.story });\n    67→        } else {\n    68→          ok(`Workspace prepared: ${workspace}`);\n    69→        }\n    70→      } catch (err) {\n    71→        const message = err instanceof Error ? err.message : String(err);\n    72→        if (isJson) {\n    73→          jsonOutput({ status: 'fail', message });\n    74→        } else {\n    75→          fail(message);\n    76→        }\n    77→        process.exitCode = 1;\n    78→      }\n    79→    });\n    80→\n    81→  // ─── check ──────────────────────────────────────────────────────────\n    82→  verifyEnv\n    83→    .command('check')\n    84→    .description('Validate verification environment (image, CLI, observability)')\n    85→    .action((_opts: unknown, cmd: Command) => {\n    86→      const globalOpts = cmd.optsWithGlobals() as { json?: boolean };\n    87→      const isJson = globalOpts.json === true;\n    88→\n    89→      const result = checkVerifyEnv();\n    90→      const allPassed = result.imageExists && result.cliWorks && result.otelReachable;\n    91→\n    92→      if (isJson) {\n    93→        const jsonResult: Record<string, unknown> = {\n    94→          status: allPassed ? 'ok' : 'fail',\n    95→          imageExists: result.imageExists,\n    96→          cliWorks: result.cliWorks,\n    97→          otelReachable: result.otelReachable,\n    98→        };\n    99→        if (result.imageExists && !result.cliWorks) {\n   100→          jsonResult.message = 'CLI does not work inside verification container — build or packaging is broken';\n   101→        }\n   102→        jsonOutput(jsonResult);\n   103→      } else {\n   104→        info(`Image exists: ${result.imageExists ? 'yes' : 'no'}`);\n   105→        info(`CLI works in container: ${result.cliWorks ? 'yes' : 'no'}`);\n   106→        info(`OTEL endpoints reachable: ${result.otelReachable ? 'yes' : 'no'}`);\n   107→\n   108→        if (allPassed) {\n   109→          ok('Verification environment: ready');\n   110→        } else {\n   111→          fail('Verification environment: not ready');\n   112→          if (!result.imageExists) {\n   113→            info('Run: codeharness verify-env build');\n   114→          }\n   115→          if (result.imageExists && !result.cliWorks) {\n   116→            fail('CLI does not work inside verification container — build or packaging is broken');\n   117→          }\n   118→          if (!result.otelReachable) {\n   119→            info('Run: codeharness stack start');\n   120→          }\n   121→        }\n   122→      }\n   123→\n   124→      if (!allPassed) {\n   125→        process.exitCode = 1;\n   126→      }\n   127→    });\n   128→\n   129→  // ─── cleanup ────────────────────────────────────────────────────────\n   130→  verifyEnv\n   131→    .command('cleanup')\n   132→    .description('Remove temp workspace and stop/remove container for a story')\n   133→    .requiredOption('--story <key>', 'Story key (e.g., 13-1-verification-dockerfile-generator)')\n   134→    .action((opts: { story: string }, cmd: Command) => {\n   135→      const globalOpts = cmd.optsWithGlobals() as { json?: boolean };\n   136→      const isJson = globalOpts.json === true;\n   137→\n   138→      try {\n   139→        cleanupVerifyEnv(opts.story);\n   140→\n   141→        if (isJson) {\n   142→          jsonOutput({ status: 'ok', storyKey: opts.story, message: 'Cleanup complete' });\n   143→        } else {\n   144→          ok(`Cleanup complete for story: ${opts.story}`);\n   145→        }\n   146→      } catch (err) {\n   147→        const message = err instanceof Error ? err.message : String(err);\n   148→        if (isJson) {\n   149→          jsonOutput({ status: 'fail', message });\n   150→        } else {\n   151→          fail(message);\n   152→        }\n   153→        process.exitCode = 1;\n   154→      }\n   155→    });\n   156→}\n   157→"}]},"parent_tool_use_id":"toolu_01AE5uy3isqvp9ZhM1WQjpz4","session_id":"38809bab-d371-4c03-b647-b7b7381ee002","uuid":"46f1f9be-76b6-4ca0-a56f-0a7e77e6dff9","timestamp":"2026-03-24T23:33:23.456Z"}
