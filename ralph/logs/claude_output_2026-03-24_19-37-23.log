opts.env).toEqual({ FOO: 'bar' });\n    53→    });\n    54→\n    55→    it('allows env to be undefined', () => {\n    56→      const opts: SpawnOpts = {\n    57→        storyKey: 'x',\n    58→        prompt: 'p',\n    59→        workDir: '/w',\n    60→        timeout: 1000,\n    61→      };\n    62→      expect(opts.env).toBeUndefined();\n    63→    });\n    64→  });\n    65→\n    66→  describe('AgentProcess', () => {\n    67→    it('satisfies interface with mock implementation', () => {\n    68→      const proc = createMockProcess();\n    69→      expect(proc.stdout).toBeDefined();\n    70→      expect(proc.stderr).toBeDefined();\n    71→      expect(typeof proc.on).toBe('function');\n    72→      expect(typeof proc.kill).toBe('function');\n    73→    });\n    74→\n    75→    it('supports on close handler', () => {\n    76→      const proc = createMockProcess();\n    77→      let closeCalled = false;\n    78→      proc.on('close', (_code: number) => {\n    79→        closeCalled = true;\n    80→      });\n    81→      // Type-level: this compiles, proving the overload exists\n    82→      expect(closeCalled).toBe(false);\n    83→    });\n    84→\n    85→    it('supports on error handler', () => {\n    86→      const proc = createMockProcess();\n    87→      let errorCalled = false;\n    88→      proc.on('error', (_err: Error) => {\n    89→        errorCalled = true;\n    90→      });\n    91→      // Type-level: this compiles, proving the error overload exists\n    92→      expect(errorCalled).toBe(false);\n    93→    });\n    94→\n    95→    it('kill accepts optional signal', () => {\n    96→      const proc = createMockProcess();\n    97→      // No-arg call\n    98→      proc.kill();\n    99→      // With signal\n   100→      proc.kill('SIGTERM');\n   101→      expect(typeof proc.kill).toBe('function');\n   102→    });\n   103→  });\n   104→\n   105→  describe('AgentEvent discriminated union', () => {\n   106→    const ALL_EVENT_TYPES = [\n   107→      'tool-start',\n   108→      'tool-complete',\n   109→      'text',\n   110→      'story-complete',\n   111→      'story-failed',\n   112→      'iteration',\n   113→      'retry',\n   114→      'result',\n   115→    ] as const;\n   116→\n   117→    it('covers all 8 event types', () => {\n   118→      expect(ALL_EVENT_TYPES).toHaveLength(8);\n   119→    });\n   120→\n   121→    it('accepts tool-start event', () => {\n   122→      const event: AgentEvent = { type: 'tool-start', name: 'Read' };\n   123→      expect(event.type).toBe('tool-start');\n   124→    });\n   125→\n   126→    it('accepts tool-complete event', () => {\n   127→      const event: AgentEvent = {\n   128→        type: 'tool-complete',\n   129→        name: 'Write',\n   130→        args: '{\"path\": \"/tmp/f\"}',\n   131→      };\n   132→      expect(event.type).toBe('tool-complete');\n   133→    });\n   134→\n   135→    it('accepts text event', () => {\n   136→      const event: AgentEvent = { type: 'text', text: 'hello' };\n   137→      expect(event.type).toBe('text');\n   138→    });\n   139→\n   140→    it('accepts story-complete event', () => {\n   141→      const event: AgentEvent = {\n   142→        type: 'story-complete',\n   143→        key: '13-1',\n   144→        details: 'done',\n   145→      };\n   146→      expect(event.type).toBe('story-complete');\n   147→    });\n   148→\n   149→    it('accepts story-failed event', () => {\n   150→      const event: AgentEvent = {\n   151→        type: 'story-failed',\n   152→        key: '13-1',\n   153→        reason: 'timeout',\n   154→      };\n   155→      expect(event.type).toBe('story-failed');\n   156→    });\n   157→\n   158→    it('accepts iteration event', () => {\n   159→      const event: AgentEvent = { type: 'iteration', count: 3 };\n   160→      expect(event.type).toBe('iteration');\n   161→    });\n   162→\n   163→    it('accepts retry event', () => {\n   164→      const event: AgentEvent = { type: 'retry', attempt: 2, delay: 5000 };\n   165→      expect(event.type).toBe('retry');\n   166→    });\n   167→\n   168→    it('accepts result event', () => {\n   169→      const event: AgentEvent = {\n   170→        type: 'result',\n   171→        cost: 0.42,\n   172→        sessionId: 'abc-123',\n   173→      };\n   174→      expect(event.type).toBe('result');\n   175→    });\n   176→\n   177→    it('narrows type correctly via discriminant', () => {\n   178→      const event: AgentEvent = { type: 'retry', attempt: 1, delay: 2000 };\n   179→      if (event.type === 'retry') {\n   180→        // TypeScript narrows to { type: 'retry'; attempt: number; delay: number }\n   181→        expect(event.attempt).toBe(1);\n   182→        expect(event.delay).toBe(2000);\n   183→      }\n   184→    });\n   185→\n   186→    it('covers every event type with a valid instance', () => {\n   187→      const events: AgentEvent[] = [\n   188→        { type: 'tool-start', name: 'a' },\n   189→        { type: 'tool-complete', name: 'b', args: 'c' },\n   190→        { type: 'text', text: 'd' },\n   191→        { type: 'story-complete', key: 'e', details: 'f' },\n   192→        { type: 'story-failed', key: 'g', reason: 'h' },\n   193→        { type: 'iteration', count: 1 },\n   194→        { type: 'retry', attempt: 1, delay: 1 },\n   195→        { type: 'result', cost: 0, sessionId: 'i' },\n   196→      ];\n   197→      const types = events.map((e) => e.type);\n   198→      expect(types).toEqual([...ALL_EVENT_TYPES]);\n   199→    });\n   200→  });\n   201→\n   202→  describe('AgentDriver interface', () => {\n   203→    it('satisfies interface with mock implementation', () => {\n   204→      const driver: AgentDriver = {\n   205→        name: 'test-driver',\n   206→        spawn(_opts: SpawnOpts): AgentProcess {\n   207→          return createMockProcess();\n   208→        },\n   209→        parseOutput(_line: string): AgentEvent | null {\n   210→          return null;\n   211→        },\n   212→        getStatusFile(): string {\n   213→          return '/tmp/status.json';\n   214→        },\n   215→      };\n   216→      expect(driver.name).toBe('test-driver');\n   217→      expect(typeof driver.spawn).toBe('function');\n   218→      expect(typeof driver.parseOutput).toBe('function');\n   219→      expect(typeof driver.getStatusFile).toBe('function');\n   220→    });\n   221→\n   222→    it('has readonly name property', () => {\n   223→      const driver: AgentDriver = {\n   224→        name: 'immutable',\n   225→        spawn: () => createMockProcess(),\n   226→        parseOutput: () => null,\n   227→        getStatusFile: () => '',\n   228→      };\n   229→      // TypeScript enforces readonly at compile time; runtime check that value exists\n   230→      expect(driver.name).toBe('immutable');\n   231→    });\n   232→\n   233→    it('parseOutput can return null for unrecognized lines', () => {\n   234→      const driver: AgentDriver = {\n   235→        name: 'null-parser',\n   236→        spawn: () => createMockProcess(),\n   237→        parseOutput: () => null,\n   238→        getStatusFile: () => '',\n   239→      };\n   240→      expect(driver.parseOutput('random garbage')).toBeNull();\n   241→    });\n   242→\n   243→    it('parseOutput can return a typed AgentEvent', () => {\n   244→      const prefix = 'TEXT: ';\n   245→      const driver: AgentDriver = {\n   246→        name: 'event-parser',\n   247→        spawn: () => createMockProcess(),\n   248→        parseOutput: (line: string) => {\n   249→          if (line.startsWith(prefix)) {\n   250→            return { type: 'text', text: line.slice(prefix.length) };\n   251→          }\n   252→          return null;\n   253→        },\n   254→        getStatusFile: () => '/tmp/status.json',\n   255→      };\n   256→      const event = driver.parseOutput('TEXT: hello');\n   257→      expect(event).toEqual({ type: 'text', text: 'hello' });\n   258→      expect(driver.parseOutput('unknown')).toBeNull();\n   259→    });\n   260→  });\n   261→\n   262→  describe('barrel re-exports from index.ts', () => {\n   263→    it('re-exports all types from types.ts', () => {\n   264→      // Type-level test: if these imports compile, the barrel re-exports work.\n   265→      // Use the barrel-imported types to construct values, proving they are the same types.\n   266→      const opts: BarrelSpawnOpts = {\n   267→        storyKey: 'barrel-test',\n   268→        prompt: 'p',\n   269→        workDir: '/w',\n   270→        timeout: 1000,\n   271→      };\n   272→      const proc: BarrelAgentProcess = createMockProcess();\n   273→      const event: BarrelAgentEvent = { type: 'text', text: 'barrel' };\n   274→      const driver: BarrelAgentDriver = {\n   275→        name: 'barrel-driver',\n   276→        spawn: () => proc,\n   277→        parseOutput: () => event,\n   278→        getStatusFile: () => '',\n   279→      };\n   280→\n   281→      // Runtime assertions prove the barrel types are usable\n   282→      expect(opts.storyKey).toBe('barrel-test');\n   283→      expect(proc.stdout).toBeDefined();\n   284→      expect(event.type).toBe('text');\n   285→      expect(driver.name).toBe('barrel-driver');\n   286→    });\n   287→  });\n   288→});\n   289→"}]},"parent_tool_use_id":"toolu_01SHktkuCBrV1tHtE9gQXR6g","session_id":"3ce6f3e2-c583-4074-ab3d-bf1fc6d87b66","uuid":"332ca0a5-7efe-41af-aadc-e01580f6a790","timestamp":"2026-03-24T15:52:45.069Z"}
