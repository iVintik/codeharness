{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QfCmr66ZCzB12A6oK9yiTi","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { render } from 'ink-testing-library';\n3\timport React from 'react';\n4\timport { ActiveTool, CompletedTool, DriverCostSummary } from '../ink-activity-components.js';\n5\timport type { CompletedToolEntry } from '../ink-components.js';\n6\t\n7\t// --- ActiveTool tests ---\n8\t\n9\tdescribe('ActiveTool component', () => {\n10\t  it('renders driver name when provided', () => {\n11\t    const { lastFrame } = render(<ActiveTool name=\"Bash\" driverName=\"claude-code\" />);\n12\t    const frame = lastFrame()!;\n13\t    expect(frame).toContain('Bash');\n14\t    expect(frame).toContain('(claude-code)');\n15\t  });\n16\t\n17\t  it('renders without driver name (backward compat)', () => {\n18\t    const { lastFrame } = render(<ActiveTool name=\"Bash\" />);\n19\t    const frame = lastFrame()!;\n20\t    expect(frame).toContain('Bash');\n21\t    expect(frame).not.toContain('(');\n22\t  });\n23\t\n24\t  it('renders without driver name when null', () => {\n25\t    const { lastFrame } = render(<ActiveTool name=\"Read\" driverName={null} />);\n26\t    const frame = lastFrame()!;\n27\t    expect(frame).toContain('Read');\n28\t    expect(frame).not.toContain('(');\n29\t  });\n30\t});\n31\t\n32\t// --- CompletedTool tests ---\n33\t\n34\tdescribe('CompletedTool component', () => {\n35\t  it('renders driver name from entry', () => {\n36\t    const entry: CompletedToolEntry = { name: 'Edit', args: 'src/foo.ts', driver: 'codex' };\n37\t    const { lastFrame } = render(<CompletedTool entry={entry} />);\n38\t    const frame = lastFrame()!;\n39\t    expect(frame).toContain('Edit');\n40\t    expect(frame).toContain('src/foo.ts');\n41\t    expect(frame).toContain('(codex)');\n42\t  });\n43\t\n44\t  it('renders without driver name (backward compat)', () => {\n45\t    const entry: CompletedToolEntry = { name: 'Edit', args: 'src/foo.ts' };\n46\t    const { lastFrame } = render(<CompletedTool entry={entry} />);\n47\t    const frame = lastFrame()!;\n48\t    expect(frame).toContain('Edit');\n49\t    expect(frame).toContain('src/foo.ts');\n50\t    expect(frame).not.toContain('(');\n51\t  });\n52\t\n53\t  it('renders driver name after truncated long args', () => {\n54\t    const longArgs = 'a'.repeat(80);\n55\t    const entry: CompletedToolEntry = { name: 'Bash', args: longArgs, driver: 'opencode' };\n56\t    const { lastFrame } = render(<CompletedTool entry={entry} />);\n57\t    const frame = lastFrame()!;\n58\t    expect(frame).toContain('Bash');\n59\t    // Args truncated to 60 chars + ellipsis\n60\t    expect(frame).toContain('…');\n61\t    expect(frame).toContain('(opencode)');\n62\t  });\n63\t});\n64\t\n65\t// --- DriverCostSummary tests ---\n66\t\n67\tdescribe('DriverCostSummary component', () => {\n68\t  it('renders nothing when driverCosts is empty', () => {\n69\t    const { lastFrame } = render(<DriverCostSummary driverCosts={{}} />);\n70\t    expect(lastFrame()).toBe('');\n71\t  });\n72\t\n73\t  it('renders nothing when driverCosts is null-ish', () => {\n74\t    // Defensive: even though type says Record, runtime might get undefined\n75\t    const { lastFrame } = render(<DriverCostSummary driverCosts={undefined as unknown as Record<string, number>} />);\n76\t    expect(lastFrame()).toBe('');\n77\t  });\n78\t\n79\t  it('renders single driver cost', () => {\n80\t    const { lastFrame } = render(<DriverCostSummary driverCosts={{ 'claude-code': 1.5 }} />);\n81\t    const frame = lastFrame()!;\n82\t    expect(frame).toContain('Cost: claude-code $1.50');\n83\t  });\n84\t\n85\t  it('renders multi-driver costs sorted alphabetically', () => {\n86\t    const { lastFrame } = render(\n87\t      <DriverCostSummary driverCosts={{ codex: 0.45, 'claude-code': 1.23 }} />\n88\t    );\n89\t    const frame = lastFrame()!;\n90\t    expect(frame).toContain('Cost: claude-code $1.23, codex $0.45');\n91\t  });\n92\t\n93\t  it('formats cost as $X.XX with two decimal places', () => {\n94\t    const { lastFrame } = render(<DriverCostSummary driverCosts={{ opencode: 3 }} />);\n95\t    const frame = lastFrame()!;\n96\t    expect(frame).toContain('$3.00');\n97\t  });\n98\t});\n99\t"}]},"parent_tool_use_id":"toolu_01KuW1MjUdFwtjdSVSiFS3H5","session_id":"a0646c12-93c6-41a0-9c7a-50683cae7716","uuid":"054a581c-6450-4bf5-a9f5-cd76493dc235","timestamp":"2026-04-03T12:55:15.019Z"}
