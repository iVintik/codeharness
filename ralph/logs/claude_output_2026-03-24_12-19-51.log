{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017eBLnPCNHuK7Y8DnHWM5VU","type":"tool_result","content":"     1→/**\n     2→ * Dockerfile template generator — creates stack-appropriate Dockerfiles for user projects.\n     3→ * Returns Result<DockerfileTemplateResult> following the project's Result<T> pattern.\n     4→ *\n     5→ * FR22 (Dockerfile template based on project type).\n     6→ * Supports single-stack and multi-stage (multi-stack) Dockerfile generation.\n     7→ */\n     8→\n     9→import { existsSync, writeFileSync } from 'node:fs';\n    10→import { join } from 'node:path';\n    11→import { ok, fail } from '../../types/result.js';\n    12→import type { Result } from '../../types/result.js';\n    13→import type { StackDetection } from '../../lib/stack-detect.js';\n    14→\n    15→/** Result returned by generateDockerfileTemplate */\n    16→export interface DockerfileTemplateResult {\n    17→  readonly path: string;\n    18→  readonly stack: string;\n    19→  readonly stacks: string[];\n    20→}\n    21→\n    22→// ─── Template content generators ────────────────────────────────────────────\n    23→\n    24→function nodejsTemplate(): string {\n    25→  return `# Base image — pinned version for reproducibility\n    26→FROM node:22-slim\n    27→\n    28→ARG TARBALL=package.tgz\n    29→\n    30→# System utilities for verification\n    31→RUN apt-get update && apt-get install -y --no-install-recommends curl jq && rm -rf /var/lib/apt/lists/*\n    32→\n    33→# Install project from tarball (black-box: no source code)\n    34→COPY \\${TARBALL} /tmp/\\${TARBALL}\n    35→RUN npm install -g /tmp/\\${TARBALL} && rm /tmp/\\${TARBALL}\n    36→\n    37→# Run as non-root user\n    38→USER node\n    39→\n    40→WORKDIR /workspace\n    41→`;\n    42→}\n    43→\n    44→function pythonTemplate(): string {\n    45→  return `# Base image — pinned version for reproducibility\n    46→FROM python:3.12-slim\n    47→\n    48→# System utilities for verification\n    49→RUN apt-get update && apt-get install -y --no-install-recommends curl jq && rm -rf /var/lib/apt/lists/*\n    50→\n    51→# Install project from wheel or sdist\n    52→COPY dist/ /tmp/dist/\n    53→RUN pip install /tmp/dist/*.whl && rm -rf /tmp/dist/ && pip cache purge\n    54→\n    55→# Run as non-root user\n    56→USER nobody\n    57→\n    58→WORKDIR /workspace\n    59→`;\n    60→}\n    61→\n    62→function rustTemplate(): string {\n    63→  return `# === Builder stage ===\n    64→FROM rust:1.82-slim AS builder\n    65→\n    66→WORKDIR /build\n    67→\n    68→# Copy project files\n    69→COPY . .\n    70→\n    71→# Build release binary\n    72→RUN cargo build --release\n    73→\n    74→# === Runtime stage ===\n    75→FROM debian:bookworm-slim\n    76→\n    77→# System utilities for verification\n    78→RUN apt-get update && apt-get install -y --no-install-recommends curl jq && rm -rf /var/lib/apt/lists/*\n    79→\n    80→# Install compiled binary from builder (update 'myapp' to your binary name)\n    81→COPY --from=builder /build/target/release/myapp /usr/local/bin/myapp\n    82→\n    83→# Run as non-root user\n    84→USER nobody\n    85→\n    86→WORKDIR /workspace\n    87→`;\n    88→}\n    89→\n    90→function genericTemplate(): string {\n    91→  return `# Base image — pinned version for reproducibility\n    92→FROM node:22-slim\n    93→\n    94→# System utilities for verification\n    95→RUN apt-get update && apt-get install -y --no-install-recommends bash curl jq git && rm -rf /var/lib/apt/lists/*\n    96→\n    97→# Install project binary (update this for your project)\n    98→RUN npm install -g placeholder && npm cache clean --force\n    99→\n   100→# Run as non-root user\n   101→USER node\n   102→\n   103→WORKDIR /workspace\n   104→`;\n   105→}\n   106→\n   107→// ─── Multi-stage build-stage content extractors ─────────────────────────────\n   108→\n   109→/** Build-stage content for nodejs in a multi-stage Dockerfile */\n   110→function nodejsBuildStage(): string {\n   111→  return `# === Build stage: nodejs ===\n   112→FROM node:22-slim AS build-nodejs\n   113→WORKDIR /build\n   114→COPY package*.json ./\n   115→RUN npm ci --production\n   116→COPY . .\n   117→`;\n   118→}\n   119→\n   120→/** Build-stage content for python in a multi-stage Dockerfile */\n   121→function pythonBuildStage(): string {\n   122→  return `# === Build stage: python ===\n   123→FROM python:3.12-slim AS build-python\n   124→WORKDIR /build\n   125→COPY . .\n   126→RUN pip install --target=/build/dist .\n   127→`;\n   128→}\n   129→\n   130→/** Build-stage content for rust in a multi-stage Dockerfile */\n   131→function rustBuildStage(): string {\n   132→  return `# === Build stage: rust ===\n   133→FROM rust:1.82-slim AS build-rust\n   134→WORKDIR /build\n   135→COPY . .\n   136→RUN cargo build --release\n   137→`;\n   138→}\n   139→\n   140→/** COPY directives for each stack in the runtime stage */\n   141→function runtimeCopyDirectives(stacks: string[]): string {\n   142→  const lines: string[] = [];\n   143→  for (const stack of stacks) {\n   144→    if (stack === 'nodejs') {\n   145→      lines.push('COPY --from=build-nodejs /build/node_modules ./node_modules');\n   146→      lines.push('COPY --from=build-nodejs /build/ ./app/');\n   147→    } else if (stack === 'python') {\n   148→      lines.push('COPY --from=build-python /build/dist /opt/app/python/');\n   149→    } else if (stack === 'rust') {\n   150→      lines.push('COPY --from=build-rust /build/target/release/myapp /usr/local/bin/myapp');\n   151→    }\n   152→  }\n   153→  return lines.join('\\n');\n   154→}\n   155→\n   156→/** Stacks that have multi-stage build support */\n   157→const MULTI_STAGE_STACKS = new Set(['nodejs', 'python', 'rust']);\n   158→\n   159→/** Compose a multi-stage Dockerfile from multiple stack detections */\n   160→function multiStageTemplate(detections: StackDetection[]): string {\n   161→  // Filter to only stacks with known build-stage support\n   162→  const supported = detections.filter(d => MULTI_STAGE_STACKS.has(d.stack));\n   163→  if (supported.length === 0) {\n   164→    // All stacks unknown — fall back to generic-like runtime-only Dockerfile\n   165→    return genericTemplate();\n   166→  }\n   167→  const buildStages: string[] = [];\n   168→  const stacks = supported.map(d => d.stack);\n   169→\n   170→  for (const stack of stacks) {\n   171→    if (stack === 'nodejs') buildStages.push(nodejsBuildStage());\n   172→    else if (stack === 'python') buildStages.push(pythonBuildStage());\n   173→    else if (stack === 'rust') buildStages.push(rustBuildStage());\n   174→  }\n   175→\n   176→  const copyLines = runtimeCopyDirectives(stacks);\n   177→\n   178→  return `# NOTE: Customize COPY paths for your monorepo layout. Each build stage should only copy its own sources.\n   179→${buildStages.join('\\n')}\n   180→# === Runtime stage ===\n   181→FROM debian:bookworm-slim\n   182→\n   183→# System utilities for verification\n   184→RUN apt-get update && apt-get install -y --no-install-recommends curl jq && rm -rf /var/lib/apt/lists/*\n   185→\n   186→# Install artifacts from build stages\n   187→${copyLines}\n   188→\n   189→# Run as non-root user\n   190→USER nobody\n   191→\n   192→WORKDIR /workspace\n   193→`;\n   194→}\n   195→\n   196→// ─── Main generator ─────────────────────────────────────────────────────────\n   197→\n   198→/**\n   199→ * Generate a Dockerfile template based on detected stack type.\n   200→ * Accepts either a string stack name (backward compat) or StackDetection[] for multi-stack.\n   201→ * Returns fail() if a Dockerfile already exists — caller handles messaging.\n   202→ */\n   203→export function generateDockerfileTemplate(\n   204→  projectDir: string,\n   205→  stackOrDetections: string | null | StackDetection[],\n   206→): Result<DockerfileTemplateResult> {\n   207→  if (!projectDir) {\n   208→    return fail('projectDir is required');\n   209→  }\n   210→\n   211→  const dockerfilePath = join(projectDir, 'Dockerfile');\n   212→\n   213→  if (existsSync(dockerfilePath)) {\n   214→    return fail('Dockerfile already exists');\n   215→  }\n   216→\n   217→  // Multi-stack path: StackDetection[] with >1 entry\n   218→  if (Array.isArray(stackOrDetections) && stackOrDetections.length > 1) {\n   219→    const content = multiStageTemplate(stackOrDetections);\n   220→    const stacks = stackOrDetections.map(d => d.stack);\n   221→    try {\n   222→      writeFileSync(dockerfilePath, content, 'utf-8');\n   223→    } catch (err) {\n   224→      const message = err instanceof Error ? err.message : String(err);\n   225→      return fail(`Failed to write Dockerfile: ${message}`);\n   226→    }\n   227→    return ok({ path: dockerfilePath, stack: stacks[0], stacks });\n   228→  }\n   229→\n   230→  // Resolve single stack from StackDetection[] or string\n   231→  const stack: string | null = Array.isArray(stackOrDetections)\n   232→    ? (stackOrDetections.length === 1 ? stackOrDetections[0].stack : null)\n   233→    : stackOrDetections;\n   234→\n   235→  let content: string;\n   236→  let resolvedStack: string;\n   237→\n   238→  if (stack === 'nodejs') {\n   239→    content = nodejsTemplate();\n   240→    resolvedStack = 'nodejs';\n   241→  } else if (stack === 'python') {\n   242→    content = pythonTemplate();\n   243→    resolvedStack = 'python';\n   244→  } else if (stack === 'rust') {\n   245→    content = rustTemplate();\n   246→    resolvedStack = 'rust';\n   247→  } else {\n   248→    content = genericTemplate();\n   249→    resolvedStack = 'generic';\n   250→  }\n   251→\n   252→  try {\n   253→    writeFileSync(dockerfilePath, content, 'utf-8');\n   254→  } catch (err) {\n   255→    const message = err instanceof Error ? err.message : String(err);\n   256→    return fail(`Failed to write Dockerfile: ${message}`);\n   257→  }\n   258→\n   259→  return ok({ path: dockerfilePath, stack: resolvedStack, stacks: [resolvedStack] });\n   260→}\n   261→"}]},"parent_tool_use_id":"toolu_01BmxG7qx6yQHWseU1bwDgY4","session_id":"e39a20db-e648-4f8f-85ec-e4fa22cf8d05","uuid":"b0824f78-9a9e-4222-8597-d995998f1e2a","timestamp":"2026-03-24T08:24:02.362Z"}
