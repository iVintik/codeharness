36\tstory_flow:\n337\t  - implement\n338\tepic_flow:\n339\t  - merge\n340\t  - unknown_epic_task\n341\t`);\n342\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n343\t      expect(() => parseWorkflow(filePath)).toThrow(/unknown_epic_task/);\n344\t    });\n345\t\n346\t    it('accepts epic_flow with built-in merge and validate (AC #8)', () => {\n347\t      const filePath = writeYaml('epic-builtins.yaml', `\n348\ttasks:\n349\t  implement:\n350\t    agent: dev\n351\tstory_flow:\n352\t  - implement\n353\tepic_flow:\n354\t  - merge\n355\t  - validate\n356\t`);\n357\t      const result = parseWorkflow(filePath);\n358\t      expect(result.epicFlow).toEqual(['merge', 'validate']);\n359\t    });\n360\t  });\n361\t\n362\t  describe('flow + story_flow coexistence (AC #9)', () => {\n363\t    it('rejects workflow with both flow: and story_flow:', () => {\n364\t      const filePath = writeYaml('both-flows.yaml', `\n365\ttasks:\n366\t  implement:\n367\t    agent: dev\n368\tflow:\n369\t  - implement\n370\tstory_flow:\n371\t  - implement\n372\t`);\n373\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n374\t      expect(() => parseWorkflow(filePath)).toThrow(/both.*flow.*story_flow|Cannot have both/i);\n375\t    });\n376\t  });\n377\t\n378\t  describe('agent: null (AC #10)', () => {\n379\t    it('parses task with agent: null', () => {\n380\t      const filePath = writeYaml('null-agent.yaml', `\n381\ttasks:\n382\t  merge_step:\n383\t    agent: null\n384\tflow:\n385\t  - merge_step\n386\t`);\n387\t      const result = parseWorkflow(filePath);\n388\t      expect(result.tasks.merge_step.agent).toBeNull();\n389\t    });\n390\t  });\n391\t\n392\t  describe('scope: per-epic (AC #11)', () => {\n393\t    it('parses task with scope: per-epic', () => {\n394\t      const filePath = writeYaml('per-epic.yaml', `\n395\ttasks:\n396\t  plan:\n397\t    agent: pm\n398\t    scope: per-epic\n399\tflow:\n400\t  - plan\n401\t`);\n402\t      const result = pa