 provider.getVerifyDockerfileSection(testDir);\n    48→    expect(section).toContain('coverage');\n    49→    expect(section).toContain('pytest');\n    50→  });\n    51→});\n    52→\n    53→describe('RustProvider.getVerifyDockerfileSection', () => {\n    54→  const provider = new RustProvider();\n    55→\n    56→  it('installs rust toolchain via rustup', () => {\n    57→    const section = provider.getVerifyDockerfileSection(testDir);\n    58→    expect(section).toContain('rustup.rs');\n    59→    expect(section).toContain('--default-toolchain stable');\n    60→  });\n    61→\n    62→  it('sets PATH for cargo binaries', () => {\n    63→    const section = provider.getVerifyDockerfileSection(testDir);\n    64→    expect(section).toContain('ENV PATH=\"/root/.cargo/bin:$PATH\"');\n    65→  });\n    66→\n    67→  it('installs clippy and cargo-tarpaulin', () => {\n    68→    const section = provider.getVerifyDockerfileSection(testDir);\n    69→    expect(section).toContain('rustup component add clippy');\n    70→    expect(section).toContain('cargo install cargo-tarpaulin');\n    71→  });\n    72→\n    73→  it('includes Bevy system libs when bevy is in Cargo.toml dependencies', () => {\n    74→    writeFileSync(\n    75→      join(testDir, 'Cargo.toml'),\n    76→      '[package]\\nname = \"game\"\\nversion = \"0.1.0\"\\n\\n[dependencies]\\nbevy = \"0.12\"\\nserde = \"1.0\"\\n',\n    77→    );\n    78→    const section = provider.getVerifyDockerfileSection(testDir);\n    79→    expect(section).toContain('libudev-dev');\n    80→    expect(section).toContain('libasound2-dev');\n    81→    expect(section).toContain('libwayland-dev');\n    82→    expect(section).toContain('libxkbcommon-dev');\n    83→    expect(section).toContain('libfontconfig1-dev');\n    84→    expect(section).toContain('libx11-dev');\n    85→  });\n    86→\n    87→  it('does NOT include Bevy libs when bevy is not in dependencies', () => {\n    88→    writeFileSync(\n    89→      join(testDir, 'Cargo.toml'),\n    90→      '[package]\\nname = \"myapp\"\\nversion = \"0.1.0\"\\n\\n[dependencies]\\nserde = \"1.0\"\\ntokio = \"1.0\"\\n',\n    91→    );\n    92→    const section = provider.getVerifyDockerfileSection(testDir);\n    93→    expect(section).toContain('rustup');\n    94→    expect(section).not.toContain('libudev-dev');\n    95→    expect(section).not.toContain('libasound2-dev');\n    96→  });\n    97→\n    98→  it('does NOT include Bevy libs when no Cargo.toml exists', () => {\n    99→    const section = provider.getVerifyDockerfileSection(testDir);\n   100→    expect(section).not.toContain('libudev-dev');\n   101→  });\n   102→\n   103→  it('does NOT include Bevy libs when bevy is only in dev-dependencies', () => {\n   104→    writeFileSync(\n   105→      join(testDir, 'Cargo.toml'),\n   106→      '[package]\\nname = \"myapp\"\\nversion = \"0.1.0\"\\n\\n[dependencies]\\nserde = \"1.0\"\\n\\n[dev-dependencies]\\nbevy = \"0.12\"\\n',\n   107→    );\n   108→    const section = provider.getVerifyDockerfileSection(testDir);\n   109→    expect(section).not.toContain('libudev-dev');\n   110→  });\n   111→});\n   112→"}]},"parent_tool_use_id":"toolu_01A5VRSCWrKG5o81CvpB3aWg","session_id":"83e99bf1-19ed-4459-85db-f9346f9425ec","uuid":"253a1172-9e2b-44c5-85a5-fb551312f947","timestamp":"2026-03-27T09:33:28.967Z"}
