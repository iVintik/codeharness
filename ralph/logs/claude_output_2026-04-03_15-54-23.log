{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NmL3qHL3D7vC5LAMZx1Syz","type":"tool_result","content":"500\t// --- All-UNKNOWN Verdict Builder ---\n501\t\n502\t/**\n503\t * Build an all-UNKNOWN EvaluatorVerdict as fallback when the evaluator\n504\t * fails to produce valid JSON after retry.\n505\t */\n506\texport function buildAllUnknownVerdict(\n507\t  workItems: WorkItem[],\n508\t  reasoning: string,\n509\t): EvaluatorVerdict {\n510\t  const findings = workItems.map((_, index) => ({\n511\t    ac: index + 1,\n512\t    description: `AC #${index + 1}`,\n513\t    status: 'unknown' as const,\n514\t    evidence: {\n515\t      commands_run: [] as string[],\n516\t      output_observed: '',\n517\t      reasoning,\n518\t    },\n519\t  }));\n520\t\n521\t  return {\n522\t    verdict: 'fail',\n523\t    score: {\n524\t      passed: 0,\n525\t      failed: 0,\n526\t      unknown: findings.length,\n527\t      total: findings.length,\n528\t    },\n529\t    findings,\n530\t  };\n531\t}\n532\t\n533\t// --- Failed Story Filtering (Task 4) ---\n534\t\n535\t/**\n536\t * Determine which work items failed based on evaluator findings.\n537\t * If verdict is null (parse failure), returns all items (conservative fallback).\n538\t */\n539\texport function getFailedItems(\n540\t  verdict: EvaluatorVerdict | null,\n541\t  allItems: WorkItem[],\n542\t): WorkItem[] {\n543\t  if (!verdict) return allItems;\n544\t\n545\t  // If verdict passed, no items need retry\n546\t  if (verdict.verdict === 'pass') return [];\n547\t\n548\t  // All items are retried on failure — per-story filtering based on individual\n549\t  // story results is not possible with the current verdict shape (verdict is per-run).\n550\t  // The findings track ACs, not stories. Conservative: retry all on failure.\n551\t  return allItems;\n552\t}\n553\t\n554\t// --- Loop Block Execution (Task 5) ---\n555\t\n556\t/**\n557\t * Result of loop block execution.\n558\t */\n559\tinterface LoopBlockResult {\n560\t  state: WorkflowState;\n561\t  errors: EngineError[];\n562\t  tasksCompleted: number;\n563\t  halted: boolean;\n564\t  lastContract: OutputContract | null;\n565\t}\n566\t\n567\t/**\n568\t * Execute a loop block: iterate tasks until pass, max iterations, or circuit breaker.\n569\t */\n570\texport async function executeLoopBlock(\n571\t  loopBlock: LoopBlock,\n572\t  state: WorkflowState,\n573\t  config: EngineConfig,\n574\t  workItems: WorkItem[],\n575\t  initialContract?: OutputContract | null,\n576\t): Promise<LoopBlockResult> {\n577\t  const projectDir = config.projectDir ?? process.cwd();\n578\t  const maxIterations = config.maxIterations ?? DEFAULT_MAX_ITERATIONS;\n579\t  const errors: EngineError[] = [];\n580\t  let tasksCompleted = 0;\n581\t  let currentState = state;\n582\t  let lastVerdict: EvaluatorVerdict | null = null;\n583\t  let lastOutputContract: OutputContract | null = initialContract ?? null;\n584\t\n585\t  // Handle empty loop block\n586\t  if (loopBlock.loop.length === 0) {\n587\t    return { state: currentState, errors, tasksCompleted, halted: false, lastContract: lastOutputContract };\n588\t  }\n589\t\n590\t  while (true) {\n591\t    // 1. Determine whether to increment iteration or resume a partial one.\n592\t    //    On fresh start (iteration === 0), always increment.\n593\t    //    On resume (iteration > 0), check if the current iteration is fully done.\n594\t    const nextIteration = currentState.iteration + 1;\n595\t    const allCurrentIterationDone = currentState.iteration > 0 && loopBlock.loop.every((tn) => {\n596\t      const t = config.workflow.tasks[tn];\n597\t      if (!t) return true; // missing task = skip = \"done\"\n598\t      if (t.scope === 'per-story') {\n599\t        return workItems.every((item) =>\n600\t          isLoopTaskCompleted(currentState, tn, item.key, currentState.iteration));\n601\t      }\n602\t      return isLoopTaskCompleted(currentState, tn, PER_RUN_SENTINEL, currentState.iteration);\n603\t    });\n604\t\n605\t    if (currentState.iteration === 0 || allCurrentIterationDone) {\n606\t      // Fresh start or current iteration fully done — advance\n607\t      currentState = {\n608\t        ...currentState,\n609\t        iteration: nextIteration,\n610\t      };\n611\t      writeWorkflowState(currentState, projectDir);\n612\t    }\n613\t    // else: resuming a partially completed iteration — keep current iteration\n614\t\n615\t    let haltedInLoop = false;\n616\t\n617\t    // 2. Execute each task in the loop\n618\t    for (const taskName of loopBlock.loop) {\n619\t      const task = config.workflow.tasks[taskName];\n620\t      if (!task) {\n621\t        warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n622\t        continue;\n623\t      }\n624\t\n625\t      const definition = config.agents[task.agent];\n626\t      if (!definition) {\n627\t        warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n628\t        continue;\n629\t      }\n630\t\n631\t      if (task.scope === 'per-story') {\n632\t        // Determine which items to dispatch for\n633\t        const itemsToRetry = lastVerdict ? getFailedItems(lastVerdict, workItems) : workItems;\n634\t\n635\t        for (const item of itemsToRetry) {\n636\t          // Skip if already completed for this iteration (crash recovery — AC #4)\n637\t          if (isLoopTaskCompleted(currentState, taskName, item.key, currentState.iteration)) {\n638\t            warn(`workflow-engine: skipping completed task ${taskName} for ${item.key}`);\n639\t            continue;\n640\t          }\n641\t\n642\t          // Build prompt: inject findings if we have a previous verdict\n643\t          const prompt = lastVerdict\n644\t            ? buildRetryPrompt(item.key, lastVerdict.findings)\n645\t            : undefined;\n646\t\n647\t          try {\n648\t            const dispatchResult = await dispatchTaskWithResult(\n649\t              task, taskName, item.key, definition, currentState, config, prompt, lastOutputContract ?? undefined,\n650\t            );\n651\t            currentState = dispatchResult.updatedState;\n652\t            lastOutputContract = dispatchResult.contract;\n653\t            tasksCompleted++;\n654\t          } catch (err: unknown) {\n655\t            const engineError = handleDispatchError(err, taskName, item.key);\n656\t            errors.push(engineError);\n657\t            currentState = recordErrorInState(currentState, taskName, item.key, engineError);\n658\t            writeWorkflowState(currentState, projectDir);\n659\t\n660\t            if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n661\t              haltedInLoop = true;\n662\t              break;\n663\t            }\n664\t            continue;\n665\t          }\n666\t        }\n667\t\n668\t        if (haltedInLoop) break;\n669\t      } else {\n670\t        // per-run task (e.g., verify)\n671\t        // Skip if already completed for this iteration (crash recovery — AC #4)\n672\t        if (isLoopTaskCompleted(currentState, taskName, PER_RUN_SENTINEL, currentState.iteration)) {\n673\t          warn(`workflow-engine: skipping completed task ${taskName} for ${PER_RUN_SENTINEL}`);\n674\t          continue;\n675\t        }\n676\t\n677\t        try {\n678\t          // We need the dispatch result output to parse verdict\n679\t          const dispatchResult = await dispatchTaskWithResult(\n680\t            task, taskName, PER_RUN_SENTINEL, definition, currentState, config,\n681\t            undefined, lastOutputContract ?? undefined,\n682\t          );\n683\t          currentState = dispatchResult.updatedState;\n684\t          lastOutputContract = dispatchResult.contract;\n685\t          tasksCompleted++;\n686\t\n687\t          // Attempt to parse verdict from output with retry semantics (story 6-2)\n688\t          let verdict: EvaluatorVerdict | null = null;\n689\t          try {\n690\t            verdict = parseVerdict(dispatchResult.output);\n691\t          } catch (parseErr: unknown) {\n692\t            if (parseErr instanceof VerdictParseError && parseErr.retryable) {\n693\t              // Re-dispatch evaluator for one retry attempt\n694\t              warn(`workflow-engine: verdict parse failed, retrying evaluator for ${taskName}`);\n695\t              try {\n696\t                const retryResult = await dispatchTaskWithResult(\n697\t                  task, taskName, PER_RUN_SENTINEL, definition, currentState, config,\n698\t                  undefined, lastOutputContract ?? undefined,\n699\t                );\n700\t                currentState = retryResult.updatedState;\n701\t                lastOutputContract = retryResult.contract;\n702\t                tasksCompleted++;\n703\t                verdict = parseVerdict(retryResult.output);\n704\t              } catch { // IGNORE: retry failed — fall back to all-UNKNOWN verdict\n705\t                // Second failure: generate all-UNKNOWN verdict\n706\t                verdict = buildAllUnknownVerdict(\n707\t                  workItems,\n708\t                  'Evaluator failed to produce valid JSON after retry',\n709\t                );\n710\t              }\n711\t            }\n712\t            // If not a VerdictParseError or not retryable, verdict stays null\n713\t          }\n714\t          lastVerdict = verdict;\n715\t\n716\t          // Record score in state\n717\t          if (verdict) {\n718\t            const score = {\n719\t              iteration: currentState.iteration,\n720\t              passed: verdict.score.passed,\n721\t              failed: verdict.score.failed,\n722\t              unknown: verdict.score.unknown,\n723\t              total: verdict.score.total,\n724\t              timestamp: new Date().toISOString(),\n725\t            };\n726\t            currentState = {\n727\t              ...currentState,\n728\t              evaluator_scores: [...currentState.evaluator_scores, score],\n729\t            };\n730\t          } else {\n731\t            // Parse failure: record all-UNKNOWN score\n732\t            const totalItems = workItems.length;\n733\t            const score = {\n734\t              iteration: currentState.iteration,\n735\t              passed: 0,\n736\t              failed: 0,\n737\t              unknown: totalItems,\n738\t              total: totalItems,\n739\t              timestamp: new Date().toISOString(),\n740\t            };\n741\t            currentState = {\n742\t              ...currentState,\n743\t              evaluator_scores: [...currentState.evaluator_scores, score],\n744\t            };\n745\t          }\n746\t          writeWorkflowState(currentState, projectDir);\n747\t\n748\t          // Circuit breaker: evaluate progress after recording score\n749\t          const cbDecision = evaluateProgress(currentState.evaluator_scores);\n750\t          if (cbDecision.halt) {\n751\t            currentState = {\n752\t              ...currentState,\n753\t              circuit_breaker: {\n754\t                triggered: true,\n755\t                reason: cbDecision.reason,\n756\t                score_history: cbDecision.scoreHistory,\n757\t              },\n758\t            };\n759\t            writeWorkflowState(currentState, projectDir);\n760\t          }\n761\t        } catch (err: unknown) {\n762\t          const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n763\t          errors.push(engineError);\n764\t          currentState = recordErrorInState(currentState, taskName, PER_RUN_SENTINEL, engineError);\n765\t          writeWorkflowState(currentState, projectDir);\n766\t\n767\t          // Clear stale verdict so next iteration retries all items\n768\t          lastVerdict = null;\n769\t\n770\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n771\t            haltedInLoop = true;\n772\t            break;\n773\t          }\n774\t          continue;\n775\t        }\n776\t      }\n777\t    }\n778\t\n779\t    if (haltedInLoop) {\n780\t      return { state: currentState, errors, tasksCompleted, halted: true, lastContract: lastOutputContract };\n781\t    }\n782\t\n783\t    // 3. Check termination conditions\n784\t    if (lastVerdict?.verdict === 'pass') {\n785\t      // Success: loop passes\n786\t      return { state: currentState, errors, tasksCompleted, halted: false, lastContract: lastOutputContract };\n787\t    }\n788\t\n789\t    if (currentState.iteration >= maxIterations) {\n790\t      currentState = { ...currentState, phase: 'max-iterations' };\n791\t      writeWorkflowState(currentState, projectDir);\n792\t      return { state: currentState, errors, tasksCompleted, halted: false, lastContract: lastOutputContract };\n793\t    }\n794\t\n795\t    if (currentState.circuit_breaker.triggered) {\n796\t      currentState = { ...currentState, phase: 'circuit-breaker' };\n797\t      writeWorkflowState(currentState, projectDir);\n798\t      return { state: currentState, errors, tasksCompleted, halted: false, lastContract: lastOutputContract };\n799\t    }\n800\t  }\n801\t}\n802\t\n803\t\n804\t// --- Driver Health Check ---\n805\t\n806\t/** Default timeout for the health check phase (NFR6). */\n807\tconst HEALTH_CHECK_TIMEOUT_MS = 5000;\n808\t\n809\t/**\n810\t * Run health checks on all unique drivers referenced in a workflow.\n811\t *\n812\t * Collects unique driver names from `workflow.tasks`, resolves each via\n813\t * `getDriver()`, and runs all `healthCheck()` calls concurrently with a\n814\t * 5-second timeout (NFR6).\n815\t *\n816\t * Throws if any driver is unavailable or if the timeout fires.\n817\t */\n818\texport async function checkDriverHealth(workflow: ResolvedWorkflow, timeoutMs?: number): Promise<void> {\n819\t  // 1. Collect unique driver names from all tasks\n820\t  const driverNames = new Set<string>();\n821\t  for (const task of Object.values(workflow.tasks)) {\n822\t    driverNames.add(task.driver ?? 'claude-code');\n823\t  }\n824\t\n825\t  // 2. Resolve drivers\n826\t  const drivers = new Map<string, ReturnType<typeof getDriver>>();\n827\t  for (const name of driverNames) {\n828\t    drivers.set(name, getDriver(name));\n829\t  }\n830\t\n831\t  // 3. Run health checks concurrently, tracking which drivers responded\n832\t  interface HealthResult { name: string; health: DriverHealth }\n833\t  const responded = new Set<string>();\n834\t  const healthChecks = Promise.all(\n835\t    [...drivers.entries()].map(async ([name, driver]): Promise<HealthResult> => {\n836\t      const health = await driver.healthCheck();\n837\t      responded.add(name);\n838\t      return { name, health };\n839\t    }),\n840\t  );\n841\t\n842\t  // 4. Race against timeout (NFR6) — clear timer on success to prevent leaks\n843\t  const effectiveTimeout = timeoutMs ?? HEALTH_CHECK_TIMEOUT_MS;\n844\t  let timer: ReturnType<typeof setTimeout>;\n845\t  const timeoutPromise = new Promise<'timeout'>((resolve) => {\n846\t    timer = setTimeout(() => resolve('timeout'), effectiveTimeout);\n847\t  });\n848\t\n849\t  const result = await Promise.race([healthChecks, timeoutPromise]);\n850\t\n851\t  if (result === 'timeout') {\n852\t    // Report only the drivers that did NOT respond (AC #6)\n853\t    const pending = [...driverNames].filter((n) => !responded.has(n));\n854\t    const names = pending.length > 0 ? pending.join(', ') : [...driverNames].join(', ');\n855\t    throw new Error(\n856\t      `Driver health check timed out after ${effectiveTimeout}ms. Drivers that did not respond: ${names}`,\n857\t    );\n858\t  }\n859\t\n860\t  // Health checks completed before timeout — clear the timer\n861\t  clearTimeout(timer!);\n862\t\n863\t  // 5. Check for failures\n864\t  const failures = result.filter((r) => !r.health.available);\n865\t  if (failures.length > 0) {\n866\t    const details = failures\n867\t      .map((f) => `${f.name}: ${f.health.error ?? 'unavailable'}`)\n868\t      .join('; ');\n869\t    throw new Error(`Driver health check failed: ${details}`);\n870\t  }\n871\t}\n872\t\n873\t// --- Main Execution ---\n874\t\n875\t/**\n876\t * Execute a workflow sequentially: iterate through flow steps, dispatch tasks\n877\t * per-story or per-run, checkpoint state after each dispatch.\n878\t *\n879\t * Loop blocks execute iteratively until pass, max-iterations, or circuit-breaker.\n880\t *\n881\t * Returns an EngineResult summarizing the execution.\n882\t */\n883\texport async function executeWorkflow(config: EngineConfig): Promise<EngineResult> {\n884\t  const startMs = Date.now();\n885\t  const projectDir = config.projectDir ?? process.cwd();\n886\t  const errors: EngineError[] = [];\n887\t  let tasksCompleted = 0;\n888\t  const processedStories = new Set<string>();\n889\t\n890\t  // 1. Read or initialize workflow state\n891\t  let state = readWorkflowState(projectDir);\n892\t\n893\t  // Early exit: workflow already completed (AC #6)\n894\t  if (state.phase === 'completed') {\n895\t    return {\n896\t      success: true,\n897\t      tasksCompleted: 0,\n898\t      storiesProcessed: 0,\n899\t      errors: [],"}]},"parent_tool_use_id":"toolu_01UsAm2qXT84D1u4sW8gSAmJ","session_id":"a29ee53b-c2b0-4802-9455-7215112648b1","uuid":"753b5f69-4868-4f97-8289-0c91d35f691e","timestamp":"2026-04-03T11:58:41.951Z"}
