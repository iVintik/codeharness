{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PnK3mM9D3dz1SipKzLprXJ","type":"tool_result","content":"     1→/**\n     2→ * Ralph prompt template — generates the prompt that instructs each\n     3→ * Claude Code iteration to run /harness-run for sprint execution.\n     4→ */\n     5→\n     6→import { renderTemplateFile } from '../templates.js';\n     7→\n     8→export interface RalphPromptConfig {\n     9→  projectDir: string;\n    10→  sprintStatusPath: string;\n    11→  retryCount?: number;\n    12→  currentStoryKey?: string;\n    13→  flaggedStories?: string[];\n    14→}\n    15→\n    16→/**\n    17→ * Generates the prompt content for a Ralph iteration.\n    18→ * Reads the base template from templates/prompts/ralph-prompt.md and\n    19→ * interpolates project-specific paths.\n    20→ * Optionally includes retry context and flagged story information.\n    21→ */\n    22→export function generateRalphPrompt(config: RalphPromptConfig): string {\n    23→  let prompt = renderTemplateFile('templates/prompts/ralph-prompt.md', {\n    24→    projectDir: config.projectDir,\n    25→    sprintStatusPath: config.sprintStatusPath,\n    26→  });\n    27→\n    28→  // Add retry context if retrying a story\n    29→  if (config.retryCount && config.retryCount > 0 && config.currentStoryKey) {\n    30→    prompt += `\\n## Retry Context\\n\\n`;\n    31→    prompt += `This is retry attempt **${config.retryCount}** for story \\`${config.currentStoryKey}\\`. `;\n    32→    prompt += `Previous attempts did not complete verification. Focus on fixing the remaining issues.\\n`;\n    33→  }\n    34→\n    35→  // Add flagged stories if any\n    36→  if (config.flaggedStories && config.flaggedStories.length > 0) {\n    37→    prompt += `\\n## Flagged Stories (Skip These)\\n\\n`;\n    38→    prompt += `The following stories have exceeded the retry limit and should be skipped:\\n`;\n    39→    for (const story of config.flaggedStories) {\n    40→      prompt += `- \\`${story}\\`\\n`;\n    41→    }\n    42→  }\n    43→\n    44→  return prompt;\n    45→}\n    46→"}]},"parent_tool_use_id":"toolu_01L5LiJHunZnUnw7ysWAKpUU","session_id":"7c5953f4-1d55-4aa9-825f-60bc73601e00","uuid":"fd52d129-cf62-44ce-b950-88721fe7716f","timestamp":"2026-03-25T02:03:45.575Z"}
