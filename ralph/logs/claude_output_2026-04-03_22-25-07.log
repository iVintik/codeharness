 });\n413\t  });\n414\t\n415\t  describe('dispatch error propagation', () => {\n416\t    it('re-throws non-timeout dispatch errors', async () => {\n417\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n418\t      const mockWorkspace = makeMockWorkspace();\n419\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n420\t      vi.mocked(dispatchAgent).mockRejectedValue(new Error('Network failure'));\n421\t\n422\t      await expect(runEvaluator(makeOptions())).rejects.toThrow('Network failure');\n423\t    });\n424\t\n425\t    it('handles non-Error thrown by dispatch (string)', async () => {\n426\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n427\t      const mockWorkspace = makeMockWorkspace();\n428\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n429\t      vi.mocked(dispatchAgent).mockRejectedValue('string error');\n430\t\n431\t      await expect(runEvaluator(makeOptions())).rejects.toBe('string error');\n432\t      expect(mockWorkspace.cleanup).toHaveBeenCalledTimes(1);\n433\t    });\n434\t  });\n435\t\n436\t  describe('workspace creation failure', () => {\n437\t    it('does not call cleanup when workspace creation throws', async () => {\n438\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n439\t      vi.mocked(createIsolatedWorkspace).mockRejectedValue(new Error('disk full'));\n440\t\n441\t      await expect(runEvaluator(makeOptions())).rejects.toThrow('disk full');\n442\t      // dispatchAgent should not have been called\n443\t      expect(dispatchAgent).not.toHaveBeenCalled();\n444\t    });\n445\t  });\n446\t\n447\t  describe('timer cleanup', () => {\n448\t    it('clears timeout timer on successful dispatch to prevent process hang', async () => {\n449\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n450\t      const mockWorkspace = makeMockWorkspace();\n451\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n452\t      vi.mocked(dispatchAgent).mockResolvedValue(makeDispatchResult());\n453\t\n454\t      const clearTimeoutSpy = vi.spyOn(globalThis, 'clearTimeout');\n455\t\n456\t      await runEvaluator(makeOptions({ timeoutMs: 60000 }));\n457\t\n458\t      // clearTimeout should have been called at least once (for the race timer)\n459\t      expect(clearTimeoutSpy).toHaveBeenCalled();\n460\t      clearTimeoutSpy.mockRestore();\n461\t    });\n462\t  });\n463\t});\n464\t\n465\t// --- Story 16-5: Coverage Deduplication in Evaluator Prompt ---\n466\t\n467\tdescribe('buildEvaluatorPrompt (story 16-5)', () => {\n468\t  it('AC#1,#6: includes coverage context when coverageContext is provided', () => {\n469\t    const ctx: CoverageContext = { coverage: 95, target: 90 };\n470\t    const prompt = buildEvaluatorPrompt(ctx);\n471\t\n472\t    expect(prompt).toContain('Coverage already verified by engine: 95% (target: 90%). No re-run needed.');\n473\t    // Should still include standard prompt parts\n474\t    expect(prompt).toContain('Verify the acceptance criteria for this story.');\n475\t    expect(prompt).toContain('./story-files/');\n476\t    expect(prompt).toContain('./verdict/verdict.json');\n477\t  });\n478\t\n479\t  it('AC#2: does NOT include coverage context when coverageContext is undefined', () => {\n480\t    const prompt = buildEvaluatorPrompt(undefined);\n481\t\n482\t    expect(prompt).not.toContain('Coverage already verified by engine');\n483\t    expect(prompt).toContain('Verify the acceptance criteria for this story.');\n484\t  });\n485\t\n486\t  it('AC#3: does NOT include coverage context when no argument passed', () => {\n487\t    const prompt = buildEvaluatorPrompt();\n488\t\n489\t    expect(prompt).not.toContain('Coverage already verified by engine');\n490\t    expect(prompt).toContain('Verify the acceptance criteria for this story.');\n491\t  });\n492\t\n493\t  it('includes correct coverage and target values in context', () => {\n494\t    const ctx: CoverageContext = { coverage: 100, target: 100 };\n49