{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CR7pz3hXY56ya9XedVAkUX","type":"tool_result","content":"     1→/**\n     2→ * Public API for the agents subsystem.\n     3→ *\n     4→ * Re-exports types (story 13-1), RalphDriver implementation (story 13-2),\n     5→ * stream parser functions/types, ralph prompt functions/types,\n     6→ * and the getDriver() factory (story 13-3).\n     7→ */\n     8→\n     9→import type { AgentDriver } from './types.js';\n    10→import { RalphDriver, type RalphConfig } from './ralph.js';\n    11→\n    12→// Types\n    13→export type {\n    14→  SpawnOpts,\n    15→  AgentProcess,\n    16→  AgentEvent,\n    17→  AgentDriver,\n    18→} from './types.js';\n    19→\n    20→// RalphDriver\n    21→export { RalphDriver } from './ralph.js';\n    22→export type { RalphConfig } from './ralph.js';\n    23→export { buildSpawnArgs, resolveRalphPath, parseRalphMessage, parseIterationMessage } from './ralph.js';\n    24→\n    25→// Stream parser\n    26→export { parseStreamLine } from './stream-parser.js';\n    27→export type {\n    28→  StreamEvent,\n    29→  ToolStartEvent,\n    30→  ToolInputEvent,\n    31→  ToolCompleteEvent,\n    32→  TextEvent,\n    33→  RetryEvent,\n    34→  ResultEvent,\n    35→} from './stream-parser.js';\n    36→\n    37→// Ralph prompt\n    38→export { generateRalphPrompt } from './ralph-prompt.js';\n    39→export type { RalphPromptConfig } from './ralph-prompt.js';\n    40→\n    41→// --- Driver Factory ---\n    42→\n    43→/**\n    44→ * Returns an AgentDriver instance by name.\n    45→ * Defaults to 'ralph'. Throws for unknown driver names.\n    46→ */\n    47→export function getDriver(name?: string, config?: RalphConfig): AgentDriver {\n    48→  const driverName = name ?? 'ralph';\n    49→  switch (driverName) {\n    50→    case 'ralph':\n    51→      return new RalphDriver(config);\n    52→    default:\n    53→      throw new Error(`Unknown agent driver: ${driverName}`);\n    54→  }\n    55→}\n    56→"}]},"parent_tool_use_id":"toolu_01AeYymucNLjmuqL83DiV485","session_id":"a5a043ae-cfd1-4d51-82dd-d0069edc63ef","uuid":"9a78fad9-40ed-4743-9ca1-f938d19cf29e","timestamp":"2026-03-24T16:30:29.511Z"}
