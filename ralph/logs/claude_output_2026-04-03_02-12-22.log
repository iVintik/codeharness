k')) {\n1450\t          return { sessionId: 'sess-v', success: true, durationMs: 100, output: makePassVerdict() };\n1451\t        }\n1452\t        return { sessionId: 'sess-r', success: true, durationMs: 100, output: 'ok' };\n1453\t      },\n1454\t    );\n1455\t\n1456\t    mockParse.mockReturnValue({\n1457\t      development_status: { '3-1-foo': 'ready-for-dev' },\n1458\t    });\n1459\t\n1460\t    const config = makeConfig({\n1461\t      workflow: {\n1462\t        tasks: {\n1463\t          retry: makeTask({ scope: 'per-story' }),\n1464\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n1465\t        },\n1466\t        flow: [{ loop: ['retry', 'verify'] }],\n1467\t      },\n1468\t    });\n1469\t\n1470\t    await executeWorkflow(config);\n1471\t\n1472\t    // Check that evaluator_scores were recorded in state\n1473\t    const stateWrites = mockWriteWorkflowState.mock.calls.map((c: unknown[]) => c[0] as WorkflowState);\n1474\t    const stateWithScore = stateWrites.find((s) => s.evaluator_scores.length > 0);\n1475\t    expect(stateWithScore).toBeDefined();\n1476\t    expect(stateWithScore!.evaluator_scores[0].passed).toBe(2);\n1477\t    expect(stateWithScore!.evaluator_scores[0].failed).toBe(0);\n1478\t  });\n1479\t\n1480\t  it('records all-UNKNOWN score when verdict parsing fails (AC #6)', async () => {\n1481\t    mockDispatchAgent.mockImplementation(\n1482\t      async (_def: SubagentDefinition, prompt: string) => {\n1483\t        if (prompt.includes('Execute task')) {\n1484\t          // Return non-JSON output\n1485\t          return { sessionId: 'sess-v', success: true, durationMs: 100, output: 'not a json verdict' };\n1486\t        }\n1487\t        return { sessionId: 'sess-r', success: true, durationMs: 100, output: 'ok' };\n1488\t      },\n1489\t    );\n1490\t\n1491\t    mockParse.mockReturnValue({\n1492\t      development_status: {\n1493\t        '3-1-foo': 'ready-for-dev',\n1494\t        '3-2-bar': 'backlog',\n1495\t      },\n1496\t    });