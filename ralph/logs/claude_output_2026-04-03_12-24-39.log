ot found (AC #7)', () => {\n310\t    it('throws WorkflowParseError for non-existent file', () => {\n311\t      const fakePath = join(testDir, 'does-not-exist.yaml');\n312\t\n313\t      expect(() => parseWorkflow(fakePath)).toThrow(WorkflowParseError);\n314\t      try {\n315\t        parseWorkflow(fakePath);\n316\t      } catch (err) {\n317\t        const pe = err as WorkflowParseError;\n318\t        expect(pe.message).toContain('File not found');\n319\t        expect(pe.errors.length).toBeGreaterThan(0);\n320\t      }\n321\t    });\n322\t\n323\t    it('throws WorkflowParseError when path is a directory', () => {\n324\t      const dirPath = join(testDir, 'subdir');\n325\t      mkdirSync(dirPath);\n326\t\n327\t      expect(() => parseWorkflow(dirPath)).toThrow(WorkflowParseError);\n328\t      try {\n329\t        parseWorkflow(dirPath);\n330\t      } catch (err) {\n331\t        const pe = err as WorkflowParseError;\n332\t        expect(pe.message).toContain('Path is a directory');\n333\t      }\n334\t    });\n335\t  });\n336\t\n337\t  describe('typed interfaces (AC #8)', () => {\n338\t    it('ResolvedWorkflow has correct structure', () => {\n339\t      const filePath = writeYaml('typed.yaml', fullYaml);\n340\t      const result: ResolvedWorkflow = parseWorkflow(filePath);\n341\t\n342\t      // tasks is Record<string, ResolvedTask>\n343\t      const taskKeys = Object.keys(result.tasks);\n344\t      expect(taskKeys).toContain('implement');\n345\t      expect(taskKeys).toContain('verify');\n346\t\n347\t      // flow is FlowStep[]\n348\t      expect(Array.isArray(result.flow)).toBe(true);\n349\t\n350\t      // Each task has ResolvedTask properties\n351\t      const task: ResolvedTask = result.tasks.implement;\n352\t      expect(typeof task.agent).toBe('string');\n353\t      expect(typeof task.scope).toBe('string');\n354\t      expect(typeof task.session).toBe('string');\n355\t      expect(typeof task.source_access).toBe('boolean');\n356\t    });\n357\t\n358\t    it('FlowStep is a union of string | LoopBlock', () => {\n359\t      const filePath = writeYaml('flow-types.yaml', loopYaml);\n360\t      const result = parseWorkflow(filePath);\n361\t\n362\t      // String flow step\n363\t      const stringStep: FlowStep = result.flow[0];\n364\t      expect(typeof stringStep).toBe('string');\n365\t\n366\t      // LoopBlock flow step\n367\t      const loopStep: FlowStep = result.flow[2];\n368\t      expect(typeof loopStep).toBe('object');\n369\t      expect((loopStep as LoopBlock).loop).toBeDefined();\n370\t    });\n371\t  });\n372\t\n373\t  describe('driver, model, and plugins fields (Story 11-1)', () => {\n374\t    it('minimal workflow without new fields parses successfully — backward compat (AC #2)', () => {\n375\t      const filePath = writeYaml('compat.yaml', minimalYaml);\n376\t      const result = parseWorkflow(filePath);\n377\t\n378\t      expect(result.tasks.implement.driver).toBeUndefined();\n379\t      expect(result.tasks.implement.model).toBeUndefined();\n380\t      expect(result.tasks.implement.plugins).toBeUndefined();\n381\t    });\n382\t\n383\t    it('task with driver: codex parses into ResolvedTask.driver === \"codex\" (AC #3)', () => {\n384\t      const yaml = `\n385\ttasks:\n386\t  implement:\n387\t    agent: dev\n388\t    driver: codex\n389\tflow:\n390\t  - implement\n391\t`;\n392\t      const filePath = writeYaml('driver.yaml', yaml);\n393\t      const result = parseWorkflow(filePath);\n394\t\n395\t      expect(result.tasks.implement.driver).toBe('codex');\n396\t      expect(result.tasks.implement.model).toBeUndefined();\n397\t      expect(result.tasks.implement.plugins).toBeUndefined();\n398\t    });\n399\t"}]},"parent_tool_use_id":"toolu_01U85MaKaYFD6RV3D181SmSg","session_id":"4b1f7711-6ed7-4488-a0af-b261e761b450","uuid":"375dc079-80f8-493d-be22-5f77012e6d7c","timestamp":"2026-04-03T08:37:05.443Z"}
