{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0144avHSEDsSEBa2pv9p8oYz","type":"tool_result","content":"     1→/**\n     2→ * Verification environment management: Docker image lifecycle, clean workspace,\n     3→ * and environment checks for black-box verification.\n     4→ */\n     5→import { execFileSync } from 'node:child_process';\n     6→import { existsSync, mkdirSync, readdirSync, readFileSync, cpSync, rmSync, statSync } from 'node:fs';\n     7→import { join, basename } from 'node:path';\n     8→import { createHash } from 'node:crypto';\n     9→import { info } from '../../lib/output.js';\n    10→import { detectStacks } from '../../lib/stacks/index.js';\n    11→import { readStateWithBody, writeState } from '../../lib/state.js';\n    12→import { isDockerAvailable } from '../../lib/docker/index.js';\n    13→import type { BuildOptions, BuildResult, CheckResult, ProjectType } from './types.js';\n    14→\n    15→const IMAGE_TAG = 'codeharness-verify';\n    16→const STORY_DIR = '_bmad-output/implementation-artifacts';\n    17→const TEMP_PREFIX = '/tmp/codeharness-verify-';\n    18→const STATE_KEY_DIST_HASH = 'verify_env_dist_hash';\n    19→\n    20→/** Validates that a story key is safe for file paths and container names. */\n    21→export function isValidStoryKey(storyKey: string): boolean {\n    22→  if (!storyKey || storyKey.includes('..') || storyKey.includes('/') || storyKey.includes('\\\\')) {\n    23→    return false;\n    24→  }\n    25→  return /^[a-zA-Z0-9_-]+$/.test(storyKey);\n    26→}\n    27→\n    28→/** Computes a SHA-256 hash of all files in dist/ for cache invalidation. */\n    29→export function computeDistHash(projectDir: string): string | null {\n    30→  const distDir = join(projectDir, 'dist');\n    31→  if (!existsSync(distDir)) return null;\n    32→  const hash = createHash('sha256');\n    33→  const files = collectFiles(distDir).sort();\n    34→  for (const file of files) {\n    35→    hash.update(file.slice(distDir.length));\n    36→    hash.update(readFileSync(file));\n    37→  }\n    38→  return hash.digest('hex');\n    39→}\n    40→\n    41→function collectFiles(dir: string): string[] {\n    42→  const results: string[] = [];\n    43→  for (const entry of readdirSync(dir, { withFileTypes: true })) {\n    44→    const fullPath = join(dir, entry.name);\n    45→    if (entry.isDirectory()) { results.push(...collectFiles(fullPath)); }\n    46→    else { results.push(fullPath); }\n    47→  }\n    48→  return results;\n    49→}\n    50→\n    51→function getStoredDistHash(projectDir: string): string | null {\n    52→  try {\n    53→    const { state } = readStateWithBody(projectDir);\n    54→    return ((state as unknown as Record<string, unknown>)[STATE_KEY_DIST_HASH] as string) ?? null;\n    55→  } catch { return null; }\n    56→}\n    57→\n    58→function storeDistHash(projectDir: string, hash: string): void {\n    59→  try {\n    60→    const { state, body } = readStateWithBody(projectDir);\n    61→    (state as unknown as Record<string, unknown>)[STATE_KEY_DIST_HASH] = hash;\n    62→    writeState(state, projectDir, body);\n    63→  } catch {\n    64→    info('Could not persist dist hash to state file — cache will not be available until state is initialized');\n    65→  }\n    66→}\n    67→\n    68→/** Detects the project type for verification strategy selection. */\n    69→/** Stack names that map directly to ProjectType values. */\n    70→const STACK_TO_PROJECT_TYPE: Record<string, ProjectType> = {\n    71→  nodejs: 'nodejs',\n    72→  python: 'python',\n    73→  rust: 'rust',\n    74→};\n    75→\n    76→export function detectProjectType(projectDir: string): ProjectType {\n    77→  // Use detectStacks() (plural) for multi-stack awareness; derive primary from root detection\n    78→  const allStacks = detectStacks(projectDir);\n    79→  const rootDetection = allStacks.find(s => s.dir === '.');\n    80→  const stack = rootDetection ? rootDetection.stack : null;\n    81→  // Prefer known stacks when the project has a buildable package — the npm tarball\n    82→  // or Python wheel includes all distributable files. Plugin-only detection is the\n    83→  // fallback for projects that are purely Claude Code plugins with no build artifact.\n    84→  if (stack && STACK_TO_PROJECT_TYPE[stack]) return STACK_TO_PROJECT_TYPE[stack];\n    85→  if (existsSync(join(projectDir, '.claude-plugin', 'plugin.json'))) return 'plugin';\n    86→  return 'generic';\n    87→}\n    88→\n    89→/** Builds the verification Docker image with cache invalidation. */\n    90→export function buildVerifyImage(options: BuildOptions = {}): BuildResult {\n    91→  const projectDir = options.projectDir ?? process.cwd();\n    92→  if (!isDockerAvailable()) {\n    93→    throw new Error('Docker is not available. Install Docker and ensure the daemon is running.');\n    94→  }\n    95→  const projectType = detectProjectType(projectDir);\n    96→  const currentHash = computeDistHash(projectDir);\n    97→  /** Project types that don't require dist/ for verification image build */\n    98→  const NO_DIST_REQUIRED = new Set<ProjectType>(['generic', 'plugin', 'rust']);\n    99→  if (NO_DIST_REQUIRED.has(projectType)) {\n   100→    // Generic, plugin, and Rust projects may not have dist/ — skip hash check\n   101→  } else if (!currentHash) {\n   102→    throw new Error('No dist/ directory found. Run your build command first (e.g., npm run build).');\n   103→  }\n   104→  if (currentHash) {\n   105→    const storedHash = getStoredDistHash(projectDir);\n   106→    if (storedHash === currentHash && dockerImageExists(IMAGE_TAG)) {\n   107→      return { imageTag: IMAGE_TAG, imageSize: getImageSize(IMAGE_TAG), buildTimeMs: 0, cached: true };\n   108→    }\n   109→  }\n   110→  const startTime = Date.now();\n   111→  /** Per-project-type Docker image builders (no stack string comparisons). */\n   112→  const imageBuilders: Record<ProjectType, () => void> = {\n   113→    nodejs: () => buildNodeImage(projectDir),\n   114→    python: () => buildPythonImage(projectDir),\n   115→    rust: () => buildSimpleImage(projectDir, 'rust', 300_000),\n   116→    plugin: () => buildPluginImage(projectDir),\n   117→    generic: () => buildSimpleImage(projectDir, 'generic'),\n   118→  };\n   119→  imageBuilders[projectType]();\n   120→  if (currentHash) { storeDistHash(projectDir, currentHash); }\n   121→  return { imageTag: IMAGE_TAG, imageSize: getImageSize(IMAGE_TAG), buildTimeMs: Date.now() - startTime, cached: false };\n   122→}\n   123→\n   124→function buildNodeImage(projectDir: string): void {\n   125→  const packOutput = execFileSync('npm', ['pack', '--pack-destination', '/tmp'], {\n   126→    cwd: projectDir, stdio: 'pipe', timeout: 60_000,\n   127→  }).toString().trim();\n   128→  const lastLine = packOutput.split('\\n').pop()?.trim();\n   129→  if (!lastLine) throw new Error('npm pack produced no output — cannot determine tarball filename.');\n   130→  const tarballName = basename(lastLine);\n   131→  const tarballPath = join('/tmp', tarballName);\n   132→  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   133→  mkdirSync(buildContext, { recursive: true });\n   134→  try {\n   135→    cpSync(tarballPath, join(buildContext, tarballName));\n   136→    cpSync(resolveDockerfileTemplate(projectDir), join(buildContext, 'Dockerfile'));\n   137→    execFileSync('docker', ['build', '-t', IMAGE_TAG, '--build-arg', `TARBALL=${tarballName}`, '.'], {\n   138→      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   139→    });\n   140→  } finally {\n   141→    rmSync(buildContext, { recursive: true, force: true });\n   142→    rmSync(tarballPath, { force: true });\n   143→  }\n   144→}\n   145→\n   146→function buildPythonImage(projectDir: string): void {\n   147→  const distDir = join(projectDir, 'dist');\n   148→  const distFiles = readdirSync(distDir).filter(f => f.endsWith('.tar.gz') || f.endsWith('.whl'));\n   149→  if (distFiles.length === 0) {\n   150→    throw new Error('No distribution files found in dist/. Run your build command first (e.g., python -m build).');\n   151→  }\n   152→  const distFile = distFiles.filter(f => f.endsWith('.tar.gz'))[0] ?? distFiles[0];\n   153→  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   154→  mkdirSync(buildContext, { recursive: true });\n   155→  try {\n   156→    cpSync(join(distDir, distFile), join(buildContext, distFile));\n   157→    cpSync(resolveDockerfileTemplate(projectDir), join(buildContext, 'Dockerfile'));\n   158→    execFileSync('docker', ['build', '-t', IMAGE_TAG, '--build-arg', `TARBALL=${distFile}`, '.'], {\n   159→      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   160→    });\n   161→  } finally {\n   162→    rmSync(buildContext, { recursive: true, force: true });\n   163→  }\n   164→}\n   165→\n   166→/** Creates a clean temp workspace for verification (no src/, tests/, .git/). */\n   167→export function prepareVerifyWorkspace(storyKey: string, projectDir?: string): string {\n   168→  const root = projectDir ?? process.cwd();\n   169→  if (!isValidStoryKey(storyKey)) {\n   170→    throw new Error(`Invalid story key: ${storyKey}. Keys must contain only alphanumeric characters, hyphens, and underscores.`);\n   171→  }\n   172→  const storyFile = join(root, STORY_DIR, `${storyKey}.md`);\n   173→  if (!existsSync(storyFile)) throw new Error(`Story file not found: ${storyFile}`);\n   174→  const workspace = `${TEMP_PREFIX}${storyKey}`;\n   175→  if (existsSync(workspace)) rmSync(workspace, { recursive: true, force: true });\n   176→  mkdirSync(workspace, { recursive: true });\n   177→  cpSync(storyFile, join(workspace, 'story.md'));\n   178→  const readmePath = join(root, 'README.md');\n   179→  if (existsSync(readmePath)) cpSync(readmePath, join(workspace, 'README.md'));\n   180→  const docsDir = join(root, 'docs');\n   181→  if (existsSync(docsDir) && statSync(docsDir).isDirectory()) {\n   182→    cpSync(docsDir, join(workspace, 'docs'), { recursive: true });\n   183→  }\n   184→  mkdirSync(join(workspace, 'verification'), { recursive: true });\n   185→  return workspace;\n   186→}\n   187→\n   188→/** Validates verification environment: image, CLI, observability. */\n   189→export function checkVerifyEnv(): CheckResult {\n   190→  let imageExists = false;\n   191→  let cliWorks = false;\n   192→  let otelReachable = false;\n   193→\n   194→  imageExists = dockerImageExists(IMAGE_TAG);\n   195→  if (!imageExists) return { imageExists, cliWorks, otelReachable };\n   196→  try {\n   197→    execFileSync('docker', ['run', '--rm', IMAGE_TAG, 'codeharness', '--help'], {\n   198→      stdio: 'pipe', timeout: 30_000,\n   199→    });\n   200→    cliWorks = true;\n   201→  } catch { cliWorks = false; }\n   202→  try {\n   203→    execFileSync('docker', [\n   204→      'run', '--rm', '--add-host=host.docker.internal:host-gateway', IMAGE_TAG,\n   205→      'curl', '-sf', '--max-time', '5', 'http://host.docker.internal:4318/v1/status',\n   206→    ], { stdio: 'pipe', timeout: 30_000 });\n   207→    otelReachable = true;\n   208→  } catch { otelReachable = false; }\n   209→  return { imageExists, cliWorks, otelReachable };\n   210→}\n   211→\n   212→/** Cleans up all stale containers matching `codeharness-verify-*` pattern. Idempotent. */\n   213→export function cleanupStaleContainers(): void {\n   214→  try {\n   215→    const output = execFileSync(\n   216→      'docker', ['ps', '-a', '--filter', 'name=codeharness-verify-', '--format', '{{.Names}}'],\n   217→      { stdio: 'pipe', timeout: 15_000 },\n   218→    ).toString('utf-8').trim();\n   219→    if (output.length === 0) return;\n   220→    const containers = output.split('\\n').filter(name => name.length > 0);\n   221→    for (const name of containers) {\n   222→      try {\n   223→        execFileSync('docker', ['rm', '-f', name], { stdio: 'pipe', timeout: 15_000 });\n   224→      } catch { /* container may already be removed */ }\n   225→    }\n   226→  } catch { /* docker not available or no containers — ignore */ }\n   227→}\n   228→\n   229→/** Removes temp workspace and stops/removes the container. Idempotent. */\n   230→export function cleanupVerifyEnv(storyKey: string): void {\n   231→  if (!isValidStoryKey(storyKey)) {\n   232→    throw new Error(`Invalid story key: ${storyKey}. Keys must contain only alphanumeric characters, hyphens, and underscores.`);\n   233→  }\n   234→  const workspace = `${TEMP_PREFIX}${storyKey}`;\n   235→  const containerName = `codeharness-verify-${storyKey}`;\n   236→  if (existsSync(workspace)) rmSync(workspace, { recursive: true, force: true });\n   237→  try { execFileSync('docker', ['stop', containerName], { stdio: 'pipe', timeout: 15_000 }); }\n   238→  catch { /* container may not exist */ }\n   239→  try { execFileSync('docker', ['rm', '-f', containerName], { stdio: 'pipe', timeout: 15_000 }); }\n   240→  catch { /* container may not exist */ }\n   241→}\n   242→\n   243→function buildPluginImage(projectDir: string): void {\n   244→  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   245→  mkdirSync(buildContext, { recursive: true });\n   246→  try {\n   247→    // Copy plugin source into build context\n   248→    const pluginDir = join(projectDir, '.claude-plugin');\n   249→    cpSync(pluginDir, join(buildContext, '.claude-plugin'), { recursive: true });\n   250→    // Copy any commands, hooks, knowledge, skills directories if they exist\n   251→    for (const dir of ['commands', 'hooks', 'knowledge', 'skills']) {\n   252→      const src = join(projectDir, dir);\n   253→      if (existsSync(src) && statSync(src).isDirectory()) {\n   254→        cpSync(src, join(buildContext, dir), { recursive: true });\n   255→      }\n   256→    }\n   257→    cpSync(resolveDockerfileTemplate(projectDir, 'generic'), join(buildContext, 'Dockerfile'));\n   258→    execFileSync('docker', ['build', '-t', IMAGE_TAG, '.'], {\n   259→      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   260→    });\n   261→  } finally {\n   262→    rmSync(buildContext, { recursive: true, force: true });\n   263→  }\n   264→}\n   265→\n   266→function buildSimpleImage(projectDir: string, variant: string, timeout = 120_000): void {\n   267→  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   268→  mkdirSync(buildContext, { recursive: true });\n   269→  try {\n   270→    cpSync(resolveDockerfileTemplate(projectDir, variant), join(buildContext, 'Dockerfile'));\n   271→    execFileSync('docker', ['build', '-t', IMAGE_TAG, '.'], {\n   272→      cwd: buildContext, stdio: 'pipe', timeout,\n   273→    });\n   274→  } finally {\n   275→    rmSync(buildContext, { recursive: true, force: true });\n   276→  }\n   277→}\n   278→\n   279→const DOCKERFILE_VARIANTS: Record<string, string> = {\n   280→  generic: 'Dockerfile.verify.generic',\n   281→  rust: 'Dockerfile.verify.rust',\n   282→};\n   283→\n   284→function resolveDockerfileTemplate(projectDir: string, variant?: string): string {\n   285→  const filename = (variant && DOCKERFILE_VARIANTS[variant]) ?? 'Dockerfile.verify';\n   286→  const local = join(projectDir, 'templates', filename);\n   287→  if (existsSync(local)) return local;\n   288→  const pkgDir = new URL('../../', import.meta.url).pathname;\n   289→  const pkg = join(pkgDir, 'templates', filename);\n   290→  if (existsSync(pkg)) return pkg;\n   291→  throw new Error(`${filename} not found. Ensure templates/${filename} exists.`);\n   292→}\n   293→\n   294→function dockerImageExists(tag: string): boolean {\n   295→  try {\n   296→    execFileSync('docker', ['image', 'inspect', tag], { stdio: 'pipe', timeout: 10_000 });\n   297→    return true;\n   298→  } catch { return false; }\n   299→}\n   300→\n   301→function getImageSize(tag: string): string {\n   302→  try {\n   303→    const output = execFileSync('docker', ['image', 'inspect', tag, '--format', '{{.Size}}'], {\n   304→      stdio: 'pipe', timeout: 10_000,\n   305→    }).toString().trim();\n   306→    const bytes = parseInt(output, 10);\n   307→    if (isNaN(bytes)) return output;\n   308→    if (bytes >= 1_000_000_000) return `${(bytes / 1_000_000_000).toFixed(1)}GB`;\n   309→    if (bytes >= 1_000_000) return `${(bytes / 1_000_000).toFixed(1)}MB`;\n   310→    if (bytes >= 1_000) return `${(bytes / 1_000).toFixed(1)}KB`;\n   311→    return `${bytes}B`;\n   312→  } catch { return 'unknown'; }\n   313→}\n   314→"}]},"parent_tool_use_id":"toolu_01AE5uy3isqvp9ZhM1WQjpz4","session_id":"38809bab-d371-4c03-b647-b7b7381ee002","uuid":"a92b1caa-c0e8-400c-9d20-4a6009faed69","timestamp":"2026-03-24T23:32:34.022Z"}
