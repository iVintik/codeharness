duces existing output (backward compat)', () => {\n    const content = generateAgentsMdContent(testDir, 'nodejs');\n    expect(content).toContain('npm install');\n    expect(content).toContain('npm test');\n    expect(content).not.toContain('###');\n  });\n\n  it('includes python commands in multi-stack with cd prefix', () => {\n    const content = generateAgentsMdContent(testDir, [\n      { stack: 'python', dir: 'ml' },\n      { stack: 'nodejs', dir: '.' },\n    ]);\n    expect(content).toContain('cd ml && pip install');\n    expect(content).toContain('cd ml && python -m pytest');\n    expect(content).toContain('### Python (ml/)');\n  });\n});\n\ndescribe('generateDocsIndexContent', () => {"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":337,"cache_read_input_tokens":74473,"cache_creation":{"ephemeral_5m_input_tokens":337,"ephemeral_1h_input_tokens":0},"output_tokens":73,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01CVfsuk3fYkb5FT4qRVJXrF","session_id":"58ae4f51-bff6-4a66-807a-d4f10c8bdaa3","uuid":"5975c838-4784-4ce3-87d0-eaf175ac9d11"}
