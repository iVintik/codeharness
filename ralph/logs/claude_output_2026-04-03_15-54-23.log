{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014oD7pWFZQwGCV6ppLGyyqg","type":"tool_result","content":"1\t/**\n2\t * Ink Terminal Renderer — live terminal UI for Claude activity display.\n3\t *\n4\t * Exports a controller API: startRenderer(), which returns a RendererHandle\n5\t * with update(), updateSprintState(), and cleanup() methods.\n6\t *\n7\t * The renderer accumulates state from StreamEvent objects and renders\n8\t * tool calls, thoughts, and sprint progress using Ink (React for terminals).\n9\t */\n10\t\n11\timport React from 'react';\n12\timport { render as inkRender } from 'ink';\n13\timport type { StreamEvent } from './agents/stream-parser.js';\n14\timport {\n15\t  App,\n16\t  type SprintInfo,\n17\t  type CompletedToolEntry,\n18\t  type RetryInfo,\n19\t  type RendererState,\n20\t  type StoryStatusEntry,\n21\t  type StoryMessage,\n22\t  type TaskNodeState,\n23\t  type TaskNodeMeta,\n24\t} from './ink-components.js';\n25\timport type { FlowStep } from './workflow-parser.js';\n26\t\n27\t// --- Public Types ---\n28\t\n29\texport interface RendererOptions {\n30\t  quiet?: boolean;\n31\t  sprintState?: SprintInfo;\n32\t  /** @internal Force TTY mode for testing. Not part of the public API. */\n33\t  _forceTTY?: boolean;\n34\t}\n35\t\n36\texport interface RendererHandle {\n37\t  update(event: StreamEvent): void;\n38\t  updateSprintState(state: SprintInfo | undefined): void;\n39\t  updateStories(stories: StoryStatusEntry[]): void;\n40\t  addMessage(msg: StoryMessage): void;\n41\t  updateWorkflowState(flow: FlowStep[], currentTask: string | null, taskStates: Record<string, TaskNodeState>, taskMeta?: Record<string, TaskNodeMeta>): void;\n42\t  cleanup(): void;\n43\t}\n44\t\n45\t// --- No-op handle for quiet mode ---\n46\t\n47\tconst noopHandle: RendererHandle = {\n48\t  update() {},\n49\t  updateSprintState() {},\n50\t  updateStories() {},\n51\t  addMessage() {},\n52\t  updateWorkflowState() {},\n53\t  cleanup() {},\n54\t};\n55\t\n56\t/** Maximum number of completed tools to retain in the display list. */\n57\tconst MAX_COMPLETED_TOOLS = 50;\n58\t\n59\t// --- Controller ---\n60\t\n61\t/**\n62\t * Start the Ink terminal renderer.\n63\t *\n64\t * If `quiet` is true or stdout is not a TTY, returns a no-op handle\n65\t * (no Ink instance created).\n66\t * Otherwise, mounts the component tree and returns a handle for feeding events.\n67\t */\n68\texport function startRenderer(options?: RendererOptions): RendererHandle {\n69\t  if (options?.quiet || (!process.stdout.isTTY && !options?._forceTTY)) {\n70\t    return noopHandle;\n71\t  }\n72\t\n73\t  // Mutable state that drives re-renders\n74\t  let state: RendererState = {\n75\t    sprintInfo: options?.sprintState ?? null,\n76\t    stories: [],\n77\t    messages: [],\n78\t    completedTools: [],\n79\t    activeTool: null,\n80\t    activeToolArgs: '',\n81\t    lastThought: null,\n82\t    retryInfo: null,\n83\t    workflowFlow: [],\n84\t    currentTaskName: null,\n85\t    taskStates: {},\n86\t    taskMeta: {},\n87\t  };\n88\t\n89\t  let cleaned = false;\n90\t\n91\t  // Mount Ink with performance options\n92\t  const inkInstance = inkRender(<App state={state} />, {\n93\t    exitOnCtrlC: false,\n94\t    patchConsole: !options?._forceTTY,\n95\t    maxFps: 15,\n96\t  });\n97\t\n98\t  function rerender() {\n99\t    if (!cleaned) {\n100\t      // Create a new state object reference to trigger React re-render\n101\t      state = { ...state };\n102\t      inkInstance.rerender(<App state={state} />);\n103\t    }\n104\t  }\n105\t\n106\t  function cleanup() {\n107\t    if (cleaned) return;\n108\t    cleaned = true;\n109\t    try {\n110\t      inkInstance.unmount();\n111\t    } catch {\n112\t      // Ignore — may already be unmounted\n113\t    }\n114\t    try {\n115\t      inkInstance.cleanup();\n116\t    } catch {\n117\t      // Ignore\n118\t    }\n119\t    // Remove our signal handlers\n120\t    process.removeListener('SIGINT', onSigint);\n121\t    process.removeListener('SIGTERM', onSigterm);\n122\t  }\n123\t\n124\t  function onSigint() {\n125\t    cleanup();\n126\t    // Re-raise signal so the default handler runs (allows caller to handle exit)\n127\t    process.kill(process.pid, 'SIGINT');\n128\t  }\n129\t\n130\t  function onSigterm() {\n131\t    cleanup();\n132\t    process.kill(process.pid, 'SIGTERM');\n133\t  }\n134\t\n135\t  // Register signal handlers\n136\t  process.on('SIGINT', onSigint);\n137\t  process.on('SIGTERM', onSigterm);\n138\t\n139\t  function update(event: StreamEvent): void {\n140\t    if (cleaned) return;\n141\t\n142\t    switch (event.type) {\n143\t      case 'tool-start':\n144\t        // If a long-running tool was still active, promote it to completed now\n145\t        if (state.activeTool) {\n146\t          const entry: CompletedToolEntry = {\n147\t            name: state.activeTool.name,\n148\t            args: state.activeToolArgs,\n149\t          };\n150\t          const updated = [...state.completedTools, entry];\n151\t          state.completedTools = updated.length > MAX_COMPLETED_TOOLS\n152\t            ? updated.slice(updated.length - MAX_COMPLETED_TOOLS)\n153\t            : updated;\n154\t        }\n155\t        state.activeTool = { name: event.name };\n156\t        state.activeToolArgs = '';\n157\t        state.lastThought = null;\n158\t        state.retryInfo = null;\n159\t        break;\n160\t\n161\t      case 'tool-input':\n162\t        state.activeToolArgs += event.partial;\n163\t        return; // Skip rerender — args only shown on completion\n164\t\n165\t      case 'tool-complete':\n166\t        // CRITICAL: Only promote if there's an active tool.\n167\t        // The parser emits tool-complete for ALL content_block_stop events\n168\t        // (both tool and text blocks). Ignore if no activeTool is set.\n169\t        if (state.activeTool) {\n170\t          // Long-running tools (Agent, Skill) get content_block_stop when their\n171\t          // INPUT is complete, not when they finish executing. Keep them active\n172\t          // so the spinner shows during the entire execution. They'll be promoted\n173\t          // when the next tool-start fires (below in tool-start case).\n174\t          const LONG_RUNNING_TOOLS = ['Agent', 'Skill'];\n175\t          if (LONG_RUNNING_TOOLS.includes(state.activeTool.name)) {\n176\t            break; // Keep as active — don't promote to completed yet\n177\t          }\n178\t          const entry: CompletedToolEntry = {\n179\t            name: state.activeTool.name,\n180\t            args: state.activeToolArgs,\n181\t          };\n182\t          const updated = [...state.completedTools, entry];\n183\t          // Bound the list to prevent unbounded memory growth in long sessions\n184\t          state.completedTools = updated.length > MAX_COMPLETED_TOOLS\n185\t            ? updated.slice(updated.length - MAX_COMPLETED_TOOLS)\n186\t            : updated;\n187\t          state.activeTool = null;\n188\t          state.activeToolArgs = '';\n189\t        }\n190\t        break;\n191\t\n192\t      case 'text':\n193\t        state.lastThought = event.text;\n194\t        state.retryInfo = null;\n195\t        break;\n196\t\n197\t      case 'retry':\n198\t        state.retryInfo = { attempt: event.attempt, delay: event.delay };\n199\t        break;\n200\t\n201\t      case 'result':\n202\t        // Accumulate cost from result events (AC #7)\n203\t        if (event.cost > 0 && state.sprintInfo) {\n204\t          state.sprintInfo = {\n205\t            ...state.sprintInfo,\n206\t            totalCost: (state.sprintInfo.totalCost ?? 0) + event.cost,\n207\t          };\n208\t        }\n209\t        break;\n210\t    }\n211\t\n212\t    rerender();\n213\t  }\n214\t\n215\t  function updateSprintState(sprintState: SprintInfo | undefined): void {\n216\t    if (cleaned) return;\n217\t    if (sprintState && state.sprintInfo) {\n218\t      // Preserve accumulated fields (totalCost, acProgress, currentCommand)\n219\t      // that are set by event handlers but not by the polling caller.\n220\t      state.sprintInfo = {\n221\t        ...sprintState,\n222\t        totalCost: sprintState.totalCost ?? state.sprintInfo.totalCost,\n223\t        acProgress: sprintState.acProgress ?? state.sprintInfo.acProgress,\n224\t        currentCommand: sprintState.currentCommand ?? state.sprintInfo.currentCommand,\n225\t      };\n226\t    } else {\n227\t      state.sprintInfo = sprintState ?? null;\n228\t    }\n229\t    rerender();\n230\t  }\n231\t\n232\t  function updateStories(stories: StoryStatusEntry[]): void {\n233\t    if (cleaned) return;\n234\t    state.stories = [...stories];\n235\t    rerender();\n236\t  }\n237\t\n238\t  function addMessage(msg: StoryMessage): void {\n239\t    if (cleaned) return;\n240\t    state.messages = [...state.messages, msg];\n241\t    rerender();\n242\t  }\n243\t\n244\t  function updateWorkflowState(flow: FlowStep[], currentTask: string | null, taskStates: Record<string, TaskNodeState>, taskMeta?: Record<string, TaskNodeMeta>): void {\n245\t    if (cleaned) return;\n246\t    state.workflowFlow = flow;\n247\t    state.currentTaskName = currentTask;\n248\t    state.taskStates = { ...taskStates };\n249\t    state.taskMeta = taskMeta ? { ...taskMeta } : state.taskMeta;\n250\t    rerender();\n251\t  }\n252\t\n253\t  return { update, updateSprintState, updateStories, addMessage, updateWorkflowState, cleanup };\n254\t}\n255\t\n256\t// Re-export types that consumers may need\n257\texport type { SprintInfo, CompletedToolEntry, RetryInfo, RendererState, StoryStatusEntry, StoryStatusValue, StoryMessage, TaskNodeState, TaskNodeMeta } from './ink-components.js';\n258\t"}]},"parent_tool_use_id":"toolu_01UsAm2qXT84D1u4sW8gSAmJ","session_id":"a29ee53b-c2b0-4802-9455-7215112648b1","uuid":"eae5478e-ad0e-4af1-87ab-7344a00d33f1","timestamp":"2026-04-03T11:57:54.631Z"}
