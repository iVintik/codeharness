{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SY59FLTqp3DSGYJa6MAJGF","type":"tool_result","content":"     1→/**\n     2→ * Dockerfile template generator — creates stack-appropriate Dockerfiles for user projects.\n     3→ * Returns Result<DockerfileTemplateResult> following the project's Result<T> pattern.\n     4→ *\n     5→ * FR22 (Dockerfile template based on project type).\n     6→ */\n     7→\n     8→import { existsSync, writeFileSync } from 'node:fs';\n     9→import { join } from 'node:path';\n    10→import { ok, fail } from '../../types/result.js';\n    11→import type { Result } from '../../types/result.js';\n    12→\n    13→/** Result returned by generateDockerfileTemplate */\n    14→export interface DockerfileTemplateResult {\n    15→  readonly path: string;\n    16→  readonly stack: string;\n    17→}\n    18→\n    19→// ─── Template content generators ────────────────────────────────────────────\n    20→\n    21→function nodejsTemplate(): string {\n    22→  return `# Base image — pinned version for reproducibility\n    23→FROM node:22-slim\n    24→\n    25→ARG TARBALL=package.tgz\n    26→\n    27→# System utilities for verification\n    28→RUN apt-get update && apt-get install -y --no-install-recommends curl jq && rm -rf /var/lib/apt/lists/*\n    29→\n    30→# Install project from tarball (black-box: no source code)\n    31→COPY \\${TARBALL} /tmp/\\${TARBALL}\n    32→RUN npm install -g /tmp/\\${TARBALL} && rm /tmp/\\${TARBALL}\n    33→\n    34→# Run as non-root user\n    35→USER node\n    36→\n    37→WORKDIR /workspace\n    38→`;\n    39→}\n    40→\n    41→function pythonTemplate(): string {\n    42→  return `# Base image — pinned version for reproducibility\n    43→FROM python:3.12-slim\n    44→\n    45→# System utilities for verification\n    46→RUN apt-get update && apt-get install -y --no-install-recommends curl jq && rm -rf /var/lib/apt/lists/*\n    47→\n    48→# Install project from wheel or sdist\n    49→COPY dist/ /tmp/dist/\n    50→RUN pip install /tmp/dist/*.whl && rm -rf /tmp/dist/ && pip cache purge\n    51→\n    52→# Run as non-root user\n    53→USER nobody\n    54→\n    55→WORKDIR /workspace\n    56→`;\n    57→}\n    58→\n    59→function rustTemplate(): string {\n    60→  return `# === Builder stage ===\n    61→FROM rust:1.82-slim AS builder\n    62→\n    63→WORKDIR /build\n    64→\n    65→# Copy project files\n    66→COPY . .\n    67→\n    68→# Build release binary\n    69→RUN cargo build --release\n    70→\n    71→# === Runtime stage ===\n    72→FROM debian:bookworm-slim\n    73→\n    74→# System utilities for verification\n    75→RUN apt-get update && apt-get install -y --no-install-recommends curl jq && rm -rf /var/lib/apt/lists/*\n    76→\n    77→# Install compiled binary from builder (update 'myapp' to your binary name)\n    78→COPY --from=builder /build/target/release/myapp /usr/local/bin/myapp\n    79→\n    80→# Run as non-root user\n    81→USER nobody\n    82→\n    83→WORKDIR /workspace\n    84→`;\n    85→}\n    86→\n    87→function genericTemplate(): string {\n    88→  return `# Base image — pinned version for reproducibility\n    89→FROM node:22-slim\n    90→\n    91→# System utilities for verification\n    92→RUN apt-get update && apt-get install -y --no-install-recommends bash curl jq git && rm -rf /var/lib/apt/lists/*\n    93→\n    94→# Install project binary (update this for your project)\n    95→RUN npm install -g placeholder && npm cache clean --force\n    96→\n    97→# Run as non-root user\n    98→USER node\n    99→\n   100→WORKDIR /workspace\n   101→`;\n   102→}\n   103→\n   104→// ─── Main generator ─────────────────────────────────────────────────────────\n   105→\n   106→/**\n   107→ * Generate a Dockerfile template based on detected stack type.\n   108→ * Returns fail() if a Dockerfile already exists — caller handles messaging.\n   109→ */\n   110→export function generateDockerfileTemplate(\n   111→  projectDir: string,\n   112→  stack: string | null,\n   113→): Result<DockerfileTemplateResult> {\n   114→  if (!projectDir) {\n   115→    return fail('projectDir is required');\n   116→  }\n   117→\n   118→  const dockerfilePath = join(projectDir, 'Dockerfile');\n   119→\n   120→  if (existsSync(dockerfilePath)) {\n   121→    return fail('Dockerfile already exists');\n   122→  }\n   123→\n   124→  let content: string;\n   125→  let resolvedStack: string;\n   126→\n   127→  if (stack === 'nodejs') {\n   128→    content = nodejsTemplate();\n   129→    resolvedStack = 'nodejs';\n   130→  } else if (stack === 'python') {\n   131→    content = pythonTemplate();\n   132→    resolvedStack = 'python';\n   133→  } else if (stack === 'rust') {\n   134→    content = rustTemplate();\n   135→    resolvedStack = 'rust';\n   136→  } else {\n   137→    content = genericTemplate();\n   138→    resolvedStack = 'generic';\n   139→  }\n   140→\n   141→  try {\n   142→    writeFileSync(dockerfilePath, content, 'utf-8');\n   143→  } catch (err) {\n   144→    const message = err instanceof Error ? err.message : String(err);\n   145→    return fail(`Failed to write Dockerfile: ${message}`);\n   146→  }\n   147→\n   148→  return ok({ path: dockerfilePath, stack: resolvedStack });\n   149→}\n   150→"}]},"parent_tool_use_id":"toolu_01QPLvTF7hH7ZEy1LqPE8PcP","session_id":"daf25720-e009-4a3c-8a3c-df9d68d99484","uuid":"036b1b1f-b3ed-4d0e-909c-dd9738d1f144","timestamp":"2026-03-23T06:48:07.385Z"}
