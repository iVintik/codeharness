{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DmfomeTmfem635hsjubu2e","type":"tool_result","content":"1\t/**\n2\t * Merge Agent — conflict resolution via driver dispatch with retry loop.\n3\t *\n4\t * Receives a MergeConflictContext with conflicting files, epic descriptions,\n5\t * and an AgentDriver instance. Dispatches the driver to resolve conflicts,\n6\t * validates with the test suite, and retries up to 3 times before escalating.\n7\t *\n8\t * @see Story 18-2: Merge Agent for Conflict Resolution\n9\t */\n10\t\n11\timport { execSync } from 'node:child_process';\n12\timport { readFileSync } from 'node:fs';\n13\timport { join } from 'node:path';\n14\t\n15\timport type { AgentDriver } from './agents/types.js';\n16\timport { validateMerge, writeMergeTelemetry } from './cross-worktree-validator.js';\n17\t\n18\t// --- Interfaces ---\n19\t\n20\t/**\n21\t * Context provided to the merge agent for conflict resolution.\n22\t */\n23\texport interface MergeConflictContext {\n24\t  /** Epic identifier. */\n25\t  readonly epicId: string;\n26\t  /** Branch being merged. */\n27\t  readonly branch: string;\n28\t  /** List of conflicting file paths (relative to cwd). */\n29\t  readonly conflicts: string[];\n30\t  /** Description of what the main branch contains. */\n31\t  readonly mainDescription: string;\n32\t  /** Description of what the feature branch was building. */\n33\t  readonly branchDescription: string;\n34\t  /** Working directory (main repo root where merge is in progress). */\n35\t  readonly cwd: string;\n36\t  /** Command to run for test validation. */\n37\t  readonly testCommand: string;\n38\t  /** Driver instance to dispatch for conflict resolution. */\n39\t  readonly driver: AgentDriver;\n40\t}\n41\t\n42\t/**\n43\t * Result of a conflict resolution attempt.\n44\t */\n45\texport interface ConflictResolutionResult {\n46\t  /** Whether all conflicts were resolved and tests pass. */\n47\t  resolved: boolean;\n48\t  /** Number of resolution attempts made. */\n49\t  attempts: number;\n50\t  /** Whether the conflict was escalated for manual resolution. */\n51\t  escalated: boolean;\n52\t  /** Human-readable escalation message with details for manual resolution. */\n53\t  escalationMessage?: string;\n54\t  /** Test suite results from the last successful validation. */\n55\t  testResults?: { passed: number; failed: number; coverage?: number };\n56\t  /** List of files that were resolved. */\n57\t  resolvedFiles?: string[];\n58\t}\n59\t\n60\t// --- Constants ---\n61\t\n62\tconst MAX_ATTEMPTS = 3;\n63\t\n64\t// --- Prompt Construction ---\n65\t\n66\t/**\n67\t * Build the conflict resolution prompt for the driver.\n68\t *\n69\t * Includes file paths with full conflict-marker content, descriptions\n70\t * of both branches, and instructions to resolve preserving both changes.\n71\t */\n72\texport function buildConflictPrompt(ctx: MergeConflictContext, testFailure?: string): string {\n73\t  const conflictSections = ctx.conflicts.map((file) => {\n74\t    try {\n75\t      const content = readFileSync(join(ctx.cwd, file), 'utf-8');\n76\t      return `### ${file}\\n\\`\\`\\`\\n${content}\\n\\`\\`\\``;\n77\t    } catch { // IGNORE: file may be deleted on one side or unreadable — degrade gracefully in prompt\n78\t      return `### ${file}\\n*(File deleted on one side or unreadable)*`;\n79\t    }\n80\t  }).join('\\n\\n');\n81\t\n82\t  let prompt = `Merge conflict in ${ctx.conflicts.length} file(s) between main and ${ctx.branch}.\\n\\n`;\n83\t  prompt += `**Main branch context:** ${ctx.mainDescription}\\n`;\n84\t  prompt += `**Feature branch context:** ${ctx.branchDescription}\\n\\n`;\n85\t  prompt += `**Conflicting files:**\\n\\n${conflictSections}\\n\\n`;\n86\t  prompt += `Resolve ALL conflicts preserving changes from both branches. Both are correct additions.\\n`;\n87\t  prompt += `Write the resolved content to each file, stage with \\`git add\\`, and commit the merge resolution.\\n`;\n88\t\n89\t  if (testFailure) {\n90\t    prompt += `\\n**Previous attempt failed tests:**\\n\\`\\`\\`\\n${testFailure}\\n\\`\\`\\`\\n`;\n91\t    prompt += `Fix the resolution to make all tests pass.\\n`;\n92\t  }\n93\t  return prompt;\n94\t}\n95\t\n96\t// --- Escalation ---\n97\t\n98\t/**\n99\t * Build an escalation message with details for manual resolution.\n100\t */\n101\tfunction buildEscalationMessage(ctx: MergeConflictContext): string {\n102\t  const fileList = ctx.conflicts.map((f) => `  - ${f}`).join('\\n');\n103\t  return [\n104\t    `Merge conflict could not be auto-resolved after ${MAX_ATTEMPTS} attempts.`,\n105\t    ``,\n106\t    `Worktree: ${ctx.cwd}`,\n107\t    `Branch: ${ctx.branch}`,\n108\t    `Epic: ${ctx.epicId}`,\n109\t    ``,\n110\t    `Conflicting files:`,\n111\t    fileList,\n112\t    ``,\n113\t    `To inspect the diff:`,\n114\t    `  git diff ${ctx.branch}`,\n115\t  ].join('\\n');\n116\t}\n117\t\n118\t// --- Main Entry Point ---\n119\t\n120\t/**\n121\t * Resolve merge conflicts using an agent driver with retry loop.\n122\t *\n123\t * Dispatches the driver with conflict context, validates with the test suite,\n124\t * and retries up to 3 times. After 3 failures, escalates for manual resolution.\n125\t *\n126\t * @param ctx  Merge conflict context with files, descriptions, and driver.\n127\t * @returns Resolution result indicating success, failure, or escalation.\n128\t */\n129\texport async function resolveConflicts(ctx: MergeConflictContext): Promise<ConflictResolutionResult> {\n130\t  // Guard: empty conflict list\n131\t  if (ctx.conflicts.length === 0) {\n132\t    return { resolved: true, attempts: 0, escalated: false };\n133\t  }\n134\t\n135\t  let lastTestFailure: string | undefined;\n136\t\n137\t  for (let attempt = 1; attempt <= MAX_ATTEMPTS; attempt++) {\n138\t    const prompt = buildConflictPrompt(ctx, lastTestFailure);\n139\t\n140\t    // Dispatch driver — consume stream events to completion\n141\t    try {\n142\t      for await (const _event of ctx.driver.dispatch({\n143\t        prompt,\n144\t        model: ctx.driver.defaultModel,\n145\t        cwd: ctx.cwd,\n146\t        sourceAccess: true,\n147\t      })) {\n148\t        // Stream events consumed; merge agent doesn't need to display them\n149\t      }\n150\t    } catch { // IGNORE: driver dispatch failed (network error, rate limit) — treat as failed attempt\n151\t      // Treat as a failed attempt — try to revert and retry\n152\t      try {\n153\t        execSync('git reset --hard HEAD~1', { cwd: ctx.cwd, timeout: 30_000 });\n154\t      } catch { // IGNORE: git reset failed — escalate immediately on corrupted git state\n155\t        return {\n156\t          resolved: false,\n157\t          attempts: attempt,\n158\t          escalated: true,\n159\t          escalationMessage: buildEscalationMessage(ctx),\n160\t        };\n161\t      }\n162\t      lastTestFailure = 'Driver dispatch failed. Retrying with fresh attempt.';\n163\t      continue;\n164\t    }\n165\t\n166\t    // Run test suite via cross-worktree validator\n167\t    // Telemetry: false during validation; write manually on success or last attempt\n168\t    const isLastAttempt = attempt === MAX_ATTEMPTS;\n169\t    const validationOpts = {\n170\t      testCommand: ctx.testCommand,\n171\t      cwd: ctx.cwd,\n172\t      epicId: ctx.epicId,\n173\t      writeTelemetry: false,\n174\t    } as const;\n175\t    const validation = await validateMerge(validationOpts);\n176\t    if (validation.valid) {\n177\t      writeMergeTelemetry({ ...validationOpts, writeTelemetry: true }, validation);\n178\t      return {\n179\t        resolved: true,\n180\t        attempts: attempt,\n181\t        escalated: false,\n182\t        testResults: validation.testResults,\n183\t        resolvedFiles: ctx.conflicts,\n184\t      };\n185\t    }\n186\t\n187\t    // Tests failed — write telemetry on last attempt, then revert and retry\n188\t    if (isLastAttempt) {\n189\t      writeMergeTelemetry({ ...validationOpts, writeTelemetry: true }, validation);\n190\t    }\n191\t    lastTestFailure = validation.output;\n192\t    try {\n193\t      execSync('git reset --hard HEAD~1', { cwd: ctx.cwd, timeout: 30_000 });\n194\t    } catch { // IGNORE: git reset failed after test failure — escalate on corrupted git state\n195\t      return {\n196\t        resolved: false,\n197\t        attempts: attempt,\n198\t        escalated: true,\n199\t        escalationMessage: buildEscalationMessage(ctx),\n200\t      };\n201\t    }\n202\t  }\n203\t\n204\t  // All attempts exhausted — escalate\n205\t  return {\n206\t    resolved: false,\n207\t    attempts: MAX_ATTEMPTS,\n208\t    escalated: true,\n209\t    escalationMessage: buildEscalationMessage(ctx),\n210\t  };\n211\t}\n212\t"}]},"parent_tool_use_id":"toolu_01KN13KxQzTPDh38EUNUPmae","session_id":"22206bba-5847-41b1-b510-883e1dd8c0da","uuid":"85ecbaba-0096-44db-b9e2-c680ae22f205","timestamp":"2026-04-03T22:22:24.119Z"}
