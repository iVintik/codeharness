{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M1BAoqVSrTsVkhsugXQ8b3","type":"tool_result","content":"1\timport { existsSync } from 'node:fs';\n2\timport { join } from 'node:path';\n3\timport { Command } from 'commander';\n4\timport { fail, info, ok } from '../lib/output.js';\n5\timport { isDockerAvailable } from '../lib/docker/index.js';\n6\timport { cleanupContainers } from '../modules/infra/index.js';\n7\timport { getSprintState, readSprintStatusFromState, reconcileState } from '../modules/sprint/index.js';\n8\timport { countStories, formatElapsed } from '../lib/run-helpers.js';\n9\timport { parseWorkflow, resolveWorkflow } from '../lib/workflow-parser.js';\n10\timport { resolveAgent, compileSubagentDefinition } from '../lib/agent-resolver.js';\n11\timport { executeWorkflow } from '../lib/workflow-engine.js';\n12\timport { readWorkflowState, writeWorkflowState } from '../lib/workflow-state.js';\n13\timport { WorktreeManager } from '../lib/worktree-manager.js';\n14\timport { LanePool } from '../lib/lane-pool.js';\n15\timport type { EpicDescriptor, ExecuteEpicFn, LaneEvent } from '../lib/lane-pool.js';\n16\timport type { EngineConfig } from '../lib/workflow-engine.js';\n17\timport type { SubagentDefinition } from '../lib/agent-resolver.js';\n18\timport type { SprintState } from '../types/state.js';\n19\t\n20\t/** Resolves the plugin directory path (.claude/ in project root). */\n21\texport function resolvePluginDir(): string {\n22\t  return join(process.cwd(), '.claude');\n23\t}\n24\t\n25\t// Re-export helpers that tests import from run.ts\n26\texport { countStories } from '../lib/run-helpers.js';\n27\t\n28\t/**\n29\t * Extract the epic ID from a story key.\n30\t * Story keys follow the pattern `{epicId}-{storyNum}-{slug}`,\n31\t * e.g. `17-1-foo` -> epic `17`, `17-2-bar` -> epic `17`.\n32\t */\n33\texport function extractEpicId(storyKey: string): string {\n34\t  const match = storyKey.match(/^(\\d+)-/);\n35\t  return match ? match[1] : storyKey;\n36\t}\n37\t\n38\t/**\n39\t * Build EpicDescriptor[] from sprint state.\n40\t * Groups stories by epic ID, filters out epics with status 'done',\n41\t * and returns descriptors sorted by epic ID.\n42\t */\n43\texport function buildEpicDescriptors(state: SprintState): EpicDescriptor[] {\n44\t  const epicMap = new Map<string, string[]>();\n45\t  for (const storyKey of Object.keys(state.stories)) {\n46\t    const epicId = extractEpicId(storyKey);\n47\t    if (!epicMap.has(epicId)) epicMap.set(epicId, []);\n48\t    epicMap.get(epicId)!.push(storyKey);\n49\t  }\n50\t\n51\t  return [...epicMap.entries()]\n52\t    .filter(([epicId]) => {\n53\t      const epicState = state.epics[`epic-${epicId}`];\n54\t      return !epicState || epicState.status !== 'done';\n55\t    })\n56\t    .map(([epicId, stories]) => ({\n57\t      id: epicId,\n58\t      slug: `epic-${epicId}`,\n59\t      stories,\n60\t    }));\n61\t}\n62\t\n63\texport function registerRunCommand(program: Command): void {\n64\t  program\n65\t    .command('run')\n66\t    .description('Execute the autonomous coding loop')\n67\t    .option('--max-iterations <n>', 'Maximum loop iterations', '50')\n68\t    .option('--timeout <seconds>', 'Total loop timeout in seconds', '43200')\n69\t    .option('--iteration-timeout <minutes>', 'Per-iteration timeout in minutes', '30')\n70\t    .option('--quiet', 'Suppress terminal output (background mode)', false)\n71\t    .option('--calls <n>', 'Max API calls per hour', '100')\n72\t    .option('--max-story-retries <n>', 'Max retries per story before flagging', '10')\n73\t    .option('--reset', 'Clear retry counters, flagged stories, and circuit breaker before starting', false)\n74\t    .option('--resume', 'Resume from last checkpoint (engine resumes by default)', false)\n75\t    .option('--workflow <name>', 'Workflow name to load (default: \"default\")')\n76\t    .action(async (options, cmd) => {\n77\t      const globalOpts = cmd.optsWithGlobals();\n78\t      const isJson = !!globalOpts.json;\n79\t      const outputOpts = { json: isJson };\n80\t\n81\t      // 1. Resolve plugin directory\n82\t      const pluginDir = resolvePluginDir();\n83\t      if (!existsSync(pluginDir)) {\n84\t        fail('Plugin directory not found — run codeharness init first', outputOpts);\n85\t        process.exitCode = 1;\n86\t        return;\n87\t      }\n88\t\n89\t      // 1b. Reconcile state (best-effort — failures warn but don't abort)\n90\t      const reconciliation = reconcileState();\n91\t      if (reconciliation.success && reconciliation.data.corrections.length > 0) {\n92\t        for (const correction of reconciliation.data.corrections) {\n93\t          info(`[INFO] Reconciled: ${correction}`, outputOpts);\n94\t        }\n95\t      } else if (!reconciliation.success) {\n96\t        info(`[WARN] State reconciliation failed: ${reconciliation.error}`, outputOpts);\n97\t      }\n98\t\n99\t      // 1c. Docker pre-flight: fail fast if Docker unavailable\n100\t      if (!isDockerAvailable()) {\n101\t        fail('[FAIL] Docker not available — install Docker or start the daemon', outputOpts);\n102\t        process.exitCode = 1;\n103\t        return;\n104\t      }\n105\t      // 1d. Orphan container cleanup (best-effort — failures warn but don't abort)\n106\t      const cleanup = cleanupContainers();\n107\t      if (cleanup.success && cleanup.data.containersRemoved > 0) {\n108\t        info(`[INFO] Cleaned up ${cleanup.data.containersRemoved} orphaned container(s): ${cleanup.data.names.join(', ')}`, outputOpts);\n109\t      } else if (!cleanup.success) {\n110\t        info(`[WARN] Container cleanup failed: ${cleanup.error}`, outputOpts);\n111\t      }\n112\t      // 2. Read sprint status for story count (from sprint-state.json)\n113\t      const statuses = readSprintStatusFromState();\n114\t      const counts = countStories(statuses);\n115\t\n116\t      if (counts.total === 0) {\n117\t        fail('No stories found in sprint-state.json — nothing to execute', outputOpts);\n118\t        process.exitCode = 1;\n119\t        return;\n120\t      }\n121\t\n122\t      if (counts.ready === 0) {\n123\t        fail('No stories ready for execution', outputOpts);\n124\t        process.exitCode = 1;\n125\t        return;\n126\t      }\n127\t\n128\t      info(`Starting autonomous execution — ${counts.ready} ready, ${counts.inProgress} in progress, ${counts.verified} verified, ${counts.done}/${counts.total} done`, outputOpts);\n129\t      // 3. Parse and validate numeric options\n130\t      const maxIterations = parseInt(options.maxIterations, 10);\n131\t      const timeout = parseInt(options.timeout, 10);\n132\t      const iterationTimeout = parseInt(options.iterationTimeout, 10);\n133\t      const calls = parseInt(options.calls, 10);\n134\t      const maxStoryRetries = parseInt(options.maxStoryRetries, 10);\n135\t      if (isNaN(maxIterations) || isNaN(timeout) || isNaN(iterationTimeout) || isNaN(calls) || isNaN(maxStoryRetries)) {\n136\t        fail('Invalid numeric option — --max-iterations, --timeout, --iteration-timeout, --calls, and --max-story-retries must be numbers', outputOpts);\n137\t        process.exitCode = 1;\n138\t        return;\n139\t      }\n140\t\n141\t      // 4. Resolve workflow (embedded -> user patch -> project patch)\n142\t      const projectDir = process.cwd();\n143\t      const workflowName = options.workflow ?? 'default';\n144\t\n145\t      // Validate workflow name: only alphanumeric, hyphens, underscores allowed\n146\t      if (!/^[a-zA-Z0-9_-]+$/.test(workflowName)) {\n147\t        fail(`Invalid workflow name \"${workflowName}\" — only alphanumeric characters, hyphens, and underscores are allowed`, outputOpts);\n148\t        process.exitCode = 1;\n149\t        return;\n150\t      }\n151\t\n152\t      let parsedWorkflow;\n153\t      try {\n154\t        parsedWorkflow = resolveWorkflow({ cwd: projectDir, name: workflowName });\n155\t      } catch (err: unknown) {\n156\t        // Fallback: try direct file parsing for backward compatibility (only for default)\n157\t        if (workflowName !== 'default') {\n158\t          const msg = err instanceof Error ? err.message : String(err);\n159\t          fail(`Failed to resolve workflow: ${msg}`, outputOpts);\n160\t          process.exitCode = 1;\n161\t          return;\n162\t        }\n163\t        const projectWorkflowPath = join(projectDir, '.codeharness', 'workflows', 'default.yaml');\n164\t        const templateWorkflowPath = join(projectDir, 'templates', 'workflows', 'default.yaml');\n165\t        const workflowPath = existsSync(projectWorkflowPath) ? projectWorkflowPath : templateWorkflowPath;\n166\t        try {\n167\t          parsedWorkflow = parseWorkflow(workflowPath);\n168\t        } catch (fallbackErr: unknown) {\n169\t          const msg = fallbackErr instanceof Error ? fallbackErr.message : String(fallbackErr);\n170\t          fail(`Failed to resolve workflow: ${msg}`, outputOpts);\n171\t          process.exitCode = 1;\n172\t          return;\n173\t        }\n174\t      }\n175\t\n176\t      // 5. Resolve agents referenced in workflow\n177\t      const agents: Record<string, SubagentDefinition> = {};\n178\t      try {\n179\t        for (const [, task] of Object.entries(parsedWorkflow.tasks)) {\n180\t          if (task.agent != null && !agents[task.agent]) {\n181\t            const resolved = resolveAgent(task.agent, { cwd: projectDir });\n182\t            agents[task.agent] = compileSubagentDefinition(resolved);\n183\t          }\n184\t        }\n185\t      } catch (err: unknown) {\n186\t        const msg = err instanceof Error ? err.message : String(err);\n187\t        fail(`Failed to resolve agents: ${msg}`, outputOpts);\n188\t        process.exitCode = 1;\n189\t        return;\n190\t      }\n191\t\n192\t      // 6. Handle --resume: reset completed or circuit-breaker state so the engine re-enters execution\n193\t      if (options.resume) {\n194\t        const currentState = readWorkflowState(projectDir);\n195\t        if (currentState.phase === 'completed') {\n196\t          writeWorkflowState({ ...currentState, phase: 'idle' }, projectDir);\n197\t          info('Resuming from completed state — phase reset to idle', outputOpts);\n198\t        } else if (currentState.phase === 'circuit-breaker') {\n199\t          writeWorkflowState({\n200\t            ...currentState,\n201\t            phase: 'idle',\n202\t            circuit_breaker: {\n203\t              ...currentState.circuit_breaker,\n204\t              triggered: false,\n205\t              reason: null,\n206\t              // score_history is PRESERVED\n207\t            },\n208\t          }, projectDir);\n209\t          info('Resuming after circuit breaker — previous findings preserved', outputOpts);\n210\t        }\n211\t      }\n212\t\n213\t      // 7. Build EngineConfig and execute\n214\t      const config: EngineConfig = {\n215\t        workflow: parsedWorkflow,\n216\t        agents,\n217\t        sprintStatusPath: join(projectDir, '_bmad-output', 'implementation-artifacts', 'sprint-status.yaml'),\n218\t        issuesPath: join(projectDir, '.codeharness', 'issues.yaml'),\n219\t        runId: `run-${Date.now()}`,\n220\t        projectDir,\n221\t        maxIterations,\n222\t      };\n223\t\n224\t      // 8. Branch: parallel vs sequential execution\n225\t      const execution = parsedWorkflow.execution;\n226\t      const isParallel = execution?.epic_strategy === 'parallel';\n227\t\n228\t      if (isParallel) {\n229\t        // --- Parallel execution path (AC #1, #2, #4, #5, #9, #12) ---\n230\t        try {\n231\t          const maxParallel = execution.max_parallel ?? 1;\n232\t\n233\t          // Get sprint state for epic discovery (AC #3)\n234\t          const stateResult = getSprintState();\n235\t          if (!stateResult.success) {\n236\t            fail(`Failed to read sprint state for epic discovery: ${stateResult.error}`, outputOpts);\n237\t            process.exitCode = 1;\n238\t            return;\n239\t          }\n240\t\n241\t          const epics = buildEpicDescriptors(stateResult.data);\n242\t          if (epics.length === 0) {\n243\t            info('No pending epics found — nothing to execute in parallel mode', outputOpts);\n244\t            return;\n245\t          }\n246\t\n247\t          // Create worktree manager and lane pool (AC #2, #12)\n248\t          // Parallel mode always uses worktree isolation regardless of execution.isolation\n249\t          const worktreeManager = new WorktreeManager();\n250\t          const pool = new LanePool(worktreeManager, maxParallel);\n251\t\n252\t          // Register lane event logging (AC #10)\n253\t          pool.onEvent((event: LaneEvent) => {\n254\t            switch (event.type) {\n255\t              case 'lane-started':\n256\t                info(`[LANE] Started epic ${event.epicId} in lane ${event.laneIndex}`, outputOpts);\n257\t                break;\n258\t              case 'lane-completed':\n259\t                ok(`[LANE] Epic ${event.epicId} completed in lane ${event.laneIndex}`, outputOpts);\n260\t                break;\n261\t              case 'lane-failed':\n262\t                fail(`[LANE] Epic ${event.epicId} failed in lane ${event.laneIndex}: ${event.error}`, outputOpts);\n263\t                break;\n264\t              case 'epic-queued':\n265\t                info(`[LANE] Epic ${event.epicId} queued for execution`, outputOpts);\n266\t                break;\n267\t            }\n268\t          });\n269\t\n270\t          // Define executeFn: runs engine in worktree (AC #4, #5)\n271\t          const executeFn: ExecuteEpicFn = async (_epicId: string, worktreePath: string) => {\n272\t            const epicConfig: EngineConfig = {\n273\t              ...config,\n274\t              projectDir: worktreePath,\n275\t            };\n276\t            return executeWorkflow(epicConfig);\n277\t          };\n278\t\n279\t          // Start the pool (AC #9: max_parallel=1 still runs through pool)\n280\t          const poolResult = await pool.startPool(epics, executeFn);\n281\t\n282\t          // Safety net: check for remaining worktrees (AC #11)\n283\t          const remainingWorktrees = worktreeManager.listWorktrees();\n284\t          if (remainingWorktrees.length > 0) {\n285\t            info(`[WARN] ${remainingWorktrees.length} worktree(s) still exist after pool completion`, outputOpts);\n286\t            for (const wt of remainingWorktrees) {\n287\t              info(`  - ${wt.path} (epic ${wt.epicId})`, outputOpts);\n288\t            }\n289\t          }\n290\t\n291\t          // Report results (AC #7)\n292\t          let totalStories = 0;\n293\t          for (const [, epicResult] of poolResult.epicResults) {\n294\t            if (epicResult.engineResult) {\n295\t              totalStories += epicResult.engineResult.storiesProcessed;\n296\t            }\n297\t          }\n298\t\n299\t          const succeeded = [...poolResult.epicResults.values()].filter(r => r.status === 'completed').length;\n300\t          const failed = [...poolResult.epicResults.values()].filter(r => r.status === 'failed').length;\n301\t\n302\t          if (poolResult.success) {\n303\t            ok(`Parallel execution completed — ${poolResult.epicsProcessed} epics (${succeeded} succeeded), ${totalStories} stories processed in ${formatElapsed(poolResult.durationMs)}`, outputOpts);\n304\t          } else {\n305\t            fail(`Parallel execution failed — ${poolResult.epicsProcessed} epics (${succeeded} succeeded, ${failed} failed), ${totalStories} stories processed in ${formatElapsed(poolResult.durationMs)}`, outputOpts);\n306\t            for (const [epicId, epicResult] of poolResult.epicResults) {\n307\t              if (epicResult.status === 'failed') {\n308\t                info(`  Epic ${epicId}: ${epicResult.error}`, outputOpts);\n309\t              }\n310\t            }\n311\t            process.exitCode = 1;\n312\t          }\n313\t        } catch (err: unknown) {\n314\t          const msg = err instanceof Error ? err.message : String(err);\n315\t          fail(`Parallel execution error: ${msg}`, outputOpts);\n316\t          process.exitCode = 1;\n317\t        }\n318\t      } else {\n319\t        // --- Sequential execution path (AC #8) — existing single-engine behavior ---\n320\t        try {\n321\t          const result = await executeWorkflow(config);\n322\t\n323\t          if (result.success) {\n324\t            ok(`Workflow completed — ${result.storiesProcessed} stories processed, ${result.tasksCompleted} tasks completed in ${formatElapsed(result.durationMs)}`, outputOpts);\n325\t          } else {\n326\t            fail(`Workflow failed — ${result.storiesProcessed} stories processed, ${result.tasksCompleted} tasks completed, ${result.errors.length} error(s) in ${formatElapsed(result.durationMs)}`, outputOpts);\n327\t            for (const err of result.errors) {\n328\t              info(`  ${err.taskName}/${err.storyKey}: [${err.code}] ${err.message}`, outputOpts);\n329\t            }\n330\t            process.exitCode = 1;\n331\t          }\n332\t        } catch (err: unknown) {\n333\t          const msg = err instanceof Error ? err.message : String(err);\n334\t          fail(`Workflow engine error: ${msg}`, outputOpts);\n335\t          process.exitCode = 1;\n336\t        }\n337\t      }\n338\t    });\n339\t}\n340\t"}]},"parent_tool_use_id":"toolu_01KrDuJXvL9iMGiH4fKqNTEw","session_id":"1e0d780f-040f-4c10-b8e5-df49ae6fae2c","uuid":"b21698b5-90f4-4ad8-a4a3-55b7a0a8f839","timestamp":"2026-04-03T20:57:40.596Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EbCX4vM5PwQsbCGdowTzPJ","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';\n2\timport { Command } from 'commander';\n3\timport { extractEpicId, buildEpicDescriptors } from '../run.js';\n4\timport type { SprintState } from '../../types/state.js';\n5\t\n6\t// --- Hoisted mocks ---\n7\t// Mutable references so mockPoolAndWorktree can swap implementations at test time\n8\tlet _poolFactory: () => Record<string, unknown>;\n9\tlet _wtFactory: () => Record<string, unknown>;\n10\t// Track constructor calls for assertions\n11\tlet _lanePoolConstructed = false;\n12\tlet _lanePoolConstructorArgs: unknown[] = [];\n13\tlet _worktreeManagerConstructed = false;\n14\t\n15\tconst {\n16\t  existsSyncMock, readSprintStatusMock, reconcileStateMock,\n17\t  isDockerAvailableMock, cleanupContainersMock,\n18\t  resolveWorkflowMock, resolveAgentMock, compileSubagentMock,\n19\t  executeWorkflowMock,\n20\t  readWorkflowStateMock, writeWorkflowStateMock,\n21\t  getSprintStateMock,\n22\t  LanePoolClass, WorktreeManagerClass,\n23\t  realExistsSync,\n24\t} = vi.hoisted(() => {\n25\t  // eslint-disable-next-line @typescript-eslint/no-require-imports\n26\t  const fs = require('node:fs');\n27\t  const realFn = fs.existsSync.bind(fs);\n28\t\n29\t  // Class mocks that delegate to the mutable factories\n30\t  // eslint-disable-next-line @typescript-eslint/no-extraneous-class\n31\t  class LanePoolClass {\n32\t    constructor(...args: unknown[]) {\n33\t      // @ts-expect-error: module-scoped tracking variables\n34\t      _lanePoolConstructed = true;\n35\t      // @ts-expect-error: module-scoped tracking variables\n36\t      _lanePoolConstructorArgs = args;\n37\t      // @ts-expect-error: _poolFactory is module-scoped\n38\t      return _poolFactory();\n39\t    }\n40\t  }\n41\t  // eslint-disable-next-line @typescript-eslint/no-extraneous-class\n42\t  class WorktreeManagerClass {\n43\t    constructor(..._args: unknown[]) {\n44\t      // @ts-expect-error: module-scoped tracking variables\n45\t      _worktreeManagerConstructed = true;\n46\t      // @ts-expect-error: _wtFactory is module-scoped\n47\t      return _wtFactory();\n48\t    }\n49\t  }\n50\t\n51\t  return {\n52\t    existsSyncMock: vi.fn(realFn),\n53\t    readSprintStatusMock: vi.fn(() => ({}) as Record<string, string>),\n54\t    reconcileStateMock: vi.fn(() => ({ success: true, data: { corrections: [], stateChanged: false } })),\n55\t    isDockerAvailableMock: vi.fn(() => true),\n56\t    cleanupContainersMock: vi.fn(() => ({ success: true, data: { containersRemoved: 0, names: [] } })),\n57\t    resolveWorkflowMock: vi.fn(() => ({\n58\t      tasks: { implement: { agent: 'dev', scope: 'per-story', session: 'fresh', source_access: true } },\n59\t      flow: ['implement'],\n60\t      execution: { epic_strategy: 'sequential', max_parallel: 1, isolation: 'none', merge_strategy: 'merge-commit', story_strategy: 'sequential' },\n61\t      storyFlow: ['implement'],\n62\t      epicFlow: [],\n63\t    })),\n64\t    resolveAgentMock: vi.fn(() => ({\n65\t      name: 'dev',\n66\t      role: { title: 'Developer', purpose: 'Implement code' },\n67\t      persona: { identity: 'A developer', communication_style: 'direct', principles: [] },\n68\t    })),\n69\t    compileSubagentMock: vi.fn(() => ({\n70\t      name: 'dev',\n71\t      model: 'claude-sonnet-4-20250514',\n72\t      instructions: 'You are a developer',\n73\t      disallowedTools: [],\n74\t      bare: true,\n75\t    })),\n76\t    executeWorkflowMock: vi.fn(async () => ({\n77\t      success: true,\n78\t      tasksCompleted: 3,\n79\t      storiesProcessed: 1,\n80\t      errors: [],\n81\t      durationMs: 60000,\n82\t    })),\n83\t    readWorkflowStateMock: vi.fn(() => ({\n84\t      workflow_name: '',\n85\t      started: '',\n86\t      iteration: 0,\n87\t      phase: 'idle',\n88\t      tasks_completed: [],\n89\t      evaluator_scores: [],\n90\t      circuit_breaker: { triggered: false, reason: null, score_history: [] },\n91\t      trace_ids: [],\n92\t    })),\n93\t    writeWorkflowStateMock: vi.fn(),\n94\t    getSprintStateMock: vi.fn(() => ({ success: false, error: 'no state' })),\n95\t    LanePoolClass,\n96\t    WorktreeManagerClass,\n97\t    realExistsSync: realFn as (path: string) => boolean,\n98\t  };\n99\t});\n100\t\n101\tvi.mock('node:fs', async (importOriginal) => {\n102\t  const actual = await importOriginal<typeof import('node:fs')>();\n103\t  return { ...actual, existsSync: existsSyncMock };\n104\t});\n105\t\n106\tvi.mock('../../lib/ink-renderer.js', () => ({\n107\t  startRenderer: vi.fn(() => ({\n108\t    update: vi.fn(),\n109\t    updateSprintState: vi.fn(),\n110\t    updateStories: vi.fn(),\n111\t    addMessage: vi.fn(),\n112\t    cleanup: vi.fn(),\n113\t  })),\n114\t}));\n115\t\n116\tvi.mock('../../modules/sprint/index.js', () => ({\n117\t  getSprintState: (...args: unknown[]) => getSprintStateMock(...(args as [])),\n118\t  readSprintStatusFromState: (...args: unknown[]) => readSprintStatusMock(...(args as [])),\n119\t  reconcileState: (...args: unknown[]) => reconcileStateMock(...(args as [])),\n120\t  updateStoryStatus: vi.fn(() => ({ success: true, data: undefined })),\n121\t  shouldDeferPhase: vi.fn(() => false),\n122\t  getPhaseEstimate: vi.fn(() => 15),\n123\t  computeRemainingMinutes: vi.fn(() => 60),\n124\t}));\n125\t\n126\tvi.mock('../../lib/docker/index.js', () => ({\n127\t  isDockerAvailable: (...args: unknown[]) => isDockerAvailableMock(...(args as [])),\n128\t}));\n129\t\n130\tvi.mock('../../modules/infra/index.js', () => ({\n131\t  cleanupContainers: (...args: unknown[]) => cleanupContainersMock(...(args as [])),\n132\t}));\n133\t\n134\tvi.mock('../../lib/workflow-parser.js', () => ({\n135\t  parseWorkflow: vi.fn(),\n136\t  resolveWorkflow: (...args: unknown[]) => resolveWorkflowMock(...(args as [])),\n137\t}));\n138\t\n139\tvi.mock('../../lib/agent-resolver.js', () => ({\n140\t  resolveAgent: (...args: unknown[]) => resolveAgentMock(...(args as [])),\n141\t  compileSubagentDefinition: (...args: unknown[]) => compileSubagentMock(...(args as [])),\n142\t}));\n143\t\n144\tvi.mock('../../lib/workflow-engine.js', () => ({\n145\t  executeWorkflow: (...args: unknown[]) => executeWorkflowMock(...(args as [unknown])),\n146\t}));\n147\t\n148\tvi.mock('../../lib/workflow-state.js', () => ({\n149\t  readWorkflowState: (...args: unknown[]) => readWorkflowStateMock(...(args as [])),\n150\t  writeWorkflowState: (...args: unknown[]) => writeWorkflowStateMock(...(args as [])),\n151\t}));\n152\t\n153\tvi.mock('../../lib/worktree-manager.js', () => ({\n154\t  WorktreeManager: WorktreeManagerClass,\n155\t}));\n156\t\n157\tvi.mock('../../lib/lane-pool.js', () => ({\n158\t  LanePool: LanePoolClass,\n159\t}));\n160\t\n161\t\n162\t// --- Helper: minimal SprintState factory ---\n163\tfunction makeSprintState(overrides?: Partial<SprintState>): SprintState {\n164\t  return {\n165\t    version: 2,\n166\t    sprint: { total: 0, done: 0, failed: 0, blocked: 0, inProgress: null },\n167\t    stories: {},\n168\t    retries: {},\n169\t    flagged: [],\n170\t    epics: {},\n171\t    session: { active: false, startedAt: null, iteration: 0, elapsedSeconds: 0 },\n172\t    observability: { statementCoverage: null, branchCoverage: null, functionCoverage: null, lineCoverage: null },\n173\t    run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n174\t    actionItems: [],\n175\t    ...overrides,\n176\t  };\n177\t}\n178\t\n179\tconst defaultStory = { status: 'backlog' as const, attempts: 0, lastAttempt: null, lastError: null, proofPath: null, acResults: null };\n180\t\n181\t\n182\tdescribe('run command — parallel execution (Story 17.3)', () => {\n183\t  beforeEach(() => {\n184\t    existsSyncMock.mockReset();\n185\t    existsSyncMock.mockImplementation((p: unknown) => realExistsSync(String(p)));\n186\t    readSprintStatusMock.mockReset();\n187\t    readSprintStatusMock.mockReturnValue({});\n188\t    reconcileStateMock.mockReset();\n189\t    reconcileStateMock.mockReturnValue({ success: true, data: { corrections: [], stateChanged: false } });\n190\t    isDockerAvailableMock.mockReset();\n191\t    isDockerAvailableMock.mockReturnValue(true);\n192\t    cleanupContainersMock.mockReset();\n193\t    cleanupContainersMock.mockReturnValue({ success: true, data: { containersRemoved: 0, names: [] } });\n194\t    resolveWorkflowMock.mockReset();\n195\t    resolveAgentMock.mockReset();\n196\t    resolveAgentMock.mockReturnValue({\n197\t      name: 'dev', role: { title: 'Developer', purpose: 'Implement code' },\n198\t      persona: { identity: 'A developer', communication_style: 'direct', principles: [] },\n199\t    });\n200\t    compileSubagentMock.mockReset();\n201\t    compileSubagentMock.mockReturnValue({\n202\t      name: 'dev', model: 'claude-sonnet-4-20250514', instructions: 'You are a developer', disallowedTools: [], bare: true,\n203\t    });\n204\t    executeWorkflowMock.mockReset();\n205\t    executeWorkflowMock.mockResolvedValue({ success: true, tasksCompleted: 3, storiesProcessed: 1, errors: [], durationMs: 60000 });\n206\t    readWorkflowStateMock.mockReset();\n207\t    readWorkflowStateMock.mockReturnValue({\n208\t      workflow_name: '', started: '', iteration: 0, phase: 'idle',\n209\t      tasks_completed: [], evaluator_scores: [],\n210\t      circuit_breaker: { triggered: false, reason: null, score_history: [] },\n211\t      trace_ids: [],\n212\t    });\n213\t    writeWorkflowStateMock.mockReset();\n214\t    getSprintStateMock.mockReset();\n215\t    // Reset tracking variables\n216\t    _lanePoolConstructed = false;\n217\t    _lanePoolConstructorArgs = [];\n218\t    _worktreeManagerConstructed = false;\n219\t    // Reset pool/worktree factories to defaults\n220\t    _poolFactory = () => ({\n221\t      onEvent: vi.fn(),\n222\t      startPool: vi.fn().mockResolvedValue({\n223\t        success: true, epicsProcessed: 0, epicResults: new Map(), durationMs: 0,\n224\t      }),\n225\t    });\n226\t    _wtFactory = () => ({\n227\t      createWorktree: vi.fn(() => '/tmp/codeharness-wt-epic-1'),\n228\t      cleanupWorktree: vi.fn(),\n229\t      listWorktrees: vi.fn(() => []),\n230\t      detectOrphans: vi.fn(() => []),\n231\t    });\n232\t    process.exitCode = undefined;\n233\t  });\n234\t\n235\t  afterEach(() => {\n236\t    vi.restoreAllMocks();\n237\t    process.exitCode = undefined;\n238\t  });\n239\t\n240\t  function mockPaths(overrides: Record<string, boolean>) {\n241\t    existsSyncMock.mockImplementation((p: unknown) => {\n242\t      const path = String(p);\n243\t      for (const [pattern, value] of Object.entries(overrides)) {\n244\t        if (path.includes(pattern)) return value;\n245\t      }\n246\t      return realExistsSync(path);\n247\t    });\n248\t  }\n249\t\n250\t  function mockParallelWorkflow(maxParallel = 2) {\n251\t    resolveWorkflowMock.mockReturnValue({\n252\t      tasks: { implement: { agent: 'dev', scope: 'per-story', session: 'fresh', source_access: true } },\n253\t      flow: ['implement'],\n254\t      execution: { epic_strategy: 'parallel', max_parallel: maxParallel, isolation: 'none', merge_strategy: 'merge-commit', story_strategy: 'sequential' },\n255\t      storyFlow: ['implement'],\n256\t      epicFlow: [],\n257\t    });\n258\t  }\n259\t\n260\t  function mockSequentialWorkflow() {\n261\t    resolveWorkflowMock.mockReturnValue({\n262\t      tasks: { implement: { agent: 'dev', scope: 'per-story', session: 'fresh', source_access: true } },\n263\t      flow: ['implement'],\n264\t      execution: { epic_strategy: 'sequential', max_parallel: 1, isolation: 'none', merge_strategy: 'merge-commit', story_strategy: 'sequential' },\n265\t      storyFlow: ['implement'],\n266\t      epicFlow: [],\n267\t    });\n268\t  }\n269\t\n270\t  function mockPoolAndWorktree(poolOverrides?: Record<string, unknown>, wtOverrides?: Record<string, unknown>) {\n271\t    const poolInstance: Record<string, unknown> = {\n272\t      onEvent: vi.fn(),\n273\t      startPool: vi.fn().mockResolvedValue({\n274\t        success: true, epicsProcessed: 1,\n275\t        epicResults: new Map([['1', { epicId: '1', status: 'completed', engineResult: { success: true, tasksCompleted: 1, storiesProcessed: 1, errors: [], durationMs: 1000 }, durationMs: 1000 }]]),\n276\t        durationMs: 1000,\n277\t      }),\n278\t      ...poolOverrides,\n279\t    };\n280\t    const wtInstance: Record<string, unknown> = {\n281\t      createWorktree: vi.fn(() => '/tmp/codeharness-wt-epic-1'),\n282\t      cleanupWorktree: vi.fn(),\n283\t      listWorktrees: vi.fn(() => []),\n284\t      detectOrphans: vi.fn(() => []),\n285\t      ...wtOverrides,\n286\t    };\n287\t    _poolFactory = () => poolInstance;\n288\t    _wtFactory = () => wtInstance;\n289\t    return { poolInstance, wtInstance };\n290\t  }\n291\t\n292\t  async function runCommand(args: string[] = []) {\n293\t    const { registerRunCommand } = await import('../run.js');\n294\t    const program = new Command();\n295\t    program.exitOverride();\n296\t    program.option('--json', 'JSON output');\n297\t    registerRunCommand(program);\n298\t    await program.parseAsync(['node', 'codeharness', 'run', ...args]);\n299\t  }\n300\t\n301\t\n302\t  // --- extractEpicId unit tests ---\n303\t\n304\t  describe('extractEpicId', () => {\n305\t    it('extracts numeric epic prefix from story key', () => {\n306\t      expect(extractEpicId('17-1-foo')).toBe('17');\n307\t      expect(extractEpicId('3-2-bar-baz')).toBe('3');\n308\t      expect(extractEpicId('100-5-long-slug')).toBe('100');\n309\t    });\n310\t\n311\t    it('returns full key if no numeric prefix', () => {\n312\t      expect(extractEpicId('nonnumeric')).toBe('nonnumeric');\n313\t    });\n314\t  });\n315\t\n316\t\n317\t  // --- buildEpicDescriptors unit tests ---\n318\t\n319\t  describe('buildEpicDescriptors', () => {\n320\t    it('groups stories by epic ID (AC #3)', () => {\n321\t      const state = makeSprintState({\n322\t        stories: {\n323\t          '17-1-worktree': { ...defaultStory },\n324\t          '17-2-lane-pool': { ...defaultStory },\n325\t          '18-1-merge': { ...defaultStory },\n326\t        },\n327\t        epics: {},\n328\t      });\n329\t      const descriptors = buildEpicDescriptors(state);\n330\t      expect(descriptors).toHaveLength(2);\n331\t      const epic17 = descriptors.find(d => d.id === '17');\n332\t      expect(epic17).toBeDefined();\n333\t      expect(epic17!.stories).toEqual(['17-1-worktree', '17-2-lane-pool']);\n334\t      expect(epic17!.slug).toBe('epic-17');\n335\t    });\n336\t\n337\t    it('filters out epics with done status (AC #3)', () => {\n338\t      const state = makeSprintState({\n339\t        stories: {\n340\t          '17-1-foo': { ...defaultStory },\n341\t          '18-1-bar': { ...defaultStory },\n342\t        },\n343\t        epics: {\n344\t          'epic-17': { status: 'done', storiesTotal: 1, storiesDone: 1 },\n345\t          'epic-18': { status: 'in-progress', storiesTotal: 1, storiesDone: 0 },\n346\t        },\n347\t      });\n348\t      const descriptors = buildEpicDescriptors(state);\n349\t      expect(descriptors).toHaveLength(1);\n350\t      expect(descriptors[0].id).toBe('18');\n351\t    });\n352\t\n353\t    it('returns empty array when all epics are done', () => {\n354\t      const state = makeSprintState({\n355\t        stories: { '17-1-foo': { ...defaultStory } },\n356\t        epics: { 'epic-17': { status: 'done', storiesTotal: 1, storiesDone: 1 } },\n357\t      });\n358\t      expect(buildEpicDescriptors(state)).toEqual([]);\n359\t    });\n360\t\n361\t    it('includes epics not present in epics map (assumes not done)', () => {\n362\t      const state = makeSprintState({\n363\t        stories: { '99-1-new': { ...defaultStory } },\n364\t        epics: {},\n365\t      });\n366\t      const descriptors = buildEpicDescriptors(state);\n367\t      expect(descriptors).toHaveLength(1);\n368\t      expect(descriptors[0].id).toBe('99');\n369\t    });\n370\t  });\n371\t\n372\t\n373\t  // --- Parallel execution path tests ---\n374\t\n375\t  describe('parallel mode detection (AC #1, #8)', () => {\n376\t    it('detects parallel mode when epic_strategy is parallel', async () => {\n377\t      mockPaths({ '.claude': true });\n378\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n379\t      mockParallelWorkflow(2);\n380\t      getSprintStateMock.mockReturnValue({\n381\t        success: true,\n382\t        data: makeSprintState({\n383\t          stories: { '1-1-story': { ...defaultStory } },\n384\t        }),\n385\t      });\n386\t\n387\t      const { poolInstance } = mockPoolAndWorktree();\n388\t      vi.spyOn(console, 'log').mockImplementation(() => {});\n389\t\n390\t      await runCommand();\n391\t\n392\t      expect(_lanePoolConstructed).toBe(true);\n393\t      expect(_worktreeManagerConstructed).toBe(true);\n394\t      expect(poolInstance.startPool).toHaveBeenCalled();\n395\t      // executeWorkflow should NOT be called directly in parallel mode\n396\t      expect(executeWorkflowMock).not.toHaveBeenCalled();\n397\t    });\n398\t\n399\t    it('uses sequential path when epic_strategy is sequential (AC #8)', async () => {\n400\t      mockPaths({ '.claude': true });\n401\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n402\t      mockSequentialWorkflow();\n403\t      vi.spyOn(console, 'log').mockImplementation(() => {});\n404\t\n405\t      await runCommand();\n406\t\n407\t      expect(_lanePoolConstructed).toBe(false);\n408\t      expect(_worktreeManagerConstructed).toBe(false);\n409\t      expect(executeWorkflowMock).toHaveBeenCalled();\n410\t    });\n411\t\n412\t    it('uses sequential path when no execution config present (AC #8)', async () => {\n413\t      mockPaths({ '.claude': true });\n414\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n415\t      resolveWorkflowMock.mockReturnValue({\n416\t        tasks: { implement: { agent: 'dev', scope: 'per-story', session: 'fresh', source_access: true } },\n417\t        flow: ['implement'],\n418\t        // No execution field\n419\t      });\n420\t      vi.spyOn(console, 'log').mockImplementation(() => {});\n421\t\n422\t      await runCommand();\n423\t\n424\t      expect(_lanePoolConstructed).toBe(false);\n425\t      expect(executeWorkflowMock).toHaveBeenCalled();\n426\t    });\n427\t  });\n428\t\n429\t  describe('LanePool created with correct config (AC #2)', () => {\n430\t    it('creates LanePool with maxParallel from execution config', async () => {\n431\t      mockPaths({ '.claude': true });\n432\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n433\t      mockParallelWorkflow(3);\n434\t      getSprintStateMock.mockReturnValue({\n435\t        success: true,\n436\t        data: makeSprintState({ stories: { '1-1-story': { ...defaultStory } } }),\n437\t      });\n438\t\n439\t      mockPoolAndWorktree();\n440\t      vi.spyOn(console, 'log').mockImplementation(() => {});\n441\t\n442\t      await runCommand();\n443\t\n444\t      expect(_lanePoolConstructorArgs[1]).toBe(3);\n445\t    });\n446\t  });\n447\t\n448\t  describe('executeFn sets projectDir to worktree path (AC #4, #5)', () => {\n449\t    it('passes worktree path as projectDir in EngineConfig', async () => {\n450\t      mockPaths({ '.claude': true });\n451\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n452\t      mockParallelWorkflow(2);\n453\t      getSprintStateMock.mockReturnValue({\n454\t        success: true,\n455\t        data: makeSprintState({ stories: { '1-1-story': { ...defaultStory } } }),\n456\t      });\n457\t\n458\t      let capturedExecuteFn: ((epicId: string, worktreePath: string) => Promise<unknown>) | undefined;\n459\t      mockPoolAndWorktree({\n460\t        startPool: vi.fn().mockImplementation((epics: unknown[], executeFn: (epicId: string, path: string) => Promise<unknown>) => {\n461\t          capturedExecuteFn = executeFn;\n462\t          return Promise.resolve({\n463\t            success: true, epicsProcessed: 1,\n464\t            epicResults: new Map([['1', { epicId: '1', status: 'completed', engineResult: { success: true, tasksCompleted: 1, storiesProcessed: 1, errors: [], durationMs: 1000 }, durationMs: 1000 }]]),\n465\t            durationMs: 1000,\n466\t          });\n467\t        }),\n468\t      });\n469\t      vi.spyOn(console, 'log').mockImplementation(() => {});\n470\t\n471\t      await runCommand();\n472\t\n473\t      expect(capturedExecuteFn).toBeDefined();\n474\t      // Call executeFn to verify it sets projectDir\n475\t      await capturedExecuteFn!('1', '/tmp/codeharness-wt-epic-1');\n476\t      expect(executeWorkflowMock).toHaveBeenCalledWith(\n477\t        expect.objectContaining({ projectDir: '/tmp/codeharness-wt-epic-1' }),\n478\t      );\n479\t    });\n480\t  });\n481\t\n482\t  describe('pool result maps to correct exit code (AC #7)', () => {\n483\t    it('exits 0 when pool succeeds', async () => {\n484\t      mockPaths({ '.claude': true });\n485\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n486\t      mockParallelWorkflow(2);\n487\t      getSprintStateMock.mockReturnValue({\n488\t        success: true,\n489\t        data: makeSprintState({ stories: { '1-1-story': { ...defaultStory } } }),\n490\t      });\n491\t\n492\t      mockPoolAndWorktree({\n493\t        startPool: vi.fn().mockResolvedValue({\n494\t          success: true, epicsProcessed: 2,\n495\t          epicResults: new Map([\n496\t            ['1', { epicId: '1', status: 'completed', engineResult: { success: true, tasksCompleted: 2, storiesProcessed: 1, errors: [], durationMs: 1000 }, durationMs: 1000 }],\n497\t            ['2', { epicId: '2', status: 'completed', engineResult: { success: true, tasksCompleted: 1, storiesProcessed: 1, errors: [], durationMs: 2000 }, durationMs: 2000 }],\n498\t          ]),\n499\t          durationMs: 3000,\n500\t        }),\n501\t      });\n502\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n503\t\n504\t      await runCommand();\n505\t\n506\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Parallel execution completed'));\n507\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('2 epics'));\n508\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('2 stories processed'));\n509\t      expect(process.exitCode).toBeUndefined();\n510\t    });\n511\t\n512\t    it('exits 1 when pool fails (AC #7)', async () => {\n513\t      mockPaths({ '.claude': true });\n514\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n515\t      mockParallelWorkflow(2);\n516\t      getSprintStateMock.mockReturnValue({\n517\t        success: true,\n518\t        data: makeSprintState({ stories: { '1-1-story': { ...defaultStory } } }),\n519\t      });\n520\t\n521\t      mockPoolAndWorktree({\n522\t        startPool: vi.fn().mockResolvedValue({\n523\t          success: false, epicsProcessed: 2,\n524\t          epicResults: new Map([\n525\t            ['1', { epicId: '1', status: 'completed', engineResult: { success: true, tasksCompleted: 2, storiesProcessed: 1, errors: [], durationMs: 1000 }, durationMs: 1000 }],\n526\t            ['2', { epicId: '2', status: 'failed', error: 'Engine crashed', durationMs: 500 }],\n527\t          ]),\n528\t          durationMs: 2000,\n529\t        }),\n530\t      });\n531\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n532\t\n533\t      await runCommand();\n534\t\n535\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Parallel execution failed'));\n536\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('1 failed'));\n537\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Epic 2: Engine crashed'));\n538\t      expect(process.exitCode).toBe(1);\n539\t    });\n540\t  });\n541\t\n542\t  describe('lane events are logged (AC #10)', () => {\n543\t    it('registers onEvent callback for lane event logging', async () => {\n544\t      mockPaths({ '.claude': true });\n545\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n546\t      mockParallelWorkflow(2);\n547\t      getSprintStateMock.mockReturnValue({\n548\t        success: true,\n549\t        data: makeSprintState({ stories: { '1-1-story': { ...defaultStory } } }),\n550\t      });\n551\t\n552\t      const { poolInstance } = mockPoolAndWorktree();\n553\t      vi.spyOn(console, 'log').mockImplementation(() => {});\n554\t\n555\t      await runCommand();\n556\t\n557\t      expect(poolInstance.onEvent).toHaveBeenCalledWith(expect.any(Function));\n558\t\n559\t      // Simulate lane events and verify console output\n560\t      const consoleSpy = vi.spyOn(console, 'log');\n561\t      const eventCallback = poolInstance.onEvent.mock.calls[0][0];\n562\t\n563\t      eventCallback({ type: 'lane-started', epicId: '17', laneIndex: 0, timestamp: new Date().toISOString() });\n564\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('[LANE] Started epic 17 in lane 0'));\n565\t\n566\t      eventCallback({ type: 'lane-completed', epicId: '17', laneIndex: 0, timestamp: new Date().toISOString() });\n567\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('[LANE] Epic 17 completed in lane 0'));\n568\t\n569\t      eventCallback({ type: 'lane-failed', epicId: '18', laneIndex: 1, timestamp: new Date().toISOString(), error: 'boom' });\n570\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('[LANE] Epic 18 failed in lane 1: boom'));\n571\t\n572\t      eventCallback({ type: 'epic-queued', epicId: '19', laneIndex: -1, timestamp: new Date().toISOString() });\n573\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('[LANE] Epic 19 queued for execution'));\n574\t    });\n575\t  });\n576\t\n577\t  describe('max_parallel=1 with parallel strategy (AC #9)', () => {\n578\t    it('creates lane pool with maxParallel=1 for sequential-through-pool execution', async () => {\n579\t      mockPaths({ '.claude': true });\n580\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n581\t      mockParallelWorkflow(1);\n582\t      getSprintStateMock.mockReturnValue({\n583\t        success: true,\n584\t        data: makeSprintState({ stories: { '1-1-story': { ...defaultStory } } }),\n585\t      });\n586\t\n587\t      const { poolInstance } = mockPoolAndWorktree();\n588\t      vi.spyOn(console, 'log').mockImplementation(() => {});\n589\t\n590\t      await runCommand();\n591\t\n592\t      expect(_lanePoolConstructorArgs[1]).toBe(1);\n593\t      expect(poolInstance.startPool).toHaveBeenCalled();\n594\t    });\n595\t  });\n596\t\n597\t  describe('parallel strategy forces worktree isolation (AC #12)', () => {\n598\t    it('creates WorktreeManager even when isolation is none', async () => {\n599\t      mockPaths({ '.claude': true });\n600\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n601\t      // isolation: 'none' but epic_strategy: 'parallel'\n602\t      resolveWorkflowMock.mockReturnValue({\n603\t        tasks: { implement: { agent: 'dev', scope: 'per-story', session: 'fresh', source_access: true } },\n604\t        flow: ['implement'],\n605\t        execution: { epic_strategy: 'parallel', max_parallel: 2, isolation: 'none', merge_strategy: 'merge-commit', story_strategy: 'sequential' },\n606\t        storyFlow: ['implement'],\n607\t        epicFlow: [],\n608\t      });\n609\t      getSprintStateMock.mockReturnValue({\n610\t        success: true,\n611\t        data: makeSprintState({ stories: { '1-1-story': { ...defaultStory } } }),\n612\t      });\n613\t\n614\t      mockPoolAndWorktree();\n615\t      vi.spyOn(console, 'log').mockImplementation(() => {});\n616\t\n617\t      await runCommand();\n618\t\n619\t      // WorktreeManager created regardless of isolation setting\n620\t      expect(_worktreeManagerConstructed).toBe(true);\n621\t      expect(_lanePoolConstructed).toBe(true);\n622\t    });\n623\t  });\n624\t\n625\t  describe('crash in one lane does not abort run (AC #6)', () => {\n626\t    it('handles pool that reports partial failure without crashing', async () => {\n627\t      mockPaths({ '.claude': true });\n628\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n629\t      mockParallelWorkflow(2);\n630\t      getSprintStateMock.mockReturnValue({\n631\t        success: true,\n632\t        data: makeSprintState({\n633\t          stories: {\n634\t            '1-1-story': { ...defaultStory },\n635\t            '2-1-other': { ...defaultStory },\n636\t          },\n637\t        }),\n638\t      });\n639\t\n640\t      mockPoolAndWorktree({\n641\t        startPool: vi.fn().mockResolvedValue({\n642\t          success: false, epicsProcessed: 2,\n643\t          epicResults: new Map([\n644\t            ['1', { epicId: '1', status: 'failed', error: 'Lane crashed', durationMs: 500 }],\n645\t            ['2', { epicId: '2', status: 'completed', engineResult: { success: true, tasksCompleted: 1, storiesProcessed: 1, errors: [], durationMs: 2000 }, durationMs: 2000 }],\n646\t          ]),\n647\t          durationMs: 2500,\n648\t        }),\n649\t      });\n650\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n651\t\n652\t      await runCommand();\n653\t\n654\t      // Both epics were processed — crash in one did not prevent the other\n655\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('2 epics'));\n656\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('1 succeeded'));\n657\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('1 failed'));\n658\t      expect(process.exitCode).toBe(1);\n659\t    });\n660\t  });\n661\t\n662\t  describe('remaining worktrees warned after pool completion (AC #11)', () => {\n663\t    it('warns when worktrees still exist after pool finishes', async () => {\n664\t      mockPaths({ '.claude': true });\n665\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n666\t      mockParallelWorkflow(2);\n667\t      getSprintStateMock.mockReturnValue({\n668\t        success: true,\n669\t        data: makeSprintState({ stories: { '1-1-story': { ...defaultStory } } }),\n670\t      });\n671\t\n672\t      mockPoolAndWorktree({}, {\n673\t        listWorktrees: vi.fn(() => [\n674\t          { epicId: '1', path: '/tmp/codeharness-wt-epic-1', branch: 'codeharness/epic-1-foo', createdAt: new Date() },\n675\t        ]),\n676\t      });\n677\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n678\t\n679\t      await runCommand();\n680\t\n681\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('1 worktree(s) still exist after pool completion'));\n682\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('/tmp/codeharness-wt-epic-1'));\n683\t    });\n684\t  });\n685\t\n686\t  describe('sprint state failure in parallel mode', () => {\n687\t    it('exits 1 when getSprintState fails in parallel mode', async () => {\n688\t      mockPaths({ '.claude': true });\n689\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n690\t      mockParallelWorkflow(2);\n691\t      getSprintStateMock.mockReturnValue({ success: false, error: 'state file corrupt' });\n692\t\n693\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n694\t\n695\t      await runCommand();\n696\t\n697\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Failed to read sprint state for epic discovery'));\n698\t      expect(process.exitCode).toBe(1);\n699\t    });\n700\t  });\n701\t\n702\t  describe('no pending epics in parallel mode', () => {\n703\t    it('reports nothing to execute when all epics are done', async () => {\n704\t      mockPaths({ '.claude': true });\n705\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n706\t      mockParallelWorkflow(2);\n707\t      getSprintStateMock.mockReturnValue({\n708\t        success: true,\n709\t        data: makeSprintState({\n710\t          stories: { '1-1-story': { ...defaultStory } },\n711\t          epics: { 'epic-1': { status: 'done', storiesTotal: 1, storiesDone: 1 } },\n712\t        }),\n713\t      });\n714\t\n715\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n716\t\n717\t      await runCommand();\n718\t\n719\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('No pending epics'));\n720\t      expect(process.exitCode).toBeUndefined();\n721\t    });\n722\t  });\n723\t\n724\t  describe('parallel execution error handling', () => {\n725\t    it('catches and reports unexpected errors in parallel path', async () => {\n726\t      mockPaths({ '.claude': true });\n727\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n728\t      mockParallelWorkflow(2);\n729\t      getSprintStateMock.mockReturnValue({\n730\t        success: true,\n731\t        data: makeSprintState({ stories: { '1-1-story': { ...defaultStory } } }),\n732\t      });\n733\t\n734\t      // LanePool constructor throws\n735\t      _poolFactory = () => { throw new Error('pool creation failed'); };\n736\t      _wtFactory = () => ({ createWorktree: vi.fn(), cleanupWorktree: vi.fn(), listWorktrees: vi.fn(() => []), detectOrphans: vi.fn(() => []) });\n737\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n738\t\n739\t      await runCommand();\n740\t\n741\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Parallel execution error'));\n742\t      expect(process.exitCode).toBe(1);\n743\t    });\n744\t  });\n745\t});\n746\t"}]},"parent_tool_use_id":"toolu_01KrDuJXvL9i