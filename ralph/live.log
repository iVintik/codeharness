{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Fi11rcyV2FAp6RnVoMpsjZ","type":"tool_result","content":"     1→/**\n     2→ * Migration from old scattered state files to unified sprint-state.json.\n     3→ * Runs once when sprint-state.json does not exist and old files are found.\n     4→ */\n     5→\n     6→import { readFileSync, existsSync } from 'node:fs';\n     7→import { join } from 'node:path';\n     8→import { ok, fail } from '../../types/result.js';\n     9→import type { Result } from '../../types/result.js';\n    10→import type { SprintState, SprintStateV1, StoryState, StoryStatus, ActionItem, SessionState } from '../../types/state.js';\n    11→import { defaultState, writeStateAtomic, computeSprintCounts } from './state.js';\n    12→\n    13→const OLD_FILES = {\n    14→  storyRetries: 'ralph/.story_retries',\n    15→  flaggedStories: 'ralph/.flagged_stories',\n    16→  ralphStatus: 'ralph/status.json',\n    17→  sprintStatusYaml: '_bmad-output/implementation-artifacts/sprint-status.yaml',\n    18→  sessionIssues: '_bmad-output/implementation-artifacts/.session-issues.md',\n    19→} as const;\n    20→\n    21→function resolve(relative: string): string {\n    22→  return join(process.cwd(), relative);\n    23→}\n    24→\n    25→function readIfExists(relative: string): string | null {\n    26→  const p = resolve(relative);\n    27→  if (!existsSync(p)) return null;\n    28→  try { return readFileSync(p, 'utf-8'); } catch { return null; }\n    29→}\n    30→\n    31→/** Return a fresh empty StoryState */\n    32→function emptyStory(): StoryState {\n    33→  return {\n    34→    status: 'backlog', attempts: 0, lastAttempt: null,\n    35→    lastError: null, proofPath: null, acResults: null,\n    36→  };\n    37→}\n    38→\n    39→/** Ensure a story entry exists, then apply a partial update */\n    40→function upsertStory(\n    41→  stories: Record<string, StoryState>,\n    42→  key: string,\n    43→  patch: Partial<StoryState>,\n    44→): void {\n    45→  stories[key] = { ...(stories[key] ?? emptyStory()), ...patch };\n    46→}\n    47→\n    48→/** Parse ralph/.story_retries: \"<key> <count>\" per line */\n    49→function parseStoryRetries(content: string, stories: Record<string, StoryState>): void {\n    50→  for (const line of content.split('\\n')) {\n    51→    const trimmed = line.trim();\n    52→    if (!trimmed) continue;\n    53→    const parts = trimmed.split(/\\s+/);\n    54→    if (parts.length < 2) continue;\n    55→    const count = parseInt(parts[1], 10);\n    56→    if (!isNaN(count)) upsertStory(stories, parts[0], { attempts: count });\n    57→  }\n    58→}\n    59→\n    60→/**\n    61→ * Parse ralph/.story_retries into a Record<string, number> for v2 retries field.\n    62→ * Format: \"<key> <count>\" per line (space-separated).\n    63→ */\n    64→export function parseStoryRetriesRecord(content: string): Record<string, number> {\n    65→  const result: Record<string, number> = {};\n    66→  for (const line of content.split('\\n')) {\n    67→    const trimmed = line.trim();\n    68→    if (!trimmed) continue;\n    69→    const parts = trimmed.split(/\\s+/);\n    70→    if (parts.length < 2) continue;\n    71→    const count = parseInt(parts[1], 10);\n    72→    if (!isNaN(count) && count >= 0) result[parts[0]] = count;\n    73→  }\n    74→  return result;\n    75→}\n    76→\n    77→/**\n    78→ * Parse ralph/.flagged_stories into a string[] for v2 flagged field.\n    79→ * Format: one key per line.\n    80→ */\n    81→export function parseFlaggedStoriesList(content: string): string[] {\n    82→  const seen = new Set<string>();\n    83→  const result: string[] = [];\n    84→  for (const line of content.split('\\n')) {\n    85→    const trimmed = line.trim();\n    86→    if (trimmed !== '' && !seen.has(trimmed)) {\n    87→      seen.add(trimmed);\n    88→      result.push(trimmed);\n    89→    }\n    90→  }\n    91→  return result;\n    92→}\n    93→\n    94→/** Parse ralph/.flagged_stories: one key per line */\n    95→function parseFlaggedStories(content: string, stories: Record<string, StoryState>): void {\n    96→  for (const line of content.split('\\n')) {\n    97→    const key = line.trim();\n    98→    if (key) upsertStory(stories, key, { status: 'blocked' });\n    99→  }\n   100→}\n   101→\n   102→/** Map YAML status strings to StoryStatus */\n   103→function mapYamlStatus(value: string): StoryStatus | null {\n   104→  const mapping: Record<string, StoryStatus> = {\n   105→    done: 'done', backlog: 'backlog', verifying: 'verifying',\n   106→    'in-progress': 'in-progress', 'ready-for-dev': 'ready',\n   107→    blocked: 'blocked', failed: 'failed', review: 'review', ready: 'ready',\n   108→  };\n   109→  return mapping[value.trim().toLowerCase()] ?? null;\n   110→}\n   111→\n   112→/**\n   113→ * Parse sprint-status.yaml (flat key: value).\n   114→ * Story lines like \"  1-1-result-type: done\" become entries.\n   115→ * Epic lines like \"  epic-1: done\" are skipped.\n   116→ */\n   117→function parseSprintStatusYaml(content: string, stories: Record<string, StoryState>): void {\n   118→  for (const line of content.split('\\n')) {\n   119→    const trimmed = line.trim();\n   120→    if (!trimmed || trimmed.startsWith('#')) continue;\n   121→    const match = trimmed.match(/^([a-zA-Z0-9_-]+):\\s*(.+)$/);\n   122→    if (!match) continue;\n   123→    const key = match[1];\n   124→    if (key === 'development_status' || key.startsWith('epic-')) continue;\n   125→    const status = mapYamlStatus(match[2]);\n   126→    if (status) upsertStory(stories, key, { status });\n   127→  }\n   128→}\n   129→\n   130→interface RalphStatusJson {\n   131→  loop_count?: number;\n   132→  stories_total?: number;\n   133→  stories_completed?: number;\n   134→  elapsed_seconds?: number;\n   135→  status?: string;\n   136→}\n   137→\n   138→/** Parse ralph/status.json into run section */\n   139→function parseRalphStatus(content: string): SprintState['run'] | null {\n   140→  try {\n   141→    const data = JSON.parse(content) as RalphStatusJson;\n   142→    return {\n   143→      active: data.status === 'running', startedAt: null,\n   144→      iteration: data.loop_count ?? 0, cost: 0, completed: [], failed: [],\n   145→      currentStory: null, currentPhase: null, lastAction: null, acProgress: null,\n   146→    };\n   147→  } catch { return null; }\n   148→}\n   149→\n   150→/** Parse ralph/status.json into SessionState for v2 */\n   151→function parseRalphStatusToSession(content: string): SessionState | null {\n   152→  try {\n   153→    const data = JSON.parse(content) as RalphStatusJson;\n   154→    return {\n   155→      active: data.status === 'running',\n   156→      startedAt: null,\n   157→      iteration: data.loop_count ?? 0,\n   158→      elapsedSeconds: data.elapsed_seconds ?? 0,\n   159→    };\n   160→  } catch { return null; }\n   161→}\n   162→\n   163→/** Parse .session-issues.md for action items (best effort) */\n   164→function parseSessionIssues(content: string): ActionItem[] {\n   165→  const items: ActionItem[] = [];\n   166→  let currentStory = '';\n   167→  let itemId = 0;\n   168→  for (const line of content.split('\\n')) {\n   169→    const headerMatch = line.match(/^###\\s+([a-zA-Z0-9_-]+)\\s*[—-]/);\n   170→    if (headerMatch) { currentStory = headerMatch[1]; continue; }\n   171→    const bulletMatch = line.match(/^-\\s+(.+)/);\n   172→    if (bulletMatch && currentStory) {\n   173→      itemId++;\n   174→      items.push({\n   175→        id: `migrated-${itemId}`, story: currentStory,\n   176→        description: bulletMatch[1], source: 'retro', resolved: false,\n   177→      });\n   178→    }\n   179→  }\n   180→  return items;\n   181→}\n   182→\n   183→/**\n   184→ * Migrate a v1 state to v2 by reading external files and merging into unified schema.\n   185→ * Does NOT delete source files (.story_retries, .flagged_stories).\n   186→ */\n   187→export function migrateV1ToV2(v1: SprintStateV1): SprintState {\n   188→  const defaults = defaultState();\n   189→\n   190→  // Read retries from external file\n   191→  const retriesContent = readIfExists(OLD_FILES.storyRetries);\n   192→  const retries = retriesContent ? parseStoryRetriesRecord(retriesContent) : {};\n   193→\n   194→  // Read flagged stories from external file\n   195→  const flaggedContent = readIfExists(OLD_FILES.flaggedStories);\n   196→  const flagged = flaggedContent ? parseFlaggedStoriesList(flaggedContent) : [];\n   197→\n   198→  // Read session info from ralph/status.json\n   199→  const statusContent = readIfExists(OLD_FILES.ralphStatus);\n   200→  const session = statusContent\n   201→    ? (parseRalphStatusToSession(statusContent) ?? defaults.session)\n   202→    : defaults.session;\n   203→\n   204→  return {\n   205→    version: 2,\n   206→    sprint: v1.sprint,\n   207→    stories: v1.stories,\n   208→    retries,\n   209→    flagged,\n   210→    epics: {},\n   211→    session,\n   212→    observability: defaults.observability,\n   213→    run: {\n   214→      ...defaults.run,\n   215→      ...v1.run,\n   216→    },\n   217→    actionItems: v1.actionItems,\n   218→  };\n   219→}\n   220→\n   221→/**\n   222→ * Migrate from old format files to SprintState.\n   223→ * Returns fail() if no old files exist (caller should use default).\n   224→ */\n   225→export function migrateFromOldFormat(): Result<SprintState> {\n   226→  const hasAnyOldFile = Object.values(OLD_FILES).some((rel) => existsSync(resolve(rel)));\n   227→  if (!hasAnyOldFile) return fail('No old format files found for migration');\n   228→\n   229→  try {\n   230→    const stories: Record<string, StoryState> = {};\n   231→    let run = defaultState().run;\n   232→    let actionItems: ActionItem[] = [];\n   233→\n   234→    const yamlContent = readIfExists(OLD_FILES.sprintStatusYaml);\n   235→    if (yamlContent) parseSprintStatusYaml(yamlContent, stories);\n   236→\n   237→    const retriesContent = readIfExists(OLD_FILES.storyRetries);\n   238→    if (retriesContent) parseStoryRetries(retriesContent, stories);\n   239→\n   240→    const flaggedContent = readIfExists(OLD_FILES.flaggedStories);\n   241→    if (flaggedContent) parseFlaggedStories(flaggedContent, stories);\n   242→\n   243→    const statusContent = readIfExists(OLD_FILES.ralphStatus);\n   244→    let session = defaultState().session;\n   245→    if (statusContent) {\n   246→      const parsed = parseRalphStatus(statusContent);\n   247→      if (parsed) run = parsed;\n   248→      const parsedSession = parseRalphStatusToSession(statusContent);\n   249→      if (parsedSession) session = parsedSession;\n   250→    }\n   251→\n   252→    const issuesContent = readIfExists(OLD_FILES.sessionIssues);\n   253→    if (issuesContent) actionItems = parseSessionIssues(issuesContent);\n   254→\n   255→    const sprint = computeSprintCounts(stories);\n   256→\n   257→    // Parse retries and flagged for v2 fields\n   258→    const retries = retriesContent ? parseStoryRetriesRecord(retriesContent) : {};\n   259→    const flagged = flaggedContent ? parseFlaggedStoriesList(flaggedContent) : [];\n   260→\n   261→    const migrated: SprintState = {\n   262→      version: 2,\n   263→      sprint,\n   264→      stories,\n   265→      retries,\n   266→      flagged,\n   267→      epics: {},\n   268→      session,\n   269→      observability: defaultState().observability,\n   270→      run,\n   271→      actionItems,\n   272→    };\n   273→\n   274→    const writeResult = writeStateAtomic(migrated);\n   275→    if (!writeResult.success) return fail(writeResult.error);\n   276→    return ok(migrated);\n   277→  } catch (err: unknown) {\n   278→    const msg = err instanceof Error ? err.message : String(err);\n   279→    return fail(`Migration failed: ${msg}`);\n   280→  }\n   281→}\n   282→"}]},"parent_tool_use_id":"toolu_011K77Q1Nc8EiPZnCgrdVKHN","session_id":"01503c00-15e6-46f1-b837-b4628ff69656","uuid":"84d06c3f-2018-4d56-93bb-519f442bbd56","timestamp":"2026-03-24T11:33:01.785Z"}
