rts) {\n      if (line.trim().length === 0) continue;\n      const event = parseStreamLine(line);\n      if (event) {\n        callbacks.onEvent(event);\n      }\n      if (opts?.parseRalph) {\n        const msg = parseRalphMessage(line);\n        if (msg && callbacks.onMessage) {\n          callbacks.onMessage(msg);\n        }\n        const iteration = parseIterationMessage(line);\n        if (iteration !== null && callbacks.onIteration) {\n          callbacks.onIteration(iteration);\n        }\n      }\n    }\n  };\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":283,"cache_read_input_tokens":48830,"cache_creation":{"ephemeral_5m_input_tokens":283,"ephemeral_1h_input_tokens":0},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01FovCBiSYXRKp8ZFdrhG5VU","session_id":"eb26302c-c52a-41c7-9204-5eb8c12a854c","uuid":"403cc459-a911-4fc1-874f-8bb8d7bd109b"}
