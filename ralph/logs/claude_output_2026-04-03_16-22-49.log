f (status === 429 || /rate.?limit/i.test(message)) {\n55\t    return 'RATE_LIMIT';\n56\t  }\n57\t\n58\t  // Network errors: known error codes\n59\t  if (code && NETWORK_CODES.has(code)) {\n60\t    return 'NETWORK';\n61\t  }\n62\t  if (/fetch|network|dns/i.test(message) && /fail|error|timeout/i.test(message)) {\n63\t    return 'NETWORK';\n64\t  }\n65\t  if (/ECONNREFUSED|ETIMEDOUT|ENOTFOUND|ENETUNREACH|ECONNRESET|EPIPE/i.test(message)) {\n66\t    return 'NETWORK';\n67\t  }\n68\t\n69\t  // Auth errors: HTTP 401/403 or auth-related messages\n70\t  if (status === 401 || status === 403 || /unauthorized|forbidden/i.test(message)) {\n71\t    return 'AUTH';\n72\t  }\n73\t\n74\t  // Timeout\n75\t  if (/timeout|timed.?out|aborted/i.test(message)) {\n76\t    return 'TIMEOUT';\n77\t  }\n78\t\n79\t  return 'UNKNOWN';\n80\t}\n81\t\n82\t// --- Line Parser ---\n83\t\n84\t/**\n85\t * Parse a single line of OpenCode CLI NDJSON output into a StreamEvent.\n86\t * Returns null for unrecognized or unparseable lines.\n87\t */\n88\texport function parseLine(line: string): StreamEvent | null {\n89\t  const trimmed = line.trim();\n90\t  if (trimmed.length === 0) return null;\n91\t\n92\t  let parsed: Record<string, unknown>;\n93\t  try {\n94\t    parsed = JSON.parse(trimmed) as Record<string, unknown>;\n95\t  } catch { // IGNORE: malformed JSON in CLI output — skip unparseable lines\n96\t    return null;\n97\t  }\n98\t\n99\t  if (typeof parsed !== 'object' || parsed === null || Array.isArray(parsed)) {\n100\t    return null;\n101\t  }\n102\t\n103\t  const type = parsed.type as string | undefined;\n104\t\n105\t  if (type === 'tool_call') {\n106\t    const name = parsed.name;\n107\t    const callId = parsed.call_id;\n108\t    if (typeof name === 'string' && typeof callId === 'string') {\n109\t      return { type: 'tool-start', name, id: callId };\n110\t    }\n111\t    return null;\n112\t  }\n113\t\n114\t  if (type === 'tool_input') {\n115\t    const input = parsed.input;\n116\t    if (typeof input === 'string') {\n117\t      return { type: 'tool-input', partial: input };\n118\t    }\n119\t    return null;\n120\t  }\n121\t\n122\t  if (type === 'tool_result') {\n123\t    return { type: 'tool-complete' };\n124\t  }\n125\t\n126\t  if (type === 'message') {\n127\t    const content = parsed.content;\n128\t    if (typeof content === 'string') {\n129\t      return { type: 'text', text: content };\n130\t    }\n131\t    return null;\n132\t  }\n133\t\n134\t  if (type === 'retry') {\n135\t    const attempt = parsed.attempt;\n136\t    const delay = parsed.delay_ms;\n137\t    if (typeof attempt === 'number' && typeof delay === 'number') {\n138\t      return { type: 'retry', attempt, delay };\n139\t    }\n140\t    return null;\n141\t  }\n142\t\n143\t  if (type === 'result') {\n144\t    const costUsd = parsed.cost_usd;\n145\t    const sessionId = parsed.session_id;\n146\t    return {\n147\t      type: 'result',\n148\t      cost: typeof costUsd === 'number' ? costUsd : 0,\n149\t      sessionId: typeof sessionId === 'string' ? sessionId : '',\n150\t      cost_usd: typeof costUsd === 'number' ? costUsd : null,\n151\t    };\n152\t  }\n153\t\n154\t  return null;\n155\t}\n156\t\n157\t// --- Driver Implementation ---\n158\t\n159\t/**\n160\t * OpenCodeDriver — CLI-wrapped AgentDriver for OpenCode.\n161\t *\n162\t * Spawns `opencode` CLI via child_process.spawn, parses stdout line-by-line\n163\t * into StreamEvent objects. Stateless between dispatches except `lastCost`.\n164\t *\n165\t * Key differences from CodexDriver:\n166\t * - Supports plugins via `--plugin` flags (CodexDriver warns and ignores)\n167\t * - Default model is 'default' (inherits from OpenCode's own config)\n168\t * - Install instructions point to https://opencode.ai\n169\t */\n170\texport class OpenCodeDriver implements AgentDriver {\n171\t  readonly name = 'opencode' as const;\n172\t  readonly defaultModel = 'default' as const;\n173\t  readonly capabilities: DriverCapabilities = {\n174\t    supportsPlugins: true,\n175\t    supportsStreaming: true,\n176\t    costReporting: true,\n177\t  };\n178\t\n179\t  private lastCost: number | null = null;\n180\t\n181\t  async healthCheck(): Promise<DriverHealth> {\n182\t    // Check if opencode binary is on PATH\n183\t    try {\n184\t      await execFileAsync('which', ['opencode']);\n185\t    } catch { // IGNORE: binary not on PATH — expected condition for health check\n186\t      return {\n187\t        available: false,\n188\t        authenticated: false,\n189\t        version: null,\n190\t        error: 'opencode not found. Install: https://opencode.ai',\n191\t      };\n192\t    }\n193\t\n194\t    // Get version\n195\t    let version: string | null = null;\n196\t    try {\n197\t      const { stdout } = await execFileAsync('opencode', ['--version']);\n198\t      version = stdout.trim() || null;\n199\t    } catch { // IGNORE: version check failed — binary exists but version unknown\n200\t      // noop\n201\t    }\n202\t\n203\t    // Check auth status\n204\t    let authenticated = false;\n205\t    try {\n206\t      await execFileAsync('opencode', ['auth', 'status']);\n207\t      authenticated = true;\n208\t    } catch { // IGNORE: auth check failed or command not supported — treat as unauthenticated\n209\t      // noop\n210\t    }\n211\t\n212\t    return { available: true, authenticated, version };\n213\t  }\n214\t\n215\t  async *dispatch(opts: DispatchOpts): AsyncGenerator<StreamEvent> {\n216\t    this.lastCost = null;\n217\t\n218\t    // Build CLI args\n219\t    const args: string[] = [];\n220\t    if (opts.model) {\n221\t      args.push('--model', opts.model);\n222\t    }\n223\t    if (opts.cwd) {\n224\t      args.push('--cwd', opts.cwd);\n225\t    }\n226\t\n227\t    // Pass plugins via --plugin flags (OpenCode supports plugins natively)\n228\t    if (opts.plugins && opts.plugins.length > 0) {\n229\t      for (const plugin of opts.plugins) {\n230\t        args.push('--plugin', plugin);\n231\t      }\n232\t    }\n233\t\n234\t    args.push(opts.prompt);\n235\t\n236\t    let yieldedResult = false;\n237\t    let timedOut = false;\n238\t    let timeoutId: ReturnType<typeof setTimeout> | undefined;\n239\t\n240\t    const proc = spawn('opencode', args, {\n241\t      stdio: ['ignore', 'pipe', 'pipe'],\n242\t    });\n243\t\n244\t    // Timeout handling\n245\t    if (opts.timeout) {\n246\t      timeoutId = setTimeout(() => {\n247\t        timedOut = true;\n248\t        proc.kill();\n249\t      }, opts.timeout);\n250\t    }\n251\t\n252\t    // Collect stderr for error classification\n253\t    let stderrData = '';\n254\t    proc.stderr.on('data', (chunk: Buffer) => {\n255\t      stderrData += chunk.toString();\n256\t    });\n257\t\n258\t    // Parse stdout line-by-line\n259\t    const rl = createInterface({ input: proc.stdout });\n260\t\n261\t    // Capture close promise BEFORE iterating — close may fire during readline iteration\n262\t    const closePromise = new Promise<number | null>((resolve) => {\n263\t      proc.on('close', (code: number | null) => resolve(code));\n264\t    });\n265\t\n266\t    try {\n267\t      for await (const line of rl) {\n268\t        const event = parseLine(line);\n269\t        if (event) {\n270\t          // Capture cost from result events\n271\t          if (event.type === 'result') {\n272\t            const resultEvent = event as ResultEvent;\n273\t            if (typeof resultEvent.cost_usd === 'number') {\n274\t              this.lastCost = resultEvent.cost_usd;\n275\t            }\n276\t            yield event;\n277\t            yieldedResult = true;\n278\t          } else {\n279\t            yield event;\n280\t          }\n281\t        } else {\n282\t          // Unparseable line — log at debug level and skip\n283\t          console.debug('[OpenCodeDriver] Skipping unparseable line:', line);\n284\t        }\n285\t      }\n286\t\n287\t      // Wait for process to close (promise was registered before readline started)\n288\t      const exitCode = await closePromise;\n289\t\n290\t      // Handle non-zero exit\n291\t      if (exitCode !== null && exitCode !== 0 && !yieldedResult) {\n292\t        const errorText = stderrData || `opencode exited with code ${exitCode}`;\n293\t        const category = timedOut ? 'TIMEOUT' : classifyError(errorText);\n294\t\n295\t        yield {\n296\t          type: 'result',\n297\t          cost: this.lastCost ?? 0,\n298\t          sessionId: '',\n299\t          cost_usd: this.lastCost,\n300\t          error: errorText,\n301\t          errorCategory: category,\n302\t        } as ResultEvent;\n303\t        yieldedResult = true;\n304\t      }\n305\t    } catch (err: unknown) {\n306\t      const errorMessage = err instanceof Error ? err.message : String(err);\n307\t      const category = timedOut ? 'TIMEOUT' : classifyError(err);\n308\t\n309\t      yield {\n310\t        type: 'result',\n311\t        cost: this.lastCost ?? 0,\n312\t        sessionId: '',\n313\t        cost_usd: this.lastCost,\n314\t        error: errorMessage,\n315\t        errorCategory: category,\n316\t      } as ResultEvent;\n317\t      yieldedResult = true;\n318\t    } finally {\n319\t      if (timeoutId) {\n320\t        clearTimeout(timeoutId);\n321\t      }\n322\t    }\n323\t\n324\t    // Guarantee a result event is always yielded\n325\t    if (!yieldedResult) {\n326\t      yield {\n327\t        type: 'result',\n328\t        cost: this.lastCost ?? 0,\n329\t        sessionId: '',\n330\t        cost_usd: this.lastCost,\n331\t      } as ResultEvent;\n332\t    }\n333\t  }\n334\t\n335\t  getLastCost(): number | null {\n336\t    return this.lastCost;\n337\t  }\n338\t}\n339\t"}]},"parent_tool_use_id":"toolu_01MERTQEVoM1FQ7mMnPAJnfv","session_id":"49777568-67d3-419d-b985-1c272283fc99","uuid":"2e1f0eab-e7ca-4aa6-8c8e-6646a8ad11aa","timestamp":"2026-04-03T12:24:46.033Z"}
