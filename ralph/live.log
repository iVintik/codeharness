{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0193qftsosKVs7qWJLJmJR8q","type":"tool_result","content":"     1→import { describe, it, expect, beforeAll } from 'vitest';\n     2→import { readFileSync, existsSync } from 'node:fs';\n     3→import { resolve } from 'node:path';\n     4→import { parse as parseYaml } from 'yaml';\n     5→import { parseSemgrepOutput, computeSummary } from '../analyzer.js';\n     6→\n     7→const ROOT = resolve(__dirname, '..', '..', '..', '..');\n     8→const PATCHES_DIR = resolve(ROOT, 'patches/observability');\n     9→\n    10→// Load all three Rust rule files\n    11→interface SemgrepRule {\n    12→  id: string;\n    13→  patterns?: unknown[];\n    14→  message: string;\n    15→  languages: string[];\n    16→  severity: string;\n    17→  metadata?: {\n    18→    category?: string;\n    19→    cwe?: string;\n    20→  };\n    21→}\n    22→\n    23→interface SemgrepConfig {\n    24→  rules: SemgrepRule[];\n    25→}\n    26→\n    27→function loadRule(filename: string): SemgrepConfig {\n    28→  const path = resolve(PATCHES_DIR, filename);\n    29→  const content = readFileSync(path, 'utf-8');\n    30→  return parseYaml(content) as SemgrepConfig;\n    31→}\n    32→\n    33→// ============================================================\n    34→// rust-function-no-tracing.yaml\n    35→// ============================================================\n    36→\n    37→describe('rust-function-no-tracing.yaml', () => {\n    38→  let config: SemgrepConfig;\n    39→\n    40→  beforeAll(() => {\n    41→    config = loadRule('rust-function-no-tracing.yaml');\n    42→  });\n    43→\n    44→  it('file exists', () => {\n    45→    expect(existsSync(resolve(PATCHES_DIR, 'rust-function-no-tracing.yaml'))).toBe(true);\n    46→  });\n    47→\n    48→  it('has exactly one rule', () => {\n    49→    expect(config.rules).toHaveLength(1);\n    50→  });\n    51→\n    52→  it('rule id is rust-function-no-tracing', () => {\n    53→    expect(config.rules[0].id).toBe('rust-function-no-tracing');\n    54→  });\n    55→\n    56→  it('targets Rust language', () => {\n    57→    expect(config.rules[0].languages).toEqual(['rust']);\n    58→  });\n    59→\n    60→  it('severity is INFO', () => {\n    61→    expect(config.rules[0].severity).toBe('INFO');\n    62→  });\n    63→\n    64→  it('has observability category metadata', () => {\n    65→    expect(config.rules[0].metadata?.category).toBe('observability');\n    66→  });\n    67→\n    68→  it('has CWE-778 metadata', () => {\n    69→    expect(config.rules[0].metadata?.cwe).toBe('CWE-778: Insufficient Logging');\n    70→  });\n    71→\n    72→  it('message mentions observability gap', () => {\n    73→    expect(config.rules[0].message).toContain('observability gap');\n    74→  });\n    75→\n    76→  it('has patterns array with pattern-either and pattern-not entries', () => {\n    77→    const patterns = config.rules[0].patterns;\n    78→    expect(patterns).toBeDefined();\n    79→    expect(Array.isArray(patterns)).toBe(true);\n    80→    expect(patterns!.length).toBeGreaterThan(1);\n    81→\n    82→    // First entry should be pattern-either with fn variants\n    83→    const patternEither = patterns![0] as Record<string, unknown>;\n    84→    expect(patternEither).toHaveProperty('pattern-either');\n    85→\n    86→    // Should have pattern-not entries for tracing exclusions\n    87→    const patternNots = patterns!.filter(\n    88→      (p) => typeof p === 'object' && p !== null && 'pattern-not' in (p as Record<string, unknown>),\n    89→    );\n    90→    expect(patternNots.length).toBeGreaterThan(0);\n    91→  });\n    92→\n    93→  it('pattern-either covers fn, pub fn, async fn, pub async fn', () => {\n    94→    const patterns = config.rules[0].patterns!;\n    95→    const patternEither = (patterns[0] as Record<string, unknown>)['pattern-either'] as string[];\n    96→    const allPatterns = patternEither.map((p: unknown) => {\n    97→      if (typeof p === 'object' && p !== null && 'pattern' in (p as Record<string, unknown>)) {\n    98→        return (p as Record<string, string>).pattern;\n    99→      }\n   100→      return '';\n   101→    });\n   102→\n   103→    const joined = allPatterns.join(' ');\n   104→    expect(joined).toContain('fn $FUNC');\n   105→    expect(joined).toContain('pub fn $FUNC');\n   106→    expect(joined).toContain('async fn $FUNC');\n   107→    expect(joined).toContain('pub async fn $FUNC');\n   108→  });\n   109→\n   110→  it('pattern-not entries exclude tracing macros (namespaced and bare)', () => {\n   111→    const patterns = config.rules[0].patterns!;\n   112→    const patternNots = patterns\n   113→      .filter(\n   114→        (p) => typeof p === 'object' && p !== null && 'pattern-not' in (p as Record<string, unknown>),\n   115→      )\n   116→      .map((p) => (p as Record<string, string>)['pattern-not']);\n   117→\n   118→    const allExclusions = patternNots.join(' ');\n   119→\n   120→    // Namespaced tracing macros\n   121→    expect(allExclusions).toContain('tracing::debug!');\n   122→    expect(allExclusions).toContain('tracing::info!');\n   123→    expect(allExclusions).toContain('tracing::warn!');\n   124→    expect(allExclusions).toContain('tracing::error!');\n   125→\n   126→    // Bare imports\n   127→    expect(allExclusions).toContain('debug!(');\n   128→    expect(allExclusions).toContain('info!(');\n   129→    expect(allExclusions).toContain('warn!(');\n   130→    expect(allExclusions).toContain('error!(');\n   131→\n   132→    // #[instrument] attribute exclusions\n   133→    expect(allExclusions).toContain('#[tracing::instrument]');\n   134→    expect(allExclusions).toContain('#[instrument]');\n   135→  });\n   136→\n   137→  it('test fixture file exists', () => {\n   138→    expect(existsSync(resolve(PATCHES_DIR, 'rust-function-no-tracing.rs'))).toBe(true);\n   139→  });\n   140→\n   141→  it('test fixture has ruleid and ok annotations', () => {\n   142→ 