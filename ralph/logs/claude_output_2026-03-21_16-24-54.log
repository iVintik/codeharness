{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Qni1LVwCGEEovA1dEPNjMk","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→\n     3→vi.mock('node:fs', () => ({\n     4→  existsSync: vi.fn(),\n     5→  readFileSync: vi.fn(),\n     6→}));\n     7→\n     8→import { existsSync, readFileSync } from 'node:fs';\n     9→import { validateDockerfile, loadRules } from '../dockerfile-validator.js';\n    10→\n    11→const mockExistsSync = vi.mocked(existsSync);\n    12→const mockReadFileSync = vi.mocked(readFileSync);\n    13→\n    14→beforeEach(() => {\n    15→  vi.clearAllMocks();\n    16→});\n    17→\n    18→// Helper: build a Dockerfile string that passes all rules\n    19→function goodDockerfile(): string {\n    20→  return [\n    21→    'FROM node:22-slim',\n    22→    'RUN apt-get update && apt-get install -y curl jq && rm -rf /var/lib/apt/lists/*',\n    23→    'RUN npm install -g codeharness',\n    24→    'COPY dist/ /app/dist/',\n    25→    'USER node',\n    26→    'CMD [\"codeharness\"]',\n    27→  ].join('\\n');\n    28→}\n    29→\n    30→// ─── Pinned FROM ────────────────────────────────────────────────────────────\n    31→\n    32→describe('pinned FROM', () => {\n    33→  it('passes for node:22-slim', () => {\n    34→    mockExistsSync.mockReturnValue(true);\n    35→    mockReadFileSync.mockReturnValue(goodDockerfile());\n    36→\n    37→    const r = validateDockerfile('/project');\n    38→    expect(r.success).toBe(true);\n    39→    if (r.success) {\n    40→      const fromGaps = r.data.gaps.filter(g => g.rule === 'pinned-from');\n    41→      expect(fromGaps).toHaveLength(0);\n    42→    }\n    43→  });\n    44→\n    45→  it('fails for node:latest', () => {\n    46→    mockExistsSync.mockReturnValue(true);\n    47→    mockReadFileSync.mockReturnValue(\n    48→      goodDockerfile().replace('FROM node:22-slim', 'FROM node:latest'),\n    49→    );\n    50→\n    51→    const r = validateDockerfile('/project');\n    52→    expect(r.success).toBe(true);\n    53→    if (r.success) {\n    54→      const fromGaps = r.data.gaps.filter(g => g.rule === 'pinned-from');\n    55→      expect(fromGaps.length).toBeGreaterThan(0);\n    56→      expect(fromGaps[0].description).toContain('unpinned base image');\n    57→    }\n    58→  });\n    59→\n    60→  it('passes for digest-pinned image', () => {\n    61→    mockExistsSync.mockReturnValue(true);\n    62→    mockReadFileSync.mockReturnValue(\n    63→      goodDockerfile().replace('FROM node:22-slim', 'FROM node@sha256:abc123def456'),\n    64→    );\n    65→\n    66→    const r = validateDockerfile('/project');\n    67→    expect(r.success).toBe(true);\n    68→    if (r.success) {\n    69→      const fromGaps = r.data.gaps.filter(g => g.rule === 'pinned-from');\n    70→      expect(fromGaps).toHaveLength(0);\n    71→    }\n    72→  });\n    73→\n    74→  it('fails for node (no tag)', () => {\n    75→    mockExistsSync.mockReturnValue(true);\n    76→    mockReadFileSync.mockReturnValue(\n    77→      goodDockerfile().replace('FROM node:22-slim', 'FROM node'),\n    78→    );\n    79→\n    80→    const r = validateDockerfile('/project');\n    81→    expect(r.success).toBe(true);\n    82→    if (r.success) {\n    83→      const fromGaps = r.data.gaps.filter(g => g.rule === 'pinned-from');\n    84→      expect(fromGaps.length).toBeGreaterThan(0);\n    85→      expect(fromGaps[0].description).toContain('unpinned base image');\n    86→    }\n    87→  });\n    88→});\n    89→\n    90→// ─── Project binary on PATH ─────────────────────────────────────────────────\n    91→\n    92→describe('project binary on PATH', () => {\n    93→  it('passes with npm install -g', () => {\n    94→    mockExistsSync.mockReturnValue(true);\n    95→    mockReadFileSync.mockReturnValue(goodDockerfile());\n    96→\n    97→    const r = validateDockerfile('/project');\n    98→    expect(r.success).toBe(true);\n    99→    if (r.success) {\n   100→      const binGaps = r.data.gaps.filter(g => g.rule === 'binary-on-path');\n   101→      expect(binGaps).toHaveLength(0);\n   102→    }\n   103→  });\n   104→\n   105→  it('passes with pip install', () => {\n   106→    mockExistsSync.mockReturnValue(true);\n   107→    const df = goodDockerfile().replace('RUN npm install -g codeharness', 'RUN pip install myapp');\n   108→    mockReadFileSync.mockReturnValue(df);\n   109→\n   110→    const r = validateDockerfile('/project');\n   111→    expect(r.success).toBe(true);\n   112→    if (r.success) {\n   113→      const binGaps = r.data.gaps.filter(g => g.rule === 'binary-on-path');\n   114→      expect(binGaps).toHaveLength(0);\n   115→    }\n   116→  });\n   117→\n   118→  it('passes with COPY --from (multi-stage)', () => {\n   119→    mockExistsSync.mockReturnValue(true);\n   120→    const df = goodDockerfile().replace('RUN npm install -g codeharness', 'COPY --from=builder /app/dist/bin /usr/local/bin/myapp');\n   121→    mockReadFileSync.mockReturnValue(df);\n   122→\n   123→    const r = validateDockerfile('/project');\n   124→    expect(r.success).toBe(true);\n   125→    if (r.success) {\n   126→      const binGaps = r.data.gaps.filter(g => g.rule === 'binary-on-path');\n   127→      expect(binGaps).toHaveLength(0);\n   128→    }\n   129→  });\n   130→\n   131→  it('fails when no binary install pattern found', () => {\n   132→    mockExistsSync.mockReturnValue(true);\n   133→    const df = goodDockerfile().replace('RUN npm install -g codeharness', 'RUN echo hello');\n   134→    mockReadFileSync.mockReturnValue(df);\n   135→\n   136→    const r = validateDockerfile('/project');\n   137→    expect(r.success).toBe(true);\n   138→    if (r.success) {\n   139→      const binGaps = r.data.gaps.filter(g => g.rule === 'binary-on-path');\n   140→      expect(binGaps).toHaveLength(1);\n   141→      expect(binGaps[0].description).toContain('project binary not installed');\n   142→    }\n   143→  });\n   144→});\n   145→\n   146→// ─── Verification tools ─────────────────────────────────────────────────────\n   147→\n   148→describe('verification tools', () => {\n   149→  it('passes when curl and jq are installed', () => {\n   150→    mockExistsSync.mockReturnValue(true);\n   151→    mockReadFileSync.mockReturnValue(goodDockerfile());\n   152→\n   153→    const r = validateDockerfile('/project');\n   154→    expect(r.success).toBe(true);\n   155→    if (r.success) {\n   156→      const toolGaps = r.data.gaps.filter(g => g.rule === 'verification-tools');\n   157→      expect(toolGaps).toHaveLength(0);\n   158→    }\n   159→  });\n   160→\n   161→  it('fails when curl is missing', () => {\n   162→    mockExistsSync.mockReturnValue(true);\n   163→    const df = goodDockerfile().replace('curl jq', 'jq');\n   164→    mockReadFileSync.mockReturnValue(df);\n   165→\n   166→    const r = validateDockerfile('/project');\n   167→    expect(r.success).toBe(true);\n   168→    if (r.success) {\n   169→      const toolGaps = r.data.gaps.filter(g => g.rule === 'verification-tools');\n   170→      expect(toolGaps.some(g => g.description.includes('curl'))).toBe(true);\n   171→    }\n   172→  });\n   173→\n   174→  it('fails when jq is missing', () => {\n   175→    mockExistsSync.mockReturnValue(true);\n   176→    const df = goodDockerfile().replace('curl jq', 'curl');\n   177→    mockReadFileSync.mockReturnValue(df);\n   178→\n   179→    const r = validateDockerfile('/project');\n   180→    expect(r.success).toBe(true);\n   181→    if (r.success) {\n   182→      const toolGaps = r.data.gaps.filter(g => g.rule === 'verification-tools');\n   183→      expect(toolGaps.some(g => g.description.includes('jq'))).toBe(true);\n   184→    }\n   185→  });\n   186→\n   187→  it('passes when tools installed via apk add', () => {\n   188→    mockExistsSync.mockReturnValue(true);\n   189→    const df = [\n   190→      'FROM node:22-alpine',\n   191→      'RUN apk add --no-cache curl jq && rm -rf /var/cache/ap