{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XDTyQkxvbmhK3S5zf6kyeA","type":"tool_result","content":"     1→/**\n     2→ * Dockerfile validator — checks Dockerfiles against 6 required rule categories.\n     3→ * Returns structured gaps for audit integration.\n     4→ *\n     5→ * FR23 (formalized Dockerfile rules), FR24 (audit validates against rules).\n     6→ */\n     7→\n     8→import { existsSync, readFileSync } from 'node:fs';\n     9→import { join } from 'node:path';\n    10→import { ok, fail } from '../../types/result.js';\n    11→import type { Result } from '../../types/result.js';\n    12→\n    13→/** A single gap found during Dockerfile validation */\n    14→export interface DockerfileGap {\n    15→  readonly rule: string;\n    16→  readonly description: string;\n    17→  readonly suggestedFix: string;\n    18→  readonly line?: number;\n    19→}\n    20→\n    21→/** Result of validating a Dockerfile against all rules */\n    22→export interface DockerfileValidationResult {\n    23→  readonly passed: boolean;\n    24→  readonly gaps: DockerfileGap[];\n    25→  readonly warnings: string[];\n    26→}\n    27→\n    28→/** Internal rules structure */\n    29→interface DockerfileRules {\n    30→  readonly requirePinnedFrom: boolean;\n    31→  readonly requireBinaryOnPath: boolean;\n    32→  readonly verificationTools: string[];\n    33→  readonly forbidSourceCopy: boolean;\n    34→  readonly requireNonRootUser: boolean;\n    35→  readonly requireCacheCleanup: boolean;\n    36→}\n    37→\n    38→const DEFAULT_RULES: DockerfileRules = {\n    39→  requirePinnedFrom: true,\n    40→  requireBinaryOnPath: true,\n    41→  verificationTools: ['curl', 'jq'],\n    42→  forbidSourceCopy: true,\n    43→  requireNonRootUser: true,\n    44→  requireCacheCleanup: true,\n    45→};\n    46→\n    47→function dfGap(rule: string, description: string, suggestedFix: string, line?: number): DockerfileGap {\n    48→  const g: DockerfileGap = { rule, description, suggestedFix };\n    49→  if (line !== undefined) return { ...g, line };\n    50→  return g;\n    51→}\n    52→\n    53→/**\n    54→ * Load rules from patches/infra/dockerfile-rules.md or fall back to defaults.\n    55→ * The markdown is documentation — the actual rules are hardcoded defaults.\n    56→ * Returns rules + any warnings about missing file.\n    57→ */\n    58→export function loadRules(projectDir: string): { rules: DockerfileRules; warnings: string[] } {\n    59→  const rulesPath = join(projectDir, 'patches', 'infra', 'dockerfile-rules.md');\n    60→  if (!existsSync(rulesPath)) {\n    61→    return {\n    62→      rules: DEFAULT_RULES,\n    63→      warnings: ['dockerfile-rules.md not found -- using defaults.'],\n    64→    };\n    65→  }\n    66→  return { rules: DEFAULT_RULES, warnings: [] };\n    67→}\n    68→\n    69→// ─── Rule checkers ──────────────────────────────────────────────────────────\n    70→\n    71→function checkPinnedFrom(lines: string[]): DockerfileGap[] {\n    72→  const gaps: DockerfileGap[] = [];\n    73→  for (let i = 0; i < lines.length; i++) {\n    74→    if (!/^\\s*FROM\\s+/i.test(lines[i])) continue;\n    75→    const ref = lines[i].replace(/^\\s*FROM\\s+/i, '').split(/\\s+/)[0];\n    76→    if (ref.endsWith(':latest')) {\n    77→      gaps.push(dfGap('pinned-from', `unpinned base image -- use specific version.`, `Pin ${ref} to a specific version tag`, i + 1));\n    78→    } else if (!ref.includes(':') && !ref.includes('@')) {\n    79→      gaps.push(dfGap('pinned-from', `unpinned base image -- use specific version.`, `Pin ${ref} to a specific version tag (e.g., ${ref}:22-slim)`, i + 1));\n    80→    }\n    81→  }\n    82→  return gaps;\n    83→}\n    84→\n    85→function checkBinaryOnPath(lines: string[]): DockerfileGap[] {\n    86→  const content = lines.join('\\n');\n    87→  const hasBinary =\n    88→    /npm\\s+install\\s+(-g|--global)\\b/i.test(content) ||\n    89→    /pip\\s+install\\b/i.test(content) ||\n    90→    /COPY\\s+--from=/i.test(content);\n    91→  if (!hasBinary) {\n    92→    return [dfGap('binary-on-path', 'project binary not installed.', 'Add npm install -g, pip install, or COPY --from to install the project binary')];\n    93→  }\n    94→  return [];\n    95→}\n    96→\n    97→function checkVerificationTools(lines: string[], tools: string[]): DockerfileGap[] {\n    98→  const content = lines.join('\\n').toLowerCase();\n    99→  const gaps: DockerfileGap[] = [];\n   100→  for (const tool of tools) {\n   101→    const installed =\n   102→      content.includes(`apt-get install`) && content.includes(tool) ||\n   103→      content.includes(`apk add`) && content.includes(tool);\n   104→    if (!installed) {\n   105→      gaps.push(dfGap('verification-tools', `verification tool missing: ${tool}`, `Install ${tool} via apt-get install or apk add`));\n   106→    }\n   107→  }\n   108→  return gaps;\n   109→}\n   110→\n   111→function checkNoSourceCopy(lines: string[]): DockerfileGap[] {\n   112→  const gaps: DockerfileGap[] = [];\n   113→  const sourcePatterns = [/COPY\\s+src\\//i, /COPY\\s+lib\\//i, /COPY\\s+test\\//i];\n   114→  for (let i = 0; i < lines.length; i++) {\n   115→    for (const pattern of sourcePatterns) {\n   116→      if (pattern.test(lines[i])) {\n   117→        gaps.push(dfGap('no-source-copy', 'source code copied into container -- use build artifact instead.', 'Use COPY --from=builder or COPY dist/ instead of copying source', i + 1));\n   118→      }\n   119→    }\n   120→  }\n   121→  return gaps;\n   122→}\n   123→\n   124→function checkNonRootUser(lines: string[]): DockerfileGap[] {\n   125→  const userLines = lines.filter(l => /^\\s*USER\\s+/i.test(l));\n   126→  if (userLines.length === 0) {\n   127→    return [dfGap('non-root-user', 'no non-root USER instruction found.', 'Add USER <non-root-user> instruction (e.g., USER node)')];\n   128→  }\n   129→  const hasNonRoot = userLines.some(l => {\n   130→    const user = l.replace(/^\\s*USER\\s+/i, '').trim().split(/\\s+/)[0];\n   131→    return user.toLowerCase() !== 'root';\n   132→  });\n   133→  if (!hasNonRoot) {\n   134→    return [dfGap('non-root-user', 'no non-root USER instruction found.', 'Add USER <non-root-user> instruction (e.g., USER node)')];\n   135→  }\n   136→  return [];\n   137→}\n   138→\n   139→function checkCacheCleanup(lines: string[]): DockerfileGap[] {\n   140→  const content = lines.join('\\n');\n   141→  const hasCleanup =\n   142→    /rm\\s+-rf\\s+\\/var\\/lib\\/apt\\/lists/i.test(content) ||\n   143→    /npm\\s+cache\\s+clean/i.test(content) ||\n   144→    /pip\\s+cache\\s+purge/i.test(content);\n   145→  if (!hasCleanup) {\n   146→    return [dfGap('cache-cleanup', 'no cache cleanup detected.', 'Add cache cleanup: rm -rf /var/lib/apt/lists/*, npm cache clean --force, or pip cache purge')];\n   147→  }\n   148→  return [];\n   149→}\n   150→\n   151→// ─── Main validator ─────────────────────────────────────────────────────────\n   152→\n   153→/**\n   154→ * Validate a Dockerfile against all 6 rule categories.\n   155→ * Returns Result<DockerfileValidationResult>.\n   156→ */\n   157→export function validateDockerfile(projectDir: string): Result<DockerfileValidationResult> {\n   158→  const dfPath = join(projectDir, 'Dockerfile');\n   159→\n   160→  if (!existsSync(dfPath)) {\n   161→    return fail('No Dockerfile found');\n   162→  }\n   163→\n   164→  let content: string;\n   165→  try {\n   166→    content = readFileSync(dfPath, 'utf-8');\n   167→  } catch {\n   168→    return fail('Dockerfile exists but could not be read');\n   169→  }\n   170→\n   171→  const lines = content.split('\\n');\n   172→  const fromLines = lines.filter(l => /^\\s*FROM\\s+/i.test(l));\n   173→  if (fromLines.length === 0) {\n   174→    return fail('Dockerfile has no FROM instruction');\n   175→  }\n   176→\n   177→  const { rules, warnings } = loadRules(projectDir);\n   178→  const gaps: DockerfileGap[] = [];\n   179→\n   180→  if (rules.requirePinnedFrom) gaps.push(...checkPinnedFrom(lines));\n   181→  if (rules.requireBinaryOnPath) gaps.push(...checkBinaryOnPath(lines));\n   182→  gaps.push(...checkVerificationTools(lines, rules.verificationTools));\n   183→  if (rules.forbidSourceCopy) gaps.push(...checkNoSourceCopy(lines));\n   184→  if (rules.requireNonRootUser) gaps.push(...checkNonRootUser(lines));\n   185→  if (rules.requireCacheCleanup) gaps.push(...checkCacheCleanup(lines));\n   186→\n   187→  return ok({\n   188→    passed: gaps.length === 0,\n   189→    gaps,\n   190→    warnings,\n   191→  });\n   192→}\n   193→"}]},"parent_tool_use_id":"toolu_014ezVhMDXjVxVyuX7sSNNfJ","session_id":"77451c69-f489-4aef-ba6d-37b512cc36ec","uuid":"49882b70-cd70-4a04-bf74-d47b9cbf6e4f","timestamp":"2026-03-21T05:18:52.827Z"}
