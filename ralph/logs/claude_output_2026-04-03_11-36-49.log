     dispatchCount++;\n1429\t        if (prompt.includes('Execute task')) {\n1430\t          // Return the same fail verdict every time → stagnation (passed=1 each iteration)\n1431\t          return { sessionId: 'sess-v', success: true, durationMs: 100, output: makeFailVerdict() };\n1432\t        }\n1433\t        return { sessionId: 'sess-r', success: true, durationMs: 100, output: 'ok' };\n1434\t      },\n1435\t    );\n1436\t\n1437\t    // Track the state written by the engine to verify circuit breaker fields\n1438\t    let lastWrittenState: WorkflowState | null = null;\n1439\t    mockWriteWorkflowState.mockImplementation((state: WorkflowState) => {\n1440\t      lastWrittenState = state;\n1441\t    });\n1442\t\n1443\t    mockParse.mockReturnValue({\n1444\t      development_status: { '3-1-foo': 'ready-for-dev' },\n1445\t    });\n1446\t\n1447\t    const config = makeConfig({\n1448\t      workflow: {\n1449\t        tasks: {\n1450\t          retry: makeTask({ scope: 'per-story' }),\n1451\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n1452\t        },\n1453\t        flow: [{ loop: ['retry', 'verify'] }],\n1454\t      },\n1455\t    });\n1456\t\n1457\t    const result = await executeWorkflow(config);\n1458\t\n1459\t    expect(result.success).toBe(false);\n1460\t    // Two full iterations: iter1 (retry+verify), iter2 (retry+verify) → circuit breaker triggers\n1461\t    expect(dispatchCount).toBe(4);\n1462\t\n1463\t    // Verify circuit breaker was set via evaluateProgress, not mock mutation\n1464\t    expect(lastWrittenState).not.toBeNull();\n1465\t    expect(lastWrittenState!.circuit_breaker.triggered).toBe(true);\n1466\t    expect(lastWrittenState!.circuit_breaker.reason).toBe('score-stagnation');\n1467\t    expect(lastWrittenState!.circuit_breaker.score_history).toEqual([1, 1]);\n1468\t    expect(lastWrittenState!.phase).toBe('circuit-breaker');\n1469\t  });\n1470\t\n1471\t  it('injects findings into retry prompt for failed stories (AC #5)', async () => {\n1472\t    const dispatches: string[] = [];\n1473\t    let callCount = 0;\n1474\t\n1475\t    mockDispatchAgent.mockImplementation(\n1476\t      async (_def: SubagentDefinition, prompt: string) => {\n1477\t        callCount++;\n1478\t        dispatches.push(prompt);\n1479\t\n1480\t        if (prompt.includes('Execute task')) {\n1481\t          // First verify: fail, second verify: pass\n1482\t          if (callCount <= 2) {\n1483\t            return { sessionId: 'sess-v', success: true, durationMs: 100, output: makeFailVerdict() };\n1484\t          }\n1485\t          return { sessionId: 'sess-v', success: true, durationMs: 100, output: makePassVerdict() };\n1486\t        }\n1487\t        return { sessionId: 'sess-r', success: true, durationMs: 100, output: 'ok' };\n1488\t      },\n1489\t    );\n1490\t\n1491\t    mockParse.mockReturnValue({\n1492\t      development_status: { '3-1-foo': 'ready-for-dev' },\n1493\t    });\n1494\t\n1495\t    const config = makeConfig({\n1496\t      workflow: {\n1497\t        tasks: {\n1498\t          retry: makeTask({ scope: 'per-story' }),\n1499\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n1500\t        },\n1501\t        flow: [{ loop: ['retry', 'verify'] }],\n1502\t      },\n1503\t    });\n1504\t\n1505\t    await executeWorkflow(config);\n1506\t\n1507\t    // Second retry prompt (iteration 2) should contain findings\n1508\t    const secondRetryPrompt = dispatches[2]; // [0]=retry, [1]=verify, [2]=retry(with findings)\n1509\t    expect(secondRetryPrompt).toContain('Retry story 3-1-foo');\n1510\t    expect(secondRetryPrompt).toContain('AC #1 (FAIL)');\n1511\t    expect(secondRetryPrompt).toContain('Test suite failed');\n1512\t  });\n1513\t\n1514\t  it('parses verdict from DispatchResult.output (AC #6)', async () => {\n1515\t    mockDispatchAgent.mockImplementation(\n1516\t      async (_def: SubagentDefinition, prompt: string) => {\n1517\t        if (prompt.includes('Execute task')) {\n1518\t      