expect(result.success).toBe(true);\n   425→    if (result.success) {\n   426→      expect(result.data.status).toBe('warn');\n   427→    }\n   428→  });\n   429→\n   430→  it('returns warn when scanDocHealth throws', () => {\n   431→    mockScanDocHealth.mockImplementation(() => {\n   432→      throw new Error('scan error');\n   433→    });\n   434→\n   435→    const result = checkDocumentation('/project');\n   436→    expect(result.success).toBe(true);\n   437→    if (result.success) {\n   438→      expect(result.data.status).toBe('warn');\n   439→    }\n   440→  });\n   441→});\n   442→\n   443→// ─── checkVerification ──────────────────────────────────────────────────────\n   444→\n   445→describe('checkVerification', () => {\n   446→  it('returns warn when no sprint-status.yaml', () => {\n   447→    mockExistsSync.mockReturnValue(false);\n   448→\n   449→    const result = checkVerification('/project');\n   450→    expect(result.success).toBe(true);\n   451→    if (result.success) {\n   452→      expect(result.data.status).toBe('warn');\n   453→      expect(result.data.metric).toBe('no sprint data');\n   454→    }\n   455→  });\n   456→\n   457→  it('returns pass with all proofs passing', () => {\n   458→    mockExistsSync.mockImplementation((p: unknown) => {\n   459→      const path = String(p);\n   460→      if (path.includes('sprint-status.yaml')) return true;\n   461→      if (path.includes('verification')) return true;\n   462→      return false;\n   463→    });\n   464→    mockReaddirSync.mockReturnValue(['1-1-story-proof.md'] as unknown as ReturnType<typeof readdirSync>);\n   465→    mockParseProof.mockReturnValue({\n   466→      success: true,\n   467→      data: { verified: 3, pending: 0, escalated: 0, total: 3, passed: true, grepSrcCount: 0, dockerExecCount: 0, observabilityQueryCount: 0 },\n   468→    });\n   469→\n   470→    const result = checkVerification('/project');\n   471→    expect(result.success).toBe(true);\n   472→    if (result.success) {\n