{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EuvEKwppbRMfwgmCubyFoB","type":"tool_result","content":"1\t/**\n2\t * Epic Completion Detection.\n3\t *\n4\t * Pure logic module that detects when all stories in an epic reach\n5\t * \"done\" status and provides a state machine for epic lifecycle\n6\t * transitions: in-progress → completing → merging → validating → done.\n7\t *\n8\t * @see Story 19-1: Epic Completion Detection\n9\t */\n10\t\n11\timport type { SprintState } from '../types/state.js';\n12\t\n13\t// --- Types ---\n14\t\n15\t/**\n16\t * All possible epic lifecycle statuses.\n17\t * Narrows the broad `string` type from EpicState.status.\n18\t */\n19\texport type EpicLifecycleStatus =\n20\t  | 'in-progress'\n21\t  | 'completing'\n22\t  | 'merging'\n23\t  | 'validating'\n24\t  | 'done'\n25\t  | 'failed';\n26\t\n27\t// --- Error ---\n28\t\n29\t/**\n30\t * Error thrown for invalid epic operations:\n31\t * - Epic not found in state\n32\t * - Invalid state transition\n33\t */\n34\texport class EpicCompletionError extends Error {\n35\t  constructor(message: string) {\n36\t    super(message);\n37\t    this.name = 'EpicCompletionError';\n38\t  }\n39\t}\n40\t\n41\t// --- State Machine ---\n42\t\n43\t/**\n44\t * Valid epic state transitions.\n45\t *\n46\t * Happy path: in-progress → completing → merging → validating → done\n47\t * Failure:    completing|merging|validating → failed\n48\t *\n49\t * Terminal statuses (done, failed) have no outgoing transitions.\n50\t */\n51\ttype TransitionableStatus = Exclude<EpicLifecycleStatus, 'done' | 'failed'>;\n52\t\n53\texport const VALID_TRANSITIONS: Record<TransitionableStatus, EpicLifecycleStatus[]> = {\n54\t  'in-progress': ['completing'],\n55\t  'completing': ['merging', 'failed'],\n56\t  'merging': ['validating', 'failed'],\n57\t  'validating': ['done', 'failed'],\n58\t};\n59\t\n60\t// --- Functions ---\n61\t\n62\t/**\n63\t * Get all story keys belonging to a given epic.\n64\t *\n65\t * Stories are matched by the numeric prefix before the first dash.\n66\t * E.g., epicId \"19\" matches \"19-1-foo\" and \"19-2-bar\" but not \"1-9-baz\".\n67\t */\n68\texport function getEpicStories(state: SprintState, epicId: string): string[] {\n69\t  return Object.keys(state.stories).filter((key) => {\n70\t    const dash = key.indexOf('-');\n71\t    if (dash === -1) return false;\n72\t    return key.slice(0, dash) === epicId;\n73\t  }).sort();\n74\t}\n75\t\n76\t/**\n77\t * Check whether all stories in an epic have status \"done\".\n78\t *\n79\t * Returns false for epics with zero stories (never considered complete).\n80\t * Throws EpicCompletionError if the epic does not exist in state.\n81\t */\n82\texport function checkEpicCompletion(state: SprintState, epicId: string): boolean {\n83\t  if (!state.epics[`epic-${epicId}`]) {\n84\t    throw new EpicCompletionError(`Epic epic-${epicId} not found in state`);\n85\t  }\n86\t  const stories = getEpicStories(state, epicId);\n87\t  if (stories.length === 0) return false;\n88\t  return stories.every((key) => state.stories[key]?.status === 'done');\n89\t}\n90\t\n91\t/**\n92\t * Transition an epic to a new lifecycle status (immutable).\n93\t *\n94\t * Validates that:\n95\t * 1. The epic exists in state\n96\t * 2. The transition is allowed by the state machine\n97\t *\n98\t * When transitioning to \"completing\", updates storiesDone to the\n99\t * count of stories with status \"done\".\n100\t *\n101\t * Returns a new SprintState — does not mutate the input.\n102\t */\n103\texport function transitionEpicState(\n104\t  state: SprintState,\n105\t  epicId: string,\n106\t  targetStatus: EpicLifecycleStatus,\n107\t): SprintState {\n108\t  const epicKey = `epic-${epicId}`;\n109\t  const epic = state.epics[epicKey];\n110\t  if (!epic) throw new EpicCompletionError(`Epic ${epicKey} not found in state`);\n111\t\n112\t  const currentStatus = epic.status as EpicLifecycleStatus;\n113\t  const allowed = VALID_TRANSITIONS[currentStatus as TransitionableStatus];\n114\t  if (!allowed?.includes(targetStatus)) {\n115\t    throw new EpicCompletionError(\n116\t      `Invalid transition: ${currentStatus} → ${targetStatus}`,\n117\t    );\n118\t  }\n119\t\n120\t  const storiesDone = targetStatus === 'completing'\n121\t    ? getEpicStories(state, epicId).filter((k) => state.stories[k]?.status === 'done').length\n122\t    : epic.storiesDone;\n123\t\n124\t  return {\n125\t    ...state,\n126\t    epics: {\n127\t      ...state.epics,\n128\t      [epicKey]: { ...epic, status: targetStatus, storiesDone },\n129\t    },\n130\t  };\n131\t}\n132\t"}]},"parent_tool_use_id":"toolu_016EMr5poT3LRabJonL53yHn","session_id":"d383a9e0-3bc4-4a94-aaff-6965a5cc223b","uuid":"78453b14-c375-407c-ace5-8f7c55162572","timestamp":"2026-04-03T23:14:20.538Z"}
