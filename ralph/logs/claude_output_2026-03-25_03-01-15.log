{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016iZtS3kHp5cN9pKKiS7VYe","type":"tool_result","content":"     1→/**\n     2→ * Status formatters — human-readable and JSON formatting for status output.\n     3→ * Handles the full status display, docker check, and health check formatting.\n     4→ */\n     5→\n     6→import { ok, fail, info, jsonOutput } from '../../lib/output.js';\n     7→import { readState, StateFileNotFoundError } from '../../lib/state.js';\n     8→import { getStackHealth, getCollectorHealth, checkRemoteEndpoint } from '../../lib/docker/index.js';\n     9→import { listIssues, isBeadsInitialized } from '../../lib/beads.js';\n    10→import { getOnboardingProgress } from '../../lib/onboard-checks.js';\n    11→import { getStackDir, getComposeFilePath } from '../../lib/stack-path.js';\n    12→import { generateReport } from '../sprint/index.js';\n    13→import { getValidationProgress } from '../verify/index.js';\n    14→import { DEFAULT_ENDPOINTS, buildScopedEndpoints, resolveEndpoints } from './endpoints.js';\n    15→import type { HarnessState } from '../../lib/state.js';\n    16→import type { StatusReport } from '../sprint/index.js';\n    17→\n    18→// ─── Full Status Display ────────────────────────────────────────────────────\n    19→\n    20→export function handleFullStatus(isJson: boolean): void {\n    21→  let state: HarnessState;\n    22→  try {\n    23→    state = readState();\n    24→  } catch (err) {\n    25→    if (err instanceof StateFileNotFoundError) {\n    26→      if (isJson) {\n    27→        jsonOutput({ status: 'fail', message: \"Harness not initialized. Run 'codeharness init' first.\" });\n    28→      } else {\n    29→        fail(\"Harness not initialized. Run 'codeharness init' first.\");\n    30→      }\n    31→      process.exitCode = 1;\n    32→      return;\n    33→    }\n    34→    throw err;\n    35→  }\n    36→\n    37→  if (isJson) {\n    38→    handleFullStatusJson(state);\n    39→    return;\n    40→  }\n    41→\n    42→  // Sprint state sections (Project State, Run, Action Items)\n    43→  printSprintState();\n    44→\n    45→  // Validation progress (if validation stories exist)\n    46→  printValidationProgress();\n    47→\n    48→  // Version & Stack\n    49→  console.log(`Harness: codeharness v${state.harness_version}`);\n    50→  console.log(`Stack: ${state.stack ?? 'unknown'}`);\n    51→  if (state.app_type) {\n    52→    console.log(`App type: ${state.app_type}`);\n    53→    if (state.app_type === 'agent' && state.otlp?.agent_sdk) {\n    54→      console.log(`Agent SDK: ${state.otlp.agent_sdk}`);\n    55→    }\n    56→  }\n    57→\n    58→  // Enforcement\n    59→  const e = state.enforcement;\n    60→  console.log(\n    61→    `Enforcement: front:${e.frontend ? 'ON' : 'OFF'} db:${e.database ? 'ON' : 'OFF'} api:${e.api ? 'ON' : 'OFF'} obs:ON`,\n    62→  );\n    63→\n    64→  // Docker (always shown — observability is mandatory unless backend is 'none')\n    65→  {\n    66→    const backend = state.otlp?.backend ?? 'victoria';\n    67→    const mode = state.otlp?.mode ?? 'local-shared';\n    68→\n    69→    if (backend === 'none') {\n    70→      console.log('Docker: disabled (observability off)');\n    71→    } else if (mode === 'remote-direct') {\n    72→      const endpoint = state.otlp?.endpoint ?? 'unknown';\n    73→      console.log(`Docker: none (remote OTLP at ${endpoint})`);\n    74→    } else if (mode === 'remote-routed') {\n    75→      const re = state.docker?.remote_endpoints;\n    76→      console.log(`Docker: OTel Collector only (backends at ${re?.logs_url ?? 'unknown'}, ${re?.metrics_url ?? 'unknown'}, ${re?.traces_url ?? 'unknown'})`);\n    77→      const sharedComposeFile = getComposeFilePath();\n    78→      const health = getCollectorHealth(sharedComposeFile);\n    79→      for (const svc of health.services) {\n    80→        console.log(`  ${svc.name}: ${svc.running ? 'running' : 'stopped'}`);\n    81→      }\n    82→    } else {\n    83→      const composeFile = state.docker?.compose_file ?? 'docker-compose.harness.yml';\n    84→      const stackDir = getStackDir();\n    85→      const isShared = composeFile.startsWith(stackDir);\n    86→\n    87→      const resolvedComposeFile = isShared ? getComposeFilePath() : composeFile;\n    88→      const projectName = isShared ? 'codeharness-shared' : undefined;\n    89→      const header = isShared ? 'Docker: shared stack at ~/.codeharness/stack/' : 'Docker:';\n    90→\n    91→      console.log(header);\n    92→      const health = getStackHealth(resolvedComposeFile, projectName);\n    93→      for (const svc of health.services) {\n    94→        console.log(`  ${svc.name}: ${svc.running ? 'running' : 'stopped'}`);\n    95→      }\n    96→      if (health.healthy) {\n    97→        console.log(\n    98→          `  Endpoints: logs=${DEFAULT_ENDPOINTS.logs} metrics=${DEFAULT_ENDPOINTS.metrics} traces=${DEFAULT_ENDPOINTS.traces}`,\n    99→        );\n   100→      }\n   101→    }\n   102→  }\n   103→\n   104→  // Service-scoped endpoints\n   105→  const serviceName = state.otlp?.service_name;\n   106→  if (serviceName) {\n   107→    const endpoints = resolveEndpoints(state);\n   108→    const scoped = buildScopedEndpoints(endpoints, serviceName);\n   109→    console.log(`  Scoped: logs=${scoped.logs} metrics=${scoped.metrics} traces=${scoped.traces}`);\n   110→  }\n   111→\n   112→  // Beads\n   113→  printBeadsSummary();\n   114→\n   115→  // Onboarding progress\n   116→  printOnboardingProgress();\n   117→\n   118→  // Session flags\n   119→  const sf = state.session_flags;\n   120→  console.log(\n   121→    `Session: tests_passed=${sf.tests_passed} coverage_met=${sf.coverage_met} verification_run=${sf.verification_run} logs_queried=${sf.logs_queried}`,\n   122→  );\n   123→\n   124→  // Coverage\n   125→  const currentCov = state.coverage.current !== null ? `${state.coverage.current}%` : '\\u2014';\n   126→  console.log(`Coverage: ${currentCov} / ${state.coverage.target}% target`);\n   127→\n   128→  // Verification log\n   129→  if (state.verification_log.length === 0) {\n   130→    console.log('Verification: no entries');\n   131→  } else {\n   132→    console.log('Verification log:');\n   133→    for (const entry of state.verification_log) {\n   134→      console.log(`  ${entry}`);\n   135→    }\n   136→  }\n   137→}\n   138→\n   139→function handleFullStatusJson(state: HarnessState): void {\n   140→  // Docker (always present — observability is mandatory unless backend is 'none')\n   141→  let docker: Record<string, unknown>;\n   142→  {\n   143→    const backend = state.otlp?.backend ?? 'victoria';\n   144→    const mode = state.otlp?.mode ?? 'local-shared';\n   145→\n   146→    if (backend === 'none') {\n   147→      docker = { mode: 'none', message: 'Observability disabled' };\n   148→    } else if (mode === 'remote-direct') {\n   149→      docker = {\n   150→        mode: 'remote-direct',\n   151→        endpoint: state.otlp?.endpoint,\n   152→      };\n   153→    } else if (mode === 'remote-routed') {\n   154→      const sharedComposeFile = getComposeFilePath();\n   155→      const health = getCollectorHealth(sharedComposeFile);\n   156→      docker = {\n   157→        mode: 'remote-routed',\n   158→        healthy: health.healthy,\n   159→        services: health.services,\n   160→        remote_endpoints: state.docker?.remote_endpoints,\n   161→      };\n   162→    } else {\n   163→      const composeFile = state.docker?.compose_file ?? 'docker-compose.harness.yml';\n   164→      const stackDir = getStackDir();\n   165→      const isShared = composeFile.startsWith(stackDir);\n   166→\n   167→      if (isShared) {\n   168→        const sharedComposeFile = getComposeFilePath();\n   169→        const health = getStackHealth(sharedComposeFile, 'codeharness-shared');\n   170→        docker = {\n   171→          shared: true,\n   172→          stack_dir: '~/.codeharness/stack/',\n   173→          healthy: health.healthy,\n   174→          services: health.services,\n   175→          ...(health.healthy ? { endpoints: DEFAULT_ENDPOINTS } : {}),\n   176→        };\n   177→      } else {\n   178→        const health = getStackHealth(composeFile);\n   179→        docker = {\n   180→          healthy: health.healthy,\n   181→          services: health.services,\n   182→          ...(health.healthy ? { endpoints: DEFAULT_ENDPOINTS } : {}),\n   183→        };\n   184→      }\n   185→    }\n   186→  }\n   187→\n   188→  // Resolved endpoints\n   189→  const endpoints = resolveEndpoints(state);\n   190→\n   191→  // Scoped endpoints\n   192→  const serviceName = state.otlp?.service_name;\n   193→  const scoped_endpoints = serviceName ? buildScopedEndpoints(endpoints, serviceName) : undefined;\n   194→\n   195→  // Beads\n   196→  const beads = getBeadsData();\n   197→\n   198→  // Onboarding progress\n   199→  const onboarding = getOnboardingProgressData();\n   200→\n   201→  // Sprint state\n   202→  const sprint = getSprintReportData();\n   203→\n   204→  // Validation progress\n   205→  const validationResult = getValidationProgress();\n   206→  const validation = validationResult.success && validationResult.data.total > 0\n   207→    ? validationResult.data : undefined;\n   208→\n   209→  jsonOutput({\n   210→    version: state.harness_version,\n   211→    stack: state.stack,\n   212→    ...(state.app_type ? { app_type: state.app_type } : {}),\n   213→    ...(sprint ? { sprint } : {}),\n   214→    ...(validation ? { validation } : {}),\n   215→    enforcement: state.enforcement,\n   216→    docker,\n   217→    endpoints,\n   218→    ...(scoped_endpoints ? { scoped_endpoints } : {}),\n   219→    beads,\n   220→    ...(onboarding ? { onboarding } : {}),\n   221→    session_flags: state.session_flags,\n   222→    coverage: state.coverage,\n   223→    verification_log: state.verification_log,\n   224→  });\n   225→}\n   226→\n   227→// ─── Health Check Mode ──────────────────────────────────────────────────────\n   228→\n   229→export async function handleHealthCheck(isJson: boolean): Promise<void> {\n   230→  const checks: { name: string; status: 'ok' | 'fail'; detail: string }[] = [];\n   231→\n   232→  // 1. State file integrity\n   233→  let state: HarnessState | null = null;\n   234→  try {\n   235→    state = readState();\n   236→    checks.push({ name: 'state_file', status: 'ok', detail: 'valid' });\n   237→  } catch {\n   238→    checks.push({ name: 'state_file', status: 'fail', detail: 'not found' });\n   239→  }\n   240→\n   241→  // 2. Docker health (always checked — observability is mandatory unless backend is 'none')\n   242→  if (state) {\n   243→    const backend = state.otlp?.backend ?? 'victoria';\n   244→    const mode = state.otlp?.mode ?? 'local-shared';\n   245→\n   246→    if (backend === 'none') {\n   247→      checks.push({ name: 'docker', status: 'ok', detail: 'observability disabled — skipped' });\n   248→    } else if (mode === 'remote-direct') {\n   249→      const endpoint = state.otlp?.endpoint ?? '';\n   250→      const result = await checkRemoteEndpoint(endpoint);\n   251→      checks.push({\n   252→        name: 'docker',\n   253→        status: result.reachable ? 'ok' : 'fail',\n   254→        detail: result.reachable ? `remote OTLP reachable (${endpoint})` : `remote OTLP unreachable (${result.error ?? 'unknown'})`,\n   255→      });\n   256→    } else if (mode === 'remote-routed') {\n   257→      const sharedComposeFile = getComposeFilePath();\n   258→      const health = getCollectorHealth(sharedComposeFile);\n   259→      checks.push({\n   260→        name: 'docker',\n   261→        status: health.healthy ? 'ok' : 'fail',\n   262→        detail: health.healthy ? 'OTel Collector running' : (health.remedy ?? 'collector down'),\n   263→      });\n   264→\n   265→      // Check remote endpoints\n   266→      const re = state.docker?.remote_endpoints;\n   267→      if (re) {\n   268→        for (const [label, url] of [['logs', re.logs_url], ['metrics', re.metrics_url], ['traces', re.traces_url]] as const) {\n   269→          if (url) {\n   270→            const result = await checkRemoteEndpoint(url);\n   271→            checks.push({\n   272→              name: `remote_${label}`,\n   273→              status: result.reachable ? 'ok' : 'fail',\n   274→              detail: result.reachable ? `reachable (${url})` : `unreachable (${result.error ?? 'unknown'})`,\n   275→            });\n   276→          }\n   277→        }\n   278→      }\n   279→    } else {\n   280→      const composeFile = state.docker?.compose_file ?? 'docker-compose.harness.yml';\n   281→      const sDir = getStackDir();\n   282→      const isShared = composeFile.startsWith(sDir);\n   283→      const healthComposeFile = isShared ? getComposeFilePath() : composeFile;\n   284→      const healthProjectName = isShared ? 'codeharness-shared' : undefined;\n   285→      const health = getStackHealth(healthComposeFile, healthProjectName);\n   286→      checks.push({\n   287→        name: 'docker',\n   288→        status: health.healthy ? 'ok' : 'fail',\n   289→        detail: health.healthy ? 'all services running' : (health.remedy ?? 'services down'),\n   290→      });\n   291→    }\n   292→  } else {\n   293→    checks.push({ name: 'docker', status: 'fail', detail: 'cannot check (no state)' });\n   294→  }\n   295→\n   296→  // 3. Beads availability\n   297→  try {\n   298→    if (isBeadsInitialized()) {\n   299→      listIssues();\n   300→      checks.push({ name: 'beads', status: 'ok', detail: 'available' });\n   301→    } else {\n   302→      checks.push({ name: 'beads', status: 'fail', detail: 'not initialized' });\n   303→    }\n   304→  } catch {\n   305→    checks.push({ name: 'beads', status: 'fail', detail: 'bd command failed' });\n   306→  }\n   307→\n   308→  const allPassed = checks.every(c => c.status === 'ok');\n   309→\n   310→  if (isJson) {\n   311→    const checksObj: Record<string, { status: string; detail: string }> = {};\n   312→    for (const c of checks) {\n   313→      checksObj[c.name] = { status: c.status, detail: c.detail };\n   314→    }\n   315→    jsonOutput({ status: allPassed ? 'ok' : 'fail', checks: checksObj });\n   316→  } else {\n   317→    for (const c of checks) {\n   318→      const prefix = c.status === 'ok' ? '[OK]' : '[FAIL]';\n   319→      const label = c.name.replace(/_/g, ' ');\n   320→      console.log(`${prefix} ${label[0].toUpperCase() + label.slice(1)}: ${c.detail}`);\n   321→    }\n   322→  }\n   323→\n   324→  process.exitCode = allPassed ? 0 : 1;\n   325→}\n   326→\n   327→// ─── Docker Check ───────────────────────────────────────────────────────────\n   328→\n   329→export async function handleDockerCheck(isJson: boolean): Promise<void> {\n   330→  let state: HarnessState | null = null;\n   331→  try {\n   332→    state = readState();\n   333→  } catch {\n   334→    // No state file or corrupted\n   335→  }\n   336→\n   337→  const backend = state?.otlp?.backend ?? 'victoria';\n   338→\n   339→  if (backend === 'none') {\n   340→    if (isJson) {\n   341→      jsonOutput({ status: 'ok', mode: 'none', message: 'Observability disabled — no Docker check needed' });\n   342→    } else {\n   343→      info('[INFO] Observability disabled — no Docker check needed');\n   344→    }\n   345→    return;\n   346→  }\n   347→\n   348→  const mode = state?.otlp?.mode ?? 'local-shared';\n   349→\n   350→  if (mode === 'remote-direct') {\n   351→    const endpoint = state?.otlp?.endpoint ?? '';\n   352→    const result = await checkRemoteEndpoint(endpoint);\n   353→    if (isJson) {\n   354→      jsonOutput({\n   355→        status: result.reachable ? 'ok' : 'fail',\n   356→        mode: 'remote-direct',\n   357→        endpoint,\n   358→        reachable: result.reachable,\n   359→        ...(result.error ? { error: result.error } : {}),\n   360→      });\n   361→    } else {\n   362→      if (result.reachable) {\n   363→        ok(`Remote OTLP endpoint: reachable (${endpoint})`);\n   364→      } else {\n   365→        fail(`Remote OTLP endpoint: unreachable (${endpoint})`);\n   366→        if (result.error) {\n   367→          info(`Error: ${result.error}`);\n   368→        }\n   369→      }\n   370→    }\n   371→    return;\n   372→  }\n   373→\n   374→  if (mode === 'remote-routed') {\n   375→    const sharedComposeFile = getComposeFilePath();\n   376→    const health = getCollectorHealth(sharedComposeFile);\n   377→\n   378→    if (isJson) {\n   379→      jsonOutput({\n   380→        status: health.healthy ? 'ok' : 'fail',\n   381→        mode: 'remote-routed',\n   382→        docker: {\n   383→          healthy: health.healthy,\n   384→          services: health.services,\n   385→          remedy: health.remedy,\n   386→        },\n   387→        remote_endpoints: state?.docker?.remote_endpoints,\n   388→      });\n   389→    } else {\n   390→      if (health.healthy) {\n   391→        ok('OTel Collector: running');\n   392→      } else {\n   393→        fail('OTel Collector: not running');\n   394→        if (health.remedy) {\n   395→          info(`-> ${health.remedy}`);\n   396→        }\n   397→      }\n   398→      const re = state?.docker?.remote_endpoints;\n   399→      if (re) {\n   400→        info(`Remote backends: logs=${re.logs_url} metrics=${re.metrics_url} traces=${re.traces_url}`);\n   401→      }\n   402→    }\n   403→    return;\n   404→  }\n   405→\n   406→  // local-shared mode (default)\n   407→  let composeFile = 'docker-compose.harness.yml';\n   408→  let projectName: string | undefined;\n   409→\n   410→  if (state?.docker?.compose_file) {\n   411→    composeFile = state.docker.compose_file;\n   412→  }\n   413→\n   414→  const stackDir = getStackDir();\n   415→  if (composeFile.startsWith(stackDir)) {\n   416→    composeFile = getComposeFilePath();\n   417→    projectName = 'codeharness-shared';\n   418→  }\n   419→\n   420→  const health = getStackHealth(composeFile, projectName);\n   421→\n   422→  if (isJson) {\n   423→    jsonOutput({\n   424→      status: health.healthy ? 'ok' : 'fail',\n   425→      backend,\n   426→      ...(projectName ? { project_name: projectName } : {}),\n   427→      docker: {\n   428→        healthy: health.healthy,\n   429→        services: health.services,\n   430→        remedy: health.remedy,\n   431→      },\n   432→      ...(health.healthy ? { endpoints: DEFAULT_ENDPOINTS } : {}),\n   433→    });\n   434→    return;\n   435→  }\n   436→\n   437→  const stackLabel = backend === 'elk' ? 'OpenSearch/ELK stack' : 'VictoriaMetrics stack';\n   438→\n   439→  if (health.healthy) {\n   440→    ok(`${stackLabel}: running${projectName ? ` (project: ${projectName})` : ''}`);\n   441→    for (const svc of health.services) {\n   442→      info(`  ${svc.name}: ${svc.running ? 'running' : 'stopped'}`);\n   443→    }\n   444→    info(`Endpoints: logs=${DEFAULT_ENDPOINTS.logs} metrics=${DEFAULT_ENDPOINTS.metrics} traces=${DEFAULT_ENDPOINTS.traces}`);\n   445→  } else {\n   446→    fail(`${stackLabel}: not running${projectName ? ` (project: ${projectName})` : ''}`);\n   447→    for (const svc of health.services) {\n   448→      if (!svc.running) {\n   449→        info(`  ${svc.name}: down`);\n   450→      }\n   451→    }\n   452→    if (health.remedy) {\n   453→      info(`-> ${health.remedy}`);\n   454→    }\n   455→  }\n   456→}\n   457→\n   458→// ─── Sprint State Helpers ────────────────────────────────────────────────────\n   459→\n   460→function printSprintState(): void {\n   461→  const reportResult = generateReport();\n   462→  if (!reportResult.success) {\n   463→    console.log('Sprint state: unavailable');\n   464→    return;\n   465→  }\n   466→\n   467→  const r = reportResult.data;\n   468→  console.log(`\\u2500\\u2500 Project State \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500`);\n   469→  console.log(`Sprint: ${r.done}/${r.total} done (${r.sprintPercent}%) | ${r.epicsDone}/${r.epicsTotal} epics complete`);\n   470→\n   471→  if (r.activeRun) {\n   472→    console.log('');\n   473→    console.log(`\\u2500\\u2500 Active Run \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500`);\n   474→    const currentStory = r.inProgress ?? 'none';\n   475→    console.log(`Status: running (iteration ${r.activeRun.iterations}, ${r.activeRun.duration} elapsed)`);\n   476→    console.log(`Current: ${currentStory}`);\n   477→    console.log(`Budget: $${r.activeRun.cost.toFixed(2)} spent`);\n   478→  } else if (r.lastRun) {\n   479→    console.log('');\n   480→    console.log(`\\u2500\\u2500 Last Run Summary \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500`);\n   481→    console.log(`Duration: ${r.lastRun.duration} | Cost: $${r.lastRun.cost.toFixed(2)} | Iterations: ${r.lastRun.iterations}`);\n   482→    console.log(`Completed:  ${r.lastRun.completed.length} stories${r.lastRun.completed.length > 0 ? ` (${r.lastRun.completed.join(', ')})` : ''}`);\n   483→    if (r.failedDetails.length > 0) {\n   484→      console.log(`Failed:     ${r.failedDetails.length} stor${r.failedDetails.length === 1 ? 'y' : 'ies'}`);\n   485→      for (const fd of r.failedDetails) {\n   486→        const acPart = fd.acNumber !== null ? `AC ${fd.acNumber}` : 'unknown AC';\n   487→        console.log(`  \\u2514 ${fd.key}: ${acPart} \\u2014 ${fd.errorLine} (attempt ${fd.attempts}/${fd.maxAttempts})`);\n   488→      }\n   489→    }\n   490→    if (r.lastRun.blocked.length > 0) {\n   491→      console.log(`Blocked:    ${r.lastRun.blocked.length} stories (retry-exhausted)`);\n   492→    }\n   493→  }\n   494→\n   495→  if (r.actionItemsLabeled.length > 0) {\n   496→    console.log('');\n   497→    console.log(`\\u2500\\u2500 Action Items \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500`);\n   498→    for (const la of r.actionItemsLabeled) {\n   499→      console.log(`  [${la.label}] ${la.item.story}: ${la.item.description}`);\n   500→    }\n   501→  }\n   502→\n   503→  console.log('');\n   504→}\n   505→\n   506→function printValidationProgress(): void {\n   507→  const result = getValidationProgress();\n   508→  if (!result.success) return;\n   509→  const p = result.data;\n   510→  if (p.total === 0) return;\n   511→  console.log(`Validation: ${p.passed}/${p.total} passed, ${p.failed} failed, ${p.blocked} blocked, ${p.remaining} remaining`);\n   512→}\n   513→\n   514→function getSprintReportData(): StatusReport | null {\n   515→  const reportResult = generateReport();\n   516→  if (!reportResult.success) return null;\n   517→  return reportResult.data;\n   518→}\n   519→\n   520→// ─── Beads Helpers ──────────────────────────────────────────────────────────\n   521→\n   522→function printBeadsSummary(): void {\n   523→  if (!isBeadsInitialized()) {\n   524→    console.log('Beads: not initialized');\n   525→    return;\n   526→  }\n   527→\n   528→  try {\n   529→    const issues = listIssues();\n   530→    const byType = new Map<string, number>();\n   531→    const byStatus = new Map<string, number>();\n   532→\n   533→    for (const issue of issues) {\n   534→      byType.set(issue.type, (byType.get(issue.type) ?? 0) + 1);\n   535→      byStatus.set(issue.status, (byStatus.get(issue.status) ?? 0) + 1);\n   536→    }\n   537→\n   538→    const typeParts = Array.from(byType.entries())\n   539→      .map(([t, n]) => `${t}:${n}`)\n   540→      .join(' ');\n   541→    const ready = byStatus.get('ready') ?? 0;\n   542→    const inProgress = byStatus.get('in_progress') ?? 0;\n   543→    const done = byStatus.get('done') ?? 0;\n   544→\n   545→    const typeInfo = typeParts ? ` (${typeParts})` : '';\n   546→    console.log(\n   547→      `Beads: ${issues.length} issues${typeInfo} | ready:${ready} in-progress:${inProgress} done:${done}`,\n   548→    );\n   549→  } catch {\n   550→    console.log('Beads: unavailable (bd command failed)');\n   551→  }\n   552→}\n   553→\n   554→function printOnboardingProgress(): void {\n   555→  const progress = getOnboardingProgress({ listIssues });\n   556→  if (progress) {\n   557→    console.log(`Onboarding: ${progress.resolved}/${progress.total} gaps resolved (${progress.remaining} remaining)`);\n   558→  }\n   559→}\n   560→\n   561→function getOnboardingProgressData(): Record<string, unknown> | null {\n   562→  const progress = getOnboardingProgress({ listIssues });\n   563→  if (!progress) {\n   564→    return null;\n   565→  }\n   566→  return {\n   567→    total: progress.total,\n   568→    resolved: progress.resolved,\n   569→    remaining: progress.remaining,\n   570→  };\n   571→}\n   572→\n   573→function getBeadsData(): Record<string, unknown> {\n   574→  if (!isBeadsInitialized()) {\n   575→    return { initialized: false };\n   576→  }\n   577→\n   578→  try {\n   579→    const issues = listIssues();\n   580→    const issuesByType: Record<string, number> = {};\n   581→    const issuesByStatus: Record<string, number> = {};\n   582→\n   583→    for (const issue of issues) {\n   584→      issuesByType[issue.type] = (issuesByType[issue.type] ?? 0) + 1;\n   585→      issuesByStatus[issue.status] = (issuesByStatus[issue.status] ?? 0) + 1;\n   586→    }\n   587→\n   588→    return {\n   589→      initialized: true,\n   590→      total: issues.length,\n   591→      issues_by_type: issuesByType,\n   592→      issues_by_status: issuesByStatus,\n   593→    };\n   594→  } catch {\n   595→    return { initialized: true, error: 'bd command failed' };\n   596→  }\n   597→}\n   598→"}]},"parent_tool_use_id":"toolu_013rWcam9ZLGWy8y97T6yhWS","session_id":"790cd04c-5c91-45bb-998d-78a56b65af9a","uuid":"058d48cd-97b7-4d16-b047-9bbb2cc93a62","timestamp":"2026-03-24T23:17:07.530Z"}
