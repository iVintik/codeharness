{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018nqsWdPSAnYobVCGv3ifaN","type":"tool_result","content":"     1→/**\n     2→ * Audit report formatters — human-readable and JSON output.\n     3→ *\n     4→ * Human format uses UX prefix format: [OK], [FAIL], [WARN].\n     5→ * JSON format returns structured AuditResult shape.\n     6→ */\n     7→\n     8→import type { AuditResult, DimensionResult } from './types.js';\n     9→\n    10→// ─── Status to prefix mapping ────────────────────────────────────────────────\n    11→\n    12→const STATUS_PREFIX: Record<string, string> = {\n    13→  pass: '[OK]',\n    14→  fail: '[FAIL]',\n    15→  warn: '[WARN]',\n    16→};\n    17→\n    18→// ─── Human-readable format (Task 4.1) ───────────────────────────────────────\n    19→\n    20→/**\n    21→ * Formats audit result as human-readable output lines.\n    22→ *\n    23→ * Each dimension: `[OK] dimension: metric` or `[FAIL] dimension: metric`\n    24→ * Gaps listed below as: `  [WARN] description -- fix: remedy`\n    25→ */\n    26→export function formatAuditHuman(result: AuditResult): string[] {\n    27→  const lines: string[] = [];\n    28→\n    29→  for (const dimension of Object.values(result.dimensions)) {\n    30→    const prefix = STATUS_PREFIX[dimension.status] ?? '[WARN]';\n    31→    lines.push(`${prefix} ${dimension.name}: ${dimension.metric}`);\n    32→\n    33→    // List gaps with suggested fixes\n    34→    for (const gap of dimension.gaps) {\n    35→      lines.push(`  [WARN] ${gap.description} -- fix: ${gap.suggestedFix}`);\n    36→    }\n    37→  }\n    38→\n    39→  // Summary line\n    40→  const overallPrefix = STATUS_PREFIX[result.overallStatus] ?? '[WARN]';\n    41→  lines.push('');\n    42→  lines.push(\n    43→    `${overallPrefix} Audit complete: ${result.gapCount} gap${result.gapCount !== 1 ? 's' : ''} found (${result.durationMs}ms)`,\n    44→  );\n    45→\n    46→  return lines;\n    47→}\n    48→\n    49→// ─── JSON format (Task 4.2) ─────────────────────────────────────────────────\n    50→\n    51→/**\n    52→ * Returns structured JSON matching the AuditResult shape.\n    53→ * Used for --json output.\n    54→ */\n    55→export function formatAuditJson(result: AuditResult): AuditResult {\n    56→  return result;\n    57→}\n    58→"}]},"parent_tool_use_id":"toolu_01HFX9goKWGsXmLXf2BWi9oC","session_id":"0deb1693-f450-4ee3-ba9f-130c7ba0aec5","uuid":"8f51e788-23e0-4a4b-97b8-642ec3bc7263","timestamp":"2026-03-20T09:16:04.637Z"}
