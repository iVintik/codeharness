{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014kDgKa8FJQ2fahDRPi2cey","type":"tool_result","content":"     1→import { existsSync, readFileSync } from 'node:fs';\n     2→import { join } from 'node:path';\n     3→import { ok, fail as failOut, info, warn } from '../output.js';\n     4→import { readStateWithBody, writeState } from '../state.js';\n     5→import type { CoverageResult, CoverageEvaluation, FileCoverageEntry, PerFileCoverageResult } from './types.js';\n     6→import { findCoverageSummary } from './parser.js';\n     7→\n     8→// ─── Coverage Evaluation and State Updates ───────────────────────────────────\n     9→\n    10→export function evaluateCoverage(result: CoverageResult, dir?: string): CoverageEvaluation {\n    11→  const baseDir = dir ?? process.cwd();\n    12→\n    13→  let target = 90;\n    14→  let baseline: number | null = null;\n    15→\n    16→  try {\n    17→    const { state } = readStateWithBody(baseDir);\n    18→    target = state.coverage.target ?? 90;\n    19→    baseline = state.coverage.baseline;\n    20→  } catch {\n    21→    // No state file — use defaults\n    22→  }\n    23→\n    24→  const actual = result.coveragePercent;\n    25→  const met = actual >= target;\n    26→\n    27→  // If baseline is null (first run), set it to current\n    28→  const effectiveBaseline = baseline ?? actual;\n    29→  const delta = baseline !== null ? actual - baseline : null;\n    30→\n    31→  return {\n    32→    met,\n    33→    target,\n    34→    actual,\n    35→    delta,\n    36→    baseline: effectiveBaseline,\n    37→  };\n    38→}\n    39→\n    40→export function updateCoverageState(\n    41→  result: CoverageResult,\n    42→  evaluation: CoverageEvaluation,\n    43→  dir?: string,\n    44→): void {\n    45→  const baseDir = dir ?? process.cwd();\n    46→  const { state, body } = readStateWithBody(baseDir);\n    47→\n    48→  state.session_flags.tests_passed = result.testsPassed;\n    49→  state.session_flags.coverage_met = evaluation.met;\n    50→  state.coverage.current = evaluation.actual;\n    51→\n    52→  // Set baseline on first run (when it was null)\n    53→  if (state.coverage.baseline === null) {\n    54→    state.coverage.baseline = evaluation.actual;\n    55→  }\n    56→\n    57→  writeState(state, baseDir, body);\n    58→}\n    59→\n    60→// ─── Per-file Coverage Floor Check ───────────────────────────────────────────\n    61→\n    62→/**\n    63→ * Checks per-file coverage against a minimum floor.\n    64→ * Reads coverage-summary.json and returns any files below the threshold.\n    65→ */\n    66→export function checkPerFileCoverage(floor: number, dir?: string): PerFileCoverageResult {\n    67→  const baseDir = dir ?? process.cwd();\n    68→  const reportPath = findCoverageSummary(baseDir);\n    69→\n    70→  if (!reportPath) {\n    71→    return { floor, violations: [], totalFiles: 0 };\n    72→  }\n    73→\n    74→  let report: Record<string, { statements?: { pct?: number }; branches?: { pct?: number }; functions?: { pct?: number }; lines?: { pct?: number } }>;\n    75→  try {\n    76→    report = JSON.parse(readFileSync(reportPath, 'utf-8')) as typeof report;\n    77→  } catch {\n    78→    warn('Failed to parse coverage-summary.json');\n    79→    return { floor, violations: [], totalFiles: 0 };\n    80→  }\n    81→\n    82→  const violations: FileCoverageEntry[] = [];\n    83→  let totalFiles = 0;\n    84→\n    85→  for (const [key, data] of Object.entries(report)) {\n    86→    if (key === 'total') continue;\n    87→    totalFiles++;\n    88→\n    89→    const stmts = data.statements?.pct ?? 0;\n    90→    const branches = data.branches?.pct ?? 0;\n    91→    const funcs = data.functions?.pct ?? 0;\n    92→    const lines = data.lines?.pct ?? 0;\n    93→\n    94→    if (stmts < floor) {\n    95→      // Extract relative path from absolute\n    96→      const relative = key.startsWith(baseDir)\n    97→        ? key.slice(baseDir.length + 1)\n    98→        : key;\n    99→\n   100→      violations.push({\n   101→        file: relative,\n   102→        statements: stmts,\n   103→        branches,\n   104→        functions: funcs,\n   105→        lines,\n   106→      });\n   107→    }\n   108→  }\n   109→\n   110→  // Sort worst first\n   111→  violations.sort((a, b) => a.statements - b.statements);\n   112→\n   113→  return { floor, violations, totalFiles };\n   114→}\n   115→\n   116→// ─── Coverage Output Formatting ──────────────────────────────────────────────\n   117→\n   118→export function formatCoverageOutput(evaluation: CoverageEvaluation): string[] {\n   119→  const lines: string[] = [];\n   120→\n   121→  if (evaluation.met) {\n   122→    lines.push(`[OK] Coverage: ${evaluation.actual}%`);\n   123→  } else {\n   124→    lines.push(`[FAIL] Coverage: ${evaluation.actual}% (target: ${evaluation.target}%)`);\n   125→  }\n   126→\n   127→  if (evaluation.delta !== null && evaluation.baseline !== null) {\n   128→    const sign = evaluation.delta >= 0 ? '+' : '';\n   129→    const before = evaluation.actual - evaluation.delta;\n   130→    lines.push(\n   131→      `[INFO] Coverage delta: ${sign}${evaluation.delta}% (${before}% -> ${evaluation.actual}%)`,\n   132→    );\n   133→  }\n   134→\n   135→  return lines;\n   136→}\n   137→\n   138→export function printCoverageOutput(\n   139→  result: CoverageResult,\n   140→  evaluation: CoverageEvaluation,\n   141→): void {\n   142→  // Print test results\n   143→  if (result.testsPassed) {\n   144→    ok(`Tests passed: ${result.passCount} passed`);\n   145→  } else {\n   146→    failOut(`Tests failed: ${result.passCount} passed, ${result.failCount} failed`);\n   147→  }\n   148→\n   149→  // Print coverage evaluation\n   150→  if (evaluation.met) {\n   151→    ok(`Coverage: ${evaluation.actual}%`);\n   152→  } else {\n   153→    failOut(`Coverage: ${evaluation.actual}% (target: ${evaluation.target}%)`);\n   154→  }\n   155→\n   156→  // Print delta if available\n   157→  if (evaluation.delta !== null && evaluation.baseline !== null) {\n   158→    const sign = evaluation.delta >= 0 ? '+' : '';\n   159→    const before = evaluation.actual - evaluation.delta;\n   160→    info(`Coverage delta: ${sign}${evaluation.delta}% (${before}% -> ${evaluation.actual}%)`);\n   161→  }\n   162→}\n   163→"}]},"parent_tool_use_id":"toolu_01KNQnUKBFtzFzrosUg6K7qd","session_id":"7d2c764f-deb1-4354-ad31-e0a846d19ae3","uuid":"d5d17001-793d-419a-aa5d-f02983921596","timestamp":"2026-03-25T00:18:13.974Z"}
