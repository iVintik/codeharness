{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Svkzp7RiU92YJmzgeXRg85","type":"tool_result","content":"80\t  code: string;\n81\t  message: string;\n82\t}\n83\t\n84\t/**\n85\t * A work item (story or issue) ready for execution.\n86\t */\n87\texport interface WorkItem {\n88\t  key: string;\n89\t  title?: string;\n90\t  source: 'sprint' | 'issues';\n91\t}\n92\t\n93\t// --- Constants ---\n94\t\n95\t/** Sentinel story key for per-run tasks. */\n96\texport const PER_RUN_SENTINEL = '__run__';\n97\t\n98\t/** DispatchError codes that should halt execution immediately. */\n99\tconst HALT_ERROR_CODES = new Set(['RATE_LIMIT', 'NETWORK', 'SDK_INIT']);\n100\t\n101\t/** Default maximum loop iterations before termination. */\n102\tconst DEFAULT_MAX_ITERATIONS = 5;\n103\t\n104\t// --- Verify Flag Propagation (Story 16-4) ---\n105\t\n106\t/**\n107\t * Propagate test/coverage flags from the implement task's output contract\n108\t * to the harness state file. Only runs for tasks named 'implement' whose\n109\t * output contract contains a non-null `testResults`.\n110\t *\n111\t * This sets `session_flags.tests_passed` and `session_flags.coverage_met`\n112\t * before the verify task runs, so verify's precondition check passes\n113\t * without re-running coverage.\n114\t */\n115\tfunction propagateVerifyFlags(\n116\t  taskName: string,\n117\t  contract: OutputContract | null,\n118\t  projectDir: string,\n119\t): void {\n120\t  // Guard: only run for implement tasks\n121\t  if (taskName !== 'implement') return;\n122\t\n123\t  // Guard: skip if no contract or no test results\n124\t  if (!contract?.testResults) return;\n125\t\n126\t  const { failed, coverage } = contract.testResults;\n127\t\n128\t  try {\n129\t    const { state, body } = readStateWithBody(projectDir);\n130\t\n131\t    // Set tests_passed if all tests passed\n132\t    if (failed === 0) {\n133\t      state.session_flags.tests_passed = true;\n134\t    }\n135\t\n136\t    // Set coverage_met if coverage meets the target\n137\t    // null coverage is not >= any target (null >= N is false in JS)\n138\t    if (coverage !== null && coverage !== undefined && coverage >= state.coverage.target) {\n139\t      state.session_flags.coverage_met = true;\n140\t    }\n141\t\n142\t    writeState(state, projectDir, body);\n143\t  } catch (err: unknown) {\n144\t    // IGNORE: if state file doesn't exist or can't be written,\n145\t    // flag propagation is best-effort — the verify step will\n146\t    // still work via the coverage evaluator path.\n147\t    const msg = err instanceof Error ? err.message : String(err);\n148\t    warn(`workflow-engine: flag propagation failed for ${taskName}: ${msg}`);\n149\t  }\n150\t}\n151\t\n152\t// --- Crash Recovery: Task Completion Check ---\n153\t\n154\t/**\n155\t * Check whether a (taskName, storyKey) combination is already recorded\n156\t * in the workflow state's tasks_completed array.\n157\t *\n158\t * Both fields must match for the task to be considered completed.\n159\t * Used by the resume logic to skip already-completed dispatches.\n160\t */\n161\texport function isTaskCompleted(\n162\t  state: WorkflowState,\n163\t  taskName: string,\n164\t  storyKey: string,\n165\t): boolean {\n166\t  return state.tasks_completed.some(\n167\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey && !cp.error,\n168\t  );\n169\t}\n170\t\n171\t/**\n172\t * Check whether a (taskName, storyKey) combination has been completed\n173\t * enough times to cover the current iteration in a loop block.\n174\t *\n175\t * Loop tasks execute the same (taskName, storyKey) pair each iteration,\n176\t * recording a new checkpoint each time. To determine if a task is done\n177\t * for the current iteration, we count how many matching checkpoints exist\n178\t * and compare to the current iteration number.\n179\t */\n180\texport function isLoopTaskCompleted(\n181\t  state: WorkflowState,\n182\t  taskName: string,\n183\t  storyKey: string,\n184\t  iteration: number,\n185\t): boolean {\n186\t  const count = state.tasks_completed.filter(\n187\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey && !cp.error,\n188\t  ).length;\n189\t  return count >= iteration;\n190\t}\n191\t\n192\t// --- Work Item Loading ---\n193\t\n194\t/**\n195\t * Load work items from sprint-status.yaml and optionally issues.yaml.\n196\t *\n197\t * Stories are extracted from the `development_status` section of sprint-status.yaml.\n198\t * Issues are extracted from the `issues` array of issues.yaml.\n199\t *\n200\t * Only items with status `backlog` or `ready-for-dev` are included.\n201\t * Epic keys (`epic-*`) and retrospective keys (`*-retrospective`) are excluded.\n202\t *\n203\t * If issues.yaml does not exist, returns only stories (no error).\n204\t */\n205\texport function loadWorkItems(sprintStatusPath: string, issuesPath?: string): WorkItem[] {\n206\t  const items: WorkItem[] = [];\n207\t\n208\t  // --- Load stories from sprint-status.yaml ---\n209\t  if (existsSync(sprintStatusPath)) {\n210\t    let raw: string;\n211\t    try {\n212\t      raw = readFileSync(sprintStatusPath, 'utf-8');\n213\t    } catch { // IGNORE: unreadable file — warn and return empty\n214\t      warn(`workflow-engine: could not read sprint-status.yaml at ${sprintStatusPath}`);\n215\t      return items;\n216\t    }\n217\t\n218\t    let parsed: unknown;\n219\t    try {\n220\t      parsed = parse(raw);\n221\t    } catch { // IGNORE: malformed YAML — warn and return empty\n222\t      warn(`workflow-engine: invalid YAML in sprint-status.yaml at ${sprintStatusPath}`);\n223\t      return items;\n224\t    }\n225\t\n226\t    if (parsed && typeof parsed === 'object') {\n227\t      const data = parsed as Record<string, unknown>;\n228\t      const devStatus = data.development_status as Record<string, unknown> | undefined;\n229\t\n230\t      if (devStatus && typeof devStatus === 'object') {\n231\t        for (const [key, status] of Object.entries(devStatus)) {\n232\t          // Skip epic keys and retrospective keys\n233\t          if (key.startsWith('epic-')) continue;\n234\t          if (key.endsWith('-retrospective')) continue;\n235\t\n236\t          // Only include backlog or ready-for-dev\n237\t          if (status === 'backlog' || status === 'ready-for-dev') {\n238\t            items.push({ key, source: 'sprint' });\n239\t          }\n240\t        }\n241\t      }\n242\t    }\n243\t  }\n244\t\n245\t  // --- Load issues from issues.yaml ---\n246\t  if (issuesPath && existsSync(issuesPath)) {\n247\t    let raw: string;\n248\t    try {\n249\t      raw = readFileSync(issuesPath, 'utf-8');\n250\t    } catch { // IGNORE: unreadable issues file — warn and return what we have\n251\t      warn(`workflow-engine: could not read issues.yaml at ${issuesPath}`);\n252\t      return items;\n253\t    }\n254\t\n255\t    let parsed: unknown;\n256\t    try {\n257\t      parsed = parse(raw);\n258\t    } catch { // IGNORE: malformed issues YAML — warn and return what we have\n259\t      warn(`workflow-engine: invalid YAML in issues.yaml at ${issuesPath}`);\n260\t      return items;\n261\t    }\n262\t\n263\t    if (parsed && typeof parsed === 'object') {\n264\t      const data = parsed as Record<string, unknown>;\n265\t      const issuesList = data.issues as Array<Record<string, unknown>> | undefined;\n266\t\n267\t      if (Array.isArray(issuesList)) {\n268\t        for (const issue of issuesList) {\n269\t          if (issue && typeof issue === 'object') {\n270\t            const status = issue.status as string | undefined;\n271\t            if (status === 'backlog' || status === 'ready-for-dev') {\n272\t              items.push({\n273\t                key: issue.id as string,\n274\t                title: issue.title as string | undefined,\n275\t                source: 'issues',\n276\t              });\n277\t            }\n278\t          }\n279\t        }"}]},"parent_tool_use_id":"toolu_01Hody5ZigZ3cTLmGuBw8VE3","session_id":"b6bb3bfc-8778-4f16-a616-88028acc2431","uuid":"1c9d56b4-4845-4f33-90f7-f300726efc3e","timestamp":"2026-04-03T18:31:31.218Z"}
