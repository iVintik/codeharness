{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J5iWNHJHbpp2RDi6H7nRUd","type":"tool_result","content":"     1→/**\n     2→ * Sprint state — read/write unified sprint-state.json with atomic writes.\n     3→ * Also generates sprint-status.yaml as a derived human-readable view.\n     4→ */\n     5→\n     6→import { readFileSync, writeFileSync, renameSync, existsSync, unlinkSync } from 'node:fs';\n     7→import { join, dirname } from 'node:path';\n     8→import { ok, fail } from '../../types/result.js';\n     9→import type { Result } from '../../types/result.js';\n    10→import type { SprintState, SprintStateAny, StoryStatus, StoryState, EpicState } from '../../types/state.js';\n    11→import type { StoryDetail, RunProgressUpdate } from './types.js';\n    12→import { migrateFromOldFormat, migrateV1ToV2, parseStoryRetriesRecord, parseFlaggedStoriesList } from './migration.js';\n    13→\n    14→/** Result of state reconciliation */\n    15→export interface ReconciliationResult {\n    16→  readonly corrections: string[];\n    17→  readonly stateChanged: boolean;\n    18→}\n    19→\n    20→/** Resolve project root (directory containing package.json) */\n    21→function projectRoot(): string {\n    22→  return process.cwd();\n    23→}\n    24→\n    25→/** Path to the sprint state file */\n    26→export function statePath(): string {\n    27→  return join(projectRoot(), 'sprint-state.json');\n    28→}\n    29→\n    30→/** Path to the temporary file used for atomic writes */\n    31→function tmpPath(): string {\n    32→  return join(projectRoot(), '.sprint-state.json.tmp');\n    33→}\n    34→\n    35→/** Path to the sprint-status.yaml file (derived view) */\n    36→export function sprintStatusYamlPath(): string {\n    37→  return join(projectRoot(), '_bmad-output', 'implementation-artifacts', 'sprint-status.yaml');\n    38→}\n    39→\n    40→/** Return an empty default SprintState (v2) */\n    41→export function defaultState(): SprintState {\n    42→  return {\n    43→    version: 2,\n    44→    sprint: {\n    45→      total: 0,\n    46→      done: 0,\n    47→      failed: 0,\n    48→      blocked: 0,\n    49→      inProgress: null,\n    50→    },\n    51→    stories: {},\n    52→    retries: {},\n    53→    flagged: [],\n    54→    epics: {},\n    55→    session: {\n    56→      active: false,\n    57→      startedAt: null,\n    58→      iteration: 0,\n    59→      elapsedSeconds: 0,\n    60→    },\n    61→    observability: {\n    62→      statementCoverage: null,\n    63→      branchCoverage: null,\n    64→      functionCoverage: null,\n    65→      lineCoverage: null,\n    66→    },\n    67→    run: {\n    68→      active: false,\n    69→      startedAt: null,\n    70→      iteration: 0,\n    71→      cost: 0,\n    72→      completed: [],\n    73→      failed: [],\n    74→      currentStory: null,\n    75→      currentPhase: null,\n    76→      lastAction: null,\n    77→      acProgress: null,\n    78→    },\n    79→    actionItems: [],\n    80→  };\n    81→}\n    82→\n    83→/** Return a default StoryState */\n    84→function defaultStoryState(): StoryState {\n    85→  return {\n    86→    status: 'backlog',\n    87→    attempts: 0,\n    88→    lastAttempt: null,\n    89→    lastError: null,\n    90→    proofPath: null,\n    91→    acResults: null,\n    92→  };\n    93→}\n    94→\n    95→/**\n    96→ * Derive a flat story-key → status map from sprint state.\n    97→ * This replaces the old `readSprintStatus()` which parsed YAML.\n    98→ * Only includes story keys (digit-digit-name pattern), not epic keys.\n    99→ */\n   100→export function getStoryStatusesFromState(state: SprintState): Record<string, string> {\n   101→  const result: Record<string, string> = {};\n   102→  for (const [key, story] of Object.entries(state.stories)) {\n   103→    result[key] = story.status;\n   104→  }\n   105→  return result;\n   106→}\n   107→\n   108→/**\n   109→ * Map internal StoryStatus values to sprint-status.yaml status strings.\n   110→ * Most map 1:1, but 'ready' maps to 'ready-for-dev' for YAML compatibility.\n   111→ */\n   112→function yamlStatus(status: StoryStatus): string {\n   113→  if (status === 'ready') return 'ready-for-dev';\n   114→  return status;\n   115→}\n   116→\n   117→/**\n   118→ * Generate sprint-status.yaml content from sprint state.\n   119→ * Groups stories by epic prefix and produces the same YAML structure\n   120→ * that existed as the hand-maintained file.\n   121→ */\n   122→export function generateSprintStatusYaml(state: SprintState): string {\n   123→  const lines: string[] = [\n   124→    '# codeharness Sprint Status (auto-generated from sprint-state.json)',\n   125→    `# generated: ${new Date().toISOString().slice(0, 10)}`,\n   126→    '# This file is a derived view — do NOT edit manually.',\n   127→    '# Source of truth: sprint-state.json',\n   128→    '',\n   129→    'development_status:',\n   130→  ];\n   131→\n   132→  // Group stories by epic prefix (first number segment, or 'TD' for TD- stories)\n   133→  const epicGroups = new Map<string, string[]>();\n   134→  const sortedKeys = Object.keys(state.stories).sort((a, b) => {\n   135→    // Sort by epic number, then story number (TD stories sort last)\n   136→    const [aEpic, aStory] = parseStoryKey(a);\n   137→    const [bEpic, bStory] = parseStoryKey(b);\n   138→    if (aEpic !== bEpic) return aEpic - bEpic;\n   139→    return aStory - bStory;\n   140→  });\n   141→\n   142→  for (const key of sortedKeys) {\n   143→    const epicKey = getEpicGroupKey(key);\n   144→    if (!epicGroups.has(epicKey)) {\n   145→      epicGroups.set(epicKey, []);\n   146→    }\n   147→    epicGroups.get(epicKey)!.push(key);\n   148→  }\n   149→\n   150→  // Emit each epic group\n   151→  for (const [epicKey, storyKeys] of epicGroups) {\n   152→    lines.push('');\n   153→    lines.push(`  # Epic ${epicKey}`);\n   154→\n   155→    // Compute epic status from stories\n   156→    // epic-TD is always in-progress regardless of story statuses\n   157→    let epicStatus: string;\n   158→    if (epicKey === 'TD') {\n   159→      epicStatus = 'in-progress';\n   160→    } else {\n   161→      const allDone = storyKeys.every(k => state.stories[k].status === 'done');\n   162→      epicStatus = allDone ? 'done' : 'backlog';\n   163→    }\n   164→    lines.push(`  epic-${epicKey}: ${epicStatus}`);\n   165→\n   166→    for (const key of storyKeys) {\n   167→      const story = state.stories[key];\n   168→      lines.push(`  ${key}: ${yamlStatus(story.status)}`);\n   169→    }\n   170→  }\n   171→\n   172→  lines.push('');\n   173→  return lines.join('\\n');\n   174→}\n   175→\n   176→/**\n   177→ * Parse a story key into [epicNumber, storyNumber].\n   178→ * e.g. \"11-2-sprint-status-yaml-derived-view\" → [11, 2]\n   179→ * TD-prefix stories (e.g. \"TD-1-slug\") return [Infinity, storyNumber].\n   180→ */\n   181→function parseStoryKey(key: string): [number, number] {\n   182→  // Handle TD-prefix stories\n   183→  const tdMatch = key.match(/^TD-(\\d+)/);\n   184→  if (tdMatch) return [Infinity, parseInt(tdMatch[1], 10)];\n   185→  const match = key.match(/^(\\d+)-(\\d+)/);\n   186→  if (!match) return [Infinity, Infinity];\n   187→  return [parseInt(match[1], 10), parseInt(match[2], 10)];\n   188→}\n   189→\n   190→/**\n   191→ * Get the epic group key for a story key.\n   192→ * Returns 'TD' for TD-prefix stories, or the numeric epic prefix as string.\n   193→ */\n   194→function getEpicGroupKey(key: string): string {\n   195→  if (key.startsWith('TD-')) return 'TD';\n   196→  const match = key.match(/^(\\d+)-/);\n   197→  return match ? match[1] : String(Infinity);\n   198→}\n   199→\n   200→/**\n   201→ * Write the derived sprint-status.yaml from current state.\n   202→ * Best-effort: failures are silently ignored since this is a convenience view.\n   203→ */\n   204→function writeSprintStatusYaml(state: SprintState): void {\n   205→  try {\n   206→    const yamlPath = sprintStatusYamlPath();\n   207→    // Only write if the directory exists (project has been set up)\n   208→    const dir = dirname(yamlPath);\n   209→    if (!existsSync(dir)) return;\n   210→    const content = generateSprintStatusYaml(state);\n   211→    writeFileSync(yamlPath, content, 'utf-8');\n   212→  } catch {\n   213→    // Best-effort: YAML view is not critical\n   214→  }\n   215→}\n   216→\n   217→/**\n   218→ * Write state to disk atomically: write to tmp, then rename.\n   219→ * Also regenerates sprint-status.yaml as a derived view.\n   220→ */\n   221→export function writeStateAtomic(state: SprintState): Result<void> {\n   222→  try {\n   223→    const data = JSON.stringify(state, null, 2) + '\\n';\n   224→    const tmp = tmpPath();\n   225→    const final = statePath();\n   226→    writeFileSync(tmp, data, 'utf-8');\n   227→    renameSync(tmp, final);\n   228→    // Regenerate YAML view after successful state write\n   229→    writeSprintStatusYaml(state);\n   230→    return ok(undefined);\n   231→  } catch (err: unknown) {\n   232→    const msg = err instanceof Error ? err.message : String(err);\n   233→    return fail(`Failed to write sprint state: ${msg}`);\n   234→  }\n   235→}\n   236→\n   237→/**\n   238→ * Read and parse sprint-state.json.\n   239→ * If the file does not exist, attempt migration from old files.\n   240→ * If no old files exist either, return defaultState().\n   241→ * Automatically migrates v1 state to v2.\n   242→ */\n   243→export function getSprintState(): Result<SprintState> {\n   244→  const fp = statePath();\n   245→\n   246→  if (existsSync(fp)) {\n   247→    try {\n   248→      const raw = readFileSync(fp, 'utf-8');\n   249→      const parsed = JSON.parse(raw) as Record<string, unknown>;\n   250→      const version = parsed.version as number | undefined;\n   251→\n   252→      // Already v2 — merge with defaults and return\n   253→      if (version === 2) {\n   254→        const defaults = defaultState();\n   255→        const run = parsed.run as Record<string, unknown> | undefined;\n   256→        const sprint = parsed.sprint as Record<string, unknown> | undefined;\n   257→        const session = parsed.session as Record<string, unknown> | undefined;\n   258→        const observability = parsed.observability as Record<string, unknown> | undefined;\n   259→        const state: SprintState = {\n   260→          ...(parsed as unknown as SprintState),\n   261→          sprint: {\n   262→            ...defaults.sprint,\n   263→            ...(sprint as unknown as SprintState['sprint']),\n   264→          },\n   265→          run: {\n   266→            ...defaults.run,\n   267→            ...(run as unknown as SprintState['run']),\n   268→          },\n   269→          session: {\n   270→            ...defaults.session,\n   271→            ...(session as unknown as SprintState['session']),\n   272→          },\n   273→          observability: {\n   274→            ...defaults.observability,\n   275→            ...(observability as unknown as SprintState['observability']),\n   276→          },\n   277→          retries: (parsed.retries as Record<string, number>) ?? {},\n   278→          flagged: (parsed.flagged as string[]) ?? [],\n   279→          epics: (parsed.epics as Record<string, import('../../types/state.js').EpicState>) ?? {},\n   280→        };\n   281→        return ok(state);\n   282→      }\n   283→\n   284→      // v1 or missing version — migrate to v2\n   285→      const v1State = parsed as unknown as import('../../types/state.js').SprintStateV1;\n   286→      const migrated = migrateV1ToV2(v1State);\n   287→      const writeResult = writeStateAtomic(migrated);\n   288→      if (!writeResult.success) {\n   289→        return fail(writeResult.error);\n   290→      }\n   291→      return ok(migrated);\n   292→    } catch (err: unknown) {\n   293→      const msg = err instanceof Error ? err.message : String(err);\n   294→      return fail(`Failed to read sprint state: ${msg}`);\n   295→    }\n   296→  }\n   297→\n   298→  // No sprint-state.json — try migration from old scattered files\n   299→  const migrationResult = migrateFromOldFormat();\n   300→  if (migrationResult.success) {\n   301→    return migrationResult;\n   302→  }\n   303→\n   304→  // Migration found nothing or failed — return default\n   305→  return ok(defaultState());\n   306→}\n   307→\n   308→/** Recompute sprint summary counts from story data */\n   309→export function computeSprintCounts(\n   310→  stories: Record<string, StoryState>,\n   311→): SprintState['sprint'] {\n   312→  let total = 0;\n   313→  let done = 0;\n   314→  let failed = 0;\n   315→  let blocked = 0;\n   316→  let inProgress: string | null = null;\n   317→\n   318→  for (const [key, story] of Object.entries(stories)) {\n   319→    total++;\n   320→    if (story.status === 'done') done++;\n   321→    else if (story.status === 'failed') failed++;\n   322→    else if (story.status === 'blocked') blocked++;\n   323→    else if (story.status === 'in-progress') inProgress = key;\n   324→  }\n   325→\n   326→  return { total, done, failed, blocked, inProgress };\n   327→}\n   328→\n   329→/**\n   330→ * Update a single story's status in sprint-state.json.\n   331→ * Reads current state, merges update, writes atomically.\n   332→ */\n   333→export function updateStoryStatus(\n   334→  key: string,\n   335→  status: StoryStatus,\n   336→  detail?: StoryDetail,\n   337→): Result<void> {\n   338→  const stateResult = getSprintState();\n   339→  if (!stateResult.success) {\n   340→    return fail(stateResult.error);\n   341→  }\n   342→\n   343→  const current = stateResult.data;\n   344→  const existingStory = current.stories[key] ?? defaultStoryState();\n   345→\n   346→  const isNewAttempt = status === 'in-progress';\n   347→\n   348→  const updatedStory: StoryState = {\n   349→    ...existingStory,\n   350→    status,\n   351→    attempts: isNewAttempt\n   352→      ? existingStory.attempts + 1\n   353→      : existingStory.attempts,\n   354→    lastAttempt: isNewAttempt\n   355→      ? new Date().toISOString()\n   356→      : existingStory.lastAttempt,\n   357→    lastError: detail?.error ?? existingStory.lastError,\n   358→    proofPath: detail?.proofPath ?? existingStory.proofPath,\n   359→    acResults: existingStory.acResults,\n   360→  };\n   361→\n   362→  const updatedStories = { ...current.stories, [key]: updatedStory };\n   363→  const updatedSprint = computeSprintCounts(updatedStories);\n   364→\n   365→  const updatedState: SprintState = {\n   366→    ...current,\n   367→    sprint: updatedSprint,\n   368→    stories: updatedStories,\n   369→  };\n   370→\n   371→  return writeStateAtomic(updatedState);\n   372→}\n   373→\n   374→/**\n   375→ * Update live run progress fields in sprint-state.json.\n   376→ * Only provided fields are updated; omitted fields retain their current values.\n   377→ */\n   378→export function updateRunProgress(update: RunProgressUpdate): Result<void> {\n   379→  const stateResult = getSprintState();\n   380→  if (!stateResult.success) {\n   381→    return fail(stateResult.error);\n   382→  }\n   383→\n   384→  const current = stateResult.data;\n   385→  const updatedRun = {\n   386→    ...current.run,\n   387→    ...(update.currentStory !== undefined && { currentStory: update.currentStory }),\n   388→    ...(update.currentPhase !== undefined && { currentPhase: update.currentPhase }),\n   389→    ...(update.lastAction !== undefined && { lastAction: update.lastAction }),\n   390→    ...(update.acProgress !== undefined && { acProgress: update.acProgress }),\n   391→  };\n   392→\n   393→  const updatedState: SprintState = {\n   394→    ...current,\n   395→    run: updatedRun,\n   396→  };\n   397→\n   398→  return writeStateAtomic(updatedState);\n   399→}\n   400→\n   401→/**\n   402→ * Clear all live run progress fields to null.\n   403→ * Called when a story completes or fails.\n   404→ */\n   405→export function clearRunProgress(): Result<void> {\n   406→  const stateResult = getSprintState();\n   407→  if (!stateResult.success) {\n   408→    return fail(stateResult.error);\n   409→  }\n   410→\n   411→  const current = stateResult.data;\n   412→  const updatedState: SprintState = {\n   413→    ...current,\n   414→    run: {\n   415→      ...current.run,\n   416→      currentStory: null,\n   417→      currentPhase: null,\n   418→      lastAction: null,\n   419→      acProgress: null,\n   420→    },\n   421→  };\n   422→\n   423→  return writeStateAtomic(updatedState);\n   424→}\n   425→\n   426→/**\n   427→ * Reconcile sprint state on session start.\n   428→ * Merges orphaned files, validates epic consistency, regenerates YAML.\n   429→ * Best-effort: returns corrections made; callers should log them.\n   430→ */\n   431→export function reconcileState(): Result<ReconciliationResult> {\n   432→  try {\n   433→    // 1. Read current state (handles v1→v2 migration internally)\n   434→    const stateResult = getSprintState();\n   435→    if (!stateResult.success) {\n   436→      return fail(stateResult.error);\n   437→    }\n   438→\n   439→    // Work with a mutable copy\n   440→    const state: SprintState = JSON.parse(JSON.stringify(stateResult.data));\n   441→    const corrections: string[] = [];\n   442→    let changed = false;\n   443→\n   444→    // 2. Merge orphaned .story_retries file\n   445→    const retriesPath = join(projectRoot(), 'ralph', '.story_retries');\n   446→    if (existsSync(retriesPath)) {\n   447→      try {\n   448→        const content = readFileSync(retriesPath, 'utf-8');\n   449→        const fileRetries = parseStoryRetriesRecord(content);\n   450→        const mergedRetries = { ...state.retries };\n   451→        for (const [key, count] of Object.entries(fileRetries)) {\n   452→          if (count > (mergedRetries[key] ?? 0)) {\n   453→            mergedRetries[key] = count;\n   454→            changed = true;\n   455→          }\n   456→        }\n   457→        (state as { retries: Record<string, number> }).retries = mergedRetries;\n   458→        unlinkSync(retriesPath);\n   459→        corrections.push('merged .story_retries into sprint-state.json');\n   460→      } catch {\n   461→        // Malformed file — delete it and move on\n   462→        try { unlinkSync(retriesPath); } catch { /* ignore */ }\n   463→        corrections.push('removed malformed .story_retries file');\n   464→      }\n   465→    }\n   466→\n   467→    // 3. Merge orphaned .flagged_stories file\n   468→    const flaggedPath = join(projectRoot(), 'ralph', '.flagged_stories');\n   469→    if (existsSync(flaggedPath)) {\n   470→      try {\n   471→        const content = readFileSync(flaggedPath, 'utf-8');\n   472→        const fileKeys = parseFlaggedStoriesList(content);\n   473→        const existing = new Set(state.flagged);\n   474→        const merged = [...state.flagged];\n   475→        for (const key of fileKeys) {\n   476→          if (!existing.has(key)) {\n   477→            merged.push(key);\n   478→            existing.add(key);\n   479→            changed = true;\n   480→          }\n   481→        }\n   482→        (state as { flagged: string[] }).flagged = merged;\n   483→        unlinkSync(flaggedPath);\n   484→        corrections.push('merged .flagged_stories into sprint-state.json');\n   485→      } catch {\n   486→        // Malformed file — delete it and move on\n   487→        try { unlinkSync(flaggedPath); } catch { /* ignore */ }\n   488→        corrections.push('removed malformed .flagged_stories file');\n   489→      }\n   490→    }\n   491→\n   492→    // 4. Validate epic consistency — ensure every story's epic prefix has an epic entry\n   493→    const epicStories = new Map<string, string[]>();\n   494→    for (const key of Object.keys(state.stories)) {\n   495→      const [epicNum] = parseStoryKey(key);\n   496→      if (epicNum === Infinity) continue; // Not a valid story key\n   497→      const epicKey = `epic-${epicNum}`;\n   498→      if (!epicStories.has(epicKey)) {\n   499→        epicStories.set(epicKey, []);\n   500→      }\n   501→      epicStories.get(epicKey)!.push(key);\n   502→    }\n   503→\n   504→    const updatedEpics: Record<string, import('../../types/state.js').EpicState> = { ...state.epics };\n   505→    for (const [epicKey, storyKeys] of epicStories) {\n   506→      if (!(epicKey in updatedEpics)) {\n   507→        // Compute epic status from its stories\n   508→        const total = storyKeys.length;\n   509→        const doneCount = storyKeys.filter(k => state.stories[k].status === 'done').length;\n   510→        const epicStatus = doneCount === total ? 'done' : 'in-progress';\n   511→        updatedEpics[epicKey] = {\n   512→          status: epicStatus,\n   513→          storiesTotal: total,\n   514→          storiesDone: doneCount,\n   515→        };\n   516→        changed = true;\n   517→        corrections.push(`created missing epic entry: ${epicKey}`);\n   518→      }\n   519→    }\n   520→    (state as { epics: Record<string, import('../../types/state.js').EpicState> }).epics = updatedEpics;\n   521→\n   522→    // 5. Write state atomically if mutations were made (also regenerates YAML),\n   523→    //    otherwise just regenerate YAML standalone (idempotent, cheap).\n   524→    if (changed) {\n   525→      const writeResult = writeStateAtomic(state);\n   526→      if (!writeResult.success) {\n   527→        return fail(writeResult.error);\n   528→      }\n   529→    } else {\n   530→      writeSprintStatusYaml(state);\n   531→    }\n   532→\n   533→    // 7. Note YAML regeneration in corrections if any corrections were made\n   534→    if (corrections.length > 0) {\n   535→      corrections.push('regenerated sprint-status.yaml');\n   536→    }\n   537→\n   538→    return ok({ corrections, stateChanged: changed });\n   539→  } catch (err: unknown) {\n   540→    const msg = err instanceof Error ? err.message : String(err);\n   541→    return fail(`State reconciliation failed: ${msg}`);\n   542→  }\n   543→}\n   544→"}]},"parent_tool_use_id":"toolu_01QdekhbhdCn1yMfA8HwX61q","session_id":"84a01a9c-e466-45b4-91ef-8201b3712d8d","uuid":"945b04b2-5400-4ab5-a622-d53628bd62d4","timestamp":"2026-03-24T21:56:58.425Z"}
