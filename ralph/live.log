IFICATION_TAG_PATTERN.exec(text);\n    99→  if (!match) return null;\n   100→  const raw = match[1];\n   101→  // Map legacy values to new tiers; validate result is a known tier\n   102→  const mapped = LEGACY_TIER_MAP[raw] ?? raw;\n   103→  if (!TIER_HIERARCHY.includes(mapped as VerificationTier)) return null;\n   104→  return mapped as VerificationTier;\n   105→}\n   106→\n   107→// ─── Classification ─────────────────────────────────────────────────────────\n   108→\n   109→/**"}]},"parent_tool_use_id":"toolu_01RCDsLLGxuhJfk5hTk4yfBE","session_id":"ff167eff-13f5-482e-8ffe-9c15eb86695c","uuid":"92073d16-5f16-4d6b-94aa-b54be7d73532","timestamp":"2026-03-28T11:36:37.308Z"}
