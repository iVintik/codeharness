{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xm66jfnssYUveoWmKgSEsm","type":"tool_result","content":"     1в†’import { mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n     2в†’import { dirname, resolve } from 'node:path';\n     3в†’import { fileURLToPath } from 'node:url';\n     4в†’\n     5в†’const __dirname = dirname(fileURLToPath(import.meta.url));\n     6в†’\n     7в†’/** Package root directory вЂ” works for both dev (src/) and installed (dist/) layouts. */\n     8в†’export function getPackageRoot(): string {\n     9в†’  // __dirname is src/lib/ in dev or dist/ in installed package\n    10в†’  // Walk up to find the directory containing package.json\n    11в†’  return resolve(__dirname, '..', '..');\n    12в†’}\n    13в†’\n    14в†’export function generateFile(targetPath: string, content: string): void {\n    15в†’  mkdirSync(dirname(targetPath), { recursive: true });\n    16в†’  writeFileSync(targetPath, content, 'utf-8');\n    17в†’}\n    18в†’\n    19в†’/**\n    20в†’ * Interpolates `{{VAR}}` placeholders in a template string.\n    21в†’ * Unmatched placeholders are left as-is.\n    22в†’ */\n    23в†’export function renderTemplate(template: string, vars: Record<string, string>): string {\n    24в†’  return template.replace(/\\{\\{(\\w+)\\}\\}/g, (match, key: string) => vars[key] ?? match);\n    25в†’}\n    26в†’\n    27в†’/**\n    28в†’ * Reads a template file relative to the package root and interpolates `{{VAR}}` placeholders.\n    29в†’ * @param templatePath - Path relative to package root, e.g. 'templates/dockerfiles/Dockerfile.nodejs'\n    30в†’ * @param vars - Key/value pairs for placeholder interpolation\n    31в†’ * @returns The rendered template content\n    32в†’ */\n    33в†’export function renderTemplateFile(templatePath: string, vars: Record<string, string> = {}): string {\n    34в†’  const fullPath = resolve(getPackageRoot(), templatePath);\n    35в†’  const content = readFileSync(fullPath, 'utf-8');\n    36в†’  if (Object.keys(vars).length === 0) return content;\n    37в†’  return renderTemplate(content, vars);\n    38в†’}\n    39в†’"}]},"parent_tool_use_id":"toolu_011Fip6m9FHVBszWegBeTJVL","session_id":"406ac605-1908-4bc8-82ff-6bd28578af4b","uuid":"7acdda88-da8f-4eb9-8243-7691372b2d65","timestamp":"2026-03-25T02:24:37.957Z"}
