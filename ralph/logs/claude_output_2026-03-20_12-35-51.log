{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012y9uVBKFjJAGM73mwPTd4h","type":"tool_result","content":"     1→/**\n     2→ * CLI command: `codeharness audit`\n     3→ *\n     4→ * Checks all compliance dimensions and reports project health.\n     5→ * Supports --json for machine-readable output.\n     6→ */\n     7→\n     8→import { Command } from 'commander';\n     9→import { ok as okOutput, fail as failOutput, jsonOutput } from '../lib/output.js';\n    10→import { runPreconditions } from '../lib/onboard-checks.js';\n    11→import { runAudit } from '../modules/audit/index.js';\n    12→import { formatAuditHuman, formatAuditJson } from '../modules/audit/report.js';\n    13→\n    14→export function registerAuditCommand(program: Command): void {\n    15→  program\n    16→    .command('audit')\n    17→    .description('Check all compliance dimensions and report project health')\n    18→    .option('--json', 'Output in machine-readable JSON format')\n    19→    .action(async (opts, cmd) => {\n    20→      const globalOpts = cmd.optsWithGlobals();\n    21→      const isJson = opts.json === true || globalOpts.json === true;\n    22→\n    23→      // Precondition: harness must be initialized (AC #7)\n    24→      const preconditions = runPreconditions();\n    25→      if (!preconditions.canProceed) {\n    26→        if (isJson) {\n    27→          jsonOutput({\n    28→            status: 'fail',\n    29→            message: 'Harness not initialized -- run codeharness init first',\n    30→          });\n    31→        } else {\n    32→          failOutput('Harness not initialized -- run codeharness init first');\n    33→        }\n    34→        process.exitCode = 1;\n    35→        return;\n    36→      }\n    37→\n    38→      // Run audit\n    39→      const result = await runAudit(process.cwd());\n    40→\n    41→      if (!result.success) {\n    42→        if (isJson) {\n    43→          jsonOutput({ status: 'fail', message: result.error });\n    44→        } else {\n    45→          failOutput(result.error);\n    46→        }\n    47→        process.exitCode = 1;\n    48→        return;\n    49→      }\n    50→\n    51→      // Format output\n    52→      if (isJson) {\n    53→        jsonOutput(formatAuditJson(result.data));\n    54→      } else {\n    55→        const lines = formatAuditHuman(result.data);\n    56→        for (const line of lines) {\n    57→          console.log(line);\n    58→        }\n    59→      }\n    60→\n    61→      // Set exit code based on overall status\n    62→      if (result.data.overallStatus === 'fail') {\n    63→        process.exitCode = 1;\n    64→      }\n    65→    });\n    66→}\n    67→"}]},"parent_tool_use_id":"toolu_01UmDTVZ4iS72Xuw7ncmN4YZ","session_id":"e1f3df9b-d919-466e-880e-1001c8652ee8","uuid":"2744ef7a-8e5f-4884-b914-1605d026d586","timestamp":"2026-03-20T08:52:05.791Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EDBYSrC14oHGsP2j9ahLsw","type":"tool_result","content":"     1→import { Command } from 'commander';\n     2→import { registerInitCommand } from './commands/init.js';\n     3→import { registerBridgeCommand } from './commands/bridge.js';\n     4→import { registerRunCommand } from './commands/run.js';\n     5→import { registerVerifyCommand } from './commands/verify.js';\n     6→import { registerStatusCommand } from './commands/status.js';\n     7→import { registerOnboardCommand } from './commands/onboard.js';\n     8→import { registerTeardownCommand } from './commands/teardown.js';\n     9→import { registerStateCommand } from './commands/state.js';\n    10→import { registerSyncCommand } from './commands/sync.js';\n    11→import { registerCoverageCommand } from './commands/coverage.js';\n    12→import { registerDocHealthCommand } from './commands/doc-health.js';\n    13→import { registerStackCommand } from './commands/stack.js';\n    14→import { registerQueryCommand } from './commands/query.js';\n    15→import { registerRetroImportCommand } from './commands/retro-import.js';\n    16→import { registerGithubImportCommand } from './commands/github-import.js';\n    17→import { registerVerifyEnvCommand } from './commands/verify-env.js';\n    18→import { registerRetryCommand } from './commands/retry.js';\n    19→import { registerTimeoutReportCommand } from './commands/timeout-report.js';\n    20→import { registerValidateStateCommand } from './commands/validate-state.js';\n    21→import { registerValidateCommand } from './commands/validate.js';\n    22→import { registerProgressCommand } from './commands/progress.js';\n    23→import { registerObservabilityGateCommand } from './commands/observability-gate.js';\n    24→import { registerAuditCommand } from './commands/audit.js';\n    25→\n    26→declare const __PKG_VERSION__: string;\n    27→const VERSION = typeof __PKG_VERSION__ !== 'undefined' ? __PKG_VERSION__ : '0.0.0-dev';\n    28→\n    29→export function createProgram(): Command {\n    30→  const program = new Command();\n    31→\n    32→  program\n    33→    .name('codeharness')\n    34→    .description('Makes autonomous coding agents produce software that actually works')\n    35→    .version(VERSION)\n    36→    .option('--json', 'Output in machine-readable JSON format');\n    37→\n    38→  registerInitCommand(program);\n    39→  registerBridgeCommand(program);\n    40→  registerRunCommand(program);\n    41→  registerVerifyCommand(program);\n    42→  registerStatusCommand(program);\n    43→  registerOnboardCommand(program);\n    44→  registerTeardownCommand(program);\n    45→  registerStateCommand(program);\n    46→  registerSyncCommand(program);\n    47→  registerCoverageCommand(program);\n    48→  registerDocHealthCommand(program);\n    49→  registerStackCommand(program);\n    50→  registerQueryCommand(program);\n    51→  registerRetroImportCommand(program);\n    52→  registerGithubImportCommand(program);\n    53→  registerVerifyEnvCommand(program);\n    54→  registerRetryCommand(program);\n    55→  registerTimeoutReportCommand(program);\n    56→  registerValidateStateCommand(program);\n    57→  registerValidateCommand(program);\n    58→  registerProgressCommand(program);\n    59→  registerObservabilityGateCommand(program);\n    60→  registerAuditCommand(program);\n    61→\n    62→  return program;\n    63→}\n    64→\n    65→// Only parse when running as CLI entry point, not when imported in tests\n    66→if (!process.env['VITEST']) {\n    67→  const program = createProgram();\n    68→  program.parse(process.argv);\n    69→}\n    70→"}]},"parent_tool_use_id":"toolu_01UmDTVZ4iS72Xuw7ncmN4YZ","session_id":"e1f3df9b-d919-466e-880e-1001c8652ee8","uuid":"5464307d-dc50-4309-a17b-0aa597b92148","timestamp":"2026-03-20T08:52:05.792Z"}
