{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QT7h1pZxdd8pdaf1uzMw8E","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach } from 'vitest';\n2\t\n3\timport {\n4\t  executeEpicFlow,\n5\t  EpicFlowError,\n6\t  type EpicFlowConfig,\n7\t  type EpicFlowResult,\n8\t  type EpicFlowStepResult,\n9\t} from '../epic-flow-executor.js';\n10\t\n11\timport { buildSprintState, buildEpicState, buildStoryEntry } from './fixtures/state-builders.js';\n12\t\n13\timport type { WorktreeManager, MergeResult } from '../worktree-manager.js';\n14\timport type { SprintState } from '../../types/state.js';\n15\t\n16\t// --- Mocks ---\n17\t\n18\tvi.mock('../telemetry-writer.js', () => ({\n19\t  readTelemetryForEpic: vi.fn().mockReturnValue([]),\n20\t}));\n21\t\n22\tvi.mock('../cross-worktree-validator.js', () => ({\n23\t  validateMerge: vi.fn().mockResolvedValue({\n24\t    valid: true,\n25\t    testResults: { passed: 10, failed: 0, coverage: 95 },\n26\t    output: '10 passed',\n27\t    durationMs: 1000,\n28\t  }),\n29\t}));\n30\t\n31\t// We do NOT mock epic-completion — we use the real state machine\n32\t\n33\timport { readTelemetryForEpic } from '../telemetry-writer.js';\n34\timport { validateMerge } from '../cross-worktree-validator.js';\n35\t\n36\tconst mockReadTelemetry = vi.mocked(readTelemetryForEpic);\n37\tconst mockValidateMerge = vi.mocked(validateMerge);\n38\t\n39\t// --- Helpers ---\n40\t\n41\tfunction createMockWorktreeManager(mergeResult?: Partial<MergeResult>): WorktreeManager {\n42\t  return {\n43\t    mergeWorktree: vi.fn().mockResolvedValue({\n44\t      success: true,\n45\t      durationMs: 500,\n46\t      ...mergeResult,\n47\t    }),\n48\t    createWorktree: vi.fn(),\n49\t    cleanupWorktree: vi.fn(),\n50\t    listWorktrees: vi.fn().mockReturnValue([]),\n51\t    detectOrphans: vi.fn().mockReturnValue([]),\n52\t  } as unknown as WorktreeManager;\n53\t}\n54\t\n55\t/**\n56\t * Build a state where epic-19 is in \"completing\" status with all stories done.\n57\t * This is the expected starting state when executeEpicFlow is called.\n58\t */\n59\tfunction buildCompletingState(epicId = '19'): SprintState {\n60\t  return buildSprintState({\n61\t    epics: { [`epic-${epicId}`]: buildEpicState({ status: 'completing', storiesTotal: 2, storiesDone: 2 }) },\n62\t    stories: {\n63\t      [`${epicId}-1-foo`]: buildStoryEntry({ status: 'done' }),\n64\t      [`${epicId}-2-bar`]: buildStoryEntry({ status: 'done' }),\n65\t    },\n66\t  });\n67\t}\n68\t\n69\tfunction buildBaseConfig(overrides?: Partial<EpicFlowConfig>): EpicFlowConfig {\n70\t  return {\n71\t    epicId: '19',\n72\t    epicFlow: ['retro', 'merge', 'validate'],\n73\t    worktreeManager: createMockWorktreeManager(),\n74\t    mergeStrategy: 'merge-commit',\n75\t    testCommand: 'npm test',\n76\t    projectDir: '/tmp/test-project',\n77\t    initialState: buildCompletingState(),\n78\t    ...overrides,\n79\t  };\n80\t}\n81\t\n82\t// --- Tests ---\n83\t\n84\tdescribe('epic-flow-executor', () => {\n85\t  beforeEach(() => {\n86\t    vi.clearAllMocks();\n87\t    mockReadTelemetry.mockReturnValue([]);\n88\t    mockValidateMerge.mockResolvedValue({\n89\t      valid: true,\n90\t      testResults: { passed: 10, failed: 0, coverage: 95 },\n91\t      output: '10 passed',\n92\t      durationMs: 1000,\n93\t    });\n94\t  });\n95\t\n96\t  // --- Exports (AC #1) ---\n97\t\n98\t  describe('exports', () => {\n99\t    it('exports executeEpicFlow function', () => {\n100\t      expect(typeof executeEpicFlow).toBe('function');\n101\t    });\n102\t\n103\t    it('exports EpicFlowError class', () => {\n104\t      const err = new EpicFlowError('test');\n105\t      expect(err).toBeInstanceOf(Error);\n106\t      expect(err.name).toBe('EpicFlowError');\n107\t      expect(err.message).toBe('test');\n108\t    });\n109\t  });\n110\t\n111\t  // --- Sequential execution (AC #2) ---\n112\t\n113\t  describe('sequential execution', () => {\n114\t    it('executes retro → merge → validate in strict sequence', async () => {\n115\t      const executionOrder: string[] = [];\n116\t      const dispatchRetro = vi.fn().mockImplementation(async () => {\n117\t        executionOrder.push('retro');\n118\t      });\n119\t      const wm = createMockWorktreeManager();\n120\t      (wm.mergeWorktree as ReturnType<typeof vi.fn>).mockImplementation(async () => {\n121\t        executionOrder.push('merge');\n122\t        return { success: true, durationMs: 100 };\n123\t      });\n124\t      mockValidateMerge.mockImplementation(async () => {\n125\t        executionOrder.push('validate');\n126\t        return { valid: true, testResults: { passed: 5, failed: 0, coverage: 90 }, output: '', durationMs: 100 };\n127\t      });\n128\t\n129\t      const config = buildBaseConfig({ worktreeManager: wm, dispatchRetro });\n130\t      await executeEpicFlow(config);\n131\t\n132\t      expect(executionOrder).toEqual(['retro', 'merge', 'validate']);\n133\t    });\n134\t\n135\t    it('never runs steps in parallel', async () => {\n136\t      let concurrent = 0;\n137\t      let maxConcurrent = 0;\n138\t\n139\t      const trackConcurrency = async (name: string, fn: () => Promise<void>) => {\n140\t        concurrent++;\n141\t        maxConcurrent = Math.max(maxConcurrent, concurrent);\n142\t        await fn();\n143\t        concurrent--;\n144\t      };\n145\t\n146\t      const dispatchRetro = vi.fn().mockImplementation(() =>\n147\t        trackConcurrency('retro', async () => {}),\n148\t      );\n149\t      const wm = createMockWorktreeManager();\n150\t      (wm.mergeWorktree as ReturnType<typeof vi.fn>).mockImplementation(() =>\n151\t        trackConcurrency('merge', async () => ({ success: true, durationMs: 1 })),\n152\t      );\n153\t      mockValidateMerge.mockImplementation(() =>\n154\t        trackConcurrency('validate', async () => ({\n155\t          valid: true,\n156\t          testResults: { passed: 1, failed: 0, coverage: null },\n157\t          output: '',\n158\t          durationMs: 1,\n159\t        })) as any,\n160\t      );\n161\t\n162\t      const config = buildBaseConfig({ worktreeManager: wm, dispatchRetro });\n163\t      await executeEpicFlow(config);\n164\t\n165\t      expect(maxConcurrent).toBe(1);\n166\t    });\n167\t  });\n168\t\n169\t  // --- Retro step (AC #3) ---\n170\t\n171\t  describe('retro step', () => {\n172\t    it('reads telemetry and dispatches callback', async () => {\n173\t      const mockTelemetry = [{ version: 1 as const, timestamp: '2026-01-01', storyKey: '19-1-foo', epicId: '19', duration_ms: 100, cost_usd: null, attempts: null, acResults: null, filesChanged: [], testResults: null, errors: [] }];\n174\t      mockReadTelemetry.mockReturnValue(mockTelemetry);\n175\t\n176\t      const dispatchRetro = vi.fn().mockResolvedValue(undefined);\n177\t      // Use 'validating' state so the final → done transition is valid\n178\t      // (retro has no state mapping, so the state stays at validating throughout)\n179\t      const state = buildSprintState({\n180\t        epics: { 'epic-19': buildEpicState({ status: 'validating', storiesTotal: 2, storiesDone: 2 }) },\n181\t        stories: {\n182\t          '19-1-foo': buildStoryEntry({ status: 'done' }),\n183\t          '19-2-bar': buildStoryEntry({ status: 'done' }),\n184\t        },\n185\t      });\n186\t      const config = buildBaseConfig({ epicFlow: ['retro'], dispatchRetro, initialState: state });\n187\t\n188\t      const result = await executeEpicFlow(config);\n189\t\n190\t      expect(mockReadTelemetry).toHaveBeenCalledWith('19', '/tmp/test-project');\n191\t      expect(dispatchRetro).toHaveBeenCalledWith('19', mockTelemetry);\n192\t      expect(result.success).toBe(true);\n193\t    });\n194\t\n195\t    it('succeeds without callback (retro is advisory)', async () => {\n196\t      const state = buildSprintState({\n197\t        epics: { 'epic-19': buildEpicState({ status: 'validating', storiesTotal: 1, storiesDone: 1 }) },\n198\t        stories: { '19-1-foo': buildStoryEntry({ status: 'done' }) },\n199\t      });\n200\t      const config = buildBaseConfig({ epicFlow: ['retro'], dispatchRetro: undefined, initialState: state });\n201\t\n202\t      const result = await executeEpicFlow(config);\n203\t\n204\t      expect(result.success).toBe(true);\n205\t      expect(result.stepsCompleted).toContain('retro');\n206\t    });\n207\t\n208\t    it('passes empty telemetry array when no entries exist', async () => {\n209\t      mockReadTelemetry.mockReturnValue([]);\n210\t      const dispatchRetro = vi.fn().mockResolvedValue(undefined);\n211\t      const state = buildSprintState({\n212\t        epics: { 'epic-19': buildEpicState({ status: 'validating', storiesTotal: 1, storiesDone: 1 }) },\n213\t        stories: { '19-1-foo': buildStoryEntry({ status: 'done' }) },\n214\t      });\n215\t      const config = buildBaseConfig({ epicFlow: ['retro'], dispatchRetro, initialState: state });\n216\t\n217\t      await executeEpicFlow(config);\n218\t\n219\t      expect(dispatchRetro).toHaveBeenCalledWith('19', []);\n220\t    });\n221\t  });\n222\t\n223\t  // --- Merge step (AC #4, #12) ---\n224\t\n225\t  describe('merge step', () => {\n226\t    it('calls worktreeManager.mergeWorktree with correct args', async () => {\n227\t      const wm = createMockWorktreeManager();\n228\t      const onConflict = vi.fn();\n229\t      // State: completing → merging (merge step transitions), then merging → done not valid\n230\t      // We need: completing → merging → done. But done only from validating.\n231\t      // For a flow with just ['merge'], completing → merging, then → done.\n232\t      // But VALID_TRANSITIONS says merging can go to validating or failed, NOT done.\n233\t      // So we need at least merge + validate, or we test merge in the full flow.\n234\t      const config = buildBaseConfig({\n235\t        worktreeManager: wm,\n236\t        onConflict,\n237\t        epicFlow: ['merge', 'validate'],\n238\t      });\n239\t\n240\t      await executeEpicFlow(config);\n241\t\n242\t      expect(wm.mergeWorktree).toHaveBeenCalledWith('19', 'merge-commit', 'npm test', onConflict);\n243\t    });\n244\t\n245\t    it('worktree cleanup happens via mergeWorktree (not separately)', async () => {\n246\t      const wm = createMockWorktreeManager();\n247\t      const config = buildBaseConfig({ worktreeManager: wm, epicFlow: ['merge', 'validate'] });\n248\t\n249\t      await executeEpicFlow(config);\n250\t\n251\t      // cleanupWorktree should NOT be called by the executor — it's internal to mergeWorktree\n252\t      expect(wm.cleanupWorktree).not.toHaveBeenCalled();\n253\t    });\n254\t\n255\t    it('fails when mergeWorktree returns success: false with conflict', async () => {\n256\t      const wm = createMockWorktreeManager({\n257\t        success: false,\n258\t        reason: 'conflict',\n259\t        conflicts: ['src/index.ts'],\n260\t      });\n261\t      const config = buildBaseConfig({ worktreeManager: wm, epicFlow: ['merge', 'validate'] });\n262\t\n263\t      const result = await executeEpicFlow(config);\n264\t\n265\t      expect(result.success).toBe(false);\n266\t      expect(result.failedStep).toBe('merge');\n267\t      expect(result.error).toContain('Merge failed');\n268\t    });\n269\t\n270\t    it('fails when mergeWorktree returns success: false with tests-failed', async () => {\n271\t      const wm = createMockWorktreeManager({\n272\t        success: false,\n273\t        reason: 'tests-failed',\n274\t      });\n275\t      const config = buildBaseConfig({ worktreeManager: wm, epicFlow: ['merge', 'validate'] });\n276\t\n277\t      const result = await executeEpicFlow(config);\n278\t\n279\t      expect(result.success).toBe(false);\n280\t      expect(result.failedStep).toBe('merge');\n281\t    });\n282\t  });\n283\t\n284\t  // --- Validate step (AC #5) ---\n285\t\n286\t  describe('validate step', () => {\n287\t    it('calls validateMerge with correct args', async () => {\n288\t      const config = buildBaseConfig({ epicFlow: ['merge', 'validate'] });\n289\t\n290\t      await executeEpicFlow(config);\n291\t\n292\t      expect(mockValidateMerge).toHaveBeenCalledWith({\n293\t        testCommand: 'npm test',\n294\t        cwd: '/tmp/test-project',\n295\t        epicId: '19',\n296\t        writeTelemetry: true,\n297\t      });\n298\t    });\n299\t\n300\t    it('fails when validation returns valid: false', async () => {\n301\t      mockValidateMerge.mockResolvedValue({\n302\t        valid: false,\n303\t        testResults: { passed: 8, failed: 2, coverage: 80 },\n304\t        output: '2 failed',\n305\t        durationMs: 500,\n306\t      });\n307\t\n308\t      const config = buildBaseConfig({ epicFlow: ['merge', 'validate'] });\n309\t      const result = await executeEpicFlow(config);\n310\t\n311\t      expect(result.success).toBe(false);\n312\t      expect(result.failedStep).toBe('validate');\n313\t      expect(result.error).toContain('2 test(s) failed');\n314\t    });\n315\t  });\n316\t\n317\t  // --- State transitions (AC #6) ---\n318\t\n319\t  describe('state transitions', () => {\n320\t    it('transitions completing → merging before merge step', async () => {\n321\t      const stateChanges: string[] = [];\n322\t      const onStateChange = vi.fn().mockImplementation((s: SprintState) => {\n323\t        stateChanges.push(s.epics['epic-19'].status);\n324\t      });\n325\t\n326\t      const config = buildBaseConfig({ onStateChange, epicFlow: ['merge', 'validate'] });\n327\t      await executeEpicFlow(config);\n328\t\n329\t      // merging (before merge), validating (before validate), done (after all)\n330\t      expect(stateChanges).toEqual(['merging', 'validating', 'done']);\n331\t    });\n332\t\n333\t    it('transitions merging → validating before validate step', async () => {\n334\t      const stateChanges: string[] = [];\n335\t      const onStateChange = vi.fn().mockImplementation((s: SprintState) => {\n336\t        stateChanges.push(s.epics['epic-19'].status);\n337\t      });\n338\t\n339\t      const config = buildBaseConfig({ onStateChange, epicFlow: ['merge', 'validate'] });\n340\t      await executeEpicFlow(config);\n341\t\n342\t      expect(stateChanges[1]).toBe('validating');\n343\t    });\n344\t\n345\t    it('transitions to done after all steps succeed', async () => {\n346\t      const stateChanges: string[] = [];\n347\t      const onStateChange = vi.fn().mockImplementation((s: SprintState) => {\n348\t        stateChanges.push(s.epics['epic-19'].status);\n349\t      });\n350\t\n351\t      const config = buildBaseConfig({ onStateChange, epicFlow: ['merge', 'validate'] });\n352\t      await executeEpicFlow(config);\n353\t\n354\t      expect(stateChanges[stateChanges.length - 1]).toBe('done');\n355\t    });\n356\t\n357\t    it('does not transition state for retro step (no mapping)', async () => {\n358\t      const stateChanges: string[] = [];\n359\t      const onStateChange = vi.fn().mockImplementation((s: SprintState) => {\n360\t        stateChanges.push(s.epics['epic-19'].status);\n361\t      });\n362\t\n363\t      const config = buildBaseConfig({ onStateChange });\n364\t      await executeEpicFlow(config);\n365\t\n366\t      // retro has no state mapping, so first change is merging (from merge step)\n367\t      expect(stateChanges[0]).toBe('merging');\n368\t    });\n369\t  });\n370\t\n371\t  // --- Failure handling (AC #7) ---\n372\t\n373\t  describe('failure handling', () => {\n374\t    it('skips remaining steps on failure', async () => {\n375\t      const wm = createMockWorktreeManager({ success: false, reason: 'conflict' });\n376\t      const config = buildBaseConfig({ worktreeManager: wm, epicFlow: ['merge', 'validate'] });\n377\t\n378\t      const result = await executeEpicFlow(config);\n379\t\n380\t      expect(result.stepsCompleted).toEqual([]);\n381\t      expect(result.failedStep).toBe('merge');\n382\t      // validate was never called\n383\t      expect(mockValidateMerge).not.toHaveBeenCalled();\n384\t    });\n385\t\n386\t    it('transitions to failed on step failure', async () => {\n387\t      const stateChanges: string[] = [];\n388\t      const onStateChange = vi.fn().mockImplementation((s: SprintState) => {\n389\t        stateChanges.push(s.epics['epic-19'].status);\n390\t      });\n391\t\n392\t      const wm = createMockWorktreeManager({ success: false, reason: 'conflict' });\n393\t      const config = buildBaseConfig({ worktreeManager: wm, onStateChange, epicFlow: ['merge', 'validate'] });\n394\t\n395\t      await executeEpicFlow(config);\n396\t\n397\t      expect(stateChanges).toContain('failed');\n398\t    });\n399\t\n400\t    it('handles unknown step name as failure', async () => {\n401\t      // Need a state where completing can go to failed\n402\t      const config = buildBaseConfig({ epicFlow: ['unknown-step'] });\n403\t\n404\t      const result = await executeEpicFlow(config);\n405\t\n406\t      expect(result.success).toBe(false);\n407\t      expect(result.failedStep).toBe('unknown-step');\n408\t      expect(result.error).toContain('Unknown epic_flow step: \"unknown-step\"');\n409\t    });\n410\t\n411\t    it('handles dispatchRetro throwing an error', async () => {\n412\t      const dispatchRetro = vi.fn().mockRejectedValue(new Error('Agent dispatch failed'));\n413\t      // Retro has no state mapping; on failure it transitions to 'failed'.\n414\t      // completing → failed is valid.\n415\t      const config = buildBaseConfig({ epicFlow: ['retro'], dispatchRetro });\n416\t\n417\t      const result = await executeEpicFlow(config);\n418\t\n419\t      expect(result.success).toBe(false);\n420\t      expect(result.failedStep).toBe('retro');\n421\t      expect(result.error).toContain('Agent dispatch failed');\n422\t    });\n423\t  });\n424\t\n425\t  // --- EpicFlowResult shape (AC #8) ---\n426\t\n427\t  describe('EpicFlowResult', () => {\n428\t    it('has all expected fields on success', async () => {\n429\t      const config = buildBaseConfig({ epicFlow: ['merge', 'validate'] });\n