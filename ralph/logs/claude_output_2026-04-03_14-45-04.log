{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XFKEbxNcJxNPgSwE516z5N","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { parse } from 'yaml';\n3\timport { warn } from './output.js';\n4\timport { DispatchError } from './agent-dispatch.js';\n5\timport type { DispatchErrorCode } from './agent-dispatch.js';\n6\t// Note: dispatchAgent is no longer imported — dispatch goes through the driver factory\n7\timport { getDriver } from './agents/drivers/factory.js';\n8\timport { resolveModel } from './agents/model-resolver.js';\n9\timport type { DispatchOpts, DriverHealth, OutputContract } from './agents/types.js';\n10\timport type { ResultEvent } from './agents/stream-parser.js';\n11\timport type { SubagentDefinition } from './agent-resolver.js';\n12\timport type { ResolvedWorkflow, ResolvedTask, FlowStep, LoopBlock } from './workflow-parser.js';\n13\timport {\n14\t  readWorkflowState,\n15\t  writeWorkflowState,\n16\t} from './workflow-state.js';\n17\timport { buildPromptWithContractContext } from './agents/output-contract.js';\n18\timport type { WorkflowState, TaskCheckpoint } from './workflow-state.js';\n19\timport { createIsolatedWorkspace } from './source-isolation.js';\n20\timport { generateTraceId, formatTracePrompt, recordTraceId } from './trace-id.js';\n21\timport { resolveSessionId, recordSessionId } from './session-manager.js';\n22\timport type { SessionLookupKey } from './session-manager.js';\n23\timport { parseVerdict, VerdictParseError } from './verdict-parser.js';\n24\timport type { EvaluatorVerdict } from './verdict-parser.js';\n25\timport { evaluateProgress } from './circuit-breaker.js';\n26\t\n27\t// Re-export EvaluatorVerdict for downstream consumers that import from workflow-engine\n28\texport type { EvaluatorVerdict } from './verdict-parser.js';\n29\texport { parseVerdict } from './verdict-parser.js';\n30\t\n31\t// --- Interfaces ---\n32\t\n33\t/**\n34\t * Configuration for the workflow engine.\n35\t */\n36\texport interface EngineConfig {\n37\t  /** The resolved workflow with tasks and flow steps. */\n38\t  workflow: ResolvedWorkflow;\n39\t  /** Pre-compiled agent definitions keyed by agent name. */\n40\t  agents: Record<string, SubagentDefinition>;\n41\t  /** Path to sprint-status.yaml for work item discovery. */\n42\t  sprintStatusPath: string;\n43\t  /** Optional path to issues.yaml for additional work items. */\n44\t  issuesPath?: string;\n45\t  /** Unique identifier for this engine run. */\n46\t  runId: string;\n47\t  /** Project root directory. Defaults to process.cwd(). */\n48\t  projectDir?: string;\n49\t  /** Maximum loop iterations before termination. Defaults to 5. */\n50\t  maxIterations?: number;\n51\t}\n52\t\n53\t/**\n54\t * Result returned by executeWorkflow().\n55\t */\n56\texport interface EngineResult {\n57\t  /** Whether the workflow completed without errors. */\n58\t  success: boolean;\n59\t  /** Number of task dispatches completed. */\n60\t  tasksCompleted: number;\n61\t  /** Number of work items (stories/issues) processed. */\n62\t  storiesProcessed: number;\n63\t  /** Errors encountered during execution. */\n64\t  errors: EngineError[];\n65\t  /** Wall-clock duration of the entire workflow in milliseconds. */\n66\t  durationMs: number;\n67\t}\n68\t\n69\t/**\n70\t * Structured error recorded during workflow execution.\n71\t */\n72\texport interface EngineError {\n73\t  taskName: string;\n74\t  storyKey: string;\n75\t  code: string;\n76\t  message: string;\n77\t}\n78\t\n79\t/**\n80\t * A work item (story or issue) ready for execution.\n81\t */\n82\texport interface WorkItem {\n83\t  key: string;\n84\t  title?: string;\n85\t  source: 'sprint' | 'issues';\n86\t}\n87\t\n88\t// --- Constants ---\n89\t\n90\t/** Sentinel story key for per-run tasks. */\n91\texport const PER_RUN_SENTINEL = '__run__';\n92\t\n93\t/** DispatchError codes that should halt execution immediately. */\n94\tconst HALT_ERROR_CODES = new Set(['RATE_LIMIT', 'NETWORK', 'SDK_INIT']);\n95\t\n96\t/** Default maximum loop iterations before termination. */\n97\tconst DEFAULT_MAX_ITERATIONS = 5;\n98\t\n99\t// --- Crash Recovery: Task Completion Check ---\n100\t\n101\t/**\n102\t * Check whether a (taskName, storyKey) combination is already recorded\n103\t * in the workflow state's tasks_completed array.\n104\t *\n105\t * Both fields must match for the task to be considered completed.\n106\t * Used by the resume logic to skip already-completed dispatches.\n107\t */\n108\texport function isTaskCompleted(\n109\t  state: WorkflowState,\n110\t  taskName: string,\n111\t  storyKey: string,\n112\t): boolean {\n113\t  return state.tasks_completed.some(\n114\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey && !cp.error,\n115\t  );\n116\t}\n117\t\n118\t/**\n119\t * Check whether a (taskName, storyKey) combination has been completed\n120\t * enough times to cover the current iteration in a loop block.\n121\t *\n122\t * Loop tasks execute the same (taskName, storyKey) pair each iteration,\n123\t * recording a new checkpoint each time. To determine if a task is done\n124\t * for the current iteration, we count how many matching checkpoints exist\n125\t * and compare to the current iteration number.\n126\t */\n127\texport function isLoopTaskCompleted(\n128\t  state: WorkflowState,\n129\t  taskName: string,\n130\t  storyKey: string,\n131\t  iteration: number,\n132\t): boolean {\n133\t  const count = state.tasks_completed.filter(\n134\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey && !cp.error,\n135\t  ).length;\n136\t  return count >= iteration;\n137\t}\n138\t\n139\t// --- Work Item Loading ---\n140\t\n141\t/**\n142\t * Load work items from sprint-status.yaml and optionally issues.yaml.\n143\t *\n144\t * Stories are extracted from the `development_status` section of sprint-status.yaml.\n145\t * Issues are extracted from the `issues` array of issues.yaml.\n146\t *\n147\t * Only items with status `backlog` or `ready-for-dev` are included.\n148\t * Epic keys (`epic-*`) and retrospective keys (`*-retrospective`) are excluded.\n149\t *\n150\t * If issues.yaml does not exist, returns only stories (no error).\n151\t */\n152\texport function loadWorkItems(sprintStatusPath: string, issuesPath?: string): WorkItem[] {\n153\t  const items: WorkItem[] = [];\n154\t\n155\t  // --- Load stories from sprint-status.yaml ---\n156\t  if (existsSync(sprintStatusPath)) {\n157\t    let raw: string;\n158\t    try {\n159\t      raw = readFileSync(sprintStatusPath, 'utf-8');\n160\t    } catch { // IGNORE: unreadable file — warn and return empty\n161\t      warn(`workflow-engine: could not read sprint-status.yaml at ${sprintStatusPath}`);\n162\t      return items;\n163\t    }\n164\t\n165\t    let parsed: unknown;\n166\t    try {\n167\t      parsed = parse(raw);\n168\t    } catch { // IGNORE: malformed YAML — warn and return empty\n169\t      warn(`workflow-engine: invalid YAML in sprint-status.yaml at ${sprintStatusPath}`);\n170\t      return items;\n171\t    }\n172\t\n173\t    if (parsed && typeof parsed === 'object') {\n174\t      const data = parsed as Record<string, unknown>;\n175\t      const devStatus = data.development_status as Record<string, unknown> | undefined;\n176\t\n177\t      if (devStatus && typeof devStatus === 'object') {\n178\t        for (const [key, status] of Object.entries(devStatus)) {\n179\t          // Skip epic keys and retrospective keys\n180\t          if (key.startsWith('epic-')) continue;\n181\t          if (key.endsWith('-retrospective')) continue;\n182\t\n183\t          // Only include backlog or ready-for-dev\n184\t          if (status === 'backlog' || status === 'ready-for-dev') {\n185\t            items.push({ key, source: 'sprint' });\n186\t          }\n187\t        }\n188\t      }\n189\t    }\n190\t  }\n191\t\n192\t  // --- Load issues from issues.yaml ---\n193\t  if (issuesPath && existsSync(issuesPath)) {\n194\t    let raw: string;\n195\t    try {\n196\t      raw = readFileSync(issuesPath, 'utf-8');\n197\t    } catch { // IGNORE: unreadable issues file — warn and return what we have\n198\t      warn(`workflow-engine: could not read issues.yaml at ${issuesPath}`);\n199\t      return items;\n200\t    }\n201\t\n202\t    let parsed: unknown;\n203\t    try {\n204\t      parsed = parse(raw);\n205\t    } catch { // IGNORE: malformed issues YAML — warn and return what we have\n206\t      warn(`workflow-engine: invalid YAML in issues.yaml at ${issuesPath}`);\n207\t      return items;\n208\t    }\n209\t\n210\t    if (parsed && typeof parsed === 'object') {\n211\t      const data = parsed as Record<string, unknown>;\n212\t      const issuesList = data.issues as Array<Record<string, unknown>> | undefined;\n213\t\n214\t      if (Array.isArray(issuesList)) {\n215\t        for (const issue of issuesList) {\n216\t          if (issue && typeof issue === 'object') {\n217\t            const status = issue.status as string | undefined;\n218\t            if (status === 'backlog' || status === 'ready-for-dev') {\n219\t              items.push({\n220\t                key: issue.id as string,\n221\t                title: issue.title as string | undefined,\n222\t                source: 'issues',\n223\t              });\n224\t            }\n225\t          }\n226\t        }\n227\t      }\n228\t    }\n229\t  }\n230\t\n231\t  return items;\n232\t}\n233\t\n234\t// --- Single Task Dispatch ---\n235\t\n236\t/**\n237\t * Dispatch a single task for a specific work item (or per-run sentinel).\n238\t *\n239\t * Handles: trace ID generation, session resolution, source isolation,\n240\t * agent dispatch, state checkpointing, and cleanup.\n241\t *\n242\t * Returns the updated workflow state after recording the dispatch.\n243\t */\n244\texport async function dispatchTask(\n245\t  task: ResolvedTask,\n246\t  taskName: string,\n247\t  storyKey: string,\n248\t  definition: SubagentDefinition,\n249\t  state: WorkflowState,\n250\t  config: EngineConfig,\n251\t  customPrompt?: string,\n252\t  previousOutputContract?: OutputContract,\n253\t): Promise<WorkflowState> {\n254\t  const { updatedState } = await dispatchTaskWithResult(\n255\t    task, taskName, storyKey, definition, state, config, customPrompt, previousOutputContract,\n256\t  );\n257\t  return updatedState;\n258\t}\n259\t\n260\t// --- Flow Step Type Guard ---\n261\t\n262\tfunction isLoopBlock(step: FlowStep): step is LoopBlock {\n263\t  return typeof step === 'object' && step !== null && 'loop' in step;\n264\t}\n265\t\n266\t// --- Core Dispatch (shared by dispatchTask and loop block execution) ---\n267\t\n268\t/**\n269\t * Dispatch a task and return both the updated state and the raw dispatch output.\n270\t * This is the single implementation of task dispatch logic. Both `dispatchTask()`\n271\t * and loop block execution delegate here.\n272\t */\n273\tasync function dispatchTaskWithResult(\n274\t  task: ResolvedTask,\n275\t  taskName: string,\n276\t  storyKey: string,\n277\t  definition: SubagentDefinition,\n278\t  state: WorkflowState,\n279\t  config: EngineConfig,\n280\t  customPrompt?: string,\n281\t  previousOutputContract?: OutputContract,\n282\t): Promise<{ updatedState: WorkflowState; output: string }> {\n283\t  const projectDir = config.projectDir ?? process.cwd();\n284\t\n285\t  // 1. Generate trace ID\n286\t  const traceId = generateTraceId(config.runId, state.iteration, taskName);\n287\t\n288\t  // 2. Format trace prompt — injected into driver via DispatchOpts.appendSystemPrompt\n289\t  const tracePrompt = formatTracePrompt(traceId);\n290\t\n291\t  // 3. Resolve session ID\n292\t  const sessionKey: SessionLookupKey = { taskName, storyKey };\n293\t  const sessionId = resolveSessionId(task.session, sessionKey, state);\n294\t\n295\t  // 4. Resolve driver\n296\t  const driverName = task.driver ?? 'claude-code';\n297\t  const driver = getDriver(driverName);\n298\t\n299\t  // 5. Resolve model via cascade: task → agent → driver\n300\t  const agentAsModelSource = { model: definition.model };\n301\t  const model = resolveModel(task, agentAsModelSource, driver);\n302\t\n303\t  // 6. Determine cwd based on source_access\n304\t  let cwd: string;\n305\t  let workspace: Awaited<ReturnType<typeof createIsolatedWorkspace>> | null = null;\n306\t\n307\t  if (task.source_access === false) {\n308\t    workspace = await createIsolatedWorkspace({ runId: config.runId, storyFiles: [] });\n309\t    cwd = workspace.toDispatchOptions().cwd ?? projectDir;\n310\t  } else {\n311\t    cwd = projectDir;\n312\t  }\n313\t\n314\t  // 7. Construct prompt\n315\t  const basePrompt = customPrompt\n316\t    ?? (storyKey === PER_RUN_SENTINEL\n317\t      ? `Execute task \"${taskName}\" for the current run.`\n318\t      : `Implement story ${storyKey}`);\n319\t\n320\t  // 7b. Inject previous task's output contract context into the prompt (story 13-2)\n321\t  const prompt = buildPromptWithContractContext(basePrompt, previousOutputContract ?? null);\n322\t\n323\t  // 8. Build DispatchOpts for the driver\n324\t  const dispatchOpts: DispatchOpts = {\n325\t    prompt,\n326\t    model,\n327\t    cwd,\n328\t    sourceAccess: task.source_access !== false,\n329\t    ...(sessionId ? { sessionId } : {}),\n330\t    ...(tracePrompt ? { appendSystemPrompt: tracePrompt } : {}),\n331\t    ...(task.plugins ? { plugins: task.plugins } : {}),\n332\t    ...(task.max_budget_usd != null ? { timeout: task.max_budget_usd } : {}),\n333\t  };\n334\t\n335\t  // 9. Dispatch through the driver and consume AsyncIterable<StreamEvent>\n336\t  let output = '';\n337\t  let resultSessionId = '';\n338\t  let cost = 0;\n339\t  let errorEvent: { error: string; errorCategory?: string } | null = null;\n340\t\n341\t  try {\n342\t    for await (const event of driver.dispatch(dispatchOpts)) {\n343\t      if (event.type === 'text') {\n344\t        output += event.text;\n345\t      }\n346\t      if (event.type === 'result') {\n347\t        const resultEvt = event as ResultEvent;\n348\t        resultSessionId = resultEvt.sessionId;\n349\t        cost = resultEvt.cost;\n350\t        if (resultEvt.error) {\n351\t          errorEvent = { error: resultEvt.error, errorCategory: resultEvt.errorCategory };\n352\t        }\n353\t      }\n354\t    }\n355\t  } finally {\n356\t    // Cleanup workspace regardless of dispatch success/failure\n357\t    if (workspace) {\n358\t      await workspace.cleanup();\n359\t    }\n360\t  }\n361\t\n362\t  // 10. If the driver reported an error in the result event, throw DispatchError\n363\t  if (errorEvent) {\n364\t    // Map ErrorCategory to DispatchErrorCode\n365\t    const categoryToCode: Record<string, string> = {\n366\t      RATE_LIMIT: 'RATE_LIMIT',\n367\t      NETWORK: 'NETWORK',\n368\t      SDK_INIT: 'SDK_INIT',\n369\t      AUTH: 'UNKNOWN',\n370\t      TIMEOUT: 'UNKNOWN',\n371\t      UNKNOWN: 'UNKNOWN',\n372\t    };\n373\t    const code = categoryToCode[errorEvent.errorCategory ?? 'UNKNOWN'] ?? 'UNKNOWN';\n374\t    throw new DispatchError(\n375\t      errorEvent.error,\n376\t      code as DispatchErrorCode,\n377\t      definition.name,\n378\t      errorEvent,\n379\t    );\n380\t  }\n381\t\n382\t  // 11. Record session ID (if dispatch returned one)\n383\t  let updatedState = state;\n384\t  if (resultSessionId) {\n385\t    updatedState = recordSessionId(sessionKey, resultSessionId, updatedState);\n386\t  } else {\n387\t    // Append checkpoint manually when no session ID is returned\n388\t    const checkpoint: TaskCheckpoint = {\n389\t      task_name: taskName,\n390\t      story_key: storyKey,\n391\t      completed_at: new Date().toISOString(),\n392\t    };\n393\t    updatedState = {\n394\t      ...updatedState,\n395\t      tasks_completed: [...updatedState.tasks_completed, checkpoint],\n396\t    };\n397\t  }\n398\t\n399\t  // 12. Record trace ID\n400\t  updatedState = recordTraceId(traceId, updatedState);\n401\t\n402\t  // 13. Write state to disk\n403\t  writeWorkflowState(updatedState, projectDir);\n404\t\n405\t  return { updatedState, output };\n406\t}\n407\t\n408\t// --- Retry Prompt Construction (Task 3) ---\n409\t\n410\t/**\n411\t * Build a retry prompt with evaluator findings injected.\n412\t * Includes only failed/unknown findings.\n413\t */\n414\texport function buildRetryPrompt(storyKey: string, findings: EvaluatorVerdict['findings']): string {\n415\t  const failedFindings = findings.filter(\n416\t    (f) => f.status === 'fail' || f.status === 'unknown',\n417\t  );\n418\t\n419\t  if (failedFindings.length === 0) {\n420\t    return `Implement story ${storyKey}`;\n421\t  }\n422\t\n423\t  const formattedFindings = failedFindings\n424\t    .map((f) => {\n425\t      const status = f.status.toUpperCase();\n426\t      let entry = `AC #${f.ac} (${status}): ${f.description}`;\n427\t      if (f.evidence?.reasoning) {\n428\t        entry += `\\n  Evidence: ${f.evidence.reasoning}`;\n429\t      }\n430\t      return entry;\n431\t    })\n432\t    .join('\\n\\n');\n433\t\n434\t  return `Retry story ${storyKey}. Previous evaluator findings:\\n\\n${formattedFindings}\\n\\nFocus on fixing the failed criteria above.`;\n435\t}\n436\t\n437\t// --- All-UNKNOWN Verdict Builder ---\n438\t\n439\t/**\n440\t * Build an all-UNKNOWN EvaluatorVerdict as fallback when the evaluator\n441\t * fails to produce valid JSON after retry.\n442\t */\n443\texport function buildAllUnknownVerdict(\n444\t  workItems: WorkItem[],\n445\t  reasoning: string,\n446\t): EvaluatorVerdict {\n447\t  const findings = workItems.map((_, index) => ({\n448\t    ac: index + 1,\n449\t    description: `AC #${index + 1}`,\n450\t    status: 'unknown' as const,\n451\t    evidence: {\n452\t      commands_run: [] as string[],\n453\t      output_observed: '',\n454\t      reasoning,\n455\t    },\n456\t  }));\n457\t\n458\t  return {\n459\t    verdict: 'fail',\n460\t    score: {\n461\t      passed: 0,\n462\t      failed: 0,\n463\t      unknown: findings.length,\n464\t      total: findings.length,\n465\t    },\n466\t    findings,\n467\t  };\n468\t}\n469\t\n470\t// --- Failed Story Filtering (Task 4) ---\n471\t\n472\t/**\n473\t * Determine which work items failed based on evaluator findings.\n474\t * If verdict is null (parse failure), returns all items (conservative fallback).\n475\t */\n476\texport function getFailedItems(\n477\t  verdict: EvaluatorVerdict | null,\n478\t  allItems: WorkItem[],\n479\t): WorkItem[] {\n480\t  if (!verdict) return allItems;\n481\t\n482\t  // If verdict passed, no items need retry\n483\t  if (verdict.verdict === 'pass') return [];\n484\t\n485\t  // All items are retried on failure — per-story filtering based on individual\n486\t  // story results is not possible with the current verdict shape (verdict is per-run).\n487\t  // The findings track ACs, not stories. Conservative: retry all on failure.\n488\t  return allItems;\n489\t}\n490\t\n491\t// --- Loop Block Execution (Task 5) ---\n492\t\n493\t/**\n494\t * Result of loop block execution.\n495\t */\n496\tinterface LoopBlockResult {\n497\t  state: WorkflowState;\n498\t  errors: EngineError[];\n499\t  tasksCompleted: number;\n500\t  halted: boolean;\n501\t}\n502\t\n503\t/**\n504\t * Execute a loop block: iterate tasks until pass, max iterations, or circuit breaker.\n505\t */\n506\texport async function executeLoopBlock(\n507\t  loopBlock: LoopBlock,\n508\t  state: WorkflowState,\n509\t  config: EngineConfig,\n510\t  workItems: WorkItem[],\n511\t): Promise<LoopBlockResult> {\n512\t  const projectDir = config.projectDir ?? process.cwd();\n513\t  const maxIterations = config.maxIterations ?? DEFAULT_MAX_ITERATIONS;\n514\t  const errors: EngineError[] = [];\n515\t  let tasksCompleted = 0;\n516\t  let currentState = state;\n517\t  let lastVerdict: EvaluatorVerdict | null = null;\n518\t\n519\t  // Handle empty loop block\n520\t  if (loopBlock.loop.length === 0) {\n521\t    return { state: currentState, errors, tasksCompleted, halted: false };\n522\t  }\n523\t\n524\t  while (true) {\n525\t    // 1. Determine whether to increment iteration or resume a partial one.\n526\t    //    On fresh start (iteration === 0), always increment.\n527\t    //    On resume (iteration > 0), check if the current iteration is fully done.\n528\t    const nextIteration = currentState.iteration + 1;\n529\t    const allCurrentIterationDone = currentState.iteration > 0 && loopBlock.loop.every((tn) => {\n530\t      const t = config.workflow.tasks[tn];\n531\t      if (!t) return true; // missing task = skip = \"done\"\n532\t      if (t.scope === 'per-story') {\n533\t        return workItems.every((item) =>\n534\t          isLoopTaskCompleted(currentState, tn, item.key, currentState.iteration));\n535\t      }\n536\t      return isLoopTaskCompleted(currentState, tn, PER_RUN_SENTINEL, currentState.iteration);\n537\t    });\n538\t\n539\t    if (currentState.iteration === 0 || allCurrentIterationDone) {\n540\t      // Fresh start or current iteration fully done — advance\n541\t      currentState = {\n542\t        ...currentState,\n543\t        iteration: nextIteration,\n544\t      };\n545\t      writeWorkflowState(currentState, projectDir);\n546\t    }\n547\t    // else: resuming a partially completed iteration — keep current iteration\n548\t\n549\t    let haltedInLoop = false;\n550\t\n551\t    // 2. Execute each task in the loop\n552\t    for (const taskName of loopBlock.loop) {\n553\t      const task = config.workflow.tasks[taskName];\n554\t      if (!task) {\n555\t        warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n556\t        continue;\n557\t      }\n558\t\n559\t      const definition = config.agents[task.agent];\n560\t      if (!definition) {\n561\t        warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n562\t        continue;\n563\t      }\n564\t\n565\t      if (task.scope === 'per-story') {\n566\t        // Determine which items to dispatch for\n567\t        const itemsToRetry = lastVerdict ? getFailedItems(lastVerdict, workItems) : workItems;\n568\t\n569\t        for (const item of itemsToRetry) {\n570\t          // Skip if already completed for this iteration (crash recovery — AC #4)\n571\t          if (isLoopTaskCompleted(currentState, taskName, item.key, currentState.iteration)) {\n572\t            warn(`workflow-engine: skipping completed task ${taskName} for ${item.key}`);\n573\t            continue;\n574\t          }\n575\t\n576\t          // Build prompt: inject findings if we have a previous verdict\n577\t          const prompt = lastVerdict\n578\t            ? buildRetryPrompt(item.key, lastVerdict.findings)\n579\t            : undefined;\n580\t\n581\t          try {\n582\t            currentState = await dispatchTask(\n583\t              task, taskName, item.key, definition, currentState, config, prompt,\n584\t            );\n585\t            tasksCompleted++;\n586\t          } catch (err: unknown) {\n587\t            const engineError = handleDispatchError(err, taskName, item.key);\n588\t            errors.push(engineError);\n589\t            currentState = recordErrorInState(currentState, taskName, item.key, engineError);\n590\t            writeWorkflowState(currentState, projectDir);\n591\t\n592\t            if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n593\t              haltedInLoop = true;\n594\t              break;\n595\t            }\n596\t            continue;\n597\t          }\n598\t        }\n599\t\n600\t        if (haltedInLoop) break;\n601\t      } else {\n602\t        // per-run task (e.g., verify)\n603\t        // Skip if already completed for this iteration (crash recovery — AC #4)\n604\t        if (isLoopTaskCompleted(currentState, taskName, PER_RUN_SENTINEL, currentState.iteration)) {\n605\t          warn(`workflow-engine: skipping completed task ${taskName} for ${PER_RUN_SENTINEL}`);\n606\t          continue;\n607\t        }\n608\t\n609\t        try {\n610\t          // We need the dispatch result output to parse verdict\n611\t          // dispatchTask doesn't return the DispatchResult directly, so we\n612\t          // intercept via a wrapper that captures the output\n613\t          const dispatchResult = await dispatchTaskWithResult(\n614\t            task, taskName, PER_RUN_SENTINEL, definition, currentState, config,\n615\t          );\n616\t          currentState = dispatchResult.updatedState;\n617\t          tasksCompleted++;\n618\t\n619\t          // Attempt to parse verdict from output with retry semantics (story 6-2)\n620\t          let verdict: EvaluatorVerdict | null = null;\n621\t          try {\n622\t            verdict = parseVerdict(dispatchResult.output);\n623\t          } catch (parseErr: unknown) {\n624\t            if (parseErr instanceof VerdictParseError && parseErr.retryable) {\n625\t              // Re-dispatch evaluator for one retry attempt\n626\t              warn(`workflow-engine: verdict parse failed, retrying evaluator for ${taskName}`);\n627\t              try {\n628\t                const retryResult = await dispatchTaskWithResult(\n629\t                  task, taskName, PER_RUN_SENTINEL, definition, currentState, config,\n630\t                );\n631\t                currentState = retryResult.updatedState;\n632\t                tasksCompleted++;\n633\t                verdict = parseVerdict(retryResult.output);\n634\t              } catch { // IGNORE: retry failed — fall back to all-UNKNOWN verdict\n635\t                // Second failure: generate all-UNKNOWN verdict\n636\t                verdict = buildAllUnknownVerdict(\n637\t                  workItems,\n638\t                  'Evaluator failed to produce valid JSON after retry',\n639\t                );\n640\t              }\n641\t            }\n642\t            // If not a VerdictParseError or not retryable, verdict stays null\n643\t          }\n644\t          lastVerdict = verdict;\n645\t\n646\t          // Record score in state\n647\t          if (verdict) {\n648\t            const score = {\n649\t              iteration: currentState.iteration,\n650\t              passed: verdict.score.passed,\n651\t              failed: verdict.score.failed,\n652\t              unknown: verdict.score.unknown,\n653\t              total: verdict.score.total,\n654\t              timestamp: new Date().toISOString(),\n655\t            };\n656\t            currentState = {\n657\t              ...currentState,\n658\t              evaluator_scores: [...currentState.evaluator_scores, score],\n659\t            };\n660\t          } else {\n661\t            // Parse failure: record all-UNKNOWN score\n662\t            const totalItems = workItems.length;\n663\t            const score = {\n664\t              iteration: currentState.iteration,\n665\t              passed: 0,\n666\t              failed: 0,\n667\t              unknown: totalItems,\n668\t              total: totalItems,\n669\t              timestamp: new Date().toISOString(),\n670\t            };\n671\t            currentState = {\n672\t              ...currentState,\n673\t              evaluator_scores: [...currentState.evaluator_scores, score],\n674\t            };\n675\t          }\n676\t          writeWorkflowState(currentState, projectDir);\n677\t\n678\t          // Circuit breaker: evaluate progress after recording score\n679\t          const cbDecision = evaluateProgress(currentState.evaluator_scores);\n680\t          if (cbDecision.halt) {\n681\t            currentState = {\n682\t              ...currentState,\n683\t              circuit_breaker: {\n684\t                triggered: true,\n685\t                reason: cbDecision.reason,\n686\t                score_history: cbDecision.scoreHistory,\n687\t              },\n688\t            };\n689\t            writeWorkflowState(currentState, projectDir);\n690\t          }\n691\t        } catch (err: unknown) {\n692\t          const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n693\t          errors.push(engineError);\n694\t          currentState = recordErrorInState(currentState, taskName, PER_RUN_SENTINEL, engineError);\n695\t          writeWorkflowState(currentState, projectDir);\n696\t\n697\t          // Clear stale verdict so next iteration retries all items\n698\t          lastVerdict = null;\n699\t\n700\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n701\t            haltedInLoop = true;\n702\t            break;\n703\t          }\n704\t          continue;\n705\t        }\n706\t      }\n707\t    }\n708\t\n709\t    if (haltedInLoop) {\n710\t      return { state: currentState, errors, tasksCompleted, halted: true };\n711\t    }\n712\t\n713\t    // 3. Check termination conditions\n714\t    if (lastVerdict?.verdict === 'pass') {\n715\t      // Success: loop passes\n716\t      return { state: currentState, errors, tasksCompleted, halted: false };\n717\t    }\n718\t\n719\t    if (currentState.iteration >= maxIterations) {\n720\t      currentState = { ...currentState, phase: 'max-iterations' };\n721\t      writeWorkflowState(currentState, projectDir);\n722\t      return { state: currentState, errors, tasksCompleted, halted: false };\n723\t    }\n724\t\n725\t    if (currentState.circuit_breaker.triggered) {\n726\t      currentState = { ...currentState, phase: 'circuit-breaker' };\n727\t      writeWorkflowState(currentState, projectDir);\n728\t      return { state: currentState, errors, tasksCompleted, halted: false };\n729\t    }\n730\t  }\n731\t}\n732\t\n733\t\n734\t// --- Driver Health Check ---\n735\t\n736\t/** Default timeout for the health check phase (NFR6). */\n737\tconst HEALTH_CHECK_TIMEOUT_MS = 5000;\n738\t\n739\t/**\n740\t * Run health checks on all unique drivers referenced in a workflow.\n741\t *\n742\t * Collects unique driver names from `workflow.tasks`, resolves each via\n743\t * `getDriver()`, and runs all `healthCheck()` calls concurrently with a\n744\t * 5-second timeout (NFR6).\n745\t *\n746\t * Throws if any driver is unavailable or if the timeout fires.\n747\t */\n748\texport async function checkDriverHealth(workflow: ResolvedWorkflow, timeoutMs?: number): Promise<void> {\n749\t  // 1. Collect unique driver names from all tasks\n750\t  const driverNames = new Set<string>();\n751\t  for (const task of Object.values(workflow.tasks)) {\n752\t    driverNames.add(task.driver ?? 'claude-code');\n753\t  }\n754\t\n755\t  // 2. Resolve drivers\n756\t  const drivers = new Map<string, ReturnType<typeof getDriver>>();\n757\t  for (const name of driverNames) {\n758\t    drivers.set(name, getDriver(name));\n759\t  }\n760\t\n761\t  // 3. Run health checks concurrently, tracking which drivers responded\n762\t  interface HealthResult { name: string; health: DriverHealth }\n763\t  const responded = new Set<string>();\n764\t  const healthChecks = Promise.all(\n765\t    [...drivers.entries()].map(async ([name, driver]): Promise<HealthResult> => {\n766\t      const health = await driver.healthCheck();\n767\t      responded.add(name);\n768\t      return { name, health };\n769\t    }),\n770\t  );\n771\t\n772\t  // 4. Race against timeout (NFR6) — clear timer on success to prevent leaks\n773\t  const effectiveTimeout = timeoutMs ?? HEALTH_CHECK_TIMEOUT_MS;\n774\t  let timer: ReturnType<typeof setTimeout>;\n775\t  const timeoutPromise = new Promise<'timeout'>((resolve) => {\n776\t    timer = setTimeout(() => resolve('timeout'), effectiveTimeout);\n777\t  });\n778\t\n779\t  const result = await Promise.race([healthChecks, timeoutPromise]);\n780\t\n781\t  if (result === 'timeout') {\n782\t    // Report only the drivers that did NOT respond (AC #6)\n783\t    const pending = [...driverNames].filter((n) => !responded.has(n));\n784\t    const names = pending.length > 0 ? pending.join(', ') : [...driverNames].join(', ');\n785\t    throw new Error(\n786\t      `Driver health check timed out after ${effectiveTimeout}ms. Drivers that did not respond: ${names}`,\n787\t    );\n788\t  }\n789\t\n790\t  // Health checks completed before timeout — clear the timer\n791\t  clearTimeout(timer!);\n792\t\n793\t  // 5. Check for failures\n794\t  const failures = result.filter((r) => !r.health.available);\n795\t  if (failures.length > 0) {\n796\t    const details = failures\n797\t      .map((f) => `${f.name}: ${f.health.error ?? 'unavailable'}`)\n798\t      .join('; ');\n799\t    throw new Error(`Driver health check failed: ${details}`);\n800\t  }\n801\t}\n802\t\n803\t// --- Main Execution ---\n804\t\n805\t/**\n806\t * Execute a workflow sequentially: iterate through flow steps, dispatch tasks\n807\t * per-story or per-run, checkpoint state after each dispatch.\n808\t *\n809\t * Loop blocks execute iteratively until pass, max-iterations, or circuit-breaker.\n810\t *\n811\t * Returns an EngineResult summarizing the execution.\n812\t */\n813\texport async function executeWorkflow(config: EngineConfig): Promise<EngineResult> {\n814\t  const startMs = Date.now();\n815\t  const projectDir = config.projectDir ?? process.cwd();\n816\t  const errors: EngineError[] = [];\n817\t  let tasksCompleted = 0;\n818\t  const processedStories = new Set<string>();\n819\t\n820\t  // 1. Read or initialize workflow state\n821\t  let state = readWorkflowState(projectDir);\n822\t\n823\t  // Early exit: workflow already completed (AC #6)\n824\t  if (state.phase === 'completed') {\n825\t    return {\n826\t      success: true,\n827\t      tasksCompleted: 0,\n828\t      storiesProcessed: 0,\n829\t      errors: [],\n830\t      durationMs: 0,\n831\t    };\n832\t  }\n833\t\n834\t  state = {\n835\t    ...state,\n836\t    phase: 'executing',\n837\t    started: state.started || new Date().toISOString(),\n838\t    workflow_name: config.workflow.flow.filter((s) => typeof s === 'string').join(' -> '),\n839\t  };\n840\t  writeWorkflowState(state, projectDir);\n841\t\n842\t  // 1b. Pre-flight driver health check\n843\t  try {\n844\t    await checkDriverHealth(config.workflow);\n845\t  } catch (err: unknown) { // IGNORE: health check failure — record and abort\n846\t    const message = err instanceof Error ? err.message : String(err);\n847\t    state = { ...state, phase: 'failed' };\n848\t    const engineError: EngineError = {\n849\t      taskName: '__health_check__',\n850\t      storyKey: '__health_check__',\n851\t      code: 'HEALTH_CHECK',\n852\t      message,\n853\t    };\n854\t    errors.push(engineError);\n855\t    writeWorkflowState(state, projectDir);\n856\t    return {\n857\t      success: false,\n858\t      tasksCompleted: 0,\n859\t      storiesProcessed: 0,\n860\t      errors,\n861\t      durationMs: Date.now() - startMs,\n862\t    };\n863\t  }\n864\t\n865\t  // 2. Load work items\n866\t  const workItems = loadWorkItems(config.sprintStatusPath, config.issuesPath);\n867\t\n868\t  // 3. Iterate through flow steps\n869\t  let halted = false;\n870\t  for (const step of config.workflow.flow) {\n871\t    if (halted) break;\n872\t\n873\t    // Execute loop blocks\n874\t    if (isLoopBlock(step)) {\n875\t      const loopResult = await executeLoopBlock(step, state, config, workItems);\n876\t      state = loopResult.state;\n877\t      errors.push(...loopResult.errors);\n878\t      tasksCompleted += loopResult.tasksCompleted;\n879\t\n880\t      // Track processed stories from loop\n881\t      for (const item of workItems) {\n882\t        processedStories.add(item.key);\n883\t      }\n884\t\n885\t      if (loopResult.halted) {\n886\t        halted = true;\n887\t      }\n888\t\n889\t      // If loop ended with max-iterations or circuit-breaker, treat as failure\n890\t      if (state.phase === 'max-iterations' || state.phase === 'circuit-breaker') {\n891\t        halted = true;\n892\t      }\n893\t      continue;\n894\t    }\n895\t\n896\t    // step is a string task name\n897\t    const taskName = step;\n898\t    const task = config.workflow.tasks[taskName];\n899\t\n900\t    if (!task) {\n901\t      warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n902\t      continue;\n903\t    }\n904\t\n905\t    // Look up the agent definition\n906\t    const definition = config.agents[task.agent];\n907\t    if (!definition) {\n908\t      warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n909\t      continue;\n910\t    }\n911\t\n912\t    if (task.scope === 'per-run') {\n913\t      // Skip if already completed (crash recovery — AC #3)\n914\t      if (isTaskCompleted(state, taskName, PER_RUN_SENTINEL)) {\n915\t        warn(`workflow-engine: skipping completed task ${taskName} for ${PER_RUN_SENTINEL}`);\n916\t        continue;\n917\t      }\n918\t\n919\t      // Per-run: dispatch once with sentinel key\n920\t      try {\n921\t        state = await dispatchTask(task, taskName, PER_RUN_SENTINEL, definition, state, config);\n922\t        tasksCompleted++;\n923\t      } catch (err: unknown) {\n924\t        const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n925\t        errors.push(engineError);\n926\t\n927\t        // Record error checkpoint in state (AC #13)\n928\t        state = recordErrorInState(state, taskName, PER_RUN_SENTINEL, engineError);\n929\t        writeWorkflowState(state, projectDir);\n930\t\n931\t        // Halt on critical errors\n932\t        if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n933\t          halted = true;\n934\t        }\n935\t      }\n936\t    } else {\n937\t      // Per-story: dispatch once per work item\n938\t      for (const item of workItems) {\n939\t        processedStories.add(item.key);\n940\t\n941\t        // Skip if already completed (crash recovery — AC #1, #2, #7)\n942\t        if (isTaskCompleted(state, taskName, item.key)) {\n943\t          warn(`workflow-engine: skipping completed task ${taskName} for ${item.key}`);\n944\t          continue;\n945\t        }\n946\t\n947\t        try {\n948\t          state = await dispatchTask(task, taskName, item.key, definition, state, config);\n949\t          tasksCompleted++;\n950\t        } catch (err: unknown) {\n951\t          const engineError = handleDispatchError(err, taskName, item.key);\n952\t          errors.push(engineError);\n953\t\n954\t          // Record error checkpoint in state (AC #13)\n955\t          state = recordErrorInState(state, taskName, item.key, engineError);\n956\t          writeWorkflowState(state, projectDir);\n957\t\n958\t          // Halt on critical errors, continue on UNKNOWN\n959\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n960\t            halted = true;\n961\t            break;\n962\t          }\n963\t          // UNKNOWN errors: record and continue to next story\n964\t          continue;\n965\t        }\n966\t      }\n967\t    }\n968\t  }\n969\t\n970\t  // 4. Set final phase if no errors and phase not already set by loop termination\n971\t  if (errors.length === 0 && state.phase !== 'max-iterations' && state.phase !== 'circuit-breaker') {\n972\t    state = { ...state, phase: 'completed' };\n973\t    writeWorkflowState(state, projectDir);\n974\t  }\n975\t\n976\t  // 5. Return result\n977\t  const loopTerminated = state.phase === 'max-iterations' || state.phase === 'circuit-breaker';\n978\t  return {\n979\t    success: errors.length === 0 && !loopTerminated,\n980\t    tasksCompleted,\n981\t    storiesProcessed: processedStories.size,\n982\t    errors,\n983\t    durationMs: Date.now() - startMs,\n984\t  };\n985\t}\n986\t\n987\t// --- Error Handling ---\n988\t\n989\t/**\n990\t * Record a dispatch error in workflow state: set phase to \"error\" and append\n991\t * a TaskCheckpoint with the error details (AC #13).\n992\t */\n993\tfunction recordErrorInState(\n994\t  state: WorkflowState,\n995\t  taskName: string,\n996\t  storyKey: string,\n997\t  error: EngineError,\n998\t): WorkflowState {\n999\t  const errorCheckpoint: TaskCheckpoint = {\n1000\t    task_name: taskName,\n1001\t    story_key: storyKey,\n1002\t    completed_at: new Date().toISOString(),\n1003\t    error: true,\n1004\t  };\n1005\t  return {\n1006\t    ...state,\n1007\t    phase: 'error',\n1008\t    tasks_completed: [...state.tasks_completed, errorCheckpoint],\n1009\t  };\n1010\t}\n1011\t\n1012\tfunction handleDispatchError(err: unknown, taskName: string, storyKey: string): EngineError {\n1013\t  if (err instanceof DispatchError) {\n1014\t    return {\n1015\t      taskName,\n1016\t      storyKey,\n1017\t      code: err.code,\n1018\t      message: err.message,\n1019\t    };\n1020\t  }\n1021\t\n1022\t  const message = err instanceof Error ? err.message : String(err);\n1023\t  return {\n1024\t    taskName,\n1025\t    storyKey,\n1026\t    code: 'UNKNOWN',\n1027\t    message,\n1028\t  };\n1029\t}\n1030\t"}]},"parent_tool_use_id":"toolu_01YBicm9mTokZCKuJz78on3G","session_id":"d2473842-56c4-49f2-ab43-68fabe9113bb","uuid":"47dc43c6-afe5-4c5f-bf37-745fa4a3dfb3","timestamp":"2026-04-03T10:50:25.195Z"}
