{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ud8Lw2MjST3s73TH3uzLfi","type":"tool_result","content":"   123→export function generateSprintStatusYaml(state: SprintState): string {\n   124→  const lines: string[] = [\n   125→    '# codeharness Sprint Status (auto-generated from sprint-state.json)',\n   126→    `# generated: ${new Date().toISOString().slice(0, 10)}`,\n   127→    '# This file is a derived view — do NOT edit manually.',\n   128→    '# Source of truth: sprint-state.json',\n   129→    '',\n   130→    'development_status:',\n   131→  ];\n   132→\n   133→  // Group stories by epic prefix (first number segment, or 'TD' for TD- stories)\n   134→  const epicGroups = new Map<string, string[]>();\n   135→  const sortedKeys = Object.keys(state.stories).sort((a, b) => {\n   136→    // Sort by epic number, then story number (TD stories sort last)\n   137→    const [aEpic, aStory] = parseStoryKey(a);\n   138→    const [bEpic, bStory] = parseStoryKey(b);\n   139→    if (aEpic !== bEpic) return aEpic - bEpic;\n   140→    return aStory - bStory;\n   141→  });\n   142→\n   143→  for (const key of sortedKeys) {\n   144→    const epicKey = getEpicGroupKey(key);\n   145→    if (!epicGroups.has(epicKey)) {\n   146→      epicGroups.set(epicKey, []);\n   147→    }\n   148→    epicGroups.get(epicKey)!.push(key);\n   149→  }\n   150→\n   151→  // Emit each epic group\n   152→  for (const [epicKey, storyKeys] of epicGroups) {\n   153→    lines.push('');\n   154→    lines.push(`  # Epic ${epicKey}`);\n   155→\n   156→    // Compute epic status from stories\n   157→    // epic-TD is always in-progress regardless of story statuses\n   158→    let epicStatus: string;\n   159→    if (epicKey === 'TD') {\n   160→      epicStatus = 'in-progress';\n   161→    } else {\n   162→      const allDone = storyKeys.every(k => state.stories[k].status === 'done');\n   163→      epicStatus = allDone ? 'done' : 'backlog';\n   164→    }\n   165→    lines.push(`  epic-${epicKey}: ${epicStatus}`);\n   166→\n   167→    for (const key of storyKeys) {\n   168→      const story = state.stories[key];\n   169→      lines.push(`  ${key}: ${yamlStatus(story.status)}`);\n   170→    }\n   171→  }\n   172→"}]},"parent_tool_use_id":"toolu_01GTepbYbnTDehnMhc3XqM2y","session_id":"2610e689-589b-4ec2-8784-d06d07275472","uuid":"82771165-5e92-4283-adcf-568e9c443bcc","timestamp":"2026-03-27T14:55:26.489Z"}
