{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0113pRMfKLeYKkqnmRgnqLzG","type":"tool_result","content":"1\timport { Command } from 'commander';\n2\timport { registerInitCommand } from './commands/init.js';\n3\timport { registerBridgeCommand } from './commands/bridge.js';\n4\timport { registerRunCommand } from './commands/run.js';\n5\timport { registerVerifyCommand } from './commands/verify.js';\n6\timport { registerStatusCommand } from './commands/status.js';\n7\timport { registerOnboardCommand } from './commands/onboard.js';\n8\timport { registerTeardownCommand } from './commands/teardown.js';\n9\timport { registerStateCommand } from './commands/state.js';\n10\timport { registerSyncCommand } from './commands/sync.js';\n11\timport { registerCoverageCommand } from './commands/coverage.js';\n12\timport { registerDocHealthCommand } from './commands/doc-health.js';\n13\timport { registerStackCommand } from './commands/stack.js';\n14\timport { registerQueryCommand } from './commands/query.js';\n15\timport { registerRetroImportCommand } from './commands/retro-import.js';\n16\timport { registerGithubImportCommand } from './commands/github-import.js';\n17\timport { registerVerifyEnvCommand } from './commands/verify-env.js';\n18\timport { registerTimeoutReportCommand } from './commands/timeout-report.js';\n19\timport { registerValidateStateCommand } from './commands/validate-state.js';\n20\timport { registerValidateCommand } from './commands/validate.js';\n21\timport { registerProgressCommand } from './commands/progress.js';\n22\timport { registerObservabilityGateCommand } from './commands/observability-gate.js';\n23\timport { registerAuditCommand } from './commands/audit.js';\n24\timport { registerStatsCommand } from './commands/stats.js';\n25\t\n26\t// Library exports — available to consumers via `import { parseStreamLine } from 'codeharness'`\n27\texport { parseStreamLine } from './lib/agents/stream-parser.js';\n28\texport type { StreamEvent, ToolStartEvent, ToolInputEvent, ToolCompleteEvent, TextEvent, RetryEvent, ResultEvent } from './lib/agents/stream-parser.js';\n29\t\n30\tdeclare const __PKG_VERSION__: string;\n31\tconst VERSION = typeof __PKG_VERSION__ !== 'undefined' ? __PKG_VERSION__ : '0.0.0-dev';\n32\t\n33\texport function createProgram(): Command {\n34\t  const program = new Command();\n35\t\n36\t  program\n37\t    .name('codeharness')\n38\t    .description('Makes autonomous coding agents produce software that actually works')\n39\t    .version(VERSION)\n40\t    .option('--json', 'Output in machine-readable JSON format');\n41\t\n42\t  registerInitCommand(program);\n43\t  registerBridgeCommand(program);\n44\t  registerRunCommand(program);\n45\t  registerVerifyCommand(program);\n46\t  registerStatusCommand(program);\n47\t  registerOnboardCommand(program);\n48\t  registerTeardownCommand(program);\n49\t  registerStateCommand(program);\n50\t  registerSyncCommand(program);\n51\t  registerCoverageCommand(program);\n52\t  registerDocHealthCommand(program);\n53\t  registerStackCommand(program);\n54\t  registerQueryCommand(program);\n55\t  registerRetroImportCommand(program);\n56\t  registerGithubImportCommand(program);\n57\t  registerVerifyEnvCommand(program);\n58\t  // registerRetryCommand removed (Story 1.2) — retry merged into workflow-state (Epic 5)\n59\t  registerTimeoutReportCommand(program);\n60\t  registerValidateStateCommand(program);\n61\t  registerValidateCommand(program);\n62\t  registerProgressCommand(program);\n63\t  registerObservabilityGateCommand(program);\n64\t  registerAuditCommand(program);\n65\t  registerStatsCommand(program);\n66\t\n67\t  return program;\n68\t}\n69\t\n70\t// Only parse when running as CLI entry point, not when imported in tests\n71\tif (!process.env['VITEST']) {\n72\t  const program = createProgram();\n73\t  program.parse(process.argv);\n74\t}\n75\t"}]},"parent_tool_use_id":"toolu_01DuVFpc4kAp6TjMAncLaYvJ","session_id":"5fca15c0-771e-463c-9e4f-c528b230e359","uuid":"