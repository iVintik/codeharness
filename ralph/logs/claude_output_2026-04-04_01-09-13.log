{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018UMJmRKB8KSgkjP95HcUpE","type":"tool_result","content":"1\t/**\n2\t * Worktree Manager.\n3\t *\n4\t * Handles git worktree lifecycle for parallel epic execution:\n5\t * create, cleanup, list, and orphan detection. Each epic gets\n6\t * its own git worktree on a dedicated branch under the\n7\t * `codeharness/` namespace.\n8\t *\n9\t * @see Story 17-1: Worktree Manager\n10\t */\n11\t\n12\timport { exec, execSync } from 'node:child_process';\n13\timport { existsSync, readFileSync, statSync } from 'node:fs';\n14\timport { join } from 'node:path';\n15\timport { promisify } from 'node:util';\n16\t\n17\tconst execAsync = promisify(exec);\n18\t\n19\t// --- Constants ---\n20\t\n21\t/** Branch prefix for all codeharness worktree branches. */\n22\texport const BRANCH_PREFIX = 'codeharness/epic-';\n23\t\n24\t/** Base path for worktree directories in /tmp. */\n25\texport const WORKTREE_BASE = '/tmp/codeharness-wt-epic-';\n26\t\n27\t// --- Interfaces ---\n28\t\n29\t/**\n30\t * Information about a codeharness worktree.\n31\t */\n32\texport interface WorktreeInfo {\n33\t  /** Epic identifier extracted from the branch name. */\n34\t  readonly epicId: string;\n35\t  /** Absolute path to the worktree directory. */\n36\t  readonly path: string;\n37\t  /** Full branch name (e.g., `codeharness/epic-17-worktree-manager`). */\n38\t  readonly branch: string;\n39\t  /** Timestamp when the worktree was created. */\n40\t  readonly createdAt: Date;\n41\t}\n42\t\n43\t// --- Error Class ---\n44\t\n45\t/**\n46\t * Error thrown by worktree operations. Includes stderr from git commands.\n47\t */\n48\texport class WorktreeError extends Error {\n49\t  /** Raw stderr output from the failed git command. */\n50\t  readonly stderr: string;\n51\t\n52\t  constructor(message: string, stderr: string) {\n53\t    super(message);\n54\t    this.name = 'WorktreeError';\n55\t    this.stderr = stderr;\n56\t  }\n57\t}\n58\t\n59\t// --- Merge Types ---\n60\t\n61\t/**\n62\t * Strategy used when merging an epic branch into main.\n63\t */\n64\texport type MergeStrategy = 'rebase' | 'merge-commit';\n65\t\n66\t/**\n67\t * Result of a merge operation.\n68\t */\n69\texport interface MergeResult {\n70\t  /** Whether the merge and post-merge validation succeeded. */\n71\t  success: boolean;\n72\t  /** Reason for failure, if any. */\n73\t  reason?: 'conflict' | 'tests-failed' | 'git-error';\n74\t  /** List of conflicting file paths, when reason is 'conflict'. */\n75\t  conflicts?: string[];\n76\t  /** Test suite results from post-merge validation. */\n77\t  testResults?: { passed: number; failed: number; coverage?: number };\n78\t  /** Total wall-clock duration of the merge operation in milliseconds. */\n79\t  durationMs: number;\n80\t}\n81\t\n82\t// --- Async Mutex ---\n83\t\n84\t/**\n85\t * Simple async mutex for serializing merge operations.\n86\t * No external dependencies — uses a promise-based wait queue.\n87\t */\n88\texport class AsyncMutex {\n89\t  private locked = false;\n90\t  private waitQueue: Array<() => void> = [];\n91\t\n92\t  async acquire(): Promise<() => void> {\n93\t    while (this.locked) {\n94\t      await new Promise<void>((resolve) => this.waitQueue.push(resolve));\n95\t    }\n96\t    this.locked = true;\n97\t    return () => {\n98\t      this.locked = false;\n99\t      const next = this.waitQueue.shift();\n100\t      if (next) next();\n101\t    };\n102\t  }\n103\t}\n104\t\n105\t/** Module-level singleton merge mutex shared across all WorktreeManager instances. */\n106\texport const mergeMutex = new AsyncMutex();\n107\t\n108\t// --- WorktreeManager Class ---\n109\t\n110\t/**\n111\t * Manages git worktrees for parallel epic execution.\n112\t *\n113\t * Creates isolated working directories (worktrees) for each epic,\n114\t * each on its own branch under the `codeharness/` namespace.\n115\t */\n116\texport class WorktreeManager {\n117\t  private readonly mainBranch: string;\n118\t  private readonly cwd: string;\n119\t\n120\t  /**\n121\t   * @param mainBranch  The main branch to base new worktree branches on (default: `'main'`).\n122\t   * @param cwd  The git repository root directory (default: `process.cwd()`).\n123\t   */\n124\t  constructor(mainBranch: string = 'main', cwd?: string) {\n125\t    this.mainBranch = mainBranch;\n126\t    this.cwd = cwd ?? process.cwd();\n127\t  }\n128\t\n129\t  /**\n130\t   * Create a worktree for a parallel epic.\n131\t   *\n132\t   * Creates a branch `codeharness/epic-{epicId}-{slug}` from the main branch HEAD,\n133\t   * then creates a git worktree at `/tmp/codeharness-wt-epic-{epicId}`.\n134\t   *\n135\t   * If a stale branch or worktree exists from a previous crashed run,\n136\t   * it is cleaned up before re-creating (idempotent recovery).\n137\t   *\n138\t   * @param epicId  The epic identifier (numeric or string).\n139\t   * @param slug  A human-readable slug for the branch name (sanitized to `[a-z0-9-]`).\n140\t   * @returns The absolute path to the created worktree directory.\n141\t   * @throws {WorktreeError} If the git command fails.\n142\t   */\n143\t  createWorktree(epicId: string, slug: string): string {\n144\t    this.validateEpicId(epicId);\n145\t    const sanitizedSlug = this.sanitizeSlug(slug);\n146\t    const branchName = `${BRANCH_PREFIX}${epicId}-${sanitizedSlug}`;\n147\t    const worktreePath = `${WORKTREE_BASE}${epicId}`;\n148\t\n149\t    // Clean up stale state from previous crashed runs (AC #9)\n150\t    this.cleanupStale(epicId, branchName, worktreePath);\n151\t\n152\t    let branchCreated = false;\n153\t    try {\n154\t      // Create branch from main branch HEAD\n155\t      this.execGit(`git branch ${branchName} ${this.mainBranch}`);\n156\t      branchCreated = true;\n157\t\n158\t      // Create worktree\n159\t      this.execGit(`git worktree add ${worktreePath} ${branchName}`);\n160\t\n161\t      return worktreePath;\n162\t    } catch (err: unknown) {\n163\t      // Clean up partial state on failure (AC #10)\n164\t      this.cleanupPartial(branchCreated, branchName, worktreePath);\n165\t\n166\t      // execGit always wraps errors as WorktreeError; re-throw directly\n167\t      if (err instanceof WorktreeError) {\n168\t        throw err;\n169\t      }\n170\t\n171\t      // Defensive: handle unexpected non-WorktreeError (should not happen)\n172\t      const message = err instanceof Error ? err.message : String(err);\n173\t      throw new WorktreeError(\n174\t        `Failed to create worktree for epic ${epicId}: ${message}`,\n175\t        '',\n176\t      );\n177\t    }\n178\t  }\n179\t\n180\t  /**\n181\t   * Remove a worktree and its branch for an epic.\n182\t   *\n183\t   * Idempotent: completes without error if the worktree or branch\n184\t   * does not exist (AC #5).\n185\t   *\n186\t   * @param epicId  The epic identifier.\n187\t   */\n188\t  cleanupWorktree(epicId: string): void {\n189\t    this.validateEpicId(epicId);\n190\t    const worktreePath = `${WORKTREE_BASE}${epicId}`;\n191\t\n192\t    // Remove worktree (ignore errors if it doesn't exist)\n193\t    try {\n194\t      this.execGit(`git worktree remove ${worktreePath} --force`);\n195\t    } catch { // IGNORE: idempotent cleanup — worktree may not exist per AC #5\n196\t    }\n197\t\n198\t    // Find and delete the branch matching this epicId\n199\t    const branch = this.findBranchForEpic(epicId);\n200\t    if (branch) {\n201\t      try {\n202\t        this.execGit(`git branch -D ${branch}`);\n203\t      } catch { // IGNORE: idempotent cleanup — branch may not exist per AC #5\n204\t      }\n205\t    }\n206\t  }\n207\t\n208\t  /**\n209\t   * List all codeharness worktrees.\n210\t   *\n211\t   * @returns An array of `WorktreeInfo` objects sorted by epicId.\n212\t   *          Returns an empty array when no codeharness worktrees exist.\n213\t   */\n214\t  listWorktrees(): WorktreeInfo[] {\n215\t    let output: string;\n216\t    try {\n217\t      output = this.execGit('git worktree list --porcelain');\n218\t    } catch { // IGNORE: non-git-repo or corrupt state returns empty list safely\n219\t      return [];\n220\t    }\n221\t\n222\t    const entries = this.parsePorcelainOutput(output);\n223\t    return entries\n224\t      .filter((e) => e.branch.startsWith(`refs/heads/${BRANCH_PREFIX}`))\n225\t      .map((e) => {\n226\t        const branchName = e.branch.replace('refs/heads/', '');\n227\t        const epicId = this.extractEpicId(branchName);\n228\t        return {\n229\t          epicId,\n230\t          path: e.path,\n231\t          branch: branchName,\n232\t          createdAt: this.getWorktreeCreatedAt(e.path),\n233\t        };\n234\t      })\n235\t      .sort((a, b) => a.epicId.localeCompare(b.epicId, undefined, { numeric: true }));\n236\t  }\n237\t\n238\t  /**\n239\t   * Detect orphaned worktrees from previous crashed runs.\n240\t   *\n241\t   * A worktree is considered orphaned if its directory exists on disk\n242\t   * but has no `.codeharness/lane-state.json` file or the file has\n243\t   * no active PID.\n244\t   *\n245\t   * @returns An array of orphaned `WorktreeInfo` entries.\n246\t   */\n247\t  detectOrphans(): WorktreeInfo[] {\n248\t    const worktrees = this.listWorktrees();\n249\t    return worktrees.filter((wt) => this.isOrphaned(wt));\n250\t  }\n251\t\n252\t  /**\n253\t   * Merge an epic branch into the main branch with serialized access.\n254\t   *\n255\t   * Acquires a module-level mutex so only one merge runs at a time.\n256\t   * After a clean merge, runs the test suite. If tests fail, the merge\n257\t   * is reverted. On conflict or git error, the main branch is restored.\n258\t   *\n259\t   * @param epicId  The epic identifier whose branch should be merged.\n260\t   * @param strategy  Merge strategy: `'merge-commit'` (default) or `'rebase'`.\n261\t   * @param testCommand  Command to run for post-merge validation (default: `'npm test'`).\n262\t   * @returns A `MergeResult` describing the outcome.\n263\t   */\n264\t  async mergeWorktree(\n265\t    epicId: string,\n266\t    strategy: MergeStrategy = 'merge-commit',\n267\t    testCommand: string = 'npm test',\n268\t  ): Promise<MergeResult> {\n269\t    const start = Date.now();\n270\t\n271\t    // Validate testCommand to prevent shell injection — only allow safe characters\n272\t    if (!/^[a-zA-Z0-9_./ -]+$/.test(testCommand)) {\n273\t      return {\n274\t        success: false,\n275\t        reason: 'git-error',\n276\t        durationMs: Date.now() - start,\n277\t      };\n278\t    }\n279\t\n280\t    // Find branch for this epicId\n281\t    const branch = this.findBranchForEpic(epicId);\n282\t    if (!branch) {\n283\t      return {\n284\t        success: false,\n285\t        reason: 'git-error',\n286\t        durationMs: Date.now() - start,\n287\t      };\n288\t    }\n289\t\n290\t    // Validate branch name to prevent command injection via malicious branch names\n291\t    if (!/^[a-zA-Z0-9_./-]+$/.test(branch)) {\n292\t      return {\n293\t        success: false,\n294\t        reason: 'git-error',\n295\t        durationMs: Date.now() - start,\n296\t      };\n297\t    }\n298\t\n299\t    const release = await mergeMutex.acquire();\n300\t    try {\n301\t      // Re-verify branch still exists after acquiring mutex (could be deleted while waiting)\n302\t      const branchCheck = this.findBranchForEpic(epicId);\n303\t      if (!branchCheck || branchCheck !== branch) {\n304\t        return {\n305\t          success: false,\n306\t          reason: 'git-error',\n307\t          durationMs: Date.now() - start,\n308\t        };\n309\t      }\n310\t\n311\t      // Verify main branch is clean before merge\n312\t      const status = this.execGit('git status --porcelain');\n313\t      if (status.length > 0) {\n314\t        return {\n315\t          success: false,\n316\t          reason: 'git-error',\n317\t          durationMs: Date.now() - start,\n318\t        };\n319\t      }\n320\t\n321\t      // Attempt merge or rebase\n322\t      try {\n323\t        if (strategy === 'rebase') {\n324\t          this.execGit(`git rebase ${branch}`);\n325\t        } else {\n326\t          this.execGit(`git merge --no-ff ${branch}`);\n327\t        }\n328\t      } catch { // IGNORE: merge/rebase failure is expected — detect conflict vs git-error below\n329\t        const conflicts = this.detectConflicts();\n330\t        if (conflicts.length > 0) {\n331\t          this.abortMerge(strategy);\n332\t          return {\n333\t            success: false,\n334\t            reason: 'conflict',\n335\t            conflicts,\n336\t            durationMs: Date.now() - start,\n337\t          };\n338\t        }\n339\t        // Not a conflict — unexpected git error\n340\t        this.abortMerge(strategy);\n341\t        return {\n342\t          success: false,\n343\t          reason: 'git-error',\n344\t          durationMs: Date.now() - start,\n345\t        };\n346\t      }\n347\t\n348\t      // Run test suite after successful merge\n349\t      const testResults = await this.runTestSuite(testCommand);\n350\t      if (testResults.failed > 0) {\n351\t        // Revert merge on test failure\n352\t        try {\n353\t          this.execGit('git reset --hard HEAD~1');\n354\t        } catch { // IGNORE: reset failure indicates corrupted git state; still return tests-failed\n355\t        }\n356\t        return {\n357\t          success: false,\n358\t          reason: 'tests-failed',\n359\t          testResults,\n360\t          durationMs: Date.now() - start,\n361\t        };\n362\t      }\n363\t\n364\t      // Success — cleanup worktree\n365\t      this.cleanupWorktree(epicId);\n366\t      return {\n367\t        success: true,\n368\t        testResults,\n369\t        durationMs: Date.now() - start,\n370\t      };\n371\t    } finally {\n372\t      release();\n373\t    }\n374\t  }\n375\t\n376\t  // --- Private Helpers ---\n377\t\n378\t  /**\n379\t   * Get the creation time of a worktree directory.\n380\t   * Falls back to current time if the directory doesn't exist or stat fails.\n381\t   */\n382\t  private getWorktreeCreatedAt(worktreePath: string): Date {\n383\t    try {\n384\t      const stats = statSync(worktreePath);\n385\t      return stats.birthtime;\n386\t    } catch { // IGNORE: stat failure — worktree dir may not be accessible; fall back to now\n387\t      return new Date();\n388\t    }\n389\t  }\n390\t\n391\t  /**\n392\t   * Validate epicId contains only safe characters `[a-zA-Z0-9-]`.\n393\t   * Prevents command injection via crafted epicId values.\n394\t   */\n395\t  private validateEpicId(epicId: string): void {\n396\t    if (!epicId || !/^[a-zA-Z0-9-]+$/.test(epicId)) {\n397\t      throw new WorktreeError(\n398\t        `Invalid epicId: \"${epicId}\" — must be non-empty and contain only [a-zA-Z0-9-]`,\n399\t        '',\n400\t      );\n401\t    }\n402\t  }\n403\t\n404\t  /**\n405\t   * Sanitize a slug to contain only `[a-z0-9-]`.\n406\t   */\n407\t  private sanitizeSlug(slug: string): string {\n408\t    return slug\n409\t      .toLowerCase()\n410\t      .replace(/[^a-z0-9-]/g, '-')\n411\t      .replace(/-+/g, '-')\n412\t      .replace(/^-|-$/g, '');\n413\t  }\n414\t\n415\t  /**\n416\t   * Execute a git command and return its stdout.\n417\t   * Wraps errors in WorktreeError with captured stderr.\n418\t   */\n419\t  private execGit(cmd: string): string {\n420\t    try {\n421\t      const result = execSync(cmd, {\n422\t        cwd: this.cwd,\n423\t        stdio: ['pipe', 'pipe', 'pipe'],\n424\t        timeout: 30_000,\n425\t      });\n426\t      return result.toString().trim();\n427\t    } catch (err: unknown) {\n428\t      const stderr = (err as { stderr?: Buffer })?.stderr?.toString() ?? '';\n429\t      throw new WorktreeError(`Git command failed: ${cmd} — ${stderr}`, stderr);\n430\t    }\n431\t  }\n432\t\n433\t  /**\n434\t   * Clean up stale branch and worktree from a previous crash (AC #9).\n435\t   */\n436\t  private cleanupStale(epicId: string, branchName: string, worktreePath: string): void {\n437\t    // Check if worktree path exists on disk\n438\t    if (existsSync(worktreePath)) {\n439\t      try {\n440\t        this.execGit(`git worktree remove ${worktreePath} --force`);\n441\t      } catch { // IGNORE: stale worktree removal is best-effort before re-create per AC #9\n442\t        try {\n443\t          this.execGit('git worktree prune');\n444\t        } catch { // IGNORE: prune is best-effort fallback for stale worktree cleanup\n445\t        }\n446\t      }\n447\t    }\n448\t\n449\t    // Check if branch already exists\n450\t    const existingBranch = this.findBranchForEpic(epicId);\n451\t    if (existingBranch) {\n452\t      try {\n453\t        this.execGit(`git branch -D ${existingBranch}`);\n454\t      } catch { // IGNORE: stale branch deletion is best-effort before re-create per AC #9\n455\t      }\n456\t    }\n457\t  }\n458\t\n459\t  /**\n460\t   * Clean up partial state after a failed createWorktree (AC #10).\n461\t   */\n462\t  private cleanupPartial(branchCreated: boolean, branchName: string, worktreePath: string): void {\n463\t    // Try to remove worktree if it was partially created\n464\t    try {\n465\t      this.execGit(`git worktree remove ${worktreePath} --force`);\n466\t    } catch { // IGNORE: partial worktree may not exist during failure cleanup per AC #10\n467\t    }\n468\t\n469\t    // Delete branch if it was created\n470\t    if (branchCreated) {\n471\t      try {\n472\t        this.execGit(`git branch -D ${branchName}`);\n473\t      } catch { // IGNORE: partial branch may not exist during failure cleanup per AC #10\n474\t      }\n475\t    }\n476\t  }\n477\t\n478\t  /**\n479\t   * Find a branch matching `codeharness/epic-{epicId}-*`.\n480\t   */\n481\t  private findBranchForEpic(epicId: string): string | undefined {\n482\t    try {\n483\t      const output = this.execGit(`git branch --list ${BRANCH_PREFIX}${epicId}-*`);\n484\t      const branches = output\n485\t        .split('\\n')\n486\t        .map((b) => b.trim().replace(/^\\*\\s*/, ''))\n487\t        .filter((b) => b.length > 0);\n488\t      return branches[0];\n489\t    } catch { // IGNORE: branch listing failure means no branch exists — safe to return undefined\n490\t      return undefined;\n491\t    }\n492\t  }\n493\t\n494\t  /**\n495\t   * Parse `git worktree list --porcelain` output into structured entries.\n496\t   */\n497\t  private parsePorcelainOutput(output: string): Array<{ path: string; branch: string }> {\n498\t    if (!output.trim()) return [];\n499\t\n500\t    const blocks = output.split('\\n\\n').filter((b) => b.trim());\n501\t    const entries: Array<{ path: string; branch: string }> = [];\n502\t\n503\t    for (const block of blocks) {\n504\t      const lines = block.split('\\n');\n505\t      let path = '';\n506\t      let branch = '';\n507\t\n508\t      for (const line of lines) {\n509\t        if (line.startsWith('worktree ')) {\n510\t          path = line.slice('worktree '.length);\n511\t        } else if (line.startsWith('branch ')) {\n512\t          branch = line.slice('branch '.length);\n513\t        }\n514\t      }\n515\t\n516\t      if (path && branch) {\n517\t        entries.push({ path, branch });\n518\t      }\n519\t    }\n520\t\n521\t    return entries;\n522\t  }\n523\t\n524\t  /**\n525\t   * Extract epicId from a branch name like `codeharness/epic-17-slug`.\n526\t   */\n527\t  private extractEpicId(branchName: string): string {\n528\t    const withoutPrefix = branchName.slice(BRANCH_PREFIX.length);\n529\t    const dashIndex = withoutPrefix.indexOf('-');\n530\t    if (dashIndex === -1) return withoutPrefix;\n531\t    return withoutPrefix.slice(0, dashIndex);\n532\t  }\n533\t\n534\t  /**\n535\t   * Detect conflicting files after a failed merge/rebase.\n536\t   * Uses `git diff --name-only --diff-filter=U` to find unmerged paths.\n537\t   */\n538\t  private detectConflicts(): string[] {\n539\t    try {\n540\t      const output = this.execGit('git diff --name-only --diff-filter=U');\n541\t      return output\n542\t        .split('\\n')\n543\t        .map((f) => f.trim())\n544\t        .filter((f) => f.length > 0);\n545\t    } catch { // IGNORE: diff failure means no conflict info available\n546\t      return [];\n547\t    }\n548\t  }\n549\t\n550\t  /**\n551\t   * Abort an in-progress merge or rebase to restore main branch state.\n552\t   */\n553\t  private abortMerge(strategy: MergeStrategy): void {\n554\t    try {\n555\t      if (strategy === 'rebase') {\n556\t        this.execGit('git rebase --abort');\n557\t      } else {\n558\t        this.execGit('git merge --abort');\n559\t      }\n560\t    } catch { // IGNORE: abort may fail if merge already resolved; main state is preserved\n561\t    }\n562\t  }\n563\t\n564\t  /**\n565\t   * Run the test suite and parse results from stdout.\n566\t   * Uses async exec with a 5-minute timeout.\n567\t   */\n568\t  private async runTestSuite(\n569\t    testCommand: string = 'npm test',\n570\t  ): Promise<{ passed: number; failed: number; coverage?: number }> {\n571\t    try {\n572\t      const { stdout } = await execAsync(testCommand, {\n573\t        cwd: this.cwd,\n574\t        timeout: 300_000, // 5 minutes\n575\t      });\n576\t\n577\t      return this.parseTestOutput(stdout);\n578\t    } catch (err: unknown) {\n579\t      // Test command failed (non-zero exit) — parse whatever output we got\n580\t      const stdout = (err as { stdout?: string })?.stdout ?? '';\n581\t      const result = this.parseTestOutput(stdout);\n582\t      // If we couldn't parse anything, report 1 failure\n583\t      if (result.passed === 0 && result.failed === 0) {\n584\t        return { passed: 0, failed: 1 };\n585\t      }\n586\t      return result;\n587\t    }\n588\t  }\n589\t\n590\t  /**\n591\t   * Parse test output to extract pass/fail counts and optional coverage.\n592\t   * Supports common vitest/jest output patterns.\n593\t   */\n594\t  private parseTestOutput(stdout: string): { passed: number; failed: number; coverage?: number } {\n595\t    let passed = 0;\n596\t    let failed = 0;\n597\t    let coverage: number | undefined;\n598\t\n599\t    // Match vitest/jest \"Tests: X passed, Y failed\" or \"X passed\" patterns\n600\t    const passMatch = stdout.match(/(\\d+)\\s+passed/);\n601\t    const failMatch = stdout.match(/(\\d+)\\s+failed/);\n602\t    if (passMatch) passed = parseInt(passMatch[1], 10);\n603\t    if (failMatch) failed = parseInt(failMatch[1], 10);\n604\t\n605\t    // Match coverage percentage patterns like \"All files | 85.5\"\n606\t    const covMatch = stdout.match(/All files[^|]*\\|\\s*([\\d.]+)/);\n607\t    if (covMatch) coverage = parseFloat(covMatch[1]);\n608\t\n609\t    return { passed, failed, ...(coverage !== undefined && { coverage }) };\n610\t  }\n611\t\n612\t  /**\n613\t   * Check if a worktree is orphaned (no active codeharness process).\n614\t   */\n615\t  private isOrphaned(wt: WorktreeInfo): boolean {\n616\t    const laneStatePath = join(wt.path, '.codeharness', 'lane-state.json');\n617\t\n618\t    if (!existsSync(laneStatePath)) {\n619\t      return true;\n620\t    }\n621\t\n622\t    try {\n623\t      const content = readFileSync(laneStatePath, 'utf-8');\n624\t      const state = JSON.parse(content) as { pid?: number };\n625\t\n626\t      if (!state.pid) {\n627\t        return true;\n628\t      }\n629\t\n630\t      // Check if the PID is still running\n631\t      try {\n632\t        process.kill(state.pid, 0);\n633\t        return false; // Process is alive — not orphaned\n634\t      } catch { // IGNORE: ESRCH means process is dead — worktree is orphaned per AC #8\n635\t        return true;\n636\t      }\n637\t    } catch { // IGNORE: unreadable/corrupt lane-state.json means orphaned per AC #8\n638\t      return true;\n639\t    }\n640\t  }\n641\t}\n642\t"}]},"parent_tool_use_id":"toolu_01TY52iqp6ju3tRJQNo8fNat","session_id":"80ecde4e-3ccc-44de-925d-a2036bf845d1","uuid":"dc764410-ca58-4901-bb0e-d8ab7548c95a","timestamp":"2026-04-03T21:29:37.254Z"}
