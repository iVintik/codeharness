{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VjFbwLEV6Z7eMfSeo3tHvJ","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';\n     2→import { unlinkSync, existsSync } from 'node:fs';\n     3→import { join } from 'node:path';\n     4→\n     5→// Mock migration so index tests are isolated from real project files\n     6→vi.mock('../migration.js', () => ({\n     7→  migrateFromOldFormat: vi.fn(() => ({\n     8→    success: false,\n     9→    error: 'No old format files found for migration',\n    10→  })),\n    11→  migrateV1ToV2: vi.fn((v1: Record<string, unknown>) => ({\n    12→    ...v1,\n    13→    version: 2,\n    14→    retries: {},\n    15→    flagged: [],\n    16→    epics: {},\n    17→    session: { active: false, startedAt: null, iteration: 0, elapsedSeconds: 0 },\n    18→    observability: { statementCoverage: null, branchCoverage: null, functionCoverage: null, lineCoverage: null },\n    19→  })),\n    20→}));\n    21→\n    22→const {\n    23→  getNextStory,\n    24→  updateStoryStatus,\n    25→  getSprintState,\n    26→  generateReport,\n    27→  getStoryDrillDown,\n    28→} = await import('../index.js');\n    29→\n    30→const { writeFileSync } = await import('node:fs');\n    31→\n    32→const STATE_FILE = join(process.cwd(), 'sprint-state.json');\n    33→const TMP_FILE = join(process.cwd(), '.sprint-state.json.tmp');\n    34→\n    35→function cleanup(): void {\n    36→  for (const f of [STATE_FILE, TMP_FILE]) {\n    37→    if (existsSync(f)) unlinkSync(f);\n    38→  }\n    39→}\n    40→\n    41→describe('sprint module', () => {\n    42→  beforeEach(cleanup);\n    43→  afterEach(cleanup);\n    44→\n    45→  it('getNextStory returns ok with null selected when no stories exist', () => {\n    46→    const result = getNextStory();\n    47→    expect(result.success).toBe(true);\n    48→    if (result.success) {\n    49→      expect(result.data.selected).toBeNull();\n    50→      expect(result.data.retryExhausted).toEqual([]);\n    51→    }\n    52→  });\n    53→\n    54→  it('getNextStory delegates to selector and returns selected story', () => {\n    55→    // Write a state file with a backlog story\n    56→    const state = {\n    57→      version: 1,\n    58→      sprint: { total: 1, done: 0, failed: 0, blocked: 0, inProgress: null },\n    59→      stories: {\n    60→        'test-story': {\n    61→          status: 'backlog',\n    62→          attempts: 0,\n    63→          lastAttempt: null,\n    64→          lastError: null,\n    65→          proofPath: null,\n    66→          acResults: null,\n    67→        },\n    68→      },\n    69→      run: {\n    70→        active: false,\n    71→        startedAt: null,\n    72→        iteration: 0,\n    73→        cost: 0,\n    74→        completed: [],\n    75→        failed: [],\n    76→      },\n    77→      actionItems: [],\n    78→    };\n    79→    writeFileSync(STATE_FILE, JSON.stringify(state, null, 2), 'utf-8');\n    80→\n    81→    const result = getNextStory();\n    82→    expect(result.success).toBe(true);\n    83→    if (result.success) {\n    84→      expect(result.data.selected).not.toBeNull();\n    85→      expect(result.data.selected!.key).toBe('test-story');\n    86→    }\n    87→  });\n    88→\n    89→  it('getNextStory marks retry-exhausted stories as blocked', () => {\n    90→    const state = {\n    91→      version: 1,\n    92→      sprint: { total: 2, done: 0, failed: 0, blocked: 0, inProgress: null },\n    93→      stories: {\n    94→        'exhausted-story': {\n    95→          status: 'backlog',\n    96→          attempts: 10,\n    97→          lastAttempt: null,\n    98→          lastError: null,\n    99→          proofPath: null,\n   100→          acResults: null,\n   101→        },\n   102→        'good-story': {\n   103→          status: 'backlog',\n   104→          attempts: 1,\n   105→          lastAttempt: null,\n   106→          lastError: null,\n   107→          proofPath: null,\n   108→          acResults: null,\n   109→        },\n   110→      },\n   111→      run: {\n   112→        active: false,\n   113→        startedAt: null,\n   114→        iteration: 0,\n   115→        cost: 0,\n   116→        completed: [],\n   117→        failed: [],\n   118→      },\n   119→      actionItems: [],\n   120→    };\n   121→    writeFileSync(STATE_FILE, JSON.stringify(state, null, 2), 'utf-8');\n   122→\n   123→    const result = getNextStory();\n   124→    expect(result.success).toBe(true);\n   125→    if (result.success) {\n   126→      expect(result.data.selected!.key).toBe('good-story');\n   127→      expect(result.data.retryExhausted).toHaveLength(1);\n   128→      expect(result.data.retryExhausted[0].key).toBe('exhausted-story');\n   129→    }\n   130→\n   131→    // Verify the exhausted story was actually marked as blocked in state\n   132→    const stateResult = getSprintState();\n   133→    expect(stateResult.success).toBe(true);\n   134→    if (stateResult.success) {\n   135→      expect(stateResult.data.stories['exhausted-story'].status).toBe(\n   136→        'blocked',\n   137→      );\n   138→      expect(stateResult.data.stories['exhausted-story'].lastError).toBe(\n   139→        'retry-exhausted',\n   140→      );\n   141→    }\n   142→  });\n   143→\n   144→  it('getNextStory returns fail on state read error', () => {\n   145→    writeFileSync(STATE_FILE, '{invalid json!!!', 'utf-8');\n   146→    const result = getNextStory();\n   147→    expect(result.success).toBe(false);\n   148→    if (!result.success) {\n   149→      expect(result.error).toContain('Failed to read sprint state');\n   150→    }\n   151→  });\n   152→\n   153→  it('getSprintState returns ok with default state when no file exists', () => {\n   154→    const result = getSprintState();\n   155→    expect(result.success).toBe(true);\n   156→    if (result.success) {\n   157→      expect(result.data.version).toBe(2);\n   158→      expect(result.data.stories).toEqual({});\n   159→    }\n   160→  });\n   161→\n   162→  it('updateStoryStatus writes state successfully', () => {\n   163→    const result = updateStoryStatus('1.1', 'in-progress');\n   164→    expect(result.success).toBe(true);\n   165→  });\n   166→\n   167→  it('updateStoryStatus with detail writes state successfully', () => {\n   168→    const result = updateStoryStatus('1.1', 'failed', { error: 'boom' });\n   169→    expect(result.success).toBe(true);\n   170→  });\n   171→\n   172→  it('generateReport returns a valid StatusReport from state', () => {\n   173→    // Write a state file with some stories\n   174→    const state = {\n   175→      version: 1,\n   176→      sprint: { total: 2, done: 1, failed: 0, blocked: 0, inProgress: null },\n   177→      stories: {\n   178→        '1-1-a': {\n   179→          status: 'done',\n   180→          attempts: 1,\n   181→          lastAttempt: null,\n   182→          lastError: null,\n   183→          proofPath: null,\n   184→          acResults: null,\n   185→        },\n   186→        '2-1-b': {\n   187→          status: 'backlog',\n   188→          attempts: 0,\n   189→          lastAttempt: null,\n   190→          lastError: null,\n   191→          proofPath: null,\n   192→          acResults: null,\n   193→        },\n   194→      },\n   195→      run: {\n   196→        active: false,\n   197→        startedAt: null,\n   198→        iteration: 0,\n   199→        cost: 0,\n   200→        completed: [],\n   201→        failed: [],\n   202→      },\n   203→      actionItems: [],\n   204→    };\n   205→    writeFileSync(STATE_FILE, JSON.stringify(state, null, 2), 'utf-8');\n   206→\n   207→    const result = generateReport();\n   208→    expect(result.success).toBe(true);\n   209→    if (result.success) {\n   210→      expect(result.data.total).toBe(2);\n   211→      expect(result.data.done).toBe(1);\n   212→      expect(result.data.epicsTotal).toBe(2);\n   213→      expect(result.data.sprintPercent).toBe(50);\n   214→      expect(result.data.storyStatuses).toHaveLength(2);\n   215→    }\n   216→  });\n   217→\n   218→  it('generateReport returns ok with empty report when no state file', () => {\n   219→    const result = generateReport();\n   220→    expect(result.success).toBe(true);\n   221→    if (result.success) {\n   222→      expect(result.data.total).toBe(0);\n   223→      expect(result.data.done).toBe(0);\n   224→    }\n   225→  });\n   226→\n   227→  it('generateReport returns fail on corrupted state file', () => {\n   228→    writeFileSync(STATE_FILE, '{bad json!!!', 'utf-8');\n   229→    const result = generateReport();\n   230→    expect(result.success).toBe(false);\n   231→  });\n   232→\n   233→  it('getStoryDrillDown delegates to reporter and returns drill-down data', () => {\n   234→    const state = {\n   235→      version: 1,\n   236→      sprint: { total: 1, done: 0, failed: 1, blocked: 0, inProgress: null },\n   237→      stories: {\n   238→        '2-3-status': {\n   239→          status: 'failed',\n   240→          attempts: 3,\n   241→          lastAttempt: '2026-03-18T03:42:15Z',\n   242→          lastError: 'exit 1',\n   243→          proofPath: null,\n   244→          acResults: [{ id: 'AC1', verdict: 'pass' }, { id: 'AC4', verdict: 'fail' }],\n   245→        },\n   246→      },\n   247→      run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [] },\n   248→      actionItems: [],\n   249→    };\n   250→    writeFileSync(STATE_FILE, JSON.stringify(state, null, 2), 'utf-8');\n   251→\n   252→    const result = getStoryDrillDown('2-3-status');\n   253→    expect(result.success).toBe(true);\n   254→    if (result.success) {\n   255→      expect(result.data.key).toBe('2-3-status');\n   256→      expect(result.data.status).toBe('failed');\n   257→      expect(result.data.epic).toBe('2');\n   258→      expect(result.data.attempts).toBe(3);\n   259→      expect(result.data.acDetails).toHaveLength(2);\n   260→    }\n   261→  });\n   262→\n   263→  it('getStoryDrillDown returns fail on state read error', () => {\n   264→    writeFileSync(STATE_FILE, '{invalid json!!!', 'utf-8');\n   265→    const result = getStoryDrillDown('anything');\n   266→    expect(result.success).toBe(false);\n   267→    if (!result.success) {\n   268→      expect(result.error).toContain('Failed to read sprint state');\n   269→    }\n   270→  });\n   271→\n   272→  it('getStoryDrillDown returns fail for nonexistent story', () => {\n   273→    const result = getStoryDrillDown('nonexistent');\n   274→    expect(result.success).toBe(false);\n   275→    if (!result.success) {\n   276→      expect(result.error).toContain(\"Story 'nonexistent' not found\");\n   277→    }\n   278→  });\n   279→});\n   280→"}]},"parent_tool_use_id":"toolu_01S1Fmwybv95nEtmZySwttre","session_id":"bd5543f6-f408-4218-88bd-6e3bcdc37563","uuid":"fdb0b97c-5651-4532-a67c-dfbc38e1843d","timestamp":"2026-03-24T11:12:52.088Z"}
