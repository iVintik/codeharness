{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MnyhH99ct8RrD8dV66moDN","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach } from 'vitest';\n2\timport { readFileSync } from 'node:fs';\n3\timport { resolve } from 'node:path';\n4\timport type { AgentDriver, DispatchOpts, DriverHealth } from '../types.js';\n5\timport type { StreamEvent } from '../stream-parser.js';\n6\timport {\n7\t  registerDriver,\n8\t  getDriver,\n9\t  listDrivers,\n10\t  resetDrivers,\n11\t  suggestCheaperDriver,\n12\t} from '../drivers/factory.js';\n13\t\n14\t// --- Helpers ---\n15\t\n16\t/** Creates a minimal mock AgentDriver for testing. */\n17\tfunction createMockDriver(\n18\t  name: string,\n19\t  opts: { supportsPlugins?: boolean; costTier?: number } = {},\n20\t): AgentDriver {\n21\t  return {\n22\t    name,\n23\t    defaultModel: 'mock-model',\n24\t    capabilities: {\n25\t      supportsPlugins: opts.supportsPlugins ?? false,\n26\t      supportsStreaming: true,\n27\t      costReporting: false,\n28\t      costTier: opts.costTier ?? 1,\n29\t    },\n30\t    async healthCheck(): Promise<DriverHealth> {\n31\t      return { available: true, authenticated: true, version: '1.0.0' };\n32\t    },\n33\t    async *dispatch(_opts: DispatchOpts): AsyncIterable<StreamEvent> {\n34\t      yield { type: 'text', text: 'mock' };\n35\t    },\n36\t    getLastCost(): number | null {\n37\t      return null;\n38\t    },\n39\t  };\n40\t}\n41\t\n42\t// --- Tests ---\n43\t\n44\tdescribe('agents/drivers/factory — Driver Factory & Registry', () => {\n45\t  beforeEach(() => {\n46\t    resetDrivers();\n47\t  });\n48\t\n49\t  describe('registerDriver + getDriver', () => {\n50\t    it('registers a driver and retrieves it by name (same reference)', () => {\n51\t      const driver = createMockDriver('claude-code');\n52\t      registerDriver(driver);\n53\t      const retrieved = getDriver('claude-code');\n54\t      expect(retrieved).toBe(driver); // same reference\n55\t    });\n56\t\n57\t    it('registers multiple drivers and retrieves each by name', () => {\n58\t      const d1 = createMockDriver('claude-code');\n59\t      const d2 = createMockDriver('codex');\n60\t      registerDriver(d1);\n61\t      registerDriver(d2);\n62\t      expect(getDriver('claude-code')).toBe(d1);\n63\t      expect(getDriver('codex')).toBe(d2);\n64\t    });\n65\t  });\n66\t\n67\t  describe('getDriver — unknown name', () => {\n68\t    it('throws when no drivers are registered', () => {\n69\t      expect(() => getDriver('unknown')).toThrow(\"Driver 'unknown' not found\");\n70\t    });\n71\t\n72\t    it('includes the unknown name in the error message', () => {\n73\t      expect(() => getDriver('nonexistent')).toThrow('nonexistent');\n74\t    });\n75\t\n76\t    it('lists registered driver names in the error message', () => {\n77\t      registerDriver(createMockDriver('claude-code'));\n78\t      registerDriver(createMockDriver('opencode'));\n79\t      expect(() => getDriver('codex')).toThrow('claude-code');\n80\t      expect(() => getDriver('codex')).toThrow('opencode');\n81\t    });\n82\t\n83\t    it('shows \"(none)\" when no drivers are registered', () => {\n84\t      expect(() => getDriver('x')).toThrow('(none)');\n85\t    });\n86\t  });\n87\t\n88\t  describe('registerDriver — input validation', () => {\n89\t    it('throws when called with null', () => {\n90\t      expect(() => registerDriver(null as unknown as AgentDriver)).toThrow(\n91\t        'registerDriver requires a valid AgentDriver',\n92\t      );\n93\t    });\n94\t\n95\t    it('throws when called with undefined', () => {\n96\t      expect(() => registerDriver(undefined as unknown as AgentDriver)).toThrow(\n97\t        'registerDriver requires a valid AgentDriver',\n98\t      );\n99\t    });\n100\t\n101\t    it('throws when driver has no name property', () => {\n102\t      expect(() => registerDriver({} as unknown as AgentDriver)).toThrow(\n103\t        'registerDriver requires a valid AgentDriver',\n104\t      );\n105\t    });\n106\t\n107\t    it('throws when driver name is empty string', () => {\n108\t      expect(() => registerDriver(createMockDriver(''))).toThrow(\n109\t        'Driver name must be a non-empty string',\n110\t      );\n111\t    });\n112\t  });\n113\t\n114\t  describe('getDriver — input validation', () => {\n115\t    it('throws when called with empty string', () => {\n116\t      expect(() => getDriver('')).toThrow('getDriver requires a non-empty string name');\n117\t    });\n118\t\n119\t    it('throws when called with null', () => {\n120\t      expect(() => getDriver(null as unknown as string)).toThrow(\n121\t        'getDriver requires a non-empty string name',\n122\t      );\n123\t    });\n124\t\n125\t    it('throws when called with undefined', () => {\n126\t      expect(() => getDriver(undefined as unknown as string)).toThrow(\n127\t        'getDriver requires a non-empty string name',\n128\t      );\n129\t    });\n130\t  });\n131\t\n132\t  describe('registerDriver — duplicate', () => {\n133\t    it('throws when registering a driver with an already-registered name', () => {\n134\t      registerDriver(createMockDriver('claude-code'));\n135\t      expect(() => registerDriver(createMockDriver('claude-code'))).toThrow(\n136\t        \"Driver 'claude-code' is already registered\",\n137\t      );\n138\t    });\n139\t\n140\t    it('includes the duplicate name in the error message', () => {\n141\t      registerDriver(createMockDriver('opencode'));\n142\t      expect(() => registerDriver(createMockDriver('opencode'))).toThrow(\n143\t        'opencode',\n144\t      );\n145\t    });\n146\t  });\n147\t\n148\t  describe('listDrivers', () => {\n149\t    it('returns empty array when no drivers are registered', () => {\n150\t      expect(listDrivers()).toEqual([]);\n151\t    });\n152\t\n153\t    it('returns all registered driver names', () => {\n154\t      registerDriver(createMockDriver('claude-code'));\n155\t      registerDriver(createMockDriver('codex'));\n156\t      registerDriver(createMockDriver('opencode'));\n157\t      expect(listDrivers()).toEqual(['claude-code', 'codex', 'opencode']);\n158\t    });\n159\t\n160\t    it('returns a copy — mutating the result does not affect registry', () => {\n161\t      registerDriver(createMockDriver('claude-code'));\n162\t      const list = listDrivers();\n163\t      list.push('injected');\n164\t      expect(listDrivers()).toEqual(['claude-code']);\n165\t      expect(listDrivers()).not.toContain('injected');\n166\t    });\n167\t  });\n168\t\n169\t  describe('resetDrivers', () => {\n170\t    it('clears all registered drivers', () => {\n171\t      registerDriver(createMockDriver('claude-code'));\n172\t      registerDriver(createMockDriver('codex'));\n173\t      expect(listDrivers()).toHaveLength(2);\n174\t\n175\t      resetDrivers();\n176\t\n177\t      expect(listDrivers()).toEqual([]);\n178\t      expect(() => getDriver('claude-code')).toThrow();\n179\t      expect(() => getDriver('codex')).toThrow();\n180\t    });\n181\t  });\n182\t\n183\t  describe('no auto-discovery', () => {\n184\t    it('factory.ts source has no dynamic import(), readdir, glob, or require() calls', () => {\n185\t      const factoryPath = resolve(\n186\t        import.meta.dirname ?? __dirname,\n187\t        '..',\n188\t        'drivers',\n189\t        'factory.ts',\n190\t      );\n191\t      const source = readFileSync(factoryPath, 'utf-8');\n192\t\n193\t      // Forbidden patterns that would indicate auto-discovery\n194\t      expect(source).not.toMatch(/\\bimport\\s*\\(/);\n195\t      expect(source).not.toMatch(/\\breaddir/i);\n196\t      expect(source).not.toMatch(/\\bglob\\b/i);\n197\t      expect(source).not.toMatch(/\\brequire\\s*\\(/);\n198\t    });\n199\t  });\n200\t\n201\t  describe('suggestCheaperDriver', () => {\n202\t    it('returns cheaper driver when one exists', () => {\n203\t      registerDriver(createMockDriver('claude-code', { supportsPlugins: true, costTier: 3 }));\n204\t      registerDriver(createMockDriver('codex', { supportsPlugins: false, costTier: 1 }));\n205\t      // No required caps — codex can handle it\n206\t      const result = suggestCheaperDriver('claude-code', {});\n207\t      expect(result).toBe('codex');\n208\t    });\n209\t\n210\t    it('returns null when current driver is cheapest', () => {\n211\t      registerDriver(createMockDriver('codex', { supportsPlugins: false, costTier: 1 }));\n212\t      registerDriver(createMockDriver('claude-code', { supportsPlugins: true, costTier: 3 }));\n213\t      const result = suggestCheaperDriver('codex', {});\n214\t      expect(result).toBeNull();\n215\t    });\n216\t\n217\t    it('respects required capabilities when suggesting', () => {\n218\t      registerDriver(createMockDriver('claude-code', { supportsPlugins: true, costTier: 3 }));\n219\t      registerDriver(createMockDriver('codex', { supportsPlugins: false, costTier: 1 }));\n220\t      registerDriver(createMockDriver('opencode', { supportsPlugins: true, costTier: 2 }));\n221\t      // Requires plugins — codex can't handle it, opencode can\n222\t      const result = suggestCheaperDriver('claude-code', { supportsPlugins: true });\n223\t      expect(result).toBe('opencode');\n224\t    });\n225\t\n226\t    it('returns null when no driver satisfies required caps at lower cost', () => {\n227\t      registerDriver(createMockDriver('claude-code', { supportsPlugins: true, costTier: 3 }));\n228\t      registerDriver(createMockDriver('codex', { supportsPlugins: false, costTier: 1 }));\n229\t      // Requires plugins — codex can't, only claude-code can (no cheaper option)\n230\t      const result = suggestCheaperDriver('claude-code', { supportsPlugins: true });\n231\t      expect(result).toBeNull();\n232\t    });\n233\t\n234\t    it('returns null for unregistered driver', () => {\n235\t      const result = suggestCheaperDriver('nonexistent', {});\n236\t      expect(result).toBeNull();\n237\t    });\n238\t\n239\t    it('returns cheapest among multiple capable drivers', () => {\n240\t      registerDriver(createMockDriver('expensive', { supportsPlugins: true, costTier: 5 }));\n241\t      registerDriver(createMockDriver('mid', { supportsPlugins: true, costTier: 3 }));\n242\t      registerDriver(createMockDriver('cheap', { supportsPlugins: true, costTier: 1 }));\n243\t      const result = suggestCheaperDriver('expensive', { supportsPlugins: true });\n244\t      expect(result).toBe('cheap');\n245\t    });\n246\t  });\n247\t\n248\t  describe('barrel re-exports', () => {\n249\t    it('drivers/index.ts re-exports all factory functions', async () => {\n250\t      const barrel = await import('../drivers/index.js');\n251\t      expect(typeof barrel.getDriver).toBe('function');\n252\t      expect(typeof barrel.registerDriver).toBe('function');\n253\t      expect(typeof barrel.listDrivers).toBe('function');\n254\t      expect(typeof barrel.resetDrivers).toBe('function');\n255\t    });\n256\t\n257\t    it('agents/index.ts re-exports factory functions', async () => {\n258\t      const agents = await import('../index.js');\n259\t      expect(typeof agents.getDriver).toBe('function');\n260\t      expect(typeof agents.registerDriver).toBe('function');\n261\t      expect(typeof agents.listDrivers).toBe('function');\n262\t      expect(typeof agents.resetDrivers).toBe('function');\n263\t    });\n264\t  });\n265\t});\n266\t"}]},"parent_tool_use_id":"toolu_01WL7MCsNF3La2JHGCjnTeXK","session_id":"cf16e575-8267-4c58-a992-20b07458710f","uuid":"ca16fe0c-4258-462b-b2c0-9dfb6924cf27","timestamp":"2026-04-03T13:30:03.775Z"}
