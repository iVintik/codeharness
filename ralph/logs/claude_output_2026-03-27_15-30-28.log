{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016NHzvWPZnHTvPz1qNtQNtz","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import {\n     3→  VALIDATION_ACS,\n     4→  getACsByCategory,\n     5→  getTestProvableACs,\n     6→  getEnvironmentProvableACs,\n     7→  getCliVerifiableACs,\n     8→  getIntegrationRequiredACs,\n     9→  getACById,\n    10→} from '../validation-acs.js';\n    11→import type { ValidationAC, AcCategory, VerificationMethod } from '../validation-acs.js';\n    12→\n    13→describe('Validation AC Registry', () => {\n    14→  // ─── Task 6: Registry contains exactly 79 ACs ──────────────────────────────\n    15→\n    16→  it('contains exactly 79 ACs', () => {\n    17→    expect(VALIDATION_ACS).toHaveLength(79);\n    18→  });\n    19→\n    20→  // ─── Task 6: Every FR (1-40) has exactly one AC ────────────────────────────\n    21→\n    22→  it('has exactly one AC per FR (IDs 1-40)', () => {\n    23→    for (let frNum = 1; frNum <= 40; frNum++) {\n    24→      const matches = VALIDATION_ACS.filter(ac => ac.id === frNum);\n    25→      expect(matches).toHaveLength(1);\n    26→      expect(matches[0].frRef).toMatch(/^FR\\d+$/);\n    27→    }\n    28→  });\n    29→\n    30→  // ─── Task 6: No duplicate AC IDs ───────────────────────────────────────────\n    31→\n    32→  it('has no duplicate AC IDs', () => {\n    33→    const ids = VALIDATION_ACS.map(ac => ac.id);\n    34→    const uniqueIds = new Set(ids);\n    35→    expect(uniqueIds.size).toBe(ids.length);\n    36→  });\n    37→\n    38→  // ─── Task 6: Every AC has a verificationMethod ─────────────────────────────\n    39→\n    40→  it('every AC has a verificationMethod', () => {\n    41→    const validMethods: VerificationMethod[] = ['cli', 'integration'];\n    42→    for (const ac of VALIDATION_ACS) {\n    43→      expect(validMethods).toContain(ac.verificationMethod);\n    44→    }\n    45→  });\n    46→\n    47→  // ─── Task 6: CLI-verifiable ACs have a command ─────────────────────────────\n    48→\n    49→  it('every cli-verifiable AC has a command', () => {\n    50→    const cliACs = VALIDATION_ACS.filter(ac => ac.verificationMethod === 'cli');\n    51→    for (const ac of cliACs) {\n    52→      expect(ac.command, `AC ${ac.id} (${ac.frRef}) is cli-verifiable but has no command`).toBeDefined();\n    53→      expect(ac.command!.length).toBeGreaterThan(0);\n    54→    }\n    55→  });\n    56→\n    57→  // ─── Additional structural validations ─────────────────────────────────────\n    58→\n    59→  it('ACs are numbered sequentially 1-79', () => {\n    60→    for (let i = 0; i < VALIDATION_ACS.length; i++) {\n    61→      expect(VALIDATION_ACS[i].id).toBe(i + 1);\n    62→    }\n    63→  });\n    64→\n    65→  it('every AC has a non-empty description', () => {\n    66→    for (const ac of VALIDATION_ACS) {\n    67→      expect(ac.description.length, `AC ${ac.id} has empty description`).toBeGreaterThan(0);\n    68→    }\n    69→  });\n    70→\n    71→  it('every AC has a non-empty frRef', () => {\n    72→    for (const ac of VALIDATION_ACS) {\n    73→      expect(ac.frRef.length, `AC ${ac.id} has empty frRef`).toBeGreaterThan(0);\n    74→    }\n    75→  });\n    76→\n    77→  it('every AC has a valid category', () => {\n    78→    const validCategories: AcCategory[] = ['FR', 'NFR', 'UX', 'Regression', 'ActionItem'];\n    79→    for (const ac of VALIDATION_ACS) {\n    80→      expect(validCategories).toContain(ac.category);\n    81→    }\n    82→  });\n    83→\n    84→  // ─── Category distribution ─────────────────────────────────────────────────\n    85→\n    86→  it('has correct category distribution', () => {\n    87→    const frCount = VALIDATION_ACS.filter(ac => ac.category === 'FR').length;\n    88→    const nfrCount = VALIDATION_ACS.filter(ac => ac.category === 'NFR').length;\n    89→    const uxCount = VALIDATION_ACS.filter(ac => ac.category === 'UX').length;\n    90→    const regressionCount = VALIDATION_ACS.filter(ac => ac.category === 'Regression').length;\n    91→    const actionItemCount = VALIDATION_ACS.filter(ac => ac.category === 'ActionItem').length;\n    92→\n    93→    expect(frCount).toBe(40);\n    94→    expect(nfrCount).toBe(8);\n    95→    expect(uxCount).toBe(3);\n    96→    expect(regressionCount).toBe(20);\n    97→    expect(actionItemCount).toBe(8);\n    98→  });\n    99→\n   100→  // ─── Verification method distribution ──────────────────────────────────────\n   101→\n   102→  it('has correct verification method distribution', () => {\n   103→    const cliCount = VALIDATION_ACS.filter(ac => ac.verificationMethod === 'cli').length;\n   104→    const integrationCount = VALIDATION_ACS.filter(ac => ac.verificationMethod === 'integration').length;\n   105→\n   106→    // Story table says 53/26 but actual AC verification tags yield 55/24\n   107→    expect(cliCount).toBe(55);\n   108→    expect(integrationCount).toBe(24);\n   109→  });\n   110→\n   111→  // ─── FR ref uniqueness ─────────────────────────────────────────────────────\n   112→\n   113→  it('FR ACs have unique frRef values', () => {\n   114→    const frACs = VALIDATION_ACS.filter(ac => ac.category === 'FR');\n   115→    const refs = frACs.map(ac => ac.frRef);\n   116→    const uniqueRefs = new Set(refs);\n   117→    expect(uniqueRefs.size).toBe(refs.length);\n   118→  });\n   119→});\n   120→\n   121→// ─── Helper function tests ───────────────────────────────────────────────────\n   122→\n   123→describe('getACsByCategory', () => {\n   124→  it('returns only FR ACs when asked', () => {\n   125→    const frs = getACsByCategory('FR');\n   126→    expect(frs).toHaveLength(40);\n   127→    expect(frs.every(ac => ac.category === 'FR')).toBe(true);\n   128→  });\n   129→\n   130→  it('returns only NFR ACs when asked', () => {\n   131→    const nfrs = getACsByCategory('NFR');\n   132→    expect(nfrs).toHaveLength(8);\n   133→    expect(nfrs.every(ac => ac.category === 'NFR')).toBe(true);\n   134→  });\n   135→\n   136→  it('returns only UX ACs when asked', () => {\n   137→    const ux = getACsByCategory('UX');\n   138→    expect(ux).toHaveLength(3);\n   139→  });\n   140→\n   141→  it('returns only Regression ACs when asked', () => {\n   142→    const reg = getACsByCategory('Regression');\n   143→    expect(reg).toHaveLength(20);\n   144→  });\n   145→\n   146→  it('returns only ActionItem ACs when asked', () => {\n   147→    const actions = getACsByCategory('ActionItem');\n   148→    expect(actions).toHaveLength(8);\n   149→  });\n   150→});\n   151→\n   152→describe('getTestProvableACs', () => {\n   153→  it('returns 55 test-provable ACs (verificationMethod === cli)', () => {\n   154→    const acs = getTestProvableACs();\n   155→    expect(acs).toHaveLength(55);\n   156→    expect(acs.every(ac => ac.verificationMethod === 'cli')).toBe(true);\n   157→  });\n   158→\n   159→  it('every returned AC has a command', () => {\n   160→    const acs = getTestProvableACs();\n   161→    for (const ac of acs) {\n   162→      expect(ac.command).toBeDefined();\n   163→    }\n   164→  });\n   165→\n   166→  it('returns same data as deprecated getCliVerifiableACs()', () => {\n   167→    const newResult = getTestProvableACs();\n   168→    const oldResult = getCliVerifiableACs();\n   169→    expect(newResult).toEqual(oldResult);\n   170→  });\n   171→});\n   172→\n   173→describe('getEnvironmentProvableACs', () => {\n   174→  it('returns 24 environment-provable ACs (verificationMethod === integration)', () => {\n   175→    const acs = getEnvironmentProvableACs();\n   176→    expect(acs).toHaveLength(24);\n   177→    expect(acs.every(ac => ac.verificationMethod === 'integration')).toBe(true);\n   178→  });\n   179→\n   180→  it('returns same data as deprecated getIntegrationRequiredACs()', () => {\n   181→    const newResult = getEnvironmentProvableACs();\n   182→    const oldResult = getIntegrationRequiredACs();\n   183→    expect(newResult).toEqual(oldResult);\n   184→  });\n   185→});\n   186→\n   187→describe('getCliVerifiableACs (deprecated alias)', () => {\n   188→  it('returns 55 cli-verifiable ACs', () => {\n   189→    const cliACs = getCliVerifiableACs();\n   190→    expect(cliACs).toHaveLength(55);\n   191→    expect(cliACs.every(ac => ac.verificationMethod === 'cli')).toBe(true);\n   192→  });\n   193→\n   194→  it('every returned AC has a command', () => {\n   195→    const cliACs = getCliVerifiableACs();\n   196→    for (const ac of cliACs) {\n   197→      expect(ac.command).toBeDefined();\n   198→    }\n   199→  });\n   200→});\n   201→\n   202→describe('getIntegrationRequiredACs (deprecated alias)', () => {\n   203→  it('returns 24 integration-required ACs', () => {\n   204→    const intACs = getIntegrationRequiredACs();\n   205→    expect(intACs).toHaveLength(24);\n   206→    expect(intACs.every(ac => ac.verificationMethod === 'integration')).toBe(true);\n   207→  });\n   208→});\n   209→\n   210→describe('getACById', () => {\n   211→  it('returns the correct AC for a valid ID', () => {\n   212→    const ac1 = getACById(1);\n   213→    expect(ac1).toBeDefined();\n   214→    expect(ac1!.id).toBe(1);\n   215→    expect(ac1!.frRef).toBe('FR1');\n   216→  });\n   217→\n   218→  it('returns the last AC (79)', () => {\n   219→    const ac79 = getACById(79);\n   220→    expect(ac79).toBeDefined();\n   221→    expect(ac79!.id).toBe(79);\n   222→    expect(ac79!.category).toBe('ActionItem');\n   223→  });\n   224→\n   225→  it('returns undefined for non-existent ID', () => {\n   226→    expect(getACById(0)).toBeUndefined();\n   227→    expect(getACById(80)).toBeUndefined();\n   228→    expect(getACById(-1)).toBeUndefined();\n   229→  });\n   230→});\n   231→\n   232→// ─── Integration prerequisite tags (Task 3) ──────────────────────────────────\n   233→\n   234→describe('Integration AC prerequisites', () => {\n   235→  it('Docker-dependent ACs are integration-required', () => {\n   236→    const dockerACs = [2, 5, 6, 13, 14, 63];\n   237→    for (const id of dockerACs) {\n   238→      const ac = getACById(id);\n   239→      expect(ac).toBeDefined();\n   240→      expect(ac!.verificationMethod, `AC ${id} should be integration`).toBe('integration');\n   241→    }\n   242→  });\n   243→\n   244→  it('Shared stack ACs are integration-required', () => {\n   245→    const stackACs = [2, 66];\n   246→    for (const id of stackACs) {\n   247→      const ac = getACById(id);\n   248→      expect(ac).toBeDefined();\n   249→      expect(ac!.verificationMethod, `AC ${id} should be integration`).toBe('integration');\n   250→    }\n   251→  });\n   252→\n   253→  it('OpenSearch ACs are integration-required', () => {\n   254→    const osACs = [3, 32, 69];\n   255→    for (const id of osACs) {\n   256→      const ac = getACById(id);\n   257→      expect(ac).toBeDefined();\n   258→      expect(ac!.verificationMethod, `AC ${id} should be integration`).toBe('integration');\n   259→    }\n   260→  });\n   261→\n   262→  it('Agent-browser ACs are integration-required', () => {\n   263→    const browserACs = [16, 70];\n   264→    for (const id of browserACs) {\n   265→      const ac = getACById(id);\n   266→      expect(ac).toBeDefined();\n   267→      expect(ac!.verificationMethod, `AC ${id} should be integration`).toBe('integration');\n   268→    }\n   269→  });\n   270→\n   271→  it('Ralph session ACs are integration-required', () => {\n   272→    const ralphACs = [9, 42];\n   273→    for (const id of ralphACs) {\n   274→      const ac = getACById(id);\n   275→      expect(ac).toBeDefined();\n   276→      expect(ac!.verificationMethod, `AC ${id} should be integration`).toBe('integration');\n   277→    }\n   278→  });\n   279→});\n   280→\n   281→// ─── Regression mapping (Task 4) ─────────────────────────────────────────────\n   282→\n   283→describe('Regression ACs map to v1 stories', () => {\n   284→  it('regression ACs cover IDs 52-71', () => {\n   285→    const regACs = getACsByCategory('Regression');\n   286→    const ids = regACs.map(ac => ac.id).sort((a, b) => a - b);\n   287→    expect(ids[0]).toBe(52);\n   288→    expect(ids[ids.length - 1]).toBe(71);\n   289→  });\n   290→\n   291→  it('each regression AC references a story number', () => {\n   292→    const regACs = getACsByCategory('Regression');\n   293→    for (const ac of regACs) {\n   294→      expect(ac.frRef).toMatch(/^Regression: \\d+-\\d+$/);\n   295→    }\n   296→  });\n   297→});\n   298→\n   299→// ─── Action item ACs (Task 5) ────────────────────────────────────────────────\n   300→\n   301→describe('Action item ACs map to session retros', () => {\n   302→  it('action item ACs cover IDs 72-79', () => {\n   303→    const actionACs = getACsByCategory('ActionItem');\n   304→    const ids = actionACs.map(ac => ac.id).sort((a, b) => a - b);\n   305→    expect(ids[0]).toBe(72);\n   306→    expect(ids[ids.length - 1]).toBe(79);\n   307→  });\n   308→\n   309→  it('each action item AC references a session retro', () => {\n   310→    const actionACs = getACsByCategory('ActionItem');\n   311→    for (const ac of actionACs) {\n   312→      expect(ac.frRef).toMatch(/^Action: session-retro-/);\n   313→    }\n   314→  });\n   315→\n   316→  it('all action item ACs are cli-verifiable', () => {\n   317→    const actionACs = getACsByCategory('ActionItem');\n   318→    expect(actionACs.every(ac => ac.verificationMethod === 'cli')).toBe(true);\n   319→  });\n   320→});\n   321→"}]},"parent_tool_use_id":"toolu_01WsJumCEeohz8aetMGbH1m9","session_id":"15a05376-1038-4ca0-9130-3347fd423c16","uuid":"53e391c8-760a-437c-a6d9-e01e821f2713","timestamp":"2026-03-27T11:41:36.750Z"}
