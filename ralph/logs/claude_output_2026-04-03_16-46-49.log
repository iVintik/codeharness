{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QjcTNBqAa2fXwWF94yNxYx","type":"tool_result","content":"1\t/**\n2\t * Ink Terminal Renderer — live terminal UI for Claude activity display.\n3\t *\n4\t * Exports a controller API: startRenderer(), which returns a RendererHandle\n5\t * with update(), updateSprintState(), and cleanup() methods.\n6\t *\n7\t * The renderer accumulates state from StreamEvent objects and renders\n8\t * tool calls, thoughts, and sprint progress using Ink (React for terminals).\n9\t */\n10\t\n11\timport React from 'react';\n12\timport { render as inkRender } from 'ink';\n13\timport type { StreamEvent } from './agents/stream-parser.js';\n14\timport {\n15\t  App,\n16\t  type SprintInfo,\n17\t  type CompletedToolEntry,\n18\t  type RetryInfo,\n19\t  type RendererState,\n20\t  type StoryStatusEntry,\n21\t  type StoryMessage,\n22\t  type TaskNodeState,\n23\t  type TaskNodeMeta,\n24\t} from './ink-components.js';\n25\timport type { FlowStep } from './workflow-parser.js';\n26\t\n27\t// --- Public Types ---\n28\t\n29\texport interface RendererOptions {\n30\t  quiet?: boolean;\n31\t  sprintState?: SprintInfo;\n32\t  /** @internal Force TTY mode for testing. Not part of the public API. */\n33\t  _forceTTY?: boolean;\n34\t}\n35\t\n36\texport interface RendererHandle {\n37\t  update(event: StreamEvent, driverName?: string): void;\n38\t  updateSprintState(state: SprintInfo | undefined): void;\n39\t  updateStories(stories: StoryStatusEntry[]): void;\n40\t  addMessage(msg: StoryMessage): void;\n41\t  updateWorkflowState(flow: FlowStep[], currentTask: string | null, taskStates: Record<string, TaskNodeState>, taskMeta?: Record<string, TaskNodeMeta>): void;\n42\t  cleanup(): void;\n43\t}\n44\t\n45\t// --- No-op handle for quiet mode ---\n46\t\n47\tconst noopHandle: RendererHandle = {\n48\t  update(_event: StreamEvent, _driverName?: string) {},\n49\t  updateSprintState() {},\n50\t  updateStories() {},\n51\t  addMessage() {},\n52\t  updateWorkflowState() {},\n53\t  cleanup() {},\n54\t};\n55\t\n56\t/** Maximum number of completed tools to retain in the display list. */\n57\tconst MAX_COMPLETED_TOOLS = 50;\n58\t\n59\t// --- Controller ---\n60\t\n61\t/**\n62\t * Start the Ink terminal renderer.\n63\t *\n64\t * If `quiet` is true or stdout is not a TTY, returns a no-op handle\n65\t * (no Ink instance created).\n66\t * Otherwise, mounts the component tree and returns a handle for feeding events.\n67\t */\n68\texport function startRenderer(options?: RendererOptions): RendererHandle {\n69\t  if (options?.quiet || (!process.stdout.isTTY && !options?._forceTTY)) {\n70\t    return noopHandle;\n71\t  }\n72\t\n73\t  // Mutable state that drives re-renders\n74\t  let state: RendererState = {\n75\t    sprintInfo: options?.sprintState ?? null,\n76\t    stories: [],\n77\t    messages: [],\n78\t    completedTools: [],\n79\t    activeTool: null,\n80\t    activeToolArgs: '',\n81\t    lastThought: null,\n82\t    retryInfo: null,\n83\t    workflowFlow: [],\n84\t    currentTaskName: null,\n85\t    taskStates: {},\n86\t    taskMeta: {},\n87\t    activeDriverName: null,\n88\t    driverCosts: {},\n89\t  };\n90\t\n91\t  let cleaned = false;\n92\t\n93\t  // Mount Ink with performance options\n94\t  const inkInstance = inkRender(<App state={state} />, {\n95\t    exitOnCtrlC: false,\n96\t    patchConsole: !options?._forceTTY,\n97\t    maxFps: 15,\n98\t  });\n99\t\n100\t  function rerender() {\n101\t    if (!cleaned) {\n102\t      // Create a new state object reference to trigger React re-render\n103\t      state = { ...state };\n104\t      inkInstance.rerender(<App state={state} />);\n105\t    }\n106\t  }\n107\t\n108\t  function cleanup() {\n109\t    if (cleaned) return;\n110\t    cleaned = true;\n111\t    try {\n112\t      inkInstance.unmount();\n113\t    } catch {\n114\t      // Ignore — may already be unmounted\n115\t    }\n116\t    try {\n117\t      inkInstance.cleanup();\n118\t    } catch {\n119\t      // Ignore\n120\t    }\n121\t    // Remove our signal handlers\n122\t    process.removeListener('SIGINT', onSigint);\n123\t    process.removeListener('SIGTERM', onSigterm);\n124\t  }\n125\t\n126\t  function onSigint() {\n127\t    cleanup();\n128\t    // Re-raise signal so the default handler runs (allows caller to handle exit)\n129\t    process.kill(process.pid, 'SIGINT');\n130\t  }\n131\t\n132\t  function onSigterm() {\n133\t    cleanup();\n134\t    process.kill(process.pid, 'SIGTERM');\n135\t  }\n136\t\n137\t  // Register signal handlers\n138\t  process.on('SIGINT', onSigint);\n139\t  process.on('SIGTERM', onSigterm);\n140\t\n141\t  function update(event: StreamEvent, driverName?: string): void {\n142\t    if (cleaned) return;\n143\t\n144\t    switch (event.type) {\n145\t      case 'tool-start':\n146\t        // If a long-running tool was still active, promote it to completed now\n147\t        if (state.activeTool) {\n148\t          const entry: CompletedToolEntry = {\n149\t            name: state.activeTool.name,\n150\t            args: state.activeToolArgs,\n151\t            driver: state.activeDriverName ?? undefined,\n152\t          };\n153\t          const updated = [...state.completedTools, entry];\n154\t          state.completedTools = updated.length > MAX_COMPLETED_TOOLS\n155\t            ? updated.slice(updated.length - MAX_COMPLETED_TOOLS)\n156\t            : updated;\n157\t        }\n158\t        state.activeTool = { name: event.name };\n159\t        state.activeToolArgs = '';\n160\t        state.activeDriverName = driverName ?? null;\n161\t        state.lastThought = null;\n162\t        state.retryInfo = null;\n163\t        break;\n164\t\n165\t      case 'tool-input':\n166\t        state.activeToolArgs += event.partial;\n167\t        return; // Skip rerender — args only shown on completion\n168\t\n169\t      case 'tool-complete':\n170\t        // CRITICAL: Only promote if there's an active tool.\n171\t        // The parser emits tool-complete for ALL content_block_stop events\n172\t        // (both tool and text blocks). Ignore if no activeTool is set.\n173\t        if (state.activeTool) {\n174\t          // Long-running tools (Agent, Skill) get content_block_stop when their\n175\t          // INPUT is complete, not when they finish executing. Keep them active\n176\t          // so the spinner shows during the entire execution. They'll be promoted\n177\t          // when the next tool-start fires (below in tool-start case).\n178\t          const LONG_RUNNING_TOOLS = ['Agent', 'Skill'];\n179\t          if (LONG_RUNNING_TOOLS.includes(state.activeTool.name)) {\n180\t            break; // Keep as active — don't promote to completed yet\n181\t          }\n182\t          const entry: CompletedToolEntry = {\n183\t            name: state.activeTool.name,\n184\t            args: state.activeToolArgs,\n185\t            driver: state.activeDriverName ?? undefined,\n186\t          };\n187\t          const updated = [...state.completedTools, entry];\n188\t          // Bound the list to prevent unbounded memory growth in long sessions\n189\t          state.completedTools = updated.length > MAX_COMPLETED_TOOLS\n190\t            ? updated.slice(updated.length - MAX_COMPLETED_TOOLS)\n191\t            : updated;\n192\t          state.activeTool = null;\n193\t          state.activeToolArgs = '';\n194\t          state.activeDriverName = null;\n195\t        }\n196\t        break;\n197\t\n198\t      case 'text':\n199\t        state.lastThought = event.text;\n200\t        state.retryInfo = null;\n201\t        break;\n202\t\n203\t      case 'retry':\n204\t        state.retryInfo = { attempt: event.attempt, delay: event.delay };\n205\t        break;\n206\t\n207\t      case 'result':\n208\t        // Accumulate cost from result events (AC #7)\n209\t        if (event.cost > 0 && state.sprintInfo) {\n210\t          state.sprintInfo = {\n211\t            ...state.sprintInfo,\n212\t            totalCost: (state.sprintInfo.totalCost ?? 0) + event.cost,\n213\t          };\n214\t        }\n215\t        // Accumulate per-driver cost\n216\t        if (event.cost > 0 && driverName) {\n217\t          state.driverCosts = {\n218\t            ...state.driverCosts,\n219\t            [driverName]: (state.driverCosts[driverName] ?? 0) + event.cost,\n220\t          };\n221\t        }\n222\t        break;\n223\t    }\n224\t\n225\t    rerender();\n226\t  }\n227\t\n228\t  function updateSprintState(sprintState: SprintInfo | undefined): void {\n229\t    if (cleaned) return;\n230\t    if (sprintState && state.sprintInfo) {\n231\t      // Preserve accumulated fields (totalCost, acProgress, currentCommand)\n232\t      // that are set by event handlers but not by the polling caller.\n233\t      state.sprintInfo = {\n234\t        ...sprintState,\n235\t        totalCost: sprintState.totalCost ?? state.sprintInfo.totalCost,\n236\t        acProgress: sprintState.acProgress ?? state.sprintInfo.acProgress,\n237\t        currentCommand: sprintState.currentCommand ?? state.sprintInfo.currentCommand,\n238\t      };\n239\t    } else {\n240\t      state.sprintInfo = sprintState ?? null;\n241\t    }\n242\t    rerender();\n243\t  }\n244\t\n245\t  function updateStories(stories: StoryStatusEntry[]): void {\n246\t    if (cleaned) return;\n247\t    state.stories = [...stories];\n248\t    rerender();\n249\t  }\n250\t\n251\t  function addMessage(msg: StoryMessage): void {\n252\t    if (cleaned) return;\n253\t    state.messages = [...state.messages, msg];\n254\t    rerender();\n255\t  }\n256\t\n257\t  function updateWorkflowState(flow: FlowStep[], currentTask: string | null, taskStates: Record<string, TaskNodeState>, taskMeta?: Record<string, TaskNodeMeta>): void {\n258\t    if (cleaned) return;\n259\t    state.workflowFlow = flow;\n260\t    state.currentTaskName = currentTask;\n261\t    state.taskStates = { ...taskStates };\n262\t    state.taskMeta = taskMeta ? { ...taskMeta } : state.taskMeta;\n263\t    rerender();\n264\t  }\n265\t\n266\t  return { update, updateSprintState, updateStories, addMessage, updateWorkflowState, cleanup };\n267\t}\n268\t\n269\t// Re-export types that consumers may need\n270\texport type { SprintInfo, CompletedToolEntry, RetryInfo, RendererState, StoryStatusEntry, StoryStatusValue, StoryMessage, TaskNodeState, TaskNodeMeta } from './ink-components.js';\n271\t"}]},"parent_tool_use_id":"toolu_01KuW1MjUdFwtjdSVSiFS3H5","session_id":"a0646c12-93c6-41a0-9c7a-50683cae7716","uuid":"bcc0e46c-d031-4d91-8f8a-c8f50b49c92e","timestamp":"2026-04-03T12:55:13.555Z"}
