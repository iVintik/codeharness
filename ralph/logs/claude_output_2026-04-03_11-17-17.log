{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01HPYP8FohJDQrZqn6r9viUX","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01B9sZWwfSsw37kAM9A7h5aA","name":"Write","input":{"file_path":"/Users/ivintik/dev/personal/codeharness/src/lib/agents/model-resolver.ts","content":"/**\n * Model Resolution Module (Story 10-4).\n *\n * Resolves the effective model for a task dispatch using a 3-level cascade:\n *   1. Task-level model (highest priority)\n *   2. Agent-level model\n *   3. Driver default model (lowest priority, must be valid)\n *\n * Architecture reference: Decision 4 in architecture-multi-framework.md.\n */\n\n/**\n * Resolves the effective model string using a task → agent → driver cascade.\n *\n * Empty strings, `null`, and `undefined` are all treated as \"not set\" and\n * fall through to the next level. The driver's `defaultModel` is the final\n * fallback and must be a non-empty string — if it is falsy, an error is thrown.\n *\n * @param task   - Object with an optional `model` field (e.g. workflow task)\n * @param agent  - Object with an optional `model` field (e.g. resolved agent config)\n * @param driver - Object with a required `defaultModel` field (e.g. AgentDriver)\n * @returns The resolved model string\n * @throws {Error} If `driver.defaultModel` is empty or falsy\n */\nexport function resolveModel(\n  task: { model?: string | null },\n  agent: { model?: string | null },\n  driver: { defaultModel: string },\n): string {\n  if (!driver.defaultModel) {\n    throw new Error(\n      'Driver has no default model: driver.defaultModel must be a non-empty string',\n    );\n  }\n\n  if (task.model) {\n    return task.model;\n  }\n\n  if (agent.model) {\n    return agent.model;\n  }\n\n  return driver.defaultModel;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":6732,"cache_read_input_tokens":20453,"cache_creation":{"ephemeral_5m_input_tokens":6732,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_013tv4KsrvbUrsFbPV6hVKzc","session_id":"2c102368-34ec-49f5-8d34-59f136ae42aa","uuid":"7264e4eb-3e3f-4584-a2c0-e790bdcbc75f"}
