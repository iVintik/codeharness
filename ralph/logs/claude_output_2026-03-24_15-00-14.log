{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AY9ffjoR7RqLHkjtmCVdz2","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';\n     2→import {\n     3→  readFileSync,\n     4→  writeFileSync,\n     5→  unlinkSync,\n     6→  existsSync,\n     7→  chmodSync,\n     8→} from 'node:fs';\n     9→import { join } from 'node:path';\n    10→import type { SprintState } from '../../../types/state.js';\n    11→\n    12→// Mock migration so state tests are isolated from real project files\n    13→vi.mock('../migration.js', () => ({\n    14→  migrateFromOldFormat: vi.fn(() => ({\n    15→    success: false,\n    16→    error: 'No old format files found for migration',\n    17→  })),\n    18→  migrateV1ToV2: vi.fn((v1: Record<string, unknown>) => ({\n    19→    ...v1,\n    20→    version: 2,\n    21→    retries: {},\n    22→    flagged: [],\n    23→    epics: {},\n    24→    session: { active: false, startedAt: null, iteration: 0, elapsedSeconds: 0 },\n    25→    observability: { statementCoverage: null, branchCoverage: null, functionCoverage: null, lineCoverage: null },\n    26→  })),\n    27→}));\n    28→\n    29→// Import after mock setup\n    30→const { getSprintState, updateStoryStatus, writeStateAtomic, defaultState, statePath } =\n    31→  await import('../state.js');\n    32→\n    33→const STATE_FILE = join(process.cwd(), 'sprint-state.json');\n    34→const TMP_FILE = join(process.cwd(), '.sprint-state.json.tmp');\n    35→\n    36→function cleanup(): void {\n    37→  for (const f of [STATE_FILE, TMP_FILE]) {\n    38→    try {\n    39→      chmodSync(f, 0o644);\n    40→    } catch {\n    41→      // ignore — file may not exist\n    42→    }\n    43→    try {\n    44→      unlinkSync(f);\n    45→    } catch {\n    46→      // ignore — file may not exist\n    47→    }\n    48→  }\n    49→}\n    50→\n    51→describe('defaultState', () => {\n    52→  it('returns version 2 with empty stories and v2 fields', () => {\n    53→    const state = defaultState();\n    54→    expect(state.version).toBe(2);\n    55→    expect(state.stories).toEqual({});\n    56→    expect(state.run.active).toBe(false);\n    57→    expect(state.run.iteration).toBe(0);\n    58→    expect(state.sprint.total).toBe(0);\n    59→    expect(state.actionItems).toEqual([]);\n    60→  });\n    61→});\n    62→\n    63→describe('statePath', () => {\n    64→  it('returns path ending in sprint-state.json', () => {\n    65→    expect(statePath()).toBe(STATE_FILE);\n    66→  });\n    67→});\n    68→\n    69→describe('writeStateAtomic', () => {\n    70→  beforeEach(cleanup);\n    71→  afterEach(cleanup);\n    72→\n    73→  it('writes valid JSON to sprint-state.json', () => {\n    74→    const state = defaultState();\n    75→    const result = writeStateAtomic(state);\n    76→    expect(result.success).toBe(true);\n    77→    expect(existsSync(STATE_FILE)).toBe(true);\n    78→\n    79→    const raw = readFileSync(STATE_FILE, 'utf-8');\n    80→    const parsed = JSON.parse(raw);\n    81→    expect(parsed.version).toBe(2);\n    82→  });\n    83→\n    84→  it('tmp file does not remain after successful write', () => {\n    85→    const result = writeStateAtomic(defaultState());\n    86→    expect(result.success).toBe(true);\n    87→    expect(existsSync(TMP_FILE)).toBe(false);\n    88→  });\n    89→});\n    90→\n    91→describe('getSprintState', () => {\n    92→  beforeEach(cleanup);\n    93→  afterEach(cleanup);\n    94→\n    95→  it('returns default state when no file exists', () => {\n    96→    const result = getSprintState();\n    97→    expect(result.success).toBe(true);\n    98→    if (result.success) {\n    99→      expect(result.data.version).toBe(2);\n   100→      expect(result.data.stories).toEqual({});\n   101→      expect(result.data.run.active).toBe(false);\n   102→      expect(result.data.sprint.inProgress).toBeNull();\n   103→      expect(result.data.actionItems).toEqual([]);\n   104→      expect(result.data.retries).toEqual({});\n   105→      expect(result.data.flagged).toEqual([]);\n   106→      expect(result.data.epics).toEqual({});\n   107→      expect(result.data.session.active).toBe(false);\n   108→      expect(result.data.observability.statementCoverage).toBeNull();\n   109→    }\n   110→  });\n   111→\n   112→  it('reads and parses existing sprint-state.json', () => {\n   113→    const state: SprintState = {\n   114→      ...defaultState(),\n   115→      stories: {\n   116→        'test-story': {\n   117→          status: 'done',\n   118→          attempts: 2,\n   119→          lastAttempt: '2026-01-01T00:00:00Z',\n   120→          lastError: null,\n   121→          proofPath: null,\n   122→          acResults: null,\n   123→        },\n   124→      },\n   125→    };\n   126→    writeFileSync(STATE_FILE, JSON.stringify(state, null, 2), 'utf-8');\n   127→\n   128→    const result = getSprintState();\n   129→    expect(result.success).toBe(true);\n   130→    if (result.success) {\n   131→      expect(result.data.stories['test-story'].status).toBe('done');\n   132→      expect(result.data.stories['test-story'].attempts).toBe(2);\n   133→    }\n   134→  });\n   135→\n   136→  it('returns fail on invalid JSON', () => {\n   137→    writeFileSync(STATE_FILE, '{not valid json', 'utf-8');\n   138→    const result = getSprintState();\n   139→    expect(result.success).toBe(false);\n   140→    if (!result.success) {\n   141→      expect(result.error).toContain('Failed to read sprint state');\n   142→    }\n   143→  });\n   144→\n   145→  it('parse time is under 100ms for 50 stories', () => {\n   146→    const stories: Record<string, SprintState['stories'][string]> = {};\n   147→    for (let i = 0; i < 50; i++) {\n   148→      stories[`story-${i}`] = {\n   149→        status: 'backlog',\n   150→        attempts: i,\n   151→        lastAttempt: new Date().toISOString(),\n   152→        lastError: `error ${i}`,\n   153→        proofPath: null,\n   154→    