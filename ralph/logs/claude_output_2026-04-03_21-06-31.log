{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01564KgjvTWsaCLaQsVFyv14","type":"tool_result","content":"100\t\n101\t// --- Crash Recovery: Task Completion Check ---\n102\t\n103\t/**\n104\t * Check whether a (taskName, storyKey) combination is already recorded\n105\t * in the workflow state's tasks_completed array.\n106\t *\n107\t * Both fields must match for the task to be considered completed.\n108\t * Used by the resume logic to skip already-completed dispatches.\n109\t */\n110\texport function isTaskCompleted(\n111\t  state: WorkflowState,\n112\t  taskName: string,\n113\t  storyKey: string,\n114\t): boolean {\n115\t  return state.tasks_completed.some(\n116\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey && !cp.error,\n117\t  );\n118\t}\n119\t\n120\t/**\n121\t * Check whether a (taskName, storyKey) combination has been completed\n122\t * enough times to cover the current iteration in a loop block.\n123\t *\n124\t * Loop tasks execute the same (taskName, storyKey) pair each iteration,\n125\t * recording a new checkpoint each time. To determine if a task is done\n126\t * for the current iteration, we count how many matching checkpoints exist\n127\t * and compare to the current iteration number.\n128\t */\n129\texport function isLoopTaskCompleted(\n130\t  state: WorkflowState,\n131\t  taskName: string,\n132\t  storyKey: string,\n133\t  iteration: number,\n134\t): boolean {\n135\t  const count = state.tasks_completed.filter(\n136\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey && !cp.error,\n137\t  ).length;\n138\t  return count >= iteration;\n139\t}\n140\t\n141\t// --- Work Item Loading ---\n142\t\n143\t/**\n144\t * Load work items from sprint-status.yaml and optionally issues.yaml.\n145\t *\n146\t * Stories are extracted from the `development_status` section of sprint-status.yaml.\n147\t * Issues are extracted from the `issues` array of issues.yaml.\n148\t *\n149\t * Only items with status `backlog` or `ready-for-dev` are included.\n150\t * Epic keys (`epic-*`) and retrospective keys (`*-retrospective`) are excluded.\n151\t *\n152\t * If issues.yaml does not exist, returns only stories (no error).\n153\t */\n154\texport function loadWorkItems(sprintStatusPath: string, issuesPath?: string): WorkItem[] {\n155\t  const items: WorkItem[] = [];\n156\t\n157\t  // --- Load stories from sprint-status.yaml ---\n158\t  if (existsSync(sprintStatusPath)) {\n159\t    let raw: string;\n160\t    try {\n161\t      raw = readFileSync(sprintStatusPath, 'utf-8');\n162\t    } catch { // IGNORE: unreadable file — warn and return empty\n163\t      warn(`workflow-engine: could not read sprint-status.yaml at ${sprintStatusPath}`);\n164\t      return items;\n165\t    }\n166\t\n167\t    let parsed: unknown;\n168\t    try {\n169\t      parsed = parse(raw);\n170\t    } catch { // IGNORE: malformed YAML — warn and return empty\n171\t      warn(`workflow-engine: invalid YAML in sprint-status.yaml at ${sprintStatusPath}`);\n172\t      return items;\n173\t    }\n174\t\n175\t    if (parsed && typeof parsed === 'object') {\n176\t      const data = parsed as Record<string, unknown>;\n177\t      const devStatus = data.development_status as Record<string, unknown> | undefined;\n178\t\n179\t      if (devStatus && typeof devStatus === 'object') {\n180\t        for (const [key, status] of Object.entries(devStatus)) {\n181\t          // Skip epic keys and retrospective keys\n182\t          if (key.startsWith('epic-')) continue;\n183\t          if (key.endsWith('-retrospective')) continue;\n184\t\n185\t          // Only include backlog or ready-for-dev\n186\t          if (status === 'backlog' || status === 'ready-for-dev') {\n187\t            items.push({ key, source: 'sprint' });\n188\t          }\n189\t        }\n190\t      }\n191\t    }\n192\t  }\n193\t\n194\t  // --- Load issues from issues.yaml ---\n195\t  if (issuesPath && existsSync(issuesPath)) {\n196\t    let raw: string;\n197\t    try {\n198\t      raw = readFileSync(issuesPath, 'utf-8');\n199\t    } catch { // IGNORE: unreadable issues file — warn and return what we have\n200\t      warn(`workflow-engine: could not read issues.yaml at ${issuesPath}`);\n201\t      return items;\n202\t    }\n203\t\n204\t    let parsed: unknown;\n205\t    try {\n206\t      parsed = parse(raw);\n207\t    } catch { // IGNORE: malformed issues YAML — warn and return what we have\n208\t      warn(`workflow-engine: invalid YAML in issues.yaml at ${issuesPath}`);\n209\t      return items;\n210\t    }\n211\t\n212\t    if (parsed && typeof parsed === 'object') {\n213\t      const data = parsed as Record<string, unknown>;\n214\t      const issuesList = data.issues as Array<Record<string, unknown>> | undefined;\n215\t\n216\t      if (Array.isArray(issuesList)) {\n217\t        for (const issue of issuesList) {\n218\t          if (issue && typeof issue === 'object') {\n219\t            const status = issue.status as string | undefined;\n220\t            if (status === 'backlog' || status === 'ready-for-dev') {\n221\t              items.push({\n222\t                key: issue.id as string,\n223\t                title: issue.title as string | undefined,\n224\t                source: 'issues',\n225\t              });\n226\t            }\n227\t          }\n228\t        }\n229\t      }\n230\t    }\n231\t  }\n232\t\n233\t  return items;\n234\t}\n235\t\n236\t// --- Single Task Dispatch ---\n237\t\n238\t/**\n239\t * Dispatch a single task for a specific work item (or per-run sentinel).\n240\t *\n241\t * Handles: trace ID generation, session resolution, source isolation,\n242\t * agent dispatch, state checkpointing, and cleanup.\n243\t *\n244\t * Returns the updated workflow state after recording the dispatch.\n245\t */\n246\texport async function dispatchTask(\n247\t  task: ResolvedTask,\n248\t  taskName: string,\n249\t  storyKey: string,\n250\t  definition: SubagentDefinition,\n251\t  state: WorkflowState,\n252\t  config: EngineConfig,\n253\t  customPrompt?: string,\n254\t  previousOutputContract?: OutputContract,\n255\t): Promise<WorkflowState> {\n256\t  const { updatedState } = await dispatchTaskWithResult(\n257\t    task, taskName, storyKey, definition, state, config, customPrompt, previousOutputContract,\n258\t  );\n259\t  return updatedState;\n260\t}\n261\t\n262\t/** Tool names that indicate file write/edit operations across different drivers. */\n263\tconst FILE_WRITE_TOOL_NAMES = new Set([\n264\t  'Write', 'Edit', 'write_to_file', 'edit_file',\n265\t  'write', 'edit', 'WriteFile', 'EditFile',\n266\t]);\n267\t\n268\t// --- Flow Step Type Guard ---\n269\t\n270\tfunction isLoopBlock(step: FlowStep): step is LoopBlock {\n271\t  return typeof step === 'object' && step !== null && 'loop' in step;\n272\t}\n273\t\n274\t// --- Core Dispatch (shared by dispatchTask and loop block execution) ---\n275\t\n276\t/**\n277\t * Dispatch a task and return both the updated state and the raw dispatch output.\n278\t * This is the single implementation of task dispatch logic. Both `dispatchTask()`\n279\t * and loop block execution delegate here.\n280\t */\n281\tasync function dispatchTaskWithResult(\n282\t  task: ResolvedTask,\n283\t  taskName: string,\n284\t  storyKey: string,\n285\t  definition: SubagentDefinition,\n286\t  state: WorkflowState,\n287\t  config: EngineConfig,\n288\t  customPrompt?: string,\n289\t  previousOutputContract?: OutputContract,\n290\t): Promise<{ updatedState: WorkflowState; output: string; contract: OutputContract | null }> {\n291\t  const projectDir = config.projectDir ?? process.cwd();\n292\t\n293\t  // 1. Generate trace ID\n294\t  const traceId = generateTraceId(config.runId, state.iteration, taskName);\n295\t\n296\t  // 2. Format trace prompt — injected into driver via DispatchOpts.appendSystemPrompt\n297\t  const tracePrompt = formatTracePrompt(traceId);\n298\t\n299\t  // 3. Resolve session ID"}]},"parent_tool_use_id":"toolu_01E368mBox6AGS9E4aPFSS48","session_id":"8a461711-53e2-475a-88dd-c7013f6080c5","uuid":"b3864434-c0c1-46e7-af16-e728f47abcfd","timestamp":"2026-04-03T17:13:13.545Z"}
{"type":"system","subtype":"task_progress","task_id":"a01847a97803bab00","tool_use_id":"toolu_01E368mBox6AGS9E4aPFSS48","description":"Reading src/lib/workflow-engine.ts","usage":{"total_tokens":29866,"tool_uses":12,"duration_ms":27958},"last_tool_name":"Read","uuid":"8e6f18ad-5276-46b5-b840-aaf117f147e3","session_id":"8a461711-53e2-475a-88dd-c7013f6080c5"}
