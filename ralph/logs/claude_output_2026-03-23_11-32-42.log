{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011gNVphnmsBpfH8HBVKTk6j","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n     2→import { mkdtempSync, rmSync, writeFileSync, readFileSync, existsSync, mkdirSync } from 'node:fs';\n     3→import { tmpdir } from 'node:os';\n     4→import { join } from 'node:path';\n     5→\n     6→vi.mock('node:child_process', () => ({\n     7→  execFileSync: vi.fn(),\n     8→}));\n     9→\n    10→import { execFileSync } from 'node:child_process';\n    11→import {\n    12→  installNodeOtlp,\n    13→  patchNodeStartScript,\n    14→  installPythonOtlp,\n    15→  configureOtlpEnvVars,\n    16→  ensureServiceNameEnvVar,\n    17→  instrumentProject,\n    18→  configureCli,\n    19→  configureWeb,\n    20→  configureAgent,\n    21→  WEB_OTLP_PACKAGES,\n    22→  AGENT_OTLP_PACKAGES_NODE,\n    23→  AGENT_OTLP_PACKAGES_PYTHON,\n    24→} from '../otlp.js';\n    25→import { writeState, getDefaultState, readState } from '../state.js';\n    26→\n    27→const mockExecFileSync = vi.mocked(execFileSync);\n    28→\n    29→let testDir: string;\n    30→\n    31→beforeEach(() => {\n    32→  vi.restoreAllMocks();\n    33→  vi.spyOn(console, 'log').mockImplementation(() => {});\n    34→  testDir = mkdtempSync(join(tmpdir(), 'ch-otlp-test-'));\n    35→});\n    36→\n    37→afterEach(() => {\n    38→  rmSync(testDir, { recursive: true, force: true });\n    39→});\n    40→\n    41→function initState(stack: string | null): void {\n    42→  const state = getDefaultState(stack);\n    43→  state.initialized = true;\n    44→  writeState(state, testDir);\n    45→}\n    46→\n    47→function initStateWithOtlp(stack: string | null): void {\n    48→  const state = getDefaultState(stack);\n    49→  state.initialized = true;\n    50→  state.otlp = {\n    51→    enabled: true,\n    52→    endpoint: 'http://localhost:4318',\n    53→    service_name: 'test-project',\n    54→    mode: 'local-shared',\n    55→  };\n    56→  writeState(state, testDir);\n    57→}\n    58→\n    59→describe('installNodeOtlp', () => {\n    60→  it('installs OTLP packages via npm install', () => {\n    61→    mockExecFileSync.mockReturnValue(Buffer.from(''));\n    62→    const result = installNodeOtlp(testDir);\n    63→    expect(result.status).toBe('configured');\n    64→    expect(result.packages_installed).toBe(true);\n    65→    expect(mockExecFileSync).toHaveBeenCalledWith(\n    66→      'npm',\n    67→      expect.arrayContaining(['install', '@opentelemetry/auto-instrumentations-node']),\n    68→      expect.objectContaining({ cwd: testDir }),\n    69→    );\n    70→  });\n    71→\n    72→  it('returns failed when npm install fails', () => {\n    73→    mockExecFileSync.mockImplementation(() => {\n    74→      throw new Error('npm install failed');\n    75→    });\n    76→    const result = installNodeOtlp(testDir);\n    77→    expect(result.status).toBe('failed');\n    78→    expect(result.packages_installed).toBe(false);\n    79→    expect(result.error).toContain('Failed to install Node.js OTLP packages');\n    80→  });\n    81→\n    82→  it('truncates long error messages from npm install failures', () => {\n    83→    const longStderr = 'E'.repeat(500);\n    84→    mockExecFileSync.mockImplementation(() => {\n    85→      throw new Error(longStderr);\n    86→    });\n    87→    const result = installNodeOtlp(testDir);\n    88→    expect(result.error).toBeDefined();\n    89→    expect(result.error!.length).toBeLessThan(500);\n    90→    expect(result.error).toContain('(truncated)');\n    91→  });\n    92→\n    93→  it('includes all four OTLP packages in install command', () => {\n    94→    mockExecFileSync.mockReturnValue(Buffer.from(''));\n    95→    installNodeOtlp(testDir);\n    96→    const args = mockExecFileSync.mock.calls[0][1] as string[];\n    97→    expect(args).toContain('@opentelemetry/auto-instrumentations-node');\n    98→    expect(args).toContain('@opentelemetry/sdk-node');\n    99→    expect(args).toContain('@opentelemetry/exporter-trace-otlp-http');\n   100→    expect(args).toContain('@opentelemetry/exporter-metrics-otlp-http');\n   101→  });\n   102→});\n   103→\n   104→describe('patchNodeStartScript', () => {\n   105→  it('patches start script with --require flag', () => {\n   106→    writeFileSync(\n   107→      join(testDir, 'package.json'),\n   108→      JSON.stringify({\n   109→        name: 'test',\n   110→        scripts: { start: 'node dist/server.js' },\n   111→      }),\n   112→    );\n   113→\n   114→    const patched = patchNodeStartScript(testDir);\n   115→    expect(patched).toBe(true);\n   116→\n   117→    const pkg = JSON.parse(readFileSync(join(testDir, 'package.json'), 'utf-8'));\n   118→    expect(pkg.scripts['start:instrumented']).toContain('--require @opentelemetry/auto-instrumentations-node/register');\n   119→    expect(pkg.scripts['start:instrumented']).toContain('node dist/server.js');\n   120→    // Original start script is preserved\n   121→    expect(pkg.scripts.start).toBe('node dist/server.js');\n   122→  });\n   123→\n   124→  it('patches dev script when no start script exists', () => {\n   125→    writeFileSync(\n   126→      join(testDir, 'package.json'),\n   127→      JSON.stringify({\n   128→        name: 'test',\n   129→        scripts: { dev: 'ts-node src/index.ts' },\n   130→      }),\n   131→    );\n   132→\n   133→    const patched = patchNodeStartScript(testDir);\n   134→    expect(patched).toBe(true);\n   135→\n   136→    const pkg = JSON.parse(readFileSync(join(testDir, 'package.json'), 'utf-8'));\n   137→    expect(pkg.scripts['dev:instrumented']).toContain('--require');\n   138→  });\n   139→\n   140→  it('returns false when already patched (idempotent)', () => {\n   141→    // Simulate a previously patched package.json — the instrumented key already exists\n   142→    writeFileSync(\n   143→      join(testDir, 'package.json'),\n   144→      JSON.stringify({\n   145→        name: 'test',\n   146→        scripts: {\n   147→          start: 'node dist/server.js',\n   148→          'start:instrumented': \"NODE_OPTIONS='--require @opentelemetry/auto-instrumentations-node/register' node dist/server.js\",\n   149→        },\n   150→      }),\n   151→    );\n   152→\n   153→    const patched = patchNodeStartScript(testDir);\n   154→    expect(patched).toBe(false);\n   155→  });\n   156→\n   157→  it('returns false when no scripts section', () => {\n   158→    writeFileSync(join(testDir, 'package.json'), JSON.stringify({ name: 'test' }));\n   159→    const patched = patchNodeStartScript(testDir);\n   160→    expect(patched).toBe(false);\n   161→  });\n   162→\n   163→  it('returns false when no start or dev script', () => {\n   164→    writeFileSync(\n   165→      join(testDir, 'package.json'),\n   166→      JSON.stringify({ name: 'test', scripts: { build: 'tsc' } }),\n   167→    );\n   168→    const patched = patchNodeStartScript(testDir);\n   169→    expect(patched).toBe(false);\n   170→  });\n   171→\n   172→  it('returns false when no package.json', () => {\n   173→    const patched = patchNodeStartScript(testDir);\n   174→    expect(patched).toBe(false);\n   175→  });\n   176→\n   177→  it('returns false when package.json is malformed JSON', () => {\n   178→    writeFileSync(join(testDir, 'package.json'), '{ invalid json !!!');\n   179→    const patched = patchNodeStartScript(testDir);\n   180→    expect(patched).toBe(false);\n   181→  });\n   182→});\n   183→\n   184→describe('installPythonOtlp', () => {\n   185→  it('installs via pip when available', () => {\n   186→    mockExecFileSync.mockReturnValue(Buffer.from(''));\n   187→    const result = installPythonOtlp(testDir);\n   188→    expect(result.status).toBe('configured');\n   189→    expect(result.packages_installed).toBe(true);\n   190→  });\n   191→\n   192→  it('falls back to pipx when pip fails', () => {\n   193→    mockExecFileSync.mockImplementation((cmd) => {\n   194→      const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   195→      if (cmdStr === 'pip') throw new Error('pip not found');\n   196→      // pipx calls succeed (one for each package)\n   197→      return Buffer.from('');\n   198→    });\n   199→\n   200→    const result = installPythonOtlp(testDir);\n   201→    expect(result.status).toBe('configured');\n   202→  });\n   203→\n   204→  it('returns failed when all install methods fail', () => {\n   205→    mockExecFileSync.mockImplementation(() => {\n   206→      throw new Error('command failed');\n   207→    });\n   208→\n   209→    const result = installPythonOtlp(testDir);\n   210→    expect(result.status).toBe('failed');\n   211→    expect(result.packages_installed).toBe(false);\n   212→    expect(result.error).toContain('Failed to install Python OTLP packages');\n   213→  });\n   214→});\n   215→\n   216→describe('configureOtlpEnvVars', () => {\n   217→  it('writes OTLP config for Node.js to state', () => {\n   218→    initState('nodejs');\n   219→\n   220→    configureOtlpEnvVars(testDir, 'nodejs');\n   221→\n   222→    const state = readState(testDir);\n   223→    expect(state.otlp).toBeDefined();\n   224→    expect(state.otlp!.enabled).toBe(true);\n   225→    expect(state.otlp!.endpoint).toBe('http://localhost:4318');\n   226→    expect(state.otlp!.service_name).toBeTruthy();\n   227→    expect(state.otlp!.node_require).toContain('--require');\n   228→  });\n   229→\n   230→  it('writes OTLP config for Python to state', () => {\n   231→    initState('python');\n   232→\n   233→    configureOtlpEnvVars(testDir, 'python');\n   234→\n   235→    const state = readState(testDir);\n   236→    expect(state.otlp).toBeDefined();\n   237→    expect(state.otlp!.enabled).toBe(true);\n   238→    expect(state.otlp!.python_wrapper).toBe('opentelemetry-instrument');\n   239→    expect(state.otlp!.node_require).toBeUndefined();\n   240→  });\n   241→\n   242→  it('writes OTLP config for Rust with rust_env_hint', () => {\n   243→    initState('rust');\n   244→\n   245→    configureOtlpEnvVars(testDir, 'rust');\n   246→\n   247→    const state = readState(testDir);\n   248→    expect(state.otlp).toBeDefined();\n   249→    expect(state.otlp!.enabled).toBe(true);\n   250→    expect(state.otlp!.rust_env_hint).toBe('OTEL_EXPORTER_OTLP_ENDPOINT');\n   251→    expect(state.otlp!.node_require).toBeUndefined();\n   252→    expect(state.otlp!.python_wrapper).toBeUndefined();\n   253→  });\n   254→\n   255→  it('writes OTLP config for unknown stack without stack-specific fields', () => {\n   256→    initState(null);\n   257→\n   258→    configureOtlpEnvVars(testDir, null);\n   259→\n   260→    const state = readState(testDir);\n   261→    expect(state.otlp).toBeDefined();\n   262→    expect(state.otlp!.enabled).toBe(true);\n   263→    expect(state.otlp!.node_require).toBeUndefined();\n   264→    expect(state.otlp!.python_wrapper).toBeUndefined();\n   265→  });\n   266→\n   267→  it('sets resource_attributes in state', () => {\n   268→    initState('nodejs');\n   269→\n   270→    configureOtlpEnvVars(testDir, 'nodejs');\n   271→\n   272→    const state = readState(testDir);\n   273→    expect(state.otlp!.resource_attributes).toBe('service.instance.id=$(hostname)-$$');\n   274→  });\n   275→\n   276→  it('does not set cli_env_vars (cli config is handled by configureCli)', () => {\n   277→    initState('nodejs');\n   278→\n   279→    configureOtlpEnvVars(testDir, 'nodejs', { appType: 'cli' });\n   280→\n   281→    const state = readState(testDir);\n   282→    // CLI env vars are set by configureCli(), not configureOtlpEnvVars()\n   283→    expect(state.otlp!.cli_env_vars).toBeUndefined();\n   284→  });\n   285→});\n   286→\n   287→describe('configureCli', () => {\n   288→  it('sets cli_env_vars with fast flush settings', () => {\n   289→    initStateWithOtlp('nodejs');\n   290→\n   291→    configureCli(testDir);\n   292→\n   293→    const state = readState(testDir);\n   294→    expect(state.otlp!.cli_env_vars).toEqual({\n   295→      OTEL_BSP_SCHEDULE_DELAY: '100',\n   296→      OTEL_TRACES_SAMPLER: 'always_on',\n   297→      OTEL_BLRP_SCHEDULE_DELAY: '100',\n   298→    });\n   299→  });\n   300→\n   301→  it('does nothing when otlp is not configured', () => {\n   302→    initState('nodejs');\n   303→\n   304→    // No otlp in state — should not throw\n   305→    configureCli(testDir);\n   306→\n   307→    const state = readState(testDir);\n   308→    expect(state.otlp).toBeUndefined();\n   309→  });\n   310→});\n   311→\n   312→describe('configureWeb', () => {\n   313→  it('installs web OTLP packages for Node.js', () => {\n   314→    initStateWithOtlp('nodejs');\n   315→    mockExecFileSync.mockReturnValue(Buffer.from(''));\n   316→\n   317→    configureWeb(testDir, 'nodejs');\n   318→\n   319→    expect(mockExecFileSync).toHaveBeenCalledWith(\n   320→      'npm',\n   321→      expect.arrayContaining(['install', ...WEB_OTLP_PACKAGES]),\n   322→      expect.objectContaining({ cwd: testDir }),\n   323→    );\n   324→  });\n   325→\n   326→  it('creates otel-web-init.js snippet with endpoint from state', () => {\n   327→    initStateWithOtlp('nodejs');\n   328→    mockExecFileSync.mockReturnValue(Buffer.from(''));\n   329→\n   330→    configureWeb(testDir, 'nodejs');\n   331→\n   332→    expect(existsSync(join(testDir, 'otel-web-init.js'))).toBe(true);\n   333→    const content = readFileSync(join(testDir, 'otel-web-init.js'), 'utf-8');\n   334→    expect(content).toContain('WebTracerProvider');\n   335→    expect(content).toContain('FetchInstrumentation');\n   336→    expect(content).toContain('http://localhost:4318/v1/traces');\n   337→  });\n   338→\n   339→  it('uses custom endpoint from state in web snippet', () => {\n   340→    const state = getDefaultState('nodejs');\n   341→    state.initialized = true;\n   342→    state.otlp = {\n   343→      enabled: true,\n   344→      endpoint: 'https://otel.company.com:4318',\n   345→      service_n