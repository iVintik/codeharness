{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019ppfeXx8JaYbzU4LaRAvxm","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { resolve, join } from 'node:path';\n3\timport os from 'node:os';\n4\timport { parse } from 'yaml';\n5\timport { validateAgentSchema } from './schema-validate.js';\n6\t\n7\t// --- Interfaces ---\n8\t\n9\t/**\n10\t * Agent config shape matching agent.schema.json, plus optional prompt_patches\n11\t * accumulated from patch files.\n12\t */\n13\texport interface ResolvedAgent {\n14\t  name: string;\n15\t  role: {\n16\t    title: string;\n17\t    purpose: string;\n18\t  };\n19\t  persona: {\n20\t    identity: string;\n21\t    communication_style: string;\n22\t    principles: string[];\n23\t  };\n24\t  personality?: {\n25\t    traits: Record<string, number>;\n26\t  };\n27\t  disallowedTools?: string[];\n28\t  prompt_patches?: {\n29\t    append?: string;\n30\t  };\n31\t}\n32\t\n33\t/**\n34\t * Compiled subagent definition ready for Agent SDK dispatch.\n35\t */\n36\texport interface SubagentDefinition {\n37\t  name: string;\n38\t  model: string;\n39\t  instructions: string;\n40\t  disallowedTools: string[];\n41\t  bare: true;\n42\t}\n43\t\n44\t/**\n45\t * Patch file structure: extends identifies base, overrides deep-merged,\n46\t * prompt_patches preserved separately.\n47\t */\n48\texport interface AgentPatch {\n49\t  extends?: string;\n50\t  overrides?: Record<string, unknown>;\n51\t  prompt_patches?: {\n52\t    append?: string;\n53\t  };\n54\t}\n55\t\n56\t// --- Error Class ---\n57\t\n58\texport class AgentResolveError extends Error {\n59\t  public readonly filePath: string;\n60\t  public readonly errors: Array<{ path: string; message: string }>;\n61\t\n62\t  constructor(\n63\t    message: string,\n64\t    filePath: string,\n65\t    errors?: Array<{ path: string; message: string }>,\n66\t  ) {\n67\t    super(message);\n68\t    this.name = 'AgentResolveError';\n69\t    this.filePath = filePath;\n70\t    this.errors = errors ?? [];\n71\t  }\n72\t}\n73\t\n74\t// --- Constants ---\n75\t\n76\tconst TEMPLATES_DIR = resolve(__dirname, '../../templates/agents');\n77\tconst DEFAULT_MODEL = 'claude-sonnet-4-20250514';\n78\t\n79\t// --- Input Validation ---\n80\t\n81\tconst SAFE_NAME_RE = /^[a-zA-Z0-9_-]+$/;\n82\t\n83\t/**\n84\t * Validate agent name to prevent path traversal and unexpected characters.\n85\t */\n86\tfunction validateName(name: string): void {\n87\t  if (!name || !SAFE_NAME_RE.test(name)) {\n88\t    throw new AgentResolveError(\n89\t      `Invalid agent name: \"${name}\" ŌĆö must match ${SAFE_NAME_RE}`,\n90\t      '',\n91\t      [{ path: '', message: `Invalid agent name: ${name}` }],\n92\t    );\n93\t  }\n94\t}\n95\t\n96\t// --- Deep Merge ---\n97\t\n98\t/**\n99\t * Deep merge strategy: objects merge recursively, arrays replace, scalars replace.\n100\t */\n101\tfunction deepMerge(base: Record<string, unknown>, patch: Record<string, unknown>): Record<string, unknown> {\n102\t  const result: Record<string, unknown> = { ...base };\n103\t\n104\t  for (const key of Object.keys(patch)) {\n105\t    const baseVal = base[key];\n106\t    const patchVal = patch[key];\n107\t\n108\t    if (\n109\t      patchVal !== null &&\n110\t      typeof patchVal === 'object' &&\n111\t      !Array.isArray(patchVal) &&\n112\t      baseVal !== null &&\n113\t      typeof baseVal === 'object' &&\n114\t      !Array.isArray(baseVal)\n115\t    ) {\n116\t      result[key] = deepMerge(\n117\t        baseVal as Record<string, unknown>,\n118\t        patchVal as Record<string, unknown>,\n119\t      );\n120\t    } else {\n121\t      result[key] = patchVal;\n122\t    }\n123\t  }\n124\t\n125\t  return result;\n126\t}\n127\t\n128\t// --- Embedded Agent Loading ---\n129\t\n130\t/**\n131\t * Load an embedded agent template from templates/agents/{name}.yaml.\n132\t * Throws AgentResolveError if not found or invalid.\n133\t */\n134\texport function loadEmbeddedAgent(name: string): ResolvedAgent {\n135\t  validateName(name);\n136\t  const filePath = join(TEMPLATES_DIR, `${name}.yaml`);\n137\t\n138\t  let raw: string;\n139\t  try {\n140\t    raw = readFileSync(filePath, 'utf-8');\n141\t  } catch { // IGNORE: rethrow as AgentResolveError with context\n142\t    throw new AgentResolveError(\n143\t      `Embedded agent not found: ${name}`,\n144\t      filePath,\n145\t      [{ path: filePath, message: `File not found: ${filePath}` }],\n146\t    );\n147\t  }\n148\t\n149\t  let parsed: unknown;\n150\t  try {\n151\t    parsed = parse(raw);\n152\t  } catch (err: unknown) {\n153\t    const msg = err instanceof Error ? err.message : String(err);\n154\t    throw new AgentResolveError(\n155\t      `Invalid YAML in embedded agent ${name}: ${msg}`,\n156\t      filePath,\n157\t      [{ path: filePath, message: msg }],\n158\t    );\n159\t  }\n160\t\n161\t  const result = validateAgentSchema(parsed);\n162\t  if (!result.valid) {\n163\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n164\t    throw new AgentResolveError(\n165\t      `Schema validation failed for embedded agent ${name}: ${details}`,\n166\t      filePath,\n167\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n168\t    );\n169\t  }\n170\t\n171\t  return parsed as ResolvedAgent;\n172\t}\n173\t\n174\t// --- Patch Loading ---\n175\t\n176\t/**\n177\t * Load a patch file. Returns null if the file does not exist (silent skip).\n178\t * Throws AgentResolveError on malformed YAML.\n179\t */\n180\texport function loadPatch(filePath: string): AgentPatch | null {\n181\t  if (!existsSync(filePath)) {\n182\t    return null;\n183\t  }\n184\t\n185\t  let raw: string;\n186\t  try {\n187\t    raw = readFileSync(filePath, 'utf-8');\n188\t  } catch { // IGNORE: file unreadable ŌĆö treat as missing patch\n189\t    return null;\n190\t  }\n191\t\n192\t  let parsed: unknown;\n193\t  try {\n194\t    parsed = parse(raw);\n195\t  } catch (err: unknown) {\n196\t    const msg = err instanceof Error ? err.message : String(err);\n197\t    throw new AgentResolveError(\n198\t      `Invalid YAML in patch file: ${msg}`,\n199\t      filePath,\n200\t      [{ path: filePath, message: msg }],\n201\t    );\n202\t  }\n203\t\n204\t  if (parsed === null || typeof parsed !== 'object') {\n205\t    throw new AgentResolveError(\n206\t      `Patch file is not a valid object`,\n207\t      filePath,\n208\t      [{ path: filePath, message: 'Patch must be a YAML object' }],\n209\t    );\n210\t  }\n211\t\n212\t  return parsed as AgentPatch;\n213\t}\n214\t\n215\t// --- Patch Merging ---\n216\t\n217\t/**\n218\t * Merge a patch onto a base config. Deep-merges overrides, preserves prompt_patches separately.\n219\t */\n220\texport function mergePatch(\n221\t  base: Record<string, unknown>,\n222\t  patch: AgentPatch,\n223\t): Record<string, unknown> {\n224\t  let result = { ...base };\n225\t\n226\t  if (patch.overrides) {\n227\t    result = deepMerge(result, patch.overrides);\n228\t  }\n229\t\n230\t  if (patch.prompt_patches) {\n231\t    const existing = result.prompt_patches as { append?: string } | undefined;\n232\t    const existingAppend = existing?.append ?? '';\n233\t    const newAppend = patch.prompt_patches.append ?? '';\n234\t\n235\t    if (newAppend) {\n236\t      result.prompt_patches = {\n237\t        append: existingAppend ? `${existingAppend}\\n${newAppend}` : newAppend,\n238\t      };\n239\t    }\n240\t  }\n241\t\n242\t  return result;\n243\t}\n244\t\n245\t// --- Main Resolution ---\n246\t\n247\t/**\n248\t * Resolve an agent through the embedded -> user -> project patch chain.\n249\t * For custom agents (no embedded match, found at project/user level without extends), loads directly.\n250\t */\n251\texport function resolveAgent(name: string, options?: { cwd?: string }): ResolvedAgent {\n252\t  validateName(name);\n253\t  const cwd = options?.cwd ?? process.cwd();\n254\t  const userPatchPath = join(os.homedir(), '.codeharness', 'agents', `${name}.patch.yaml`);\n255\t  const projectPatchPath = join(cwd, '.codeharness', 'agents', `${name}.patch.yaml`);\n256\t\n257\t  // Check for custom agent (project-level full config, no extends)\n258\t  const projectCustomPath = join(cwd, '.codeharness', 'agents', `${name}.yaml`);\n259\t  const userCustomPath = join(os.homedir(), '.codeharness', 'agents', `${name}.yaml`);\n260\t\n261\t  // Try custom agent at project level first, then user level\n262\t  for (const customPath of [projectCustomPath, userCustomPath]) {\n263\t    if (existsSync(customPath)) {\n264\t      const patch = loadPatch(customPath);\n265\t      if (patch && !patch.extends) {\n266\t        // This is a full custom agent, not a patch ŌĆö load and validate directly\n267\t        const parsed = patch as unknown as Record<string, unknown>;\n268\t        // Strip prompt_patches before schema validation (not in schema, same as patch path)\n269\t        const { prompt_patches: customPP, ...customForValidation } = parsed as Record<string, unknown> & { prompt_patches?: unknown };\n270\t        const result = validateAgentSchema(customForValidation);\n271\t        if (!result.valid) {\n272\t          const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n273\t          throw new AgentResolveError(\n274\t            `Schema validation failed for custom agent ${name}: ${details}`,\n275\t            customPath,\n276\t            result.errors.map((e) => ({ path: e.path, message: e.message })),\n277\t          );\n278\t        }\n279\t        return (customPP ? { ...customForValidation, prompt_patches: customPP } : customForValidation) as unknown as ResolvedAgent;\n280\t      }\n281\t    }\n282\t  }\n283\t\n284\t  // Load embedded base\n285\t  const base = loadEmbeddedAgent(name);\n286\t  let merged: Record<string, unknown> = base as unknown as Record<string, unknown>;\n287\t\n288\t  // Apply user patch\n289\t  const userPatch = loadPatch(userPatchPath);\n290\t  if (userPatch) {\n291\t    merged = mergePatch(merged, userPatch);\n292\t  }\n293\t\n294\t  // Apply project patch\n295\t  const projectPatch = loadPatch(projectPatchPath);\n296\t  if (projectPatch) {\n297\t    merged = mergePatch(merged, projectPatch);\n298\t  }\n299\t\n300\t  // Validate merged result (strip prompt_patches for schema validation since it's not in schema)\n301\t  const { prompt_patches, ...forValidation } = merged as Record<string, unknown> & { prompt_patches?: unknown };\n302\t  const result = validateAgentSchema(forValidation);\n303\t  if (!result.valid) {\n304\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n305\t    const errorPath = projectPatch ? projectPatchPath : userPatch ? userPatchPath : 'merged';\n306\t    throw new AgentResolveError(\n307\t      `Schema validation failed after merging patches for ${name}: ${details}`,\n308\t      errorPath,\n309\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n310\t    );\n311\t  }\n312\t\n313\t  // Re-attach prompt_patches if present, return without mutating forValidation\n314\t  return (prompt_patches\n315\t    ? { ...forValidation, prompt_patches }\n316\t    : forValidation) as unknown as ResolvedAgent;\n317\t}\n318\t\n319\t// --- Subagent Compilation ---\n320\t\n321\t/**\n322\t * Compile a ResolvedAgent into a SubagentDefinition for Agent SDK dispatch.\n323\t */\n324\texport function compileSubagentDefinition(agent: ResolvedAgent): SubagentDefinition {\n325\t  const parts: string[] = [];\n326\t\n327\t  parts.push(`You are ${agent.persona.identity}`);\n328\t  parts.push(`Communication style: ${agent.persona.communication_style}`);\n329\t\n330\t  if (agent.persona.principles.length > 0) {\n331\t    const bullets = agent.persona.principles.map((p) => `- ${p}`).join('\\n');\n332\t    parts.push(`Principles:\\n${bullets}`);\n333\t  }\n334\t\n335\t  if (agent.prompt_patches?.append) {\n336\t    parts.push(agent.prompt_patches.append);\n337\t  }\n338\t\n339\t  return {\n340\t    name: agent.name,\n341\t    model: DEFAULT_MODEL,\n342\t    instructions: parts.join('\\n\\n'),\n343\t    disallowedTools: agent.disallowedTools ?? [],\n344\t    bare: true,\n345\t  };\n346\t}\n347\t"}]},"parent_tool_use_id":"toolu_01TfX7ZQpGDbV1a3EhZ1z5Ve","session_id":"605a3302-c654-40ea-969b-1ce171500852","uuid":"4b0bd7cd-d0ab-48bb-b8d8-e196e1e13d86","timestamp":"2026-04-02T19:16:05.951Z"}
