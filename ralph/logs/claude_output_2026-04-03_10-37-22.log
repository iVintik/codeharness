{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XrYVv8iDxttoHky4dEyuN6","type":"tool_result","content":"1\t/**\n2\t * Driver Factory & Registry.\n3\t *\n4\t * Module-singleton registry for AgentDriver instances.\n5\t * Drivers are registered explicitly via registerDriver() — no auto-discovery,\n6\t * no filesystem scanning, no dynamic imports.\n7\t *\n8\t * @see architecture-multi-framework.md — \"Register in factory.ts — never auto-discover\"\n9\t */\n10\t\n11\timport type { AgentDriver } from '../types.js';\n12\t\n13\tconst registry = new Map<string, AgentDriver>();\n14\t\n15\t/**\n16\t * Register an AgentDriver by its `name` property.\n17\t * Throws if a driver with the same name is already registered.\n18\t */\n19\texport function registerDriver(driver: AgentDriver): void {\n20\t  if (registry.has(driver.name)) {\n21\t    throw new Error(\n22\t      `Driver '${driver.name}' is already registered. Each driver name must be unique.`,\n23\t    );\n24\t  }\n25\t  registry.set(driver.name, driver);\n26\t}\n27\t\n28\t/**\n29\t * Retrieve a registered AgentDriver by name.\n30\t * Throws with a helpful message listing all registered drivers if not found.\n31\t */\n32\texport function getDriver(name: string): AgentDriver {\n33\t  const driver = registry.get(name);\n34\t  if (!driver) {\n35\t    const registered = [...registry.keys()];\n36\t    const list =\n37\t      registered.length > 0 ? registered.join(', ') : '(none)';\n38\t    throw new Error(\n39\t      `Driver '${name}' not found. Registered drivers: ${list}`,\n40\t    );\n41\t  }\n42\t  return driver;\n43\t}\n44\t\n45\t/**\n46\t * List all registered driver names.\n47\t * Returns a copy — mutating the returned array does not affect the registry.\n48\t */\n49\texport function listDrivers(): string[] {\n50\t  return [...registry.keys()];\n51\t}\n52\t\n53\t/**\n54\t * Clear all registered drivers. Exported for test isolation.\n55\t */\n56\texport function resetDrivers(): void {\n57\t  registry.clear();\n58\t}\n59\t"}]},"parent_tool_use_id":"toolu_017Urm7EPd5KhakJiz43kv21","session_id":"61d40628-eabe-45b5-b544-2f5989944a22","uuid":"81358739-6932-4962-96c4-04b4976fe334","timestamp":"2026-04-03T06:45:10.509Z"}
