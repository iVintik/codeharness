{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QpEoTaiC2j6nVyfE8hUCcA","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';\n     2→import {\n     3→  existsSync,\n     4→  readFileSync,\n     5→  writeFileSync,\n     6→  unlinkSync,\n     7→  mkdirSync,\n     8→  mkdtempSync,\n     9→  rmSync,\n    10→} from 'node:fs';\n    11→import { join } from 'node:path';\n    12→import { tmpdir } from 'node:os';\n    13→import { parse } from 'yaml';\n    14→import type { SprintState } from '../../../types/state.js';\n    15→\n    16→// Mock migration so tests are isolated from real project files\n    17→vi.mock('../migration.js', () => ({\n    18→  migrateFromOldFormat: vi.fn(() => ({\n    19→    success: false,\n    20→    error: 'No old format files found for migration',\n    21→  })),\n    22→  migrateV1ToV2: vi.fn((v1: Record<string, unknown>) => ({\n    23→    ...v1,\n    24→    version: 2,\n    25→    retries: {},\n    26→    flagged: [],\n    27→    epics: {},\n    28→    session: { active: false, startedAt: null, iteration: 0, elapsedSeconds: 0 },\n    29→    observability: { statementCoverage: null, branchCoverage: null, functionCoverage: null, lineCoverage: null },\n    30→  })),\n    31→}));\n    32→\n    33→// Import functions under test\n    34→const {\n    35→  generateSprintStatusYaml,\n    36→  getStoryStatusesFromState,\n    37→  writeStateAtomic,\n    38→  defaultState,\n    39→  sprintStatusYamlPath,\n    40→} = await import('../state.js');\n    41→\n    42→function mkStory(status: string): SprintState['stories'][string] {\n    43→  return {\n    44→    status: status as 'done',\n    45→    attempts: 0,\n    46→    lastAttempt: null,\n    47→    lastError: null,\n    48→    proofPath: null,\n    49→    acResults: null,\n    50→  };\n    51→}\n    52→\n    53→// ─── getStoryStatusesFromState ──────────────────────────────────────────────\n    54→\n    55→describe('getStoryStatusesFromState', () => {\n    56→  it('returns empty map for empty state', () => {\n    57→    const state = defaultState();\n    58→    const result = getStoryStatusesFromState(state);\n    59→    expect(result).toEqual({});\n    60→  });\n    61→\n    62→  it('returns flat key->status map from state stories', () => {\n    63→    const state: SprintState = {\n    64→      ...defaultState(),\n    65→      stories: {\n    66→        '1-1-first-story': mkStory('done'),\n    67→        '1-2-second-story': mkStory('in-progress'),\n    68→        '2-1-third-story': mkStory('backlog'),\n    69→      },\n    70→    };\n    71→    const result = getStoryStatusesFromState(state);\n    72→    expect(result).toEqual({\n    73→      '1-1-first-story': 'done',\n    74→      '1-2-second-story': 'in-progress',\n    75→      '2-1-third-story': 'backlog',\n    76→    });\n    77→  });\n    78→\n    79→  it('preserves all status types', () => {\n    80→    const state: SprintState = {\n    81→      ...defaultState(),\n    82→      stories: {\n    83→        '1-1-a': mkStory('done'),\n    84→        '1-2-b': mkStory('failed'),\n    85→        '1-3-c': mkStory('blocked'),\n    86→        '2-1-d': mkStory('verifying'),\n    87→        '2-2-e': mkStory('review'),\n    88→        '2-3-f': mkStory('ready'),\n    89→      },\n    90→    };\n    91→    const result = getStoryStatusesFromState(state);\n    92→    expect(result['1-1-a']).toBe('done');\n    93→    expect(result['1-2-b']).toBe('failed');\n    94→    expect(result['1-3-c']).toBe('blocked');\n    95→    expect(result['2-1-d']).toBe('verifying');\n    96→    expect(result['2-2-e']).toBe('review');\n    97→    expect(result['2-3-f']).toBe('ready');\n    98→  });\n    99→});\n   100→\n   101→// ─── generateSprintStatusYaml ───────────────────────────────────────────────\n   102→\n   103→describe('generateSprintStatusYaml', () => {\n   104→  it('produces valid YAML for empty state', () => {\n   105→    const state = defaultState();\n   106→    const yaml = generateSprintStatusYaml(state);\n   107→    expect(yaml).toContain('development_status:');\n   108→    // Should parse without error\n   109→    const parsed = parse(yaml);\n   110→    expect(parsed).toBeDefined();\n   111→  });\n   112→\n   113→  it('groups stories by epic and sorts by epic/story number', () => {\n   114→    const state: SprintState = {\n   115→      ...defaultState(),\n   116→      stories: {\n   117→        '2-1-beta': mkStory('backlog'),\n   118→        '1-2-second': mkStory('done'),\n   119→        '1-1-first': mkStory('done'),\n   120→        '2-2-gamma': mkStory('in-progress'),\n   121→      },\n   122→    };\n   123→    const yaml = generateSprintStatusYaml(state);\n   124→\n   125→    // Epic 1 should appear before Epic 2\n   126→    const epic1Pos = yaml.indexOf('# Epic 1');\n   127→    const epic2Pos = yaml.indexOf('# Epic 2');\n   128→    expect(epic1Pos).toBeLessThan(epic2Pos);\n   129→\n   130→    // Within Epic 1, story 1-1 should appear before 1-2\n   131→    const story11Pos = yaml.indexOf('1-1-first');\n   132→    const story12Pos = yaml.indexOf('1-2-second');\n   133→    expect(story11Pos).toBeLessThan(story12Pos);\n   134→  });\n   135→\n   136→  it('computes epic status as done when all stories done', () => {\n   137→    const state: SprintState = {\n   138→      ...defaultState(),\n   139→      stories: {\n   140→        '1-1-first': mkStory('done'),\n   141→        '1-2-second': mkStory('done'),\n   142→      },\n   143→    };\n   144→    const yaml = generateSprintStatusYaml(state);\n   145→    expect(yaml).toContain('epic-1: done');\n   146→  });\n   147→\n   148→  it('computes epic status as backlog when not all stories done', () => {\n   149→    const state: SprintState = {\n   150→      ...defaultState(),\n   151→      stories: {\n   152→        '1-1-first': mkStory('done'),\n   153→        '1-2-second': mkStory('in-progress'),\n   154→      },\n   155→    };\n   156→    const yaml = generateSprintStatusYaml(state);\n   157→    expect(yaml).toContain('epic-1: backlog');\n   158→  });\n   159→\n   160→  it('maps \"ready\" status to \"ready-for-dev\" in YAML', () => {\n   161→    const state: SprintState = {\n   162→      ...defaultState(),\n   163→      stories: {\n   164→        '3-1-some-story': mkStory('ready'),\n   165→      },\n   166→    };\n   167→    const yaml = generateSprintStatusYaml(state);\n   168→    expect(yaml).toContain('3-1-some-story: ready-for-dev');\n   169→  });\n   170→\n   171→  it('produces parseable YAML with correct development_status', () => {\n   172→    const state: SprintState = {\n   173→      ...defaultState(),\n   174→      stories: {\n   175→        '1-1-alpha': mkStory('done'),\n   176→        '2-1-beta': mkStory('backlog'),\n   177→      },\n   178→    };\n   179→    const yaml = generateSprintStatusYaml(state);\n   180→    const parsed = parse(yaml) as Record<string, unknown>;\n   181→    expect(parsed.development_status).toBeDefined();\n   182→\n   183→    const devStatus = parsed.development_status as Record<string, string>;\n   184→    expect(devStatus['1-1-alpha']).toBe('done');\n   185→    expect(devStatus['2-1-beta']).toBe('backlog');\n   186→    expect(devStatus['epic-1']).toBe('done');\n   187→    expect(devStatus['epic-2']).toBe('backlog');\n   188→  });\n   189→\n   190→  it('includes auto-generated header comment', () => {\n   191→    const state = defaultState();\n   192→    const yaml = generateSprintStatusYaml(state);\n   193→    expect(yaml).toContain('auto-generated from sprint-state.json');\n   194→    expect(yaml).toContain('do NOT edit manually');\n   195→  });\n   196→\n   197→  it('handles multiple epics with mixed statuses', () => {\n   198→    const state: SprintState = {\n   199→      ...defaultState(),\n   200→      stories: {\n   201→        '1-1-a': mkStory('done'),\n   202→        '1-2-b': mkStory('done'),\n   203→        '2-1-c': mkStory('done'),\n   204→        '2-2-d': mkStory('failed'),\n   205→        '3-1-e': mkStory('backlog'),\n   206→      },\n   207→    };\n   208→    const yaml = generateSprintStatusYaml(state);\n   209→    expect(yaml).toContain('epic-1: done');\n   210→    expect(yaml).toContain('epic-2: backlog'); // 2-2-d is failed, not done\n   211→    expect(yaml).toContain('epic-3: backlog');\n   212→  });\n   213→\n   214→  it('handles stories with non-standard keys gracefully (sorted last)', () => {\n   215→    const state: SprintState = {\n   216→      ...defaultState(),\n   217→      stories: {\n   218→        '1-1-normal': mkStory('done'),\n   219→        'no-match-key': mkStory('backlog'),\n   220→      },\n   221→    };\n   222→    // Should not throw\n   223→    const yaml = generateSprintStatusYaml(state);\n   224→    expect(yaml).toContain('1-1-normal: done');\n   225→    expect(yaml).toContain('no-match-key: backlog');\n   226→  });\n   227→\n   228→  it('always shows epic-TD as in-progress even when all TD stories are done', () => {\n   229→    const state: SprintState = {\n   230→      ...defaultState(),\n   231→      stories: {\n   232→        '1-1-normal': mkStory('done'),\n   233→        'TD-1-fix-catch-blocks': mkStory('done'),\n   234→        'TD-2-add-tests': mkStory('done'),\n   235→      },\n   236→    };\n   237→    const yaml = generateSprintStatusYaml(state);\n   238→    expect(yaml).toContain('epic-TD: in-progress');\n   239→    // Normal epic should still be done\n   240→    expect(yaml).toContain('epic-1: done');\n   241→  });\n   242→\n   243→  it('groups TD stories under Epic TD section', () => {\n   244→    const state: SprintState = {\n   245→      ...defaultState(),\n   246→      stories: {\n   247→        'TD-1-some-fix': mkStory('backlog'),\n   248→        '1-1-normal': mkStory('done'),\n   249→      },\n   250→    };\n   251→    const yaml = generateSprintStatusYaml(state);\n   252→    expect(yaml).toContain('# Epic TD');\n   253→    expect(yaml).toContain('TD-1-some-fix: backlog');\n   254→  });\n   255→\n   256→  it('handles state with epics field populated (ignored — epics derived from stories)', () => {\n   257→    const state: SprintState = {\n   258→      ...defaultState(),\n   259→      epics: {\n   260→        '1': { status: 'done', storiesTotal: 2, storiesDone: 2 },\n   261→      },\n   262→      stories: {\n   263→        '1-1-a': mkStory('done'),\n   264→        '1-2-b': mkStory('backlog'),\n   265→      },\n   266→    };\n   267→    const yaml = generateSprintStatusYaml(state);\n   268→    // Epic status should be derived from stories, not from epics field\n   269→    expect(yaml).toContain('epic-1: backlog');\n   270→  });\n   271→});\n   272→\n   273→// ─── writeStateAtomic regenerates YAML (filesystem-isolated) ─────────────────\n   274→\n   275→describe('writeStateAtomic regenerates sprint-status.yaml', () => {\n   276→  let testDir: string;\n   277→  let originalCwd: string;\n   278→\n   279→  beforeEach(() => {\n   280→    testDir = mkdtempSync(join(tmpdir(), 'ch-yaml-'));\n   281→    originalCwd = process.cwd();\n   282→    process.chdir(testDir);\n   283→  });\n   284→\n   285→  afterEach(() => {\n   286→    process.chdir(originalCwd);\n   287→    rmSync(testDir, { recursive: true, force: true });\n   288→  });\n   289→\n   290→  it('writes sprint-status.yaml when directory exists', () => {\n   291→    const yamlDir = join(testDir, '_bmad-output', 'implementation-artifacts');\n   292→    mkdirSync(yamlDir, { recursive: true });\n   293→\n   294→    const state: SprintState = {\n   295→      ...defaultState(),\n   296→      stories: {\n   297→        '1-1-test-story': mkStory('done'),\n   298→      },\n   299→    };\n   300→    const result = writeStateAtomic(state);\n   301→    expect(result.success).toBe(true);\n   302→\n   303→    // Verify sprint-status.yaml was written\n   304→    const yamlFile = join(yamlDir, 'sprint-status.yaml');\n   305→    expect(existsSync(yamlFile)).toBe(true);\n   306→    const yamlContent = readFileSync(yamlFile, 'utf-8');\n   307→    expect(yamlContent).toContain('1-1-test-story: done');\n   308→    expect(yamlContent).toContain('auto-generated');\n   309→  });\n   310→\n   311→  it('YAML updates on every state write', () => {\n   312→    const yamlDir = join(testDir, '_bmad-output', 'implementation-artifacts');\n   313→    mkdirSync(yamlDir, { recursive: true });\n   314→\n   315→    // First write\n   316→    const state1: SprintState = {\n   317→      ...defaultState(),\n   318→      stories: {\n   319→        '1-1-story': mkStory('backlog'),\n   320→      },\n   321→    };\n   322→    writeStateAtomic(state1);\n   323→    const yamlFile = join(yamlDir, 'sprint-status.yaml');\n   324→    const yaml1 = readFileSync(yamlFile, 'utf-8');\n   325→    expect(yaml1).toContain('1-1-story: backlog');\n   326→\n   327→    // Second write with updated status\n   328→    const state2: SprintState = {\n   329→      ...defaultState(),\n   330→      stories: {\n   331→        '1-1-story': mkStory('done'),\n   332→      },\n   333→    };\n   334→    writeStateAtomic(state2);\n   335→    const yaml2 = readFileSync(yamlFile, 'utf-8');\n   336→    expect(yaml2).toContain('1-1-story: done');\n   337→    expect(yaml2).not.toContain('1-1-story: backlog');\n   338→  });\n   339→\n   340→  it('skips YAML write when output directory does not exist', () => {\n   341→    // No _bmad-output dir created — should not throw\n   342→    const state: SprintState = {\n   343→      ...defaultState(),\n   344→      stories: {\n   345→        '1-1-test': mkStory('done'),\n   346→      },\n   347→    };\n   348→    const result = writeStateAtomic(state);\n   349→    expect(result.success).toBe(true);\n   350→\n   351→    // YAML file should not exist\n   352→    const yamlFile = join(testDir, '_bmad-output', 'implementation-artifacts', 'sprint-status.yaml');\n   353→    expect(existsSync(yamlFile)).toBe(false);\n   354→  });\n   355→\n   356→  it('YAML write failure does not fail the state write', () => {\n   357→    // Create directory as a file to force YAML write failure\n   358→    const yamlDir = join(testDir, '_bmad-output', 'implementation-artifacts');\n   359→    mkdirSync(join(testDir, '_bmad-output'), { recursive: true });\n   360→    // Create a file where the yaml file should go, making writeFileSync fail\n   361→    mkdirSync(yamlDir, { recursive: true });\n   362→    const yamlFile = join(yamlDir, 'sprint-status.yaml');\n   363→    mkdirSync(yamlFile); // directory instead of file — writeFileSync will fail\n   364→\n   365→    const state: SprintState = {\n   366→      ...defaultState(),\n   367→      stories: { '1-1-x': mkStory('done') },\n   368→    };\n   369→    const result = writeStateAtomic(state);\n   370→    // State write should succeed even though YAML write fails\n   371→    expect(result.success).toBe(true);\n   372→\n   373→    // Verify JSON state was written\n   374→    const stateFile = join(testDir, 'sprint-state.json');\n   375→    expect(existsSync(stateFile)).toBe(true);\n   376→  });\n   377→});\n   378→\n   379→// ─── sprintStatusYamlPath ───────────────────────────────────────────────────\n   380→\n   381→describe('sprintStatusYamlPath', () => {\n   382→  it('returns expected path', () => {\n   383→    const path = sprintStatusYamlPath();\n   384→    expect(path).toContain('_bmad-output');\n   385→    expect(path).toContain('implementation-artifacts');\n   386→    expect(path).toContain('sprint-status.yaml');\n   387→  });\n   388→});\n   389→"}]},"parent_tool_use_id":"toolu_01QdekhbhdCn1yMfA8HwX61q","session_id":"84a01a9c-e466-45b4-91ef-8201b3712d8d","uuid":"81dd32aa-8daa-4011-8805-6e02011c21c3","timestamp":"2026-03-24T21:57:00.064Z"}
