{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013AU7pqY5Y9A6rNTKrsXRbU","type":"tool_result","content":"     1→/**\n     2→ * Stale container cleanup for infra containers.\n     3→ *\n     4→ * Removes exited/dead containers matching codeharness-shared-* and\n     5→ * codeharness-collector-* patterns. Complements verify/env.ts which\n     6→ * handles codeharness-verify-* containers.\n     7→ *\n     8→ * Public functions return Result<T> and never throw.\n     9→ */\n    10→\n    11→import { execFileSync } from 'node:child_process';\n    12→import { isDockerAvailable } from '../../lib/docker/index.js';\n    13→import { ok, fail } from '../../types/result.js';\n    14→import type { Result } from '../../types/result.js';\n    15→import type { CleanupResult } from './types.js';\n    16→\n    17→/** Container name patterns to match for cleanup */\n    18→const STALE_PATTERNS = ['codeharness-shared-', 'codeharness-collector-'];\n    19→\n    20→/**\n    21→ * Remove stale codeharness infra containers (exited or dead).\n    22→ *\n    23→ * If Docker is not available, returns ok with 0 removed (AC#7).\n    24→ */\n    25→export function cleanupContainers(): Result<CleanupResult> {\n    26→  try {\n    27→    if (!isDockerAvailable()) {\n    28→      return ok({ containersRemoved: 0, names: [] });\n    29→    }\n    30→\n    31→    // List all containers (including stopped) matching our patterns\n    32→    const staleNames: string[] = [];\n    33→\n    34→    for (const pattern of STALE_PATTERNS) {\n    35→      try {\n    36→        const output = execFileSync(\n    37→          'docker',\n    38→          [\n    39→            'ps',\n    40→            '-a',\n    41→            '--filter', `name=${pattern}`,\n    42→            '--filter', 'status=exited',\n    43→            '--filter', 'status=dead',\n    44→            '--format', '{{.Names}}',\n    45→          ],\n    46→          { stdio: 'pipe', timeout: 10_000 },\n    47→        );\n    48→        const names = output\n    49→          .toString()\n    50→          .trim()\n    51→          .split('\\n')\n    52→          .filter(n => n.trim());\n    53→        staleNames.push(...names);\n    54→      } catch {\n    55→        // docker ps failed for this pattern — skip\n    56→      }\n    57→    }\n    58→\n    59→    if (staleNames.length === 0) {\n    60→      return ok({ containersRemoved: 0, names: [] });\n    61→    }\n    62→\n    63→    // Remove all stale containers\n    64→    const removed: string[] = [];\n    65→    for (const name of staleNames) {\n    66→      try {\n    67→        execFileSync('docker', ['rm', '-f', name], {\n    68→          stdio: 'pipe',\n    69→          timeout: 10_000,\n    70→        });\n    71→        removed.push(name);\n    72→      } catch {\n    73→        // Individual removal failed — continue with others\n    74→      }\n    75→    }\n    76→\n    77→    return ok({ containersRemoved: removed.length, names: removed });\n    78→    /* c8 ignore start -- defensive: inner catches handle all known paths */\n    79→  } catch (err) {\n    80→    const message = err instanceof Error ? err.message : String(err);\n    81→    return fail(`Container cleanup failed: ${message}`);\n    82→  }\n    83→  /* c8 ignore stop */\n    84→}\n    85→"}]},"parent_tool_use_id":"toolu_01NbbU2crBRehddb6AAVY9uR","session_id":"174e0897-5fbc-4ae0-bbc6-8b881d5c7525","uuid":"88e7e241-0077-4d15-af52-a6c6c10775a6","timestamp":"2026-03-24T22:45:46.803Z"}
