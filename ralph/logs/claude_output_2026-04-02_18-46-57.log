{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011o33WShjVrV3nyd8xsnNrW","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n2\timport { Command } from 'commander';\n3\timport { readFileSync } from 'node:fs';\n4\t\n5\t// ─── Mocks ───────────────────────────────────────────────────────────────────\n6\t\n7\tconst mockCreateValidationSprint = vi.fn();\n8\tconst mockRunValidationCycle = vi.fn();\n9\tconst mockGetValidationProgress = vi.fn();\n10\tconst mockGetACById = vi.fn();\n11\t\n12\tvi.mock('../../modules/verify/index.js', () => ({\n13\t  createValidationSprint: (...args: unknown[]) => mockCreateValidationSprint(...args),\n14\t  runValidationCycle: (...args: unknown[]) => mockRunValidationCycle(...args),\n15\t  getValidationProgress: (...args: unknown[]) => mockGetValidationProgress(...args),\n16\t  getACById: (...args: unknown[]) => mockGetACById(...args),\n17\t}));\n18\t\n19\t// Mock validate-schema to isolate self-validation tests\n20\tvi.mock('../validate-schema.js', () => ({\n21\t  registerValidateSchemaCommand: vi.fn(),\n22\t  runSchemaValidation: vi.fn(() => ({ status: 'pass', files: [] })),\n23\t}));\n24\t\n25\timport { registerValidateCommand } from '../validate.js';\n26\t\n27\tbeforeEach(() => {\n28\t  vi.resetAllMocks();\n29\t  process.exitCode = undefined;\n30\t});\n31\t\n32\tafterEach(() => {\n33\t  vi.restoreAllMocks();\n34\t  process.exitCode = undefined;\n35\t});\n36\t\n37\tfunction createCli(): Command {\n38\t  const program = new Command();\n39\t  program.exitOverride();\n40\t  program.option('--json', 'JSON output');\n41\t  registerValidateCommand(program);\n42\t  return program;\n43\t}\n44\t\n45\tasync function runCli(args: string[]): Promise<{ stdout: string }> {\n46\t  const logs: string[] = [];\n47\t  const consoleSpy = vi.spyOn(console, 'log').mockImplementation((...a: unknown[]) => {\n48\t    logs.push(a.map(String).join(' '));\n49\t  });\n50\t  const program = createCli();\n51\t  await program.parseAsync(['node', 'codeharness', ...args]);\n52\t  consoleSpy.mockRestore();\n53\t  return { stdout: logs.join('\\n') };\n54\t}\n55\t\n56\t// Helper: set up mocks for a full successful run (all pass)\n57\tfunction setupAllPass(total = 5, blocked = 2) {\n58\t  mockCreateValidationSprint.mockReturnValue({ success: true, data: { acsAdded: total, existingPreserved: 0 } });\n59\t  // First call returns a cycle, second returns no-actionable\n60\t  mockRunValidationCycle\n61\t    .mockReturnValueOnce({ success: true, data: { acId: 1, action: 'passed' } })\n62\t    .mockReturnValue({ success: true, data: { acId: 0, action: 'no-actionable-ac' } });\n63\t  mockGetValidationProgress.mockReturnValue({\n64\t    success: true,\n65\t    data: {\n66\t      total, passed: total - blocked, failed: 0, blocked, remaining: 0,\n67\t      perAC: Array.from({ length: total }, (_, i) => ({\n68\t        acId: i + 1,\n69\t        status: i < total - blocked ? 'done' : 'blocked',\n70\t        attempts: 1,\n71\t        lastError: null,\n72\t      })),\n73\t    },\n74\t  });\n75\t}\n76\t\n77\t// Helper: set up mocks for a run with failures\n78\tfunction setupWithFailures() {\n79\t  mockCreateValidationSprint.mockReturnValue({ success: true, data: { acsAdded: 3, existingPreserved: 0 } });\n80\t  mockRunValidationCycle\n81\t    .mockReturnValueOnce({ success: true, data: { acId: 1, action: 'passed' } })\n82\t    .mockReturnValue({ success: true, data: { acId: 0, action: 'no-actionable-ac' } });\n83\t  mockGetValidationProgress.mockReturnValue({\n84\t    success: true,\n85\t    data: {\n86\t      total: 3, passed: 1, failed: 1, blocked: 1, remaining: 0,\n87\t      perAC: [\n88\t        { acId: 1, status: 'done', attempts: 1, lastError: null },\n89\t        { acId: 2, status: 'failed', attempts: 3, lastError: 'command exited with code 1' },\n90\t        { acId: 3, status: 'blocked', attempts: 1, lastError: 'blocked' },\n91\t      ],\n92\t    },\n93\t  });\n94\t  mockGetACById.mockImplementation((id: number) => {\n95\t    if (id === 2) return { id: 2, frRef: 'FR2', description: 'Test AC 2', verificationMethod: 'cli', command: 'echo test', category: 'FR' };\n96\t    if (id === 3) return { id: 3, frRef: 'FR3', description: 'Test AC 3', verificationMethod: 'integration', category: 'FR' };\n97\t    return null;\n98\t  });\n99\t}\n100\t\n101\tdescribe('validate self subcommand', () => {\n102\t  it('produces report with correct counts (AC 1)', async () => {\n103\t    setupAllPass(10, 3);\n104\t    const { stdout } = await runCli(['validate', 'self']);\n105\t    expect(stdout).toContain('Total: 10');\n106\t    expect(stdout).toContain('Passed: 7');\n107\t    expect(stdout).toContain('Failed: 0');\n108\t    expect(stdout).toContain('Blocked: 3');\n109\t    expect(stdout).toContain('Cycles: 1');\n110\t  });\n111\t\n112\t  it('outputs RELEASE GATE: PASS on all-pass scenario (AC 2)', async () => {\n113\t    setupAllPass(5, 2);\n114\t    const { stdout } = await runCli(['validate', 'self']);\n115\t    expect(stdout).toContain('RELEASE GATE: PASS -- v1.0 ready');\n116\t    expect(process.exitCode).toBe(0);\n117\t  });\n118\t\n119\t  it('includes per-failure detail on failure scenario (AC 3)', async () => {\n120\t    setupWithFailures();\n121\t    const { stdout } = await runCli(['validate', 'self']);\n122\t    expect(stdout).toContain('RELEASE GATE: FAIL');\n123\t    expect(stdout).toContain('AC 2');\n124\t    expect(stdout).toContain('Test AC 2');\n125\t    expect(stdout).toContain('Command: echo test');\n126\t    expect(stdout).toContain('Output: command exited with code 1');\n127\t    expect(stdout).toContain('Attempts: 3');\n128\t    expect(stdout).toContain('Blocker: failed');\n129\t    expect(process.exitCode).toBe(1);\n130\t  });\n131\t\n132\t  it('--ci sets exit code 0 on pass (AC 5)', async () => {\n133\t    setupAllPass();\n134\t    const { stdout } = await runCli(['validate', 'self', '--ci']);\n135\t    expect(stdout).toContain('RELEASE GATE: PASS -- v1.0 ready');\n136\t    expect(process.exitCode).toBe(0);\n137\t  });\n138\t\n139\t  it('--ci sets exit code 1 on fail (AC 5)', async () => {\n140\t    setupWithFailures();\n141\t    const { stdout } = await runCli(['validate', 'self', '--ci']);\n142\t    expect(stdout).toContain('RELEASE GATE: FAIL');\n143\t    expect(process.exitCode).toBe(1);\n144\t  });\n145\t\n146\t  it('--json outputs machine-readable JSON', async () => {\n147\t    setupAllPass(5, 2);\n148\t    const { stdout } = await runCli(['--json', 'validate', 'self']);\n149\t    const parsed = JSON.parse(stdout);\n150\t    expect(parsed.status).toBe('pass');\n151\t    expect(parsed.total).toBe(5);\n152\t    expect(parsed.passed).toBe(3);\n153\t    expect(parsed.blocked).toBe(2);\n154\t    expect(parsed.cycles).toBe(1);\n155\t    expect(parsed.gate).toBe('RELEASE GATE: PASS -- v1.0 ready');\n156\t    expect(parsed.failures).toBeDefined();\n157\t  });\n158\t\n159\t  it('--json includes failure details', async () => {\n160\t    setupWithFailures();\n161\t    const { stdout } = await runCli(['--json', 'validate', 'self']);\n162\t    const parsed = JSON.parse(stdout);\n163\t    expect(parsed.status).toBe('fail');\n164\t    expect(parsed.gate).toBe('RELEASE GATE: FAIL');\n165\t    expect(parsed.failures.length).toBeGreaterThan(0);\n166\t    const failedAc = parsed.failures.find((f: { acId: number }) => f.acId === 2);\n167\t    expect(failedAc).toBeDefined();\n168\t    expect(failedAc.description).toBe('Test AC 2');\n169\t    expect(failedAc.command).toBe('echo test');\n170\t    expect(failedAc.output).toBe('command exited with code 1');\n171\t  });\n172\t\n173\t  it('reports error when createValidationSprint fails', async () => {\n174\t    mockCreateValidationSprint.mockReturnValue({ success: false, error: 'state not found' });\n175\t    const { stdout } = await runCli(['validate', 'self']);\n176\t    expect(stdout).toContain('state not found');\n177\t    expect(process.exitCode).toBe(1);\n178\t  });\n179\t\n180\t  it('reports error when runValidationCycle fails', async () => {\n181\t    mockCreateValidationSprint.mockReturnValue({ success: true, data: { acsAdded: 1, existingPreserved: 0 } });\n182\t    mockRunValidationCycle.mockReturnValue({ success: false, error: 'cycle error' });\n183\t    const { stdout } = await runCli(['validate', 'self']);\n184\t    expect(stdout).toContain('cycle error');\n185\t    expect(process.exitCode).toBe(1);\n186\t  });\n187\t\n188\t  it('reports error when getValidationProgress fails', async () => {\n189\t    mockCreateValidationSprint.mockReturnValue({ success: true, data: { acsAdded: 1, existingPreserved: 0 } });\n190\t    mockRunValidationCycle.mockReturnValue({ success: true, data: { acId: 0, action: 'no-actionable-ac' } });\n191\t    mockGetValidationProgress.mockReturnValue({ success: false, error: 'progress error' });\n192\t    const { stdout } = await runCli(['validate', 'self']);\n193\t    expect(stdout).toContain('progress error');\n194\t    expect(process.exitCode).toBe(1);\n195\t  });\n196\t\n197\t  it('validate-self.ts is under 100 lines (FR40)', () => {\n198\t    const source = readFileSync(\n199\t      new URL('../validate-self.ts', import.meta.url).pathname,\n200\t      'utf-8',\n201\t    );\n202\t    const lineCount = source.split('\\n').length;\n203\t    expect(lineCount).toBeLessThan(100);\n204\t  });\n205\t});\n206\t"}]},"parent_tool_use_id":"toolu_01DuVFpc4kAp6TjMAncLaYvJ","session_id":"5fca15c0-771e-463c-9e4f-c528b230e359","uuid":"9ece5c2e-799e-4d5b-9714-726adb839b75","timestamp":"2026-04-02T14:57:42.543Z"}
