{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01N3HGbZRtC52tCYjusNTvxV","type":"tool_result","content":"     1→/**\n     2→ * Documentation health scanner — module detection and full scan.\n     3→ */\n     4→\n     5→import {\n     6→  existsSync,\n     7→  readFileSync,\n     8→  readdirSync,\n     9→  statSync,\n    10→} from 'node:fs';\n    11→import { join, relative } from 'node:path';\n    12→import { getExtension, isTestFile, getNewestSourceMtime } from './types.js';\n    13→import {\n    14→  checkAgentsMdForModule,\n    15→  checkAgentsMdCompleteness,\n    16→  checkDoNotEditHeaders,\n    17→} from './staleness.js';\n    18→import type { DocHealthResult, DocHealthReport } from './types.js';\n    19→\n    20→// ─── Constants ──────────────────────────────────────────────────────────────\n    21→\n    22→const SOURCE_EXTENSIONS = new Set(['.ts', '.js', '.py']);\n    23→const DEFAULT_MODULE_THRESHOLD = 3;\n    24→\n    25→// ─── Module Detection ────────────────────────────────────────────────────────\n    26→\n    27→export function findModules(dir: string, threshold?: number): string[] {\n    28→  const limit = threshold ?? DEFAULT_MODULE_THRESHOLD;\n    29→  const root = dir;\n    30→  const modules: string[] = [];\n    31→\n    32→  function walk(current: string): void {\n    33→    let entries: string[];\n    34→    try {\n    35→      entries = readdirSync(current);\n    36→    } catch {\n    37→      return;\n    38→    }\n    39→\n    40→    const dirName = current.split('/').pop() ?? '';\n    41→    if (\n    42→      dirName === 'node_modules' ||\n    43→      dirName === '.git' ||\n    44→      dirName === 'dist' ||\n    45→      dirName === 'coverage' ||\n    46→      (dirName.startsWith('.') && current !== root)\n    47→    ) {\n    48→      return;\n    49→    }\n    50→\n    51→    let sourceCount = 0;\n    52→    const subdirs: string[] = [];\n    53→\n    54→    for (const entry of entries) {\n    55→      const fullPath = join(current, entry);\n    56→      let stat;\n    57→      try {\n    58→        stat = statSync(fullPath);\n    59→      } catch {\n    60→        continue;\n    61→      }\n    62→\n    63→      if (stat.isDirectory()) {\n    64→        subdirs.push(fullPath);\n    65→      } else if (stat.isFile()) {\n    66→        const ext = getExtension(entry);\n    67→        if (SOURCE_EXTENSIONS.has(ext) && !isTestFile(entry)) {\n    68→          sourceCount++;\n    69→        }\n    70→      }\n    71→    }\n    72→\n    73→    if (sourceCount >= limit) {\n    74→      const rel = relative(root, current);\n    75→      if (rel !== '') {\n    76→        modules.push(rel);\n    77→      }\n    78→    }\n    79→\n    80→    for (const subdir of subdirs) {\n    81→      walk(subdir);\n    82→    }\n    83→  }\n    84→\n    85→  walk(root);\n    86→  return modules;\n    87→}\n    88→\n    89→// ─── Full Scan ──────────────────────────────────────────────────────────────\n    90→\n    91→export function scanDocHealth(dir?: string): DocHealthReport {\n    92→  const start = Date.now();\n    93→  const root = dir ?? process.cwd();\n    94→  const documents: DocHealthResult[] = [];\n    95→\n    96→  const modules = findModules(root);\n    97→\n    98→  // 1. Root AGENTS.md\n    99→  const rootAgentsPath = join(root, 'AGENTS.md');\n   100→  if (existsSync(rootAgentsPath)) {\n   101→    if (modules.length > 0) {\n   102→      const docMtime = statSync(rootAgentsPath).mtime;\n   103→\n   104→      let allMissing: string[] = [];\n   105→      let staleModule = '';\n   106→      let newestCode: Date | null = null;\n   107→\n   108→      for (const mod of modules) {\n   109→        const fullModPath = join(root, mod);\n   110→        const modAgentsPath = join(fullModPath, 'AGENTS.md');\n   111→        if (existsSync(modAgentsPath)) continue;\n   112→\n   113→        const { missing } = checkAgentsMdCompleteness(rootAgentsPath, fullModPath);\n   114→        if (missing.length > 0 && staleModule === '') {\n   115→          staleModule = mod;\n   116→          allMissing = missing;\n   117→        }\n   118→\n   119→        const modMtime = getNewestSourceMtime(fullModPath);\n   120→        if (modMtime !== null && (newestCode === null || modMtime.getTime() > newestCode.getTime())) {\n   121→          newestCode = modMtime;\n   122→        }\n   123→      }\n   124→\n   125→      if (allMissing.length > 0) {\n   126→        documents.push({\n   127→          path: 'AGENTS.md',\n   128→          grade: 'stale',\n   129→          lastModified: docMtime,\n   130→          codeLastModified: newestCode,\n   131→          reason: `AGENTS.md stale for module: ${staleModule} — missing: ${allMissing.join(', ')}`,\n   132→        });\n   133→      } else {\n   134→        documents.push({\n   135→          path: 'AGENTS.md',\n   136→          grade: 'fresh',\n   137→          lastModified: docMtime,\n   138→          codeLastModified: newestCode,\n   139→          reason: 'Up to date',\n   140→        });\n   141→      }\n   142→    } else {\n   143→      documents.push({\n   144→        path: 'AGENTS.md',\n   145→        grade: 'fresh',\n   146→        lastModified: statSync(rootAgentsPath).mtime,\n   147→        codeLastModified: null,\n   148→        reason: 'No modules found to compare',\n   149→      });\n   150→    }\n   151→\n   152→    checkAgentsMdLineCount(rootAgentsPath, 'AGENTS.md', documents);\n   153→  } else {\n   154→    documents.push({\n   155→      path: 'AGENTS.md',\n   156→      grade: 'missing',\n   157→      lastModified: null,\n   158→      codeLastModified: null,\n   159→      reason: 'Root AGENTS.md not found',\n   160→    });\n   161→  }\n   162→\n   163→  // 2. Per-module AGENTS.md files\n   164→  for (const mod of modules) {\n   165→    const modAgentsPath = join(root, mod, 'AGENTS.md');\n   166→    if (existsSync(modAgentsPath)) {\n   167→      const result = checkAgentsMdForModule(mod, root);\n   168→      if (result.path !== 'AGENTS.md') {\n   169→        documents.push(result);\n   170→        checkAgentsMdLineCount(modAgentsPath, result.path, documents);\n   171→      }\n   172→    }\n   173→  }\n   174→\n   175→  // 3. docs/index.md\n   176→  const indexPath = join(root, 'docs', 'index.md');\n   177→  if (existsSync(indexPath)) {\n   178→    const content = readFileSync(indexPath, 'utf-8');\n   179→    const hasAbsolutePaths = /https?:\\/\\/|file:\\/\\//i.test(content);\n   180→    documents.push({\n   181→      path: 'docs/index.md',\n   182→      grade: 'fresh',\n   183→      lastModified: statSync(indexPath).mtime,\n   184→      codeLastModified: null,\n   185→      reason: hasAbsolutePaths\n   186→        ? 'Contains absolute URLs (may violate NFR25)'\n   187→        : 'Uses relative paths',\n   188→    });\n   189→  }\n   190→\n   191→  // 4. Active exec-plans\n   192→  const activeDir = join(root, 'docs', 'exec-plans', 'active');\n   193→  if (existsSync(activeDir)) {\n   194→    const files = readdirSync(activeDir).filter(f => f.endsWith('.md'));\n   195→    for (const file of files) {\n   196→      const filePath = join(activeDir, file);\n   197→      documents.push({\n   198→        path: `docs/exec-plans/active/${file}`,\n   199→        grade: 'fresh',\n   200→        lastModified: statSync(filePath).mtime,\n   201→        codeLastModified: null,\n   202→        reason: 'Active exec-plan',\n   203→      });\n   204→    }\n   205→  }\n   206→\n   207→  // 5. docs/quality/ and docs/generated/\n   208→  for (const subdir of ['quality', 'generated']) {\n   209→    const dirPath = join(root, 'docs', subdir);\n   210→    if (!existsSync(dirPath)) continue;\n   211→\n   212→    const files = readdirSync(dirPath).filter(f => !f.startsWith('.'));\n   213→    for (const file of files) {\n   214→      const filePath = join(dirPath, file);\n   215→      let stat;\n   216→      try {\n   217→        stat = statSync(filePath);\n   218→      } catch {\n   219→        continue;\n   220→      }\n   221→      if (!stat.isFile()) continue;\n   222→\n   223→      const hasHeader = checkDoNotEditHeaders(filePath);\n   224→      documents.push({\n   225→        path: `docs/${subdir}/${file}`,\n   226→        grade: hasHeader ? 'fresh' : 'stale',\n   227→        lastModified: stat.mtime,\n   228→        codeLastModified: null,\n   229→        reason: hasHeader\n   230→          ? 'Has DO NOT EDIT MANUALLY header'\n   231→          : 'Missing DO NOT EDIT MANUALLY header (NFR26)',\n   232→      });\n   233→    }\n   234→  }\n   235→\n   236→  const summary = {\n   237→    fresh: documents.filter(d => d.grade === 'fresh').length,\n   238→    stale: documents.filter(d => d.grade === 'stale').length,\n   239→    missing: documents.filter(d => d.grade === 'missing').length,\n   240→    total: documents.length,\n   241→  };\n   242→\n   243→  return {\n   244→    documents,\n   245→    summary,\n   246→    passed: summary.stale === 0 && summary.missing === 0,\n   247→    scanDurationMs: Date.now() - start,\n   248→  };\n   249→}\n   250→\n   251→function checkAgentsMdLineCount(\n   252→  filePath: string,\n   253→  docPath: string,\n   254→  documents: DocHealthResult[],\n   255→): void {\n   256→  try {\n   257→    const content = readFileSync(filePath, 'utf-8');\n   258→    const lineCount = content.split('\\n').length;\n   259→    if (lineCount > 100) {\n   260→      documents.push({\n   261→        path: docPath,\n   262→        grade: 'fresh',\n   263→        lastModified: statSync(filePath).mtime,\n   264→        codeLastModified: null,\n   265→        reason: `AGENTS.md exceeds 100 lines (${lineCount} lines) — consider splitting`,\n   266→      });\n   267→    }\n   268→  } catch {\n   269→    // Ignore read errors\n   270→  }\n   271→}\n   272→"}]},"parent_tool_use_id":"toolu_01WxJciqSN2EMLLyK1wQ7yug","session_id":"6831c0a8-772d-4704-bc72-4469c7d7a986","uuid":"26900ac3-8996-4ef5-afb6-5fbc966cc30d","timestamp":"2026-03-24T13:14:02.022Z"}
