{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PTEHWivW3kGfQWmWgRRQQc","type":"tool_result","content":"1\t/**\n2\t * Driver Factory & Registry.\n3\t *\n4\t * Module-singleton registry for AgentDriver instances.\n5\t * Drivers are registered explicitly via registerDriver() — no auto-discovery,\n6\t * no filesystem scanning, no dynamic imports.\n7\t *\n8\t * @see architecture-multi-framework.md — \"Register in factory.ts — never auto-discover\"\n9\t */\n10\t\n11\timport type { AgentDriver, DriverCapabilities } from '../types.js';\n12\t\n13\tconst registry = new Map<string, AgentDriver>();\n14\t\n15\t/**\n16\t * Register an AgentDriver by its `name` property.\n17\t * Throws if a driver with the same name is already registered.\n18\t */\n19\texport function registerDriver(driver: AgentDriver): void {\n20\t  if (!driver || typeof driver.name !== 'string') {\n21\t    throw new Error('registerDriver requires a valid AgentDriver with a string name property.');\n22\t  }\n23\t  if (!driver.name) {\n24\t    throw new Error('Driver name must be a non-empty string.');\n25\t  }\n26\t  if (registry.has(driver.name)) {\n27\t    throw new Error(\n28\t      `Driver '${driver.name}' is already registered. Each driver name must be unique.`,\n29\t    );\n30\t  }\n31\t  registry.set(driver.name, driver);\n32\t}\n33\t\n34\t/**\n35\t * Retrieve a registered AgentDriver by name.\n36\t * Throws with a helpful message listing all registered drivers if not found.\n37\t */\n38\texport function getDriver(name: string): AgentDriver {\n39\t  if (!name || typeof name !== 'string') {\n40\t    throw new Error('getDriver requires a non-empty string name.');"}]},"parent_tool_use_id":"toolu_01WnnpXgRY1Zao1mENPUGorH","session_id":"74f4684f-cc80-4828-8405-943cba326449","uuid":"7659e96b-0d2b-4fd6-b2d3-4a83f0b1f481","timestamp":"2026-04-03T21:41:54.023Z"}
