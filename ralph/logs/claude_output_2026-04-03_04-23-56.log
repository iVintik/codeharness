{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DHkVkD7YB8k3k3JRzz3tcX","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach } from 'vitest';\n2\t\n3\t// --- Mocks (must be before imports) ---\n4\t\n5\tvi.mock('../docker/index.js', () => ({\n6\t  isDockerAvailable: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock('../source-isolation.js', () => ({\n10\t  createIsolatedWorkspace: vi.fn(),\n11\t}));\n12\t\n13\tvi.mock('../agent-dispatch.js', () => ({\n14\t  dispatchAgent: vi.fn(),\n15\t}));\n16\t\n17\tvi.mock('../trace-id.js', () => ({\n18\t  formatTracePrompt: vi.fn(),\n19\t}));\n20\t\n21\t// --- Imports ---\n22\t\n23\timport { runEvaluator } from '../evaluator.js';\n24\timport type { EvaluatorOptions, EvaluatorResult } from '../evaluator.js';\n25\timport { isDockerAvailable } from '../docker/index.js';\n26\timport { createIsolatedWorkspace } from '../source-isolation.js';\n27\timport { dispatchAgent } from '../agent-dispatch.js';\n28\timport { formatTracePrompt } from '../trace-id.js';\n29\timport type { SubagentDefinition } from '../agent-resolver.js';\n30\timport type { IsolatedWorkspace } from '../source-isolation.js';\n31\timport type { DispatchResult } from '../agent-dispatch.js';\n32\t\n33\t// --- Helpers ---\n34\t\n35\tfunction makeAgentDef(overrides?: Partial<SubagentDefinition>): SubagentDefinition {\n36\t  return {\n37\t    name: 'evaluator',\n38\t    model: 'claude-sonnet-4-20250514',\n39\t    instructions: 'You are the evaluator.',\n40\t    disallowedTools: ['Edit', 'Write'],\n41\t    bare: true,\n42\t    ...overrides,\n43\t  };\n44\t}\n45\t\n46\tfunction makeMockWorkspace(): IsolatedWorkspace {\n47\t  return {\n48\t    dir: '/tmp/codeharness-verify-test-run',\n49\t    storyFilesDir: '/tmp/codeharness-verify-test-run/story-files',\n50\t    verdictDir: '/tmp/codeharness-verify-test-run/verdict',\n51\t    toDispatchOptions: vi.fn().mockReturnValue({ cwd: '/tmp/codeharness-verify-test-run' }),\n52\t    cleanup: vi.fn().mockResolvedValue(undefined),\n53\t  };\n54\t}\n55\t\n56\tfunction makeOptions(overrides?: Partial<EvaluatorOptions>): EvaluatorOptions {\n57\t  return {\n58\t    runId: 'test-run',\n59\t    storyFiles: ['/path/to/story-1.md', '/path/to/story-2.md'],\n60\t    agentDefinition: makeAgentDef(),\n61\t    ...overrides,\n62\t  };\n63\t}\n64\t\n65\tfunction makeDispatchResult(overrides?: Partial<DispatchResult>): DispatchResult {\n66\t  return {\n67\t    sessionId: 'session-123',\n68\t    success: true,\n69\t    durationMs: 5000,\n70\t    output: '{\"verdict\":\"pass\",\"score\":{\"passed\":2,\"failed\":0,\"unknown\":0,\"total\":2},\"findings\":[]}',\n71\t    ...overrides,\n72\t  };\n73\t}\n74\t\n75\t// --- Tests ---\n76\t\n77\tbeforeEach(() => {\n78\t  vi.clearAllMocks();\n79\t  vi.useRealTimers();\n80\t});\n81\t\n82\tdescribe('runEvaluator', () => {\n83\t  describe('Docker unavailable', () => {\n84\t    it('returns all-UNKNOWN result without throwing when Docker is unavailable', async () => {\n85\t      vi.mocked(isDockerAvailable).mockReturnValue(false);\n86\t\n87\t      const result = await runEvaluator(makeOptions());\n88\t\n89\t      expect(result.dockerAvailable).toBe(false);\n90\t      expect(result.success).toBe(false);\n91\t      expect(result.timedOut).toBe(false);\n92\t      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n93\t\n94\t      const parsed = JSON.parse(result.output);\n95\t      expect(parsed.verdict).toBe('fail');\n96\t      expect(parsed.score.unknown).toBe(2);\n97\t      expect(parsed.score.total).toBe(2);\n98\t      expect(parsed.findings).toHaveLength(2);\n99\t      expect(parsed.findings[0].status).toBe('unknown');\n100\t      expect(parsed.findings[0].evidence.reasoning).toContain('Docker');\n101\t    });\n102\t\n103\t    it('does not create workspace when Docker is unavailable', async () => {\n104\t      vi.mocked(isDockerAvailable).mockReturnValue(false);\n105\t\n106\t      await runEvaluator(makeOptions());\n107\t\n108\t      expect(createIsolatedWorkspace).not.toHaveBeenCalled();\n109\t      expect(dispatchAgent).not.toHaveBeenCalled();\n110\t    });\n111\t  });\n112\t\n113\t  describe('workspace creation', () => {\n114\t    it('creates workspace with correct runId and storyFiles', async () => {\n115\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n116\t      const mockWorkspace = makeMockWorkspace();\n117\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n118\t      vi.mocked(dispatchAgent).mockResolvedValue(makeDispatchResult());\n119\t\n120\t      await runEvaluator(makeOptions({\n121\t        runId: 'my-run-123',\n122\t        storyFiles: ['/a.md', '/b.md'],\n123\t      }));\n124\t\n125\t      expect(createIsolatedWorkspace).toHaveBeenCalledWith({\n126\t        runId: 'my-run-123',\n127\t        storyFiles: ['/a.md', '/b.md'],\n128\t      });\n129\t    });\n130\t  });\n131\t\n132\t  describe('successful dispatch', () => {\n133\t    it('returns agent output and success on successful dispatch', async () => {\n134\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n135\t      const mockWorkspace = makeMockWorkspace();\n136\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n137\t      const dispatchResult = makeDispatchResult({ output: '{\"verdict\":\"pass\"}', success: true });\n138\t      vi.mocked(dispatchAgent).mockResolvedValue(dispatchResult);\n139\t\n140\t      const result = await runEvaluator(makeOptions());\n141\t\n142\t      expect(result.success).toBe(true);\n143\t      expect(result.output).toBe('{\"verdict\":\"pass\"}');\n144\t      expect(result.dockerAvailable).toBe(true);\n145\t      expect(result.timedOut).toBe(false);\n146\t      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n147\t    });\n148\t\n149\t    it('dispatches agent with workspace cwd', async () => {\n150\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n151\t      const mockWorkspace = makeMockWorkspace();\n152\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n153\t      vi.mocked(dispatchAgent).mockResolvedValue(makeDispatchResult());\n154\t\n155\t      await runEvaluator(makeOptions());\n156\t\n157\t      expect(dispatchAgent).toHaveBeenCalledWith(\n158\t        expect.objectContaining({ name: 'evaluator' }),\n159\t        expect.stringContaining('story-files'),\n160\t        expect.objectContaining({ cwd: '/tmp/codeharness-verify-test-run' }),\n161\t      );\n162\t    });\n163\t\n164\t    it('dispatch prompt includes story file paths reference (AC #7, story 6-3)', async () => {\n165\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n166\t      const mockWorkspace = makeMockWorkspace();\n167\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n168\t      vi.mocked(dispatchAgent).mockResolvedValue(makeDispatchResult());\n169\t\n170\t      await runEvaluator(makeOptions());\n171\t\n172\t      const promptArg = vi.mocked(dispatchAgent).mock.calls[0][1] as string;\n173\t      expect(promptArg).toContain('./story-files/');\n174\t    });\n175\t\n176\t    it('dispatch prompt includes verdict output path (AC #7, story 6-3)', async () => {\n177\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n178\t      const mockWorkspace = makeMockWorkspace();\n179\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n180\t      vi.mocked(dispatchAgent).mockResolvedValue(makeDispatchResult());\n181\t\n182\t      await runEvaluator(makeOptions());\n183\t\n184\t      const promptArg = vi.mocked(dispatchAgent).mock.calls[0][1] as string;\n185\t      expect(promptArg).toContain('./verdict/');\n186\t    });\n187\t  });\n188\t\n189\t  describe('trace ID injection', () => {\n190\t    it('appends trace prompt when traceId is provided', async () => {\n191\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n192\t      const mockWorkspace = makeMockWorkspace();\n193\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n194\t      vi.mocked(dispatchAgent).mockResolvedValue(makeDispatchResult());\n195\t      vi.mocked(formatTracePrompt).mockReturnValue('[TRACE] trace_id=ch-run-0-verify');\n196\t\n197\t      await runEvaluator(makeOptions({ traceId: 'ch-run-0-verify' }));\n198\t\n199\t      expect(formatTracePrompt).toHaveBeenCalledWith('ch-run-0-verify');\n200\t      expect(dispatchAgent).toHaveBeenCalledWith(\n201\t        expect.anything(),\n202\t        expect.anything(),\n203\t        expect.objectContaining({\n204\t          appendSystemPrompt: '[TRACE] trace_id=ch-run-0-verify',\n205\t        }),\n206\t      );\n207\t    });\n208\t\n209\t    it('does not set appendSystemPrompt when no traceId', async () => {\n210\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n211\t      const mockWorkspace = makeMockWorkspace();\n212\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n213\t      vi.mocked(dispatchAgent).mockResolvedValue(makeDispatchResult());\n214\t\n215\t      await runEvaluator(makeOptions({ traceId: undefined }));\n216\t\n217\t      expect(formatTracePrompt).not.toHaveBeenCalled();\n218\t      const callArgs = vi.mocked(dispatchAgent).mock.calls[0][2];\n219\t      expect(callArgs?.appendSystemPrompt).toBeUndefined();\n220\t    });\n221\t  });\n222\t\n223\t  describe('timeout handling', () => {\n224\t    it('returns UNKNOWN result with timedOut=true on timeout', async () => {\n225\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n226\t      const mockWorkspace = makeMockWorkspace();\n227\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n228\t\n229\t      // dispatchAgent never resolves\n230\t      vi.mocked(dispatchAgent).mockReturnValue(new Promise(() => {}));\n231\t\n232\t      vi.useFakeTimers();\n233\t\n234\t      const resultPromise = runEvaluator(makeOptions({ timeoutMs: 1000 }));\n235\t\n236\t      // Advance time past the timeout\n237\t      await vi.advanceTimersByTimeAsync(1001);\n238\t\n239\t      const result = await resultPromise;\n240\t\n241\t      expect(result.timedOut).toBe(true);\n242\t      expect(result.success).toBe(false);\n243\t      expect(result.dockerAvailable).toBe(true);\n244\t\n245\t      const parsed = JSON.parse(result.output);\n246\t      expect(parsed.verdict).toBe('fail');\n247\t      expect(parsed.findings[0].status).toBe('unknown');\n248\t      expect(parsed.findings[0].evidence.reasoning).toContain('timed out');\n249\t    });\n250\t\n251\t    it('uses default timeout of 300000ms when timeoutMs not specified', async () => {\n252\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n253\t      const mockWorkspace = makeMockWorkspace();\n254\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n255\t      vi.mocked(dispatchAgent).mockReturnValue(new Promise(() => {}));\n256\t\n257\t      vi.useFakeTimers();\n258\t\n259\t      const resultPromise = runEvaluator(makeOptions());\n260\t\n261\t      // Should not have timed out at 299999ms\n262\t      await vi.advanceTimersByTimeAsync(299_999);\n263\t      // Verify still pending — we can't directly check, but advancing past 300000 should resolve it\n264\t      await vi.advanceTimersByTimeAsync(2);\n265\t\n266\t      const result = await resultPromise;\n267\t      expect(result.timedOut).toBe(true);\n268\t    });\n269\t  });\n270\t\n271\t  describe('cleanup', () => {\n272\t    it('calls cleanup on successful dispatch', async () => {\n273\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n274\t      const mockWorkspace = makeMockWorkspace();\n275\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n276\t      vi.mocked(dispatchAgent).mockResolvedValue(makeDispatchResult());\n277\t\n278\t      await runEvaluator(makeOptions());\n279\t\n280\t      expect(mockWorkspace.cleanup).toHaveBeenCalledTimes(1);\n281\t    });\n282\t\n283\t    it('calls cleanup on dispatch failure', async () => {\n284\t      vi.