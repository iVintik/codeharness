{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EUVd4xMywbvjpzRZjMiR1S","type":"tool_result","content":"     1→/**\n     2→ * Public API for the doc-health subsystem.\n     3→ */\n     4→\n     5→// Types\n     6→export type { DocHealthResult, DocHealthReport } from './types.js';\n     7→\n     8→// Shared utilities (used by scanner and staleness)\n     9→export { getExtension, isTestFile, getNewestSourceMtime } from './types.js';\n    10→\n    11→// Scanner\n    12→export { findModules, scanDocHealth } from './scanner.js';\n    13→\n    14→// Staleness\n    15→export {\n    16→  isDocStale,\n    17→  getSourceFilesInModule,\n    18→  getMentionedFilesInAgentsMd,\n    19→  checkAgentsMdCompleteness,\n    20→  checkAgentsMdForModule,\n    21→  checkDoNotEditHeaders,\n    22→  checkStoryDocFreshness,\n    23→} from './staleness.js';\n    24→\n    25→// Report\n    26→export {\n    27→  formatDocHealthOutput,\n    28→  printDocHealthOutput,\n    29→  createExecPlan,\n    30→  completeExecPlan,\n    31→  getExecPlanStatus,\n    32→} from './report.js';\n    33→"}]},"parent_tool_use_id":"toolu_01WxJciqSN2EMLLyK1wQ7yug","session_id":"6831c0a8-772d-4704-bc72-4469c7d7a986","uuid":"dd48ef12-8456-447d-b868-fdc69ae02308","timestamp":"2026-03-24T13:14:01.618Z"}
