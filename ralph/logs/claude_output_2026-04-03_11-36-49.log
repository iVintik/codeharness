mpleted when no errors occur', async () => {\n855\t    mockParse.mockReturnValue({\n856\t      development_status: { '3-1-foo': 'ready-for-dev' },\n857\t    });\n858\t\n859\t    const config = makeConfig({\n860\t      workflow: {\n861\t        tasks: { implement: makeTask() },\n862\t        flow: ['implement'],\n863\t      },\n864\t    });\n865\t\n866\t    await executeWorkflow(config);\n867\t\n868\t    const lastWrite = mockWriteWorkflowState.mock.calls[\n869\t      mockWriteWorkflowState.mock.calls.length - 1\n870\t    ];\n871\t    expect((lastWrite[0] as WorkflowState).phase).toBe('completed');\n872\t  });\n873\t\n874\t  it('initializes workflow state with phase=executing at start', async () => {\n875\t    mockParse.mockReturnValue({\n876\t      development_status: { '3-1-foo': 'ready-for-dev' },\n877\t    });\n878\t\n879\t    const config = makeConfig({\n880\t      workflow: {\n881\t        tasks: { implement: makeTask() },\n882\t        flow: ['implement'],\n883\t      },\n884\t    });\n885\t\n886\t    await executeWorkflow(config);\n887\t\n888\t    const firstWrite = mockWriteWorkflowState.mock.calls[0];\n889\t    expect((firstWrite[0] as WorkflowState).phase).toBe('executing');\n890\t  });\n891\t\n892\t  it('invokes source isolation for per-run task with source_access false', async () => {\n893\t    const mockWorkspace = {\n894\t      dir: '/tmp/test',\n895\t      storyFilesDir: '/tmp/test/story-files',\n896\t      verdictDir: '/tmp/test/verdict',\n897\t      toDispatchOptions: () => ({ cwd: '/tmp/test' }),\n898\t      cleanup: vi.fn().mockResolvedValue(undefined),\n899\t    };\n900\t    mockCreateIsolatedWorkspace.mockResolvedValue(mockWorkspace);\n901\t\n902\t    mockParse.mockReturnValue({\n903\t      development_status: { '3-1-foo': 'ready-for-dev' },\n904\t    });\n905\t\n906\t    const config = makeConfig({\n907\t      workflow: {\n908\t        tasks: {\n909\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n910\t        },\n911\t