{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01E2NXcEN7hycwNMXa2PRVFk","type":"tool_result","content":"     1→/**\n     2→ * Codebase scanning, module detection, coverage gap analysis, and documentation audit.\n     3→ *\n     4→ * Story 6.1: Codebase Scan & Gap Analysis\n     5→ * Reuses findModules() from doc-health.ts and coverage tools from coverage.ts.\n     6→ */\n     7→\n     8→import {\n     9→  existsSync,\n    10→  readdirSync,\n    11→  readFileSync,\n    12→  statSync,\n    13→} from 'node:fs';\n    14→import { join, relative } from 'node:path';\n    15→import { findModules, isDocStale } from './doc-health/index.js';\n    16→import { detectCoverageTool, parseCoverageReport } from './coverage/index.js';\n    17→\n    18→// ─── Types ──────────────────────────────────────────────────────────────────\n    19→\n    20→export interface ModuleInfo {\n    21→  path: string;\n    22→  sourceFiles: number;\n    23→  testFiles: number;\n    24→}\n    25→\n    26→export interface DetectedArtifacts {\n    27→  hasBmad: boolean;\n    28→  bmadPath: string | null;\n    29→}\n    30→\n    31→export interface ScanResult {\n    32→  modules: ModuleInfo[];\n    33→  totalSourceFiles: number;\n    34→  artifacts: DetectedArtifacts;\n    35→}\n    36→\n    37→export interface ModuleCoverageInfo {\n    38→  path: string;\n    39→  coveragePercent: number;\n    40→  uncoveredFileCount: number;\n    41→}\n    42→\n    43→export interface CoverageGapReport {\n    44→  overall: number;\n    45→  modules: ModuleCoverageInfo[];\n    46→  uncoveredFiles: number;\n    47→}\n    48→\n    49→export interface DocAuditEntry {\n    50→  name: string;\n    51→  grade: 'present' | 'stale' | 'missing';\n    52→  path: string | null;\n    53→}\n    54→\n    55→export interface DocAuditResult {\n    56→  documents: DocAuditEntry[];\n    57→  summary: string;\n    58→}\n    59→\n    60→// ─── Constants ──────────────────────────────────────────────────────────────\n    61→\n    62→const SOURCE_EXTENSIONS = new Set(['.ts', '.js', '.py']);\n    63→const DEFAULT_MIN_MODULE_SIZE = 3;\n    64→\n    65→// ─── Helpers ────────────────────────────────────────────────────────────────\n    66→\n    67→function getExtension(filename: string): string {\n    68→  const dot = filename.lastIndexOf('.');\n    69→  return dot >= 0 ? filename.slice(dot) : '';\n    70→}\n    71→\n    72→function isTestFile(filename: string): boolean {\n    73→  return (\n    74→    filename.includes('.test.') ||\n    75→    filename.includes('.spec.') ||\n    76→    filename.includes('__tests__') ||\n    77→    filename.startsWith('test_')\n    78→  );\n    79→}\n    80→\n    81→function isSkippedDir(name: string): boolean {\n    82→  return name === 'node_modules' || name === '.git' || name === 'dist' || name === 'coverage';\n    83→}\n    84→\n    85→// ─── Source File Counting (Task 1.3) ────────────────────────────────────────\n    86→\n    87→/**\n    88→ * Counts total source files across the entire project, excluding test files,\n    89→ * node_modules, .git, etc.\n    90→ */\n    91→function countSourceFiles(dir: string): number {\n    92→  let count = 0;\n    93→\n    94→  function walk(current: string): void {\n    95→    let entries: string[];\n    96→    try {\n    97→      entries = readdirSync(current);\n    98→    } catch {\n    99→      // IGNORE: directory may not be readable\n   100→      return;\n   101→    }\n   102→\n   103→    for (const entry of entries) {\n   104→      if (isSkippedDir(entry)) continue;\n   105→      if (entry.startsWith('.') && current !== dir) continue;\n   106→\n   107→      const fullPath = join(current, entry);\n   108→      let stat;\n   109→      try {\n   110→        stat = statSync(fullPath);\n   111→      } catch {\n   112→        // IGNORE: file stat may fail, skip entry\n   113→        continue;\n   114→      }\n   115→\n   116→      if (stat.isDirectory()) {\n   117→        // Skip hidden directories at any level except root\n   118→        if (entry.startsWith('.')) continue;\n   119→        // Skip __tests__ directories — they contain test infrastructure, not source\n   120→        if (entry === '__tests__') continue;\n   121→        walk(fullPath);\n   122→      } else if (stat.isFile()) {\n   123→        const ext = getExtension(entry);\n   124→        if (SOURCE_EXTENSIONS.has(ext) && !isTestFile(entry)) {\n   125→          count++;\n   126→        }\n   127→      }\n   128→    }\n   129→  }\n   130→\n   131→  walk(dir);\n   132→  return count;\n   133→}\n   134→\n   135→// ─── Per-Module File Counting (Task 1.4) ─────────────────────────────────────\n   136→\n   137→/**\n   138→ * For a given module path, counts source files and test files.\n   139→ */\n   140→function countModuleFiles(\n   141→  modulePath: string,\n   142→  rootDir: string,\n   143→): { sourceFiles: number; testFiles: number } {\n   144→  const fullModulePath = join(rootDir, modulePath);\n   145→  let sourceFiles = 0;\n   146→  let testFiles = 0;\n   147→\n   148→  function walk(current: string): void {\n   149→    let entries: string[];\n   150→    try {\n   151→      entries = readdirSync(current);\n   152→    } catch {\n   153→      // IGNORE: directory may not be readable\n   154→      return;\n   155→    }\n   156→\n   157→    for (const entry of entries) {\n   158→      if (isSkippedDir(entry)) continue;\n   159→\n   160→      const fullPath = join(current, entry);\n   161→      let stat;\n   162→      try {\n   163→        stat = statSync(fullPath);\n   164→      } catch {\n   165→        // IGNORE: file stat may fail, skip entry\n   166→        continue;\n   167→      }\n   168→\n   169→      if (stat.isDirectory()) {\n   170→        walk(fullPath);\n   171→      } else if (stat.isFile()) {\n   172→        const ext = getExtension(entry);\n   173→        if (SOURCE_EXTENSIONS.has(ext)) {\n   174→          if (isTestFile(entry) || current.includes('__tests__')) {\n   175→            testFiles++;\n   176→          } else {\n   177→            sourceFiles++;\n   178→          }\n   179→        }\n   180→      }\n   181→    }\n   182→  }\n   183→\n   184→  walk(fullModulePath);\n   185→  return { sourceFiles, testFiles };\n   186→}\n   187→\n   188→// ─── Artifact Detection (Task 1.5) ──────────────────────────────────────────\n   189→\n   190→/**\n   191→ * Detects BMAD artifacts in the project.\n   192→ */\n   193→function detectArtifacts(dir: string): DetectedArtifacts {\n   194→  const bmadPath = join(dir, '_bmad');\n   195→  const hasBmad = existsSync(bmadPath);\n   196→\n   197→  return {\n   198→    hasBmad,\n   199→    bmadPath: hasBmad ? relative(dir, bmadPath) || '_bmad' : null,\n   200→  };\n   201→}\n   202→\n   203→// ─── Codebase Scanning (Task 1.2, 1.6) ──────────────────────────────────────\n   204→\n   205→/**\n   206→ * Scans the codebase for modules, source files, and artifacts.\n   207→ * Reuses findModules() from doc-health.ts for module detection.\n   208→ * Directories below the threshold are not standalone modules —\n   209→ * findModules() already handles this by only returning directories\n   210→ * that meet the threshold.\n   211→ */\n   212→export function scanCodebase(\n   213→  dir: string,\n   214→  options?: { minModuleSize?: number },\n   215→): ScanResult {\n   216→  const threshold = options?.minModuleSize ?? DEFAULT_MIN_MODULE_SIZE;\n   217→\n   218→  // Use findModules from doc-health.ts — handles threshold, skips node_modules/.git,\n   219→  // and filters test files\n   220→  const modulePaths = findModules(dir, threshold);\n   221→\n   222→  // Build ModuleInfo for each detected module\n   223→  const modules: ModuleInfo[] = modulePaths.map(modPath => {\n   224→    const { sourceFiles, testFiles } = countModuleFiles(modPath, dir);\n   225→    return { path: modPath, sourceFiles, testFiles };\n   226→  });\n   227→\n   228→  // Count total source files across the entire project\n   229→  const totalSourceFiles = countSourceFiles(dir);\n   230→\n   231→  // Detect artifacts\n   232→  const artifacts = detectArtifacts(dir);\n   233→\n   234→  return { modules, totalSourceFiles, artifacts };\n   235→}\n   236→\n   237→// ─── Coverage Gap Analysis (Task 2) ─────────────────────────────────────────\n   238→\n   239→/**\n   240→ * Analyzes per-module coverage gaps by reading the coverage report\n   241→ * and mapping file paths to detected modules.\n   242→ */\n   243→export function analyzeCoverageGaps(\n   244→  modules: ModuleInfo[],\n   245→  dir?: string,\n   246→): CoverageGapReport {\n   247→  const baseDir = dir ?? process.cwd();\n   248→\n   249→  // Detect coverage tool\n   250→  const toolInfo = detectCoverageTool(baseDir);\n   251→\n   252→  if (toolInfo.tool === 'unknown') {\n   253→    // No coverage tool — return zero report\n   254→    return {\n   255→      overall: 0,\n   256→      modules: modules.map(m => ({\n   257→        path: m.path,\n   258→        coveragePercent: 0,\n   259→        uncoveredFileCount: m.sourceFiles,\n   260→      })),\n   261→      uncoveredFiles: modules.reduce((sum, m) => sum + m.sourceFiles, 0),\n   262→    };\n   263→  }\n   264→\n   265→  // Get overall coverage from parsed report (don't run tests, just read report)\n   266→  const overall = parseCoverageReport(baseDir, toolInfo.reportFormat);\n   267→\n   268→  // Try to read per-file coverage data for module breakdown\n   269→  const perFileCoverage = readPerFileCoverage(baseDir, toolInfo.reportFormat);\n   270→\n   271→  let totalUncovered = 0;\n   272→  const moduleCoverage: ModuleCoverageInfo[] = modules.map(mod => {\n   273→    if (perFileCoverage === null) {\n   274→      // No per-file data — use overall for all modules\n   275→      return {\n   276→        path: mod.path,\n   277→        coveragePercent: overall,\n   278→        uncoveredFileCount: 0,\n   279→      };\n   280→    }\n   281→\n   282→    // Map files to this module\n   283→    let coveredSum = 0;\n   284→    let fileCount = 0;\n   285→    let uncoveredCount = 0;\n   286→\n   287→    for (const [filePath, pct] of perFileCoverage.entries()) {\n   288→      // Normalize file path to relative from project root\n   289→      const relPath = filePath.startsWith('/') ? relative(baseDir, filePath) : filePath;\n   290→      if (relPath.startsWith(mod.path + '/') || relPath === mod.path) {\n   291→        fileCount++;\n   292→        coveredSum += pct;\n   293→        if (pct === 0) {\n   294→          uncoveredCount++;\n   295→        }\n   296→      }\n   297→    }\n   298→\n   299→    totalUncovered += uncoveredCount;\n   300→\n   301→    const modulePercent = fileCount > 0 ? Math.round((coveredSum / fileCount) * 100) / 100 : 0;\n   302→    return {\n   303→      path: mod.path,\n   304→      coveragePercent: modulePercent,\n   305→      uncoveredFileCount: uncoveredCount,\n   306→    };\n   307→  });\n   308→\n   309→  // If we couldn't break down per-file, count uncovered as total source files with 0%\n   310→  if (perFileCoverage === null) {\n   311→    totalUncovered = 0;\n   312→  }\n   313→\n   314→  return {\n   315→    overall,\n   316→    modules: moduleCoverage,\n   317→    uncoveredFiles: totalUncovered,\n   318→  };\n   319→}\n   320→\n   321→/**\n   322→ * Reads per-file coverage data from the coverage report JSON.\n   323→ * Returns a Map of file path -> statement coverage percentage.\n   324→ */\n   325→function readPerFileCoverage(\n   326→  dir: string,\n   327→  format: string,\n   328→): Map<string, number> | null {\n   329→  if (format === 'vitest-json' || format === 'jest-json') {\n   330→    return readVitestPerFileCoverage(dir);\n   331→  }\n   332→  if (format === 'coverage-py-json') {\n   333→    return readPythonPerFileCoverage(dir);\n   334→  }\n   335→  return null;\n   336→}\n   337→\n   338→function readVitestPerFileCoverage(dir: string): Map<string, number> | null {\n   339→  const reportPath = join(dir, 'coverage', 'coverage-summary.json');\n   340→  if (!existsSync(reportPath)) return null;\n   341→\n   342→  try {\n   343→    const report = JSON.parse(readFileSync(reportPath, 'utf-8')) as Record<\n   344→      string,\n   345→      { statements?: { pct?: number } }\n   346→    >;\n   347→\n   348→    const result = new Map<string, number>();\n   349→    for (const [key, value] of Object.entries(report)) {\n   350→      if (key === 'total') continue;\n   351→      result.set(key, value.statements?.pct ?? 0);\n   352→    }\n   353→    return result;\n   354→  } catch {\n   355→    // IGNORE: coverage report may not exist or be malformed\n   356→    return null;\n   357→  }\n   358→}\n   359→\n   360→function readPythonPerFileCoverage(dir: string): Map<string, number> | null {\n   361→  const reportPath = join(dir, 'coverage.json');\n   362→  if (!existsSync(reportPath)) return null;\n   363→\n   364→  try {\n   365→    const report = JSON.parse(readFileSync(reportPath, 'utf-8')) as {\n   366→      files?: Record<string, { summary?: { percent_covered?: number } }>;\n   367→    };\n   368→\n   369→    if (!report.files) return null;\n   370→\n   371→    const result = new Map<string, number>();\n   372→    for (const [key, value] of Object.entries(report.files)) {\n   373→      result.set(key, value.summary?.percent_covered ?? 0);\n   374→    }\n   375→    return result;\n   376→  } catch {\n   377→    // IGNORE: Python coverage report may not exist or be malformed\n   378→    return null;\n   379→  }\n   380→}\n   381→\n   382→// ─── Documentation Audit (Task 3) ───────────────────────────────────────────\n   383→\n   384→const AUDIT_DOCUMENTS = ['README.md', 'AGENTS.md', 'ARCHITECTURE.md'];\n   385→\n   386→/**\n   387→ * Audits project documentation for presence and staleness.\n   388→ * Checks README.md, AGENTS.md, ARCHITECTURE.md, docs/ directory.\n   389→ */\n   390→export function auditDocumentation(dir?: string): DocAuditResult {\n   391→  const root = dir ?? process.cwd();\n   392→  const documents: DocAuditEntry[] = [];\n   393→\n   394→  // Check standard documentation files\n   395→  for (const docName of AUDIT_DOCUMENTS) {\n   396→    const docPath = join(root, docName);\n   397→\n   398→    if (!existsSync(docPath)) {\n   399→      documents.push({ name: docName, grade: 'missing', path: null });\n   400→      continue;\n   401→    }\n   402→\n   403→    // Check staleness — compare against src/ or project source\n   404→    const srcDir = join(root, 'src');\n   405→    const codeDir = existsSync(srcDir) ? srcDir : root;\n   406→    const stale = isDocStale(docPath, codeDir);\n   407→\n   408→    documents.push({\n   409→      name: docName,\n   410→      grade: stale ? 'stale' : 'present',\n   411→      path: docName,\n   412→    });\n   413→  }\n   414→\n   415→  // Check docs/ directory\n   416→  const docsDir = join(root, 'docs');\n   417→  if (existsSync(docsDir)) {\n   418→    try {\n   419→      const stat = statSync(docsDir);\n   420→      if (stat.isDirectory()) {\n   421→        documents.push({ name: 'docs/', grade: 'present', path: 'docs/' });\n   422→      }\n   423→    } catch {\n   424→      // IGNORE: docs/ directory stat failed, treat as missing\n   425→      documents.push({ name: 'docs/', grade: 'missing', path: null });\n   426→    }\n   427→  } else {\n   428→    documents.push({ name: 'docs/', grade: 'missing', path: null });\n   429→  }\n   430→\n   431→  // Check docs/index.md\n   432→  const indexPath = join(root, 'docs', 'index.md');\n   433→  if (existsSync(indexPath)) {\n   434→    // Check staleness against source code\n   435→    const srcDir = join(root, 'src');\n   436→    const indexCodeDir = existsSync(srcDir) ? srcDir : root;\n   437→    const indexStale = isDocStale(indexPath, indexCodeDir);\n   438→    documents.push({\n   439→      name: 'docs/index.md',\n   440→      grade: indexStale ? 'stale' : 'present',\n   441→      path: 'docs/index.md',\n   442→    });\n   443→  } else {\n   444→    documents.push({ name: 'docs/index.md', grade: 'missing', path: null });\n   445→  }\n   446→\n   447→  // Generate summary string\n   448→  const summaryParts = documents\n   449→    .filter(d => !d.name.startsWith('docs/'))\n   450→    .map(d => `${d.name}(${d.grade})`);\n   451→  const summary = summaryParts.join(' ');\n   452→\n   453→  return { documents, summary };\n   454→}\n   455→"}]},"parent_tool_use_id":"toolu_01MaiZ71xHuWaWxP6B1wGjKe","session_id":"3fcb2b1c-e710-401b-91ab-b64a3e9a3996","uuid":"d486ef0d-eed5-4837-bed4-e7b2858d20d7","timestamp":"2026-03-25T06:52:57.687Z"}
