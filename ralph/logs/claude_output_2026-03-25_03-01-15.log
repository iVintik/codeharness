d of throwing on unexpected error', async () => {\n   449→    // Force an unexpected error by making detectStacks throw\n   450→    mockDetectStacks.mockImplementation(() => { throw new Error('kaboom'); });\n   451→    writeFileSync(join(testDir, 'package.json'), '{}');\n   452→    const result = await initProject({\n   453→      projectDir: testDir,\n   454→      frontend: true,\n   455→      database: true,\n   456→      api: true,\n   457→      observability: false,\n   458→    });\n   459→    expect(result.success).toBe(false);\n   460→    if (!result.success) {\n   461→      expect(result.error).toContain('kaboom');\n   462→    }\n   463→  });\n   464→});\n   465→\n   466→describe('initProject — multi-stack orchestration', () => {\n   467→  const defaultOpts = {\n   468→    projectDir: '', // set in beforeEach via testDir\n   469→    frontend: true,\n   470→    database: true,\n   471→    api: true,\n   472→    observability: true,\n   473→  };\n   474→\n   475→  function makeOpts(overrides: Partial<typeof defaultOpts> = {}) {\n   476→    return { ...defaultOpts, projectDir: testDir, ...overrides };\n   477→  }\n   478→\n   479→  it('calls getCoverageTool() once per detected stack and stores tools map (Task 6)', async () => {\n   480→    writeFileSync(join(testDir, 'package.json'), '{}');\n   481→    writeFileSync(join(testDir, 'Cargo.toml'), '[package]\\nname = \"test\"');\n   482→    mockDetectStacks.mockReturnValue([\n   483→      { stack: 'nodejs', dir: '.' },\n   484→      { stack: 'rust', dir: '.' },\n   485→    ]);\n   486→    mockGetCoverageTool.mockClear();\n   487→\n   488→    await initProject(makeOpts({ observability: false }));\n   489→\n   490→    // getCoverageTool called for each stack in the loop + once for primary stack backward compat\n   491→    const calls = mockGetCoverageTool.mock.calls.map(c => c[0]);\n   492→    expect(calls).toContain('nodejs');\n   493→    expect(calls).toContain('rust');\n   494→\n   495→    // Verify per-stack tools