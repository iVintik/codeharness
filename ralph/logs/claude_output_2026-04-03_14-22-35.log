{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VuXwkH29NnwkfvSciavpeC","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach, afterEach } from 'vitest';\n2\timport { mkdtempSync, mkdirSync, rmSync, readdirSync, chmodSync, existsSync, writeFileSync } from 'node:fs';\n3\timport { join } from 'node:path';\n4\timport { tmpdir, platform } from 'node:os';\n5\timport {\n6\t  writeOutputContract,\n7\t  readOutputContract,\n8\t  formatContractAsPromptContext,\n9\t  buildPromptWithContractContext,\n10\t} from '../output-contract.js';\n11\timport type { OutputContract } from '../types.js';\n12\t\n13\t// --- Helpers ---\n14\t\n15\tfunction makeContract(overrides: Partial<OutputContract> = {}): OutputContract {\n16\t  return {\n17\t    version: 1,\n18\t    taskName: 'implement',\n19\t    storyId: '13-1',\n20\t    driver: 'claude-code',\n21\t    model: 'opus-4',\n22\t    timestamp: '2026-04-03T12:00:00Z',\n23\t    cost_usd: 0.42,\n24\t    duration_ms: 12345,\n25\t    changedFiles: ['src/lib/agents/output-contract.ts'],\n26\t    testResults: { passed: 10, failed: 0, coverage: 95.5 },\n27\t    output: 'All tasks complete.',\n28\t    acceptanceCriteria: [\n29\t      { id: 'AC1', description: 'Module exports write/read', status: 'passed' },\n30\t    ],\n31\t    ...overrides,\n32\t  };\n33\t}\n34\t\n35\tdescribe('output-contract', () => {\n36\t  let tmpDir: string;\n37\t\n38\t  beforeEach(() => {\n39\t    tmpDir = mkdtempSync(join(tmpdir(), 'output-contract-test-'));\n40\t  });\n41\t\n42\t  afterEach(() => {\n43\t    rmSync(tmpDir, { recursive: true, force: true });\n44\t  });\n45\t\n46\t  // AC #1, #2: writeOutputContract creates file at correct path\n47\t  it('writes contract to {taskName}-{storyId}.json', () => {\n48\t    const contract = makeContract();\n49\t    writeOutputContract(contract, tmpDir);\n50\t\n51\t    const expectedFile = join(tmpDir, 'implement-13-1.json');\n52\t    expect(existsSync(expectedFile)).toBe(true);\n53\t  });\n54\t\n55\t  // AC #2: atomic write — no .tmp file remains\n56\t  it('does not leave .tmp file after successful write', () => {\n57\t    const contract = makeContract();\n58\t    writeOutputContract(contract, tmpDir);\n59\t\n60\t    const files = readdirSync(tmpDir);\n61\t    const tmpFiles = files.filter((f) => f.endsWith('.tmp'));\n62\t    expect(tmpFiles).toHaveLength(0);\n63\t  });\n64\t\n65\t  // AC #3: readOutputContract returns deserialized contract with all fields\n66\t  it('round-trips all fields correctly', () => {\n67\t    const contract = makeContract();\n68\t    writeOutputContract(contract, tmpDir);\n69\t\n70\t    const result = readOutputContract('implement', '13-1', tmpDir);\n71\t    expect(result).not.toBeNull();\n72\t    expect(result!.version).toBe(1);\n73\t    expect(result!.taskName).toBe('implement');\n74\t    expect(result!.storyId).toBe('13-1');\n75\t    expect(result!.driver).toBe('claude-code');\n76\t    expect(result!.model).toBe('opus-4');\n77\t    expect(result!.timestamp).toBe('2026-04-03T12:00:00Z');\n78\t    expect(result!.cost_usd).toBe(0.42);\n79\t    expect(result!.duration_ms).toBe(12345);\n80\t    expect(result!.changedFiles).toEqual(['src/lib/agents/output-contract.ts']);\n81\t    expect(result!.testResults).toEqual({ passed: 10, failed: 0, coverage: 95.5 });\n82\t    expect(result!.output).toBe('All tasks complete.');\n83\t    expect(result!.acceptanceCriteria).toEqual([\n84\t      { id: 'AC1', description: 'Module exports write/read', status: 'passed' },\n85\t    ]);\n86\t  });\n87\t\n88\t  // AC #4: readOutputContract returns null when file does not exist\n89\t  it('returns null when contract file does not exist', () => {\n90\t    const result = readOutputContract('nonexistent', 'story-99', tmpDir);\n91\t    expect(result).toBeNull();\n92\t  });\n93\t\n94\t  // AC #5: null values preserved on round-trip\n95\t  it('preserves null values for cost_usd and testResults', () => {\n96\t    const contract = makeContract({ cost_usd: null, testResults: null });\n97\t    writeOutputContract(contract, tmpDir);\n98\t\n99\t    const result = readOutputContract('implement', '13-1', tmpDir);\n100\t    expect(result).not.toBeNull();\n101\t    expect(result!.cost_usd).toBeNull();\n102\t    expect(result!.testResults).toBeNull();\n103\t  });\n104\t\n105\t  // AC #7: creates directory recursively\n106\t  it('creates target directory recursively when it does not exist', () => {\n107\t    const deepDir = join(tmpDir, 'a', 'b', 'c', 'contracts');\n108\t    const contract = makeContract();\n109\t    writeOutputContract(contract, deepDir);\n110\t\n111\t    const result = readOutputContract('implement', '13-1', deepDir);\n112\t    expect(result).not.toBeNull();\n113\t    expect(result!.taskName).toBe('implement');\n114\t  });\n115\t\n116\t  // AC #9: throws descriptive error on write failure\n117\t  it.skipIf(platform() === 'win32')(\n118\t    'throws descriptive error including file path on write failure',\n119\t    () => {\n120\t      // Create a read-only directory to trigger write failure\n121\t      const readOnlyDir = join(tmpDir, 'readonly');\n122\t      mkdirSync(readOnlyDir, { recursive: true });\n123\t      chmodSync(readOnlyDir, 0o444);\n124\t\n125\t      const contract = makeContract();\n126\t      expect(() => writeOutputContract(contract, readOnlyDir)).toThrow(\n127\t        /Failed to write output contract/,\n128\t      );\n129\t      expect(() => writeOutputContract(contract, readOnlyDir)).toThrow(/implement-13-1\\.json/);\n130\t\n131\t      // Restore permissions for cleanup\n132\t      chmodSync(readOnlyDir, 0o755);\n133\t    },\n134\t  );\n135\t\n136\t  // Input validation: rejects path traversal in taskName\n137\t  it('rejects taskName containing path separators', () => {\n138\t    const contract = makeContract({ taskName: '../../../etc/passwd' });\n139\t    expect(() => writeOutputContract(contract, tmpDir)).toThrow(/invalid path characters/);\n140\t  });\n141\t\n142\t  // Input validation: rejects path traversal in storyId\n143\t  it('rejects storyId containing path separators', () => {\n144\t    const contract = makeContract({ storyId: '../secret' });\n145\t    expect(() => writeOutputContract(contract, tmpDir)).toThrow(/invalid path characters/);\n146\t  });\n147\t\n148\t  // Input validation: rejects empty taskName\n149\t  it('rejects empty taskName', () => {\n150\t    const contract = makeContract({ taskName: '' });\n151\t    expect(() => writeOutputContract(contract, tmpDir)).toThrow(/non-empty string/);\n152\t  });\n153\t\n154\t  // Input validation: rejects empty storyId\n155\t  it('rejects empty storyId', () => {\n156\t    const contract = makeContract({ storyId: '  ' });\n157\t    expect(() => writeOutputContract(contract, tmpDir)).toThrow(/non-empty string/);\n158\t  });\n159\t\n160\t  // Read validation: rejects empty taskName\n161\t  it('readOutputContract rejects empty taskName', () => {\n162\t    expect(() => readOutputContract('', '13-1', tmpDir)).toThrow(/non-empty string/);\n163\t  });\n164\t\n165\t  // Error handling: corrupted JSON on read\n166\t  it('throws descriptive error when contract file contains invalid JSON', () => {\n167\t    const filePath = join(tmpDir, 'implement-13-1.json');\n168\t    writeFileSync(filePath, '{not valid json!!!', 'utf-8');\n169\t\n170\t    expect(() => readOutputContract('implement', '13-1', tmpDir)).toThrow(\n171\t      /Failed to read output contract/,\n172\t    );\n173\t  });\n174\t\n175\t  // AC #8: performance — 1MB round-trip within 1 second\n176\t  it('round-trips a ~1MB contract within 1 second', () => {\n177\t    const largeOutput = 'x'.repeat(1_000_000);\n178\t    const contract = makeContract({ output: largeOutput });\n179\t\n180\t    const start = performance.now();\n181\t    writeOutputContract(contract, tmpDir);\n182\t    const result = readOutputContract('implement', '13-1', tmpDir);\n183\t    const elapsed = performance.now() - start;\n184\t\n185\t    expect(result).not.toBeNull();\n186\t    expect(result!.output).toHaveLength(1_000_000);\n187\t    expect(elapsed).toBeLessThan(1000);\n188\t  });\n189\t\n190\t  // AC #6: JSON Schema validates a correct contract\n191\t  describe('JSON Schema validation', () => {\n192\t    // We use Ajv for schema validation in tests\n193\t    it('validates a correct contract against the schema', async () => {\n194\t      const Ajv = (await import('ajv')).default;\n195\t      const { readFileSync } = await import('node:fs');\n196\t      const schemaPath = join(\n197\t        import.meta.dirname,\n198\t        '..',\n199\t        '..',\n200\t        '..',\n201\t        'schemas',\n202\t        'output-contract.schema.json',\n203\t      );\n204\t      const schema = JSON.parse(readFileSync(schemaPath, 'utf-8'));\n205\t      const ajv = new Ajv();\n206\t      const validate = ajv.compile(schema);\n207\t\n208\t      const contract = makeContract();\n209\t      const valid = validate(contract);\n210\t      expect(valid).toBe(true);\n211\t    });\n212\t\n213\t    it('rejects a contract missing required fields', async () => {\n214\t      const Ajv = (await import('ajv')).default;\n215\t      const { readFileSync } = await import('node:fs');\n216\t      const schemaPath = join(\n217\t        import.meta.dirname,\n218\t        '..',\n219\t        '..',\n220\t        '..',\n221\t        'schemas',\n222\t        'output-contract.schema.json',\n223\t      );\n224\t      const schema = JSON.parse(readFileSync(schemaPath, 'utf-8'));\n225\t      const ajv = new Ajv();\n226\t      const validate = ajv.compile(schema);\n227\t\n228\t      const incomplete = { version: 1, taskName: 'test' };\n229\t      const valid = validate(incomplete);\n230\t      expect(valid).toBe(false);\n231\t      expect(validate.errors).not.toBeNull();\n232\t      expect(validate.errors!.length).toBeGreaterThan(0);\n233\t    });\n234\t  });\n235\t\n236\t  // AC #1: barrel exports\n237\t  it('is exported from barrel index', async () => {\n238\t    const barrel = await import('../index.js');\n239\t    expect(typeof barrel.writeOutputContract).toBe('function');\n240\t    expect(typeof barrel.readOutputContract).toBe('function');\n241\t  });\n242\t\n243\t  // --- Story 13-2: formatContractAsPromptContext ---\n244\t\n245\t  describe('formatContractAsPromptContext', () => {\n246\t    it('returns a string containing header with task name, driver, model, cost, duration, timestamp', () => {\n247\t      const contract = makeContract();\n248\t      const result = formatContractAsPromptContext(contract);\n249\t\n250\t      expect(result).toContain('implement');\n251\t      expect(result).toContain('claude-code');\n252\t      expect(result).toContain('opus-4');\n253\t      expect(result).toContain('$0.42');\n254\t      expect(result).toContain('12.3s');\n255\t      expect(result).toContain('2026-04-03T12:00:00Z');\n256\t    });\n257\t\n258\t    it('formats Changed Files section listing each file', () => {\n259\t      const contract = makeContract({\n260\t        changedFiles: ['src/api/users.ts', 'src/api/users.test.ts'],\n261\t      });\n262\t      const result = formatContractAsPromptContext(contract);\n263\t\n264\t      expect(result).toContain('### Changed Files');\n265\t      expect(result).toContain('- src/api/users.ts');\n266\t      expect(result).toContain('- src/api/users.test.ts');\n267\t    });\n268\t\n269\t    it('formats Test Results section with passed, failed, and coverage', () => {\n270\t      const contract = makeContract({\n271\t        testResults: { passed: 12, failed: 0, coverage: 98.5 },\n272\t      });\n273\t      const result = formatContractAsPromptContext(contract);\n274\t\n275\t      expect(result).toContain('### Test Results');\n276\t      expect(result).toContain('**Passed:** 12');\n277\t      expect(result).toContain('**Failed:** 0');\n278\t      expect(result).toContain('**Coverage:** 98.5%');\n279\t    });\n280\t\n281\t    it('shows \"No test results available\" when testResults is null', () => {\n282\t      const contract = makeContract({ testResults: null });\n283\t      const result = formatContractAsPromptContext(contract);\n284\t\n285\t      expect(result).toContain('### Test Results');\n286\t      expect(result).toContain('No test results available');\n287\t    });\n288\t\n289\t    it('formats Acceptance Criteria section listing each AC with id, description, status', () => {\n290\t      const contract = makeContract({\n291\t        acceptanceCriteria: [\n292\t          { id: 'AC1', description: 'User can register', status: 'implemented' },\n293\t          { id: 'AC2', description: 'User can login', status: 'passed' },\n294\t        ],\n295\t      });\n296\t      const result = formatContractAsPromptContext(contract);\n297\t\n298\t      expect(result).toContain('### Acceptance Criteria');\n299\t      expect(result).toContain('**AC1** (implemented): User can register');\n300\t      expect(result).toContain('**AC2** (passed): User can login');\n301\t    });\n302\t\n303\t    it('handles empty changedFiles and null testResults without crashing', () => {\n304\t      const contract = makeContract({\n305\t        changedFiles: [],\n306\t        testResults: null,\n307\t      });\n308\t      const result = formatContractAsPromptContext(contract);\n309\t\n310\t      expect(typeof result).toBe('string');\n311\t      expect(result.length).toBeGreaterThan(0);\n312\t      expect(result).toContain('### Changed Files');\n313\t      expect(result).toContain('None');\n314\t      expect(result).toContain('No test results available');\n315\t    });\n316\t\n317\t    it('handles empty acceptanceCriteria array', () => {\n318\t      const contract = makeContract({ acceptanceCriteria: [] });\n319\t      const result = formatContractAsPromptContext(contract);\n320\t\n321\t      expect(result).toContain('### Acceptance Criteria');\n322\t      expect(result).toContain('None');\n323\t    });\n324\t\n325\t    it('truncates output field > 2000 characters with [truncated] marker', () => {\n326\t      const longOutput = 'x'.repeat(3000);\n327\t      const contract = makeContract({ output: longOutput });\n328\t      const result = formatContractAsPromptContext(contract);\n329\t\n330\t      expect(result).toContain('[truncated]');\n331\t      // The output section should not contain the full 3000 chars\n332\t      expect(result).not.toContain('x'.repeat(2001));\n333\t    });\n334\t\n335\t    it('does NOT truncate output field <= 2000 characters', () => {\n336\t      const shortOutput = 'y'.repeat(2000);\n337\t      const contract = makeContract({ output: shortOutput });\n338\t      const result = formatContractAsPromptContext(contract);\n339\t\n340\t      expect(result).not.toContain('[truncated]');\n341\t      expect(result).toContain(shortOutput);\n342\t    });\n343\t\n344\t    it('shows \"None\" for empty output', () => {\n345\t      const contract = makeContract({ output: '' });\n346\t      const result = formatContractAsPromptContext(contract);\n347\t\n348\t      expect(result).toContain('### Output Summary');\n349\t      expect(result).toContain('None');\n350\t    });\n351\t\n352\t    it('handles null cost_usd gracefully', () => {\n353\t      const contract = makeContract({ cost_usd: null });\n354\t      const result = formatContractAsPromptContext(contract);\n355\t\n356\t      expect(result).toContain('**Cost:** N/A');\n357\t    });\n358\t\n359\t    it('handles null coverage in testResults', () => {\n360\t      const contract = makeContract({\n361\t        testResults: { passed: 5, failed: 1, coverage: null },\n362\t      });\n363\t      const result = formatContractAsPromptContext(contract);\n364\t\n365\t      expect(result).toContain('**Coverage:** N/A');\n366\t    });\n367\t  });\n368\t\n369\t  // --- Story 13-2: buildPromptWithContractContext ---\n370\t\n371\t  describe('buildPromptWithContractContext', () => {\n372\t    it('returns basePrompt unchanged when contract is null', () => {\n373\t      const base = 'Implement story 13-2';\n374\t      const result = buildPromptWithContractContext(base, null);\n375\t      expect(result).toBe(base);\n376\t    });\n377\t\n378\t    it('appends formatted context with separator when contract is provided', () => {\n379\t      const base = 'Implement story 13-2';\n380\t      const contract = makeContract();\n381\t      const result = buildPromptWithContractContext(base, contract);\n382\t\n383\t      expect(result).toContain(base);\n384\t      expect(result).toContain('---');\n385\t      expect(result).toContain('## Previous Task Context');\n386\t      expect(result).toContain('### Context from Previous Task');\n387\t    });\n388\t\n389\t    it('preserves the base prompt at the beginning', () => {\n390\t      const base = 'Implement story 13-2';\n391\t      const contract = makeContract();\n392\t      const result = buildPromptWithContractContext(base, contract);\n393\t\n394\t      expect(result.startsWith(base)).toBe(true);\n395\t    });\n396\t\n397\t    it('round-trip: all key contract fields appear in the combined prompt', () => {\n398\t      const base = 'Implement story 13-2';\n399\t      const contract = makeContract({\n400\t        taskName: 'implement',\n401\t        driver: 'codex',\n402\t        model: 'gpt-4',\n403\t        changedFiles: ['src/main.ts'],\n404\t        testResults: { passed: 8, failed: 2, coverage: 75.0 },\n405\t        output: 'Completed with warnings.',\n406\t        acceptanceCriteria: [\n407\t          { id: 'AC1', description: 'Auth works', status: 'passed' },\n408\t        ],\n409\t      });\n410\t      const result = buildPromptWithContractContext(base, contract);\n411\t\n412\t      expect(result).toContain('implement');\n413\t      expect(result).toContain('codex');\n414\t      expect(result).toContain('gpt-4');\n415\t      expect(result).toContain('src/main.ts');\n416\t      expect(result).toContain('**Passed:** 8');\n417\t      expect(result).toContain('**Failed:** 2');\n418\t      expect(result).toContain('75%');\n419\t      expect(result).toContain('Completed with warnings.');\n420\t      expect(result).toContain('AC1');\n421\t      expect(result).toContain('Auth works');\n422\t    });\n423\t  });\n424\t\n425\t  // --- Story 13-2: barrel exports for new functions ---\n426\t\n427\t  it('exports formatContractAsPromptContext and buildPromptWithContractContext from barrel', async () => {\n428\t    const barrel = await import('../index.js');\n429\t    expect(typeof barrel.formatContractAsPromptContext).toBe('function');\n430\t    expect(typeof barrel.buildPromptWithContractContext).toBe('function');\n431\t  });\n432\t});\n433\t"}]},"parent_tool_use_id":"toolu_01C5MehsTfY23j2CBRX28n4h","session_id":"8f19e005-5742-4a5a-a61f-d8a88dc16bec","uuid":"f3f3c06d-7bf8-4dd7-be63-94a4a1d884f5","timestamp":"2026-04-03T10:31:59.824Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TA6zPvdWCCiYvkuZVTaJEi","type":"tool_result","content":"1\t/**\n2\t * Public API for the agents subsystem.\n3\t *\n4\t * Re-exports types (story 10-1), stream parser functions/types,\n5\t * and the driver factory (story 10-2).\n6\t */\n7\t\n8\t// New types (Epic 10)\n9\texport type {\n10\t  AgentDriver,\n11\t  DriverHealth,\n12\t  DriverCapabilities,\n13\t  DispatchOpts,\n14\t  ErrorCategory,\n15\t  OutputContract,\n16\t  TestResults,\n17\t  ACStatus,\n18\t} from './types.js';\n19\t\n20\t// Deprecated types — kept for backward compatibility until story 10-3\n21\t/** @deprecated Use `DispatchOpts` instead. */\n22\texport type { SpawnOpts } from './types.js';\n23\t/** @deprecated Use `AsyncIterable<StreamEvent>` from `dispatch()` instead. */\n24\texport type { AgentProcess } from './types.js';\n25\t/** @deprecated Use `StreamEvent` from `stream-parser.ts` instead. */\n26\texport type { AgentEvent } from './types.js';\n27\t\n28\t// Stream parser\n29\texport { parseStreamLine } from './stream-parser.js';\n30\texport type {\n31\t  StreamEvent,\n32\t  ToolStartEvent,\n33\t  ToolInputEvent,\n34\t  ToolCompleteEvent,\n35\t  TextEvent,\n36\t  RetryEvent,\n37\t  ResultEvent,\n38\t} from './stream-parser.js';\n39\t\n40\t// --- Driver Factory ---\n41\t\n42\texport { getDriver, registerDriver, listDrivers, resetDrivers } from './drivers/factory.js';\n43\t\n44\t// --- Model Resolution ---\n45\t\n46\texport { resolveModel } from './model-resolver.js';\n47\t\n48\t// --- Output Contract ---\n49\t\n50\texport {\n51\t  writeOutputContract,\n52\t  readOutputContract,\n53\t  formatContractAsPromptContext,\n54\t  buildPromptWithContractContext,\n55\t} from './output-contract.js';\n56\t"}]},"parent_tool_use_id":"toolu_01C5MehsTfY23j2CBRX28n4h","session_id":"8f19e005-5742-4a5a-a61f-d8a88dc16bec","uuid":"619fdf8d-e40d-42bc-b023-6af26861d555","timestamp":"2026-04-03T10:31:59.769Z"}
