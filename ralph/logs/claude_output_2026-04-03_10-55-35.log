{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013t1Lihahfc8Zkxi2rBuPRE","type":"tool_result","content":"40\t\n41\texport interface ResultEvent {\n42\t  readonly type: 'result';\n43\t  readonly cost: number;\n44\t  readonly sessionId: string;\n45\t  /** Normalized cost in USD for multi-driver comparison. */\n46\t  readonly cost_usd?: number | null;\n47\t}\n48\t\n49\t/** Discriminated union of all stream events the parser can emit. */\n50\texport type StreamEvent =\n51\t  | ToolStartEvent\n52\t  | ToolInputEvent\n53\t  | ToolCompleteEvent\n54\t  | TextEvent\n55\t  | RetryEvent\n56\t  | ResultEvent;"}]},"parent_tool_use_id":"toolu_01WS3YvqeZ2mgtciSgM5MVh6","session_id":"ccf790f5-4b27-4b46-b089-256c4e0022f0","uuid":"d5c378d5-bef2-4793-a3f4-f754c5100b6a","timestamp":"2026-04-03T07:07:01.256Z"}
