{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q1X8QXs3nbYdMd2X3H1f98","type":"tool_result","content":"     1→/**\n     2→ * Sprint state — read/write unified sprint-state.json with atomic writes.\n     3→ * Also generates sprint-status.yaml as a derived human-readable view.\n     4→ */\n     5→\n     6→import { readFileSync, writeFileSync, renameSync, existsSync, unlinkSync } from 'node:fs';\n     7→import { join, dirname } from 'node:path';\n     8→import { ok, fail } from '../../types/result.js';\n     9→import type { Result } from '../../types/result.js';\n    10→import type { SprintState, SprintStateAny, StoryStatus, StoryState, EpicState } from '../../types/state.js';\n    11→import type { StoryDetail, RunProgressUpdate } from './types.js';\n    12→import { migrateFromOldFormat, migrateV1ToV2, parseStoryRetriesRecord, parseFlaggedStoriesList } from './migration.js';\n    13→\n    14→/** Result of state reconciliation */\n    15→export interface ReconciliationResult {\n    16→  readonly corrections: string[];\n    17→  readonly stateChanged: boolean;\n    18→}\n    19→\n    20→/** Resolve project root (directory containing package.json) */\n    21→function projectRoot(): string {\n    22→  return process.cwd();\n    23→}\n    24→\n    25→/** Path to the sprint state file */\n    26→export function statePath(): string {\n    27→  return join(projectRoot(), 'sprint-state.json');\n    28→}\n    29→\n    30→/** Path to the temporary file used for atomic writes */\n    31→function tmpPath(): string {\n    32→  return join(projectRoot(), '.sprint-state.json.tmp');\n    33→}\n    34→\n    35→/** Path to the sprint-status.yaml file (derived view) */\n    36→export function sprintStatusYamlPath(): string {\n    37→  return join(projectRoot(), '_bmad-output', 'implementation-artifacts', 'sprint-status.yaml');\n    38→}\n    39→\n    40→/** Return an empty default SprintState (v2) */\n    41→export function defaultState(): SprintState {\n    42→  return {\n    43→    version: 2,\n    44→    sprint: {\n    45→      total: 0,\n    46→      done: 0,\n    47→      failed: 0,\n    48→      blocked: 0,\n    49→      inProgress: null,\n    50→    },\n    51→    stories: {},\n    52→    retries: {},\n    53→    flagged: [],\n    54→    epics: {},\n    55→    session: {\n    56→      active: false,\n    57→      startedAt: null,\n    58→      iteration: 0,\n    59→      elapsedSeconds: 0,\n    60→    },\n    61→    observability: {\n    62→      statementCoverage: null,\n    63→      branchCoverage: null,\n    64→      functionCoverage: null,\n    65→      lineCoverage: null,\n    66→    },\n    67→    run: {\n    68→      active: false,\n    69→      startedAt: null,\n    70→      iteration: 0,\n    71→      cost: 0,\n    72→      completed: [],\n    73→      failed: [],\n    74→      currentStory: null,\n    75→      currentPhase: null,\n    76→      lastAction: null,\n    77→      acProgress: null,\n    78→    },\n    79→    actionItems: [],\n    80→  };\n    81→}\n    82→\n    83→/** Return a default StoryState */\n    84→function defaultStoryState(): StoryState {\n    85→  return {\n    86→    status: 'backlog',\n    87→    attempts: 0,\n    88→    lastAttempt: null,\n    89→    lastError: null,\n    90→    proofPath: null,\n    91→    acResults: null,\n    92→  };\n    93→}\n    94→\n    95→/**\n    96→ * Derive a flat story-key → status map from sprint state.\n    97→ * This replaces the old `readSprintStatus()` which parsed YAML.\n    98→ * Only includes story keys (digit-digit-name pattern), not epic keys.\n    99→ */\n   100→export function getStoryStatusesFromState(state: SprintState): Record<string, string> {\n   101→  const result: Record<string, string> = {};\n   102→  for (const [key, story] of Object.entries(state.stories)) {\n   103→    result[key] = story.status;\n   104→  }\n   105→  return result;\n   106→}\n   107→\n   108→/**\n   109→ * Map internal StoryStatus values to sprint-status.yaml status strings.\n   110→ * Most map 1:1, but 'ready' maps to 'ready-for-dev' for YAML compatibility.\n   111→ */\n   112→function yamlStatus(status: StoryStatus): string {\n   113→  if (status === 'ready') return 'ready-for-dev';\n   114→  return status;\n   115→}\n   116→\n   117→/**\n   118→ * Generate sprint-status.yaml content from sprint state.\n   119→ * Groups stories by epic prefix and produces the same YAML structure\n   120→ * that existed as the hand-maintained file.\n   121→ */\n   122→export function generateSprintStatusYaml(state: SprintState): string {\n   123→  const lines: string[] = [\n   124→    '# codeharness Sprint Status (auto-generated from sprint-state.json)',\n   125→    `# generated: ${new Date().toISOString().slice(0, 10)}`,\n   126→    '# This file is a derived view — do NOT edit manually.',\n   127→    '# Source of truth: sprint-state.json',\n   128→    '',\n   129→    'development_status:',\n   130→  ];\n   131→\n   132→  // Group stories by epic prefix (first number segment)\n   133→  const epicGroups = new Map<string, string[]>();\n   134→  const sortedKeys = Object.keys(state.stories).sort((a, b) => {\n   135→    // Sort by epic number, then story number\n   136→    const [aEpic, aStory] = parseStoryKey(a);\n   137→    const [bEpic, bStory] = parseStoryKey(b);\n   138→    if (aEpic !== bEpic) return aEpic - bEpic;\n   139→    return aStory - bStory;\n   140→  });\n   141→\n   142→  for (const key of sortedKeys) {\n   143→    const epicNum = parseStoryKey(key)[0];\n   144→    const epicKey = String(epicNum);\n   145→    if (!epicGroups.has(epicKey)) {\n   146→      epicGroups.set(epicKey, []);\n   147→    }\n   148→    epicGroups.get(epicKey)!.push(key);\n   149→  }\n   150→\n   151→  // Emit each epic group\n   152→  for (const [epicKey, storyKeys] of epicGroups) {\n   153→    lines.push('');\n   154→    lines.push(`  # Epic ${epicKey}`);\n   155→\n   156→    // Compute epic status from stories\n   157→    const allDone = storyKeys.every(k => state.stories[k].status === 'done');\n   158→    const epicStatus = allDone ? 'done' : 'backlog';\n   159→    lines.push(`  epic-${epicKey}: ${epicStatus}`);\n   160→\n   161→    for (const key of storyKeys) {\n   162→      const story = state.stories[key];\n   163→      lines.push(`  ${key}: ${yamlStatus(story.status)}`);\n   164→    }\n   165→  }\n   166→\n   167→  lines.push('');\n   168→  return lines.join('\\n');\n   169→}\n   170→\n   171→/**\n   172→ * Parse a story key into [epicNumber, storyNumber].\n   173→ * e.g. \"11-2-sprint-status-yaml-derived-view\" → [11, 2]\n   174→ */\n   175→function parseStoryKey(key: string): [number, number] {\n   176→  const match = key.match(/^(\\d+)-(\\d+)/);\n   177→  if (!match) return [Infinity, Infinity];\n   178→  return [parseInt(match[1], 10), parseInt(match[2], 10)];\n   179→}\n   180→\n   181→/**\n   182→ * Write the derived sprint-status.yaml from current state.\n   183→ * Best-effort: failures are silently ignored since this is a convenience view.\n   184→ */\n   185→function writeSprintStatusYaml(state: SprintState): void {\n   186→  try {\n   187→    const yamlPath = sprintStatusYamlPath();\n   188→    // Only write if the directory exists (project has been set up)\n   189→    const dir = dirname(yamlPath);\n   190→    if (!existsSync(dir)) return;\n   191→    const content = generateSprintStatusYaml(state);\n   192→    writeFileSync(yamlPath, content, 'utf-8');\n   193→  } catch {\n   194→    // Best-effort: YAML view is not critical\n   195→  }\n   196→}\n   197→\n   198→/**\n   199→ * Write state to disk atomically: write to tmp, then rename.\n   200→ * Also regenerates sprint-status.yaml as a derived view.\n   201→ */\n   202→export function writeStateAtomic(state: SprintState): Result<void> {\n   203→  try {\n   204→    const data = JSON.stringify(state, null, 2) + '\\n';\n   205→    const tmp = tmpPath();\n   206→    const final = statePath();\n   207→    writeFileSync(tmp, data, 'utf-8');\n   208→    renameSync(tmp, final);\n   209→    // Regenerate YAML view after successful state write\n   210→    writeSprintStatusYaml(state);\n   211→    return ok(undefined);\n   212→  } catch (err: unknown) {\n   213→    const msg = err instanceof Error ? err.message : String(err);\n   214→    return fail(`Failed to write sprint state: ${msg}`);\n   215→  }\n   216→}\n   217→\n   218→/**\n   219→ * Read and parse sprint-state.json.\n   220→ * If the file does not exist, attempt migration from old files.\n   221→ * If no old files exist either, return defaultState().\n   222→ * Automatically migrates v1 state to v2.\n   223→ */\n   224→export function getSprintState(): Result<SprintState> {\n   225→  const fp = statePath();\n   226→\n   227→  if (existsSync(fp)) {\n   228→    try {\n   229→      const raw = readFileSync(fp, 'utf-8');\n   230→      const parsed = JSON.parse(raw) as Record<string, unknown>;\n   231→      const version = parsed.version as number | undefined;\n   232→\n   233→      // Already v2 — merge with defaults and return\n   234→      if (version === 2) {\n   235→        const defaults = defaultState();\n   236→        const run = parsed.run as Record<string, unknown> | undefined;\n   237→        const sprint = parsed.sprint as Record<string, unknown> | undefined;\n   238→        const session = parsed.session as Record<string, unknown> | undefined;\n   239→        const observability = parsed.observability as Record<string, unknown> | undefined;\n   240→        const state: SprintState = {\n   241→          ...(parsed as unknown as SprintState),\n   242→          sprint: {\n   243→            ...defaults.sprint,\n   244→            ...(sprint as unknown as SprintState['sprint']),\n   245→          },\n   246→          run: {\n   247→            ...defaults.run,\n   248→            ...(run as unknown as SprintState['run']),\n   249→          },\n   250→          session: {\n   251→            ...defaults.session,\n   252→            ...(session as unknown as SprintState['session']),\n   253→          },\n   254→          observability: {\n   255→            ...defaults.observability,\n   256→            ...(observability as unknown as SprintState['observability']),\n   257→          },\n   258→          retries: (parsed.retries as Record<string, number>) ?? {},\n   259→          flagged: (parsed.flagged as string[]) ?? [],\n   260→          epics: (parsed.epics as Record<string, import('../../types/state.js').EpicState>) ?? {},\n   261→        };\n   262→        return ok(state);\n   263→      }\n   264→\n   265→      // v1 or missing version — migrate to v2\n   266→      const v1State = parsed as unknown as import('../../types/state.js').SprintStateV1;\n   267→      const migrated = migrateV1ToV2(v1State);\n   268→      const writeResult = writeStateAtomic(migrated);\n   269→      if (!writeResult.success) {\n   270→        return fail(writeResult.error);\n   271→      }\n   272→      return ok(migrated);\n   273→    } catch (err: unknown) {\n   274→      const msg = err instanceof Error ? err.message : String(err);\n   275→      return fail(`Failed to read sprint state: ${msg}`);\n   276→    }\n   277→  }\n   278→\n   279→  // No sprint-state.json — try migration from old scattered files\n   280→  const migrationResult = migrateFromOldFormat();\n   281→  if (migrationResult.success) {\n   282→    return migrationResult;\n   283→  }\n   284→\n   285→  // Migration found nothing or failed — return default\n   286→  return ok(defaultState());\n   287→}\n   288→\n   289→/** Recompute sprint summary counts from story data */\n   290→export function computeSprintCounts(\n   291→  stories: Record<string, StoryState>,\n   292→): SprintState['sprint'] {\n   293→  let total = 0;\n   294→  let done = 0;\n   295→  let failed = 0;\n   296→  let blocked = 0;\n   297→  let inProgress: string | null = null;\n   298→\n   299→  for (const [key, story] of Object.entries(stories)) {\n   300→    total++;\n   301→    if (story.status === 'done') done++;\n   302→    else if (story.status === 'failed') failed++;\n   303→    else if (story.status === 'blocked') blocked++;\n   304→    else if (story.status === 'in-progress') inProgress = key;\n   305→  }\n   306→\n   307→  return { total, done, failed, blocked, inProgress };\n   308→}\n   309→\n   310→/**\n   311→ * Update a single story's status in sprint-state.json.\n   312→ * Reads current state, merges update, writes atomically.\n   313→ */\n   314→export function updateStoryStatus(\n   315→  key: string,\n   316→  status: StoryStatus,\n   317→  detail?: StoryDetail,\n   318→): Result<void> {\n   319→  const stateResult = getSprintState();\n   320→  if (!stateResult.success) {\n   321→    return fail(stateResult.error);\n   322→  }\n   323→\n   324→  const current = stateResult.data;\n   325→  const existingStory = current.stories[key] ?? defaultStoryState();\n   326→\n   327→  const isNewAttempt = status === 'in-progress';\n   328→\n   329→  const updatedStory: StoryState = {\n   330→    ...existingStory,\n   331→    status,\n   332→    attempts: isNewAttempt\n   333→      ? existingStory.attempts + 1\n   334→      : existingStory.attempts,\n   335→    lastAttempt: isNewAttempt\n   336→      ? new Date().toISOString()\n   337→      : existingStory.lastAttempt,\n   338→    lastError: detail?.error ?? existingStory.lastError,\n   339→    proofPath: detail?.proofPath ?? existingStory.proofPath,\n   340→    acResults: existingStory.acResults,\n   341→  };\n   342→\n   343→  const updatedStories = { ...current.stories, [key]: updatedStory };\n   344→  const updatedSprint = computeSprintCounts(updatedStories);\n   345→\n   346→  const updatedState: SprintState = {\n   347→    ...current,\n   348→    sprint: updatedSprint,\n   349→    stories: updatedStories,\n   350→  };\n   351→\n   352→  return writeStateAtomic(updatedState);\n   353→}\n   354→\n   355→/**\n   356→ * Update live run progress fields in sprint-state.json.\n   357→ * Only provided fields are updated; omitted fields retain their current values.\n   358→ */\n   359→export function updateRunProgress(update: RunProgressUpdate): Result<void> {\n   360→  const stateResult = getSprintState();\n   361→  if (!stateResult.success) {\n   362→    return fail(stateResult.error);\n   363→  }\n   364→\n   365→  const current = stateResult.data;\n   366→  const updatedRun = {\n   367→    ...current.run,\n   368→    ...(update.currentStory !== undefined && { currentStory: update.currentStory }),\n   369→    ...(update.currentPhase !== undefined && { currentPhase: update.currentPhase }),\n   370→    ...(update.lastAction !== undefined && { lastAction: update.lastAction }),\n   371→    ...(update.acProgress !== undefined && { acProgress: update.acProgress }),\n   372→  };\n   373→\n   374→  const updatedState: SprintState = {\n   375→    ...current,\n   376→    run: updatedRun,\n   377→  };\n   378→\n   379→  return writeStateAtomic(updatedState);\n   380→}\n   381→\n   382→/**\n   383→ * Clear all live run progress fields to null.\n   384→ * Called when a story completes or fails.\n   385→ */\n   386→export function clearRunProgress(): Result<void> {\n   387→  const stateResult = getSprintState();\n   388→  if (!stateResult.success) {\n   389→    return fail(stateResult.error);\n   390→  }\n   391→\n   392→  const current = stateResult.data;\n   393→  const updatedState: SprintState = {\n   394→    ...current,\n   395→    run: {\n   396→      ...current.run,\n   397→      currentStory: null,\n   398→      currentPhase: null,\n   399→      lastAction: null,\n   400→      acProgress: null,\n   401→    },\n   402→  };\n   403→\n   404→  return writeStateAtomic(updatedState);\n   405→}\n   406→\n   407→/**\n   408→ * Reconcile sprint state on session start.\n   409→ * Merges orphaned files, validates epic consistency, regenerates YAML.\n   410→ * Best-effort: returns corrections made; callers should log them.\n   411→ */\n   412→export function reconcileState(): Result<ReconciliationResult> {\n   413→  try {\n   414→    // 1. Read current state (handles v1→v2 migration internally)\n   415→    const stateResult = getSprintState();\n   416→    if (!stateResult.success) {\n   417→      return fail(stateResult.error);\n   418→    }\n   419→\n   420→    // Work with a mutable copy\n   421→    const state: SprintState = JSON.parse(JSON.stringify(stateResult.data));\n   422→    const corrections: string[] = [];\n   423→    let changed = false;\n   424→\n   425→    // 2. Merge orphaned .story_retries file\n   426→    const retriesPath = join(projectRoot(), 'ralph', '.story_retries');\n   427→    if (existsSync(retriesPath)) {\n   428→      try {\n   429→        const content = readFileSync(retriesPath, 'utf-8');\n   430→        const fileRetries = parseStoryRetriesRecord(content);\n   431→        const mergedRetries = { ...state.retries };\n   432→        for (const [key, count] of Object.entries(fileRetries)) {\n   433→          if (count > (mergedRetries[key] ?? 0)) {\n   434→            mergedRetries[key] = count;\n   435→            changed = true;\n   436→          }\n   437→        }\n   438→        (state as { retries: Record<string, number> }).retries = mergedRetries;\n   439→        unlinkSync(retriesPath);\n   440→        corrections.push('merged .story_retries into sprint-state.json');\n   441→      } catch {\n   442→        // Malformed file — delete it and move on\n   443→        try { unlinkSync(retriesPath); } catch { /* ignore */ }\n   444→        corrections.push('removed malformed .story_retries file');\n   445→      }\n   446→    }\n   447→\n   448→    // 3. Merge orphaned .flagged_stories file\n   449→    const flaggedPath = join(projectRoot(), 'ralph', '.flagged_stories');\n   450→    if (existsSync(flaggedPath)) {\n   451→      try {\n   452→        const content = readFileSync(flaggedPath, 'utf-8');\n   453→        const fileKeys = parseFlaggedStoriesList(content);\n   454→        const existing = new Set(state.flagged);\n   455→        const merged = [...state.flagged];\n   456→        for (const key of fileKeys) {\n   457→          if (!existing.has(key)) {\n   458→            merged.push(key);\n   459→            existing.add(key);\n   460→            changed = true;\n   461→          }\n   462→        }\n   463→        (state as { flagged: string[] }).flagged = merged;\n   464→        unlinkSync(flaggedPath);\n   465→        corrections.push('merged .flagged_stories into sprint-state.json');\n   466→      } catch {\n   467→        // Malformed file — delete it and move on\n   468→        try { unlinkSync(flaggedPath); } catch { /* ignore */ }\n   469→        corrections.push('removed malformed .flagged_stories file');\n   470→      }\n   471→    }\n   472→\n   473→    // 4. Validate epic consistency — ensure every story's epic prefix has an epic entry\n   474→    const epicStories = new Map<string, string[]>();\n   475→    for (const key of Object.keys(state.stories)) {\n   476→      const [epicNum] = parseStoryKey(key);\n   477→      if (epicNum === Infinity) continue; // Not a valid story key\n   478→      const epicKey = `epic-${epicNum}`;\n   479→      if (!epicStories.has(epicKey)) {\n   480→        epicStories.set(epicKey, []);\n   481→      }\n   482→      epicStories.get(epicKey)!.push(key);\n   483→    }\n   484→\n   485→    const updatedEpics: Record<string, import('../../types/state.js').EpicState> = { ...state.epics };\n   486→    for (const [epicKey, storyKeys] of epicStories) {\n   487→      if (!(epicKey in updatedEpics)) {\n   488→        // Compute epic status from its stories\n   489→        const total = storyKeys.length;\n   490→        const doneCount = storyKeys.filter(k => state.stories[k].status === 'done').length;\n   491→        const epicStatus = doneCount === total ? 'done' : 'in-progress';\n   492→        updatedEpics[epicKey] = {\n   493→          status: epicStatus,\n   494→          storiesTotal: total,\n   495→          storiesDone: doneCount,\n   496→        };\n   497→        changed = true;\n   498→        corrections.push(`created missing epic entry: ${epicKey}`);\n   499→      }\n   500→    }\n   501→    (state as { epics: Record<string, import('../../types/state.js').EpicState> }).epics = updatedEpics;\n   502→\n   503→    // 5. Always regenerate YAML (idempotent, cheap)\n   504→    writeSprintStatusYaml(state);\n   505→\n   506→    // 6. Write state atomically only if mutations were made\n   507→    if (changed) {\n   508→      const writeResult = writeStateAtomic(state);\n   509→      if (!writeResult.success) {\n   510→        return fail(writeResult.error);\n   511→      }\n   512→    }\n   513→\n   514→    // 7. Note YAML regeneration in corrections if any corrections were made\n   515→    if (corrections.length > 0) {\n   516→      corrections.push('regenerated sprint-status.yaml');\n   517→    }\n   518→\n   519→    return ok({ corrections, stateChanged: changed });\n   520→  } catch (err: unknown) {\n   521→    const msg = err instanceof Error ? err.message : String(err);\n   522→    return fail(`State reconciliation failed: ${msg}`);\n   523→  }\n   524→}\n   525→"}]},"parent_tool_use_id":"toolu_0184tJvxCPux1RS3fH2NtyBW","session_id":"01503c00-15e6-46f1-b837-b4628ff69656","uuid":"98908f02-7628-4388-aee6-6fd03448a083","timestamp":"2026-03-24T11:46:24.654Z"}
