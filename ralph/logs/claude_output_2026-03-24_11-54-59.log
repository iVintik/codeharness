{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0151FYxGA33xuKDEQyuJbm99","type":"tool_result","content":"     1→/**\n     2→ * Shared utility functions for stack providers.\n     3→ * Extracted from stack-detect.ts to avoid duplication across providers.\n     4→ */\n     5→\n     6→import { existsSync, readFileSync } from 'node:fs';\n     7→\n     8→/** Safely read and parse a JSON file. Returns null on any error. */\n     9→export function readJsonSafe(path: string): Record<string, unknown> | null {\n    10→  try {\n    11→    if (!existsSync(path)) return null;\n    12→    return JSON.parse(readFileSync(path, 'utf-8')) as Record<string, unknown>;\n    13→  } catch {\n    14→    return null;\n    15→  }\n    16→}\n    17→\n    18→/** Safely read a text file. Returns null on any error. */\n    19→export function readTextSafe(path: string): string | null {\n    20→  try {\n    21→    if (!existsSync(path)) return null;\n    22→    return readFileSync(path, 'utf-8');\n    23→  } catch {\n    24→    return null;\n    25→  }\n    26→}\n    27→\n    28→/** Collect all dependency names from a package.json object (dependencies + devDependencies). */\n    29→export function getNodeDeps(pkg: Record<string, unknown>): Set<string> {\n    30→  const deps = new Set<string>();\n    31→  for (const field of ['dependencies', 'devDependencies']) {\n    32→    const section = pkg[field] as Record<string, string> | undefined;\n    33→    if (section && typeof section === 'object') {\n    34→      for (const key of Object.keys(section)) {\n    35→        deps.add(key);\n    36→      }\n    37→    }\n    38→  }\n    39→  return deps;\n    40→}\n    41→"}]},"parent_tool_use_id":"toolu_01AYUK9c5QWsnPVHthUcsHao","session_id":"ec2bf7d9-1cd3-4665-9804-65790a3eadb3","uuid":"20e0dd6a-3a10-4f50-8f83-e1dd0b80b79c","timestamp":"2026-03-24T08:05:27.077Z"}
