{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Dypix1FjyujFPaXxLgix2D","type":"tool_result","content":"     1→/**\n     2→ * Sprint state — read/write unified sprint-state.json with atomic writes.\n     3→ */\n     4→\n     5→import { readFileSync, writeFileSync, renameSync, existsSync } from 'node:fs';\n     6→import { join } from 'node:path';\n     7→import { ok, fail } from '../../types/result.js';\n     8→import type { Result } from '../../types/result.js';\n     9→import type { SprintState, SprintStateAny, StoryStatus, StoryState } from '../../types/state.js';\n    10→import type { StoryDetail, RunProgressUpdate } from './types.js';\n    11→import { migrateFromOldFormat, migrateV1ToV2 } from './migration.js';\n    12→\n    13→/** Resolve project root (directory containing package.json) */\n    14→function projectRoot(): string {\n    15→  return process.cwd();\n    16→}\n    17→\n    18→/** Path to the sprint state file */\n    19→export function statePath(): string {\n    20→  return join(projectRoot(), 'sprint-state.json');\n    21→}\n    22→\n    23→/** Path to the temporary file used for atomic writes */\n    24→function tmpPath(): string {\n    25→  return join(projectRoot(), '.sprint-state.json.tmp');\n    26→}\n    27→\n    28→/** Return an empty default SprintState (v2) */\n    29→export function defaultState(): SprintState {\n    30→  return {\n    31→    version: 2,\n    32→    sprint: {\n    33→      total: 0,\n    34→      done: 0,\n    35→      failed: 0,\n    36→      blocked: 0,\n    37→      inProgress: null,\n    38→    },\n    39→    stories: {},\n    40→    retries: {},\n    41→    flagged: [],\n    42→    epics: {},\n    43→    session: {\n    44→      active: false,\n    45→      startedAt: null,\n    46→      iteration: 0,\n    47→      elapsedSeconds: 0,\n    48→    },\n    49→    observability: {\n    50→      statementCoverage: null,\n    51→      branchCoverage: null,\n    52→      functionCoverage: null,\n    53→      lineCoverage: null,\n    54→    },\n    55→    run: {\n    56→      active: false,\n    57→      startedAt: null,\n    58→      iteration: 0,\n    59→      cost: 0,\n    60→      completed: [],\n    61→      failed: [],\n    62→      currentStory: null,\n    63→      currentPhase: null,\n    64→      lastAction: null,\n    65→      acProgress: null,\n    66→    },\n    67→    actionItems: [],\n    68→  };\n    69→}\n    70→\n    71→/** Return a default StoryState */\n    72→function defaultStoryState(): StoryState {\n    73→  return {\n    74→    status: 'backlog',\n    75→    attempts: 0,\n    76→    lastAttempt: null,\n    77→    lastError: null,\n    78→    proofPath: null,\n    79→    acResults: null,\n    80→  };\n    81→}\n    82→\n    83→/**\n    84→ * Write state to disk atomically: write to tmp, then rename.\n    85→ */\n    86→export function writeStateAtomic(state: SprintState): Result<void> {\n    87→  try {\n    88→    const data = JSON.stringify(state, null, 2) + '\\n';\n    89→    const tmp = tmpPath();\n    90→    const final = statePath();\n    91→    writeFileSync(tmp, data, 'utf-8');\n    92→    renameSync(tmp, final);\n    93→    return ok(undefined);\n    94→  } catch (err: unknown) {\n    95→    const msg = err instanceof Error ? err.message : String(err);\n    96→    return fail(`Failed to write sprint state: ${msg}`);\n    97→  }\n    98→}\n    99→\n   100→/**\n   101→ * Read and parse sprint-state.json.\n   102→ * If the file does not exist, attempt migration from old files.\n   103→ * If no old files exist either, return defaultState().\n   104→ * Automatically migrates v1 state to v2.\n   105→ */\n   106→export function getSprintState(): Result<SprintState> {\n   107→  const fp = statePath();\n   108→\n   109→  if (existsSync(fp)) {\n   110→    try {\n   111→      const raw = readFileSync(fp, 'utf-8');\n   112→      const parsed = JSON.parse(raw) as Record<string, unknown>;\n   113→      const version = parsed.version as number | undefined;\n   114→\n   115→      // Already v2 — merge with defaults and return\n   116→      if (version === 2) {\n   117→        const defaults = defaultState();\n   118→        const run = parsed.run as Record<string, unknown> | undefined;\n   119→        const sprint = parsed.sprint as Record<string, unknown> | undefined;\n   120→        const session = parsed.session as Record<string, unknown> | undefined;\n   121→        const observability = parsed.observability as Record<string, unknown> | undefined;\n   122→        const state: SprintState = {\n   123→          ...(parsed as unknown as SprintState),\n   124→          sprint: {\n   125→            ...defaults.sprint,\n   126→            ...(sprint as unknown as SprintState['sprint']),\n   127→          },\n   128→          run: {\n   129→            ...defaults.run,\n   130→            ...(run as unknown as SprintState['run']),\n   131→          },\n   132→          session: {\n   133→            ...defaults.session,\n   134→            ...(session as unknown as SprintState['session']),\n   135→          },\n   136→          observability: {\n   137→            ...defaults.observability,\n   138→            ...(observability as unknown as SprintState['observability']),\n   139→          },\n   140→          retries: (parsed.retries as Record<string, number>) ?? {},\n   141→          flagged: (parsed.flagged as string[]) ?? [],\n   142→          epics: (parsed.epics as Record<string, import('../../types/state.js').EpicState>) ?? {},\n   143→        };\n   144→        return ok(state);\n   145→      }\n   146→\n   147→      // v1 or missing version — migrate to v2\n   148→      const v1State = parsed as unknown as import('../../types/state.js').SprintStateV1;\n   149→      const migrated = migrateV1ToV2(v1State);\n   150→      const writeResult = writeStateAtomic(migrated);\n   151→      if (!writeResult.success) {\n   152→        return fail(writeResult.error);\n   153→      }\n   154→      return ok(migrated);\n   155→    } catch (err: unknown) {\n   156→      const msg = err instanceof Error ? err.message : String(err);\n   157→      return fail(`Failed to read sprint state: ${msg}`);\n   158→    }\n   159→  }\n   160→\n   161→  // No sprint-state.json — try migration from old scattered files\n   162→  const migrationResult = migrateFromOldFormat();\n   163→  if (migrationResult.success) {\n   164→    return migrationResult;\n   165→  }\n   166→\n   167→  // Migration found nothing or failed — return default\n   168→  return ok(defaultState());\n   169→}\n   170→\n   171→/** Recompute sprint summary counts from story data */\n   172→export function computeSprintCounts(\n   173→  stories: Record<string, StoryState>,\n   174→): SprintState['sprint'] {\n   175→  let total = 0;\n   176→  let done = 0;\n   177→  let failed = 0;\n   178→  let blocked = 0;\n   179→  let inProgress: string | null = null;\n   180→\n   181→  for (const [key, story] of Object.entries(stories)) {\n   182→    total++;\n   183→    if (story.status === 'done') done++;\n   184→    else if (story.status === 'failed') failed++;\n   185→    else if (story.status === 'blocked') blocked++;\n   186→    else if (story.status === 'in-progress') inProgress = key;\n   187→  }\n   188→\n   189→  return { total, done, failed, blocked, inProgress };\n   190→}\n   191→\n   192→/**\n   193→ * Update a single story's status in sprint-state.json.\n   194→ * Reads current state, merges update, writes atomically.\n   195→ */\n   196→export function updateStoryStatus(\n   197→  key: string,\n   198→  status: StoryStatus,\n   199→  detail?: StoryDetail,\n   200→): Result<void> {\n   201→  const stateResult = getSprintState();\n   202→  if (!stateResult.success) {\n   203→    return fail(stateResult.error);\n   204→  }\n   205→\n   206→  const current = stateResult.data;\n   207→  const existingStory = current.stories[key] ?? defaultStoryState();\n   208→\n   209→  const isNewAttempt = status === 'in-progress';\n   210→\n   211→  const updatedStory: StoryState = {\n   212→    ...existingStory,\n   213→    status,\n   214→    attempts: isNewAttempt\n   215→      ? existingStory.attempts + 1\n   216→      : existingStory.attempts,\n   217→    lastAttempt: isNewAttempt\n   218→      ? new Date().toISOString()\n   219→      : existingStory.lastAttempt,\n   220→    lastError: detail?.error ?? existingStory.lastError,\n   221→    proofPath: detail?.proofPath ?? existingStory.proofPath,\n   222→    acResults: existingStory.acResults,\n   223→  };\n   224→\n   225→  const updatedStories = { ...current.stories, [key]: updatedStory };\n   226→  const updatedSprint = computeSprintCounts(updatedStories);\n   227→\n   228→  const updatedState: SprintState = {\n   229→    ...current,\n   230→    sprint: updatedSprint,\n   231→    stories: updatedStories,\n   232→  };\n   233→\n   234→  return writeStateAtomic(updatedState);\n   235→}\n   236→\n   237→/**\n   238→ * Update live run progress fields in sprint-state.json.\n   239→ * Only provided fields are updated; omitted fields retain their current values.\n   240→ */\n   241→export function updateRunProgress(update: RunProgressUpdate): Result<void> {\n   242→  const stateResult = getSprintState();\n   243→  if (!stateResult.success) {\n   244→    return fail(stateResult.error);\n   245→  }\n   246→\n   247→  const current = stateResult.data;\n   248→  const updatedRun = {\n   249→    ...current.run,\n   250→    ...(update.currentStory !== undefined && { currentStory: update.currentStory }),\n   251→    ...(update.currentPhase !== undefined && { currentPhase: update.currentPhase }),\n   252→    ...(update.lastAction !== undefined && { lastAction: update.lastAction }),\n   253→    ...(update.acProgress !== undefined && { acProgress: update.acProgress }),\n   254→  };\n   255→\n   256→  const updatedState: SprintState = {\n   257→    ...current,\n   258→    run: updatedRun,\n   259→  };\n   260→\n   261→  return writeStateAtomic(updatedState);\n   262→}\n   263→\n   264→/**\n   265→ * Clear all live run progress fields to null.\n   266→ * Called when a story completes or fails.\n   267→ */\n   268→export function clearRunProgress(): Result<void> {\n   269→  const stateResult = getSprintState();\n   270→  if (!stateResult.success) {\n   271→    return fail(stateResult.error);\n   272→  }\n   273→\n   274→  const current = stateResult.data;\n   275→  const updatedState: SprintState = {\n   276→    ...current,\n   277→    run: {\n   278→      ...current.run,\n   279→      currentStory: null,\n   280→      currentPhase: null,\n   281→      lastAction: null,\n   282→      acProgress: null,\n   283→    },\n   284→  };\n   285→\n   286→  return writeStateAtomic(updatedState);\n   287→}\n   288→"}]},"parent_tool_use_id":"toolu_01WHShw3WenWAwXLiDPJ4eCA","session_id":"bd5543f6-f408-4218-88bd-6e3bcdc37563","uuid":"56d478f1-b0f1-4329-8bff-bdd632328f71","timestamp":"2026-03-24T11:02:00.918Z"}
