 55→    service_name: 'test-project',\n    56→    mode: 'local-shared',\n    57→  };\n    58→  writeState(state, testDir);\n    59→}\n    60→\n    61→describe('installNodeOtlp', () => {\n    62→  it('installs OTLP packages via npm install', () => {\n    63→    mockExecFileSync.mockReturnValue(Buffer.from(''));\n    64→    const result = installNodeOtlp(testDir);\n    65→    expect(result.status).toBe('configured');\n    66→    expect(result.packages_installed).toBe(true);\n    67→    expect(mockExecFileSync).toHaveBeenCalledWith(\n    68→      'npm',\n    69→      expect.arrayContaining(['install', '@opentelemetry/auto-instrumentations-node']),\n    70→      expect.objectContaining({ cwd: testDir }),\n    71→    );\n    72→  });\n    73→\n    74→  it('returns failed when npm install fails', () => {\n    75→    mockExecFileSync.mockImplementation(() => {\n    76→      throw new Error('npm install failed');\n    77→    });\n    78→    const result = installNodeOtlp(testDir);\n    79→    expect(result.status).toBe('failed');\n    80→    expect(result.packages_installed).toBe(false);\n    81→    expect(result.error).toContain('Failed to install Node.js OTLP packages');\n    82→  });\n    83→\n    84→  it('truncates long error messages from npm install failures', () => {\n    85→    const longStderr = 'E'.repeat(500);\n    86→    mockExecFileSync.mockImplementation(() => {\n    87→      throw new Error(longStderr);\n    88→    });\n    89→    const result = installNodeOtlp(testDir);\n    90→    expect(result.error).toBeDefined();\n    91→    expect(result.error!.length).toBeLessThan(500);\n    92→    expect(result.error).toContain('(truncated)');\n    93→  });\n    94→\n    95→  it('includes all four OTLP packages in install command', () => {\n    96→    mockExecFileSync.mockReturnValue(Buffer.from(''));\n    97→    installNodeOtlp(testDir);\n    98→    const args = mockExecFileSync.mock.calls[0][1] as string[];\n    99→    expect(args).toContain('@opentelemetry/auto-instrumentations-node');\n   100→    expect(args).toContain('@opentelemetry/sdk-node');\n   101→    expect(args).toContain('@opentelemetry/exporter-trace-otlp-http');\n   102→    expect(args).toContain('@opentelemetry/exporter-metrics-otlp-http');\n   103→  });\n   104→});\n   105→\n   106→describe('patchNodeStartScript', () => {\n   107→  it('patches start script with --require flag', () => {\n   108→    writeFileSync(\n   109→      join(testDir, 'package.json'),\n   110→      JSON.stringify({\n   111→        name: 'test',\n   112→        scripts: { start: 'node dist/server.js' },\n   113→      }),\n   114→    );\n   115→\n   116→    const patched = patchNodeStartScript(testDir);\n   117→    expect(patched).toBe(true);\n   118→\n   119→    const pkg = JSON.parse(readFileSync(join(testDir, 'package.json'), 'utf-8'));\n   120→    expect(pkg.scripts['start:instrumented']).toContain('--require @opentelemetry/auto-instrumentations-node/register');\n   121→    expect(pkg.scripts['start:instrumented']).toContain('node dist/server.js');\n   122→    // Original start script is preserved\n   123→    expect(pkg.scripts.start).toBe('node dist/server.js');\n   124→  });\n   125→\n   126→  it('patches dev script when no start script exists', () => {\n   127→    writeFileSync(\n   128→      join(testDir, 'package.json'),\n   129→      JSON.stringify({\n   130→        name: 'test',\n   131→        scripts: { dev: 'ts-node src/index.ts' },\n   132→      }),\n   133→    );\n   134→\n   135→    const patched = patchNodeStartScript(testDir);\n   136→    expect(patched).toBe(true);\n   137→\n   138→    const pkg = JSON.parse(readFileSync(join(testDir, 'package.json'), 'utf-8'));\n   139→    expect(pkg.scripts['dev:instrumented']).toContain('--require');\n   140→  });\n   141→\n   142→  it('returns false when already patched (idempotent)', () => {\n   143→    // Simulate a previously patched package.json — the instrumented key already exists\n   144→    writeFileSync(\n   145→      join(testDir, 'package.json'),\n   146→      JSON.stringify({\n   147→        name: 'test',\n   148→        scripts: {\n   149→          start: 'node dist/server.js',\n   150→          'start:instrumented': \"NODE_OPTIONS='--require @opentelemetry/auto-instrumentations-node/register' node dist/server.js\",\n   151→        },\n   152→      }),\n   153→    );\n   154→\n   155→    const patched = patchNodeStartScript(testDir);\n   156→    expect(patched).toBe(false);\n   157→  });\n   158→\n   159→  it('returns false when no scripts section', () => {\n   160→    writeFileSync(join(testDir, 'package.json'), JSON.stringify({ name: 'test' }));\n   161→    const patched = patchNodeStartScript(testDir);\n   162→    expect(patched).toBe(false);\n   163→  });\n   164→\n   165→  it('returns false when no start or dev script', () => {\n   166→    writeFileSync(\n   167→      join(testDir, 'package.json'),\n   168→      JSON.stringify({ name: 'test', scripts: { build: 'tsc' } }),\n   169→    );\n   170→    const patched = patchNodeStartScript(testDir);\n   171→    expect(patched).toBe(false);\n   172→  });\n   173→\n   174→  it('returns false when no package.json', () => {\n   175→    const patched = patchNodeStartScript(testDir);\n   176→    expect(patched).toBe(false);\n   177→  });\n   178→\n   179→  it('returns false when package.json is malformed JSON', () => {\n   180→    writeFileSync(join(testDir, 'package.json'), '{ invalid json !!!');\n   181→    const patched = patchNodeStartScript(testDir);\n   182→    expect(patched).toBe(false);\n   183→  });\n   184→});\n   185→\n   186→describe('installPythonOtlp', () => {\n   187→  it('installs via pip when available', () => {\n   188→    mockExecFileSync.mockReturnValue(Buffer.from(''));\n   189→    const result = installPythonOtlp(testDir);\n   190→    expect(result.status).toBe('configured');\n   191→    expect(result.packages_installed).toBe(true);\n   192→  });\n   193→\n   194→  it('falls back to pipx when pip fails', () => {\n  