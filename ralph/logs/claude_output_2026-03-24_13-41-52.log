{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Kcj3nYJ3vCHdX4FVHvein3","type":"tool_result","content":"     1→import { execSync } from 'node:child_process';\n     2→import { existsSync, readFileSync } from 'node:fs';\n     3→import { join } from 'node:path';\n     4→import { ok, fail as failOut, info, warn } from './output.js';\n     5→import { readStateWithBody, writeState } from './state.js';\n     6→import { detectStack, getStackProvider } from './stacks/index.js';\n     7→import type { StackName } from './stacks/index.js';\n     8→\n     9→// ─── Types ───────────────────────────────────────────────────────────────────\n    10→\n    11→export interface CoverageToolInfo {\n    12→  tool: 'c8' | 'coverage.py' | 'cargo-tarpaulin' | 'unknown';\n    13→  runCommand: string;\n    14→  reportFormat: string;\n    15→}\n    16→\n    17→export interface CoverageResult {\n    18→  success: boolean;\n    19→  testsPassed: boolean;\n    20→  passCount: number;\n    21→  failCount: number;\n    22→  coveragePercent: number;\n    23→  rawOutput: string;\n    24→}\n    25→\n    26→export interface CoverageEvaluation {\n    27→  met: boolean;\n    28→  target: number;\n    29→  actual: number;\n    30→  delta: number | null;\n    31→  baseline: number | null;\n    32→}\n    33→\n    34→// ─── Coverage Tool Detection (Task 1) ────────────────────────────────────────\n    35→\n    36→export function detectCoverageTool(dir?: string): CoverageToolInfo {\n    37→  const baseDir = dir ?? process.cwd();\n    38→\n    39→  // Check state file hint first\n    40→  const stateHint = getStateToolHint(baseDir);\n    41→\n    42→  const stack = detectStack(baseDir);\n    43→  if (!stack) {\n    44→    warn('No recognized stack detected — cannot determine coverage tool');\n    45→    return { tool: 'unknown', runCommand: '', reportFormat: '' };\n    46→  }\n    47→\n    48→  const provider = getStackProvider(stack as StackName);\n    49→  if (!provider) {\n    50→    warn('No recognized stack detected — cannot determine coverage tool');\n    51→    return { tool: 'unknown', runCommand: '', reportFormat: '' };\n    52→  }\n    53→\n    54→  // Delegate to stack-specific detection via provider-keyed helper map\n    55→  const detector = coverageDetectors[provider.name];\n    56→  if (detector) {\n    57→    return detector(baseDir, stateHint);\n    58→  }\n    59→\n    60→  warn('No recognized stack detected — cannot determine coverage tool');\n    61→  return { tool: 'unknown', runCommand: '', reportFormat: '' };\n    62→}\n    63→\n    64→/** Stack-keyed coverage detection dispatchers (no stack string comparisons outside stacks/) */\n    65→const coverageDetectors: Record<string, (dir: string, stateHint: string | null) => CoverageToolInfo> = {\n    66→  nodejs: (dir, stateHint) => detectNodeCoverageTool(dir, stateHint),\n    67→  python: (dir) => detectPythonCoverageTool(dir),\n    68→  rust: (dir) => detectRustCoverageTool(dir),\n    69→};\n    70→\n    71→function detectRustCoverageTool(dir: string): CoverageToolInfo {\n    72→  // Check if cargo-tarpaulin is installed\n    73→  try {\n    74→    execSync('cargo tarpaulin --version', { stdio: 'pipe', timeout: 10_000 });\n    75→  } catch {\n    76→    warn('cargo-tarpaulin not installed — coverage detection unavailable');\n    77→    return { tool: 'unknown', runCommand: '', reportFormat: '' };\n    78→  }\n    79→\n    80→  // Detect workspace\n    81→  const cargoPath = join(dir, 'Cargo.toml');\n    82→  let isWorkspace = false;\n    83→  try {\n    84→    const cargoContent = readFileSync(cargoPath, 'utf-8');\n    85→    isWorkspace = /^\\[workspace\\]/m.test(cargoContent);\n    86→  } catch { /* not a workspace */ }\n    87→\n    88→  const wsFlag = isWorkspace ? ' --workspace' : '';\n    89→  return {\n    90→    tool: 'cargo-tarpaulin',\n    91→    runCommand: `cargo tarpaulin --out json --output-dir coverage/${wsFlag}`,\n    92→    reportFormat: 'tarpaulin-json',\n    93→  };\n    94→}\n    95→\n    96→function getStateToolHint(dir: string): string | null {\n    97→  try {\n    98→    const { state } = readStateWithBody(dir);\n    99→    return state.coverage.tool || null;\n   100→  } catch {\n   101→    return null;\n   102→  }\n   103→}\n   104→\n   105→function detectNodeCoverageTool(dir: string, stateHint: string | null): CoverageToolInfo {\n   106→  // Check for Vitest config files\n   107→  const hasVitestConfig =\n   108→    existsSync(join(dir, 'vitest.config.ts')) ||\n   109→    existsSync(join(dir, 'vitest.config.js'));\n   110→\n   111→  // Check package.json devDependencies\n   112→  const pkgPath = join(dir, 'package.json');\n   113→  let hasVitestCoverageV8 = false;\n   114→  let hasVitestCoverageIstanbul = false;\n   115→  let hasC8 = false;\n   116→  let hasJest = false;\n   117→  let pkgScripts: Record<string, string> = {};\n   118→\n   119→  if (existsSync(pkgPath)) {\n   120→    try {\n   121→      const pkg = JSON.parse(readFileSync(pkgPath, 'utf-8')) as {\n   122→        devDependencies?: Record<string, string>;\n   123→        dependencies?: Record<string, string>;\n   124→        scripts?: Record<string, string>;\n   125→      };\n   126→      const allDeps = { ...(pkg.dependencies ?? {}), ...(pkg.devDependencies ?? {}) };\n   127→      hasVitestCoverageV8 = '@vitest/coverage-v8' in allDeps;\n   128→      hasVitestCoverageIstanbul = '@vitest/coverage-istanbul' in allDeps;\n   129→      hasC8 = 'c8' in allDeps;\n   130→      hasJest = 'jest' in allDeps;\n   131→      pkgScripts = pkg.scripts ?? {};\n   132→    } catch {\n   133→      // Malformed package.json — continue with defaults\n   134→    }\n   135→  }\n   136→\n   137→  // Determine tool and run command\n   138→  if (hasVitestConfig || hasVitestCoverageV8 || hasVitestCoverageIstanbul) {\n   139→    const runCommand = getNodeTestCommand(pkgScripts, 'vitest');\n   140→    return { tool: 'c8', runCommand, reportFormat: 'vitest-json' };\n   141→  }\n   142→\n   143→  if (hasC8) {\n   144→    const runCommand = getNodeTestCommand(pkgScripts, 'c8');\n   145→    return { tool: 'c8', runCommand, reportFormat: 'vitest-json' };\n   146→  }\n   147→\n   148→  if (hasJest) {\n   149→    return {\n   150→      tool: 'c8',\n   151→      runCommand: 'npx jest --coverage --coverageReporters=json-summary',\n   152→      reportFormat: 'jest-json',\n   153→    };\n   154→  }\n   155→\n   156→  // State hint says c8 but nothing found — re-detect failed\n   157→  if (stateHint === 'c8') {\n   158→    warn('State indicates c8 but no Vitest/c8 found in project — re-detecting');\n   159→  }\n   160→\n   161→  warn('No Node.js coverage tool detected');\n   162→  return { tool: 'unknown', runCommand: '', reportFormat: '' };\n   163→}\n   164→\n   165→function getNodeTestCommand(scripts: Record<string, string>, runner: string): string {\n   166→  // Prefer package.json scripts in order: test:coverage -> test:unit -> test\n   167→  if (scripts['test:coverage']) {\n   168→    return 'npm run test:coverage';\n   169→  }\n   170→  if (scripts['test:unit']) {\n   171→    // Need to add --coverage flag\n   172→    if (runner === 'vitest') {\n   173→      return 'npx vitest run --coverage';\n   174→    }\n   175→    return `npm run test:unit`;\n   176→  }\n   177→  if (scripts['test']) {\n   178→    if (runner === 'vitest') {\n   179→      return 'npx vitest run --coverage';\n   180→    }\n   181→    return 'npm test';\n   182→  }\n   183→  if (runner === 'vitest') {\n   184→    return 'npx vitest run --coverage';\n   185→  }\n   186→  return 'npm test';\n   187→}\n   188→\n   189→function detectPythonCoverageTool(dir: string): CoverageToolInfo {\n   190→  // Check requirements.txt\n   191→  const reqPath = join(dir, 'requirements.txt');\n   192→  if (existsSync(reqPath)) {\n   193→    try {\n   194→      const content = readFileSync(reqPath, 'utf-8');\n   195→      if (content.includes('pytest-cov') || content.includes('coverage')) {\n   196→        return {\n   197→          tool: 'coverage.py',\n   198→          runCommand: 'coverage run -m pytest && coverage json',\n   199→          reportFormat: 'coverage-py-json',\n   200→        };\n   201→      }\n   202→    } catch {\n   203→      // Continue checking\n   204→    }\n   205→  }\n   206→\n   207→  // Check pyproject.toml\n   208→  const pyprojectPath = join(dir, 'pyproject.toml');\n   209→  if (existsSync(pyprojectPath)) {\n   210→    try {\n   211→      const content = readFileSync(pyprojectPath, 'utf-8');\n   212→      if (content.includes('pytest-cov') || content.includes('coverage')) {\n   213→        return {\n   214→          tool: 'coverage.py',\n   215→          runCommand: 'coverage run -m pytest && coverage json',\n   216→          reportFormat: 'coverage-py-json',\n   217→        };\n   218→      }\n   219→    } catch {\n   220→      // Continue checking\n   221→    }\n   222→  }\n   223→\n   224→  warn('No Python coverage tool detected');\n   225→  return { tool: 'unknown', runCommand: '', reportFormat: '' };\n   226→}\n   227→\n   228→export function getTestCommand(dir?: string): string {\n   229→  const toolInfo = detectCoverageTool(dir);\n   230→  return toolInfo.runCommand;\n   231→}\n   232→\n   233→// ─── Coverage Execution and Parsing (Task 2) ─────────────────────────────────\n   234→\n   235→export function runCoverage(dir?: string): CoverageResult {\n   236→  const baseDir = dir ?? process.cwd();\n   237→  const toolInfo = detectCoverageTool(baseDir);\n   238→\n   239→  if (toolInfo.tool === 'unknown' || !toolInfo.runCommand) {\n   240→    return {\n   241→      success: false,\n   242→      testsPassed: false,\n   243→      passCount: 0,\n   244→      failCount: 0,\n   245→      coveragePercent: 0,\n   246→      rawOutput: 'No coverage tool detected. Ensure your project has a test runner configured.',\n   247→    };\n   248→  }\n   249→\n   250→  let rawOutput = '';\n   251→  let testsPassed = true;\n   252→\n   253→  try {\n   254→    rawOutput = execSync(toolInfo.runCommand, {\n   255→      cwd: baseDir,\n   256→      encoding: 'utf-8',\n   257→      stdio: ['pipe', 'pipe', 'pipe'],\n   258→      timeout: 300_000, // 5 minute timeout\n   259→    });\n   260→  } catch (err: unknown) {\n   261→    const execError = err as { status?: number; stdout?: string; stderr?: string };\n   262→    testsPassed = false;\n   263→    rawOutput = (execError.stdout ?? '') + (execError.stderr ?? '');\n   264→\n   265→    if (!rawOutput) {\n   266→      return {\n   267→        success: false,\n   268→        testsPassed: false,\n   269→        passCount: 0,\n   270→        failCount: 0,\n   271→        coveragePercent: 0,\n   272→        rawOutput: 'Test command failed with no output',\n   273→      };\n   274→    }\n   275→  }\n   276→\n   277→  // Parse test counts from output\n   278→  const { passCount, failCount } = parseTestCounts(rawOutput);\n   279→\n   280→  // If we detected failures from output but exit code was 0, trust the output\n   281→  if (failCount > 0) {\n   282→    testsPassed = false;\n   283→  }\n   284→\n   285→  // Parse coverage from report file\n   286→  const coveragePercent = parseCoverageReport(baseDir, toolInfo.reportFormat);\n   287→\n   288→  return {\n   289→    success: true,\n   290→    testsPassed,\n   291→    passCount,\n   292→    failCount,\n   293→    coveragePercent,\n   294→    rawOutput,\n   295→  };\n   296→}\n   297→\n   298→export function parseCoverageReport(dir: string, format: string): number {\n   299→  if (format === 'vitest-json' || format === 'jest-json') {\n   300→    return parseVitestCoverage(dir);\n   301→  }\n   302→  if (format === 'coverage-py-json') {\n   303→    return parsePythonCoverage(dir);\n   304→  }\n   305→  if (format === 'tarpaulin-json') {\n   306→    return parseTarpaulinCoverage(dir);\n   307→  }\n   308→  return 0;\n   309→}\n   310→\n   311→function parseVitestCoverage(dir: string): number {\n   312→  const reportPath = findCoverageSummary(dir);\n   313→  if (!reportPath) {\n   314→    warn('Coverage report not found at coverage/coverage-summary.json');\n   315→    return 0;\n   316→  }\n   317→\n   318→  try {\n   319→    const report = JSON.parse(readFileSync(reportPath, 'utf-8')) as {\n   320→      total?: {\n   321→        statements?: { pct?: number };\n   322→        lines?: { pct?: number };\n   323→        branches?: { pct?: number };\n   324→        functions?: { pct?: number };\n   325→      };\n   326→    };\n   327→    return report.total?.statements?.pct ?? 0;\n   328→  } catch {\n   329→    warn('Failed to parse coverage report');\n   330→    return 0;\n   331→  }\n   332→}\n   333→\n   334→function parsePythonCoverage(dir: string): number {\n   335→  const reportPath = join(dir, 'coverage.json');\n   336→  if (!existsSync(reportPath)) {\n   337→    warn('Coverage report not found at coverage.json');\n   338→    return 0;\n   339→  }\n   340→\n   341→  try {\n   342→    const report = JSON.parse(readFileSync(reportPath, 'utf-8')) as {\n   343→      totals?: { percent_covered?: number };\n   344→    };\n   345→    return report.totals?.percent_covered ?? 0;\n   346→  } catch {\n   347→    warn('Failed to parse coverage report');\n   348→    return 0;\n   349→  }\n   350→}\n   351→\n   352→function parseTarpaulinCoverage(dir: string): number {\n   353→  const reportPath = join(dir, 'coverage', 'tarpaulin-report.json');\n   354→  if (!existsSync(reportPath)) {\n   355→    warn('Tarpaulin report not found at coverage/tarpaulin-report.json');\n   356→    return 0;\n   357→  }\n   358→  try {\n   359→    const report = JSON.parse(readFileSync(reportPath, 'utf-8')) as { coverage?: number };\n   360→    return report.coverage ?? 0;\n   361→  } catch {\n   362→    warn('Failed to parse tarpaulin coverage report');\n   363→    return 0;\n   364→  }\n   365→}\n   366→\n   367→export function parseTestCounts(output: string): { passCount: number; failCount: number } {\n   368→  // Vitest format: \"Tests  12 passed | 3 failed\"\n   369→  const vitestMatch = /Tests\\s+(\\d+)\\s+passed(?:\\s*\\|\\s*(\\d+)\\s+failed)?/i.exec(output);\n   370→  if (vitestMatch) {\n   371→    return {\n   372→      passCount: parseInt(vitestMatch[1], 10),\n   373→      failCount: vitestMatch[2] ? parseInt(vitestMatch[2], 10) : 0,\n   374→    };\n   375→  }\n   376→\n   377→  // Jest format: \"Tests:  3 failed, 12 passed, 15 total\"\n   378→  const jestMatch = /Tests:\\s*(?:(\\d+)\\s+failed,\\s*)?(\\d+)\\s+passed/i.exec(output);\n   379→  if (jestMatch) {\n   380→    return {\n   381→      passCount: parseInt(jestMatch[2], 10),\n   382→      failCount: jestMatch[1] ? parseInt(jestMatch[1], 10) : 0,\n   383→    };\n   384→  }\n   385→\n   386→  // cargo test format: \"test result: ok. 42 passed; 3 failed; 0 ignored\"\n   387→  // Workspace projects emit multiple test result lines (one per crate) — aggregate all.\n   388→  const cargoRegex = /test result:.*?(\\d+)\\s+passed;\\s*(\\d+)\\s+failed/gi;\n   389→  let cargoMatch = cargoRegex.exec(output);\n   390→  if (cargoMatch) {\n   391→    let totalPass = 0;\n   392→    let totalFail = 0;\n   393→    while (cargoMatch) {\n   394→      totalPass += parseInt(cargoMatch[1], 10);\n   395→      totalFail += parseInt(cargoMatch[2], 10);\n   396→      cargoMatch = cargoRegex.exec(output);\n   397→    }\n   398→    return { passCount: totalPass, failCount: totalFail };\n   399→  }\n   400→\n   401→  // pytest format: \"12 passed, 3 failed\"\n   402→  const pytestMatch = /(\\d+)\\s+passed(?:,\\s*(\\d+)\\s+failed)?/i.exec(output);\n   403→  if (pytestMatch) {\n   404→    return {\n   405→      passCount: parseInt(pytestMatch[1], 10),\n   406→      failCount: pytestMatch[2] ? parseInt(pytestMatch[2], 10) : 0,\n   407→    };\n   408→  }\n   409→\n   410→  return { passCount: 0, failCount: 0 };\n   411→}\n   412→\n   413→// ─── Check-only mode: read last coverage report without running tests ────────\n   414→\n   415→export function checkOnlyCoverage(dir?: string): CoverageResult {\n   416→  const baseDir = dir ?? process.cwd();\n   417→  const toolInfo = detectCoverageTool(baseDir);\n   418→\n   419→  if (toolInfo.tool === 'unknown') {\n   420→    return {\n   421→      success: false,\n   422→      testsPassed: false,\n   423→      passCount: 0,\n   424→      failCount: 0,\n   425→      coveragePercent: 0,\n   426→      rawOutput: 'No coverage tool detected',\n   427→    };\n   428→  }\n   429→\n   430→  const coveragePercent = parseCoverageReport(baseDir, toolInfo.reportFormat);\n   431→\n   432→  // Preserve existing tests_passed flag from state rather than blindly assuming true.\n   433→  // Check-only mode doesn't run tests, so it should not overwrite the flag.\n   434→  let testsPassed = true;\n   435→  try {\n   436→    const { state } = readStateWithBody(baseDir);\n   437→    testsPassed = state.session_flags.tests_passed;\n   438→  } catch {\n   439→    // No state file — default to true (optimistic for first-run check-only)\n   440→  }\n   441→\n   442→  return {\n   443→    success: true,\n   444→    testsPassed,\n   445→    passCount: 0,\n   446→    failCount: 0,\n   447→    coveragePercent,\n   448→    rawOutput: 'Check-only mode — read existing coverage report',\n   449→  };\n   450→}\n   451→\n   452→// ─── Coverage Evaluation and State Updates (Task 3) ──────────────────────────\n   453→\n   454→export function evaluateCoverage(result: CoverageResult, dir?: string): CoverageEvaluation {\n   455→  const baseDir = dir ?? process.cwd();\n   456→\n   457→  let target = 90;\n   458→  let baseline: number | null = null;\n   459→\n   460→  try {\n   461→    const { state } = readStateWithBody(baseDir);\n   462→    target = state.coverage.target ?? 90;\n   463→    baseline = state.coverage.baseline;\n   464→  } catch {\n   465→    // No state file — use defaults\n   466→  }\n   467→\n   468→  const actual = result.coveragePercent;\n   469→  const met = actual >= target;\n   470→\n   471→  // If baseline is null (first run), set it to current\n   472→  const effectiveBaseline = baseline ?? actual;\n   473→  const delta = baseline !== null ? actual - baseline : null;\n   474→\n   475→  return {\n   476→    met,\n   477→    target,\n   478→    actual,\n   479→    delta,\n   480→    baseline: effectiveBaseline,\n   481→  };\n   482→}\n   483→\n   484→export function updateCoverageState(\n   485→  result: CoverageResult,\n   486→  evaluation: CoverageEvaluation,\n   487→  dir?: string,\n   488→): void {\n   489→  const baseDir = dir ?? process.cwd();\n   490→  const { state, body } = readStateWithBody(baseDir);\n   491→\n   492→  state.session_flags.tests_passed = result.testsPassed;\n   493→  state.session_flags.coverage_met = evaluation.met;\n   494→  state.coverage.current = evaluation.actual;\n   495→\n   496→  // Set baseline on first run (when it was null)\n   497→  if (state.coverage.baseline === null) {\n   498→    state.coverage.baseline = evaluation.actual;\n   499→  }\n   500→\n   501→  writeState(state, baseDir, body);\n   502→}\n   503→\n   504→// ─── Per-file Coverage Floor Check ───────────────────────────────────────────\n   505→\n   506→export interface FileCoverageEntry {\n   507→  file: string;\n   508→  statements: number;\n   509→  branches: number;\n   510→  functions: number;\n   511→  lines: number;\n   512→}\n   513→\n   514→export interface PerFileCoverageResult {\n   515→  floor: number;\n   516→  violations: FileCoverageEntry[];\n   517→  totalFiles: number;\n   518→}\n   519→\n   520→/**\n   521→ * Checks per-file coverage against a minimum floor.\n   522→ * Reads coverage-summary.json and returns any files below the threshold.\n   523→ */\n   524→export function checkPerFileCoverage(floor: number, dir?: string): PerFileCoverageResult {\n   525→  const baseDir = dir ?? process.cwd();\n   526→  const reportPath = findCoverageSummary(baseDir);\n   527→\n   528→  if (!reportPath) {\n   529→    return { floor, violations: [], totalFiles: 0 };\n   530→  }\n   531→\n   532→  let report: Record<string, { statements?: { pct?: number }; branches?: { pct?: number }; functions?: { pct?: number }; lines?: { pct?: number } }>;\n   533→  try {\n   534→    report = JSON.parse(readFileSync(reportPath, 'utf-8')) as typeof report;\n   535→  } catch {\n   536→    warn('Failed to parse coverage-summary.json');\n   537→    return { floor, violations: [], totalFiles: 0 };\n   538→  }\n   539→\n   540→  const violations: FileCoverageEntry[] = [];\n   541→  let totalFiles = 0;\n   542→\n   543→  for (const [key, data] of Object.entries(report)) {\n   544→    if (key === 'total') continue;\n   545→    totalFiles++;\n   546→\n   547→    const stmts = data.statements?.pct ?? 0;\n   548→    const branches = data.branches?.pct ?? 0;\n   549→    const funcs = data.functions?.pct ?? 0;\n   550→    const lines = data.lines?.pct ?? 0;\n   551→\n   552→    if (stmts < floor) {\n   553→      // Extract relative path from absolute\n   554→      const relative = key.startsWith(baseDir)\n   555→        ? key.slice(baseDir.length + 1)\n   556→        : key;\n   557→\n   558→      violations.push({\n   559→        file: relative,\n   560→        statements: stmts,\n   561→        branches,\n   562→        functions: funcs,\n   563→        lines,\n   564→      });\n   565→    }\n   566→  }\n   567→\n   568→  // Sort worst first\n   569→  violations.sort((a, b) => a.statements - b.statements);\n   570→\n   571→  return { floor, violations, totalFiles };\n   572→}\n   573→\n   574→/**\n   575→ * Find coverage-summary.json — it may be at coverage/ or src/coverage/\n   576→ * depending on the vitest root config.\n   577→ */\n   578→function findCoverageSummary(dir: string): string | null {\n   579→  const candidates = [\n   580→    join(dir, 'coverage', 'coverage-summary.json'),\n   581→    join(dir, 'src', 'coverage', 'coverage-summary.json'),\n   582→  ];\n   583→  for (const p of candidates) {\n   584→    if (existsSync(p)) return p;\n   585→  }\n   586→  return null;\n   587→}\n   588→\n   589→export function formatCoverageOutput(evaluation: CoverageEvaluation): string[] {\n   590→  const lines: string[] = [];\n   591→\n   592→  if (evaluation.met) {\n   593→    lines.push(`[OK] Coverage: ${evaluation.actual}%`);\n   594→  } else {\n   595→    lines.push(`[FAIL] Coverage: ${evaluation.actual}% (target: ${evaluation.target}%)`);\n   596→  }\n   597→\n   598→  if (evaluation.delta !== null && evaluation.baseline !== null) {\n   599→    const sign = evaluation.delta >= 0 ? '+' : '';\n   600→    const before = evaluation.actual - evaluation.delta;\n   601→    lines.push(\n   602→      `[INFO] Coverage delta: ${sign}${evaluation.delta}% (${before}% -> ${evaluation.actual}%)`,\n   603→    );\n   604→  }\n   605→\n   606→  return lines;\n   607→}\n   608→\n   609→export function printCoverageOutput(\n   610→  result: CoverageResult,\n   611→  evaluation: CoverageEvaluation,\n   612→): void {\n   613→  // Print test results\n   614→  if (result.testsPassed) {\n   615→    ok(`Tests passed: ${result.passCount} passed`);\n   616→  } else {\n   617→    failOut(`Tests failed: ${result.passCount} passed, ${result.failCount} failed`);\n   618→  }\n   619→\n   620→  // Print coverage evaluation\n   621→  if (evaluation.met) {\n   622→    ok(`Coverage: ${evaluation.actual}%`);\n   623→  } else {\n   624→    failOut(`Coverage: ${evaluation.actual}% (target: ${evaluation.target}%)`);\n   625→  }\n   626→\n   627→  // Print delta if available\n   628→  if (evaluation.delta !== null && evaluation.baseline !== null) {\n   629→    const sign = evaluation.delta >= 0 ? '+' : '';\n   630→    const before = evaluation.actual - evaluation.delta;\n   631→    info(`Coverage delta: ${sign}${evaluation.delta}% (${before}% -> ${evaluation.actual}%)`);\n   632→  }\n   633→}\n   634→"}]},"parent_tool_use_id":"toolu_01NQFJhfdisZwxGgfMvJomZh","session_id":"01d3be87-3cff-45e1-920c-7390a9e4093c","uuid":"214dd4df-49e5-4e11-a9