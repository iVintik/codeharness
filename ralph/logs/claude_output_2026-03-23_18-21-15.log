{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012hGiv3dGFjE1daotjDTGHy","type":"tool_result","content":"     1→/**\n     2→ * Project initialization orchestrator.\n     3→ * Composes sub-steps: stack detection, deps, Docker, BMAD, beads, state, docs, OTLP.\n     4→ */\n     5→\n     6→import { existsSync } from 'node:fs';\n     7→import { basename } from 'node:path';\n     8→import { ok as okOutput, fail as failOutput, info, jsonOutput } from '../../lib/output.js';\n     9→import { detectStack, detectStacks, detectAppType } from '../../lib/stack-detect.js';\n    10→import { readState, writeState, getDefaultState, getStatePath } from '../../lib/state.js';\n    11→import type { HarnessState } from '../../lib/state.js';\n    12→import { instrumentProject } from '../../lib/otlp.js';\n    13→import type { Result } from '../../types/result.js';\n    14→import { ok, fail, isOk } from '../../types/result.js';\n    15→import type { InitOptions, InitResult } from './types.js';\n    16→import { checkDocker, setupDocker } from './docker-setup.js';\n    17→import { installDeps, verifyDeps } from './deps-install.js';\n    18→import { setupBmad, verifyBmadOnRerun } from './bmad-setup.js';\n    19→import { initializeBeads } from './beads-init.js';\n    20→import { scaffoldDocs, getCoverageTool, getStackLabel } from './docs-scaffold.js';\n    21→import { generateDockerfileTemplate } from './dockerfile-template.js';\n    22→\n    23→declare const __PKG_VERSION__: string;\n    24→const HARNESS_VERSION = typeof __PKG_VERSION__ !== 'undefined' ? __PKG_VERSION__ : '0.0.0-dev';\n    25→\n    26→/** Helper: build a fail-status InitResult for early returns */\n    27→function failResult(opts: InitOptions, error: string): InitResult {\n    28→  return {\n    29→    status: 'fail', stack: null, stacks: [], error,\n    30→    enforcement: { frontend: opts.frontend, database: opts.database, api: opts.api },\n    31→    documentation: { agents_md: 'skipped', docs_scaffold: 'skipped', readme: 'skipped' },\n    32→  };\n    33→}\n    34→\n    35→/** Output error and set exit code for validation/critical failures */\n    36→function emitError(error: string, isJson: boolean): void {\n    37→  if (isJson) { jsonOutput({ status: 'fail', error }); } else { failOutput(error); }\n    38→  process.exitCode = 1;\n    39→}\n    40→\n    41→/** Main project initialization orchestrator. Never throws — returns fail() on unexpected errors. */\n    42→export async function initProject(opts: InitOptions): Promise<Result<InitResult>> {\n    43→  try {\n    44→    return await initProjectInner(opts);\n    45→  } catch (err) {\n    46→    const message = err instanceof Error ? err.message : String(err);\n    47→    return fail(`Unexpected init error: ${message}`);\n    48→  }\n    49→}\n    50→\n    51→async function initProjectInner(opts: InitOptions): Promise<Result<InitResult>> {\n    52→  const { projectDir, json: isJson = false } = opts;\n    53→  const result: InitResult = {\n    54→    status: 'ok', stack: null, stacks: [],\n    55→    enforcement: { frontend: opts.frontend, database: opts.database, api: opts.api },\n    56→    documentation: { agents_md: 'skipped', docs_scaffold: 'skipped', readme: 'skipped' },\n    57→  };\n    58→\n    59→  // --- Idempotent re-run check ---\n    60→  const rerunResult = handleRerun(opts, result);\n    61→  if (rerunResult !== null) return rerunResult;\n    62→\n    63→  // --- Remote endpoint URL validation ---\n    64→  const urlError = validateRemoteUrls(opts);\n    65→  if (urlError !== null) { emitError(urlError, isJson); return ok(failResult(opts, urlError)); }\n    66→\n    67→  // --- Stack detection ---\n    68→  const stack = detectStack(projectDir);\n    69→  result.stack = stack;\n    70→  const allStacks = detectStacks(projectDir);\n    71→  result.stacks = [...new Set(allStacks.map(s => s.stack))];\n    72→  const appType = detectAppType(projectDir, stack);\n    73→  result.app_type = appType;\n    74→  if (!isJson) {\n    75→    if (stack) info(`Stack detected: ${getStackLabel(stack)}`);\n    76→    info(`App type: ${appType}`);\n    77→  }\n    78→\n    79→  // --- Dockerfile template generation ---\n    80→  const dfResult = generateDockerfileTemplate(projectDir, stack);\n    81→  if (isOk(dfResult)) {\n    82→    result.dockerfile = { generated: true, stack: dfResult.data.stack };\n    83→    if (!isJson) info(`Generated Dockerfile for ${dfResult.data.stack} project.`);\n    84→  } else {\n    85→    if (!isJson) info('Dockerfile already exists -- skipping template generation.');\n    86→  }\n    87→\n    88→  // --- Docker check ---\n    89→  const dockerCheck = checkDocker({ observability: opts.observability, otelEndpoint: opts.otelEndpoint, logsUrl: opts.logsUrl, opensearchUrl: opts.opensearchUrl, isJson });\n    90→  if (!isOk(dockerCheck)) return fail(dockerCheck.error);\n    91→  const { available: dockerAvailable, criticalFailure, dockerResult: criticalDockerResult } = dockerCheck.data;\n    92→  if (criticalFailure) {\n    93→    result.status = 'fail'; result.error = 'Docker not installed'; result.docker = criticalDockerResult;\n    94→    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); }\n    95→    else { failOutput('Docker not installed'); info('\\u2192 Install Docker: https://docs.docker.com/engine/install/'); info('\\u2192 Or skip observability: codeharness init --no-observability'); }\n    96→    process.exitCode = 1;\n    97→    return ok(result);\n    98→  }\n    99→\n   100→  // --- Dependency install ---\n   101→  const depResult = installDeps({ isJson });\n   102→  if (!isOk(depResult)) {\n   103→    result.status = 'fail'; result.error = depResult.error;\n   104→    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); } else { info('Critical dependency failed — aborting init'); }\n   105→    process.exitCode = 1;\n   106→    return ok(result);\n   107→  }\n   108→  result.dependencies = depResult.data;\n   109→\n   110→  // --- Beads initialization ---\n   111→  result.beads = initializeBeads(projectDir, isJson);\n   112→\n   113→  // --- BMAD installation ---\n   114→  const bmadResult = setupBmad({ projectDir, isJson });\n   115→  if (isOk(bmadResult)) result.bmad = bmadResult.data;\n   116→\n   117→  // --- State file creation ---\n   118→  let state: HarnessState = getDefaultState(stack);\n   119→  state.harness_version = HARNESS_VERSION;\n   120→  state.initialized = true;\n   121→  state.app_type = appType;\n   122→  state.enforcement = { frontend: opts.frontend, database: opts.database, api: opts.api };\n   123→  state.coverage.tool = getCoverageTool(stack);\n   124→  writeState(state, projectDir);\n   125→  if (!isJson) okOutput('State file: .claude/codeharness.local.md created');\n   126→\n   127→  // --- Documentation scaffold ---\n   128→  const docsResult = await scaffoldDocs({ projectDir, stack, isJson });\n   129→  if (isOk(docsResult)) result.documentation = docsResult.data;\n   130→\n   131→  // --- OTLP instrumentation ---\n   132→  if (!opts.observability) {\n   133→    result.otlp = { status: 'skipped', packages_installed: false, start_script_patched: false, env_vars_configured: false };\n   134→    if (!isJson) info('OTLP: skipped (--no-observability)');\n   135→  } else {\n   136→    result.otlp = instrumentProject(projectDir, stack, { json: isJson, appType });\n   137→  }\n   138→\n   139→  // Re-read state to pick up otlp changes written by instrumentProject\n   140→  try { const u = readState(projectDir); if (u.otlp) state.otlp = u.otlp; } catch { /* ignore */ }\n   141→  if (!state.otlp) {\n   142→    state.otlp = { enabled: true, endpoint: 'http://localhost:4318', service_name: basename(projectDir), mode: 'local-shared' };\n   143→  }\n   144→\n   145→  // --- Docker stack setup ---\n   146→  const dockerSetup = setupDocker({\n   147→    observability: opts.observability, otelEndpoint: opts.otelEndpoint,\n   148→    opensearchUrl: opts.opensearchUrl,\n   149→    logsUrl: opts.logsUrl, metricsUrl: opts.metricsUrl, tracesUrl: opts.tracesUrl,\n   150→    isJson, dockerAvailable, appType, state, projectDir,\n   151→  });\n   152→  if (isOk(dockerSetup)) result.docker = dockerSetup.data.docker;\n   153→\n   154→  // --- Enforcement summary ---\n   155→  if (!isJson) {\n   156→    const e = state.enforcement;\n   157→    const fmt = (v: boolean): string => v ? 'ON' : 'OFF';\n   158→    okOutput(`Enforcement: frontend:${fmt(e.frontend)} database:${fmt(e.database)} api:${fmt(e.api)} observability:ON`);\n   159→    info('Harness initialized. Run: codeharness bridge --epics <path>');\n   160→  }\n   161→  if (isJson) jsonOutput(result as unknown as Record<string, unknown>);\n   162→\n   163→  return ok(result);\n   164→}\n   165→\n   166→function handleRerun(opts: InitOptions, result: InitResult): Result<InitResult> | null {\n   167→  const { projectDir, json: isJson = false } = opts;\n   168→  if (!existsSync(getStatePath(projectDir))) return null;\n   169→\n   170→  try {\n   171→    const existingState = readState(projectDir);\n   172→    const legacyObsDisabled = (existingState.enforcement as Record<string, unknown>).observability === false;\n   173→    if (!existingState.initialized || legacyObsDisabled) {\n   174→      if (legacyObsDisabled && !isJson) info('Observability upgraded from disabled to enabled');\n   175→      return null;\n   176→    }\n   177→    result.stack = existingState.stack;\n   178→    result.stacks = existingState.stacks ?? [];\n   179→    result.enforcement = existingState.enforcement;\n   180→    result.documentation = { agents_md: 'exists', docs_scaffold: 'exists', readme: 'exists' };\n   181→    result.dependencies = verifyDeps(isJson);\n   182→    result.docker = existingState.docker\n   183→      ? { compose_file: existingState.docker.compose_file, stack_running: existingState.docker.stack_running, services: [], ports: existingState.docker.ports }\n   184→      : null;\n   185→    const bmadResult = verifyBmadOnRerun(projectDir, isJson);\n   186→    if (bmadResult) result.bmad = bmadResult;\n   187→    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); }\n   188→    else { info('Harness already initialized — verifying configuration'); okOutput('Configuration verified'); }\n   189→    return ok(result);\n   190→  } catch {\n   191→    return null;\n   192→  }\n   193→}\n   194→\n   195→/** Returns error message string if validation fails, null if OK */\n   196→function validateRemoteUrls(opts: InitOptions): string | null {\n   197→  const remoteUrls = [opts.otelEndpoint, opts.opensearchUrl, opts.logsUrl, opts.metricsUrl, opts.tracesUrl].filter(Boolean) as string[];\n   198→  for (const url of remoteUrls) {\n   199→    if (!/^https?:\\/\\//i.test(url)) return `Invalid URL: '${url}' \\u2014 must start with http:// or https://`;\n   200→  }\n   201→  if (opts.otelEndpoint && (opts.logsUrl || opts.metricsUrl || opts.tracesUrl)) {\n   202→    return 'Cannot combine --otel-endpoint with --logs-url/--metrics-url/--traces-url';\n   203→  }\n   204→  const hasAny = opts.logsUrl || opts.metricsUrl || opts.tracesUrl;\n   205→  if (hasAny && !(opts.logsUrl && opts.metricsUrl && opts.tracesUrl)) {\n   206→    return 'When using remote backends, all three are required: --logs-url, --metrics-url, --traces-url';\n   207→  }\n   208→  return null;\n   209→}\n   210→"}]},"parent_tool_use_id":"toolu_01GATsxowjKTFTmnhPqJRdwx","session_id":"90f5ac9b-34a6-4398-bbd9-dd5bc4930bef","uuid":"85a6565f-10af-49dd-bb2b-77dce86d9d11","timestamp":"2026-03-23T14:32:42.230Z"}
