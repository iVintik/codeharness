{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DGaFpx3GFBPGzmkoFfbrfn","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n2\timport fs from 'node:fs';\n3\timport path from 'node:path';\n4\timport os from 'node:os';\n5\timport YAML from 'yaml';\n6\timport {\n7\t  loadEmbeddedAgent,\n8\t  loadPatch,\n9\t  mergePatch,\n10\t  resolveAgent,\n11\t  compileSubagentDefinition,\n12\t  AgentResolveError,\n13\t} from '../agent-resolver.js';\n14\timport type { ResolvedAgent, AgentPatch } from '../agent-resolver.js';\n15\t\n16\tconst TEMPLATES_DIR = path.resolve(__dirname, '../../../templates/agents');\n17\t\n18\tconst EXPECTED_AGENTS = [\n19\t  'dev', 'qa', 'architect', 'pm', 'sm',\n20\t  'analyst', 'ux-designer', 'tech-writer', 'evaluator',\n21\t];\n22\t\n23\t// --- Helpers ---\n24\t\n25\tfunction makeMinimalAgent(overrides?: Partial<ResolvedAgent>): ResolvedAgent {\n26\t  return {\n27\t    name: 'test-agent',\n28\t    role: { title: 'Test Agent', purpose: 'Testing' },\n29\t    persona: {\n30\t      identity: 'A test agent for unit tests',\n31\t      communication_style: 'Direct and clear',\n32\t      principles: ['Be thorough', 'Be honest'],\n33\t    },\n34\t    ...overrides,\n35\t  };\n36\t}\n37\t\n38\tfunction writeTempYaml(dir: string, relativePath: string, content: unknown): string {\n39\t  const filePath = path.join(dir, relativePath);\n40\t  const dirPath = path.dirname(filePath);\n41\t  fs.mkdirSync(dirPath, { recursive: true });\n42\t  fs.writeFileSync(filePath, YAML.stringify(content), 'utf-8');\n43\t  return filePath;\n44\t}\n45\t\n46\t// --- Tests ---\n47\t\n48\tdescribe('agent-resolver', () => {\n49\t  describe('loadEmbeddedAgent', () => {\n50\t    it('loads dev.yaml and returns valid ResolvedAgent (AC #1)', () => {\n51\t      const agent = loadEmbeddedAgent('dev');\n52\t      expect(agent.name).toBe('dev');\n53\t      expect(agent.role.title).toBeDefined();\n54\t      expect(agent.persona.identity).toBeDefined();\n55\t      expect(agent.persona.communication_style).toBeDefined();\n56\t      expect(Array.isArray(agent.persona.principles)).toBe(true);\n57\t    });\n58\t\n59\t    it('loads evaluator.yaml with disallowedTools (AC #7)', () => {\n60\t      const agent = loadEmbeddedAgent('evaluator');\n61\t      expect(agent.name).toBe('evaluator');\n62\t      expect(agent.disallowedTools).toContain('Edit');\n63\t      expect(agent.disallowedTools).toContain('Write');\n64\t    });\n65\t\n66\t    it('loads evaluator.yaml with prompt_template field present (AC #5, story 6-3)', () => {\n67\t      const agent = loadEmbeddedAgent('evaluator');\n68\t      expect(agent.prompt_template).toBeDefined();\n69\t      expect(typeof agent.prompt_template).toBe('string');\n70\t      expect(agent.prompt_template!.length).toBeGreaterThan(0);\n71\t    });\n72\t\n73\t    it('evaluator.yaml prompt_template contains anti-leniency keywords (AC #2, story 6-3)', () => {\n74\t      const agent = loadEmbeddedAgent('evaluator');\n75\t      const template = agent.prompt_template!;\n76\t      expect(template).toContain('broken');\n77\t      expect(template).toContain('benefit of the doubt');\n78\t      expect(template).toContain('UNKNOWN');\n79\t    });\n80\t\n81\t    it('evaluator.yaml prompt_template references verdict JSON structure (AC #3, story 6-3)', () => {\n82\t      const agent = loadEmbeddedAgent('evaluator');\n83\t      const template = agent.prompt_template!;\n84\t      expect(template).toContain('verdict');\n85\t      expect(template).toContain('score');\n86\t      expect(template).toContain('findings');\n87\t      expect(template).toContain('commands_run');\n88\t      expect(template).toContain('output_observed');\n89\t      expect(template).toContain('reasoning');\n90\t    });\n91\t\n92\t    it('evaluator.yaml prompt_template includes tool access instructions (AC #4, story 6-3)', () => {\n93\t      const agent = loadEmbeddedAgent('evaluator');\n94\t      const template = agent.prompt_template!;\n95\t      expect(template).toContain('docker exec');\n96\t      expect(template).toContain('docker logs');\n97\t      expect(template).toContain('docker ps');\n98\t      expect(template).toContain('source code');\n99\t    });\n100\t\n101\t    it('evaluator.yaml prompt_template instructs output to ./verdict/ (AC #3, story 6-3)', () => {\n102\t      const agent = loadEmbeddedAgent('evaluator');\n103\t      const template = agent.prompt_template!;\n104\t      expect(template).toContain('./verdict/');\n105\t    });\n106\t\n107\t    it('evaluator.yaml prompt_template instructs reading from ./story-files/ (AC #1, story 6-3)', () => {\n108\t      const agent = loadEmbeddedAgent('evaluator');\n109\t      const template = agent.prompt_template!;\n110\t      expect(template).toContain('./story-files/');\n111\t    });\n112\t\n113\t    it('evaluator.yaml prompt_template instructs re-verification from scratch (AC #1, story 6-3)', () => {\n114\t      const agent = loadEmbeddedAgent('evaluator');\n115\t      const template = agent.prompt_template!;\n116\t      expect(template).toContain('scratch');\n117\t      expect(template).toContain('cache');\n118\t    });\n119\t\n120\t    it('throws AgentResolveError for non-existent embedded agent', () => {\n121\t      expect(() => loadEmbeddedAgent('nonexistent-agent')).toThrow(AgentResolveError);\n122\t      try {\n123\t        loadEmbeddedAgent('nonexistent-agent');\n124\t      } catch (err) {\n125\t        const e = err as AgentResolveError;\n126\t        expect(e.filePath).toContain('nonexistent-agent.yaml');\n127\t        expect(e.errors.length).toBeGreaterThan(0);\n128\t      }\n129\t    });\n130\t\n131\t    it.each(EXPECTED_AGENTS)('loads %s.yaml successfully', (name) => {\n132\t      const agent = loadEmbeddedAgent(name);\n133\t      expect(agent.name).toBe(name);\n134\t    });\n135\t\n136\t    it('throws AgentResolveError with details when schema validation would fail', () => {\n137\t      // Embedded agents in templates/ are always valid, so we test the error constructor\n138\t      // to ensure the schema validation error branch produces the right shape\n139\t      const err = new AgentResolveError(\n140\t        'Schema validation failed for embedded agent test: /name: must be string',\n141\t        '/tmp/test.yaml',\n142\t        [{ path: '/name', message: 'must be string' }],\n143\t      );\n144\t      expect(err.name).toBe('AgentResolveError');\n145\t      expect(err.filePath).toBe('/tmp/test.yaml');\n146\t      expect(err.errors).toHaveLength(1);\n147\t      expect(err.errors[0].path).toBe('/name');\n148\t    });\n149\t\n150\t    it('throws AgentResolveError for path-traversal agent names', () => {\n151\t      expect(() => loadEmbeddedAgent('../../../etc/passwd')).toThrow(AgentResolveError);\n152\t      expect(() => loadEmbeddedAgent('')).toThrow(AgentResolveError);\n153\t      expect(() => loadEmbeddedAgent('foo bar')).toThrow(AgentResolveError);\n154\t    });\n155\t\n156\t    it('covers the YAML parse error path via corrupted embedded file', () => {\n157\t      // We test that the YAML parse error branch is reachable by constructing\n158\t      // the error path directly, since mocking named imports requires module-level vi.mock.\n159\t      // The loadEmbeddedAgent function's YAML parse error branch (lines 135-136) is\n160\t      // defensive code for corrupted template files. We verify the error shape is correct.\n161\t      const err = new AgentResolveError(\n162\t        'Invalid YAML in embedded agent dev: unexpected token',\n163\t        '/templates/agents/dev.yaml',\n164\t        [{ path: '/templates/agents/dev.yaml', message: 'unexpected token' }],\n165\t      );\n166\t      expect(err.name).toBe('AgentResolveError');\n167\t      expect(err.message).toContain('Invalid YAML');\n168\t      expect(err.filePath).toContain('dev.yaml');\n169\t    });\n170\t\n171\t    it('covers the schema validation error path via corrupted embedded file', () => {\n172\t      // The schema validation failure branch (lines 145-149) is defensive code\n173\t      // for corrupted template files that parse as valid YAML but fail schema validation.\n174\t      // We verify the error shape is correct.\n175\t      const err = new AgentResolveError(\n176\t        'Schema validation failed for embedded agent dev: /name: must be string',\n177\t        '/templates/agents/dev.yaml',\n178\t        [{ path: '/name', message: 'must be string' }],\n179\t      );\n180\t      expect(err.name).toBe('AgentResolveError');\n181\t      expect(err.message).toContain('Schema validation failed');\n182\t      expect(err.errors[0].message).toBe('must be string');\n183\t    });\n184\t  });\n185\t\n186\t  describe('loadPatch', () => {\n187\t    it('returns null for non-existent file (silent skip, AC #4)', () => {\n188\t      const result = loadPatch('/tmp/nonexistent-patch-file-xyz.yaml');\n189\t      expect(result).toBeNull();\n190\t    });\n191\t\n192\t    it('loads a valid patch file', () => {\n193\t      const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'agent-resolver-'));\n194\t      try {\n195\t        const patchContent = {\n196\t          extends: 'embedded://dev',\n197\t          overrides: { personality: { traits: { rigor: 0.9 } } },\n198\t        };\n199\t        const patchPath = writeTempYaml(tmpDir, 'dev.patch.yaml', patchContent);\n200\t        const result = loadPatch(patchPath);\n201\t        expect(result).not.toBeNull();\n202\t        expect(result!.extends).toBe('embedded://dev');\n203\t        expect(result!.overrides).toEqual({ personality: { traits: { rigor: 0.9 } } });\n204\t      } finally {\n205\t        fs.rmSync(tmpDir, { recursive: true, force: true });\n206\t      }\n207\t    });\n208\t\n209\t    it('throws AgentResolveError on malformed YAML (AC #5)', () => {\n210\t      const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'agent-resolver-'));\n211\t      try {\n212\t        const patchPath = path.join(tmpDir, 'bad.patch.yaml');\n213\t        fs.writeFileSync(patchPath, '{ invalid yaml: [unterminated', 'utf-8');\n214\t        expect(() => loadPatch(patchPath)).toThrow(AgentResolveError);\n215\t        try {\n216\t          loadPatch(patchPath);\n217\t        } catch (err) {\n218\t          const e = err as AgentResolveError;\n219\t          expect(e.filePath).toBe(patchPath);\n220\t          expect(e.errors.length).toBeGreaterThan(0);\n221\t        }\n222\t      } finally {\n223\t        fs.rmSync(tmpDir, { recursive: true, force: true });\n224\t      }\n225\t    });\n226\t\n227\t    it('throws AgentResolveError when patch file is a scalar (not an object)', () => {\n228\t      const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'agent-resolver-'));\n229\t      try {\n230\t        const patchPath = path.join(tmpDir, 'scalar.patch.yaml');\n231\t        fs.writeFileSync(patchPath, 'just a string', 'utf-8');\n232\t        expect(() => loadPatch(patchPath)).toThrow(AgentResolveError);\n233\t        try {\n234\t          loadPatch(patchPath);\n235\t        } catch (err) {\n236\t          const e = err as AgentResolveError;\n237\t          expect(e.filePath).toBe(patchPath);\n238\t          expect(e.message).toContain('not a valid object');\n239\t        }\n240\t      } finally {\n241\t        fs.rmSync(tmpDir, { recursive: true, force: true });\n242\t      }\n243\t    });\n244\t\n245\t    it('returns null when file exists but is unreadable', () => {\n246\t      const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'agent-resolver-'));\n247\t      try {\n248\t        const patchPath = path.join(tmpDir, 'unreadable.patch.yaml');\n249\t        fs.writeFileSync(patchPath, 'name: test', 'utf-8');\n250\t        // Make file unreadable (mode 0o000)\n251\t        fs.chmodSync(patchPath, 0o000);\n252\t        // On some systems (macOS root), chmod doesn't prevent reading\n253\t        // so this test may not hit the branch; that's acceptable\n254\t        const result = loadPatch(patchPath);\n255\t        // Either null (unreadable) or a valid patch (if chmod didn't work)\n256\t        expect(result === null || (typeof result === 'object')).toBe(true);\n257\t      } finally {\n258\t        // Restore permissions for cleanup\n259\t        try {\n260\t          fs.chmodSync(path.join(tmpDir, 'unreadable.patch.yaml'), 0o644);\n261\t        } catch { /* ignore */ }\n262\t        fs.rmSync(tmpDir, { recursive: true, force: true });\n263\t      }\n264\t    });\n265\t  });\n266\t\n267\t  describe('mergePatch', () => {\n268\t    it('deep-merges overrides onto base (AC #2)', () => {\n269\t      const base: Record<string, unknown> = {\n270\t        name: 'dev',\n271\t        persona: {\n272\t          identity: 'A developer',\n273\t          communication_style: 'Direct',\n274\t          principles: ['Be thorough'],\n275\t        },\n276\t      };\n277\t      const patch: AgentPatch = {\n278\t        extends: 'embedded://dev',\n279\t        overrides: {\n280\t          personality: { traits: { rigor: 0.9 } },\n281\t        },\n282\t      };\n283\t      const result = mergePatch(base, patch);\n284\t      expect(result.name).toBe('dev');\n285\t      expect((result.personality as Record<string, unknown>)).toEqual({ traits: { rigor: 0.9 } });\n286\t      // Original fields preserved\n287\t      expect((result.persona as Record<string, unknown>)).toEqual(base.persona);\n288\t    });\n289\t\n290\t    it('arrays replace entirely (not concatenate)', () => {\n291\t      const base: Record<string, unknown> = {\n292\t        name: 'dev',\n293\t        persona: {\n294\t          identity: 'A developer',\n295\t          communication_style: 'Direct',\n296\t          principles: ['Original principle 1', 'Original principle 2'],\n297\t        },\n298\t      };\n299\t      const patch: AgentPatch = {\n300\t        overrides: {\n301\t          persona: {\n302\t            principles: ['New principle only'],\n303\t          },\n304\t        },\n305\t      };\n306\t      const result = mergePatch(base, patch);\n307\t      const persona = result.persona as Record<string, unknown>;\n308\t      expect(persona.principles).toEqual(['New principle only']);\n309\t    });\n310\t\n311\t    it('scalars replace', () => {\n312\t      const base: Record<string, unknown> = {\n313\t        name: 'dev',\n314\t        role: { title: 'Original', purpose: 'Original purpose' },\n315\t      };\n316\t      const patch: AgentPatch = {\n317\t        overrides: {\n318\t          role: { title: 'Patched' },\n319\t        },\n320\t      };\n321\t      const result = mergePatch(base, patch);\n322\t      const role = result.role as Record<string, unknown>;\n323\t      expect(role.title).toBe('Patched');\n324\t      expect(role.purpose).toBe('Original purpose');\n325\t    });\n326\t\n327\t    it('preserves prompt_patches separately (AC #3)', () => {\n328\t      const base: Record<string, unknown> = { name: 'dev' };\n329\t      const patch: AgentPatch = {\n330\t        prompt_patches: { append: 'Extra instructions here.' },\n331\t      };\n332\t      const result = mergePatch(base, patch);\n333\t      expect(result.prompt_patches).toEqual({ append: 'Extra instructions here.' });\n334\t    });\n335\t\n336\t    it('concatenates prompt_patches.append from multiple patches', () => {\n337\t      const base: Record<string, unknown> = {\n338\t        name: 'dev',\n339\t        prompt_patches: { append: 'First instruction.' },\n340\t      };\n341\t      const patch: AgentPatch = {\n342\t        prompt_patches: { append: 'Second instruction.' },\n343\t      };\n344\t      const result = mergePatch(base, patch);\n345\t      const pp = result.prompt_patches as { append: string };\n346\t      expect(pp.append).toContain('First instruction.');\n347\t      expect(pp.append).toContain('Second instruction.');\n348\t    });\n349\t  });\n350\t\n351\t  describe('resolveAgent', () => {\n352\t    let tmpDir: string;\n353\t\n354\t    beforeEach(() => {\n355\t      tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'agent-resolver-'));\n356\t    });\n357\t\n358\t    afterEach(() => {\n359\t      fs.rmSync(tmpDir, { recursive: true, force: true });\n360\t      vi.restoreAllMocks();\n361\t    });\n362\t\n363\t    it('loads embedded dev.yaml with no patches and returns unchanged (AC #1, #4)', () => {\n364\t      // Point to a cwd with no patches\n365\t      const agent = resolveAgent('dev', { cwd: tmpDir });\n366\t      expect(agent.name).toBe('dev');\n367\t      expect(agent.role.title).toBe('Developer Agent');\n368\t      expect(agent.persona.identity).toBeDefined();\n369\t    });\n370\t\n371\t    it('missing user and project patches are silently skipped (AC #4)', () => {\n372\t      // No patches exist in tmpDir or mocked homedir\n373\t      vi.spyOn(os, 'homedir').mockReturnValue(tmpDir);\n374\t      const agent = resolveAgent('dev', { cwd: tmpDir });\n375\t      expect(agent.name).toBe('dev');\n376\t    });\n377\t\n378\t    it('applies user patch with overrides (AC #2)', () => {\n379\t      const userHome = path.join(tmpDir, 'home');\n380\t      vi.spyOn(os, 'homedir').mockReturnValue(userHome);\n381\t\n382\t      writeTempYaml(userHome, '.codeharness/agents/dev.patch.yaml', {\n383\t        extends: 'embedded://dev',\n384\t        overrides: {\n385\t          personality: { traits: { rigor: 0.9 } },\n386\t        },\n387\t      });\n388\t\n389\t      const agent = resolveAgent('dev', { cwd: tmpDir });\n390\t      expect(agent.name).toBe('dev');\n391\t      expect(agent.personality?.traits.rigor).toBe(0.9);\n392\t    });\n393\t\n394\t    it('applies project patch on top of user patch (AC #3)', () => {\n395\t      const userHome = path.join(tmpDir, 'home');\n396\t      const projectDir = path.join(tmpDir, 'project');\n397\t      vi.spyOn(os, 'homedir').mockReturnValue(userHome);\n398\t\n399\t      writeTempYaml(userHome, '.codeharness/agents/dev.patch.yaml', {\n400\t        extends: 'embedded://dev',\n401\t        overrides: {\n402\t          personality: { traits: { rigor: 0.9 } },\n403\t        },\n404\t      });\n405\t\n406\t      writeTempYaml(projectDir, '.codeharness/agents/dev.patch.yaml', {\n407\t        extends: 'embedded://dev',\n408\t        prompt_patches: { append: 'Use React + Vite.' },\n409\t      });\n410\t\n411\t      const agent = resolveAgent('dev', { cwd: projectDir });\n412\t      expect(agent.name).toBe('dev');\n413\t      expect(agent.personality?.traits.rigor).toBe(0.9);\n414\t      expect(agent.prompt_patches?.append).toBe('Use React + Vite.');\n415\t    });\n416\t\n417\t    it('full 3-layer chain: embedded + user + project (AC #2, #3)', () => {\n418\t      const userHome = path.join(tmpDir, 'home');\n419\t      const projectDir = path.join(tmpDir, 'project');\n420\t      vi.spyOn(os, 'homedir').mockReturnValue(userHome);\n421\t\n422\t      writeTempYaml(userHome, '.codeharness/agents/dev.patch.yaml', {\n423\t        extends: 'embedded://dev',\n424\t        overrides: {\n425\t          personality: { traits: { rigor: 0.85 } },\n426\t        },\n427\t        prompt_patches: { append: 'User-level instruction.' },\n428\t      });\n429\t\n430\t      writeTempYaml(projectDir, '.codeharness/agents/dev.patch.yaml', {\n431\t        extends: 'embedded://dev',\n432\t        overrides: {\n433\t          personality: { traits: { directness: 0.7 } },\n434\t        },\n435\t        prompt_patches: { append: 'Project-level instruction.' },\n436\t      });\n437\t\n438\t      const agent = resolveAgent('dev', { cwd: projectDir });\n439\t      expect(agent.personality?.traits.rigor).toBe(0.85);\n440\t      expect(agent.personality?.traits.directness).toBe(0.7);\n441\t      expect(agent.prompt_patches?.append).toContain('User-level instruction.');\n442\t      expect(agent.prompt_patches?.append).toContain('Project-level instruction.');\n443\t    });\n444\t\n445\t    it('throws AgentResolveError for malformed patch (AC #5)', () => {\n446\t      const userHome = path.join(tmpDir, 'home');\n447\t      vi.spyOn(os, 'homedir').mockReturnValue(userHome);\n448\t\n449\t      const patchDir = path.join(userHome, '.codeharness', 'agents');\n450\t      fs.mkdirSync(patchDir, { recursive: true });\n451\t      fs.writeFileSync(path.join(patchDir, 'dev.patch.yaml'), '{ bad yaml [[[', 'utf-8');\n452\t\n453\t      expect(() => resolveAgent('dev', { cwd: tmpDir })).toThrow(AgentResolveError);\n454\t    });\n455\t\n456\t    it('throws AgentResolveError when patch produces schema-invalid result (AC #5)', () => {\n457\t      const userHome = path.join(tmpDir, 'home');\n458\t      vi.spyOn(os, 'homedir').mockReturnValue(userHome);\n459\t\n460\t      // Patch that adds an invalid field (additionalProperties: false in schema)\n461\t      writeTempYaml(userHome, '.codeharness/agents/dev.patch.yaml', {\n462\t        extends: 'embedded://dev',\n463\t        overrides: {\n464\t          unknownTopLevelField: 'this should fail validation',\n465\t        },\n466\t      });\n467\t\n468\t      expect(() => resolveAgent('dev', { cwd: tmpDir })).toThrow(AgentResolveError);\n469\t    });\n470\t\n471\t    it('loads custom agent directly without patch chain (AC #8)', () => {\n472\t      const projectDir = path.join(tmpDir, 'project');\n473\t      vi.spyOn(os, 'homedir').mockReturnValue(path.join(tmpDir, 'home'));\n474\t\n475\t      const customAgent = makeMinimalAgent({ name: 'my-agent' });\n476\t      writeTempYaml(projectDir, '.codeharness/agents/my-agent.yaml', customAgent);\n477\t\n478\t      const agent = resolveAgent('my-agent', { cwd: projectDir });\n479\t      expect(agent.name).toBe('my-agent');\n480\t      expect(agent.role.title).toBe('Test Agent');\n481\t    });\n482\t\n483\t    it('throws AgentResolveError for invalid custom agent (AC #8, #5)', () => {\n484\t      const projectDir = path.join(tmpDir, 'project');\n485\t      vi.spyOn(os, 'homedir').mockReturnValue(path.join(tmpDir, 'home'));\n486\t\n487\t      // Custom agent missing required fields\n488\t      writeTempYaml(projectDir, '.codeharness/agents/bad-agent.yaml', {\n489\t        name: 'bad-agent',\n490\t        // missing role and persona\n491\t      });\n492\t\n493\t      expect(() => resolveAgent('bad-agent', { cwd: projectDir })).toThrow(AgentResolveError);\n494\t    });\n495\t\n496\t    it('throws AgentResolveError for path-traversal names in resolveAgent', () => {\n497\t      expect(() => resolveAgent('../../etc/passwd', { cwd: tmpDir })).toThrow(AgentResolveError);\n498\t      expect(() => resolveAgent('foo bar', { cwd: tmpDir })).toThrow(AgentResolveError);\n499\t    });\n500\t\n501\t    it('loads custom agent with prompt_patches (stripped before validation)', () => {\n502\t      const projectDir = path.join(tmpDir, 'project');\n503\t      vi.spyOn(os, 'homedir').mockReturnValue(path.join(tmpDir, 'home'));\n504\t\n505\t      const customAgent = {\n506\t        ...makeMinimalAgent({ name: 'custom-pp' }),\n507\t        prompt_patches: { append: 'Custom prompt patch.' },\n508\t      };\n509\t      writeTempYaml(projectDir, '.codeharness/agents/custom-pp.yaml', customAgent);\n510\t\n511\t      const agent = resolveAgent('custom-pp', { cwd: projectDir });\n512\t      expect(agent.name).toBe('custom-pp');\n513\t      expect(agent.prompt_patches?.append).toBe('Custom prompt patch.');\n514\t    });\n515\t\n516\t    it('resolving all 9 embedded agents completes in <200ms (AC #9)', () => {\n517\t      vi.spyOn(os, 'homedir').mockReturnValue(path.join(tmpDir, 'home'));\n518\t\n519\t      const start = performance.now();\n520\t      for (const name of EXPECTED_AGENTS) {\n521\t        resolveAgent(name, { cwd: tmpDir });\n522\t      }\n523\t      const elapsed = performance.now() - start;\n524\t      expect(elapsed).toBeLessThan(200);\n525\t    });\n526\t  });\n527\t\n528\t  describe('compileSubagentDefinition', () => {\n529\t    it('produces correct instructions string (AC #6)', () => {\n530\t      const agent = makeMinimalAgent();\n531\t      const result = compileSubagentDefinition(agent);\n532\t\n533\t      expect(result.name).toBe('test-agent');\n534\t      expect(result.model).toBe('claude-sonnet-4-20250514');\n535\t      expect(result.bare).toBe(true);\n536\t      expect(result.instructions).toContain('You are A test agent for unit tests');\n537\t      expect(result.instructions).toContain('Communication style: Direct and clear');\n538\t      expect(result.instructions).toContain('Principles:');\n539\t      expect(result.instructions).toContain('- Be thorough');\n540\t      expect(result.instructions).toContain('- Be honest');\n541\t    });\n542\t\n543\t    it('includes prompt_patches.append in instructions (AC #6)', () => {\n544\t      const agent = makeMinimalAgent({\n545\t        prompt_patches: { append: 'Run npm build first.' },\n546\t      });\n547\t      const result = compileSubagentDefinition(agent);\n548\t      expect(result.instructions).toContain('Run npm build first.');\n549\t    });\n550\t\n551\t    it('preserves disallowedTools for evaluator (AC #7)', () => {\n552\t      const agent = loadEmbeddedAgent('evaluator');\n553\t      const result = compileSubagentDefinition(agent);\n554\t      expect(result.disallowedTools).toContain('Edit');\n555\t      expect(result.disallowedTools).toContain('Write');\n556\t      expect(result.disallowedTools).toHaveLength(2);\n557\t    });\n558\t\n559\t    it('returns empty disallowedTools when not present', () => {\n560\t      const agent = makeMinimalAgent();\n561\t      const result = compileSubagentDefinition(agent);\n562\t      expect(result.disallowedTools).toEqual([]);\n563\t    });\n564\t\n565\t    it('sets bare: true always (AD2)', () => {\n566\t      const agent = makeMinimalAgent();\n567\t      const result = compileSubagentDefinition(agent);\n568\t      expect(result.bare).toBe(true);\n569\t    });\n570\t\n571\t    it('sets default model', () => {\n572\t      const agent = makeMinimalAgent();\n573\t      const result = compileSubagentDefinition(agent);\n574\t      expect(result.model).toBe('claude-sonnet-4-20250514');\n575\t    });\n576\t\n577\t    it('compiles real embedded dev agent correctly', () => {\n578\t      const agent = loadEmbeddedAgent('dev');\n579\t      const result = compileSubagentDefinition(agent);\n580\t      expect(result.name).toBe('dev');\n581\t      expect(result.instructions).toContain('You are');\n582\t      expect(result.instructions).toContain('Communication style:');\n583\t      expect(result.instructions).toContain('Principles:');\n584\t      expect(result.disallowedTools).toEqual([]);\n585\t    });\n586\t\n587\t    it('includes prompt_template in instructions when present (AC #6)', () => {\n588\t      const agent = makeMinimalAgent({\n589\t        prompt_template: 'Verify all acceptance criteria from ./story-files/.',\n590\t      });\n591\t      const result = compileSubagentDefinition(agent);\n592\t      expect(result.instructions).toContain('Verify all acceptance criteria from ./story-files/.');\n593\t    });\n594\t\n595\t    it('output unchanged when prompt_template is absent (AC #6)', () => {\n596\t      const agent = makeMinimalAgent();\n597\t      const withoutTemplate = compileSubagentDefinition(agent);\n598\t\n599\t      const agentWithTemplate = makeMinimalAgent({ prompt_template: undefined });\n600\t      const alsoWithout = compileSubagentDefinition(agentWithTemplate);\n601\t\n602\t      expect(withoutTemplate.instructions).toBe(alsoWithout.instructions);\n603\t    });\n604\t\n605\t    it('prompt_template appears after prompt_patches.append in instructions', () => {\n606\t      const agent = makeMinimalAgent({\n607\t        prompt_patches: { append: 'PATCH_CONTENT_HERE' },\n608\t        prompt_template: 'TEMPLATE_CONTENT_HERE',\n609\t      });\n610\t      const result = compileSubagentDefinition(agent);\n611\t      const patchIdx = result.instructions.indexOf('PATCH_CONTENT_HERE');\n612\t      const templateIdx = result.instructions.indexOf('TEMPLATE_CONTENT_HERE');\n613\t      expect(patchIdx).toBeGreaterThan(-1);\n614\t      expect(templateIdx).toBeGreaterThan(-1);\n615\t      expect(templateIdx).toBeGreaterThan(patchIdx);\n616\t    });\n617\t  });\n618\t\n619\t  describe('AgentResolveError', () => {\n620\t    it('has correct name, filePath, and errors', () => {\n621\t      const err = new AgentResolveError('test error', '/tmp/test.yaml', [\n622\t        { path: '/name', message: 'missing' },\n623\t      ]);\n624\t      expect(err.name).toBe('AgentResolveError');\n625\t      expect(err.filePath).toBe('/tmp/test.yaml');\n626\t      expect(err.errors).toHaveLength(1);\n627\t      expect(err.message).toBe('test error');\n628\t    });\n629\t\n630\t    it('defaults errors to empty array', () => {\n631\t      const err = new AgentResolveError('test', '/tmp/x.yaml');\n632\t      expect(err.errors).toEqual([]);\n633\t    });\n634\t  });\n635\t\n636\t  describe('no regressions', () => {\n637\t    it('existing schema validation still works', async () => {\n638\t      const { validateAgentSchema } = await import('../schema-validate.js');\n639\t      const result = validateAgentSchema(makeMinimalAgent());\n640\t      expect(result.valid).toBe(true);\n641\t    });\n642\t\n643\t    it('existing workflow parser still works', async () => {\n644\t      const { parseWorkflow } = await import('../workflow-parser.js');\n645\t      expect(typeof parseWorkflow).toBe('function');\n646\t    });\n647\t  });\n648\t\n649\t  describe('agent.schema.json prompt_template support (story 6-3)', () => {\n650\t    it('accepts agent config with prompt_template (AC #8)', async () => {\n651\t      const { validateAgentSchema } = await import('../schema-validate.js');\n652\t      const agent = {\n653\t        ...makeMinimalAgent(),\n654\t        prompt_template: 'Some task instructions here.',\n655\t      };\n656\t      const result = validateAgentSchema(agent);\n657\t      expect(result.valid).toBe(true);\n658\t    });\n659\t\n660\t    it('accepts agent config without prompt_template (AC #8)', async () => {\n661\t      const { validateAgentSchema } = await import('../schema-validate.js');\n662\t      const agent = makeMinimalAgent();\n663\t      const result = validateAgentSchema(agent);\n664\t      expect(result.valid).toBe(true);\n665\t    });\n666\t\n667\t    it('rejects prompt_template with non-string type', async () => {\n668\t      const { validateAgentSchema } = await import('../schema-validate.js');\n669\t      const agent = {\n670\t        ...makeMinimalAgent(),\n671\t        prompt_template: 42,\n672\t      };\n673\t      const result = validateAgentSchema(agent);\n674\t      expect(result.valid).toBe(false);\n675\t    });\n676\t\n677\t    it('evaluator.yaml with prompt_template passes schema validation', () => {\n678\t      // loadEmbeddedAgent validates against schema internally\n679\t      const agent = loadEmbeddedAgent('evaluator');\n680\t      expect(agent.name).toBe('evaluator');\n681\t      expect(agent.prompt_template).toBeDefined();\n682\t    });\n683\t  });\n684\t});\n685\t"}]},"parent_tool_use_id":"toolu_01WBGtD6t91yRv6Crn8gGaXn","session_id":"52ded6f4-857c-404a-a480-19bb12459ee1","uuid":"8f14da38-2197-4295-9b63-1339a2abb2a3","timestamp":"2026-04-03T00:38:50.814Z"}
