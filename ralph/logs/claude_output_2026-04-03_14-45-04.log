k = makeTask();\n2888\t    const definition = makeDefinition();\n2889\t    const state = makeDefaultState();\n2890\t    const config = makeConfig();\n2891\t\n2892\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n2893\t\n2894\t    // dispatchAgent should NOT be called — dispatch goes through driver\n2895\t    expect(mockDispatchAgent).not.toHaveBeenCalled();\n2896\t    // getDriver + driver.dispatch should be used instead\n2897\t    expect(mockGetDriver).toHaveBeenCalled();\n2898\t    expect(mockDriverDispatch).toHaveBeenCalled();\n2899\t  });\n2900\t\n2901\t  it('loop block dispatches through driver identically to sequential tasks (AC #9)', async () => {\n2902\t    const dispatches: string[] = [];\n2903\t    mockDriverDispatch.mockImplementation((opts: { prompt: string }) => {\n2904\t      dispatches.push(opts.prompt);\n2905\t      if (opts.prompt.includes('Execute task')) {\n2906\t        return makeDriverStream(JSON.stringify({\n2907\t          verdict: 'pass',\n2908\t          score: { passed: 1, failed: 0, unknown: 0, total: 1 },\n2909\t          findings: [],\n2910\t        }), 'sess-v');\n2911\t      }\n2912\t      return makeDriverStream('ok', 'sess-r');\n2913\t    });\n2914\t\n2915\t    mockParse.mockReturnValue({\n2916\t      development_status: { '3-1-foo': 'ready-for-dev' },\n2917\t    });\n2918\t\n2919\t    const config = makeConfig({\n2920\t      workflow: {\n2921\t        tasks: {\n2922\t          retry: makeTask({ scope: 'per-story' }),\n2923\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n2924\t        },\n2925\t        flow: [{ loop: ['retry', 'verify'] }],\n2926\t      },\n2927\t    });\n2928\t\n2929\t    await executeWorkflow(config);\n2930\t\n2931\t    // Both retry and verify should go through driver.dispatch\n2932\t    // +1 for health check (deduped to 1 call for claude-code default)\n2933\t    expect(mockGetDriver).toHaveBeenCalledTimes(3);\n2934\t    expect(mockDriverDispatch).toHav