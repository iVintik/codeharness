real command output\n- The test suite section is mandatory and must show all tests passing\n- Use `showboat exec` for all evidence capture — do not write output by hand\n- The document must be reproducible via `showboat verify`"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1556,"cache_read_input_tokens":105743,"cache_creation":{"ephemeral_5m_input_tokens":1556,"ephemeral_1h_input_tokens":0},"output_tokens":46,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01KNQnUKBFtzFzrosUg6K7qd","session_id":"7d2c764f-deb1-4354-ad31-e0a846d19ae3","uuid":"83eb4f44-39e4-4168-8248-967c52aebbaa"}
