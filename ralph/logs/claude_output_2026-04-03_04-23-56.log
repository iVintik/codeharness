{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CYdLouztTGBusrLnZ7wGon","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { resolve, join, dirname } from 'node:path';\n3\timport { fileURLToPath } from 'node:url';\n4\timport os from 'node:os';\n5\timport { parse } from 'yaml';\n6\t\n7\tconst __filename = fileURLToPath(import.meta.url);\n8\tconst __dirname = dirname(__filename);\n9\timport { validateAgentSchema } from './schema-validate.js';\n10\t\n11\t// --- Interfaces ---\n12\t\n13\t/**\n14\t * Agent config shape matching agent.schema.json, plus optional prompt_patches\n15\t * accumulated from patch files.\n16\t */\n17\texport interface ResolvedAgent {\n18\t  name: string;\n19\t  role: {\n20\t    title: string;\n21\t    purpose: string;\n22\t  };\n23\t  persona: {\n24\t    identity: string;\n25\t    communication_style: string;\n26\t    principles: string[];\n27\t  };\n28\t  personality?: {\n29\t    traits: Record<string, number>;\n30\t  };\n31\t  disallowedTools?: string[];\n32\t  prompt_patches?: {\n33\t    append?: string;\n34\t  };\n35\t  prompt_template?: string;\n36\t}\n37\t\n38\t/**\n39\t * Compiled subagent definition ready for Agent SDK dispatch.\n40\t */\n41\texport interface SubagentDefinition {\n42\t  name: string;\n43\t  model: string;\n44\t  instructions: string;\n45\t  disallowedTools: string[];\n46\t  bare: true;\n47\t}\n48\t\n49\t/**\n50\t * Patch file structure: extends identifies base, overrides deep-merged,\n51\t * prompt_patches preserved separately.\n52\t */\n53\texport interface AgentPatch {\n54\t  extends?: string;\n55\t  overrides?: Record<string, unknown>;\n56\t  prompt_patches?: {\n57\t    append?: string;\n58\t  };\n59\t}\n60\t\n61\t// --- Error Class ---\n62\t\n63\texport class AgentResolveError extends Error {\n64\t  public readonly filePath: string;\n65\t  public readonly errors: Array<{ path: string; message: string }>;\n66\t\n67\t  constructor(\n68\t    message: string,\n69\t    filePath: string,\n70\t    errors?: Array<{ path: string; message: string }>,\n71\t  ) {\n72\t    super(message);\n73\t    this.name = 'AgentResolveError';\n74\t    this.filePath = filePath;\n75\t    this.errors = errors ?? [];\n76\t  }\n77\t}\n78\t\n79\t// --- Constants ---\n80\t\n81\tconst TEMPLATES_DIR = resolve(__dirname, '../../templates/agents');\n82\tconst DEFAULT_MODEL = 'claude-sonnet-4-20250514';\n83\t\n84\t// --- Input Validation ---\n85\t\n86\tconst SAFE_NAME_RE = /^[a-zA-Z0-9_-]+$/;\n87\t\n88\t/**\n89\t * Validate agent name to prevent path traversal and unexpected characters.\n90\t */\n91\tfunction validateName(name: string): void {\n92\t  if (!name || !SAFE_NAME_RE.test(name)) {\n93\t    throw new AgentResolveError(\n94\t      `Invalid agent name: \"${name}\" — must match ${SAFE_NAME_RE}`,\n95\t      '',\n96\t      [{ path: '', message: `Invalid agent name: ${name}` }],\n97\t    );\n98\t  }\n99\t}\n100\t\n101\t// --- Deep Merge ---\n102\t\n103\t/**\n104\t * Deep merge strategy: objects merge recursively, arrays replace, scalars replace.\n105\t */\n106\tfunction deepMerge(base: Record<string, unknown>, patch: Record<string, unknown>): Record<string, unknown> {\n107\t  const result: Record<string, unknown> = { ...base };\n108\t\n109\t  for (const key of Object.keys(patch)) {\n110\t    const baseVal = base[key];\n111\t    const patchVal = patch[key];\n112\t\n113\t    if (\n114\t      patchVal !== null &&\n115\t      typeof patchVal === 'object' &&\n116\t      !Array.isArray(patchVal) &&\n117\t      baseVal !== null &&\n118\t      typeof baseVal === 'object' &&\n119\t      !Array.isArray(baseVal)\n120\t    ) {\n121\t      result[key] = deepMerge(\n122\t        baseVal as Record<string, unknown>,\n123\t        patchVal as Record<string, unknown>,\n124\t      );\n125\t    } else {\n126\t      result[key] = patchVal;\n127\t    }\n128\t  }\n129\t\n130\t  return result;\n131\t}\n132\t\n133\t// --- Embedded Agent Loading ---\n134\t\n135\t/**\n136\t * Load an embedded agent template from templates/agents/{name}.yaml.\n137\t * Throws AgentResolveError if not found or invalid.\n138\t */\n139\texport function loadEmbeddedAgent(name: string): ResolvedAgent {\n140\t  validateName(name);\n141\t  const filePath = join(TEMPLATES_DIR, `${name}.yaml`);\n142\t\n143\t  let raw: string;\n144\t  try {\n145\t    raw = readFileSync(filePath, 'utf-8');\n146\t  } catch { // IGNORE: rethrow as AgentResolveError with context\n147\t    throw new AgentResolveError(\n148\t      `Embedded agent not found: ${name}`,\n149\t      filePath,\n150\t      [{ path: filePath, message: `File not found: ${filePath}` }],\n151\t    );\n152\t  }\n153\t\n154\t  let parsed: unknown;\n155\t  try {\n156\t    parsed = parse(raw);\n157\t  } catch (err: unknown) {\n158\t    const msg = err instanceof Error ? err.message : String(err);\n159\t    throw new AgentResolveError(\n160\t      `Invalid YAML in embedded agent ${name}: ${msg}`,\n161\t      filePath,\n162\t      [{ path: filePath, message: msg }],\n163\t    );\n164\t  }\n165\t\n166\t  const result = validateAgentSchema(parsed);\n167\t  if (!result.valid) {\n168\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n169\t    throw new AgentResolveError(\n170\t      `Schema validation failed for embedded agent ${name}: ${details}`,\n171\t      filePath,\n172\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n173\t    );\n174\t  }\n175\t\n176\t  return parsed as ResolvedAgent;\n177\t}\n178\t\n179\t// --- Patch Loading ---\n180\t\n181\t/**\n182\t * Load a patch file. Returns null if the file does not exist (silent skip).\n183\t * Throws AgentResolveError on malformed YAML.\n184\t */\n185\texport function loadPatch(filePath: string): AgentPatch | null {\n186\t  if (!existsSync(filePath)) {\n187\t    return null;\n188\t  }\n189\t\n190\t  let raw: string;\n191\t  try {\n192\t    raw = readFileSync(filePath, 'utf-8');\n193\t  } catch { // IGNORE: file unreadable — treat as missing patch\n194\t    return null;\n195\t  }\n196\t\n197\t  let parsed: unknown;\n198\t  try {\n199\t    parsed = parse(raw);\n200\t  } catch (err: unknown) {\n201\t    const msg = err instanceof Error ? err.message : String(err);\n202\t    throw new AgentResolveError(\n203\t      `Invalid YAML in patch file: ${msg}`,\n204\t      filePath,\n205\t      [{ path: filePath, message: msg }],\n206\t    );\n207\t  }\n208\t\n209\t  if (parsed === null || typeof parsed !== 'object') {\n210\t    throw new AgentResolveError(\n211\t      `Patch file is not a valid object`,\n212\t      filePath,\n213\t      [{ path: filePath, message: 'Patch must be a YAML object' }],\n214\t    );\n215\t  }\n216\t\n217\t  return parsed as AgentPatch;\n218\t}\n219\t\n220\t// --- Patch Merging ---\n221\t\n222\t/**\n223\t * Merge a patch onto a base config. Deep-merges overrides, preserves prompt_patches separately.\n224\t */\n225\texport function mergePatch(\n226\t  base: Record<string, unknown>,\n227\t  patch: AgentPatch,\n228\t): Record<string, unknown> {\n229\t  let result = { ...base };\n230\t\n231\t  if (patch.overrides) {\n232\t    result = deepMerge(result, patch.overrides);\n233\t  }\n234\t\n235\t  if (patch.prompt_patches) {\n236\t    const existing = result.prompt_patches as { append?: string } | undefined;\n237\t    const existingAppend = existing?.append ?? '';\n238\t    const newAppend = patch.prompt_patches.append ?? '';\n239\t\n240\t    if (newAppend) {\n241\t      result.prompt_patches = {\n242\t        append: existingAppend ? `${existingAppend}\\n${newAppend}` : newAppend,\n243\t      };\n244\t    }\n245\t  }\n246\t\n247\t  return result;\n248\t}\n249\t\n250\t// --- Main Resolution ---\n251\t\n252\t/**\n253\t * Resolve an agent through the embedded -> user -> project patch chain.\n254\t * For custom agents (no embedded match, found at project/user level without extends), loads directly.\n255\t */\n256\texport function resolveAgent(name: string, options?: { cwd?: string }): ResolvedAgent {\n257\t  validateName(name);\n258\t  const cwd = options?.cwd ?? process.cwd();\n259\t  const userPatchPath = join(os.homedir(), '.codeharness', 'agents', `${name}.patch.yaml`);\n260\t  const projectPatchPath = join(cwd, '.codeharness', 'agents', `${name}.patch.yaml`);\n261\t\n262\t  // Check for custom agent (project-level full config, no extends)\n263\t  const projectCustomPath = join(cwd, '.codeharness', 'agents', `${name}.yaml`);\n264\t  const userCustomPath = join(os.homedir(), '.codeharness', 'agents', `${name}.yaml`);\n265\t\n266\t  // Try custom agent at project level first, then user level\n267\t  for (const customPath of [projectCustomPath, userCustomPath]) {\n268\t    if (existsSync(customPath)) {\n269\t      const patch = loadPatch(customPath);\n270\t      if (patch && !patch.extends) {\n271\t        // This is a full custom agent, not a patch — load and validate directly\n272\t        const parsed = patch as unknown as Record<string, unknown>;\n273\t        // Strip prompt_patches before schema validation (not in schema, same as patch path)\n274\t        const { prompt_patches: customPP, ...customForValidation } = parsed as Record<string, unknown> & { prompt_patches?: unknown };\n275\t        const result = validateAgentSchema(customForValidation);\n276\t        if (!result.valid) {\n277\t          const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n278\t          throw new AgentResolveError(\n279\t            `Schema validation failed for custom agent ${name}: ${details}`,\n280\t            customPath,\n281\t            result.errors.map((e) => ({ path: e.path, message: e.message })),\n282\t          );\n283\t        }\n284\t        return (customPP ? { ...customForValidation, prompt_patches: customPP } : customForValidation) as unknown as ResolvedAgent;\n285\t      }\n286\t    }\n287\t  }\n288\t\n289\t  // Load embedded base\n290\t  const base = loadEmbeddedAgent(name);\n291\t  let merged: Record<string, unknown> = base as unknown as Record<string, unknown>;\n292\t\n293\t  // Apply user patch\n294\t  const userPatch = loadPatch(userPatchPath);\n295\t  if (userPatch) {\n296\t    merged = mergePatch(merged, userPatch);\n297\t  }\n298\t\n299\t  // Apply project patch\n300\t  const projectPatch = loadPatch(projectPatchPath);\n301\t  if (projectPatch) {\n302\t    merged = mergePatch(merged, projectPatch);\n303\t  }\n304\t\n305\t  // Validate merged result (strip prompt_patches for schema validation since it's not in schema)\n306\t  const { prompt_patches, ...forValidation } = merged as Record<string, unknown> & { prompt_patches?: unknown };\n307\t  const result = validateAgentSchema(forValidation);\n308\t  if (!result.valid) {\n309\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n310\t    const errorPath = projectPatch ? projectPatchPath : userPatch ? userPatchPath : 'merged';\n311\t    throw new AgentResolveError(\n312\t      `Schema validation failed after merging patches for ${name}: ${details}`,\n313\t      errorPath,\n314\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n315\t    );\n316\t  }\n317\t\n318\t  // Re-attach prompt_patches if present, return without mutating forValidation\n319\t  return (prompt_patches\n320\t    ? { ...forValidation, prompt_patches }\n321\t    : forValidation) as unknown as ResolvedAgent;\n322\t}\n323\t\n324\t// --- Subagent Compilation ---\n325\t\n326\t/**\n327\t * Compile a ResolvedAgent into a SubagentDefinition for Agent SDK dispatch.\n328\t */\n329\texport function compileSubagentDefinition(agent: ResolvedAgent): SubagentDefinition {\n330\t  const parts: string[] = [];\n331\t\n332\t  parts.push(`You are ${agent.persona.identity}`);\n333\t  parts.push(`Communication style: ${agent.persona.communication_style}`);\n334\t\n335\t  if (agent.persona.principles.length > 0) {\n336\t    const bullets = agent.persona.principles.map((p) => `- ${p}`).join('\\n');\n337\t    parts.push(`Principles:\\n${bullets}`);\n338\t  }\n339\t\n340\t  if (agent.prompt_patches?.append) {\n341\t    parts.push(agent.prompt_patches.append);\n342\t  }\n343\t\n344\t  if (agent.prompt_template) {\n345\t    parts.push(agent.prompt_template);\n346\t  }\n347\t\n348\t  return {\n349\t    name: agent.name,\n350\t    model: DEFAULT_MODEL,\n351\t    instructions: parts.join('\\n\\n'),\n352\t    disallowedTools: agent.disallowedTools ?? [],\n353\t    bare: true,\n354\t  };\n355\t}\n356\t"}]},"parent_tool_use_id":"toolu_01WBGtD6t91yRv6Crn8gGaXn","session_id":"52ded6f4-857c-404a-a480-19bb12459ee1","uuid":"c156fb96-eb28-4bb6-88ab-863940818bbd","timestamp":"2026-04-03T00:38:44.259Z"}
