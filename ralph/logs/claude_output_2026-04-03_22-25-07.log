{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RLhUm6XWHZ22mx6YvZixxf","type":"tool_result","content":"1\timport type { SubagentDefinition } from './agent-resolver.js';\n2\timport type { DispatchResult } from './agent-dispatch.js';\n3\timport { dispatchAgent } from './agent-dispatch.js';\n4\timport { createIsolatedWorkspace } from './source-isolation.js';\n5\timport type { IsolatedWorkspace } from './source-isolation.js';\n6\timport { isDockerAvailable } from './docker/index.js';\n7\timport { formatTracePrompt } from './trace-id.js';\n8\t\n9\t// --- Interfaces ---\n10\t\n11\t/**\n12\t * Coverage context from a previous task's output contract.\n13\t * When present, the evaluator prompt includes pre-computed coverage data\n14\t * so coverage does not need to be re-run.\n15\t */\n16\texport interface CoverageContext {\n17\t  /** The coverage percentage from the implement task's output contract. */\n18\t  coverage: number;\n19\t  /** The coverage target from the harness state. */\n20\t  target: number;\n21\t}\n22\t\n23\t/**\n24\t * Options for running the blind evaluator.\n25\t */\n26\texport interface EvaluatorOptions {\n27\t  /** Unique run identifier — used in workspace path and tracing. */\n28\t  runId: string;\n29\t  /** Absolute paths to story files containing acceptance criteria. */\n30\t  storyFiles: string[];\n31\t  /** Pre-compiled subagent definition for the evaluator agent. */\n32\t  agentDefinition: SubagentDefinition;\n33\t  /** Timeout in milliseconds for the evaluator dispatch. Default: 300000 (5 minutes). */\n34\t  timeoutMs?: number;\n35\t  /** Optional trace ID for correlation in logs/metrics. */\n36\t  traceId?: string;\n37\t  /** Optional pre-computed coverage context — when provided, coverage is not re-run. */\n38\t  coverageContext?: CoverageContext;\n39\t}\n40\t\n41\t/**\n42\t * Result of an evaluator run.\n43\t */\n44\texport interface EvaluatorResult {\n45\t  /** Raw agent output (or synthesized JSON for fallback cases). */\n46\t  output: string;\n47\t  /** Whether the evaluator completed successfully. */\n48\t  success: boolean;\n49\t  /** Wall-clock duration of the evaluator run in milliseconds. */\n50\t  durationMs: number;\n51\t  /** Whether Docker was available at the time of the run. */\n52\t  dockerAvailable: boolean;\n53\t  /** Whether the evaluator timed out. */\n54\t  timedOut: boolean;\n55\t}\n56\t\n57\t// --- Constants ---\n58\t\n59\tconst DEFAULT_TIMEOUT_MS = 300_000; // 5 minutes\n60\t\n61\t/**\n62\t * Build the evaluator dispatch prompt from the compiled agent definition instructions.\n63\t * The compiled SubagentDefinition.instructions already contain the prompt_template\n64\t * from evaluator.yaml (appended by compileSubagentDefinition). This function adds\n65\t * the minimal task-kick context that varies per dispatch — story file location and\n66\t * output directory. The full anti-leniency prompt, evidence requirements, and output\n67\t * format are in the instructions (system prompt), not duplicated here.\n68\t *\n69\t * When `coverageContext` is provided (coverage already met by engine flag propagation),\n70\t * a coverage context block is appended so the evaluator does not re-run coverage.\n71\t */\n72\texport function buildEvaluatorPrompt(coverageContext?: CoverageContext): string {\n73\t  const parts: string[] = [];\n74\t\n75\t  parts.push('Verify the acceptance criteria for this story.');\n76\t  parts.push('Story files are available in ./story-files/. Read each file to find the ACs.');\n77\t  parts.push('Write your verdict JSON output to ./verdict/verdict.json.');\n78\t\n79\t  if (coverageContext) {\n80\t    parts.push('');\n81\t    parts.push(\n82\t      `Coverage already verified by engine: ${coverageContext.coverage}% (target: ${coverageContext.target}%). No re-run needed.`,\n83\t    );\n84\t  }\n85\t\n86\t  return parts.join('\\n');\n87\t}\n88\t\n89\t// --- Helpers ---\n90\t\n91\t/**\n92\t * Build a fallback output JSON string with all ACs scored UNKNOWN.\n93\t */\n94\tfunction buildUnknownOutput(storyFiles: string[], reasoning: string): string {\n95\t  // We don't know how many ACs each story file has, so we produce\n96\t  // a single finding per story file with status unknown.\n97\t  const findings = storyFiles.map((_, index) => ({\n98\t    ac: index + 1,\n99\t    description: `AC #${index + 1}`,\n100\t    status: 'unknown' as const,\n101\t    evidence: {\n102\t      commands_run: [],\n103\t      output_observed: '',\n104\t      reasoning,\n105\t    },\n106\t  }));\n107\t\n108\t  return JSON.stringify({\n109\t    verdict: 'fail',\n110\t    score: {\n111\t      passed: 0,\n112\t      failed: 0,\n113\t      unknown: findings.length,\n114\t      total: findings.length,\n115\t    },\n116\t    findings,\n117\t  });\n118\t}\n119\t\n120\t// --- Main Function ---\n121\t\n122\t/**\n123\t * Run the blind evaluator lifecycle:\n124\t *   1. Check Docker availability\n125\t *   2. Create isolated workspace\n126\t *   3. Dispatch evaluator agent (with timeout)\n127\t *   4. Collect result\n128\t *   5. Cleanup workspace\n129\t *\n130\t * Returns raw output for downstream parsing (story 6-2).\n131\t * Does NOT throw on Docker unavailability or timeout — returns graceful UNKNOWN results.\n132\t */\n133\texport async function runEvaluator(options: EvaluatorOptions): Promise<EvaluatorResult> {\n134\t  const startMs = Date.now();\n135\t  const timeoutMs = options.timeoutMs ?? DEFAULT_TIMEOUT_MS;\n136\t\n137\t  // Step 1: Check Docker availability\n138\t  const dockerAvailable = isDockerAvailable();\n139\t  if (!dockerAvailable) {\n140\t    return {\n141\t      output: buildUnknownOutput(\n142\t        options.storyFiles,\n143\t        'Docker is not available — cannot run verification commands.',\n144\t      ),\n145\t      success: false,\n146\t      durationMs: Date.now() - startMs,\n147\t      dockerAvailable: false,\n148\t      timedOut: false,\n149\t    };\n150\t  }\n151\t\n152\t  // Step 2: Create isolated workspace\n153\t  let workspace: IsolatedWorkspace | undefined;\n154\t  try {\n155\t    workspace = await createIsolatedWorkspace({\n156\t      runId: options.runId,\n157\t      storyFiles: options.storyFiles,\n158\t    });\n159\t\n160\t    // Step 3: Build dispatch options\n161\t    const dispatchOptions = workspace.toDispatchOptions();\n162\t    if (options.traceId) {\n163\t      dispatchOptions.appendSystemPrompt = formatTracePrompt(options.traceId);\n164\t    }\n165\t\n166\t    // Step 4: Race dispatch against timeout\n167\t    const evaluatorPrompt = buildEvaluatorPrompt(options.coverageContext);\n168\t    const dispatchPromise = dispatchAgent(\n169\t      options.agentDefinition,\n170\t      evaluatorPrompt,\n171\t      dispatchOptions,\n172\t    );\n173\t\n174\t    let timeoutTimer: ReturnType<typeof setTimeout> | undefined;\n175\t    const timeoutPromise = new Promise<never>((_, reject) => {\n176\t      timeoutTimer = setTimeout(() => reject(new Error('Evaluator timeout')), timeoutMs);\n177\t    });\n178\t\n179\t    let result: DispatchResult;\n180\t    try {\n181\t      result = await Promise.race([dispatchPromise, timeoutPromise]);\n182\t    } catch (err: unknown) {\n183\t      const message = err instanceof Error ? err.message : String(err);\n184\t      if (message === 'Evaluator timeout') {\n185\t        return {\n186\t          output: buildUnknownOutput(\n187\t            options.storyFiles,\n188\t            `Evaluator timed out after ${timeoutMs}ms.`,\n189\t          ),\n190\t          success: false,\n191\t          durationMs: Date.now() - startMs,\n192\t          dockerAvailable: true,\n193\t          timedOut: true,\n194\t        };\n195\t      }\n196\t      // Re-throw non-timeout errors\n197\t      throw err;\n198\t    } finally {\n199\t      // Clear the timeout timer to prevent Node.js process from hanging\n200\t      if (timeoutTimer) {\n201\t        clearTimeout(timeoutTimer);\n202\t      }\n203\t    }\n204\t\n205\t    return {\n206\t      output: result.output,\n207\t      success: result.success,\n208\t      durationMs: Date.now() - startMs,\n209\t      dockerAvailable: true,\n210\t      timedOut: false,\n211\t    };\n212\t  } finally {\n213\t    // Step 5: Cleanup workspace (always)\n214\t    if (workspace) {\n215\t      await workspace.cleanup();\n216\t    }\n217\t  }\n218\t}\n219\t"}]},"parent_tool_use_id":"toolu_01Ddtfy6XmQWtkAycqZdji9G","session_id":"b6bb3bfc-8778-4f16-a616-88028acc2431","uuid":"c3ce68e5-e273-48b3-bfed-b956156f673b","timestamp":"2026-04-03T18:40:27.895Z"}
