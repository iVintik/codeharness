{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Vbqnr1dQZt16YM7jhLyzqN","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport {\n3\t  parseVerdict,\n4\t  validateVerdict,\n5\t  VerdictParseError,\n6\t} from '../verdict-parser.js';\n7\timport type { EvaluatorVerdict, VerdictValidationResult } from '../verdict-parser.js';\n8\t\n9\t// --- Fixtures ---\n10\t\n11\tfunction makeValidVerdict(overrides?: Partial<EvaluatorVerdict>): EvaluatorVerdict {\n12\t  return {\n13\t    verdict: 'pass',\n14\t    score: { passed: 2, failed: 0, unknown: 0, total: 2 },\n15\t    findings: [\n16\t      {\n17\t        ac: 1,\n18\t        description: 'Server starts on port 3000',\n19\t        status: 'pass',\n20\t        evidence: {\n21\t          commands_run: ['curl http://localhost:3000'],\n22\t          output_observed: 'HTTP 200 OK',\n23\t          reasoning: 'Server responded with 200',\n24\t        },\n25\t      },\n26\t      {\n27\t        ac: 2,\n28\t        description: 'Database migrated',\n29\t        status: 'pass',\n30\t        evidence: {\n31\t          commands_run: ['npm run migrate:status'],\n32\t          output_observed: 'All migrations applied',\n33\t          reasoning: 'Migration status confirmed',\n34\t        },\n35\t      },\n36\t    ],\n37\t    ...overrides,\n38\t  };\n39\t}\n40\t\n41\tfunction makeValidVerdictJSON(overrides?: Partial<EvaluatorVerdict>): string {\n42\t  return JSON.stringify(makeValidVerdict(overrides));\n43\t}\n44\t\n45\t// --- Schema Validation Tests ---\n46\t\n47\tdescribe('validateVerdict', () => {\n48\t  it('validates a correct verdict object', () => {\n49\t    const result = validateVerdict(makeValidVerdict());\n50\t    expect(result.valid).toBe(true);\n51\t    expect(result.verdict).toBeDefined();\n52\t    expect(result.errors).toBeUndefined();\n53\t  });\n54\t\n55\t  it('rejects missing verdict field', () => {\n56\t    const data = { score: { passed: 0, failed: 0, unknown: 0, total: 0 }, findings: [] };\n57\t    const result = validateVerdict(data);\n58\t    expect(result.valid).toBe(false);\n59\t    expect(result.errors).toBeDefined();\n60\t    expect(result.errors!.some((e) => e.includes('verdict'))).toBe(true);\n61\t  });\n62\t\n63\t  it('rejects invalid verdict enum value', () => {\n64\t    const data = makeValidVerdict();\n65\t    (data as Record<string, unknown>).verdict = 'maybe';\n66\t    const result = validateVerdict(data);\n67\t    expect(result.valid).toBe(false);\n68\t    expect(result.errors).toBeDefined();\n69\t    expect(result.errors!.some((e) => e.includes('verdict'))).toBe(true);\n70\t  });\n71\t\n72\t  it('rejects missing score field', () => {\n73\t    const data = { verdict: 'pass', findings: [] };\n74\t    const result = validateVerdict(data);\n75\t    expect(result.valid).toBe(false);\n76\t    expect(result.errors!.some((e) => e.includes('score'))).toBe(true);\n77\t  });\n78\t\n79\t  it('rejects missing findings field', () => {\n80\t    const data = { verdict: 'pass', score: { passed: 0, failed: 0, unknown: 0, total: 0 } };\n81\t    const result = validateVerdict(data);\n82\t    expect(result.valid).toBe(false);\n83\t    expect(result.errors!.some((e) => e.includes('findings'))).toBe(true);\n84\t  });\n85\t\n86\t  it('rejects non-integer score values', () => {\n87\t    const data = makeValidVerdict();\n88\t    (data.score as Record<string, unknown>).passed = 'one';\n89\t    const result = validateVerdict(data);\n90\t    expect(result.valid).toBe(false);\n91\t    expect(result.errors).toBeDefined();\n92\t  });\n93\t\n94\t  it('rejects negative score values', () => {\n95\t    const data = makeValidVerdict();\n96\t    data.score.passed = -1;\n97\t    const result = validateVerdict(data);\n98\t    expect(result.valid).toBe(false);\n99\t  });\n100\t\n101\t  it('rejects invalid finding status enum', () => {\n102\t    const data = makeValidVerdict();\n103\t    (data.findings[0] as Record<string, unknown>).status = 'partial';\n104\t    const result = validateVerdict(data);\n105\t    expect(result.valid).toBe(false);\n106\t    expect(result.errors!.some((e) => e.includes('status'))).toBe(true);\n107\t  });\n108\t\n109\t  it('rejects missing evidence in finding', () => {\n110\t    const data = makeValidVerdict();\n111\t    delete (data.findings[0] as Record<string, unknown>).evidence;\n112\t    const result = validateVerdict(data);\n113\t    expect(result.valid).toBe(false);\n114\t  });\n115\t\n116\t  it('rejects non-string commands_run items', () => {\n117\t    const data = makeValidVerdict();\n118\t    (data.findings[0].evidence.commands_run as unknown[]) = [42];\n119\t    const result = validateVerdict(data);\n120\t    expect(result.valid).toBe(false);\n121\t  });\n122\t\n123\t  it('accepts optional evaluator_trace_id', () => {\n124\t    const data = makeValidVerdict();\n125\t    data.evaluator_trace_id = 'trace-abc-123';\n126\t    const result = validateVerdict(data);\n127\t    expect(result.valid).toBe(true);\n128\t    expect(result.verdict!.evaluator_trace_id).toBe('trace-abc-123');\n129\t  });\n130\t\n131\t  it('accepts optional duration_seconds', () => {\n132\t    const data = makeValidVerdict();\n133\t    data.duration_seconds = 12.5;\n134\t    const result = validateVerdict(data);\n135\t    expect(result.valid).toBe(true);\n136\t    expect(result.verdict!.duration_seconds).toBe(12.5);\n137\t  });\n138\t\n139\t  it('returns specific error messages for each violation', () => {\n140\t    // Multiple violations at once\n141\t    const data = { verdict: 'maybe', score: { passed: 'x' }, findings: 'not-array' };\n142\t    const result = validateVerdict(data);\n143\t    expect(result.valid).toBe(false);\n144\t    expect(result.errors!.length).toBeGreaterThan(1);\n145\t  });\n146\t});\n147\t\n148\t// --- parseVerdict Tests ---\n149\t\n150\tdescribe('parseVerdict', () => {\n151\t  it('parses valid verdict JSON and returns typed object', () => {\n152\t    const verdict = parseVerdict(makeValidVerdictJSON());\n153\t    expect(verdict.verdict).toBe('pass');\n154\t    expect(verdict.score.passed).toBe(2);\n155\t    expect(verdict.score.failed).toBe(0);\n156\t    expect(verdict.findings).toHaveLength(2);\n157\t    expect(verdict.findings[0].ac).toBe(1);\n158\t    expect(verdict.findings[0].evidence.commands_run).toContain('curl http://localhost:3000');\n159\t  });\n160\t\n161\t  it('parses verdict with all optional fields', () => {\n162\t    const verdict = parseVerdict(makeValidVerdictJSON({\n163\t      evaluator_trace_id: 'trace-xyz',\n164\t      duration_seconds: 45.2,\n165\t    }));\n166\t    expect(verdict.evaluator_trace_id).toBe('trace-xyz');\n167\t    expect(verdict.duration_seconds).toBe(45.2);\n168\t  });\n169\t\n170\t  it('tolerates extra fields in verdict (not rejected)', () => {\n171\t    const input = {\n172\t      ...makeValidVerdict(),\n173\t      custom_metadata: { foo: 'bar' },\n174\t      extra_field: true,\n175\t    };\n176\t    const verdict = parseVerdict(JSON.stringify(input));\n177\t    expect(verdict.verdict).toBe('pass');\n178\t  });\n179\t\n180\t  // --- PASS-evidence downgrade tests ---\n181\t\n182\t  it('downgrades PASS finding with empty commands_run to UNKNOWN', () => {\n183\t    const input = makeValidVerdict();\n184\t    input.findings[0].status = 'pass';\n185\t    input.findings[0].evidence.commands_run = [];\n186\t    input.findings[0].evidence.reasoning = 'Looked good';\n187\t\n188\t    const verdict = parseVerdict(JSON.stringify(input));\n189\t    expect(verdict.findings[0].status).toBe('unknown');\n190\t    expect(verdict.findings[0].evidence.reasoning).toContain(\n191\t      '[Downgraded from PASS: no commands_run evidence provided]',\n192\t    );\n193\t  });\n194\t\n195\t  it('recalculates score after PASS-evidence downgrade', () => {\n196\t    const input = makeValidVerdict();\n197\t    // Both findings are PASS but first has empty commands_run\n198\t    input.findings[0].evidence.commands_run = [];\n199\t    input.score = { passed: 2, failed: 0, unknown: 0, total: 2 };\n200\t\n201\t    const verdict = parseVerdict(JSON.stringify(input));\n202\t    expect(verdict.score.passed).toBe(1);\n203\t    expect(verdict.score.unknown).toBe(1);\n204\t    expect(verdict.score.total).toBe(2);\n205\t  });\n206\t\n207\t  it('flips verdict to fail when all PASSes are downgraded', () => {\n208\t    const input = makeValidVerdict();\n209\t    // Both findings have empty commands_run\n210\t    input.findings[0].evidence.commands_run = [];\n211\t    input.findings[1].evidence.commands_run = [];\n212\t\n213\t    const verdict = parseVerdict(JSON.stringify(input));\n214\t    expect(verdict.verdict).toBe('fail');\n215\t    expect(verdict.score.passed).toBe(0);\n216\t    expect(verdict.score.unknown).toBe(2);\n217\t  });\n218\t\n219\t  it('keeps PASS finding with non-empty commands_run', () => {\n220\t    const verdict = parseVerdict(makeValidVerdictJSON());\n221\t    expect(verdict.findings[0].status).toBe('pass');\n222\t    expect(verdict.findings[1].status).toBe('pass');\n223\t  });\n224\t\n225\t  // --- Error cases ---\n226\t\n227\t  it('throws VerdictParseError with retryable=true for invalid JSON', () => {\n228\t    try {\n229\t      parseVerdict('not json at all');\n230\t      expect.fail('should have thrown');\n231\t    } catch (err) {\n232\t      expect(err).toBeInstanceOf(VerdictParseError);\n233\t      const vpe = err as VerdictParseError;\n234\t      expect(vpe.retryable).toBe(true);\n235\t      expect(vpe.rawOutput).toBe('not json at all');\n236\t    }\n237\t  });\n238\t\n239\t  it('throws VerdictParseError with retryable=true for empty string', () => {\n240\t    try {\n241\t      parseVerdict('');\n242\t      expect.fail('should have thrown');\n243\t    } catch (err) {\n244\t      expect(err).toBeInstanceOf(VerdictParseError);\n245\t      const vpe = err as VerdictParseError;\n246\t      expect(vpe.retryable).toBe(true);\n247\t      expect(vpe.rawOutput).toBe('');\n248\t    }\n249\t  });\n250\t\n251\t  it('throws VerdictParseError with retryable=true for partial JSON', () => {\n252\t    try {\n253\t      parseVerdict('{\"verdict\": \"pass\", \"score\":');\n254\t      expect.fail('should have thrown');\n255\t    } catch (err) {\n256\t      expect(err).toBeInstanceOf(VerdictParseError);\n257\t      const vpe = err as VerdictParseError;\n258\t      expect(vpe.retryable).toBe(true);\n259\t    }\n260\t  });\n261\t\n262\t  it('throws VerdictParseError with retryable=true for schema-invalid JSON', () => {\n263\t    try {\n264\t      parseVerdict(JSON.stringify({ verdict: 'maybe', score: {}, findings: [] }));\n265\t      expect.fail('should have thrown');\n266\t    } catch (err) {\n267\t      expect(err).toBeInstanceOf(VerdictParseError);\n268\t      const vpe = err as VerdictParseError;\n269\t      expect(vpe.retryable).toBe(true);\n270\t      expect(vpe.validationErrors).toBeDefined();\n271\t      expect(vpe.validationErrors!.length).toBeGreaterThan(0);\n272\t    }\n273\t  });\n274\t\n275\t  it('throws VerdictParseError for non-object JSON values', () => {\n276\t    expect(() => parseVerdict('\"just a string\"')).toThrow(VerdictParseError);\n277\t    expect(() => parseVerdict('42')).toThrow(VerdictParseError);\n278\t    expect(() => parseVerdict('null')).toThrow(VerdictParseError);\n279\t    expect(() => parseVerdict('true')).toThrow(VerdictParseError);\n280\t  });\n281\t});\n282\t\n283\t// --- VerdictParseError shape tests ---\n284\t\n285\tdescribe('VerdictParseError', () => {\n286\t  it('extends Error', () => {\n287\t    const err = new VerdictParseError('test', true, 'raw');\n288\t    expect(err).toBeInstanceOf(Error);\n289\t    expect(err.name).toBe('VerdictParseError');\n290\t  });\n291\t\n292\t  it('has retryable, rawOutput, and optional validationErrors', () => {\n293\t    const err = new VerdictParseError('msg', true, 'raw-output', ['err1', 'err2']);\n294\t    expect(err.retryable).toBe(true);\n295\t    expect(err.rawOutput).toBe('raw-output');\n296\t    expect(err.validationErrors).toEqual(['err1', 'err2']);\n297\t    expect(err.message).toBe('msg');\n298\t  });\n299\t\n300\t  it('validationErrors is undefined when not provided', () => {\n301\t    const err = new VerdictParseError('msg', false, 'raw');\n302\t    expect(err.retryable).toBe(false);\n303\t    expect(err.validationErrors).toBeUndefined();\n304\t  });\n305\t});\n306\t"}]},"parent_tool_use_id":"toolu_01Lp1WM9dkDn419erDDCd9nG","session_id":"64d7a6a2-a6f8-43cb-b618-df314a0f5500","uuid":"2644bec5-e61c-4a25-9bcd-ac35d470af4b","timestamp":"2026-04-03T00:08:54.620Z"}
