{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Vhk5aRyVdwr5C4qeZng7zD","type":"tool_result","content":"160\t      }\n161\t    }\n162\t  }\n163\t\n164\t  // --- Load issues from issues.yaml ---\n165\t  if (issuesPath && existsSync(issuesPath)) {\n166\t    let raw: string;\n167\t    try {\n168\t      raw = readFileSync(issuesPath, 'utf-8');\n169\t    } catch { // IGNORE: unreadable issues file — warn and return what we have\n170\t      warn(`workflow-engine: could not read issues.yaml at ${issuesPath}`);\n171\t      return items;\n172\t    }\n173\t\n174\t    let parsed: unknown;\n175\t    try {\n176\t      parsed = parse(raw);\n177\t    } catch { // IGNORE: malformed issues YAML — warn and return what we have\n178\t      warn(`workflow-engine: invalid YAML in issues.yaml at ${issuesPath}`);\n179\t      return items;\n180\t    }\n181\t\n182\t    if (parsed && typeof parsed === 'object') {\n183\t      const data = parsed as Record<string, unknown>;\n184\t      const issuesList = data.issues as Array<Record<string, unknown>> | undefined;\n185\t\n186\t      if (Array.isArray(issuesList)) {\n187\t        for (const issue of issuesList) {\n188\t          if (issue && typeof issue === 'object') {\n189\t            const status = issue.status as string | undefined;\n190\t            if (status === 'backlog' || status === 'ready-for-dev') {\n191\t              items.push({\n192\t                key: issue.id as string,\n193\t                title: issue.title as string | undefined,\n194\t                source: 'issues',\n195\t              });\n196\t            }\n197\t          }\n198\t        }\n199\t      }\n200\t    }\n201\t  }\n202\t\n203\t  return items;\n204\t}\n205\t\n206\t// --- Single Task Dispatch ---\n207\t\n208\t/**\n209\t * Dispatch a single task for a specific work item (or per-run sentinel).\n210\t *\n211\t * Handles: trace ID generation, session resolution, source isolation,\n212\t * agent dispatch, state checkpointing, and cleanup.\n213\t *\n214\t * Returns the updated workflow state after recording the dispatch.\n215\t */\n216\texport async function dispatchTask(\n217\t  task: ResolvedTask,\n218\t  taskName: string,\n219\t  storyKey: string,\n220\t  definition: SubagentDefinition,\n221\t  state: WorkflowState,\n222\t  config: EngineConfig,\n223\t  customPrompt?: string,\n224\t): Promise<WorkflowState> {\n225\t  const { updatedState } = await dispatchTaskWithResult(\n226\t    task, taskName, storyKey, definition, state, config, customPrompt,\n227\t  );\n228\t  return updatedState;\n229\t}\n230\t\n231\t// --- Flow Step Type Guard ---\n232\t\n233\tfunction isLoopBlock(step: FlowStep): step is LoopBlock {\n234\t  return typeof step === 'object' && step !== null && 'loop' in step;\n235\t}\n236\t\n237\t// --- Core Dispatch (shared by dispatchTask and loop block execution) ---\n238\t\n239\t/**\n240\t * Dispatch a task and return both the updated state and the raw dispatch output.\n241\t * This is the single implementation of task dispatch logic. Both `dispatchTask()`\n242\t * and loop block execution delegate here.\n243\t */\n244\tasync function dispatchTaskWithResult(\n245\t  task: ResolvedTask,\n246\t  taskName: string,\n247\t  storyKey: string,\n248\t  definition: SubagentDefinition,\n249\t  state: WorkflowState,\n250\t  config: EngineConfig,\n251\t  customPrompt?: string,\n252\t): Promise<{ updatedState: WorkflowState; output: string }> {\n253\t  const projectDir = config.projectDir ?? process.cwd();\n254\t\n255\t  // 1. Generate trace ID\n256\t  const traceId = generateTraceId(config.runId, state.iteration, taskName);\n257\t\n258\t  // 2. Format trace prompt\n259\t  const tracePrompt = formatTracePrompt(traceId);\n260\t\n261\t  // 3. Resolve session ID\n262\t  const sessionKey: SessionLookupKey = { taskName, storyKey };\n263\t  const sessionId = resolveSessionId(task.session, sessionKey, state);\n264\t\n265\t  // 4. Build dispatch options based on source_access\n266\t  let dispatchOptions: DispatchOptions;\n267\t  let workspace: Awaited<ReturnType<typeof createIsolatedWorkspace>> | null = null;\n268\t\n269\t  if (task.source_access === false) {\n270\t    workspace = await createIsolatedWorkspace({ runId: config.runId, storyFiles: [] });\n271\t    dispatchOptions = {\n272\t      ...workspace.toDispatchOptions(),\n273\t      sessionId,\n274\t      appendSystemPrompt: tracePrompt,\n275\t    };\n276\t  } else {\n277\t    dispatchOptions = {\n278\t      cwd: projectDir,\n279\t      sessionId,\n280\t      appendSystemPrompt: tracePrompt,\n281\t    };\n282\t  }\n283\t\n284\t  // 5. Construct prompt\n285\t  const prompt = customPrompt\n286\t    ?? (storyKey === PER_RUN_SENTINEL\n287\t      ? `Execute task \"${taskName}\" for the current run.`\n288\t      : `Implement story ${storyKey}`);\n289\t\n290\t  // 6. Dispatch agent\n291\t  let result: DispatchResult;\n292\t  try {\n293\t    result = await dispatchAgent(definition, prompt, dispatchOptions);\n294\t  } finally {\n295\t    // Cleanup workspace regardless of dispatch success/failure\n296\t    if (workspace) {\n297\t      await workspace.cleanup();\n298\t    }\n299\t  }\n300\t\n301\t  // 7. Record session ID (if dispatch returned one)\n302\t  let updatedState = state;\n303\t  if (result.sessionId) {\n304\t    updatedState = recordSessionId(sessionKey, result.sessionId, updatedState);\n305\t  } else {\n306\t    // Append checkpoint manually when no session ID is returned\n307\t    const checkpoint: TaskCheckpoint = {\n308\t      task_name: taskName,\n309\t      story_key: storyKey,\n310\t      completed_at: new Date().toISOString(),\n311\t    };\n312\t    updatedState = {\n313\t      ...updatedState,\n314\t      tasks_completed: [...updatedState.tasks_completed, checkpoint],\n315\t    };\n316\t  }\n317\t\n318\t  // 8. Record trace ID\n319\t  updatedState = recordTraceId(traceId, updatedState);\n320\t\n321\t  // 9. Write state to disk\n322\t  writeWorkflowState(updatedState, projectDir);\n323\t\n324\t  return { updatedState, output: result.output };\n325\t}\n326\t\n327\t// --- Verdict Parsing (Task 2) ---\n328\t\n329\t/**\n330\t * Attempt to parse a DispatchResult.output string as an EvaluatorVerdict.\n331\t * Returns null if parsing fails or required fields are missing.\n332\t */\n333\texport function parseVerdict(output: string): EvaluatorVerdict | null {\n334\t  let parsed: unknown;\n335\t  try {\n336\t    parsed = JSON.parse(output);\n337\t  } catch { // IGNORE: invalid JSON means no verdict — return null\n338\t    return null;\n339\t  }\n340\t\n341\t  if (!parsed || typeof parsed !== 'object') return null;\n342\t\n343\t  const obj = parsed as Record<string, unknown>;\n344\t\n345\t  // Validate required top-level fields\n346\t  if (obj.verdict !== 'pass' && obj.verdict !== 'fail') return null;\n347\t  if (!obj.score || typeof obj.score !== 'object') return null;\n348\t  if (!Array.isArray(obj.findings)) return null;\n349\t\n350\t  const score = obj.score as Record<string, unknown>;\n351\t  if (typeof score.passed !== 'number') return null;\n352\t  if (typeof score.failed !== 'number') return null;\n353\t  if (typeof score.unknown !== 'number') return null;\n354\t  if (typeof score.total !== 'number') return null;\n355\t\n356\t  return parsed as EvaluatorVerdict;\n357\t}\n358\t\n359\t// --- Retry Prompt Construction (Task 3) ---"}]},"parent_tool_use_id":"toolu_011eJ4iFzBFG7CSy7fE3qSCc","session_id":"8b4a1da7-9e18-4302-ad13-ce7f0aff0314","uuid":"b7408dff-2e2f-49af-bf34-b78e329791fb","timestamp":"2026-04-02T22:43:22.616Z"}
