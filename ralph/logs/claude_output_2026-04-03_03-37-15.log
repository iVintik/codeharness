{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016eJ9pKMcknJeJu1zPwCBef","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach } from 'vitest';\n2\t\n3\t// --- Mocks (must be before imports) ---\n4\t\n5\tvi.mock('../docker/index.js', () => ({\n6\t  isDockerAvailable: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock('../source-isolation.js', () => ({\n10\t  createIsolatedWorkspace: vi.fn(),\n11\t}));\n12\t\n13\tvi.mock('../agent-dispatch.js', () => ({\n14\t  dispatchAgent: vi.fn(),\n15\t}));\n16\t\n17\tvi.mock('../trace-id.js', () => ({\n18\t  formatTracePrompt: vi.fn(),\n19\t}));\n20\t\n21\t// --- Imports ---\n22\t\n23\timport { runEvaluator } from '../evaluator.js';\n24\timport type { EvaluatorOptions, EvaluatorResult } from '../evaluator.js';\n25\timport { isDockerAvailable } from '../docker/index.js';\n26\timport { createIsolatedWorkspace } from '../source-isolation.js';\n27\timport { dispatchAgent } from '../agent-dispatch.js';\n28\timport { formatTracePrompt } from '../trace-id.js';\n29\timport type { SubagentDefinition } from '../agent-resolver.js';\n30\timport type { IsolatedWorkspace } from '../source-isolation.js';\n31\timport type { DispatchResult } from '../agent-dispatch.js';\n32\t\n33\t// --- Helpers ---\n34\t\n35\tfunction makeAgentDef(overrides?: Partial<SubagentDefinition>): SubagentDefinition {\n36\t  return {\n37\t    name: 'evaluator',\n38\t    model: 'claude-sonnet-4-20250514',\n39\t    instructions: 'You are the evaluator.',\n40\t    disallowedTools: ['Edit', 'Write'],\n41\t    bare: true,\n42\t    ...overrides,\n43\t  };\n44\t}\n45\t\n46\tfunction makeMockWorkspace(): IsolatedWorkspace {\n47\t  return {\n48\t    dir: '/tmp/codeharness-verify-test-run',\n49\t    storyFilesDir: '/tmp/codeharness-verify-test-run/story-files',\n50\t    verdictDir: '/tmp/codeharness-verify-test-run/verdict',\n51\t    toDispatchOptions: vi.fn().mockReturnValue({ cwd: '/tmp/codeharness-verify-test-run' }),\n52\t    cleanup: vi.fn().mockResolvedValue(undefined),\n53\t  };\n54\t}\n55\t\n56\tfunction makeOptions(overrides?: Partial<EvaluatorOptions>): EvaluatorOptions {\n57\t  return {\n58\t    runId: 'test-run',\n59\t    storyFiles: ['/path/to/story-1.md', '/path/to/story-2.md'],\n60\t    agentDefinition: makeAgentDef(),\n61\t    ...overrides,\n62\t  };\n63\t}\n64\t\n65\tfunction makeDispatchResult(overrides?: Partial<DispatchResult>): DispatchResult {\n66\t  return {\n67\t    sessionId: 'session-123',\n68\t    success: true,\n69\t    durationMs: 5000,\n70\t    output: '{\"verdict\":\"pass\",\"score\":{\"passed\":2,\"failed\":0,\"unknown\":0,\"total\":2},\"findings\":[]}',\n71\t    ...overrides,\n72\t  };\n73\t}\n74\t\n75\t// --- Tests ---\n76\t\n77\tbeforeEach(() => {\n78\t  vi.clearAllMocks();\n79\t  vi.useRealTimers();\n80\t});\n81\t\n82\tdescribe('runEvaluator', () => {\n83\t  describe('Docker unavailable', () => {\n84\t    it('returns all-UNKNOWN result without throwing when Docker is unavailable', async () => {\n85\t      vi.mocked(isDockerAvailable).mockReturnValue(false);\n86\t\n87\t      const result = await runEvaluator(makeOptions());\n88\t\n89\t      expect(result.dockerAvailable).toBe(false);\n90\t      expect(result.success).toBe(false);\n91\t      expect(result.timedOut).toBe(false);\n92\t      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n93\t\n94\t      const parsed = JSON.parse(result.output);\n95\t      expect(parsed.verdict).toBe('fail');\n96\t      expect(parsed.score.unknown).toBe(2);\n97\t      expect(parsed.score.total).toBe(2);\n98\t      expect(parsed.findings).toHaveLength(2);\n99\t      expect(parsed.findings[0].status).toBe('unknown');\n100\t      expect(parsed.findings[0].evidence.reasoning).toContain('Docker');\n101\t    });\n102\t\n103\t    it('does not create workspace when Docker is unavailable', async () => {\n104\t      vi.mocked(isDockerAvailable).mockReturnValue(false);\n105\t\n106\t      await runEvaluator(makeOptions());\n107\t\n108\t      expect(createIsolatedWorkspace).not.toHaveBeenCalled();\n109\t      expect(dispatchAgent).not.toHaveBeenCalled();\n110\t    });\n111\t  });\n112\t\n113\t  describe('workspace creation', () => {\n114\t    it('creates workspace with correct runId and storyFiles', async () => {\n115\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n116\t      const mockWorkspace = makeMockWorkspace();\n117\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n118\t      vi.mocked(dispatchAgent).mockResolvedValue(makeDispatchResult());\n119\t\n120\t      await runEvaluator(makeOptions({\n121\t        runId: 'my-run-123',\n122\t        storyFiles: ['/a.md', '/b.md'],\n123\t      }));\n124\t\n125\t      expect(createIsolatedWorkspace).toHaveBeenCalledWith({\n126\t        runId: 'my-run-123',\n127\t        storyFiles: ['/a.md', '/b.md'],\n128\t      });\n129\t    });\n130\t  });\n131\t\n132\t  describe('successful dispatch', () => {\n133\t    it('returns agent output and success on successful dispatch', async () => {\n134\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n135\t      const mockWorkspace = makeMockWorkspace();\n136\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n137\t      const dispatchResult = makeDispatchResult({ output: '{\"verdict\":\"pass\"}', success: true });\n138\t      vi.mocked(dispatchAgent).mockResolvedValue(dispatchResult);\n139\t\n140\t      const result = await runEvaluator(makeOptions());\n141\t\n142\t      expect(result.success).toBe(true);\n143\t      expect(result.output).toBe('{\"verdict\":\"pass\"}');\n144\t      expect(result.dockerAvailable).toBe(true);\n145\t      expect(result.timedOut).toBe(false);\n146\t      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n147\t    });\n148\t\n149\t    it('dispatches agent with workspace cwd', async () => {\n150\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n151\t      const mockWorkspace = makeMockWorkspace();\n152\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n153\t      vi.mocked(dispatchAgent).mockResolvedValue(makeDispatchResult());\n154\t\n155\t      await runEvaluator(makeOptions());\n156\t\n157\t      expect(dispatchAgent).toHaveBeenCalledWith(\n158\t        expect.objectContaining({ name: 'evaluator' }),\n159\t        expect.stringContaining('story-files'),\n160\t        expect.objectContaining({ cwd: '/tmp/codeharness-verify-test-run' }),\n161\t      );\n162\t    });\n163\t  });\n164\t\n165\t  describe('trace ID injection', () => {\n166\t    it('appends trace prompt when traceId is provided', async () => {\n167\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n168\t      const mockWorkspace = makeMockWorkspace();\n169\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n170\t      vi.mocked(dispatchAgent).mockResolvedValue(makeDispatchResult());\n171\t      vi.mocked(formatTracePrompt).mockReturnValue('[TRACE] trace_id=ch-run-0-verify');\n172\t\n173\t      await runEvaluator(makeOptions({ traceId: 'ch-run-0-verify' }));\n174\t\n175\t      expect(formatTracePrompt).toHaveBeenCalledWith('ch-run-0-verify');\n176\t      expect(dispatchAgent).toHaveBeenCalledWith(\n177\t        expect.anything(),\n178\t        expect.anything(),\n179\t        expect.objectContaining({\n180\t          appendSystemPrompt: '[TRACE] trace_id=ch-run-0-verify',\n181\t        }),\n182\t      );\n183\t    });\n184\t\n185\t    it('does not set appendSystemPrompt when no traceId', async () => {\n186\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n187\t      const mockWorkspace = makeMockWorkspace();\n188\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n189\t      vi.mocked(dispatchAgent).mockResolvedValue(makeDispatchResult());\n190\t\n191\t      await runEvaluator(makeOptions({ traceId: undefined }));\n192\t\n193\t      expect(formatTracePrompt).not.toHaveBeenCalled();\n194\t      const callArgs = vi.mocked(dispatchAgent).mock.calls[0][2];\n195\t      expect(callArgs?.appendSystemPrompt).toBeUndefined();\n196\t    });\n197\t  });\n198\t\n199\t  describe('timeout handling', () => {\n200\t    it('returns UNKNOWN result with timedOut=true on timeout', async () => {\n201\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n202\t      const mockWorkspace = makeMockWorkspace();\n203\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n204\t\n205\t      // dispatchAgent never resolves\n206\t      vi.mocked(dispatchAgent).mockReturnValue(new Promise(() => {}));\n207\t\n208\t      vi.useFakeTimers();\n209\t\n210\t      const resultPromise = runEvaluator(makeOptions({ timeoutMs: 1000 }));\n211\t\n212\t      // Advance time past the timeout\n213\t      await vi.advanceTimersByTimeAsync(1001);\n214\t\n215\t      const result = await resultPromise;\n216\t\n217\t      expect(result.timedOut).toBe(true);\n218\t      expect(result.success).toBe(false);\n219\t      expect(result.dockerAvailable).toBe(true);\n220\t\n221\t      const parsed = JSON.parse(result.output);\n222\t      expect(parsed.verdict).toBe('fail');\n223\t      expect(parsed.findings[0].status).toBe('unknown');\n224\t      expect(parsed.findings[0].evidence.reasoning).toContain('timed out');\n225\t    });\n226\t\n227\t    it('uses default timeout of 300000ms when timeoutMs not specified', async () => {\n228\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n229\t      const mockWorkspace = makeMockWorkspace();\n230\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n231\t      vi.mocked(dispatchAgent).mockReturnValue(new Promise(() => {}));\n232\t\n233\t      vi.useFakeTimers();\n234\t\n235\t      const resultPromise = runEvaluator(makeOptions());\n236\t\n237\t      // Should not have timed out at 299999ms\n238\t      await vi.advanceTimersByTimeAsync(299_999);\n239\t      // Verify still pending — we can't directly check, but advancing past 300000 should re