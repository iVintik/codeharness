eSummary handles Rust rule IDs in level distribution', () => {\n   490→    const gaps = [\n   491→      {\n   492→        file: 'src/main.rs', line: 10,\n   493→        type: 'rust-function-no-tracing',\n   494→        description: 'fn', severity: 'info' as const,\n   495→      },\n   496→      {\n   497→        file: 'src/lib.rs', line: 42,\n   498→        type: 'rust-catch-without-tracing',\n   499→        description: 'catch', severity: 'warning' as const,\n   500→      },\n   501→      {\n   502→        file: 'src/handler.rs', line: 88,\n   503→        type: 'rust-error-path-no-tracing',\n   504→        description: 'err', severity: 'warning' as const,\n   505→      },\n   506→    ];\n   507→\n   508→    const summary = computeSummary(gaps);\n   509→\n   510→    // Rust rule IDs are distinct from JS/TS rule IDs — they don't match\n   511→    // the hardcoded JS/TS rule names in matchesRule(), so they appear as\n   512→    // unrecognized gap types. The level distribution still works correctly.\n   513→    expect(summary.levelDistribution).toEqual({ info: 1, warning: 2 });\n   514→\n   515→    // Total gaps are still reported\n   516→    expect(summary.totalFunctions).toBe(0); // No JS/TS function gaps matched\n   517→    expect(summary.errorHandlersWithoutLogs).toBe(0); // No JS/TS error handler gaps matched\n   518→  });\n   519→});\n   520→"}]},"parent_tool_use_id":"toolu_01TaKDa3xnFU9du99GSAyprR","session_id":"6dce843f-9ba8-4a40-8e6f-55f9620fecc1","uuid":"e75fa739-69a5-4b03-a528-d6aa72ed65ec","timestamp":"2026-03-23T08:58:17.634Z"}
