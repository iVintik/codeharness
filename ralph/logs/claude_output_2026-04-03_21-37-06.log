edFiles] : [],\n52\t  testResults: contract?.testResults ? ... : null,\n53\t  errors: [],\n54\t};\n55\t```\n56\tTest \"entry contains all required fields with correct types\" (line 66) verifies all fields exist with correct types. 19/19 tests pass.\n57\t\n58\t---\n59\t\n60\t## AC 3: Null/missing fields set to null\n61\t\n62\t**Verdict:** PASS\n63\t\n64\t**Evidence:**\n65\t```typescript\n66\t// telemetry-writer.test.ts lines 125-135\n67\tit('unavailable fields are null when no output contract', async () => {\n68\t  const ctx = makeCtx({ projectDir: tmpDir, outputContract: null });\n69\t  await writeTelemetryEntry(ctx);\n70\t  const entry: TelemetryEntry = JSON.parse(readTelemetryFile(tmpDir).trim());\n71\t  expect(entry.attempts).toBeNull();\n72\t  expect(entry.acResults).toBeNull();\n73\t  expect(entry.testResults).toBeNull();\n74\t  expect(entry.filesChanged).toEqual([]);\n75\t  expect(entry.errors).toEqual([]);\n76\t});\n77\t```\n78\tTest passes. When `outputContract` is null, `attempts`, `acResults`, `testResults` are all `null`.\n79\t\n80\t---\n81\t\n82\t## AC 4: appendFileSync used (not truncate) and .codeharness dir created\n83\t\n84\t**Verdict:** PASS\n85\t\n86\t**Evidence:**\n87\t```typescript\n88\t// src/lib/telemetry-writer.ts lines 106-108\n89\tconst dir = join(ctx.projectDir, TELEMETRY_DIR);\n90\tmkdirSync(dir, { recursive: true });\n91\tappendFileSync(join(dir, TELEMETRY_FILE), JSON.stringify(entry) + '\\n');\n92\t```\n93\tUses `appendFileSync` (not `writeFileSync`). Directory created with `mkdirSync({ recursive: true })`.\n94\t\n95\tTests verify:\n96\t- \"creates .codeharness/ directory if missing\" (line 50) — PASS\n97\t- \"multiple sequential writes produce multiple lines\" (line 165) — writes 3 entries, gets 3 lines — PASS\n98\t\n99\t---\n100\t\n101\t## AC 5: version: 1 is the first field in serialized JSON\n102\t\n103\t**Verdict:** PASS\n104\t\n105\t**Evidence:**\n106\t```typescript\n107\t// telemetry-writer.test.ts lines 118-123\n108\tit('version 