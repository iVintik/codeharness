{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BmoLjgpLR7A91G1wvFtCGj","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { join, resolve, dirname } from 'node:path';\n3\timport { fileURLToPath } from 'node:url';\n4\timport os from 'node:os';\n5\timport { parse } from 'yaml';\n6\timport { validateWorkflowSchema } from './schema-validate.js';\n7\t\n8\tconst __filename = fileURLToPath(import.meta.url);\n9\tconst __dirname = dirname(__filename);\n10\t\n11\tconst TEMPLATES_DIR = resolve(__dirname, '../../templates/workflows');\n12\t\n13\t// --- Interfaces ---\n14\t\n15\texport interface ResolvedTask {\n16\t  agent: string;\n17\t  scope: 'per-story' | 'per-run';\n18\t  session: 'fresh' | 'continue';\n19\t  source_access: boolean;\n20\t  prompt_template?: string;\n21\t  input_contract?: Record<string, unknown>;\n22\t  output_contract?: Record<string, unknown>;\n23\t  max_budget_usd?: number;\n24\t}\n25\t\n26\texport interface LoopBlock {\n27\t  loop: string[];\n28\t}\n29\t\n30\texport type FlowStep = string | LoopBlock;\n31\t\n32\texport interface ResolvedWorkflow {\n33\t  tasks: Record<string, ResolvedTask>;\n34\t  flow: FlowStep[];\n35\t}\n36\t\n37\t// --- Error Class ---\n38\t\n39\texport class WorkflowParseError extends Error {\n40\t  public readonly errors: Array<{ path: string; message: string }>;\n41\t\n42\t  constructor(message: string, errors?: Array<{ path: string; message: string }>) {\n43\t    super(message);\n44\t    this.name = 'WorkflowParseError';\n45\t    this.errors = errors ?? [];\n46\t  }\n47\t}\n48\t\n49\t// --- Shared Validation & Resolution ---\n50\t\n51\t/**\n52\t * Validate parsed YAML against JSON schema, check referential integrity,\n53\t * apply defaults, and return a typed ResolvedWorkflow.\n54\t * Shared between parseWorkflow (direct file) and resolveWorkflow (patch chain).\n55\t */\n56\tfunction validateAndResolve(parsed: unknown): ResolvedWorkflow {\n57\t  // Validate against JSON schema\n58\t  const result = validateWorkflowSchema(parsed);\n59\t  if (!result.valid) {\n60\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n61\t    throw new WorkflowParseError(\n62\t      `Schema validation failed: ${details}`,\n63\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n64\t    );\n65\t  }\n66\t\n67\t  // At this point, parsed has passed schema validation — safe to cast\n68\t  const data = parsed as { tasks: Record<string, Record<string, unknown>>; flow: unknown[] };\n69\t\n70\t  // Referential integrity check\n71\t  const taskNames = new Set(Object.keys(data.tasks));\n72\t  const danglingRefs: Array<{ path: string; message: string }> = [];\n73\t\n74\t  for (let i = 0; i < data.flow.length; i++) {\n75\t    const step = data.flow[i];\n76\t    if (typeof step === 'string') {\n77\t      if (!taskNames.has(step)) {\n78\t        danglingRefs.push({\n79\t          path: `/flow/${i}`,\n80\t          message: `Task \"${step}\" referenced in flow but not defined in tasks`,"}]},"parent_tool_use_id":"toolu_011ACjM7rS7kgs6kygtQ7sim","session_id":"f83470b7-c271-483e-ae93-7fe9bce4b683","uuid":"af072b91-0ee7-446e-9493-ba87bc4aed4b","timestamp":"2026-04-03T07:38:26.165Z"}
