{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XpovKywPcJoQnC2VEEdTwo","type":"tool_result","content":"1\timport { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n2\timport { join } from 'node:path';\n3\timport { parse, stringify } from 'yaml';\n4\timport { warn } from './output.js';\n5\t\n6\t// --- Interfaces ---\n7\t\n8\texport interface TaskCheckpoint {\n9\t  task_name: string;\n10\t  story_key: string;\n11\t  completed_at: string;\n12\t  session_id?: string;\n13\t  /** When present, indicates this checkpoint records a failed dispatch (not a success). */\n14\t  error?: boolean;\n15\t}\n16\t\n17\texport interface EvaluatorScore {\n18\t  iteration: number;\n19\t  passed: number;\n20\t  failed: number;\n21\t  unknown: number;\n22\t  total: number;\n23\t  timestamp: string;\n24\t}\n25\t\n26\texport interface CircuitBreakerState {\n27\t  triggered: boolean;\n28\t  reason: string | null;\n29\t  score_history: number[];\n30\t}\n31\t\n32\texport interface WorkflowState {\n33\t  workflow_name: string;\n34\t  started: string;\n35\t  iteration: number;\n36\t  phase: string;\n37\t  tasks_completed: TaskCheckpoint[];\n38\t  evaluator_scores: EvaluatorScore[];\n39\t  circuit_breaker: CircuitBreakerState;\n40\t  trace_ids?: string[];\n41\t}\n42\t\n43\t// --- Constants ---\n44\t\n45\tconst STATE_DIR = '.codeharness';\n46\tconst STATE_FILE = 'workflow-state.yaml';\n47\t\n48\t// --- Functions ---\n49\t\n50\texport function getDefaultWorkflowState(): WorkflowState {"}]},"parent_tool_use_id":"toolu_014KEN5emub6zvnw37GStEgR","session_id":"3330d992-072a-4898-af8b-5f3f7e12cbac","uuid":"1bbb95da-38a7-410a-90e7-eac591d8438e","timestamp":"2026-04-03T17:41:52.853Z"}
