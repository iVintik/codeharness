{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Jdo7fea4yrQTtRkUEf82CA","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';\n2\timport { mkdtempSync, rmSync, writeFileSync, mkdirSync, readFileSync } from 'node:fs';\n3\timport { tmpdir } from 'node:os';\n4\timport { join } from 'node:path';\n5\timport {\n6\t  evaluateCoverage,\n7\t  updateCoverageState,\n8\t  checkPerFileCoverage,\n9\t  formatCoverageOutput,\n10\t  printCoverageOutput,\n11\t} from '../evaluator.js';\n12\timport type { CoverageResult, CoverageEvaluation } from '../types.js';\n13\timport { writeState, getDefaultState, readStateWithBody } from '../../state.js';\n14\t\n15\tlet testDir: string;\n16\t\n17\tbeforeEach(() => {\n18\t  testDir = mkdtempSync(join(tmpdir(), 'ch-coverage-evaluator-test-'));\n19\t});\n20\t\n21\tafterEach(() => {\n22\t  rmSync(testDir, { recursive: true, force: true });\n23\t});\n24\t\n25\t// ─── evaluateCoverage ────────────────────────────────────────────────────────\n26\t\n27\tdescribe('evaluateCoverage', () => {\n28\t  it('returns met=true when coverage meets target', () => {\n29\t    const state = getDefaultState('nodejs');\n30\t    state.coverage.target = 100;\n31\t    state.coverage.baseline = 95;\n32\t    writeState(state, testDir);\n33\t\n34\t    const result: CoverageResult = {\n35\t      success: true,\n36\t      testsPassed: true,\n37\t      passCount: 10,\n38\t      failCount: 0,\n39\t      coveragePercent: 100,\n40\t      rawOutput: '',\n41\t    };\n42\t\n43\t    const evaluation = evaluateCoverage(result, testDir);\n44\t    expect(evaluation.met).toBe(true);\n45\t    expect(evaluation.target).toBe(100);\n46\t    expect(evaluation.actual).toBe(100);\n47\t    expect(evaluation.delta).toBe(5);\n48\t    expect(evaluation.baseline).toBe(95);\n49\t  });\n50\t\n51\t  it('returns met=false when coverage below target', () => {\n52\t    const state = getDefaultState('nodejs');\n53\t    state.coverage.target = 100;\n54\t    state.coverage.baseline = 90;\n55\t    writeState(state, testDir);\n56\t\n57\t    const result: CoverageResult = {\n58\t      success: true,\n59\t      testsPassed: true,\n60\t      passCount: 10,\n61\t      failCount: 0,\n62\t      coveragePercent: 87,\n63\t      rawOutput: '',\n64\t    };\n65\t\n66\t    const evaluation = evaluateCoverage(result, testDir);\n67\t    expect(evaluation.met).toBe(false);\n68\t    expect(evaluation.actual).toBe(87);\n69\t    expect(evaluation.delta).toBe(-3);\n70\t  });\n71\t\n72\t  it('sets baseline to current on first run (null baseline)', () => {\n73\t    const state = getDefaultState('nodejs');\n74\t    state.coverage.baseline = null;\n75\t    writeState(state, testDir);\n76\t\n77\t    const result: CoverageResult = {\n78\t      success: true,\n79\t      testsPassed: true,\n80\t      passCount: 10,"}]},"parent_tool_use_id":"toolu_01Hody5ZigZ3cTLmGuBw8VE3","session_id":"b6bb3bfc-8778-4f16-a616-88028acc2431","uuid":"efd1b900-ae3f-40cb-87fc-aab9c6a68b2f","timestamp":"2026-04-03T18:31:47.567Z"}
