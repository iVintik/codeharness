n {\n    38→        on: vi.fn((event: string, handler: (...args: unknown[]) => void) => {\n    39→          handlers[event] = handler;\n    40→        }),\n    41→        pid: 12345,\n    42→        stdin: null,\n    43→        stdout: stdoutEmitter,\n    44→        stderr: stderrEmitter,\n    45→      };\n    46→    }),\n    47→    getChildOnHandlers: () => handlers,\n    48→    existsSyncMock: vi.fn(realFn),\n    49→    readSprintStatusMock: vi.fn(() => ({}) as Record<string, string>),\n    50→    realExistsSync: realFn as (path: string) => boolean,\n    51→    getStdoutEmitter: () => stdoutEmitter,\n    52→    getStderrEmitter: () => stderrEmitter,\n    53→    startRendererMock: vi.fn(() => ({\n    54→      update: rendererUpdateMock,\n    55→      updateSprintState: rendererUpdateSprintStateMock,\n    56→      updateStories: rendererUpdateStoriesMock,\n    57→      addMessage: rendererAddMessageMock,\n    58→      cleanup: rendererCleanupMock,\n    59→    })),\n    60→    rendererUpdateMock,\n    61→    rendererUpdateSprintStateMock,\n    62→    rendererCleanupMock,\n    63→    rendererUpdateStoriesMock,\n    64→    rendererAddMessageMock,\n    65→    parseStreamLineMock: vi.fn(() => null),\n    66→    getSprintStateMock: vi.fn(() => ({ success: false, error: 'no state' })),\n    67→  };\n    68→});\n    69→\n    70→vi.mock('node:child_process', () => ({ spawn: spawnMock }));\n    71→\n    72→vi.mock('node:fs', async (importOriginal) => {\n    73→  const actual = await importOriginal<typeof import('node:fs')>();\n    74→  return { ...actual, existsSync: existsSyncMock };\n    75→});\n    76→\n    77→vi.mock('../../lib/beads-sync.js', () => ({\n    78→  readSprintStatus: (...args: unknown[]) => readSprintStatusMock(...args),\n    79→}));\n    80→\n    81→vi.mock('../../templates/ralph-prompt.js', () => ({\n    82→  generateRalphPrompt: vi.fn(() => 'mock prompt content'),\n    83→}));\n    84→\n    85→vi.mock('../../lib/stream-parser.js', () => ({\n    86→  parseS