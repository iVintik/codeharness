{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KASywZ9znKKr8YJXDF744K","type":"tool_result","content":"     1→/**\n     2→ * Status endpoints — URL builders for observability dashboards.\n     3→ * Pure functions; no filesystem or network access.\n     4→ */\n     5→\n     6→import type { HarnessState } from '../../lib/state.js';\n     7→\n     8→export interface EndpointUrls {\n     9→  logs: string;\n    10→  metrics: string;\n    11→  traces: string;\n    12→  otel_http: string;\n    13→}\n    14→\n    15→export interface ScopedEndpointUrls {\n    16→  logs: string;\n    17→  metrics: string;\n    18→  traces: string;\n    19→}\n    20→\n    21→export const DEFAULT_ENDPOINTS: EndpointUrls = {\n    22→  logs: 'http://localhost:9428',\n    23→  metrics: 'http://localhost:8428',\n    24→  traces: 'http://localhost:16686',\n    25→  otel_http: 'http://localhost:4318',\n    26→};\n    27→\n    28→export const ELK_ENDPOINTS: EndpointUrls = {\n    29→  logs: 'http://localhost:9200',\n    30→  metrics: 'http://localhost:9200',\n    31→  traces: 'http://localhost:9200',\n    32→  otel_http: 'http://localhost:4318',\n    33→};\n    34→\n    35→/** Return the correct default endpoints for the given backend type. */\n    36→export function getDefaultEndpointsForBackend(backend?: string): EndpointUrls {\n    37→  return backend === 'elk' ? ELK_ENDPOINTS : DEFAULT_ENDPOINTS;\n    38→}\n    39→\n    40→/**\n    41→ * Build service-scoped endpoint URLs for observability dashboards.\n    42→ * Produces URLs filtered by service_name for logs, metrics, and traces.\n    43→ */\n    44→export function buildScopedEndpoints(endpoints: EndpointUrls, serviceName: string): ScopedEndpointUrls {\n    45→  const encoded = encodeURIComponent(serviceName);\n    46→  return {\n    47→    logs: `${endpoints.logs}/select/logsql/query?query=${encodeURIComponent(`service_name:${serviceName}`)}`,\n    48→    metrics: `${endpoints.metrics}/api/v1/query?query=${encodeURIComponent(`{service_name=\"${serviceName}\"}`)}`,\n    49→    traces: `${endpoints.traces}/api/traces?service=${encoded}&limit=20`,\n    50→  };\n    51→}\n    52→\n    53→/**\n    54→ * Resolve the correct endpoint URLs based on OTLP mode.\n    55→ * - remote-direct: all endpoints point to the remote OTLP endpoint\n    56→ * - remote-routed: uses configured remote backend URLs, falls back to defaults\n    57→ * - local-shared (default): uses DEFAULT_ENDPOINTS\n    58→ */\n    59→export function resolveEndpoints(state: HarnessState): EndpointUrls {\n    60→  const mode = state.otlp?.mode ?? 'local-shared';\n    61→  const backend = state.otlp?.backend ?? 'victoria';\n    62→  if (mode === 'remote-direct') {\n    63→    const endpoint = state.otlp?.endpoint ?? 'http://localhost:4318';\n    64→    return {\n    65→      logs: endpoint,\n    66→      metrics: endpoint,\n    67→      traces: endpoint,\n    68→      otel_http: endpoint,\n    69→    };\n    70→  }\n    71→  const defaults = getDefaultEndpointsForBackend(backend);\n    72→  if (mode === 'remote-routed') {\n    73→    const re = state.docker?.remote_endpoints;\n    74→    return {\n    75→      logs: re?.logs_url ?? defaults.logs,\n    76→      metrics: re?.metrics_url ?? defaults.metrics,\n    77→      traces: re?.traces_url ?? defaults.traces,\n    78→      otel_http: defaults.otel_http,\n    79→    };\n    80→  }\n    81→  return defaults;\n    82→}\n    83→"}]},"parent_tool_use_id":"toolu_01MwzbgNwEhenGxNXV9UQBeX","session_id":"507a8d0b-20bb-4c55-954f-5f817ca0f972","uuid":"21aac43f-e183-4960-97c6-52c0b118b836","timestamp":"2026-03-27T07:04:03.851Z"}
