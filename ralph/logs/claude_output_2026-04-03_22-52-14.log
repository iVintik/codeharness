{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PQKnFiLXQwDGN7sASZV3rA","type":"tool_result","content":"1\t/**\n2\t * Tests for storyFlow execution in the workflow engine.\n3\t *\n4\t * Story 16-6: Story Flow Execution\n5\t *\n6\t * Verifies that the engine reads `storyFlow` instead of `flow` to drive\n7\t * per-story execution, preserves loop semantics, handles null tasks after\n8\t * loops, derives workflow_name from storyFlow, and maintains backward\n9\t * compatibility with legacy `flow:` workflows.\n10\t */\n11\timport { describe, it, expect, vi, beforeEach } from 'vitest';\n12\t\n13\t// --- Hoisted Mocks ---\n14\t\n15\tconst {\n16\t  mockReadWorkflowState,\n17\t  mockWriteWorkflowState,\n18\t  mockWarn,\n19\t  mockReadFileSync,\n20\t  mockExistsSync,\n21\t  mockParse,\n22\t  mockGetDriver,\n23\t  mockResolveModel,\n24\t  mockDriverDispatch,\n25\t  mockBuildPromptWithContractContext,\n26\t  mockWriteOutputContract,\n27\t  mockGenerateTraceId,\n28\t  mockFormatTracePrompt,\n29\t  mockRecordTraceId,\n30\t  mockResolveSessionId,\n31\t  mockRecordSessionId,\n32\t  mockCreateIsolatedWorkspace,\n33\t  mockGetNullTask,\n34\t  mockListNullTasks,\n35\t  mockReadStateWithBody,\n36\t  mockWriteState,\n37\t} = vi.hoisted(() => ({\n38\t  mockReadWorkflowState: vi.fn(),\n39\t  mockWriteWorkflowState: vi.fn(),\n40\t  mockWarn: vi.fn(),\n41\t  mockReadFileSync: vi.fn(),\n42\t  mockExistsSync: vi.fn(),\n43\t  mockParse: vi.fn(),\n44\t  mockGetDriver: vi.fn(),\n45\t  mockResolveModel: vi.fn(),\n46\t  mockDriverDispatch: vi.fn(),\n47\t  mockBuildPromptWithContractContext: vi.fn(),\n48\t  mockWriteOutputContract: vi.fn(),\n49\t  mockGenerateTraceId: vi.fn(),\n50\t  mockFormatTracePrompt: vi.fn(),\n51\t  mockRecordTraceId: vi.fn(),\n52\t  mockResolveSessionId: vi.fn(),\n53\t  mockRecordSessionId: vi.fn(),\n54\t  mockCreateIsolatedWorkspace: vi.fn(),\n55\t  mockGetNullTask: vi.fn(),\n56\t  mockListNullTasks: vi.fn(),\n57\t  mockReadStateWithBody: vi.fn(),\n58\t  mockWriteState: vi.fn(),\n59\t}));\n60\t\n61\tvi.mock('../agent-dispatch.js', () => ({\n62\t  dispatchAgent: vi.fn(),\n63\t  DispatchError: class DispatchError extends Error {\n64\t    public readonly code: string;\n65\t    public readonly agentName: string;\n66\t    public readonly cause: unknown;\n67\t    constructor(message: string, code: string, agentName: string, cause: unknown) {\n68\t      super(message);\n69\t      this.name = 'DispatchError';\n70\t      this.code = code;\n71\t      this.agentName = agentName;\n72\t      this.cause = cause;\n73\t    }\n74\t  },\n75\t}));\n76\t\n77\tvi.mock('../agents/drivers/factory.js', () => ({\n78\t  getDriver: mockGetDriver,\n79\t  suggestCheaperDriver: vi.fn().mockReturnValue(null),\n80\t  listDrivers: vi.fn().mockReturnValue([]),\n81\t}));\n82\t\n83\tvi.mock('../agents/capability-check.js', () => ({\n84\t  checkCapabilityConflicts: vi.fn().mockReturnValue([]),\n85\t}));\n86\t\n87\tvi.mock('../agents/model-resolver.js', () => ({\n88\t  resolveModel: mockResolveModel,\n89\t}));\n90\t\n91\tvi.mock('../workflow-state.js', () => ({\n92\t  readWorkflowState: mockReadWorkflowState,\n93\t  writeWorkflowState: mockWriteWorkflowState,\n94\t  getDefaultWorkflowState: () => ({\n95\t    workflow_name: '',\n96\t    started: '',\n97\t    iteration: 0,\n98\t    phase: 'idle',\n99\t    tasks_completed: [],\n100\t    evaluator_scores: [],\n101\t    circuit_breaker: { triggered: false, reason: null, score_history: [] },\n102\t    trace_ids: [],\n103\t  }),\n104\t}));\n105\t\n106\tvi.mock('../source-isolation.js', () => ({\n107\t  createIsolatedWorkspace: mockCreateIsolatedWorkspace,\n108\t}));\n109\t\n110\tvi.mock('../trace-id.js', () => ({\n111\t  generateTraceId: mockGenerateTraceId,\n112\t  formatTracePrompt: mockFormatTracePrompt,\n113\t  recordTraceId: mockRecordTraceId,\n114\t}));\n115\t\n116\tvi.mock('../session-manager.js', () => ({\n117\t  resolveSessionId: mockResolveSessionId,\n118\t  recordSessionId: mockRecordSessionId,\n119\t}));\n120\t\n121\tvi.mock('../output.js', () => ({\n122\t  warn: mockWarn,\n123\t}));\n124\t\n125\tvi.mock('../agents/output-contract.js', () => ({\n126\t  buildPromptWithContractContext: mockBuildPromptWithContractContext,\n127\t  writeOutputContract: mockWriteOutputContract,\n128\t}));\n129\t\n130\tvi.mock('node:fs', () => ({\n131\t  readFileSync: mockReadFileSync,\n132\t  existsSync: mockExistsSync,\n133\t}));\n134\t\n135\tvi.mock('yaml', () => ({\n136\t  parse: mockParse,\n137\t}));\n138\t\n139\tvi.mock('../null-task-registry.js', () => ({\n140\t  getNullTask: mockGetNullTask,\n141\t  listNullTasks: mockListNullTasks,\n142\t}));\n143\t\n144\tvi.mock('../../commands/state.js', () => ({\n145\t  readStateWithBody: mockReadStateWithBody,\n146\t  writeState: mockWriteState,\n147\t}));\n148\t\n149\tvi.mock('../circuit-breaker.js', () => ({\n150\t  evaluateProgress: vi.fn().mockReturnValue({ halt: false }),\n151\t}));\n152\t\n153\timport { executeWorkflow } from '../workflow-engine.js';\n154\timport type { EngineConfig } from '../workflow-engine.js';\n155\timport type { WorkflowState } from '../workflow-state.js';\n156\timport type { ResolvedWorkflow, ResolvedTask, ExecutionConfig } from '../workflow-parser.js';\n157\timport type { SubagentDefinition } from '../agent-resolver.js';\n158\t\n159\t// --- Helpers ---\n160\t\n161\tfunction makeDefaultState(overrides?: Partial<WorkflowState>): WorkflowState {\n162\t  return {\n163\t    workflow_name: '',\n164\t    started: '2026-04-03T00:00:00.000Z',\n165\t    iteration: 0,\n166\t    phase: 'idle',\n167\t    tasks_completed: [],\n168\t    evaluator_scores: [],\n169\t    circuit_breaker: { triggered: false, reason: null, score_history: [] },\n170\t    trace_ids: [],\n171\t    ...overrides,\n172\t  };\n173\t}\n174\t\n175\tfunction makeDefinition(overrides?: Partial<SubagentDefinition>): SubagentDefinition {\n176\t  return {\n177\t    name: 'test-agent',\n178\t    model: 'claude-sonnet-4-20250514',\n179\t    instructions: 'You are a test agent.',\n180\t    disallowedTools: [],\n181\t    bare: true,\n182\t    ...overrides,\n183\t  };\n184\t}\n185\t\n186\tfunction makeTask(overrides?: Partial<ResolvedTask>): ResolvedTask {\n187\t  return {\n188\t    agent: 'dev',\n189\t    scope: 'per-story',\n190\t    session: 'fresh',\n191\t    source_access: true,\n192\t    ...overrides,\n193\t  };\n194\t}\n195\t\n196\tconst defaultExecution: ExecutionConfig = {\n197\t  max_parallel: 1,\n198\t  isolation: 'none',\n199\t  merge_strategy: 'merge-commit',\n200\t  epic_strategy: 'sequential',\n201\t  story_strategy: 'sequential',\n202\t};\n203\t\n204\tfunction makeWorkflow(partial: {\n205\t  tasks: Record<string, ResolvedTask>;\n206\t  flow: (string | { loop: string[] })[];\n207\t  storyFlow?: (string | { loop: string[] })[];\n208\t}): ResolvedWorkflow {\n209\t  return {\n210\t    tasks: partial.tasks,\n211\t    flow: partial.flow,\n212\t    execution: defaultExecution,\n213\t    storyFlow: partial.storyFlow ?? partial.flow,\n214\t    epicFlow: [],\n215\t  };\n216\t}\n217\t\n218\tfunction makeConfig(overrides?: Partial<EngineConfig>): EngineConfig {\n219\t  return {\n220\t    workflow: makeWorkflow({\n221\t      tasks: {\n222\t        implement: makeTask(),\n223\t        verify: makeTask({ scope: 'per-run', source_access: false }),\n224\t      },\n225\t      flow: ['implement', 'verify'],\n226\t    }),\n227\t    agents: {\n228\t      dev: makeDefinition(),\n229\t    },\n230\t    sprintStatusPath: '/project/sprint-status.yaml',\n231\t    runId: 'run-001',\n232\t    projectDir: '/project',\n233\t    ...overrides,\n234\t  };\n235\t}\n236\t\n237\tfunction setupDefaultMocks() {\n238\t  mockReadWorkflowState.mockReturnValue(makeDefaultState());\n239\t  mockWriteWorkflowState.mockImplementation(() => {});\n240\t  mockBuildPromptWithContractContext.mockImplementation((basePrompt: string) => basePrompt);\n241\t  mockWriteOutputContract.mockImplementation(() => {});\n242\t  mockGenerateTraceId.mockReturnValue('ch-run-001-0-implement');\n243\t  mockFormatTracePrompt.mockReturnValue('[TRACE] trace_id=ch-run-001-0-implement');\n244\t  mockRecordTraceId.mockImplementation((_traceId: string, state: WorkflowState) => ({\n245\t    ...state,\n246\t    trace_ids: [...(state.trace_ids ?? []), _traceId],\n247\t  }));\n248\t  mockResolveSessionId.mockReturnValue(undefined);\n249\t  mockRecordSessionId.mockImplementation(\n250\t    (key: { taskName: string; storyKey: string }, sessionId: string, state: WorkflowState) => ({\n251\t      ...state,\n252\t      tasks_completed: [\n253\t        ...state.tasks_completed,\n254\t        {\n255\t          task_name: key.taskName,\n256\t          story_key: key.storyKey,\n257\t          completed_at: '2026-04-03T00:00:00.000Z',\n258\t          session_id: sessionId,\n259\t        },\n260\t      ],\n261\t    }),\n262\t  );\n263\t  mockDriverDispatch.mockImplementation(() => {\n264\t    return (async function* () {\n265\t      yield { type: 'text' as const, text: 'Done' };\n266\t      yield { type: 'result' as const, cost: 0.05, sessionId: 'sess-abc-123' };\n267\t    })();\n268\t  });\n269\t  mockGetDriver.mockReturnValue({\n270\t    name: 'claude-code',\n271\t    defaultModel: 'claude-sonnet-4-20250514',\n272\t    capabilities: { supportsPlugins: true, supportsStreaming: true, costReporting: true, costTier: 3 },\n273\t    healthCheck: vi.fn().mockResolvedValue({ available: true, authenticated: true, version: '1.0.0' }),\n274\t    dispatch: mockDriverDispatch,\n275\t    getLastCost: vi.fn().mockReturnValue(null),\n276\t  });\n277\t  mockResolveModel.mockReturnValue('claude-sonnet-4-20250514');\n278\t  mockExistsSync.mockImplementation((path: string) => {\n279\t    if (path === '/project/sprint-status.yaml') return true;\n280\t    return false;\n281\t  });\n282\t  mockReadFileSync.mockReturnValue('dummy yaml');\n283\t  mockParse.mockReturnValue({\n284\t    development_status: {\n285\t      'story-1': 'ready-for-dev',\n286\t    },\n287\t  });\n288\t  mockGetNullTask.mockImplementation((name: string) => {\n289\t    if (name === 'telemetry') {\n290\t      return async () => ({ success: true, output: 'telemetry collected' });\n291\t    }\n292\t    return undefined;\n293\t  });\n294\t  mockListNullTasks.mockReturnValue(['telemetry']);\n295\t  mockReadStateWithBody.mockReturnValue({\n296\t    state: {\n297\t      harness_version: '0.1.0',\n298\t      initialized: true,\n299\t      stack: 'node',\n300\t      stacks: ['node'],\n301\t      enforcement: { frontend: true, database: true, api: true },\n302\t      coverage: { target: 80, baseline: null, current: null, tool: 'c8' },\n303\t      session_flags: { logs_queried: false, tests_passed: false, coverage_met: false, verification_run: false },\n304\t      verification_log: [],\n305\t    },\n306\t    body: '\\n# Codeharness State\\n',\n307\t  });\n308\t}\n309\t\n310\t// --- Tests ---\n311\t\n312\tdescribe('Story Flow Execution (Story 16-6)', () => {\n313\t  beforeEach(() => {\n314\t    vi.clearAllMocks();\n315\t    setupDefaultMocks();\n316\t  });\n317\t\n318\t  describe('AC #1: storyFlow executes steps in order', () => {\n319\t    it('executes storyFlow steps sequentially (implement, verify, telemetry)', async () => {\n320\t      const executionOrder: string[] = [];\n321\t\n322\t      mockGetNullTask.mockImplementation((name: string) => {\n323\t        if (name === 'telemetry') {\n324\t          return async () => {\n325\t            executionOrder.push('telemetry');\n326\t            return { success: true, output: 'ok' };\n327\t          };\n328\t        }\n329\t        return undefined;\n330\t      });\n331\t\n332\t      mockDriverDispatch.mockImplementation(() => {\n333\t        return (async function* () {\n334\t          executionOrder.push('agent-task');\n335\t          yield { type: 'text' as const, text: 'Done' };\n336\t          yield { type: 'result' as const, cost: 0.05, sessionId: 'sess-1' };\n337\t        })();\n338\t      });\n339\t\n340\t      const config = makeConfig({\n341\t        workflow: makeWorkflow({\n342\t          tasks: {\n343\t            implement: makeTask(),\n344\t            verify: makeTask({ scope: 'per-run' }),\n345\t            telemetry: makeTask({ agent: null, scope: 'per-run' }),\n346\t          },\n347\t          flow: ['implement', 'verify', 'telemetry'],\n348\t        }),\n349\t      });\n350\t\n351\t      const result = await executeWorkflow(config);\n352\t\n353\t      expect(result.success).toBe(true);\n354\t      expect(result.tasksCompleted).toBe(3);\n355\t      // Agent tasks run in order, followed by null task\n356\t      expect(executionOrder).toEqual(['agent-task', 'agent-task', 'telemetry']);\n357\t    });\n358\t  });\n359\t\n360\t  describe('AC #2: telemetry null task executes after loop completes', () => {\n361\t    it('runs telemetry after loop exits early on pass verdict', async () => {\n362\t      const { evaluateProgress } = await import('../circuit-breaker.js');\n363\t      const mockEvaluateProgress = vi.mocked(evaluateProgress);\n364\t      mockEvaluateProgress.mockReturnValue({ halt: false });\n365\t\n366\t      const executionOrder: string[] = [];\n367\t\n368\t      mockGetNullTask.mockImplementation((name: string) => {\n369\t        if (name === 'telemetry') {\n370\t          return async () => {\n371\t            executionOrder.push('telemetry');\n372\t            return { success: true, output: 'ok' };\n373\t          };\n374\t        }\n375\t        return undefined;\n376\t      });\n377\t\n378\t      const passVerdict = JSON.stringify({\n379\t        verdict: 'pass',\n380\t        findings: [],\n381\t        score: { passed: 1, failed: 0, unknown: 0, total: 1 },\n382\t      });\n383\t\n384\t      // Loop: retry (per-story) then verify (per-run) — verify returns pass verdict as text\n385\t      let callCount = 0;\n386\t      mockDriverDispatch.mockImplementation(() => {\n387\t        callCount++;\n388\t        return (async function* () {\n389\t          executionOrder.push(`driver-call-${callCount}`);\n390\t          // Emit verdict JSON as text (the engine reads output from text events)\n391\t          yield { type: 'text' as const, text: passVerdict };\n392\t          yield { type: 'result' as const, cost: 0.01, sessionId: `sess-${callCount}` };\n393\t        })();\n394\t      });\n395\t\n396\t      const config = makeConfig({\n397\t        workflow: makeWorkflow({\n398\t          tasks: {\n399\t            implement: makeTask({ scope: 'per-run' }),\n400\t            retry: makeTask(),\n401\t            verify: makeTask({ scope: 'per-run' }),\n402\t            telemetry: makeTask({ agent: null, scope: 'per-run' }),\n403\t          },\n404\t          flow: [\n405\t            'implement',\n406\t            { loop: ['retry', 'verify'] },\n407\t            'telemetry',\n408\t          ],\n409\t        }),\n410\t      });\n411\t\n412\t      const result = await executeWorkflow(config);\n413\t\n414\t      expect(result.success).toBe(true);\n415\t      // Telemetry MUST run after the loop completes with pass\n416\t      expect(executionOrder).toContain('telemetry');\n417\t      // Telemetry is the last item executed\n418\t      expect(executionOrder[executionOrder.length - 1]).toBe('telemetry');\n419\t    });\n420\t\n421\t    it('does NOT run telemetry when loop triggers circuit-breaker halt', async () => {\n422\t      const { evaluateProgress } = await import('../circuit-breaker.js');\n423\t      const mockEvaluateProgress = vi.mocked(evaluateProgress);\n424\t\n425\t      // Circuit breaker triggers halt on first evaluation\n426\t      mockEvaluateProgress.mockReturnValue({ halt: true, reason: 'test-cb-halt' });\n427\t\n428\t      const telemetryHandler = vi.fn().mockResolvedValue({ success: true, output: 'ok' });\n429\t      mockGetNullTask.mockImplementation((name: string) => {\n430\t        if (name === 'telemetry') return telemetryHandler;\n431\t        return undefined;\n432\t      });\n433\t\n434\t      const failVerdict = JSON.stringify({\n435\t        verdict: 'fail',\n436\t        findings: [{ ac: 1, description: 'test', status: 'fail', evidence: { commands_run: ['echo'], output_observed: 'fail', reasoning: 'test' } }],\n437\t        score: { passed: 0, failed: 1, unknown: 0, total: 1 },\n438\t      });\n439\t\n440\t      mockDriverDispatch.mockImplementation(() => {\n441\t        return (async function* () {\n442\t          // Emit verdict JSON as text — engine parses this via parseVerdict()\n443\t          yield { type: 'text' as const, text: failVerdict };\n444\t          yield { type: 'result' as const, cost: 0.01, sessionId: 'sess-1' };\n445\t        })();\n446\t      });\n447\t\n448\t      const config = makeConfig({\n449\t        workflow: makeWorkflow({\n450\t          tasks: {\n451\t            implement: makeTask(),\n452\t            verify: makeTask({ scope: 'per-run' }),\n453\t            telemetry: makeTask({ agent: null, scope: 'per-run' }),\n454\t          },\n455\t          flow: [\n456\t            'implement',\n457\t            { loop: ['implement', 'verify'] },\n458\t            'telemetry',\n459\t          ],\n460\t        }),\n461\t      });\n462\t\n463\t      const result = await executeWorkflow(config);\n464\t\n465\t      // Telemetry should NOT run because circuit-breaker halted the engine\n466\t      expect(telemetryHandler).not.toHaveBeenCalled();\n467\t      // Engine reports halted state\n468\t      expect(result.success).toBe(false);\n469\t    });\n470\t  });\n471\t\n472\t  describe('AC #3: loop semantics preserved under storyFlow', () => {\n473\t    it('executes loop block within storyFlow with max iterations respected', async () => {\n474\t      const { evaluateProgress } = await import('../circuit-breaker.js');\n475\t      const mockEvaluateProgress = vi.mocked(evaluateProgress);\n476\t      mockEvaluateProgress.mockReturnValue({ halt: false });\n477\t\n478\t      const failVerdict = JSON.stringify({\n479\t        verdict: 'fail',\n480\t        findings: [{ ac: 1, description: 'test', status: 'fail', evidence: { commands_run: ['echo'], output_observed: 'fail', reasoning: 'test' } }],\n481\t        score: { passed: 0, failed: 1, unknown: 0, total: 1 },\n482\t      });\n483\t\n484\t      let dispatchCount = 0;\n485\t      mockDriverDispatch.mockImplementation(() => {\n486\t        dispatchCount++;\n487\t        return (async function* () {\n488\t          // Emit verdict JSON as text for the engine's parseVerdict()\n489\t          yield { type: 'text' as const, text: failVerdict };\n490\t          yield { type: 'result' as const, cost: 0.01, sessionId: `sess-${dispatchCount}` };\n491\t        })();\n492\t      });\n493\t\n494\t      // maxIterations defaults to 5 in the engine (DEFAULT_MAX_ITERATIONS = 5)\n495\t      const config = makeConfig({\n496\t        workflow: makeWorkflow({\n497\t          tasks: {\n498\t            retry: makeTask({ scope: 'per-run' }),\n499\t            verify: makeTask({ scope: 'per-run' }),\n500\t          },\n501\t          flow: [\n502\t            { loop: ['retry', 'verify'] },\n503\t          ],\n504\t        }),\n505\t      });\n506\t\n507\t      const result = await executeWorkflow(config);\n508\t\n509\t      // Loop ran retry+verify per iteration, 5 iterations = 10 dispatches\n510\t      expect(dispatchCount).toBe(10);\n511\t      // Engine should report failure (max-iterations reached, halted = true)\n512\t      expect(result.success).toBe(false);\n513\t    });\n514\t\n515\t    it('loop exits early when verdict is pass', async () => {\n516\t      const { evaluateProgress } = await import('../circuit-breaker.js');\n517\t      const mockEvaluateProgress = vi.mocked(evaluateProgress);\n518\t      mockEvaluateProgress.mockReturnValue({ halt: false });\n519\t\n520\t      const passVerdict = JSON.stringify({\n521\t        verdict: 'pass',\n522\t        findings: [],\n523\t        score: { passed: 1, failed: 0, unknown: 0, total: 1 },\n524\t      });\n525\t\n526\t      let dis