{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NXLfoFit433T3GoNWxNPJN","type":"tool_result","content":"2245\t    });\n2246\t\n2247\t    const result = await executeWorkflow(config);\n2248\t\n2249\t    // 2 per-story + 1 per-run = 3 dispatches\n2250\t    expect(mockDriverDispatch).toHaveBeenCalledTimes(3);\n2251\t    expect(result.tasksCompleted).toBe(3);\n2252\t  });\n2253\t\n2254\t  it('tasks_completed growth is proportional to actual task count only (AC #8)', async () => {\n2255\t    mockReadWorkflowState.mockReturnValue(makeDefaultState());\n2256\t\n2257\t    mockParse.mockReturnValue({\n2258\t      development_status: {\n2259\t        '5-1-a': 'ready-for-dev',\n2260\t        '5-2-b': 'ready-for-dev',\n2261\t      },\n2262\t    });\n2263\t\n2264\t    const config = makeConfig({\n2265\t      workflow: {\n2266\t        tasks: { implement: makeTask() },\n2267\t        flow: ['implement'],\n2268\t      },\n2269\t    });\n2270\t\n2271\t    await executeWorkflow(config);\n2272\t\n2273\t    // Check that state writes contain tasks_completed arrays that only grow by 1 per dispatch\n2274\t    const writes = mockWriteWorkflowState.mock.calls.map((c: unknown[]) => c[0] as WorkflowState);\n2275\t    let prevLength = 0;\n2276\t    for (const ws of writes) {\n2277\t      const len = ws.tasks_completed.length;\n2278\t      // Each write should grow by at most 1 checkpoint\n2279\t      expect(len - prevLength).toBeLessThanOrEqual(1);\n2280\t      prevLength = len;\n2281\t    }\n2282\t  });\n2283\t\n2284\t  it('loop block resumes from current iteration, skipping completed tasks (AC #4)', async () => {\n2285\t    // Simulate crash mid-iteration 2:\n2286\t    // - Iteration 1: retry(3-1-foo) and verify(__run__) both done (2 checkpoints each)\n2287\t    // Wait, iteration 1 means 1 checkpoint each.\n2288\t    // - Iteration 1 fully done: retry(3-1-foo) x1, verify(__run__) x1\n2289\t    // - Iteration 2 partially done: retry(3-1-foo) x2 done, verify(__run__) not done for iter 2\n2290\t    mockReadWorkflowState.mockReturnValue(\n2291\t      makeDefaultState({\n2292\t        phase: 'executing',\n2293\t        started: '2026-04-03T00:00:00Z',\n2294\t        iteration: 2, // currently on iteration 2\n2295\t        tasks_completed: [\n2296\t          // Iteration 1 checkpoints\n2297\t          { task_name: 'retry', story_key: '3-1-foo', completed_at: '2026-04-03T00:00:00Z' },\n2298\t          { task_name: 'verify', story_key: '__run__', completed_at: '2026-04-03T00:01:00Z' },\n2299\t          // Iteration 2 partial: retry done, verify NOT done\n2300\t          { task_name: 'retry', story_key: '3-1-foo', completed_at: '2026-04-03T00:02:00Z' },\n2301\t        ],\n2302\t      }),\n2303\t    );\n2304\t\n2305\t    mockParse.mockReturnValue({\n2306\t      development_status: { '3-1-foo': 'ready-for-dev' },\n2307\t    });\n2308\t\n2309\t    // verify returns pass so loop terminates\n2310\t    mockDriverDispatch.mockImplementation((opts: { prompt: string }) => {\n2311\t      if (opts.prompt.includes('Execute task')) {\n2312\t        return makeDriverStream(JSON.stringify({\n2313\t          verdict: 'pass',\n2314\t          score: { passed: 2, failed: 0, unknown: 0, total: 2 },\n2315\t          findings: [],\n2316\t        }), 'sess-v');\n2317\t      }\n2318\t      return makeDriverStream('ok', 'sess-r');\n2319\t    });\n2320\t\n2321\t    const config = makeConfig({\n2322\t      workflow: {\n2323\t        tasks: {\n2324\t          retry: makeTask({ scope: 'per-story' }),\n2325\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n2326\t        },\n2327\t        flow: [{ loop: ['retry', 'verify'] }],\n2328\t      },\n2329\t    });\n2330\t\n2331\t    const result = await executeWorkflow(config);\n2332\t\n2333\t    // Only verify should be dispatched (retry already done for iteration 2)\n2334\t    expect(mockDriverDispatch).toHaveBeenCalledTimes(1);\n2335\t    expect(result.tasksCompleted).toBe(1);\n2336\t    // retry should have been skipped\n2337\t    expect(mockWarn).toHaveBeenCalledWith(\n2338\t      'workflow-engine: skipping completed task retry for 3-1-foo',\n2339\t    );\n2340\t  });\n2341\t\n2342\t  it('loop iteration counter is preserved — not reset to 0 (AC #4)', async () => {\n2343\t    // Resume at iteration 2 (fully completed), should advance to 3\n2344\t    mockReadWorkflowState.mockReturnValue(\n2345\t      makeDefaultState({\n2346\t        phase: 'executing',\n2347\t        started: '2026-04-03T00:00:00Z',\n2348\t        iteration: 2,\n2349\t        tasks_completed: [\n2350\t          // Both iterations fully done\n2351\t          { task_name: 'retry', story_key: '3-1-foo', completed_at: '2026-04-03T00:00:00Z' },\n2352\t          { task_name: 'verify', story_key: '__run__', completed_at: '2026-04-03T00:01:00Z' },\n2353\t          { task_name: 'retry', story_key: '3-1-foo', completed_at: '2026-04-03T00:02:00Z' },\n2354\t          { task_name: 'verify', story_key: '__run__', completed_at: '2026-04-03T00:03:00Z' },\n2355\t        ],\n2356\t      }),\n2357\t    );\n2358\t\n2359\t    mockParse.mockReturnValue({\n2360\t      development_status: { '3-1-foo': 'ready-for-dev' },\n2361\t    });\n2362\t\n2363\t    // Pass on next verify\n2364\t    mockDriverDispatch.mockImplementation((opts: { prompt: string }) => {\n2365\t      if (opts.prompt.includes('Execute task')) {\n2366\t        return makeDriverStream(JSON.stringify({\n2367\t          verdict: 'pass',\n2368\t          score: { passed: 2, failed: 0, unknown: 0, total: 2 },\n2369\t          findings: [],\n2370\t        }), 'sess-v');\n2371\t      }\n2372\t      return makeDriverStream('ok', 'sess-r');\n2373\t    });\n2374\t\n2375\t    const config = makeConfig({\n2376\t      workflow: {\n2377\t        tasks: {\n2378\t          retry: makeTask({ scope: 'per-story' }),\n2379\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n2380\t        },\n2381\t        flow: [{ loop: ['retry', 'verify'] }],\n2382\t      },\n2383\t    });\n2384\t\n2385\t    await executeWorkflow(config);\n2386\t\n2387\t    // Check that iteration was advanced to 3 (not reset to 0 or 1)\n2388\t    const writes = mockWriteWorkflowState.mock.calls.map((c: unknown[]) => c[0] as WorkflowState);\n2389\t    const iterationValues = writes.map((s) => s.iteration);\n2390\t    // Should contain 3 (the next iteration after 2)\n2391\t    expect(iterationValues).toContain(3);\n2392\t    // Should NOT contain 0 or 1\n2393\t    expect(iterationValues).not.toContain(0);\n2394\t    expect(iterationValues).not.toContain(1);\n2395\t  });\n2396\t\n2397\t  it('error checkpoints do NOT cause task to be skipped on resume (error!=completion)', async () => {\n2398\t    // A previous run errored on implement for 5-1-foo — error checkpoint recorded.\n2399\t    // On resume, the task should NOT be skipped because error checkpoints are not completions.\n2400\t    mockReadWorkflowState.mockReturnValue(\n2401\t      makeDefaultState({\n2402\t        phase: 'error',\n2403\t        started: '2026-04-03T00:00:00Z',\n2404\t        tasks_completed: [\n2405\t          {\n2406\t            task_name: 'implement',\n2407\t            story_key: '5-1-foo',\n2408\t            completed_at: '2026-04-03T00:00:00Z',\n2409\t            error: true,\n2410\t          },\n2411\t        ],\n2412\t      }),\n2413\t    );\n2414\t\n2415\t    mockParse.mockReturnValue({\n2416\t      development_status: { '5-1-foo': 'ready-for-dev', '5-2-bar': 'backlog' },\n2417\t    });\n2418\t\n2419\t    const config = makeConfig({\n2420\t      workflow: {\n2421\t        tasks: { implement: makeTask() },\n2422\t        flow: ['implement'],\n2423\t      },\n2424\t    });\n2425\t\n2426\t    const result = await executeWorkflow(config);\n2427\t\n2428\t    // Both stories should be dispatched (error checkpoint should not skip 5-1-foo)\n2429\t    expect(mockDriverDispatch).toHaveBeenCalledTimes(2);\n2430\t    expect(result.tasksCompleted).toBe(2);\n2431\t  });\n2432\t\n2433\t  it('isTaskCompleted returns false for error checkpoints', () => {\n2434\t    const state = makeDefaultState({\n2435\t      tasks_completed: [\n2436\t        { task_name: 'implement', story_key: '3-1-foo', completed_at: '2026-04-03T00:00:00Z', error: true },\n2437\t      ],\n2438\t    });\n2439\t    expect(isTaskCompleted(state, 'implement', '3-1-foo')).toBe(false);\n2440\t  });\n2441\t\n2442\t  it('isLoopTaskCompleted excludes error checkpoints from count', () => {\n2443\t    const state = makeDefaultState({\n2444\t      tasks_completed: [\n2445\t        // 1 success + 1 error for retry/3-1-foo\n2446\t        { task_name: 'retry', story_key: '3-1-foo', completed_at: '2026-04-03T00:00:00Z' },\n2447\t        { task_name: 'retry', story_key: '3-1-foo', completed_at: '2026-04-03T00:01:00Z', error: true },\n2448\t      ],\n2449\t    });\n2450\t    // Only 1 successful checkpoint, so iteration 2 should NOT be considered complete\n2451\t    expect(isLoopTaskCompleted(state, 'retry', '3-1-foo', 2)).toBe(false);\n2452\t    expect(isLoopTaskCompleted(state, 'retry', '3-1-foo', 1)).toBe(true);\n2453\t  });\n2454\t\n2455\t  it('resumes from error phase and continues execution', async () => {\n2456\t    // Previous run ended in error phase. On resume, engine should continue.\n2457\t    mockReadWorkflowState.mockReturnValue(\n2458\t      makeDefaultState({\n2459\t        phase: 'error',\n2460\t        started: '2026-04-03T00:00:00Z',\n2461\t        tasks_completed: [\n2462\t          { task_name: 'implement', story_key: '5-1-foo', completed_at: '2026-04-03T00:00:00Z' },\n2463\t        ],\n2464\t      }),\n2465\t    );\n2466\t\n2467\t    const config = makeConfig({\n2468\t      workflow: {\n2469\t        tasks: { implement: makeTask() },\n2470\t        flow: ['implement'],\n2471\t      },\n2472\t    });\n2473\t\n2474\t    const result = await executeWorkflow(config);\n2475\t\n2476\t    // 5-1-foo was successfully completed (no error flag), so it should be skipped.\n2477\t    // Only 5-2-bar should be dispatched.\n2478\t    expect(mockDriverDispatch).toHaveBeenCalledTimes(1);\n2479\t    expect(result.tasksCompleted).toBe(1);\n2480\t  });\n2481\t\n2482\t  it('loop block: non-halt per-story error continues to next story (branch coverage)', async () => {\n2483\t    const { DispatchError } = await import('../agent-dispatch.js');\n2484\t    let callCount = 0;\n2485\t\n2486\t    mockDriverDispatch.mockImplementation(() => {\n2487\t      callCount++;\n2488\t      if (callCount === 1) {\n2489\t        // First per-story dispatch: non-halt error\n2490\t        return makeDriverStreamError(new DispatchError('bad', 'UNKNOWN', 'dev', new Error('inner')));\n2491\t      }\n2492\t      if (callCount === 2) {\n2493\t        // Second per-story dispatch succeeds\n2494\t        return makeDriverStream('ok', 'sess-r');\n2495\t      }\n2496\t      // Verify passes\n2497\t      return makeDriverStream(JSON.stringify({\n2498\t        verdict: 'pass',\n2499\t        score: { passed: 2, failed: 0, unknown: 0, total: 2 },\n2500\t        findings: [],\n2501\t      }), 'sess-v');\n2502\t    });\n2503\t\n2504\t    mockParse.mockReturnValue({\n2505\t      development_status: {\n2506\t        '3-1-foo': 'ready-for-dev',\n2507\t        '3-2-bar': 'backlog',\n2508\t      },\n2509\t    });\n2510\t\n2511\t    const config = makeConfig({\n2512\t      workflow: {\n2513\t        tasks: {\n2514\t          retry: makeTask({ scope: 'per-story' }),\n2515\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n2516\t        },\n2517\t        flow: [{ loop: ['retry', 'verify'] }],\n2518\t      },\n2519\t    });\n2520\t\n2521\t    const result = await executeWorkflow(config);\n2522\t\n2523\t    // 3 dispatches: retry(3-1-foo, error) + retry(3-2-bar, ok) + verify(pass)\n2524\t    expect(mockDriverDispatch).toHaveBeenCalledTimes(3);\n2525\t    expect(result.errors).toHaveLength(1);\n2526\t    expect(result.errors[0].storyKey).toBe('3-1-foo');\n2527\t  });\n2528\t\n2529\t  it('loop block: skips completed per-run task on resume (branch coverage)', async () => {\n2530\t    // Resume mid-loop: iteration 1, retry done, verify done for iteration 1\n2531\t    // This should advance to iteration 2 and dispatch tasks\n2532\t    mockReadWorkflowState.mockReturnValue(\n2533\t      makeDefaultState({\n2534\t        phase: 'executing',\n2535\t        started: '2026-04-03T00:00:00Z',\n2536\t        iteration: 1,\n2537\t        tasks_completed: [\n2538\t          { task_name: 'retry', story_key: '3-1-foo', completed_at: '2026-04-03T00:00:00Z' },\n2539\t          { task_name: 'verify', story_key: '__run__', completed_at: '2026-04-03T00:01:00Z' },\n2540\t        ],\n2541\t        evaluator_scores: [{\n2542\t          iteration: 1, passed: 0, failed: 1, unknown: 0, total: 1, timestamp: '2026-04-03T00:01:00Z',\n2543\t        }],\n2544\t      }),"}]},"parent_tool_use_id":"toolu_01SkXPMmo5ukZsEWidXQjyr7","session_id":"d2473842-56c4-49f2-ab43-68fabe9113bb","uuid":"f7992834-3af7-48a2-b59d-7a352075b491","timestamp":"2026-04-03T10:58:56.186Z"}
