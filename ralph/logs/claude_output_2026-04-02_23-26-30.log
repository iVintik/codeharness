{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012poe8MpbqeZKar5Hp4cyuL","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport fs from 'node:fs';\n3\timport path from 'node:path';\n4\timport YAML from 'yaml';\n5\timport { validateAgentSchema } from '../schema-validate.js';\n6\t\n7\tconst TEMPLATES_DIR = path.resolve(__dirname, '../../../templates/agents');\n8\t\n9\tconst EXPECTED_AGENTS = [\n10\t  'dev',\n11\t  'qa',\n12\t  'architect',\n13\t  'pm',\n14\t  'sm',\n15\t  'analyst',\n16\t  'ux-designer',\n17\t  'tech-writer',\n18\t  'evaluator',\n19\t];\n20\t\n21\t/** Cache parsed agents to avoid redundant fs reads across test groups */\n22\tconst agentCache = new Map<string, Record<string, unknown>>();\n23\t\n24\tfunction loadAgent(name: string): Record<string, unknown> {\n25\t  const cached = agentCache.get(name);\n26\t  if (cached) return cached;\n27\t  const filePath = path.join(TEMPLATES_DIR, `${name}.yaml`);\n28\t  const content = fs.readFileSync(filePath, 'utf-8');\n29\t  const parsed = YAML.parse(content) as Record<string, unknown>;\n30\t  agentCache.set(name, parsed);\n31\t  return parsed;\n32\t}\n33\t\n34\tdescribe('embedded agent templates', () => {\n35\t  describe('directory and file existence (AC #1)', () => {\n36\t    it('templates/agents/ directory exists', () => {\n37\t      expect(fs.existsSync(TEMPLATES_DIR)).toBe(true);\n38\t    });\n39\t\n40\t    it('contains exactly 9 YAML files', () => {\n41\t      const files = fs.readdirSync(TEMPLATES_DIR).filter((f) => f.endsWith('.yaml'));\n42\t      expect(files).toHaveLength(9);\n43\t    });\n44\t\n45\t    it.each(EXPECTED_AGENTS)('%s.yaml exists', (name) => {\n46\t      const filePath = path.join(TEMPLATES_DIR, `${name}.yaml`);\n47\t      expect(fs.existsSync(filePath)).toBe(true);\n48\t    });\n49\t  });\n50\t"}]},"parent_tool_use_id":"toolu_01WKqZRgBCkcgk47tCVdMRvD","session_id":"84c2a87f-6818-4ede-b88c-dde16fd6e99b","uuid":"e0c8a5c1-04ea-45