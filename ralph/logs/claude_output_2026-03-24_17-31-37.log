{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CLH8QcaPyPUbwC5AXLrojX","type":"tool_result","content":"     1→import { execFileSync } from 'node:child_process';\n     2→import { existsSync, readFileSync, writeFileSync } from 'node:fs';\n     3→import { join, basename } from 'node:path';\n     4→import { info } from '../output.js';\n     5→import { readState, writeState, readStateWithBody } from '../state.js';\n     6→import type { AppType } from '../stacks/index.js';\n     7→\n     8→export const WEB_OTLP_PACKAGES = [\n     9→  '@opentelemetry/sdk-trace-web',\n    10→  '@opentelemetry/instrumentation-fetch',\n    11→  '@opentelemetry/instrumentation-xml-http-request',\n    12→];\n    13→\n    14→export const AGENT_OTLP_PACKAGES_NODE = ['@traceloop/node-server-sdk'];\n    15→export const AGENT_OTLP_PACKAGES_PYTHON = ['traceloop-sdk'];\n    16→\n    17→export const NODE_REQUIRE_FLAG = '--require @opentelemetry/auto-instrumentations-node/register';\n    18→\n    19→export function ensureServiceNameEnvVar(projectDir: string, serviceName: string): void {\n    20→  const envFilePath = join(projectDir, '.env.codeharness');\n    21→  const sanitized = serviceName.replace(/[^a-zA-Z0-9._-]/g, '-');\n    22→  const envLine = `OTEL_SERVICE_NAME=${sanitized}`;\n    23→\n    24→  if (existsSync(envFilePath)) {\n    25→    const content = readFileSync(envFilePath, 'utf-8');\n    26→    const lines = content.split('\\n').filter((l, i, arr) => i < arr.length - 1 || l.trim() !== '');\n    27→    const idx = lines.findIndex(l => l.startsWith('OTEL_SERVICE_NAME='));\n    28→    if (idx !== -1) {\n    29→      lines[idx] = envLine;\n    30→    } else {\n    31→      lines.push(envLine);\n    32→    }\n    33→    writeFileSync(envFilePath, lines.join('\\n') + '\\n', 'utf-8');\n    34→  } else {\n    35→    writeFileSync(envFilePath, envLine + '\\n', 'utf-8');\n    36→  }\n    37→}\n    38→\n    39→export function ensureEndpointEnvVar(projectDir: string, endpoint: string): void {\n    40→  const envFilePath = join(projectDir, '.env.codeharness');\n    41→  const envLine = `OTEL_EXPORTER_OTLP_ENDPOINT=${endpoint}`;\n    42→\n    43→  if (existsSync(envFilePath)) {\n    44→    const content = readFileSync(envFilePath, 'utf-8');\n    45→    const lines = content.split('\\n').filter((l, i, arr) => i < arr.length - 1 || l.trim() !== '');\n    46→    const idx = lines.findIndex(l => l.startsWith('OTEL_EXPORTER_OTLP_ENDPOINT='));\n    47→    if (idx !== -1) {\n    48→      lines[idx] = envLine;\n    49→    } else {\n    50→      lines.push(envLine);\n    51→    }\n    52→    writeFileSync(envFilePath, lines.join('\\n') + '\\n', 'utf-8');\n    53→  } else {\n    54→    writeFileSync(envFilePath, envLine + '\\n', 'utf-8');\n    55→  }\n    56→}\n    57→\n    58→export function configureOtlpEnvVars(projectDir: string, stack: string | null, opts?: { endpoint?: string; appType?: AppType }): void {\n    59→  const projectName = basename(projectDir);\n    60→\n    61→  const { state, body } = readStateWithBody(projectDir);\n    62→\n    63→  const stackOtlpFields: Record<string, Record<string, string>> = {\n    64→    nodejs: { node_require: NODE_REQUIRE_FLAG },\n    65→    python: { python_wrapper: 'opentelemetry-instrument' },\n    66→    rust: { rust_env_hint: 'OTEL_EXPORTER_OTLP_ENDPOINT' },\n    67→  };\n    68→\n    69→  state.otlp = {\n    70→    enabled: true,\n    71→    endpoint: opts?.endpoint ?? 'http://localhost:4318',\n    72→    service_name: projectName,\n    73→    mode: state.otlp?.mode ?? 'local-shared',\n    74→    ...(stack && stackOtlpFields[stack] ? stackOtlpFields[stack] : {}),\n    75→  };\n    76→\n    77→  state.otlp.resource_attributes = 'service.instance.id=$(hostname)-$$';\n    78→\n    79→  writeState(state, projectDir, body);\n    80→\n    81→  ensureServiceNameEnvVar(projectDir, projectName);\n    82→\n    83→  const needsEndpointEnv = new Set(['rust']);\n    84→  if (stack && needsEndpointEnv.has(stack)) {\n    85→    ensureEndpointEnvVar(projectDir, state.otlp.endpoint);\n    86→  }\n    87→}\n    88→\n    89→export function configureCli(projectDir: string): void {\n    90→  const { state, body } = readStateWithBody(projectDir);\n    91→\n    92→  if (!state.otlp) return;\n    93→\n    94→  state.otlp.cli_env_vars = {\n    95→    OTEL_BSP_SCHEDULE_DELAY: '100',\n    96→    OTEL_TRACES_SAMPLER: 'always_on',\n    97→    OTEL_BLRP_SCHEDULE_DELAY: '100',\n    98→  };\n    99→\n   100→  writeState(state, projectDir, body);\n   101→}\n   102→\n   103→export function configureWeb(projectDir: string, stack: string | null): void {\n   104→  const webInstaller: Record<string, () => void> = {\n   105→    nodejs: () => {\n   106→      try {\n   107→        execFileSync('npm', ['install', ...WEB_OTLP_PACKAGES], { cwd: projectDir, stdio: 'pipe', timeout: 300_000 });\n   108→      } catch {\n   109→        // Web packages are supplementary; failure is non-fatal\n   110→      }\n   111→    },\n   112→  };\n   113→  if (stack && webInstaller[stack]) {\n   114→    webInstaller[stack]();\n   115→  }\n   116→\n   117→  let endpoint = 'http://localhost:4318';\n   118→  try {\n   119→    const currentState = readState(projectDir);\n   120→    if (currentState.otlp?.endpoint) {\n   121→      endpoint = currentState.otlp.endpoint;\n   122→    }\n   123→  } catch {\n   124→    // State not readable — use default endpoint\n   125→  }\n   126→\n   127→  const snippet = `// OpenTelemetry Web SDK initialization — generated by codeharness\n   128→import { WebTracerProvider } from '@opentelemetry/sdk-trace-web';\n   129→import { BatchSpanProcessor } from '@opentelemetry/sdk-trace-base';\n   130→import { OTLPTraceExporter } from '@opentelemetry/exporter-trace-otlp-http';\n   131→import { FetchInstrumentation } from '@opentelemetry/instrumentation-fetch';\n   132→import { XMLHttpRequestInstrumentation } from '@opentelemetry/instrumentation-xml-http-request';\n   133→import { registerInstrumentations } from '@opentelemetry/instrumentation';\n   134→\n   135→const exporter = new OTLPTraceExporter({\n   136→  url: '${endpoint}/v1/traces',\n   137→});\n   138→\n   139→const provider = new WebTracerProvider();\n   140→provider.addSpanProcessor(new BatchSpanProcessor(exporter));\n   141→provider.register();\n   142→\n   143→registerInstrumentations({\n   144→  instrumentations: [\n   145→    new FetchInstrumentation(),\n   146→    new XMLHttpRequestInstrumentation(),\n   147→  ],\n   148→});\n   149→`;\n   150→\n   151→  const snippetPath = join(projectDir, 'otel-web-init.js');\n   152→  writeFileSync(snippetPath, snippet, 'utf-8');\n   153→\n   154→  const { state, body } = readStateWithBody(projectDir);\n   155→  if (state.otlp) {\n   156→    state.otlp.web_snippet_path = 'otel-web-init.js';\n   157→  }\n   158→  writeState(state, projectDir, body);\n   159→}\n   160→\n   161→export function configureAgent(projectDir: string, stack: string | null): void {\n   162→  const agentInstallers: Record<string, () => boolean> = {\n   163→    nodejs: () => {\n   164→      try {\n   165→        execFileSync('npm', ['install', ...AGENT_OTLP_PACKAGES_NODE], { cwd: projectDir, stdio: 'pipe', timeout: 300_000 });\n   166→      } catch {\n   167→        // Agent packages are supplementary; failure is non-fatal\n   168→      }\n   169→      return true;\n   170→    },\n   171→    python: () => {\n   172→      try {\n   173→        execFileSync('pip', ['install', ...AGENT_OTLP_PACKAGES_PYTHON], { cwd: projectDir, stdio: 'pipe', timeout: 300_000 });\n   174→      } catch {\n   175→        try {\n   176→          for (const pkg of AGENT_OTLP_PACKAGES_PYTHON) {\n   177→            execFileSync('pipx', ['install', pkg], { cwd: projectDir, stdio: 'pipe', timeout: 300_000 });\n   178→          }\n   179→        } catch {\n   180→          // Agent packages are supplementary; failure is non-fatal\n   181→        }\n   182→      }\n   183→      return true;\n   184→    },\n   185→    rust: () => {\n   186→      info('Rust agent SDK not yet supported — skipping agent configuration');\n   187→      return false;\n   188→    },\n   189→  };\n   190→\n   191→  if (stack) {\n   192→    const installer = agentInstallers[stack];\n   193→    if (installer) {\n   194→      const proceed = installer();\n   195→      if (!proceed) return;\n   196→    }\n   197→  }\n   198→\n   199→  const { state, body } = readStateWithBody(projectDir);\n   200→  if (state.otlp) {\n   201→    state.otlp.agent_sdk = 'traceloop';\n   202→  }\n   203→  writeState(state, projectDir, body);\n   204→}\n   205→"}]},"parent_tool_use_id":"toolu_01LpBFDE1KxDokaruyokqTrj","session_id":"a74f233b-d75f-4731-af98-d5f8de661326","uuid":"f35176b8-ba4e-4e87-89a7-4e87a42c5b28","timestamp":"2026-03-24T13:49:05.193Z"}
