{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EJpbh3dKNq2KkAV4RfN4rX","type":"tool_result","content":"     1→/**\n     2→ * Python stack provider — encapsulates all Python-specific behavior.\n     3→ * Implements every StackProvider method for the python stack.\n     4→ *\n     5→ * Story 10-3: full implementation following NodejsProvider pattern from story 10-2.\n     6→ */\n     7→\n     8→import { execFileSync } from 'node:child_process';\n     9→import { existsSync, readFileSync } from 'node:fs';\n    10→import { join } from 'node:path';\n    11→\n    12→import type {\n    13→  AppType,\n    14→  CoverageToolInfo,\n    15→  CoverageToolName,\n    16→  OtlpResult,\n    17→  StackProvider,\n    18→  TestCounts,\n    19→} from './types.js';\n    20→import { readTextSafe, getPythonDepsContent, hasPythonDep } from './utils.js';\n    21→\n    22→/** Dependency names that signal an AI/agent project. */\n    23→const AGENT_DEPS = [\n    24→  'anthropic',\n    25→  'openai',\n    26→  'langchain',\n    27→  'llama-index',\n    28→  'traceloop-sdk',\n    29→];\n    30→\n    31→/** Dependency names that signal a web framework project. */\n    32→const WEB_FRAMEWORK_DEPS = ['flask', 'django', 'fastapi', 'streamlit'];\n    33→\n    34→/** OTLP packages required for Python instrumentation. */\n    35→const PYTHON_OTLP_PACKAGES = [\n    36→  'opentelemetry-distro',\n    37→  'opentelemetry-exporter-otlp',\n    38→];\n    39→\n    40→export class PythonProvider implements StackProvider {\n    41→  readonly name = 'python' as const;\n    42→  readonly markers = ['requirements.txt', 'pyproject.toml', 'setup.py'];\n    43→  readonly displayName = 'Python';\n    44→\n    45→  // ── Task 2: detectAppType ──────────────────────────────────────────────\n    46→\n    47→  detectAppType(dir: string): AppType {\n    48→    const content = getPythonDepsContent(dir);\n    49→\n    50→    // Priority 1: Agent detection\n    51→    if (AGENT_DEPS.some((d) => hasPythonDep(content, d))) {\n    52→      return 'agent';\n    53→    }\n    54→\n    55→    // Priority 2: Web detection (framework + templates/static dirs)\n    56→    const hasWebFramework = WEB_FRAMEWORK_DEPS.some((d) => hasPythonDep(content, d));\n    57→    if (hasWebFramework) {\n    58→      const hasTemplates = existsSync(join(dir, 'templates'));\n    59→      const hasStatic = existsSync(join(dir, 'static'));\n    60→      if (hasTemplates || hasStatic) {\n    61→        return 'web';\n    62→      }\n    63→      // Bare Flask/Django/FastAPI without templates => server\n    64→      return 'server';\n    65→    }\n    66→\n    67→    // Priority 3: Server detection (has main entry point)\n    68→    if (\n    69→      existsSync(join(dir, 'app.py')) ||\n    70→      existsSync(join(dir, 'main.py')) ||\n    71→      existsSync(join(dir, 'manage.py'))\n    72→    ) {\n    73→      return 'server';\n    74→    }\n    75→\n    76→    return 'generic';\n    77→  }\n    78→\n    79→  // ── Task 4: getCoverageTool ────────────────────────────────────────────\n    80→\n    81→  getCoverageTool(): CoverageToolName {\n    82→    return 'coverage-py';\n    83→  }\n    84→\n    85→  // ── Task 5: detectCoverageConfig ───────────────────────────────────────\n    86→\n    87→  detectCoverageConfig(dir: string): CoverageToolInfo {\n    88→    // Check requirements.txt\n    89→    const reqPath = join(dir, 'requirements.txt');\n    90→    const reqContent = readTextSafe(reqPath);\n    91→    if (reqContent) {\n    92→      if (hasPythonDep(reqContent, 'pytest-cov') || hasPythonDep(reqContent, 'coverage')) {\n    93→        return { tool: 'coverage-py', configFile: reqPath };\n    94→      }\n    95→    }\n    96→\n    97→    // Check pyproject.toml — use includes() here because coverage config sections\n    98→    // (e.g. [tool.coverage.run]) are not package deps and won't match hasPythonDep().\n    99→    const pyprojectPath = join(dir, 'pyproject.toml');\n   100→    const pyprojectContent = readTextSafe(pyprojectPath);\n   101→    if (pyprojectContent) {\n   102→      if (\n   103→        hasPythonDep(pyprojectContent, 'pytest-cov') ||\n   104→        hasPythonDep(pyprojectContent, 'coverage') ||\n   105→        pyprojectContent.includes('[tool.coverage')\n   106→      ) {\n   107→        return { tool: 'coverage-py', configFile: pyprojectPath };\n   108→      }\n   109→    }\n   110→\n   111→    return { tool: 'none' };\n   112→  }\n   113→\n   114→  // ── Task 6: getOtlpPackages ────────────────────────────────────────────\n   115→\n   116→  getOtlpPackages(): string[] {\n   117→    return [...PYTHON_OTLP_PACKAGES];\n   118→  }\n   119→\n   120→  // ── Task 7: installOtlp ───────────────────────────────────────────────\n   121→\n   122→  installOtlp(dir: string): OtlpResult {\n   123→    // Primary: pip install both packages in one command\n   124→    try {\n   125→      execFileSync('pip', ['install', ...PYTHON_OTLP_PACKAGES], {\n   126→        cwd: dir,\n   127→        stdio: 'pipe',\n   128→        timeout: 300_000,\n   129→      });\n   130→      return {\n   131→        success: true,\n   132→        packagesInstalled: [...PYTHON_OTLP_PACKAGES],\n   133→      };\n   134→    } catch {\n   135→      // Fallback: pipx install each package individually\n   136→    }\n   137→\n   138→    const installed: string[] = [];\n   139→    try {\n   140→      for (const pkg of PYTHON_OTLP_PACKAGES) {\n   141→        execFileSync('pipx', ['install', pkg], {\n   142→          cwd: dir,\n   143→          stdio: 'pipe',\n   144→          timeout: 300_000,\n   145→        });\n   146→        installed.push(pkg);\n   147→      }\n   148→      return {\n   149→        success: true,\n   150→        packagesInstalled: installed,\n   151→      };\n   152→    } catch (err) {\n   153→      const message = err instanceof Error ? err.message : 'Unknown error';\n   154→      return {\n   155→        success: false,\n   156→        packagesInstalled: installed,\n   157→        error: `Failed to install Python OTLP packages: ${message.length > 200 ? message.slice(0, 200) + '... (truncated)' : message}`,\n   158→      };\n   159→    }\n   160→  }\n   161→\n   162→  // ── Task 8: getDockerfileTemplate ─────────────────────────────────────\n   163→\n   164→  getDockerfileTemplate(): string {\n   165→    return `# Base image — pinned version for reproducibility\n   166→FROM python:3.12-slim\n   167→\n   168→# System utilities for verification\n   169→RUN apt-get update && apt-get install -y --no-install-recommends curl jq && rm -rf /var/lib/apt/lists/*\n   170→\n   171→# Install project from wheel or sdist\n   172→COPY dist/ /tmp/dist/\n   173→RUN pip install /tmp/dist/*.whl && rm -rf /tmp/dist/ && pip cache purge\n   174→\n   175→# Run as non-root user\n   176→USER nobody\n   177→\n   178→WORKDIR /workspace\n   179→`;\n   180→  }\n   181→\n   182→  // ── Task 9: getDockerBuildStage ───────────────────────────────────────\n   183→\n   184→  getDockerBuildStage(): string {\n   185→    return `# === Build stage: python ===\n   186→FROM python:3.12-slim AS build-python\n   187→WORKDIR /build\n   188→COPY . .\n   189→RUN pip install --target=/build/dist .\n   190→`;\n   191→  }\n   192→\n   193→  // ── Task 10: getRuntimeCopyDirectives ──────────────────────────────────\n   194→\n   195→  getRuntimeCopyDirectives(): string {\n   196→    return 'COPY --from=build-python /build/dist /opt/app/python/';\n   197→  }\n   198→\n   199→  // ── Task 11: getBuildCommands ──────────────────────────────────────────\n   200→\n   201→  getBuildCommands(): string[] {\n   202→    return ['pip install -r requirements.txt'];\n   203→  }\n   204→\n   205→  // ── Task 12: getTestCommands ──────────────────────────────────────────\n   206→\n   207→  getTestCommands(): string[] {\n   208→    return ['python -m pytest'];\n   209→  }\n   210→\n   211→  // ── Task 13: getSemgrepLanguages ──────────────────────────────────────\n   212→\n   213→  getSemgrepLanguages(): string[] {\n   214→    return ['python'];\n   215→  }\n   216→\n   217→  // ── Task 14: parseTestOutput ──────────────────────────────────────────\n   218→\n   219→  parseTestOutput(output: string): TestCounts {\n   220→    // Pytest format: \"12 passed, 3 failed\" or \"5 passed\" or \"12 passed, 3 failed, 1 skipped\"\n   221→    const passedMatch = /(\\d+)\\s+passed/i.exec(output);\n   222→    if (passedMatch) {\n   223→      const passed = parseInt(passedMatch[1], 10);\n   224→      const failedMatch = /(\\d+)\\s+failed/i.exec(output);\n   225→      const skippedMatch = /(\\d+)\\s+skipped/i.exec(output);\n   226→      const failed = failedMatch ? parseInt(failedMatch[1], 10) : 0;\n   227→      const skipped = skippedMatch ? parseInt(skippedMatch[1], 10) : 0;\n   228→      return { passed, failed, skipped, total: passed + failed + skipped };\n   229→    }\n   230→\n   231→    return { passed: 0, failed: 0, skipped: 0, total: 0 };\n   232→  }\n   233→\n   234→  // ── Task 15: parseCoverageReport ──────────────────────────────────────\n   235→\n   236→  parseCoverageReport(dir: string): number {\n   237→    const reportPath = join(dir, 'coverage.json');\n   238→    if (!existsSync(reportPath)) return 0;\n   239→\n   240→    try {\n   241→      const report = JSON.parse(readFileSync(reportPath, 'utf-8')) as {\n   242→        totals?: { percent_covered?: number };\n   243→      };\n   244→      return report.totals?.percent_covered ?? 0;\n   245→    } catch {\n   246→      return 0;\n   247→    }\n   248→  }\n   249→\n   250→  // ── Task 16: getProjectName ───────────────────────────────────────────\n   251→\n   252→  getProjectName(dir: string): string | null {\n   253→    // Try pyproject.toml first\n   254→    const pyprojectContent = readTextSafe(join(dir, 'pyproject.toml'));\n   255→    if (pyprojectContent) {\n   256→      // Extract the [project] section (up to the next section header or EOF)\n   257→      const projectIdx = pyprojectContent.search(/^\\[project\\]\\s*$/m);\n   258→      if (projectIdx !== -1) {\n   259→        const afterHeader = pyprojectContent.slice(\n   260→          projectIdx + pyprojectContent.slice(projectIdx).indexOf('\\n') + 1,\n   261→        );\n   262→        // Find where next section starts (line beginning with '[')\n   263→        const nextSectionIdx = afterHeader.search(/^\\[/m);\n   264→        const section = nextSectionIdx === -1 ? afterHeader : afterHeader.slice(0, nextSectionIdx);\n   265→        // Match name = \"...\" or name = '...' within the [project] section only\n   266→        const nameMatch = /^\\s*name\\s*=\\s*[\"']([^\"']+)[\"']/m.exec(section);\n   267→        if (nameMatch) return nameMatch[1];\n   268→      }\n   269→    }\n   270→\n   271→    // Try setup.py\n   272→    const setupContent = readTextSafe(join(dir, 'setup.py'));\n   273→    if (setupContent) {\n   274→      const match = /name\\s*=\\s*['\"]([^'\"]+)['\"]/m.exec(setupContent);\n   275→      if (match) return match[1];\n   276→    }\n   277→\n   278→    return null;\n   279→  }\n   280→}\n   281→"}]},"parent_tool_use_id":"toolu_01M6iq2XVtx8hbFMRevefAGh","session_id":"01d3be87-3cff-45e1-920c-7390a9e4093c","uuid":"7e099d57-cbcc-40bc-81ff-20c066020a57","timestamp":"2026-03-24T09:43:15.491Z"}
