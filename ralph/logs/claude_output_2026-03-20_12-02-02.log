{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01W6fvZ2uAsTSRHkJBygiAaB","type":"tool_result","content":"     1→import { spawn } from 'node:child_process';\n     2→import { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n     3→import { join, dirname } from 'node:path';\n     4→import { fileURLToPath } from 'node:url';\n     5→import { StringDecoder } from 'node:string_decoder';\n     6→import { Command } from 'commander';\n     7→import { fail, info, jsonOutput } from '../lib/output.js';\n     8→import { readSprintStatus } from '../lib/beads-sync.js';\n     9→import { generateRalphPrompt } from '../templates/ralph-prompt.js';\n    10→import { parseStreamLine } from '../lib/stream-parser.js';\n    11→import { startRenderer } from '../lib/ink-renderer.js';\n    12→import type { SprintInfo } from '../lib/ink-renderer.js';\n    13→import { getSprintState } from '../modules/sprint/index.js';\n    14→import { formatElapsed, mapSprintStatuses, parseRalphMessage } from '../lib/run-helpers.js';\n    15→\n    16→const SPRINT_STATUS_REL = '_bmad-output/implementation-artifacts/sprint-status.yaml';\n    17→const STORY_KEY_PATTERN = /^\\d+-\\d+-/;\n    18→\n    19→/**\n    20→ * Resolves the path to ralph/ralph.sh relative to the package root.\n    21→ * In the built CLI, __dirname is dist/, so we go up one level.\n    22→ */\n    23→export function resolveRalphPath(): string {\n    24→  // Use import.meta.url to find the package root\n    25→  const currentFile = fileURLToPath(import.meta.url);\n    26→  const currentDir = dirname(currentFile);\n    27→  // From dist/ or src/commands/, go up to package root\n    28→  // In built mode: dist/index.js -> dist/ -> package root\n    29→  // In dev mode: src/commands/run.ts -> src/commands/ -> src/ -> package root\n    30→  let root = dirname(currentDir); // up from commands/ or dist/\n    31→  if (root.endsWith('/src') || root.endsWith('\\\\src')) {\n    32→    root = dirname(root); // up from src/ to package root\n    33→  }\n    34→  return join(root, 'ralph', 'ralph.sh');\n    35→}\n    36→\n    37→/**\n    38→ * Resolves the plugin directory path.\n    39→ * The plugin is scaffolded to .claude/ during init.\n    40→ */\n    41→export function resolvePluginDir(): string {\n    42→  return join(process.cwd(), '.claude');\n    43→}\n    44→\n    45→/**\n    46→ * Counts stories by status from sprint-status.yaml.\n    47→ */\n    48→export function countStories(statuses: Record<string, string>): {\n    49→  total: number;\n    50→  ready: number;\n    51→  done: number;\n    52→  inProgress: number;\n    53→  // eslint-disable-next-line @typescript-eslint/naming-convention\n    54→  verified: number;\n    55→} {\n    56→  let total = 0;\n    57→  let ready = 0;\n    58→  let done = 0;\n    59→  let inProgress = 0;\n    60→  // eslint-disable-next-line @typescript-eslint/naming-convention\n    61→  let verified = 0;\n    62→\n    63→  for (const [key, status] of Object.entries(statuses)) {\n    64→    if (!STORY_KEY_PATTERN.test(key)) continue;\n    65→    total++;\n    66→    if (status === 'backlog' || status === 'ready-for-dev') ready++;\n    67→    else if (status === 'done') done++;\n    68→    else if (status === 'in-progress' || status === 'review') inProgress++;\n    69→    else if (status === 'verifying') verified++;\n    70→  }\n    71→\n    72→  return { total, ready, done, inProgress, verified };\n    73→}\n    74→\n    75→/**\n    76→ * Builds the argument array for spawning Ralph.\n    77→ */\n    78→export function buildSpawnArgs(opts: {\n    79→  ralphPath: string;\n    80→  pluginDir: string;\n    81→  promptFile: string;\n    82→  maxIterations: number;\n    83→  timeout: number;\n    84→  iterationTimeout: number;\n    85→  calls: number;\n    86→  quiet: boolean;\n    87→  maxStoryRetries?: number;\n    88→  reset?: boolean;\n    89→}): string[] {\n    90→  const args = [\n    91→    opts.ralphPath,\n    92→    '--plugin-dir', opts.pluginDir,\n    93→    '--max-iterations', String(opts.maxIterations),\n    94→    '--timeout', String(opts.timeout),\n    95→    '--iteration-timeout', String(opts.iterationTimeout),\n    96→    '--calls', String(opts.calls),\n    97→    '--prompt', opts.promptFile,\n    98→  ];\n    99→\n   100→  if (opts.maxStoryRetries !== undefined) {\n   101→    args.push('--max-story-retries', String(opts.maxStoryRetries));\n   102→  }\n   103→\n   104→  if (opts.reset) {\n   105→    args.push('--reset');\n   106→  }\n   107→\n   108→  return args;\n   109→}\n   110→\n   111→export function registerRunCommand(program: Command): void {\n   112→  program\n   113→    .command('run')\n   114→    .description('Execute the autonomous coding loop')\n   115→    .option('--max-iterations <n>', 'Maximum loop iterations', '50')\n   116→    .option('--timeout <seconds>', 'Total loop timeout in seconds', '43200')\n   117→    .option('--iteration-timeout <minutes>', 'Per-iteration timeout in minutes', '30')\n   118→    .option('--quiet', 'Suppress terminal output (background mode)', false)\n   119→    .option('--calls <n>', 'Max API calls per hour', '100')\n   120→    .option('--max-story-retries <n>', 'Max retries per story before flagging', '10')\n   121→    .option('--reset', 'Clear retry counters, flagged stories, and circuit breaker before starting', false)\n   122→    .action(async (options, cmd) => {\n   123→      const globalOpts = cmd.optsWithGlobals();\n   124→      const isJson = !!globalOpts.json;\n   125→      const outputOpts = { json: isJson };\n   126→\n   127→      // 1. Resolve Ralph script path\n   128→      const ralphPath = resolveRalphPath();\n   129→      if (!existsSync(ralphPath)) {\n   130→        fail('Ralph loop not found — reinstall codeharness', outputOpts);\n   131→        process.exitCode = 1;\n   132→        return;\n   133→      }\n   134→\n   135→      // 2. Resolve plugin directory\n   136→      const pluginDir = resolvePluginDir();\n   137→      if (!existsSync(pluginDir)) {\n   138→        fail('Plugin directory not found — run codeharness init first', outputOpts);\n   139→        process.exitCode = 1;\n   140→        return;\n   141→      }\n   142→\n   143→      // 3. Read sprint status for story count\n   144→      const projectDir = process.cwd();\n   145→      const sprintStatusPath = join(projectDir, SPRINT_STATUS_REL);\n   146→      const statuses = readSprintStatus(projectDir);\n   147→      const counts = countStories(statuses);\n   148→\n   149→      if (counts.total === 0) {\n   150→        fail('No stories found in sprint-status.yaml — nothing to execute', outputOpts);\n   151→        process.exitCode = 1;\n   152→        return;\n   153→      }\n   154→\n   155→      info(`Starting autonomous execution — ${counts.ready} ready, ${counts.inProgress} in progress, ${counts.verified} verified, ${counts.done}/${counts.total} done`, outputOpts);\n   156→\n   157→      // 4. Parse and validate numeric options\n   158→      const maxIterations = parseInt(options.maxIterations, 10);\n   159→      const timeout = parseInt(options.timeout, 10);\n   160→      const iterationTimeout = parseInt(options.iterationTimeout, 10);\n   161→      const calls = parseInt(options.calls, 10);\n   162→      const maxStoryRetries = parseInt(options.maxStoryRetries, 10);\n   163→\n   164→      if (isNaN(maxIterations) || isNaN(timeout) || isNaN(iterationTimeout) || isNaN(calls) || isNaN(maxStoryRetries)) {\n   165→        fail('Invalid numeric option — --max-iterations, --timeout, --iteration-timeout, --calls, and --max-story-retries must be numbers', outputOpts);\n   166→        process.exitCode = 1;\n   167→        return;\n   168→      }\n   169→\n   170→      // 5. Generate prompt file (with flagged stories context if available)\n   171→      const promptFile = join(projectDir, 'ralph', '.harness-prompt.md');\n   172→\n   173→      // Read flagged stories file if it exists (retry counts are managed by ralph.sh)\n   174→      const flaggedFilePath = join(projectDir, 'ralph', '.flagged_stories');\n   175→\n   176→      let flaggedStories: string[] | undefined;\n   177→\n   178→      if (existsSync(flaggedFilePath)) {\n   179→        try {\n   180→          const flaggedContent = readFileSync(flaggedFilePath, 'utf-8');\n   181→          flaggedStories = flaggedContent.split('\\n').filter(s => s.trim().length > 0);\n   182→        } catch {\n   183→          // Ignore read errors\n   184→        }\n   185→      }\n   186→\n   187→      const promptContent = generateRalphPrompt({\n   188→        projectDir,\n   189→        sprintStatusPath,\n   190→        flaggedStories,\n   191→      });\n   192→      try {\n   193→        mkdirSync(dirname(promptFile), { recursive: true });\n   194→        writeFileSync(promptFile, promptContent, 'utf-8');\n   195→      } catch (err) {\n   196→        const message = err instanceof Error ? err.message : String(err);\n   197→        fail(`Failed to write prompt file: ${message}`, outputOpts);\n   198→        process.exitCode = 1;\n   199→        return;\n   200→      }\n   201→\n   202→      // 6. Build spawn arguments\n   203→      const args = buildSpawnArgs({\n   204→        ralphPath,\n   205→        pluginDir,\n   206→        promptFile,\n   207→        maxIterations,\n   208→        timeout,\n   209→        iterationTimeout,\n   210→        calls,\n   211→        quiet: options.quiet,\n   212→        maxStoryRetries,\n   213→        reset: options.reset,\n   214→      });\n   215→\n   216→      // 7. Set environment — stream-json is always the output format\n   217→      const env = { ...process.env };\n   218→      if (isJson) {\n   219→        env.CLAUDE_OUTPUT_FORMAT = 'stream-json';\n   220→      }\n   221→\n   222→      // 8. Spawn Ralph — pipe stdout/stderr through stream parser → Ink renderer\n   223→      // Declare renderer handle outside try so cleanup is always reachable\n   224→      const quiet = options.quiet;\n   225→      const rendererHandle = startRenderer({ quiet });\n   226→      let sprintStateInterval: ReturnType<typeof setInterval> | null = null;\n   227→      const sessionStartTime = Date.now();\n   228→\n   229→      try {\n   230→        // Read initial sprint state for the renderer header\n   231→        const initialState = getSprintState();\n   232→        if (initialState.success) {\n   233→          const s = initialState.data;\n   234→          const sprintInfo: SprintInfo = {\n   235→            storyKey: s.run.currentStory ?? '',\n   236→            phase: s.run.currentPhase ?? '',\n   237→            done: s.sprint.done,\n   238→            total: s.sprint.total,\n   239→            elapsed: formatElapsed(Date.now() - sessionStartTime),\n   240→          };\n   241→          rendererHandle.updateSprintState(sprintInfo);\n   242→        }\n   243→\n   244→        // Feed initial per-story statuses to the renderer\n   245→        const initialStatuses = readSprintStatus(projectDir);\n   246→        const initialStories = mapSprintStatuses(initialStatuses);\n   247→        if (initialStories.length > 0) {\n   248→          rendererHandle.updateStories(initialStories);\n   249→        }\n   250→\n   251→        const child = spawn('bash', args, {\n   252→          stdio: quiet ? 'ignore' : ['inherit', 'pipe', 'pipe'],\n   253→          cwd: projectDir,\n   254→          env,\n   255→        });\n   256→\n   257→        if (!quiet && child.stdout && child.stderr) {\n   258→          // Buffer partial lines and feed through stream parser → Ink renderer.\n   259→          // StringDecoder handles multi-byte UTF-8 chars split across Buffer boundaries.\n   260→          const makeLineHandler = (opts?: { parseRalph?: boolean }): ((data: Buffer) => void) => {\n   261→            let partial = '';\n   262→            const decoder = new StringDecoder('utf8');\n   263→            return (data: Buffer): void => {\n   264→              const text = partial + decoder.write(data);\n   265→              const parts = text.split('\\n');\n   266→              partial = parts.pop() ?? '';\n   267→              for (const line of parts) {\n   268→                if (line.trim().length === 0) continue;\n   269→                const event = parseStreamLine(line);\n   270→                if (event) {\n   271→                  rendererHandle.update(event);\n   272→                }\n   273→                // Parse ralph structured output for story messages (AC #8)\n   274→                if (opts?.parseRalph) {\n   275→                  const msg = parseRalphMessage(line);\n   276→                  if (msg) {\n   277→                    rendererHandle.addMessage(msg);\n   278→                  }\n   279→                }\n   280→              }\n   281→            };\n   282→          };\n   283→          child.stdout.on('data', makeLineHandler());\n   284→          child.stderr.on('data', makeLineHandler({ parseRalph: true }));\n   285→\n   286→          // Periodically refresh sprint state for the header display\n   287→          sprintStateInterval = setInterval(() => {\n   288→            try {\n   289→              const stateResult = getSprintState();\n   290→              if (stateResult.success) {\n   291→                const s = stateResult.data;\n   292→                const sprintInfo: SprintInfo = {\n   293→                  storyKey: s.run.currentStory ?? '',\n   294→                  phase: s.run.currentPhase ?? '',\n   295→                  done: s.sprint.done,\n   296→                  total: s.sprint.total,\n   297→                  elapsed: formatElapsed(Date.now() - sessionStartTime),\n   298→                };\n   299→                rendererHandle.updateSprintState(sprintInfo);\n   300→              }\n   301→              // Refresh per-story statuses (AC #7)\n   302→              const currentStatuses = readSprintStatus(projectDir);\n   303→              const storyEntries = mapSprintStatuses(currentStatuses);\n   304→              rendererHandle.updateStories(storyEntries);\n   305→            } catch {\n   306→              // Ignore read errors during polling\n   307→            }\n   308→          }, 5_000);\n   309→        }\n   310→\n   311→        const exitCode = await new Promise<number>((resolve, reject) => {\n   312→          child.on('error', (err) => {\n   313→            if (sprintStateInterval) clearInterval(sprintStateInterval);\n   314→            rendererHandle.cleanup();\n   315→            reject(err);\n   316→          });\n   317→          child.on('close', (code) => {\n   318→            if (sprintStateInterval) clearInterval(sprintStateInterval);\n   319→            rendererHandle.cleanup();\n   320→            resolve(code ?? 1);\n   321→          });\n   322→        });\n   323→\n   324→        // 9. Handle JSON output on exit\n   325→        if (isJson) {\n   326→          const statusFile = join(projectDir, 'ralph', 'status.json');\n   327→          if (existsSync(statusFile)) {\n   328→            try {\n   329→              const statusData = JSON.parse(readFileSync(statusFile, 'utf-8'));\n   330→              const finalStatuses = readSprintStatus(projectDir);\n   331→              const finalCounts = countStories(finalStatuses);\n   332→              jsonOutput({\n   333→                status: statusData.status ?? (exitCode === 0 ? 'completed' : 'stopped'),\n   334→                iterations: statusData.loop_count ?? 0,\n   335→                storiesCompleted: finalCounts.done,\n   336→                storiesTotal: finalCounts.total,\n   337→                storiesRemaining: finalCounts.total - finalCounts.done,\n   338→                elapsedSeconds: statusData.elapsed_seconds ?? 0,\n   339→                flaggedStories: statusData.flagged_stories ?? [],\n   340→                exitReason: statusData.exit_reason ?? '',\n   341→              });\n   342→            } catch {\n   343→              jsonOutput({\n   344→                status: exitCode === 0 ? 'completed' : 'stopped',\n   345→                iterations: 0,\n   346→                storiesCompleted: 0,\n   347→                storiesTotal: counts.total,\n   348→                storiesRemaining: counts.total,\n   349→                elapsedSeconds: 0,\n   350→                flaggedStories: [],\n   351→                exitReason: 'status_file_unreadable',\n   352→              });\n   353→            }\n   354→          } else {\n   355→            // status.json not created (Ralph crashed early or never started)\n   356→            const finalStatuses = readSprintStatus(projectDir);\n   357→            const finalCounts = countStories(finalStatuses);\n   358→            jsonOutput({\n   359→              status: exitCode === 0 ? 'completed' : 'stopped',\n   360→              iterations: 0,\n   361→              storiesCompleted: finalCounts.done,\n   362→              storiesTotal: finalCounts.total,\n   363→              storiesRemaining: finalCounts.total - finalCounts.done,\n   364→              elapsedSeconds: 0,\n   365→              flaggedStories: [],\n   366→              exitReason: 'status_file_missing',\n   367→            });\n   368→          }\n   369→        }\n   370→\n   371→        process.exitCode = exitCode;\n   372→      } catch (err) {\n   373→        if (sprintStateInterval) clearInterval(sprintStateInterval);\n   374→        rendererHandle.cleanup();\n   375→        const message = err instanceof Error ? err.message : String(err);\n   376→        fail(`Failed to start Ralph: ${message}`, outputOpts);\n   377→        process.exitCode = 1;\n   378→      }\n   379→    });\n   380→}\n   381→"}]},"parent_tool_use_id":"toolu_01J5AdAMYAsRdio1YgdnbwDy","session_id":"64c1e9b9-a641-40be-ae67-07aee0c47965","uuid":"29d0b1a0-f016-4885-8208-d02a76aa5ace","timestamp":"2026-03-20T08:05:14.138Z"}
