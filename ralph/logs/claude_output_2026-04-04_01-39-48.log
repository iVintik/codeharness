{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PVN3bqp1v49kMp4cqRAume","type":"tool_result","content":"80\t  readonly version: number;\n81\t  readonly taskName: string;\n82\t  readonly storyId: string;\n83\t  readonly driver: string;\n84\t  readonly model: string;\n85\t  readonly timestamp: string;\n86\t  readonly cost_usd: number | null;\n87\t  readonly duration_ms: number;\n88\t  readonly changedFiles: readonly string[];\n89\t  readonly testResults: TestResults | null;\n90\t  readonly output: string;\n91\t  readonly acceptanceCriteria: readonly ACStatus[];\n92\t}\n93\t\n94\t/**\n95\t * Options for dispatching a task to a driver.\n96\t */\n97\texport interface DispatchOpts {\n98\t  readonly prompt: string;\n99\t  readonly model: string;\n100\t  readonly cwd: string;\n101\t  readonly sourceAccess: boolean;\n102\t  readonly plugins?: readonly string[];\n103\t  readonly timeout?: number;\n104\t  readonly sessionId?: string;\n105\t  readonly appendSystemPrompt?: string;\n106\t  readonly outputContract?: OutputContract;\n107\t}\n108\t\n109\t/**\n110\t * The core agent driver interface (v2 — Epic 10).\n111\t * Each driver knows how to check health, dispatch tasks, and report cost.\n112\t * `dispatch()` returns `AsyncIterable<StreamEvent>` enabling both in-process\n113\t * (Agent SDK yields) and CLI-wrapped (stdout parsed to events) drivers.\n114\t */\n115\texport interface AgentDriver {\n116\t  readonly name: string;\n117\t  readonly defaultModel: string;\n118\t  readonly capabilities: DriverCapabilities;\n119\t  healthCheck(): Promise<DriverHealth>;\n120\t  dispatch(opts: DispatchOpts): AsyncIterable<StreamEvent>;\n121\t  getLastCost(): number | null;\n122\t}\n123\t\n124\t// --- Deprecated Types (backward compatibility until story 10-3) ---\n125\t\n126\t/**\n127\t * Options for spawning an agent process.\n128\t * @deprecated Use `DispatchOpts` instead. Will be removed after story 10-3.\n129\t */\n130\texport interface SpawnOpts {\n131\t  storyKey: string;\n132\t  prompt: string;\n133\t  workDir: string;\n134\t  timeout: number;\n135\t  env?: Record<string, string>;\n136\t}\n137\t\n138\t/**\n139\t * Abstraction over a running agent process.\n140\t * Wraps Node.js ChildProcess but allows non-process-based drivers\n141\t * (direct API calls, WebSocket connections) to implement the same interface.\n142\t * @deprecated Use `AsyncIterable<StreamEvent>` from `dispatch()` instead. Will be removed after story 10-3.\n143\t */\n144\texport interface AgentProcess {\n145\t  stdout: Readable;\n146\t  stderr: Readable;\n147\t  on(event: 'close', handler: (code: number) => void): void;\n148\t  on(event: 'error', handler: (err: Error) => void): void;\n149\t  kill(signal?: string): void;\n150\t}\n151\t\n152\t/**\n153\t * Discriminated union of events emitted by an agent driver.\n154\t * The `parseOutput()` method converts raw agent output lines into these typed events.\n155\t * @deprecated Use `StreamEvent` from `stream-parser.ts` instead. Will be removed after story 10-3.\n156\t */\n157\texport type AgentEvent =\n158\t  | { type: 'tool-start'; name: string }\n159\t  | { type: 'tool-input'; partial: string }"}]},"parent_tool_use_id":"toolu_01WnnpXgRY1Zao1mENPUGorH","session_id":"74f4684f-cc80-4828-8405-943cba326449","uuid":"1bb49dc4-5d47-4f9f-9e92-77ba790ff9b0","timestamp":"2026-04-03T21:41:37.333Z"}
