{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011wCTjDRxFtTbgr1okrLD4D","type":"tool_result","content":"1\t/**\n2\t * Worktree Manager.\n3\t *\n4\t * Handles git worktree lifecycle for parallel epic execution:\n5\t * create, cleanup, list, and orphan detection. Each epic gets\n6\t * its own git worktree on a dedicated branch under the\n7\t * `codeharness/` namespace.\n8\t *\n9\t * @see Story 17-1: Worktree Manager\n10\t * @see Story 18-2: Merge Agent for Conflict Resolution (onConflict callback)\n11\t */\n12\t\n13\timport { exec, execSync } from 'node:child_process';\n14\timport { existsSync, readFileSync, statSync } from 'node:fs';\n15\timport { join } from 'node:path';\n16\timport { promisify } from 'node:util';\n17\t\n18\timport type { MergeConflictContext, ConflictResolutionResult } from './merge-agent.js';\n19\t\n20\tconst execAsync = promisify(exec);\n21\t\n22\t// --- Constants ---\n23\t\n24\t/** Branch prefix for all codeharness worktree branches. */\n25\texport const BRANCH_PREFIX = 'codeharness/epic-';\n26\t\n27\t/** Base path for worktree directories in /tmp. */\n28\texport const WORKTREE_BASE = '/tmp/codeharness-wt-epic-';\n29\t\n30\t// --- Interfaces ---\n31\t\n32\t/**\n33\t * Information about a codeharness worktree.\n34\t */\n35\texport interface WorktreeInfo {\n36\t  /** Epic identifier extracted from the branch name. */\n37\t  readonly epicId: string;\n38\t  /** Absolute path to the worktree directory. */\n39\t  readonly path: string;\n40\t  /** Full branch name (e.g., `codeharness/epic-17-worktree-manager`). */\n41\t  readonly branch: string;\n42\t  /** Timestamp when the worktree was created. */\n43\t  readonly createdAt: Date;\n44\t}\n45\t\n46\t// --- Error Class ---\n47\t\n48\t/**\n49\t * Error thrown by worktree operations. Includes stderr from git commands.\n50\t */\n51\texport class WorktreeError extends Error {\n52\t  /** Raw stderr output from the failed git command. */\n53\t  readonly stderr: string;\n54\t\n55\t  constructor(message: string, stderr: string) {\n56\t    super(message);\n57\t    this.name = 'WorktreeError';\n58\t    this.stderr = stderr;\n59\t  }\n60\t}\n61\t\n62\t// --- Merge Types ---\n63\t\n64\t/**\n65\t * Strategy used when merging an epic branch into main.\n66\t */\n67\texport type MergeStrategy = 'rebase' | 'merge-commit';\n68\t\n69\t/**\n70\t * Result of a merge operation.\n71\t */\n72\texport interface MergeResult {\n73\t  /** Whether the merge and post-merge validation succeeded. */\n74\t  success: boolean;\n75\t  /** Reason for failure, if any. */\n76\t  reason?: 'conflict' | 'tests-failed' | 'git-error';\n77\t  /** List of conflicting file paths, when reason is 'conflict'. */\n78\t  conflicts?: string[];\n79\t  /** Test suite results from post-merge validation. */\n80\t  testResults?: { passed: number; failed: number; coverage?: number };\n81\t  /** Total wall-clock duration of the merge operation in milliseconds. */\n82\t  durationMs: number;\n83\t}\n84\t\n85\t// --- Async Mutex ---\n86\t\n87\t/**\n88\t * Simple async mutex for serializing merge operations.\n89\t * No external dependencies — uses a promise-based wait queue.\n90\t */\n91\texport class AsyncMutex {\n92\t  private locked = false;\n93\t  private waitQueue: Array<() => void> = [];\n94\t\n95\t  async acquire(): Promise<() => void> {\n96\t    while (this.locked) {\n97\t      await new Promise<void>((resolve) => this.waitQueue.push(resolve));\n98\t    }\n99\t    this.locked = true;\n100\t    return () => {\n101\t      this.locked = false;\n102\t      const next = this.waitQueue.shift();\n103\t      if (next) next();\n104\t    };\n105\t  }\n106\t}\n107\t\n108\t/** Module-level singleton merge mutex shared across all WorktreeManager instances. */\n109\texport const mergeMutex = new AsyncMutex();\n110\t\n111\t/**\n112\t * Callback invoked when merge conflicts are detected.\n113\t * Receives conflict context, returns resolution result.\n114\t * The merge agent implements this contract.\n115\t */\n116\texport type OnConflictCallback = (context: MergeConflictContext) => Promise<ConflictResolutionResult>;\n117\t\n118\t// --- WorktreeManager Class ---\n119\t\n120\t/**\n121\t * Manages git worktrees for parallel epic execution.\n122\t *\n123\t * Creates isolated working directories (worktrees) for each epic,\n124\t * each on its own branch under the `codeharness/` namespace.\n125\t */\n126\texport class WorktreeManager {\n127\t  private readonly mainBranch: string;\n128\t  private readonly cwd: string;\n129\t\n130\t  /**\n131\t   * @param mainBranch  The main branch to base new worktree branches on (default: `'main'`).\n132\t   * @param cwd  The git repository root directory (default: `process.cwd()`).\n133\t   */\n134\t  constructor(mainBranch: string = 'main', cwd?: string) {\n135\t    this.mainBranch = mainBranch;\n136\t    this.cwd = cwd ?? process.cwd();\n137\t  }\n138\t\n139\t  /**\n140\t   * Create a worktree for a parallel epic.\n141\t   *\n142\t   * Creates a branch `codeharness/epic-{epicId}-{slug}` from the main branch HEAD,\n143\t   * then creates a git worktree at `/tmp/codeharness-wt-epic-{epicId}`.\n144\t   *\n145\t   * If a stale branch or worktree exists from a previous crashed run,\n146\t   * it is cleaned up before re-creating (idempotent recovery).\n147\t   *\n148\t   * @param epicId  The epic identifier (numeric or string).\n149\t   * @param slug  A human-readable slug for the branch name (sanitized to `[a-z0-9-]`).\n150\t   * @returns The absolute path to the created worktree directory.\n151\t   * @throws {WorktreeError} If the git command fails.\n152\t   */\n153\t  createWorktree(epicId: string, slug: string): string {\n154\t    this.validateEpicId(epicId);\n155\t    const sanitizedSlug = this.sanitizeSlug(slug);\n156\t    const branchName = `${BRANCH_PREFIX}${epicId}-${sanitizedSlug}`;\n157\t    const worktreePath = `${WORKTREE_BASE}${epicId}`;\n158\t\n159\t    // Clean up stale state from previous crashed runs (AC #9)\n160\t    this.cleanupStale(epicId, branchName, worktreePath);\n161\t\n162\t    let branchCreated = false;\n163\t    try {\n164\t      // Create branch from main branch HEAD\n165\t      this.execGit(`git branch ${branchName} ${this.mainBranch}`);\n166\t      branchCreated = true;\n167\t\n168\t      // Create worktree\n169\t      this.execGit(`git worktree add ${worktreePath} ${branchName}`);\n170\t\n171\t      return worktreePath;\n172\t    } catch (err: unknown) {\n173\t      // Clean up partial state on failure (AC #10)\n174\t      this.cleanupPartial(branchCreated, branchName, worktreePath);\n175\t\n176\t      // execGit always wraps errors as WorktreeError; re-throw directly\n177\t      if (err instanceof WorktreeError) {\n178\t        throw err;\n179\t      }\n180\t\n181\t      // Defensive: handle unexpected non-WorktreeError (should not happen)\n182\t      const message = err instanceof Error ? err.message : String(err);\n183\t      throw new WorktreeError(\n184\t        `Failed to create worktree for epic ${epicId}: ${message}`,\n185\t        '',\n186\t      );\n187\t    }\n188\t  }\n189\t\n190\t  /**\n191\t   * Remove a worktree and its branch for an epic.\n192\t   *\n193\t   * Idempotent: completes without error if the worktree or branch\n194\t   * does not exist (AC #5).\n195\t   *\n196\t   * @param epicId  The epic identifier.\n197\t   */\n198\t  cleanupWorktree(epicId: string): void {\n199\t    this.validateEpicId(epicId);\n200\t    const worktreePath = `${WORKTREE_BASE}${epicId}`;\n201\t\n202\t    // Remove worktree (ignore errors if it doesn't exist)\n203\t    try {\n204\t      this.execGit(`git worktree remove ${worktreePath} --force`);\n205\t    } catch { // IGNORE: idempotent cleanup — worktree may not exist per AC #5\n206\t    }\n207\t\n208\t    // Find and delete the branch matching this epicId\n209\t    const branch = this.findBranchForEpic(epicId);\n210\t    if (branch) {\n211\t      try {\n212\t        this.execGit(`git branch -D ${branch}`);\n213\t      } catch { // IGNORE: idempotent cleanup — branch may not exist per AC #5\n214\t      }\n215\t    }\n216\t  }\n217\t\n218\t  /**\n219\t   * List all codeharness worktrees.\n220\t   *\n221\t   * @returns An array of `WorktreeInfo` objects sorted by epicId.\n222\t   *          Returns an empty array when no codeharness worktrees exist.\n223\t   */\n224\t  listWorktrees(): WorktreeInfo[] {\n225\t    let output: string;\n226\t    try {\n227\t      output = this.execGit('git worktree list --porcelain');\n228\t    } catch { // IGNORE: non-git-repo or corrupt state returns empty list safely\n229\t      return [];\n230\t    }\n231\t\n232\t    const entries = this.parsePorcelainOutput(output);\n233\t    return entries\n234\t      .filter((e) => e.branch.startsWith(`refs/heads/${BRANCH_PREFIX}`))\n235\t      .map((e) => {\n236\t        const branchName = e.branch.replace('refs/heads/', '');\n237\t        const epicId = this.extractEpicId(branchName);\n238\t        return {\n239\t          epicId,\n240\t          path: e.path,\n241\t          branch: branchName,\n242\t          createdAt: this.getWorktreeCreatedAt(e.path),\n243\t        };\n244\t      })\n245\t      .sort((a, b) => a.epicId.localeCompare(b.epicId, undefined, { numeric: true }));\n246\t  }\n247\t\n248\t  /**\n249\t   * Detect orphaned worktrees from previous crashed runs.\n250\t   *\n251\t   * A worktree is considered orphaned if its directory exists on disk\n252\t   * but has no `.codeharness/lane-state.json` file or the file has\n253\t   * no active PID.\n254\t   *\n255\t   * @returns An array of orphaned `WorktreeInfo` entries.\n256\t   */\n257\t  detectOrphans(): WorktreeInfo[] {\n258\t    const worktrees = this.listWorktrees();\n259\t    return worktrees.filter((wt) => this.isOrphaned(wt));\n260\t  }\n261\t\n262\t  /**\n263\t   * Merge an epic branch into the main branch with serialized access.\n264\t   *\n265\t   * Acquires a module-level mutex so only one merge runs at a time.\n266\t   * After a clean merge, runs the test suite. If tests fail, the merge\n267\t   * is reverted. On conflict or git error, the main branch is restored.\n268\t   *\n269\t   * @param epicId  The epic identifier whose branch should be merged.\n270\t   * @param strategy  Merge strategy: `'merge-commit'` (default) or `'rebase'`.\n271\t   * @param testCommand  Command to run for post-merge validation (default: `'npm test'`).\n272\t   * @returns A `MergeResult` describing the outcome.\n273\t   */\n274\t  async mergeWorktree(\n275\t    epicId: string,\n276\t    strategy: MergeStrategy = 'merge-commit',\n277\t    testCommand: string = 'npm test',\n278\t    onConflict?: OnConflictCallback,\n279\t  ): Promise<MergeResult> {\n280\t    const start = Date.now();\n281\t\n282\t    // Validate testCommand to prevent shell injection — only allow safe characters\n283\t    if (!/^[a-zA-Z0-9_./ -]+$/.test(testCommand)) {\n284\t      return {\n285\t        success: false,\n286\t        reason: 'git-error',\n287\t        durationMs: Date.now() - start,\n288\t      };\n289\t    }\n290\t\n291\t    // Find branch for this epicId\n292\t    const branch = this.findBranchForEpic(epicId);\n293\t    if (!branch) {\n294\t      return {\n295\t        success: false,\n296\t        reason: 'git-error',\n297\t        durationMs: Date.now() - start,\n298\t      };\n299\t    }\n300\t\n301\t    // Validate branch name to prevent command injection via malicious branch names\n302\t    if (!/^[a-zA-Z0-9_./-]+$/.test(branch)) {\n303\t      return {\n304\t        success: false,\n305\t        reason: 'git-error',\n306\t        durationMs: Date.now() - start,\n307\t      };\n308\t    }\n309\t\n310\t    const release = await mergeMutex.acquire();\n311\t    try {\n312\t      // Re-verify branch still exists after acquiring mutex (could be deleted while waiting)\n313\t      const branchCheck = this.findBranchForEpic(epicId);\n314\t      if (!branchCheck || branchCheck !== branch) {\n315\t        return {\n316\t          success: false,\n317\t          reason: 'git-error',\n318\t          durationMs: Date.now() - start,\n319\t        };\n320\t      }\n321\t\n322\t      // Verify main branch is clean before merge\n323\t      const status = this.execGit('git status --porcelain');\n324\t      if (status.length > 0) {\n325\t        return {\n326\t          success: false,\n327\t          reason: 'git-error',\n328\t          durationMs: Date.now() - start,\n329\t        };\n330\t      }\n331\t\n332\t      // Attempt merge or rebase\n333\t      try {\n334\t        if (strategy === 'rebase') {\n335\t          this.execGit(`git rebase ${branch}`);\n336\t        } else {\n337\t          this.execGit(`git merge --no-ff ${branch}`);\n338\t        }\n339\t      } catch { // IGNORE: merge/rebase failure is expected — detect conflict vs git-error below\n340\t        const conflicts = this.detectConflicts();\n341\t        if (conflicts.length > 0) {\n342\t          // If onConflict callback is provided, invoke the merge agent\n343\t          if (onConflict) {\n344\t            const result = await onConflict({\n345\t              epicId,\n346\t              branch,\n347\t              conflicts,\n348\t              mainDescription: '',\n349\t              branchDescription: '',\n350\t              cwd: this.cwd,\n351\t              testCommand,\n352\t              driver: undefined as never, // Caller must provide via context\n353\t            });\n354\t            if (result.resolved) {\n355\t              // Agent resolved and committed — cleanup worktree\n356\t              this.cleanupWorktree(epicId);\n357\t              return {\n358\t                success: true,\n359\t                testResults: result.testResults,\n360\t                durationMs: Date.now() - start,\n361\t              };\n362\t            }\n363\t            // Escalated — abort merge, preserve worktree\n364\t            this.abortMerge(strategy);\n365\t            return {\n366\t              success: false,\n367\t              reason: 'conflict',\n368\t              conflicts,\n369\t              durationMs: Date.now() - start,\n370\t            };\n371\t          }\n372\t          // No callback — existing behavior\n373\t          this.abortMerge(strategy);\n374\t          return {\n375\t            success: false,\n376\t            reason: 'conflict',\n377\t            conflicts,\n378\t            durationMs: Date.now() - start,\n379\t          };\n380\t        }\n381\t        // Not a conflict — unexpected git error\n382\t        this.abortMerge(strategy);\n383\t        return {\n384\t          success: false,\n385\t          reason: 'git-error',\n386\t          durationMs: Date.now() - start,\n387\t        };\n388\t      }\n389\t\n390\t      // Run test suite after successful merge\n391\t      const testResults = await this.runTestSuite(testCommand);\n392\t      if (testResults.failed > 0) {\n393\t        // Revert merge on test failure\n394\t        try {\n395\t          this.execGit('git reset --hard HEAD~1');\n396\t        } catch { // IGNORE: reset failure indicates corrupted git state; still return tests-failed\n397\t        }\n398\t        return {\n399\t          success: false,\n400\t          reason: 'tests-failed',\n401\t          testResults,\n402\t          durationMs: Date.now() - start,\n403\t        };\n404\t      }\n405\t\n406\t      // Success — cleanup worktree\n407\t      this.cleanupWorktree(epicId);\n408\t      return {\n409\t        success: true,\n410\t        testResults,\n411\t        durationMs: Date.now() - start,\n412\t      };\n413\t    } finally {\n414\t      release();\n415\t    }\n416\t  }\n417\t\n418\t  // --- Private Helpers ---\n419\t\n420\t  /**\n421\t   * Get the creation time of a worktree directory.\n422\t   * Falls back to current time if the directory doesn't exist or stat fails.\n423\t   */\n424\t  private getWorktreeCreatedAt(worktreePath: string): Date {\n425\t    try {\n426\t      const stats = statSync(worktreePath);\n427\t      return stats.birth