{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011td5sBfhxPPxcydq6dFweW","type":"tool_result","content":"     1→/**\n     2→ * Coverage state persistence — tracks observability coverage in sprint-state.json.\n     3→ *\n     4→ * Implements Story 1.3: read/write/trend/target comparison for static analysis coverage.\n     5→ * Only the `static` section is managed here; `runtime` is deferred to Epic 2.\n     6→ */\n     7→\n     8→import { readFileSync, writeFileSync, renameSync, existsSync } from 'node:fs';\n     9→import { join } from 'node:path';\n    10→import { ok, fail } from '../../types/result.js';\n    11→import type { Result } from '../../types/result.js';\n    12→import type {\n    13→  AnalyzerResult,\n    14→  ObservabilityCoverageState,\n    15→  CoverageTrend,\n    16→  CoverageTargetResult,\n    17→  RuntimeCoverageState,\n    18→} from './types.js';\n    19→\n    20→const STATE_FILE = 'sprint-state.json';\n    21→const TMP_FILE = '.sprint-state.json.tmp';\n    22→const DEFAULT_STATIC_TARGET = 80;\n    23→const MAX_HISTORY_ENTRIES = 100;\n    24→\n    25→/**\n    26→ * Default observability coverage state when none exists.\n    27→ */\n    28→function defaultCoverageState(): ObservabilityCoverageState {\n    29→  return {\n    30→    static: {\n    31→      coveragePercent: 0,\n    32→      lastScanTimestamp: '',\n    33→      history: [],\n    34→    },\n    35→    targets: {\n    36→      staticTarget: DEFAULT_STATIC_TARGET,\n    37→    },\n    38→  };\n    39→}\n    40→\n    41→/**\n    42→ * Read the full sprint-state.json as a generic record.\n    43→ */\n    44→function readStateFile(projectDir: string): Result<Record<string, unknown>> {\n    45→  const fp = join(projectDir, STATE_FILE);\n    46→  if (!existsSync(fp)) {\n    47→    return ok({});\n    48→  }\n    49→  try {\n    50→    const raw = readFileSync(fp, 'utf-8');\n    51→    const parsed = JSON.parse(raw) as Record<string, unknown>;\n    52→    return ok(parsed);\n    53→  } catch (err: unknown) {\n    54→    const msg = err instanceof Error ? err.message : String(err);\n    55→    return fail(`Failed to read ${STATE_FILE}: ${msg}`);\n    56→  }\n    57→}\n    58→\n    59→/**\n    60→ * Write sprint-state.json atomically (write to temp, then rename).\n    61→ */\n    62→function writeStateAtomic(\n    63→  projectDir: string,\n    64→  state: Record<string, unknown>,\n    65→): Result<void> {\n    66→  try {\n    67→    const data = JSON.stringify(state, null, 2) + '\\n';\n    68→    const tmp = join(projectDir, TMP_FILE);\n    69→    const final = join(projectDir, STATE_FILE);\n    70→    writeFileSync(tmp, data, 'utf-8');\n    71→    renameSync(tmp, final);\n    72→    return ok(undefined);\n    73→  } catch (err: unknown) {\n    74→    const msg = err instanceof Error ? err.message : String(err);\n    75→    return fail(`Failed to write ${STATE_FILE}: ${msg}`);\n    76→  }\n    77→}\n    78→\n    79→/**\n    80→ * Save coverage result from an analysis run into sprint-state.json.\n    81→ *\n    82→ * Updates `observability.static.coveragePercent`, `observability.static.lastScanTimestamp`,\n    83→ * and appends to `observability.static.history`. Preserves all other state fields.\n    84→ */\n    85→export function saveCoverageResult(\n    86→  projectDir: string,\n    87→  result: AnalyzerResult,\n    88→): Result<void> {\n    89→  if (!projectDir || typeof projectDir !== 'string') {\n    90→    return fail('projectDir is required and must be a non-empty string');\n    91→  }\n    92→\n    93→  const stateResult = readStateFile(projectDir);\n    94→  if (!stateResult.success) {\n    95→    return fail(stateResult.error);\n    96→  }\n    97→\n    98→  const state = stateResult.data;\n    99→  const existing = extractCoverageState(state);\n   100→  const timestamp = new Date().toISOString();\n   101→\n   102→  const fullHistory = [\n   103→    ...existing.static.history,\n   104→    { coveragePercent: result.summary.coveragePercent, timestamp },\n   105→  ];\n   106→  // Keep only the most recent entries to prevent unbounded growth\n   107→  const trimmedHistory =\n   108→    fullHistory.length > MAX_HISTORY_ENTRIES\n   109→      ? fullHistory.slice(fullHistory.length - MAX_HISTORY_ENTRIES)\n   110→      : fullHistory;\n   111→\n   112→  const updatedStatic = {\n   113→    coveragePercent: result.summary.coveragePercent,\n   114→    lastScanTimestamp: timestamp,\n   115→    history: trimmedHistory,\n   116→  };\n   117→\n   118→  const updatedObservability: ObservabilityCoverageState = {\n   119→    static: updatedStatic,\n   120→    targets: existing.targets,\n   121→  };\n   122→\n   123→  const updatedState = {\n   124→    ...state,\n   125→    observability: updatedObservability,\n   126→  };\n   127→\n   128→  return writeStateAtomic(projectDir, updatedState);\n   129→}\n   130→\n   131→/**\n   132→ * Read the observability coverage state from sprint-state.json.\n   133→ *\n   134→ * Returns the typed `ObservabilityCoverageState` from the `observability` key.\n   135→ * If no observability section exists, returns default state.\n   136→ */\n   137→export function readCoverageState(\n   138→  projectDir: string,\n   139→): Result<ObservabilityCoverageState> {\n   140→  if (!projectDir || typeof projectDir !== 'string') {\n   141→    return fail('projectDir is required and must be a non-empty string');\n   142→  }\n   143→\n   144→  const stateResult = readStateFile(projectDir);\n   145→  if (!stateResult.success) {\n   146→    return fail(stateResult.error);\n   147→  }\n   148→\n   149→  return ok(extractCoverageState(stateResult.data));\n   150→}\n   151→\n   152→/**\n   153→ * Get coverage trend by comparing latest vs previous history entries.\n   154→ */\n   155→export function getCoverageTrend(projectDir: string): Result<CoverageTrend> {\n   156→  if (!projectDir || typeof projectDir !== 'string') {\n   157→    return fail('projectDir is required and must be a non-empty string');\n   158→  }\n   159→\n   160→  const stateResult = readCoverageState(projectDir);\n   161→  if (!stateResult.success) {\n   162→    return fail(stateResult.error);\n   163→  }\n   164→\n   165→  const { history } = stateResult.data.static;\n   166→\n   167→  if (history.length === 0) {\n   168→    return ok({\n   169→      current: 0,\n   170→      previous: null,\n   171→      delta: null,\n   172→      currentTimestamp: '',\n   173→      previousTimestamp: null,\n   174→    });\n   175→  }\n   176→\n   177→  const latest = history[history.length - 1];\n   178→\n   179→  if (history.length === 1) {\n   180→    return ok({\n   181→      current: latest.coveragePercent,\n   182→      previous: null,\n   183→      delta: null,\n   184→      currentTimestamp: latest.timestamp,\n   185→      previousTimestamp: null,\n   186→    });\n   187→  }\n   188→\n   189→  const prev = history[history.length - 2];\n   190→  return ok({\n   191→    current: latest.coveragePercent,\n   192→    previous: prev.coveragePercent,\n   193→    delta: latest.coveragePercent - prev.coveragePercent,\n   194→    currentTimestamp: latest.timestamp,\n   195→    previousTimestamp: prev.timestamp,\n   196→  });\n   197→}\n   198→\n   199→/**\n   200→ * Check current coverage against a target threshold.\n   201→ *\n   202→ * @param projectDir - Project root directory\n   203→ * @param target - Target percentage (default 80%)\n   204→ * @returns Structured result indicating whether coverage meets the target\n   205→ */\n   206→export function checkCoverageTarget(\n   207→  projectDir: string,\n   208→  target?: number,\n   209→): Result<CoverageTargetResult> {\n   210→  if (!projectDir || typeof projectDir !== 'string') {\n   211→    return fail('projectDir is required and must be a non-empty string');\n   212→  }\n   213→\n   214→  const stateResult = readCoverageState(projectDir);\n   215→  if (!stateResult.success) {\n   216→    return fail(stateResult.error);\n   217→  }\n   218→\n   219→  const effectiveTarget = target ?? stateResult.data.targets.staticTarget;\n   220→  const current = stateResult.data.static.coveragePercent;\n   221→  const met = current >= effectiveTarget;\n   222→  const gap = met ? 0 : effectiveTarget - current;\n   223→\n   224→  return ok({ met, current, target: effectiveTarget, gap });\n   225→}\n   226→\n   227→/**\n   228→ * Extract typed ObservabilityCoverageState from raw sprint-state.json data.\n   229→ * Returns defaults when the observability section doesn't exist.\n   230→ */\n   231→function extractCoverageState(\n   232→  state: Record<string, unknown>,\n   233→): ObservabilityCoverageState {\n   234→  const obs = state.observability as Record<string, unknown> | undefined;\n   235→  if (!obs) {\n   236→    return defaultCoverageState();\n   237→  }\n   238→\n   239→  const staticSection = obs.static as Record<string, unknown> | undefined;\n   240→  const targets = obs.targets as Record<string, unknown> | undefined;\n   241→  const runtimeSection = obs.runtime as Record<string, unknown> | undefined;\n   242→\n   243→  const runtime: RuntimeCoverageState | undefined =\n   244→    runtimeSection && typeof runtimeSection.coveragePercent === 'number'\n   245→      ? {\n   246→          coveragePercent: runtimeSection.coveragePercent,\n   247→          lastValidationTimestamp:\n   248→            typeof runtimeSection.lastValidationTimestamp === 'string'\n   249→              ? runtimeSection.lastValidationTimestamp : '',\n   250→          modulesWithTelemetry:\n   251→            typeof runtimeSection.modulesWithTelemetry === 'number'\n   252→              ? runtimeSection.modulesWithTelemetry : 0,\n   253→          totalModules:\n   254→            typeof runtimeSection.totalModules === 'number'\n   255→              ? runtimeSection.totalModules : 0,\n   256→          telemetryDetected:\n   257→            typeof runtimeSection.telemetryDetected === 'boolean'\n   258→              ? runtimeSection.telemetryDetected : false,\n   259→        }\n   260→      : undefined;\n   261→\n   262→  const result: ObservabilityCoverageState = {\n   263→    static: {\n   264→      coveragePercent:\n   265→        typeof staticSection?.coveragePercent === 'number'\n   266→          ? staticSection.coveragePercent\n   267→          : 0,\n   268→      lastScanTimestamp:\n   269→        typeof staticSection?.lastScanTimestamp === 'string'\n   270→          ? staticSection.lastScanTimestamp\n   271→          : '',\n   272→      history: Array.isArray(staticSection?.history)\n   273→        ? (staticSection.history as unknown[]).filter(\n   274→            (entry): entry is { coveragePercent: number; timestamp: string } =>\n   275→              typeof entry === 'object' &&\n   276→              entry !== null &&\n   277→              typeof (entry as Record<string, unknown>).coveragePercent ===\n   278→                'number' &&\n   279→              typeof (entry as Record<string, unknown>).timestamp === 'string',\n   280→          )\n   281→        : [],\n   282→    },\n   283→    targets: {\n   284→      staticTarget:\n   285→        typeof targets?.staticTarget === 'number'\n   286→          ? targets.staticTarget\n   287→          : DEFAULT_STATIC_TARGET,\n   288→      ...(typeof targets?.runtimeTarget === 'number'\n   289→        ? { runtimeTarget: targets.runtimeTarget }\n   290→        : {}),\n   291→    },\n   292→    ...(runtime ? { runtime } : {}),\n   293→  };\n   294→\n   295→  return result;\n   296→}\n   297→"}]},"parent_tool_use_id":"toolu_01L7x1Zkv5Yv1DsfgSndzqDQ","session_id":"f7a66acd-0cc1-40de-a592-d59e75273c0b","uuid":"541ac1e6-e7c2-4fcb-b064-ff5b96623e8d","timestamp":"2026-03-20T06:00:17.474Z"}
