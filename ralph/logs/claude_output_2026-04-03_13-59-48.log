{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019nVocpABoLHWBVjL1nGZm4","type":"tool_result","content":"50\t  const finalPath = contractFilePath(contract.taskName, contract.storyId, contractDir);\n51\t  const tmpPath = finalPath + '.tmp';\n52\t\n53\t  try {\n54\t    mkdirSync(contractDir, { recursive: true });\n55\t    writeFileSync(tmpPath, JSON.stringify(contract, null, 2) + '\\n', 'utf-8');\n56\t    renameSync(tmpPath, finalPath);\n57\t  } catch (err) {\n58\t    const message = err instanceof Error ? err.message : String(err);\n59\t    throw new Error(`Failed to write output contract to ${finalPath}: ${message}`);\n60\t  }\n61\t}\n62\t\n63\t/**\n64\t * Read an OutputContract from disk.\n65\t *\n66\t * Returns null if the file does not exist.\n67\t */\n68\texport function readOutputContract(\n69\t  taskName: string,\n70\t  storyId: string,\n71\t  contractDir: string,\n72\t): OutputContract | null {\n73\t  const filePath = contractFilePath(taskName, storyId, contractDir);\n74\t\n75\t  if (!existsSync(filePath)) {\n76\t    return null;\n77\t  }\n78\t\n79\t  try {\n80\t    const raw = readFileSync(filePath, 'utf-8');\n81\t    return JSON.parse(raw) as OutputContract;\n82\t  } catch (err) {\n83\t    const message = err instanceof Error ? err.message : String(err);\n84\t    throw new Error(`Failed to read output contract from ${filePath}: ${message}`);\n85\t  }\n86\t}\n87\t"}]},"parent_tool_use_id":null,"session_id":"be33ba5d-0e81-49c4-ae53-e69ac56cd1fb","uuid":"4d30ab48-db18-4f41-b810-ff0e2c16081f","timestamp":"2026-04-03T10:17:30.580Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ivintik/dev/personal/codeharness/src/lib/agents/output-contract.ts","content":"  const finalPath = contractFilePath(contract.taskName, contract.storyId, contractDir);\n  const tmpPath = finalPath + '.tmp';\n\n  try {\n    mkdirSync(contractDir, { recursive: true });\n    writeFileSync(tmpPath, JSON.stringify(contract, null, 2) + '\\n', 'utf-8');\n    renameSync(tmpPath, finalPath);\n  } catch (err) {\n    const message = err instanceof Error ? err.message : String(err);\n    throw new Error(`Failed to write output contract to ${finalPath}: ${message}`);\n  }\n}\n\n/**\n * Read an OutputContract from disk.\n *\n * Returns null if the file does not exist.\n */\nexport function readOutputContract(\n  taskName: string,\n  storyId: string,\n  contractDir: string,\n): OutputContract | null {\n  const filePath = contractFilePath(taskName, storyId, contractDir);\n\n  if (!existsSync(filePath)) {\n    return null;\n  }\n\n  try {\n    const raw = readFileSync(filePath, 'utf-8');\n    return JSON.parse(raw) as OutputContract;\n  } catch (err) {\n    const message = err instanceof Error ? err.message : String(err);\n    throw new Error(`Failed to read output contract from ${filePath}: ${message}`);\n  }\n}\n","numLines":38,"startLine":50,"totalLines":87}}}
