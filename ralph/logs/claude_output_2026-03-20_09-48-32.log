{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EbzAzbjPmA4itueDNFvo6t","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# Test helper for codeharness bats tests\n     3→# Sets up isolated test environment per test\n     4→\n     5→# Portable in-place sed (macOS uses -i '', Linux uses -i)\n     6→sed_i() {\n     7→    if sed --version 2>/dev/null | grep -q GNU; then\n     8→        sed -i \"$@\"\n     9→    else\n    10→        sed -i '' \"$@\"\n    11→    fi\n    12→}\n    13→\n    14→PROJECT_ROOT=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/..\" && pwd)\"\n    15→RALPH_DIR=\"$PROJECT_ROOT/ralph\"\n    16→\n    17→# Create a temporary directory for each test\n    18→setup_test_dir() {\n    19→    TEST_DIR=\"$(mktemp -d)\"\n    20→    export TEST_DIR\n    21→    cd \"$TEST_DIR\"\n    22→\n    23→    # Initialize a git repo for tests that need it\n    24→    git init -q\n    25→    git config user.email \"test@test.com\"\n    26→    git config user.name \"Test\"\n    27→    echo \"init\" > init.txt\n    28→    git add -A && git commit -q -m \"init\"\n    29→}\n    30→\n    31→teardown_test_dir() {\n    32→    if [[ -n \"$TEST_DIR\" && -d \"$TEST_DIR\" ]]; then\n    33→        rm -rf \"$TEST_DIR\"\n    34→    fi\n    35→}\n    36→\n    37→# Create a minimal progress.json for testing\n    38→create_test_progress() {\n    39→    local file=\"${1:-$TEST_DIR/ralph/progress.json}\"\n    40→    mkdir -p \"$(dirname \"$file\")\"\n    41→    cat > \"$file\" << 'EOF'\n    42→{\n    43→    \"tasks\": [\n    44→        {\"id\": \"US-001\", \"title\": \"First story\", \"status\": \"pending\"},\n    45→        {\"id\": \"US-002\", \"title\": \"Second story\", \"status\": \"pending\"}\n    46→    ]\n    47→}\n    48→EOF\n    49→}\n    50→\n    51→# Create a minimal prompt file for testing\n    52→create_test_prompt() {\n    53→    local file=\"${1:-$TEST_DIR/.ralph/PROMPT.md}\"\n    54→    mkdir -p \"$(dirname \"$file\")\"\n    55→    cat > \"$file\" << 'EOF'\n    56→# Test Prompt\n    57→Implement the next incomplete story.\n    58→EOF\n    59→}\n    60→\n    61→# Create .claude directory with state file\n    62→create_test_state() {\n    63→    mkdir -p \"$TEST_DIR/.claude\"\n    64→    cat > \"$TEST_DIR/.claude/codeharness.local.md\" << 'EOF'\n    65→---\n    66→harness_version: \"0.1.0\"\n    67→initialized: true\n    68→---\n    69→EOF\n    70→}\n    71→"}]},"parent_tool_use_id":"toolu_01APL3Sm5JEakF5iK2mjDEd8","session_id":"f7a66acd-0cc1-40de-a592-d59e75273c0b","uuid":"394a3535-ac61-4a32-8dde-e7f0621476ea","timestamp":"2026-03-20T05:53:53.727Z"}
