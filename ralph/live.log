{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BCzxeg1faEQbfTNPey9Dit","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';\n     2→import {\n     3→  readFileSync,\n     4→  writeFileSync,\n     5→  unlinkSync,\n     6→  existsSync,\n     7→  chmodSync,\n     8→  mkdtempSync,\n     9→  rmSync,\n    10→} from 'node:fs';\n    11→import { join } from 'node:path';\n    12→import { tmpdir } from 'node:os';\n    13→import type { SprintState } from '../../../types/state.js';\n    14→\n    15→// Mock migration so state tests are isolated from real project files\n    16→vi.mock('../migration.js', () => ({\n    17→  migrateFromOldFormat: vi.fn(() => ({\n    18→    success: false,\n    19→    error: 'No old format files found for migration',\n    20→  })),\n    21→  migrateV1ToV2: vi.fn((v1: Record<string, unknown>) => ({\n    22→    ...v1,\n    23→    version: 2,\n    24→    retries: {},\n    25→    flagged: [],\n    26→    epics: {},\n    27→    session: { active: false, startedAt: null, iteration: 0, elapsedSeconds: 0 },\n    28→    observability: { statementCoverage: null, branchCoverage: null, functionCoverage: null, lineCoverage: null },\n    29→  })),\n    30→}));\n    31→\n    32→// Import after mock setup\n    33→const { getSprintState, updateStoryStatus, writeStateAtomic, defaultState, statePath } =\n    34→  await import('../state.js');\n    35→\n    36→// Use tmpdir isolation to prevent writeStateAtomic from corrupting real sprint-status.yaml\n    37→let testDir: string;\n    38→let originalCwd: string;\n    39→\n    40→function stateFile(): string {\n    41→  return join(process.cwd(), 'sprint-state.json');\n    42→}\n    43→\n    44→function tmpFile(): string {\n    45→  return join(process.cwd(), '.sprint-state.json.tmp');\n    46→}\n    47→\n    48→// Global setup/teardown for all describe blocks that touch the filesystem\n    49→beforeEach(() => {\n    50→  testDir = mkdtempSync(join(tmpdir(), 'ch-state-'));\n    51→  originalCwd = process.cwd();\n    52→  process.chdir(testDir);\n    53→});\n    54→\n    55→afterEach(() => {\n    56→  process.chdir(originalCwd);\n    57→  rmSync(testDir, { recursive: true, force: true });\n    58→});\n    59→\n    60→describe('defaultState', () => {\n    61→  it('returns version 2 with empty stories and v2 fields', () => {\n    62→    const state = defaultState();\n    63→    expect(state.version).toBe(2);\n    64→    expect(state.stories).toEqual({});\n    65→    expect(state.run.active).toBe(false);\n    66→    expect(state.run.iteration).toBe(0);\n    67→    expect(state.sprint.total).toBe(0);\n    68→    expect(state.actionItems).toEqual([]);\n    69→  });\n    70→});\n    71→\n    72→describe('statePath', () => {\n    73→  it('returns path ending in sprint-state.json', () => {\n    74→    expect(statePath()).toBe(stateFile());\n    75→  });\n    76→});\n    77→\n    78→describe('writeStateAtomic', () => {\n    79→  it('writes valid JSON to sprint-state.json', () => {\n    80→    const state = defaultState();\n    81→    const result = writeStateAtomic(state);\n    82→    expect(result.success).toBe(true);\n    83→    expect(existsSync(stateFile())).toBe(true);\n    84→\n    85→    const raw = readFileSync(stateFile(), 'utf-8');\n    86→    const parsed = JSON.parse(raw);\n    87→    expect(parsed.version).toBe(2);\n    88→  });\n    89→\n    90→  it('tmp file does not remain after successful write', () => {\n    91→    const result = writeStateAtomic(defaultState());\n    92→    expect(result.success).toBe(true);\n    93→    expect(existsSync(tmpFile())).toBe(false);\n    94→  });\n    95→});\n    96→\n    97→describe('getSprintState', () => {\n    98→  it('returns default state when no file exists', () => {\n    99→    const result = getSprintState();\n   100→    expect(result.success).toBe(true);\n   101→    if (result.success) {\n   102→      expect(result.data.version).toBe(2);\n   103→      expect(result.data.stories).toEqual({});\n   104→      expect(result.data.run.active).toBe(false);\n   105→      expect(result.data.sprint.inProgress).toBeNull();\n   106→      expect(result.data.actionItems).toEqual([]);\n   107→      expect(result.data.retries).toEqual({});\n   108→      expect(result.data.flagged).toEqual([]);\n   109→      expect(result.data.epics).toEqual({});\n   110→      expect(result.data.session.active).toBe(false);\n   111→      expect(result.data.observability.statementCoverage).toBeNull();\n   112→    }\n   113→  });\n   114→\n   115→  it('reads and parses existing sprint-state.json', () => {\n   116→    const state: SprintState = {\n   117→      ...defaultState(),\n   118→      stories: {\n   119→        'test-story': {\n   120→          status: 'done',\n   121→          attempts: 2,\n   122→          lastAttempt: '2026-01-01T00:00:00Z',\n   123→          lastError: null,\n   124→          proofPath: null,\n   125→          acResults: null,\n   126→        },\n   127→      },\n   128→    };\n   129→    writeFileSync(stateFile(), JSON.stringify(state, null, 2), 'utf-8');\n   130→\n   131→    const result = getSprintState();\n   132→    expect(result.success).toBe(true);\n   133→    if (result.success) {\n   134→      expect(result.data.stories['test-story'].status).toBe('done');\n   135→      expect(result.data.stories['test-story'].attempts).toBe(2);\n   136→    }\n   137→  });\n   138→\n   139→  it('returns fail on invalid JSON', () => {\n   140→    writeFileSync(stateFile(), '{not valid json', 'utf-8');\n   141→    const result = getSprintState();\n   142→    expect(result.success).toBe(false);\n   143→    if (!result.success) {\n   144→      expect(result.error).toContain('Failed to read sprint state');\n   145→    }\n   146→  });\n   147→\n   148→  it('parse time is under 100ms for 50 stories', () => {\n   149→    const stories: Record<string, SprintState['stories'][string]> = {};\n   150→    for (let i = 0; i < 50; i++) {\n   151→      stories[`story-${i}`] = {\n   152→        status: 'backlog',\n   153→        attempts: i,\n   154→        lastAttempt: new Date().toISOString(),\n   155→        lastError: `error ${i}`,\n   156→        proofPath: null,\n   157→        acResults: [\n   158→          { id: `ac-${i}-1`, verdict: 'pass' },\n   159→          { id: `ac-${i}-2`, verdict: 'fail' },\n   160→        ],\n   161→      };\n   162→    }\n   163→    const state: SprintState = { ...defaultState(), stories };\n   164→    writeFileSync(stateFile(), JSON.stringify(state, null, 2), 'utf-8');\n   165→\n   166→    const start = performance.now();\n   167→    const result = getSprintState();\n   168→    const elapsed = performance.now() - start;\n   169→\n   170→    expect(result.success).toBe(true);\n   171→    expect(elapsed).toBeLessThan(100);\n   172→  });\n   173→\n   174→  it('never throws — returns fail on fs error', () => {\n   175→    writeFileSync(stateFile(), '{}', 'utf-8');\n   176→    chmodSync(stateFile(), 0o000);\n   177→\n   178→    const result = getSprintState();\n   179→    expect(result).toBeDefined();\n   180→    expect(typeof result.success).toBe('boolean');\n   181→  });\n   182→});\n   183→\n   184→describe('updateStoryStatus', () => {\n   185→  it('creates file if missing and updates story', () => {\n   186→    const result = updateStoryStatus('story-1', 'in-progress');\n   187→    expect(result.success).toBe(true);\n   188→    expect(existsSync(stateFile())).toBe(true);\n   189→\n   190→    const state = JSON.parse(readFileSync(stateFile(), 'utf-8')) as SprintState;\n   191→    expect(state.stories['story-1'].status).toBe('in-progress');\n   192→    expect(state.stories['story-1'].attempts).toBe(1);\n   193→    expect(state.sprint.inProgress).toBe('story-1');\n   194→  });\n   195→\n   196→  it('updates existing story preserving other stories', () => {\n   197→    updateStoryStatus('story-1', 'in-progress');\n   198→    updateStoryStatus('story-2', 'done');\n   199→\n   200→    const state = JSON.parse(readFileSync(stateFile(), 'utf-8')) as SprintState;\n   201→    expect(state.stories['story-1']).toBeDefined();\n   202→    expect(state.stories['story-2'].status).toBe('done');\n   203→    expect(state.sprint.done).toBe(1);\n   204→    expect(state.sprint.total).toBe(2);\n   205→  });\n   206→\n   207→  it('attaches error detail when provided', () => {\n   208→    updateStoryStatus('story-1', 'failed', { error: 'build broke' });\n   209→\n   210→    const state = JSON.parse(readFileSync(stateFile(), 'utf-8')) as SprintState;\n   211→    expect(state.stories['story-1'].lastError).toBe('build broke');\n   212→    expect(state.stories['story-1'].status).toBe('failed');\n   213→    expect(state.sprint.failed).toBe(1);\n   214→  });\n   215→\n   216→  it('attaches proofPath when provided', () => {\n   217→    updateStoryStatus('story-1', 'done', {\n   218→      proofPath: 'docs/proof.md',\n   219→    });\n   220→\n   221→    const state = JSON.parse(readFileSync(stateFile(), 'utf-8')) as SprintState;\n   222→    expect(state.stories['story-1'].proofPath).toBe('docs/proof.md');\n   223→  });\n   224→\n   225→  it('increments attempts only on in-progress transition', () => {\n   226→    updateStoryStatus('story-1', 'in-progress');\n   227→    updateStoryStatus('story-1', 'failed', { error: 'oops' });\n   228→    updateStoryStatus('story-1', 'in-progress');\n   229→\n   230→    const state = JSON.parse(readFileSync(stateFile(), 'utf-8')) as SprintState;\n   231→    expect(state.stories['story-1'].attempts).toBe(2);\n   232→  });\n   233→\n   234→  it('uses atomic write (tmp then rename)', () => {\n   235→    updateStoryStatus('story-1', 'done');\n   236→    expect(existsSync(tmpFile())).toBe(false);\n   237→    expect(existsSync(stateFile())).toBe(true);\n   238→  });\n   239→\n   240→  it('round-trips state correctly (write then read)', () => {\n   241→    updateStoryStatus('roundtrip', 'verifying');\n   242→\n   243→    const result = getSprintState();\n   244→    expect(result.success).toBe(true);\n   245→    if (result.success) {\n   246→      expect(result.data.stories['roundtrip'].status).toBe('verifying');\n   247→    }\n   248→  });\n   249→});\n   250→\n   251→describe('lastAttempt semantics and error paths', () => {\n   252→  it('sets lastAttempt only on in-progress transitions', () => {\n   253→    updateStoryStatus('story-1', 'in-progress');\n   254→    const state1 = JSON.parse(readFileSync(stateFile(), 'utf-8')) as SprintState;\n   255→    const firstAttemptTime = state1.stories['story-1'].lastAttempt;\n   256→    expect(firstAttemptTime).not.toBeNull();\n   257→    updateStoryStatus('story-1', 'done');\n   258→    const state2 = JSON.parse(readFileSync(stateFile(), 'utf-8')) as SprintState;\n   259→    expect(state2.stories['story-1'].lastAttempt).toBe(firstAttemptTime);\n   260→  });\n   261→\n   262→  it('writeStateAtomic returns fail on serialization error', () => {\n   263→    const poison = {\n   264→      ...defaultState(),\n   265→      toJSON() { throw new Error('Serialization error'); },\n   266→    } as unknown as SprintState;\n   267→    const result = writeStateAtomic(poison);\n   268→    expect(result.success).toBe(false);\n   269→    if (!result.success) {\n   270→      expect(result.error).toContain('Failed to write sprint state');\n   271→    }\n   272→  });\n   273→\n   274→  it('computeSprintCounts counts all status types', async () => {\n   275→    const { computeSprintCounts } = await import('../state.js');\n   276→    const mk = (s: string) => ({ status: s as 'done', attempts: 0, lastAttempt: null, lastError: null, proofPath: null, acResults: null });\n   277→    const counts = computeSprintCounts({ a: mk('done'), b: mk('failed'), c: mk('blocked'), d: mk('in-progress'), e: mk('backlog') });\n   278→    expect(counts).toEqual({ total: 5, done: 1, failed: 1, blocked: 1, inProgress: 'd' });\n   279→  });\n   280→});\n   281→\n   282→describe('concurrent writes', () => {\n   283→  it('both writes produce valid JSON', () => {\n   284→    updateStoryStatus('concurrent-1', 'in-progress');\n   285→    updateStoryStatus('concurrent-2', 'done');\n   286→\n   287→    const raw = readFileSync(stateFile(), 'utf-8');\n   288→    expect(() => JSON.parse(raw)).not.toThrow();\n   289→\n   290→    const state = JSON.parse(raw) as SprintState;\n   291→    expect(state.stories['concurrent-1']).toBeDefined();\n   292→    expect(state.stories['concurrent-2']).toBeDefined();\n   293→    expect(state.stories['concurrent-2'].status).toBe('done');\n   294→  });\n   295→});\n   296→"}]},"parent_tool_use_id":"toolu_01J8obBNAKVKfqgNEf6KsEED","session_id":"01503c00-15e6-46f1-b837-b4628ff69656","uuid":"e182c3b9-6c45-4bd5-b1d7-9bfc6dccbafb","timestamp":"2026-03-24T11:35:56.213Z"}
