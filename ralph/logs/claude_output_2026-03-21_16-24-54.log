{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HR2CxuAKP8hA35aHJGE1Jx","type":"tool_result","content":"     1→import { execFileSync } from 'node:child_process';\n     2→import { ok, fail as failOutput, info } from './output.js';\n     3→\n     4→export interface InstallCommand {\n     5→  cmd: string;\n     6→  args: string[];\n     7→}\n     8→\n     9→export interface DependencySpec {\n    10→  name: string;\n    11→  displayName: string;\n    12→  installCommands: InstallCommand[];\n    13→  checkCommand: InstallCommand;\n    14→  critical: boolean;\n    15→}\n    16→\n    17→export interface DependencyResult {\n    18→  name: string;\n    19→  displayName: string;\n    20→  status: 'installed' | 'already-installed' | 'skipped' | 'failed';\n    21→  version: string | null;\n    22→  error?: string;\n    23→}\n    24→\n    25→export const DEPENDENCY_REGISTRY: readonly DependencySpec[] = [\n    26→  {\n    27→    name: 'showboat',\n    28→    displayName: 'Showboat',\n    29→    installCommands: [\n    30→      { cmd: 'pip', args: ['install', 'showboat'] },\n    31→      { cmd: 'pipx', args: ['install', 'showboat'] },\n    32→    ],\n    33→    checkCommand: { cmd: 'showboat', args: ['--version'] },\n    34→    critical: false,\n    35→  },\n    36→  {\n    37→    name: 'agent-browser',\n    38→    displayName: 'agent-browser',\n    39→    installCommands: [\n    40→      { cmd: 'npm', args: ['install', '-g', '@anthropic/agent-browser'] },\n    41→    ],\n    42→    checkCommand: { cmd: 'agent-browser', args: ['--version'] },\n    43→    critical: false,\n    44→  },\n    45→  {\n    46→    name: 'beads',\n    47→    displayName: 'beads',\n    48→    installCommands: [\n    49→      { cmd: 'pip', args: ['install', 'beads'] },\n    50→      { cmd: 'pipx', args: ['install', 'beads'] },\n    51→    ],\n    52→    checkCommand: { cmd: 'bd', args: ['--version'] },\n    53→    critical: false,\n    54→  },\n    55→  {\n    56→    name: 'semgrep',\n    57→    displayName: 'Semgrep',\n    58→    installCommands: [\n    59→      { cmd: 'pipx', args: ['install', 'semgrep'] },\n    60→      { cmd: 'pip', args: ['install', 'semgrep'] },\n    61→    ],\n    62→    checkCommand: { cmd: 'semgrep', args: ['--version'] },\n    63→    critical: false,\n    64→  },\n    65→  {\n    66→    name: 'bats',\n    67→    displayName: 'BATS',\n    68→    installCommands: [\n    69→      { cmd: 'brew', args: ['install', 'bats-core'] },\n    70→      { cmd: 'npm', args: ['install', '-g', 'bats'] },\n    71→    ],\n    72→    checkCommand: { cmd: 'bats', args: ['--version'] },\n    73→    critical: false,\n    74→  },\n    75→];\n    76→\n    77→export function checkInstalled(spec: DependencySpec): { installed: boolean; version: string | null } {\n    78→  try {\n    79→    const output = execFileSync(spec.checkCommand.cmd, spec.checkCommand.args, { stdio: 'pipe', timeout: 15_000 }).toString().trim();\n    80→    const version = parseVersion(output);\n    81→    return { installed: true, version };\n    82→  } catch {\n    83→    return { installed: false, version: null };\n    84→  }\n    85→}\n    86→\n    87→export function parseVersion(output: string): string | null {\n    88→  const match = /(\\d+\\.\\d+[\\w.-]*)/.exec(output);\n    89→  return match ? match[1] : null;\n    90→}\n    91→\n    92→export function installDependency(spec: DependencySpec): DependencyResult {\n    93→  // Check if already installed\n    94→  const check = checkInstalled(spec);\n    95→  if (check.installed) {\n    96→    return {\n    97→      name: spec.name,\n    98→      displayName: spec.displayName,\n    99→      status: 'already-installed',\n   100→      version: check.version,\n   101→    };\n   102→  }\n   103→\n   104→  // Try each install command in the fallback chain\n   105→  for (const installCmd of spec.installCommands) {\n   106→    try {\n   107→      execFileSync(installCmd.cmd, installCmd.args, { stdio: 'pipe', timeout: 300_000 });\n   108→\n   109→      // Verify installation succeeded by checking version\n   110→      const postCheck = checkInstalled(spec);\n   111→      if (postCheck.installed) {\n   112→        return {\n   113→          name: spec.name,\n   114→          displayName: spec.displayName,\n   115→          status: 'installed',\n   116→          version: postCheck.version,\n   117→        };\n   118→      }\n   119→    } catch {\n   120→      // Try next fallback\n   121→      continue;\n   122→    }\n   123→  }\n   124→\n   125→  // All install commands failed\n   126→  const remedy = spec.installCommands.map(c => [c.cmd, ...c.args].join(' ')).join(' or ');\n   127→  return {\n   128→    name: spec.name,\n   129→    displayName: spec.displayName,\n   130→    status: 'failed',\n   131→    version: null,\n   132→    error: `Install failed. Try: ${remedy}`,\n   133→  };\n   134→}\n   135→\n   136→export function installAllDependencies(opts: { json?: boolean }): DependencyResult[] {\n   137→  const results: DependencyResult[] = [];\n   138→\n   139→  for (const spec of DEPENDENCY_REGISTRY) {\n   140→    const result = installDependency(spec);\n   141→    results.push(result);\n   142→\n   143→    if (!opts.json) {\n   144→      if (result.status === 'installed') {\n   145→        const versionStr = result.version ? ` (v${result.version})` : '';\n   146→        ok(`${spec.displayName}: installed${versionStr}`);\n   147→      } else if (result.status === 'already-installed') {\n   148→        const versionStr = result.version ? ` (v${result.version})` : '';\n   149→        ok(`${spec.displayName}: already installed${versionStr}`);\n   150→      } else if (result.status === 'failed') {\n   151→        failOutput(`${spec.displayName}: install failed. ${result.error ?? ''}`);\n   152→        if (!spec.critical) {\n   153→          info(`${spec.displayName} is optional — continuing without it`);\n   154→        }\n   155→      }\n   156→    }\n   157→\n   158→    if (result.status === 'failed' && spec.critical) {\n   159→      throw new CriticalDependencyError(spec.displayName, result.error ?? 'Install failed');\n   160→    }\n   161→  }\n   162→\n   163→  return results;\n   164→}\n   165→\n   166→export class CriticalDependencyError extends Error {\n   167→  constructor(\n   168→    public readonly dependencyName: string,\n   169→    public readonly reason: string,\n   170→  ) {\n   171→    super(`Critical dependency '${dependencyName}' failed to install: ${reason}`);\n   172→    this.name = 'CriticalDependencyError';\n   173→  }\n   174→}\n   175→"}]},"parent_tool_use_id":"toolu_01ByFBLT9ziGxFmVXofYDDPj","session_id":"d92c7bcb-37ff-4aa2-841f-ece7fabef071","uuid":"7160cdc8-0f02-47da-84a6-a5d2be1ad35e","timestamp":"2026-03-21T12:45:04.610Z"}
