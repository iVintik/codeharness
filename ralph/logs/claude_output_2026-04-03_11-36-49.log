ter((s) => typeof s === 'string').join(' -> '),\n711\t  };\n712\t  writeWorkflowState(state, projectDir);\n713\t\n714\t  // 2. Load work items\n715\t  const workItems = loadWorkItems(config.sprintStatusPath, config.issuesPath);\n716\t\n717\t  // 3. Iterate through flow steps\n718\t  let halted = false;\n719\t  for (const step of config.workflow.flow) {\n720\t    if (halted) break;\n721\t\n722\t    // Execute loop blocks\n723\t    if (isLoopBlock(step)) {\n724\t      const loopResult = await executeLoopBlock(step, state, config, workItems);\n725\t      state = loopResult.state;\n726\t      errors.push(...loopResult.errors);\n727\t      tasksCompleted += loopResult.tasksCompleted;\n728\t\n729\t      // Track processed stories from loop\n730\t      for (const item of workItems) {\n731\t        processedStories.add(item.key);\n732\t      }\n733\t\n734\t      if (loopResult.halted) {\n735\t        halted = true;\n736\t      }\n737\t\n738\t      // If loop ended with max-iterations or circuit-breaker, treat as failure\n739\t      if (state.phase === 'max-iterations' || state.phase === 'circuit-breaker') {\n740\t        halted = true;\n741\t      }\n742\t      continue;\n743\t    }\n744\t\n745\t    // step is a string task name\n746\t    const taskName = step;\n747\t    const task = config.workflow.tasks[taskName];\n748\t\n749\t    if (!task) {\n750\t      warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n751\t      continue;\n752\t    }\n753\t\n754\t    // Look up the agent definition\n755\t    const definition = config.agents[task.agent];\n756\t    if (!definition) {\n757\t      warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n758\t      continue;\n759\t    }\n760\t\n761\t    if (task.scope === 'per-run') {\n762\t      // Skip if already completed (crash recovery — AC #3)\n763\t      if (isTaskCompleted(state, taskName, PER_RUN_SENTINEL)) {\n764\t        warn(`workflow-engine: skipping completed task ${taskName} for ${PER_RUN_SENTINEL}`);\n765\t        continue;\n766\t      }\n767\t\n768\t      // Per-run: dispatch once with sentinel key\n769\t      try {\n770\t        state = await dispatchTask(task, taskName, PER_RUN_SENTINEL, definition, state, config);\n771\t        tasksCompleted++;\n772\t      } catch (err: unknown) {\n773\t        const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n774\t        errors.push(engineError);\n775\t\n776\t        // Record error checkpoint in state (AC #13)\n777\t        state = recordErrorInState(state, taskName, PER_RUN_SENTINEL, engineError);\n778\t        writeWorkflowState(state, projectDir);\n779\t\n780\t        // Halt on critical errors\n781\t        if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n782\t          halted = true;\n783\t        }\n784\t      }\n785\t    } else {\n786\t      // Per-story: dispatch once per work item\n787\t      for (const item of workItems) {\n788\t        processedStories.add(item.key);\n789\t\n790\t        // Skip if already completed (crash recovery — AC #1, #2, #7)\n791\t        if (isTaskCompleted(state, taskName, item.key)) {\n792\t          warn(`workflow-engine: skipping completed task ${taskName} for ${item.key}`);\n793\t          continue;\n794\t        }\n795\t\n796\t        try {\n797\t          state = await dispatchTask(task, taskName, item.key, definition, state, config);\n798\t          tasksCompleted++;\n799\t        } catch (err: unknown) {\n800\t          const engineError = handleDispatchError(err, taskName, item.key);\n801\t          errors.push(engineError);\n802\t\n803\t          // Record error checkpoint in state (AC #13)\n804\t          state = recordErrorInState(state, taskName, item.key, engineError);\n805\t          writeWorkflowState(state, projectDir);\n806\t\n807\t          // Halt on critical errors, continue on UNKNOWN\n808\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n809\t            halted = true;\n810\t            break;\n811\t          }\n812\t          // UNKNOWN errors: record and continue to next story\n813\t          continue;\n814\t        }\n815\t      }\n816\t    }\n817\t  }\n818\t\n819\t  // 4. Set final phase if no errors and phase not already set by loop termination\n820\t  if (errors.length === 0 && state.phase !== 'max-iterations' && state.phase !== 'circuit-breaker') {\n821\t    state = { ...state, phase: 'completed' };\n822\t    writeWorkflowState(state, projectDir);\n823\t  }\n824\t\n825\t  // 5. Return result\n826\t  const loopTerminated = state.phase === 'max-iterations' || state.phase === 'circuit-breaker';\n827\t  return {\n828\t    success: errors.length === 0 && !loopTerminated,\n829\t    tasksCompleted,\n830\t    storiesProcessed: processedStories.size,\n831\t    errors,\n832\t    durationMs: Date.now() - startMs,\n833\t  };\n834\t}\n835\t\n836\t// --- Error Handling ---\n837\t\n838\t/**\n839\t * Record a dispatch error in workflow state: set phase to \"error\" and append\n840\t * a TaskCheckpoint with the error details (AC #13).\n841\t */\n842\tfunction recordErrorInState(\n843\t  state: WorkflowState,\n844\t  taskName: string,\n845\t  storyKey: string,\n846\t  error: EngineError,\n847\t): WorkflowState {\n848\t  const errorCheckpoint: TaskCheckpoint = {\n849\t    task_name: taskName,\n850\t    story_key: storyKey,\n851\t    completed_at: new Date().toISOString(),\n852\t    error: true,\n853\t  };\n854\t  return {\n855\t    ...state,\n856\t    phase: 'error',\n857\t    tasks_completed: [...state.tasks_completed, errorCheckpoint],\n858\t  };\n859\t}\n860\t\n861\tfunction handleDispatchError(err: unknown, taskName: string, storyKey: string): EngineError {\n862\t  if (err instanceof DispatchError) {\n863\t    return {\n864\t      taskName,\n865\t      storyKey,\n866\t      code: err.code,\n867\t      message: err.message,\n868\t    };\n869\t  }\n870\t\n871\t  const message = err instanceof Error ? err.message : String(err);\n872\t  return {\n873\t    taskName,\n874\t    storyKey,\n875\t    code: 'UNKNOWN',\n876\t    message,\n877\t  };\n878\t}\n879\t"}]},"parent_tool_use_id":"toolu_01JHBd2h21hZJ3ormyytEjgf","session_id":"f83470b7-c271-483e-ae93-7fe9bce4b683","uuid":"61596b85-446c-4f7b-906a-c7e703e3afc3","timestamp":"2026-04-03T07:42:12.845Z"}
