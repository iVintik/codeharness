{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DBoKqqDoCJZhytNukNg7d4","type":"tool_result","content":"     1→import { Command } from 'commander';\n     2→import { join } from 'node:path';\n     3→import { ok, fail, info, warn, jsonOutput } from '../lib/output.js';\n     4→import {\n     5→  scanCodebase,\n     6→  analyzeCoverageGaps,\n     7→  auditDocumentation,\n     8→} from '../lib/scanner.js';\n     9→import type {\n    10→  ScanResult,\n    11→  CoverageGapReport,\n    12→  DocAuditResult,\n    13→} from '../lib/scanner.js';\n    14→import {\n    15→  generateOnboardingEpic,\n    16→  writeOnboardingEpic,\n    17→  formatEpicSummary,\n    18→  promptApproval,\n    19→  importOnboardingEpic,\n    20→} from '../lib/epic-generator.js';\n    21→import type { OnboardingEpic } from '../lib/epic-generator.js';\n    22→import { listIssues, createIssue } from '../lib/beads.js';\n    23→import {\n    24→  runPreconditions,\n    25→  filterTrackedGaps,\n    26→  findVerificationGaps,\n    27→  findPerFileCoverageGaps,\n    28→  findObservabilityGaps,\n    29→  getOnboardingProgress,\n    30→} from '../lib/onboard-checks.js';\n    31→import { saveScanCache, loadValidCache } from '../lib/scan-cache.js';\n    32→import { appendOnboardingEpicToSprint } from '../lib/beads-sync.js';\n    33→\n    34→// ─── Shared state for passing results between phases ─────────────────────────\n    35→\n    36→let lastScanResult: ScanResult | null = null;\n    37→let lastCoverageResult: CoverageGapReport | null = null;\n    38→let lastAuditResult: DocAuditResult | null = null;\n    39→\n    40→export function getLastScanResult(): ScanResult | null {\n    41→  return lastScanResult;\n    42→}\n    43→\n    44→export function getLastCoverageResult(): CoverageGapReport | null {\n    45→  return lastCoverageResult;\n    46→}\n    47→\n    48→export function getLastAuditResult(): DocAuditResult | null {\n    49→  return lastAuditResult;\n    50→}\n    51→\n    52→export function resetLastScanResult(): void {\n    53→  lastScanResult = null;\n    54→  lastCoverageResult = null;\n    55→  lastAuditResult = null;\n    56→}\n    57→\n    58→// ─── Command Registration ────────────────────────────────────────────────────\n    59→\n    60→export function registerOnboardCommand(program: Command): void {\n    61→  const onboard = program\n    62→    .command('onboard')\n    63→    .description('Onboard an existing codebase into the harness')\n    64→    .option('--min-module-size <n>', 'Minimum files to count as a module', '3')\n    65→    .option('--full', 'Show all gaps regardless of existing beads issues')\n    66→    .option('--force-scan', 'Ignore cached scan and perform a fresh scan');\n    67→\n    68→  // Subcommand: scan\n    69→  onboard\n    70→    .command('scan')\n    71→    .description('Scan codebase for modules and artifacts')\n    72→    .action((_, cmd) => {\n    73→      const opts = cmd.optsWithGlobals();\n    74→      const isJson = opts.json === true;\n    75→      const minModuleSize = parseInt(opts.minModuleSize ?? '3', 10);\n    76→\n    77→      const preconditions = runPreconditions();\n    78→      if (!preconditions.canProceed) {\n    79→        if (isJson) {\n    80→          jsonOutput({ status: 'fail', message: 'Harness not initialized \\u2014 run codeharness init first' });\n    81→        } else {\n    82→          fail('Harness not initialized \\u2014 run codeharness init first');\n    83→        }\n    84→        process.exitCode = 1;\n    85→        return;\n    86→      }\n    87→      if (!isJson) {\n    88→        for (const w of preconditions.warnings) {\n    89→          warn(w);\n    90→        }\n    91→      }\n    92→\n    93→      const result = runScan(minModuleSize);\n    94→\n    95→      // Save scan to cache (coverage and audit not yet run)\n    96→      saveScanCache({\n    97→        timestamp: new Date().toISOString(),\n    98→        scan: result,\n    99→        coverage: null,\n   100→        audit: null,\n   101→      });\n   102→\n   103→      if (isJson) {\n   104→        jsonOutput({ preconditions: { initialized: preconditions.initialized, bmad: preconditions.bmad, hooks: preconditions.hooks }, scan: result });\n   105→      } else {\n   106→        printScanOutput(result);\n   107→      }\n   108→    });\n   109→\n   110→  // Subcommand: coverage\n   111→  onboard\n   112→    .command('coverage')\n   113→    .description('Analyze per-module coverage gaps')\n   114→    .action((_, cmd) => {\n   115→      const opts = cmd.optsWithGlobals();\n   116→      const isJson = opts.json === true;\n   117→      const forceScan = opts.forceScan === true;\n   118→      const minModuleSize = parseInt(opts.minModuleSize ?? '3', 10);\n   119→\n   120→      const preconditions = runPreconditions();\n   121→      if (!preconditions.canProceed) {\n   122→        if (isJson) {\n   123→          jsonOutput({ status: 'fail', message: 'Harness not initialized \\u2014 run codeharness init first' });\n   124→        } else {\n   125→          fail('Harness not initialized \\u2014 run codeharness init first');\n   126→        }\n   127→        process.exitCode = 1;\n   128→        return;\n   129→      }\n   130→      for (const w of preconditions.warnings) {\n   131→        warn(w);\n   132→      }\n   133→\n   134→      // Try cached scan first\n   135→      let scan: ScanResult;\n   136→      if (lastScanResult) {\n   137→        scan = lastScanResult;\n   138→      } else {\n   139→        const cache = loadValidCache(process.cwd(), { forceScan });\n   140→        if (cache) {\n   141→          info(`Using cached scan from ${new Date(cache.timestamp).toLocaleString()}`);\n   142→          scan = cache.scan;\n   143→          lastScanResult = scan;\n   144→        } else {\n   145→          scan = runScan(minModuleSize);\n   146→        }\n   147→      }\n   148→      const result = runCoverageAnalysis(scan);\n   149→\n   150→      if (isJson) {\n   151→        jsonOutput({ preconditions: { initialized: preconditions.initialized, bmad: preconditions.bmad, hooks: preconditions.hooks }, coverage: result });\n   152→      } else {\n   153→        printCoverageOutput(result);\n   154→      }\n   155→    });\n   156→\n   157→  // Subcommand: audit\n   158→  onboard\n   159→    .command('audit')\n   160→    .description('Audit project documentation')\n   161→    .action((_, cmd) => {\n   162→      const opts = cmd.optsWithGlobals();\n   163→      const isJson = opts.json === true;\n   164→\n   165→      const preconditions = runPreconditions();\n   166→      if (!preconditions.canProceed) {\n   167→        if (isJson) {\n   168→          jsonOutput({ status: 'fail', message: 'Harness not initialized \\u2014 run codeharness init first' });\n   169→        } else {\n   170→          fail('Harness not initialized \\u2014 run codeharness init first');\n   171→        }\n   172→        process.exitCode = 1;\n   173→        return;\n   174→      }\n   175→      for (const w of preconditions.warnings) {\n   176→        warn(w);\n   177→      }\n   178→\n   179→      const result = runAudit();\n   180→\n   181→      if (isJson) {\n   182→        jsonOutput({ preconditions: { initialized: preconditions.initialized, bmad: preconditions.bmad, hooks: preconditions.hooks }, audit: result });\n   183→      } else {\n   184→        printAuditOutput(result);\n   185→      }\n   186→    });\n   187→\n   188→  // Subcommand: epic\n   189→  onboard\n   190→    .command('epic')\n   191→    .description('Generate onboarding epic from scan findings')\n   192→    .option('--auto-approve', 'Skip interactive prompt and import directly')\n   193→    .action(async (epicOpts, cmd) => {\n   194→      const opts = cmd.optsWithGlobals();\n   195→      const isJson = opts.json === true;\n   196→      const autoApprove = epicOpts.autoApprove === true;\n   197→      const isFull = opts.full === true;\n   198→      const forceScan = opts.forceScan === true;\n   199→      const minModuleSize = parseInt(opts.minModuleSize ?? '3', 10);\n   200→\n   201→      const preconditions = runPreconditions();\n   202→      if (!preconditions.canProceed) {\n   203→        if (isJson) {\n   204→          jsonOutput({ status: 'fail', message: 'Harness not initialized \\u2014 run codeharness init first' });\n   205→        } else {\n   206→          fail('Harness not initialized \\u2014 run codeharness init first');\n   207→        }\n   208→        process.exitCode = 1;\n   209→        return;\n   210→      }\n   211→      for (const w of preconditions.warnings) {\n   212→        warn(w);\n   213→      }\n   214→\n   215→      // Ensure scan results are available — try cache first\n   216→      let scan: ScanResult;\n   217→      let coverage: CoverageGapReport;\n   218→      let audit: DocAuditResult;\n   219→\n   220→      if (lastScanResult) {\n   221→        scan = lastScanResult;\n   222→      } else {\n   223→        const cache = loadValidCache(process.cwd(), { forceScan });\n   224→        if (cache) {\n   225→          info(`Using cached scan from ${new Date(cache.timestamp).toLocaleString()}`);\n   226→          scan = cache.scan;\n   227→          lastScanResult = scan;\n   228→          if (cache.coverage) {\n   229→            lastCoverageResult = cache.coverage;\n   230→          }\n   231→          if (cache.audit) {\n   232→            lastAuditResult = cache.audit;\n   233→          }\n   234→        } else {\n   235→          scan = runScan(minModuleSize);\n   236→        }\n   237→      }\n   238→      coverage = lastCoverageResult ?? runCoverageAnalysis(scan);\n   239→      audit = lastAuditResult ?? runAudit();\n   240→\n   241→      const epicPath = join(process.cwd(), 'ralph', 'onboarding-epic.md');\n   242→      const epic = generateOnboardingEpic(scan, coverage, audit);\n   243→\n   244→      // Merge extended gap detectors (story 8-3)\n   245→      mergeExtendedGaps(epic);\n   246→\n   247→      // Gap filter