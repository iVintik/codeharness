{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016D5NKQM6imtugcfaLbH7vC","type":"tool_result","content":"1\t/**\n2\t * Status formatters — human-readable and JSON formatting for status output.\n3\t * Handles the full status display, docker check, and health check formatting.\n4\t */\n5\t\n6\timport { ok, fail, info, jsonOutput } from '../../lib/output.js';\n7\timport { readState, StateFileNotFoundError } from '../../lib/state.js';\n8\timport { getStackHealth, getCollectorHealth, checkRemoteEndpoint } from '../../lib/docker/index.js';\n9\timport { getOnboardingProgress } from '../../lib/onboard-checks.js';\n10\timport { getStackDir, getComposeFilePath, getElkComposeFilePath } from '../../lib/stack-path.js';\n11\timport { generateReport } from '../sprint/index.js';\n12\timport { getValidationProgress } from '../verify/index.js';\n13\timport { DEFAULT_ENDPOINTS, buildScopedEndpoints, resolveEndpoints, getDefaultEndpointsForBackend } from './endpoints.js';\n14\timport type { HarnessState } from '../../lib/state.js';\n15\timport type { StatusReport } from '../sprint/index.js';\n16\t\n17\t/** Resolve the shared compose file path based on the backend type. */\n18\tfunction resolveSharedCompose(backend: string): string {\n19\t  return backend === 'elk' ? getElkComposeFilePath() : getComposeFilePath();\n20\t}\n21\t\n22\t// ─── Full Status Display ────────────────────────────────────────────────────\n23\t\n24\texport function handleFullStatus(isJson: boolean): void {\n25\t  let state: HarnessState;\n26\t  try {\n27\t    state = readState();\n28\t  } catch (err) {\n29\t    if (err instanceof StateFileNotFoundError) {\n30\t      if (isJson) {\n31\t        jsonOutput({ status: 'fail', message: \"Harness not initialized. Run 'codeharness init' first.\" });\n32\t      } else {\n33\t        fail(\"Harness not initialized. Run 'codeharness init' first.\");\n34\t      }\n35\t      process.exitCode = 1;\n36\t      return;\n37\t    }\n38\t    throw err;\n39\t  }\n40\t\n41\t  if (isJson) {\n42\t    handleFullStatusJson(state);\n43\t    return;\n44\t  }\n45\t\n46\t  // Sprint state sections (Project State, Run, Action Items)\n47\t  printSprintState();\n48\t\n49\t  // Validation progress (if validation stories exist)\n50\t  printValidationProgress();\n51\t\n52\t  // Version & Stack\n53\t  console.log(`Harness: codeharness v${state.harness_version}`);\n54\t  console.log(`Stack: ${state.stack ?? 'unknown'}`);\n55\t  if (state.app_type) {\n56\t    console.log(`App type: ${state.app_type}`);\n57\t    if (state.app_type === 'agent' && state.otlp?.agent_sdk) {\n58\t      console.log(`Agent SDK: ${state.otlp.agent_sdk}`);\n59\t    }\n60\t  }\n61\t\n62\t  // Enforcement\n63\t  const e = state.enforcement;\n64\t  console.log(\n65\t    `Enforcement: front:${e.frontend ? 'ON' : 'OFF'} db:${e.database ? 'ON' : 'OFF'} api:${e.api ? 'ON' : 'OFF'} obs:ON`,\n66\t  );\n67\t\n68\t  // Docker (always shown — observability is mandatory unless backend is 'none')\n69\t  {\n70\t    const backend = state.otlp?.backend ?? 'victoria';\n71\t    const mode = state.otlp?.mode ?? 'local-shared';\n72\t\n73\t    if (backend === 'none') {\n74\t      console.log('Docker: disabled (observability off)');\n75\t    } else if (mode === 'remote-direct') {\n76\t      const endpoint = state.otlp?.endpoint ?? 'unknown';\n77\t      console.log(`Docker: none (remote OTLP at ${endpoint})`);\n78\t    } else if (mode === 'remote-routed') {\n79\t      const re = state.docker?.remote_endpoints;\n80\t      console.log(`Docker: OTel Collector only (backends at ${re?.logs_url ?? 'unknown'}, ${re?.metrics_url ?? 'unknown'}, ${re?.traces_url ?? 'unknown'})`);\n81\t      const sharedComposeFile = getComposeFilePath();\n82\t      const health = getCollectorHealth(sharedComposeFile);\n83\t      for (const svc of health.services) {\n84\t        console.log(`  ${svc.name}: ${svc.running ? 'running' : 'stopped'}`);\n85\t      }\n86\t    } else {\n87\t      const composeFile = state.docker?.compose_file ?? 'docker-compose.harness.yml';\n88\t      const stackDir = getStackDir();\n89\t      const isShared = composeFile.startsWith(stackDir);\n90\t\n91\t      const resolvedComposeFile = isShared ? resolveSharedCompose(backend) : composeFile;\n92\t      const projectName = isShared ? 'codeharness-shared' : undefined;\n93\t      const header = isShared ? 'Docker: shared stack at ~/.codeharness/stack/' : 'Docker:';\n94\t\n95\t      console.log(header);\n96\t      const health = getStackHealth(resolvedComposeFile, projectName);\n97\t      for (const svc of health.services) {\n98\t        console.log(`  ${svc.name}: ${svc.running ? 'running' : 'stopped'}`);\n99\t      }\n100\t      if (health.healthy) {\n101\t        const ep = getDefaultEndpointsForBackend(backend);\n102\t        console.log(\n103\t          `  Endpoints: logs=${ep.logs} metrics=${ep.metrics} traces=${ep.traces}`,\n104\t        );\n105\t      }\n106\t    }\n107\t  }\n108\t\n109\t  // Service-scoped endpoints\n110\t  const serviceName = state.otlp?.service_name;\n111\t  if (serviceName) {\n112\t    const endpoints = resolveEndpoints(state);\n113\t    const scoped = buildScopedEndpoints(endpoints, serviceName, state.otlp?.backend);\n114\t    console.log(`  Scoped: logs=${scoped.logs} metrics=${scoped.metrics} traces=${scoped.traces}`);\n115\t  }\n116\t\n117\t  // Beads — removed (Epic 8 replacement pending)\n118\t\n119\t  // Onboarding progress\n120\t  printOnboardingProgress();\n121\t\n122\t  // Session flags\n123\t  const sf = state.session_flags;\n124\t  console.log(\n125\t    `Session: tests_passed=${sf.tests_passed} coverage_met=${sf.coverage_met} verification_run=${sf.verification_run} logs_queried=${sf.logs_queried}`,\n126\t  );\n127\t\n128\t  // Coverage\n129\t  const currentCov = state.coverage.current !== null ? `${state.coverage.current}%` : '\\u2014';\n130\t  console.log(`Coverage: ${currentCov} / ${state.coverage.target}% target`);\n131\t\n132\t  // Verification log\n133\t  if (state.verification_log.length === 0) {\n134\t    console.log('Verification: no entries');\n135\t  } else {\n136\t    console.log('Verification log:');\n137\t    for (const entry of state.verification_log) {\n138\t      console.log(`  ${entry}`);\n139\t    }\n140\t  }\n141\t}\n142\t\n143\tfunction handleFullStatusJson(state: HarnessState): void {\n144\t  // Docker (always present — observability is mandatory unless backend is 'none')\n145\t  let docker: Record<string, unknown>;\n146\t  {\n147\t    const backend = state.otlp?.backend ?? 'victoria';\n148\t    const mode = state.otlp?.mode ?? 'local-shared';\n149\t\n150\t    if (backend === 'none') {\n151\t      docker = { mode: 'none', message: 'Observability disabled' };\n152\t    } else if (mode === 'remote-direct') {\n153\t      docker = {\n154\t        mode: 'remote-direct',\n155\t        endpoint: state.otlp?.endpoint,\n156\t      };\n157\t    } else if (mode === 'remote-routed') {\n158\t      const sharedComposeFile = getComposeFilePath();\n159\t      const health = getCollectorHealth(sharedComposeFile);\n160\t      docker = {\n161\t        mode: 'remote-routed',\n162\t        healthy: health.healthy,\n163\t        services: health.services,\n164\t        remote_endpoints: state.docker?.remote_endpoints,\n165\t      };\n166\t    } else {\n167\t      const composeFile = state.docker?.compose_file ?? 'docker-compose.harness.yml';\n168\t      const stackDir = getStackDir();\n169\t      const isShared = composeFile.startsWith(stackDir);\n170\t\n171\t      const ep = getDefaultEndpointsForBackend(backend);\n172\t      if (isShared) {\n173\t        const sharedComposeFile = resolveSharedCompose(backend);\n174\t        const health = getStackHealth(sharedComposeFile, 'codeharness-shared');\n175\t        docker = {\n176\t          shared: true,\n177\t          stack_dir: '~/.codeharness/stack/',\n178\t          healthy: health.healthy,\n179\t          services: health.services,\n180\t          ...(health.healthy ? { endpoints: ep } : {}),\n181\t        };\n182\t      } else {\n183\t        const health = getStackHealth(composeFile);\n184\t        docker = {\n185\t          healthy: health.healthy,\n186\t          services: health.services,\n187\t          ...(health.healthy ? { endpoints: ep } : {}),\n188\t        };\n189\t      }\n190\t    }\n191\t  }\n192\t\n193\t  // Resolved endpoints\n194\t  const endpoints = resolveEndpoints(state);\n195\t\n196\t  // Scoped endpoints\n197\t  const serviceName = state.otlp?.service_name;\n198\t  const scoped_endpoints = serviceName ? buildScopedEndpoints(endpoints, serviceName, state.otlp?.backend) : undefined;\n199\t\n200\t  // Onboarding progress\n201\t  const onboarding = getOnboardingProgressData();\n202\t\n203\t  // Sprint state\n204\t  const sprint = getSprintReportData();\n205\t\n206\t  // Validation progress\n207\t  const validationResult = getValidationProgress();\n208\t  const validation = validationResult.success && validationResult.data.total > 0\n209\t    ? validationResult.data : undefined;\n210\t\n211\t  jsonOutput({\n212\t    version: state.harness_version,\n213\t    stack: state.stack,\n214\t    ...(state.app_type ? { app_type: state.app_type } : {}),\n215\t    ...(sprint ? { sprint } : {}),\n216\t    ...(validation ? { validation } : {}),\n217\t    enforcement: state.enforcement,\n218\t    docker,\n219\t    endpoints,\n220\t    ...(scoped_endpoints ? { scoped_endpoints } : {}),\n221\t    ...(onboarding ? { onboarding } : {}),\n222\t    session_flags: state.session_flags,\n223\t    coverage: state.coverage,\n224\t    verification_log: state.verification_log,\n225\t  });\n226\t}\n227\t\n228\t// ─── Health Check Mode ──────────────────────────────────────────────────────\n229\t\n230\texport async function handleHealthCheck(isJson: boolean): Promise<void> {\n231\t  const checks: { name: string; status: 'ok' | 'fail'; detail: string }[] = [];\n232\t\n233\t  // 1. State file integrity\n234\t  let state: HarnessState | null = null;\n235\t  try {\n236\t    state = readState();\n237\t    checks.push({ name: 'state_file', status: 'ok', detail: 'valid' });\n238\t  } catch {\n239\t    // IGNORE: state file may not exist\n240\t    checks.push({ name: 'state_file', status: 'fail', detail: 'not found' });\n241\t  }\n242\t\n243\t  // 2. Docker health (always checked — observability is mandatory unless backend is 'none')\n244\t  if (state) {\n245\t    const backend = state.otlp?.backend ?? 'victoria';\n246\t    const mode = state.otlp?.mode ?? 'local-shared';\n247\t\n248\t    if (backend === 'none') {\n249\t      checks.push({ name: 'docker', status: 'ok', detail: 'observability disabled — skipped' });\n250\t    } else if (mode === 'remote-direct') {\n251\t      const endpoint = state.otlp?.endpoint ?? '';\n252\t      const result = await checkRemoteEndpoint(endpoint);\n253\t      checks.push({\n254\t        name: 'docker',\n255\t        status: result.reachable ? 'ok' : 'fail',\n256\t        detail: result.reachable ? `remote OTLP reachable (${endpoint})` : `remote OTLP unreachable (${result.error ?? 'unknown'})`,\n257\t      });\n258\t    } else if (mode === 'remote-routed') {\n259\t      const sharedComposeFile = getComposeFilePath();\n260\t      const health = getCollectorHealth(sharedComposeFile);\n261\t      checks.push({\n262\t        name: 'docker',\n263\t        status: health.healthy ? 'ok' : 'fail',\n264\t        detail: health.healthy ? 'OTel Collector running' : (health.remedy ?? 'collector down'),\n265\t      });\n266\t\n267\t      // Check remote endpoints\n268\t      const re = state.docker?.remote_endpoints;\n269\t      if (re) {\n270\t        for (const [label, url] of [['logs', re.logs_url], ['metrics', re.metrics_url], ['traces', re.traces_url]] as const) {\n271\t          if (url) {\n272\t            const result = await checkRemoteEndpoint(url);\n273\t            checks.push({\n274\t              name: `remote_${label}`,\n275\t              status: result.reachable ? 'ok' : 'fail',\n276\t              detail: result.reachable ? `reachable (${url})` : `unreachable (${result.error ?? 'unknown'})`,\n277\t            });\n278\t          }\n279\t        }\n280\t      }\n281\t    } else {\n282\t      const composeFile = state.docker?.compose_file ?? 'docker-compose.harness.yml';\n283\t      const sDir = getStackDir();\n284\t      const isShared = composeFile.startsWith(sDir);\n285\t      const healthComposeFile = isShared ? resolveSharedCompose(backend) : composeFile;\n286\t      const healthProjectName = isShared ? 'codeharness-shared' : undefined;\n287\t      const health = getStackHealth(healthComposeFile, healthProjectName);\n288\t      checks.push({\n289\t        name: 'docker',\n290\t        status: health.healthy ? 'ok' : 'fail',\n291\t        detail: health.healthy ? 'all services running' : (health.remedy ?? 'services down'),\n292\t      });\n293\t    }\n294\t  } else {\n295\t    checks.push({ name: 'docker', status: 'fail', detail: 'cannot check (no state)' });\n296\t  }\n297\t\n298\t  // 3. Issue tracker — placeholder for Epic 8\n299\t  // Beads health check removed; Epic 8 will add issue-tracker health check here.\n300\t\n301\t  const allPassed = checks.every(c => c.status === 'ok');\n302\t\n303\t  if (isJson) {\n304\t    const checksObj: Record<string, { status: string; detail: string }> = {};\n305\t    for (const c of checks) {\n306\t      checksObj[c.name] = { status: c.status, detail: c.detail };\n307\t    }\n308\t    jsonOutput({ status: allPassed ? 'ok' : 'fail', checks: checksObj });\n309\t  } else {\n310\t    for (const c of checks) {\n311\t      const prefix = c.status === 'ok' ? '[OK]' : '[FAIL]';\n312\t      const label = c.name.replace(/_/g, ' ');\n313\t      console.log(`${prefix} ${label[0].toUpperCase() + label.slice(1)}: ${c.detail}`);\n314\t    }\n315\t  }\n316\t\n317\t  process.exitCode = allPassed ? 0 : 1;\n318\t}\n319\t\n320\t// ─── Docker Check ───────────────────────────────────────────────────────────\n321\t\n322\texport async function handleDockerCheck(isJson: boolean): Promise<void> {\n323\t  let state: HarnessState | null = null;\n324\t  try {\n325\t    state = readState();\n326\t  } catch {\n327\t    // IGNORE: state file may not exist or be corrupted\n328\t  }\n329\t\n330\t  const backend = state?.otlp?.backend ?? 'victoria';\n331\t\n332\t  if (backend === 'none') {\n333\t    if (isJson) {\n334\t      jsonOutput({ status: 'ok', mode: 'none', message: 'Observability disabled — no Docker check needed' });\n335\t    } else {\n336\t      info('[INFO] Observability disabled — no Docker check needed');\n337\t    }\n338\t    return;\n339\t  }\n340\t\n341\t  const mode = state?.otlp?.mode ?? 'local-shared';\n342\t\n343\t  if (mode === 'remote-direct') {\n344\t    const endpoint = state?.otlp?.endpoint ?? '';\n345\t    const result = await checkRemoteEndpoint(endpoint);\n346\t    if (isJson) {\n347\t      jsonOutput({\n348\t        status: result.reachable ? 'ok' : 'fail',\n349\t        mode: 'remote-direct',\n350\t        endpoint,\n351\t        reachable: result.reachable,\n352\t        ...(result.error ? { error: result.error } : {}),\n353\t      });\n354\t    } else {\n355\t      if (result.reachable) {\n356\t        ok(`Remote OTLP endpoint: reachable (${endpoint})`);\n357\t      } else {\n358\t        fail(`Remote OTLP endpoint: unreachable (${endpoint})`);\n359\t        if (result.error) {\n360\t          info(`Error: ${result.error}`);\n361\t        }\n362\t      }\n363\t    }\n364\t    return;\n365\t  }\n366\t\n367\t  if (mode === 'remote-routed') {\n368\t    const sharedComposeFile = getComposeFilePath();\n369\t    const health = getCollectorHealth(sharedComposeFile);\n370\t\n371\t    if (isJson) {\n372\t      jsonOutput({\n373\t        status: health.healthy ? 'ok' : 'fail',\n374\t        mode: 'remote-routed',\n375\t        docker: {\n376\t          healthy: health.healthy,\n377\t          services: health.services,\n378\t          remedy: health.remedy,\n379\t        },\n380\t        remote_endpoints: state?.docker?.remote_endpoints,\n381\t      });\n382\t    } else {\n383\t      if (health.healthy) {\n384\t        ok('OTel Collector: running');\n385\t      } else {\n386\t        fail('OTel Collector: not running');\n387\t        if (health.remedy) {\n388\t          info(`-> ${health.remedy}`);\n389\t        }\n390\t      }\n391\t      const re = state?.docker?.remote_endpoints;\n392\t      if (re) {\n393\t        info(`Remote backends: logs=${re.logs_url} metrics=${re.metrics_url} traces=${re.traces_url}`);\n394\t      }\n395\t    }\n396\t    return;\n397\t  }\n398\t\n399\t  // local-shared mode (default)\n400\t  let composeFile = 'docker-compose.harness.yml';\n401\t  let projectName: string | undefined;\n402\t\n403\t  if (state?.docker?.compose_file) {\n404\t    composeFile = state.docker.compose_file;\n405\t  }\n406\t\n407\t  const stackDir = getStackDir();\n408\t  if (composeFile.startsWith(stackDir)) {\n409\t    composeFile = resolveSharedCompose(backend);\n410\t    projectName = 'codeharness-shared';\n411\t  }\n412\t\n413\t  const health = getStackHealth(composeFile, projectName);\n414\t\n415\t  if (isJson) {\n416\t    jsonOutput({\n417\t      status: health.healthy ? 'ok' : 'fail',\n418\t      backend,\n419\t      ...(projectName ? { project_name: projectName } : {}),\n420\t      docker: {\n421\t        healthy: health.healthy,\n422\t        services: health.services,\n423\t        remedy: health.remedy,\n424\t      },\n425\t      ...(health.healthy ? { endpoints: getDefaultEndpointsForBackend(backend) } : {}),\n426\t    });\n427\t    return;\n428\t  }\n429\t\n430\t  const stackLabel = backend === 'elk' ? 'OpenSearch/ELK stack' : 'VictoriaMetrics stack';\n431\t  const ep = getDefaultEndpointsForBackend(backend);\n432\t\n433\t  if (health.healthy) {\n434\t    ok(`${stackLabel}: running${projectName ? ` (project: ${projectName})` : ''}`);\n435\t    for (const svc of health.services) {\n436\t      info(`  ${svc.name}: $