ionConfig;\n53\t  /** Story-level flow steps (normalized from `flow` or `story_flow`). */\n54\t  storyFlow: FlowStep[];\n55\t  /** Epic-level flow steps (empty if not defined). */\n56\t  epicFlow: FlowStep[];\n57\t}\n58\t\n59\t// --- Error Class ---\n60\t\n61\texport class WorkflowParseError extends Error {\n62\t  public readonly errors: Array<{ path: string; message: string }>;\n63\t\n64\t  constructor(message: string, errors?: Array<{ path: string; message: string }>) {\n65\t    super(message);\n66\t    this.name = 'WorkflowParseError';\n67\t    this.errors = errors ?? [];\n68\t  }\n69\t}\n70\t\n71\t// --- Referential Integrity Validation ---\n72\t\n73\t/**\n74\t * Validate that driver and agent references in tasks point to real registered\n75\t * drivers and resolvable agents. Collects errors into the provided array\n76\t * (does not throw — caller decides when to throw).\n77\t *\n78\t * Driver validation is skipped when the driver registry is empty (parse can\n79\t * be called independently of engine startup).\n80\t *\n81\t * Agent validation tries resolveAgent() first (covers embedded, user-level,\n82\t * and project-level agents). Distinguishes between \"not found\" errors and\n83\t * other failures (corrupt YAML, schema errors) to provide accurate messages.\n84\t */\n85\tfunction validateReferentialIntegrity(\n86\t  data: { tasks: Record<string, Record<string, unknown>> },\n87\t  errors: Array<{ path: string; message: string }>,\n88\t): void {\n89\t  // Driver validation — only when registry is populated\n90\t  const registeredDrivers = listDrivers();\n91\t  const driverRegistryPopulated = registeredDrivers.length > 0;\n92\t\n93\t  // Agent list for error messages\n94\t  const embeddedAgents = listEmbeddedAgents();\n95\t\n96\t  for (const [taskName, task] of Object.entries(data.tasks)) {\n97\t    // Validate driver field if present\n98\t    if (task.driver !== undefined && typeof task.driver === 'string' && driverRegistryPopulated) {\n99\t      if (!registere