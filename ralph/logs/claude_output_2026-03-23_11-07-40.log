{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KgrnFy3MFjjhyNQBJ39zUR","type":"tool_result","content":"     1в†’/**\n     2в†’ * Verification environment management: Docker image lifecycle, clean workspace,\n     3в†’ * and environment checks for black-box verification.\n     4в†’ */\n     5в†’import { execFileSync } from 'node:child_process';\n     6в†’import { existsSync, mkdirSync, readdirSync, readFileSync, cpSync, rmSync, statSync } from 'node:fs';\n     7в†’import { join, basename } from 'node:path';\n     8в†’import { createHash } from 'node:crypto';\n     9в†’import { info } from '../../lib/output.js';\n    10в†’import { detectStack } from '../../lib/stack-detect.js';\n    11в†’import { readStateWithBody, writeState } from '../../lib/state.js';\n    12в†’import { isDockerAvailable } from '../../lib/docker.js';\n    13в†’import type { BuildOptions, BuildResult, CheckResult, ProjectType } from './types.js';\n    14в†’\n    15в†’const IMAGE_TAG = 'codeharness-verify';\n    16в†’const STORY_DIR = '_bmad-output/implementation-artifacts';\n    17в†’const TEMP_PREFIX = '/tmp/codeharness-verify-';\n    18в†’const STATE_KEY_DIST_HASH = 'verify_env_dist_hash';\n    19в†’\n    20в†’/** Validates that a story key is safe for file paths and container names. */\n    21в†’export function isValidStoryKey(storyKey: string): boolean {\n    22в†’  if (!storyKey || storyKey.includes('..') || storyKey.includes('/') || storyKey.includes('\\\\')) {\n    23в†’    return false;\n    24в†’  }\n    25в†’  return /^[a-zA-Z0-9_-]+$/.test(storyKey);\n    26в†’}\n    27в†’\n    28в†’/** Computes a SHA-256 hash of all files in dist/ for cache invalidation. */\n    29в†’export function computeDistHash(projectDir: string): string | null {\n    30в†’  const distDir = join(projectDir, 'dist');\n    31в†’  if (!existsSync(distDir)) return null;\n    32в†’  const hash = createHash('sha256');\n    33в†’  const files = collectFiles(distDir).sort();\n    34в†’  for (const file of files) {\n    35в†’    hash.update(file.slice(distDir.length));\n    36в†’    hash.update(readFileSync(file));\n    37в†’  }\n    38в†’  return hash.digest('hex');\n    39в†’}\n    40в†’\n    41в†’function collectFiles(dir: string): string[] {\n    42в†’  const results: string[] = [];\n    43в†’  for (const entry of readdirSync(dir, { withFileTypes: true })) {\n    44в†’    const fullPath = join(dir, entry.name);\n    45в†’    if (entry.isDirectory()) { results.push(...collectFiles(fullPath)); }\n    46в†’    else { results.push(fullPath); }\n    47в†’  }\n    48в†’  return results;\n    49в†’}\n    50в†’\n    51в†’function getStoredDistHash(projectDir: string): string | null {\n    52в†’  try {\n    53в†’    const { state } = readStateWithBody(projectDir);\n    54в†’    return ((state as unknown as Record<string, unknown>)[STATE_KEY_DIST_HASH] as string) ?? null;\n    55в†’  } catch { return null; }\n    56в†’}\n    57в†’\n    58в†’function storeDistHash(projectDir: string, hash: string): void {\n    59в†’  try {\n    60в†’    const { state, body } = readStateWithBody(projectDir);\n    61в†’    (state as unknown as Record<string, unknown>)[STATE_KEY_DIST_HASH] = hash;\n    62в†’    writeState(state, projectDir, body);\n    63в†’  } catch {\n    64в†’    info('Could not persist dist hash to state file вЂ” cache will not be available until state is initialized');\n    65в†’  }\n    66в†’}\n    67в†’\n    68в†’/** Detects the project type for verification strategy selection. */\n    69в†’export function detectProjectType(projectDir: string): ProjectType {\n    70в†’  const stack = detectStack(projectDir);\n    71в†’  // Prefer nodejs/python when the project has a buildable package вЂ” the npm tarball\n    72в†’  // or Python wheel includes all distributable files. Plugin-only detection is the\n    73в†’  // fallback for projects that are purely Claude Code plugins with no build artifact.\n    74в†’  if (stack === 'nodejs') return 'nodejs';\n    75в†’  if (stack === 'python') return 'python';\n    76в†’  if (stack === 'rust') return 'rust';\n    77в†’  if (existsSync(join(projectDir, '.claude-plugin', 'plugin.json'))) return 'plugin';\n    78в†’  return 'generic';\n    79в†’}\n    80в†’\n    81в†’/** Builds the verification Docker image with cache invalidation. */\n    82в†’export function buildVerifyImage(options: BuildOptions = {}): BuildResult {\n    83в†’  const projectDir = options.projectDir ?? process.cwd();\n    84в†’  if (!isDockerAvailable()) {\n    85в†’    throw new Error('Docker is not available. Install Docker and ensure the daemon is running.');\n    86в†’  }\n    87в†’  const projectType = detectProjectType(projectDir);\n    88в†’  const currentHash = computeDistHash(projectDir);\n    89в†’  if (projectType === 'generic' || projectType === 'plugin' || projectType === 'rust') {\n    90в†’    // Generic and plugin projects may not have dist/ вЂ” skip hash check\n    91в†’  } else if (!currentHash) {\n    92в†’    throw new Error('No dist/ directory found. Run your build command first (e.g., npm run build).');\n    93в†’  }\n    94в†’  if (currentHash) {\n    95в†’    const storedHash = getStoredDistHash(projectDir);\n    96в†’    if (storedHash === currentHash && dockerImageExists(IMAGE_TAG)) {\n    97в†’      return { imageTag: IMAGE_TAG, imageSize: getImageSize(IMAGE_TAG), buildTimeMs: 0, cached: true };\n    98в†’    }\n    99в†’  }\n   100в†’  const startTime = Date.now();\n   101в†’  if (projectType === 'nodejs') { buildNodeImage(projectDir); }\n   102в†’  else if (projectType === 'python') { buildPythonImage(projectDir); }\n   103в†’  else if (projectType === 'rust') { buildRustImage(projectDir); }\n   104в†’  else if (projectType === 'plugin') { buildPluginImage(projectDir); }\n   105в†’  else { buildGenericImage(projectDir); }\n   106в†’  if (currentHash) { storeDistHash(projectDir, currentHash); }\n   107в†’  return { imageTag: IMAGE_TAG, imageSize: getImageSize(IMAGE_TAG), buildTimeMs: Date.now() - startTime, cached: false };\n   108в†’}\n   109в†’\n   110в†’function buildNodeImage(projectDir: string): void {\n   111в†’  const packOutput = execFileSync('npm', ['pack', '--pack-destination', '/tmp'], {\n   112в†’    cwd: projectDir, stdio: 'pipe', timeout: 60_000,\n   113в†’  }).toString().trim();\n   114в†’  const lastLine = packOutput.split('\\n').pop()?.trim();\n   115в†’  if (!lastLine) throw new Error('npm pack produced no output вЂ” cannot determine tarball filename.');\n   116в†’  const tarballName = basename(lastLine);\n   117в†’  const tarballPath = join('/tmp', tarballName);\n   118в†’  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   119в†’  mkdirSync(buildContext, { recursive: true });\n   120в†’  try {\n   121в†’    cpSync(tarballPath, join(buildContext, tarballName));\n   122в†’    cpSync(resolveDockerfileTemplate(projectDir), join(buildContext, 'Dockerfile'));\n   123в†’    execFileSync('docker', ['build', '-t', IMAGE_TAG, '--build-arg', `TARBALL=${tarballName}`, '.'], {\n   124в†’      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   125в†’    });\n   126в†’  } finally {\n   127в†’    rmSync(buildContext, { recursive: true, force: true });\n   128в†’    rmSync(tarballPath, { force: true });\n   129в†’  }\n   130в†’}\n   131в†’\n   132в†’function buildPythonImage(projectDir: string): void {\n   133в†’  const distDir = join(projectDir, 'dist');\n   134в†’  const distFiles = readdirSync(distDir).filter(f => f.endsWith('.tar.gz') || f.endsWith('.whl'));\n   135в†’  if (distFiles.length === 0) {\n   136в†’    throw new Error('No distribution files found in dist/. Run your build command first (e.g., python -m build).');\n   137в†’  }\n   138в†’  const distFile = distFiles.filter(f => f.endsWith('.tar.gz'))[0] ?? distFiles[0];\n   139в†’  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   140в†’  mkdirSync(buildContext, { recursive: true });\n   141в†’  try {\n   142в†’    cpSync(join(distDir, distFile), join(buildContext, distFile));\n   143в†’    cpSync(resolveDockerfileTemplate(projectDir), join(buildContext, 'Dockerfile'));\n   144в†’    execFileSync('docker', ['build', '-t', IMAGE_TAG, '--build-arg', `TARBALL=${distFile}`, '.'], {\n   145в†’      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   146в†’    });\n   147в†’  } finally {\n   148в†’    rmSync(buildContext, { recursive: true, force: true });\n   149в†’  }\n   150в†’}\n   151в†’\n   152в†’/** Creates a clean temp workspace for verification (no src/, tests/, .git/). */\n   153в†’export function prepareVerifyWorkspace(storyKey: string, projectDir?: string): string {\n   154в†’  const root = projectDir ?? process.cwd();\n   155в†’  if (!isValidStoryKey(storyKey)) {\n   156в†’    throw new Error(`Invalid story key: ${storyKey}. Keys must contain only alphanumeric characters, hyphens, and underscores.`);\n   157в†’  }\n   158в†’  const storyFile = join(root, STORY_DIR, `${storyKey}.md`);\n   159в†’  if (!existsSync(storyFile)) throw new Error(`Story file not found: ${storyFile}`);\n   160в†’  const workspace = `${TEMP_PREFIX}${storyKey}`;\n   161в†’  if (existsSync(workspace)) rmSync(workspace, { recursive: true, force: true });\n   162в†’  mkdirSync(workspace, { recursive: true });\n   163в†’  cpSync(storyFile, join(workspace, 'story.md'));\n   164в†’  const readmePath = join(root, 'README.md');\n   165в†’  if (existsSync(readmePath)) cpSync(readmePath, join(workspace, 'README.md'));\n   166в†’  const docsDir = join(root, 'docs');\n   167в†’  if (existsSync(docsDir) && statSync(docsDir).isDirectory()) {\n   168в†’    cpSync(docsDir, join(workspace, 'docs'), { recursive: true });\n   169в†’  }\n   170в†’  mkdirSync(join(workspace, 'verification'), { recursive: true });\n   171в†’  return workspace;\n   172в†’}\n   173в†’\n   174в†’/** Validates verification environment: image, CLI, observability. */\n   175в†’export function checkVerifyEnv(): CheckResult {\n   176в†’  let imageExists = false;\n   177в†’  let cliWorks = false;\n   178в†’  let otelReachable = false;\n   179в†’\n   180в†’  imageExists = dockerImageExists(IMAGE_TAG);\n   181в†’  if (!imageExists) return { imageExists, cliWorks, otelReachable };\n   182в†’  try {\n   183в†’    execFileSync('docker', ['run', '--rm', IMAGE_TAG, 'codeharness', '--help'], {\n   184в†’      stdio: 'pipe', timeout: 30_000,\n   185в†’    });\n   186в†’    cliWorks = true;\n   187в†’  } catch { cliWorks = false; }\n   188в†’  try {\n   189в†’    execFileSync('docker', [\n   190в†’      'run', '--rm', '--add-host=host.docker.internal:host-gateway', IMAGE_TAG,\n   191в†’      'curl', '-sf', '--max-time', '5', 'http://host.docker.internal:4318/v1/status',\n   192в†’    ], { stdio: 'pipe', timeout: 30_000 });\n   193в†’    otelReachable = true;\n   194в†’  } catch { otelReachable = false; }\n   195в†’  return { imageExists, cliWorks, otelReachable };\n   196в†’}\n   197в†’\n   198в†’/** Cleans up all stale containers matching `codeharness-verify-*` pattern. Idempotent. */\n   199в†’export function cleanupStaleContainers(): void {\n   200в†’  try {\n   201в†’    const output = execFileSync(\n   202в†’      'docker', ['ps', '-a', '--filter', 'name=codeharness-verify-', '--format', '{{.Names}}'],\n   203в†’      { stdio: 'pipe', timeout: 15_000 },\n   204в†’    ).toString('utf-8').trim();\n   205в†’    if (output.length === 0) return;\n   206в†’    const containers = output.split('\\n').filter(name => name.length > 0);\n   207в†’    for (const name of containers) {\n   208в†’      try {\n   209в†’        execFileSync('docker', ['rm', '-f', name], { stdio: 'pipe', timeout: 15_000 });\n   210в†’      } catch { /* container may already be removed */ }\n   211в†’    }\n   212в†’  } catch { /* docker not available or no containers вЂ” ignore */ }\n   213в†’}\n   214в†’\n   215в†’/** Removes temp workspace and stops/removes the container. Idempotent. */\n   216в†’export function cleanupVerifyEnv(storyKey: string): void {\n   217в†’  if (!isValidStoryKey(storyKey)) {\n   218в†’    throw new Error(`Invalid story key: ${storyKey}. Keys must contain only alphanumeric characters, hyphens, and underscores.`);\n   219в†’  }\n   220в†’  const workspace = `${TEMP_PREFIX}${storyKey}`;\n   221в†’  const containerName = `codeharness-verify-${storyKey}`;\n   222в†’  if (existsSync(workspace)) rmSync(workspace, { recursive: true, force: true });\n   223в†’  try { execFileSync('docker', ['stop', containerName], { stdio: 'pipe', timeout: 15_000 }); }\n   224в†’  catch { /* container may not exist */ }\n   225в†’  try { execFileSync('docker', ['rm', '-f', containerName], { stdio: 'pipe', timeout: 15_000 }); }\n   226в†’  catch { /* container may not exist */ }\n   227в†’}\n   228в†’\n   229в†’function buildPluginImage(projectDir: string): void {\n   230в†’  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   231в†’  mkdirSync(buildContext, { recursive: true });\n   232в†’  try {\n   233в†’    // Copy plugin source into build context\n   234в†’    const pluginDir = join(projectDir, '.claude-plugin');\n   235в†’    cpSync(pluginDir, join(buildContext, '.claude-plugin'), { recursive: true });\n   236в†’    // Copy any commands, hooks, knowledge, skills directories if they exist\n   237в†’    for (const dir of ['commands', 'hooks', 'knowledge', 'skills']) {\n   238в†’      const src = join(projectDir, dir);\n   239в†’      if (existsSync(src) && statSync(src).isDirectory()) {\n   240в†’        cpSync(src, join(buildContext, dir), { recursive: true });\n   241в†’      }\n   242в†’    }\n   243в†’    cpSync(resolveDockerfileTemplate(projectDir, 'generic'), join(buildContext, 'Dockerfile'));\n   244в†’    execFileSync('docker', ['build', '-t', IMAGE_TAG, '.'], {\n   245в†’      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   246в†’    });\n   247в†’  } finally {\n   248в†’    rmSync(buildContext, { recursive: true, force: true });\n   249в†’  }\n   250в†’}\n   251в†’\n   252в†’function buildRustImage(projectDir: string): void {\n   253в†’  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   254в†’  mkdirSync(buildContext, { recursive: true });\n   255в†’  try {\n   256в†’    cpSync(resolveDockerfileTemplate(projectDir, 'rust'), join(buildContext, 'Dockerfile'));\n   257в†’    execFileSync('docker', ['build', '-t', IMAGE_TAG, '.'], {\n   258в†’      cwd: buildContext, stdio: 'pipe', timeout: 300_000,\n   259в†’    });\n   260в†’  } finally {\n   261в†’    rmSync(buildContext, { recursive: true, force: true });\n   262в†’  }\n   263в†’}\n   264в†’\n   265в†’function buildGenericImage(projectDir: string): void {\n   266в†’  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   267в†’  mkdirSync(buildContext, { recursive: true });\n   268в†’  try {\n   269в†’    cpSync(resolveDockerfileTemplate(projectDir, 'generic'), join(buildContext, 'Dockerfile'));\n   270в†’    execFileSync('docker', ['build', '-t', IMAGE_TAG, '.'], {\n   271в†’      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   272в†’    });\n   273в†’  } finally {\n   274в†’    rmSync(buildContext, { recursive: true, force: true });\n   275в†’  }\n   276в†’}\n   277в†’\n   278в†’function resolveDockerfileTemplate(projectDir: string, variant?: string): string {\n   279в†’  const filename = variant === 'generic' ? 'Dockerfile.verify.generic' : variant === 'rust' ? 'Dockerfile.verify.rust' : 'Dockerfile.verify';\n   280в†’  const local = join(projectDir, 'templates', filename);\n   281в†’  if (existsSync(local)) return local;\n   282в†’  const pkgDir = new URL('../../', import.meta.url).pathname;\n   283в†’  const pkg = join(pkgDir, 'templates', filename);\n   284в†’  if (existsSync(pkg)) return pkg;\n   285в†’  throw new Error(`${filename} not found. Ensure templates/${filename} exists.`);\n   286в†’}\n   287в†’\n   288в†’function dockerImageExists(tag: string): boolean {\n   289в†’  try {\n   290в†’    execFileSync('docker', ['image', 'inspect', tag], { stdio: 'pipe', timeout: 10_000 });\n   291в†’    return true;\n   292в†’  } catch { return false; }\n   293в†’}\n   294в†’\n   295в†’function getImageSize(tag: string): string {\n   296в†’  try {\n   297в†’    const output = execFileSync('docker', ['image', 'inspect', tag, '--format', '{{.Size}}'], {\n   298в†’      stdio: 'pipe', timeout: 10_000,\n   299в†’    }).toString().trim();\n   300в†’    const bytes = parseInt(output, 10);\n   301в†’    if (isNaN(bytes)) return output;\n   302в†’    if (bytes >= 1_000_000_000) return `${(bytes / 1_000_000_000).toFixed(1)}GB`;\n   303в†’    if (bytes >= 1_000_000) return `${(bytes / 1_000_000).toFixed(1)}MB`;\n   304в†’    if (bytes >= 1_000) return `${(bytes / 1_000).toFixed(1)}KB`;\n   305в†’    return `${bytes}B`;\n   306в†’  } catch { return 'unknown'; }\n   307в†’}\n   308в†’"}]},"parent_tool_use_id":"toolu_01Kg9tLGsBN5iJa4HVEh4QKa","session_id":"51b9d113-d480-4846-9e18-693f5f89566d","uuid":"2a3192c3-eecc-43be-9835-662d362cd8f2","timestamp":"2026-03-23T07:16:17.735Z"}
