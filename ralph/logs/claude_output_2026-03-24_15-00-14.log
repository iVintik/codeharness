{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TWBciuB8XEhK78opxajRue","type":"tool_result","content":"     1→/**\n     2→ * Sprint reporter — generates a StatusReport from SprintState.\n     3→ * Pure function over in-memory state; no filesystem or network access.\n     4→ */\n     5→\n     6→import { ok, fail } from '../../types/result.js';\n     7→import type { Result } from '../../types/result.js';\n     8→import type { SprintState, StoryState } from '../../types/state.js';\n     9→import type {\n    10→  StatusReport,\n    11→  FailedStoryDetail,\n    12→  LabeledActionItem,\n    13→  RunSummary,\n    14→} from './types.js';\n    15→import { MAX_STORY_ATTEMPTS } from './selector.js';\n    16→\n    17→import { epicPrefix } from './drill-down.js';\n    18→export { getStoryDrillDown } from './drill-down.js';\n    19→\n    20→/** Max attempts constant used for display */\n    21→const MAX_ATTEMPTS = MAX_STORY_ATTEMPTS;\n    22→\n    23→/** Format milliseconds as a human-readable duration like \"2h14m\" or \"5m\" */\n    24→function formatDuration(ms: number): string {\n    25→  const clamped = Math.max(0, ms);\n    26→  const totalMinutes = Math.floor(clamped / 60000);\n    27→  const hours = Math.floor(totalMinutes / 60);\n    28→  const minutes = totalMinutes % 60;\n    29→  if (hours > 0) return `${hours}h${minutes}m`;\n    30→  return `${minutes}m`;\n    31→}\n    32→\n    33→/** Compute epic progress from stories */\n    34→function computeEpicProgress(\n    35→  stories: Record<string, StoryState>,\n    36→): { epicsTotal: number; epicsDone: number } {\n    37→  const epicGroups = new Map<string, { total: number; done: number }>();\n    38→\n    39→  for (const [key, story] of Object.entries(stories)) {\n    40→    const prefix = epicPrefix(key);\n    41→    const group = epicGroups.get(prefix) ?? { total: 0, done: 0 };\n    42→    group.total++;\n    43→    if (story.status === 'done') group.done++;\n    44→    epicGroups.set(prefix, group);\n    45→  }\n    46→\n    47→  let epicsTotal = 0;\n    48→  let epicsDone = 0;\n    49→  for (const group of epicGroups.values()) {\n    50→    epicsTotal++;\n    51→    if (group.total > 0 && group.done === group.total) epicsDone++;\n    52→  }\n    53→\n    54→  return { epicsTotal, epicsDone };\n    55→}\n    56→\n    57→/** Build failed story detail entries */\n    58→function buildFailedDetails(\n    59→  stories: Record<string, StoryState>,\n    60→): ReadonlyArray<FailedStoryDetail> {\n    61→  const details: FailedStoryDetail[] = [];\n    62→\n    63→  for (const [key, story] of Object.entries(stories)) {\n    64→    if (story.status !== 'failed') continue;\n    65→\n    66→    let acNumber: number | null = null;\n    67→    if (story.acResults) {\n    68→      for (const ac of story.acResults) {\n    69→        if (ac.verdict === 'fail') {\n    70→          const num = parseInt(ac.id.replace(/\\D/g, ''), 10);\n    71→          if (!isNaN(num)) {\n    72→            acNumber = num;\n    73→            break;\n    74→          }\n    75→        }\n    76→      }\n    77→    }\n    78→\n    79→    details.push({\n    80→      key,\n    81→      acNumber,\n    82→      errorLine: story.lastError ?? 'unknown error',\n    83→      attempts: story.attempts,\n    84→      maxAttempts: MAX_ATTEMPTS,\n    85→    });\n    86→  }\n    87→\n    88→  return details;\n    89→}\n    90→\n    91→/** Build labeled action items */\n    92→function buildActionItemsLabeled(\n    93→  state: SprintState,\n    94→): ReadonlyArray<LabeledActionItem> {\n    95→  const runStories = new Set([\n    96→    ...state.run.completed,\n    97→    ...state.run.failed,\n    98→  ]);\n    99→\n   100→  return state.actionItems.map((item) => {\n   101→    const isNew =\n   102→      item.source === 'verification' && runStories.has(item.story);\n   103→    return { item, label: isNew ? 'NEW' as const : 'CARRIED' as const };\n   104→  });\n   105→}\n   106→\n   107→/** Build a RunSummary from the current state */\n   108→function buildRunSummary(state: SprintState, now: Date): RunSummary | null {\n   109→  if (!state.run.startedAt) return null;\n   110→\n   111→  const startedAt = new Date(state.run.startedAt);\n   112→  const elapsed = now.getTime() - startedAt.getTime();\n   113→\n   114→  // Collect blocked/skipped stories\n   115→  // \"skipped\" = retry-exhausted (blocked with attempts >= MAX_ATTEMPTS)\n   116→  const blocked: string[] = [];\n   117→  const skipped: string[] = [];\n   118→  for (const [key, story] of Object.entries(state.stories)) {\n   119→    if (story.status === 'blocked') {\n   120→      blocked.push(key);\n   121→      if (story.attempts >= MAX_ATTEMPTS) {\n   122→        skipped.push(key);\n   123→      }\n   124→    }\n   125→  }\n   126→\n   127→  return {\n   128→    duration: formatDuration(elapsed),\n   129→    cost: state.run.cost,\n   130→    iterations: state.run.iteration,\n   131→    completed: [...state.run.completed],\n   132→    failed: [...state.run.failed],\n   133→    blocked,\n   134→    skipped,\n   135→  };\n   136→}\n   137→\n   138→/**\n   139→ * Generate a full status report from sprint state.\n   140→ * Pure function — never throws, returns Result<StatusReport>.\n   141→ */\n   142→export function generateReport(\n   143→  state: SprintState,\n   144→  now?: Date,\n   145→): Result<StatusReport> {\n   146→  try {\n   147→    const effectiveNow = now ?? new Date();\n   148→    const stories = state.stories;\n   149→\n   150→    // Basic counts\n   151→    let total = 0;\n   152→    let done = 0;\n   153→    let failed = 0;\n   154→    let blocked = 0;\n   155→\n   156→    const storyStatuses: Array<{ key: string; status: StoryState['status'] }> = [];\n   157→\n   158→    for (const [key, story] of Object.entries(stories)) {\n   159→      total++;\n   160→      if (story.status === 'done') done++;\n   161→      else if (story.status === 'failed') failed++;\n   162→      else if (story.status === 'blocked') blocked++;\n   163→      storyStatuses.push({ key, status: story.status });\n   164→    }\n   165→\n   166→    const sprintPercent = total > 0 ? Math.round((done / total) * 100) : 0;\n   167→    const { epicsTotal, epicsDone } = computeEpicProgress(stories);\n   168→\n   169→    // Run summary\n   170→    const runSummary = buildRunSummary(state, effectiveNow);\n   171→    const activeRun = state.run.active ? runSummary : null;\n   172→    const lastRun = !state.run.active ? runSummary : null;\n   173→\n   174→    // Failed details and action items\n   175→    const failedDetails = buildFailedDetails(stories);\n   176→    const actionItemsLabeled = buildActionItemsLabeled(state);\n   177→\n   178→    return ok({\n   179→      total,\n   180→      done,\n   181→      failed,\n   182→      blocked,\n   183→      inProgress: state.sprint.inProgress,\n   184→      storyStatuses,\n   185→      epicsTotal,\n   186→      epicsDone,\n   187→      sprintPercent,\n   188→      activeRun,\n   189→      lastRun,\n   190→      failedDetails,\n   191→      actionItemsLabeled,\n   192→    });\n   193→  } catch (err: unknown) {\n   194→    const msg = err instanceof Error ? err.message : String(err);\n   195→    return fail(`Failed to generate report: ${msg}`);\n   196→  }\n   197→}\n   198→\n   199→"}]},"parent_tool_use_id":"toolu_01WHShw3WenWAwXLiDPJ4eCA","session_id":"bd5543f6-f408-4218-88bd-6e3bcdc37563","uuid":"b8739bb7-fa62-4d6c-bcbb-fc154595c5a9","timestamp":"2026-03-24T11:02:02.934Z"}
