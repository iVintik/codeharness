{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NLC25Ta5dCvaPUz3KuhBE9","type":"tool_result","content":"     1→/**\n     2→ * Review module — story review execution.\n     3→ * Public interface: only this file should be imported from outside the module.\n     4→ */\n     5→\n     6→import type { Result } from '../../types/result.js';\n     7→import type { ReviewResult } from './types.js';\n     8→import { invokeBmadCodeReview } from './orchestrator.js';\n     9→\n    10→export type { ReviewResult };\n    11→\n    12→/**\n    13→ * Review a story by invoking the BMAD code-review workflow.\n    14→ * Returns Result<ReviewResult> — never throws.\n    15→ */\n    16→export function reviewStory(\n    17→  key: string,\n    18→  opts?: { timeoutMs?: number },\n    19→): Result<ReviewResult> {\n    20→  return invokeBmadCodeReview(key, opts);\n    21→}\n    22→"}]},"parent_tool_use_id":"toolu_01SYFmth4jmfGkWhMfu7ffMP","session_id":"7be24b04-34e1-424a-85e4-e656cce56dfe","uuid":"a9e42824-13b7-4bc8-9ead-0ca4bc3fab82","timestamp":"2026-03-21T06:13:02.319Z"}
