{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017Go4FgFTP2eJ2sEuvDVTL1","type":"tool_result","content":"     1→import { Command } from 'commander';\n     2→import { registerInitCommand } from './commands/init.js';\n     3→import { registerBridgeCommand } from './commands/bridge.js';\n     4→import { registerRunCommand } from './commands/run.js';\n     5→import { registerVerifyCommand } from './commands/verify.js';\n     6→import { registerStatusCommand } from './commands/status.js';\n     7→import { registerOnboardCommand } from './commands/onboard.js';\n     8→import { registerTeardownCommand } from './commands/teardown.js';\n     9→import { registerStateCommand } from './commands/state.js';\n    10→import { registerSyncCommand } from './commands/sync.js';\n    11→import { registerCoverageCommand } from './commands/coverage.js';\n    12→import { registerDocHealthCommand } from './commands/doc-health.js';\n    13→import { registerStackCommand } from './commands/stack.js';\n    14→import { registerQueryCommand } from './commands/query.js';\n    15→import { registerRetroImportCommand } from './commands/retro-import.js';\n    16→import { registerGithubImportCommand } from './commands/github-import.js';\n    17→import { registerVerifyEnvCommand } from './commands/verify-env.js';\n    18→import { registerRetryCommand } from './commands/retry.js';\n    19→import { registerTimeoutReportCommand } from './commands/timeout-report.js';\n    20→import { registerValidateStateCommand } from './commands/validate-state.js';\n    21→import { registerValidateCommand } from './commands/validate.js';\n    22→import { registerProgressCommand } from './commands/progress.js';\n    23→\n    24→declare const __PKG_VERSION__: string;\n    25→const VERSION = typeof __PKG_VERSION__ !== 'undefined' ? __PKG_VERSION__ : '0.0.0-dev';\n    26→\n    27→export function createProgram(): Command {\n    28→  const program = new Command();\n    29→\n    30→  program\n    31→    .name('codeharness')\n    32→    .description('Makes autonomous coding agents produce software that actually works')\n    33→    .version(VERSION)\n    34→    .option('--json', 'Output in machine-readable JSON format');\n    35→\n    36→  registerInitCommand(program);\n    37→  registerBridgeCommand(program);\n    38→  registerRunCommand(program);\n    39→  registerVerifyCommand(program);\n    40→  registerStatusCommand(program);\n    41→  registerOnboardCommand(program);\n    42→  registerTeardownCommand(program);\n    43→  registerStateCommand(program);\n    44→  registerSyncCommand(program);\n    45→  registerCoverageCommand(program);\n    46→  registerDocHealthCommand(program);\n    47→  registerStackCommand(program);\n    48→  registerQueryCommand(program);\n    49→  registerRetroImportCommand(program);\n    50→  registerGithubImportCommand(program);\n    51→  registerVerifyEnvCommand(program);\n    52→  registerRetryCommand(program);\n    53→  registerTimeoutReportCommand(program);\n    54→  registerValidateStateCommand(program);\n    55→  registerValidateCommand(program);\n    56→  registerProgressCommand(program);\n    57→\n    58→  return program;\n    59→}\n    60→\n    61→// Only parse when running as CLI entry point, not when imported in tests\n    62→if (!process.env['VITEST']) {\n    63→  const program = createProgram();\n    64→  program.parse(process.argv);\n    65→}\n    66→"}]},"parent_tool_use_id":"toolu_01APL3Sm5JEakF5iK2mjDEd8","session_id":"f7a66acd-0cc1-40de-a592-d59e75273c0b","uuid":"8fe24176-2d75-4382-a85c-150874b1bd56","timestamp":"2026-03-20T05:53:35.765Z"}
