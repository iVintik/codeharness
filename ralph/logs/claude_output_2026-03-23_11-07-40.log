{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KtSE5pW8WfPY6WBMxL6hZ9","type":"tool_result","content":"    68в†’/** Detects the project type for verification strategy selection. */\n    69в†’export function detectProjectType(projectDir: string): ProjectType {\n    70в†’  const stack = detectStack(projectDir);\n    71в†’  // Prefer nodejs/python when the project has a buildable package вЂ” the npm tarball\n    72в†’  // or Python wheel includes all distributable files. Plugin-only detection is the\n    73в†’  // fallback for projects that are purely Claude Code plugins with no build artifact.\n    74в†’  if (stack === 'nodejs') return 'nodejs';\n    75в†’  if (stack === 'python') return 'python';\n    76в†’  if (stack === 'rust') return 'rust';\n    77в†’  if (existsSync(join(projectDir, '.claude-plugin', 'plugin.json'))) return 'plugin';\n    78в†’  return 'generic';\n    79в†’}\n    80в†’\n    81в†’/** Builds the verification Docker image with cache invalidation. */\n    82в†’export function buildVerifyImage(options: BuildOptions = {}): BuildResult {\n    83в†’  const projectDir = options.projectDir ?? process.cwd();\n    84в†’  if (!isDockerAvailable()) {\n    85в†’    throw new Error('Docker is not available. Install Docker and ensure the daemon is running.');\n    86в†’  }\n    87в†’  const projectType = detectProjectType(projectDir);\n    88в†’  const currentHash = computeDistHash(projectDir);\n    89в†’  if (projectType === 'generic' || projectType === 'plugin' || projectType === 'rust') {\n    90в†’    // Generic and plugin projects may not have dist/ вЂ” skip hash check\n    91в†’  } else if (!currentHash) {\n    92в†’    throw new Error('No dist/ directory found. Run your build command first (e.g., npm run build).');\n    93в†’  }\n    94в†’  if (currentHash) {\n    95в†’    const storedHash = getStoredDistHash(projectDir);\n    96в†’    if (storedHash === currentHash && dockerImageExists(IMAGE_TAG)) {\n    97в†’      return { imageTag: IMAGE_TAG, imageSize: getImageSize(IMAGE_TAG), buildTimeMs: 0, cached: true };\n    98в†’    }\n    99в†’  }\n   100в†’  const startTime = Date.now();\n   101в†’  if (projectType === 'nodejs') { buildNodeImage(projectDir); }\n   102в†’  else if (projectType === 'python') { buildPythonImage(projectDir); }\n   103в†’  else if (projectType === 'rust') { buildRustImage(projectDir); }\n   104в†’  else if (projectType === 'plugin') { buildPluginImage(projectDir); }\n   105в†’  else { buildGenericImage(projectDir); }\n   106в†’  if (currentHash) { storeDistHash(projectDir, currentHash); }\n   107в†’  return { imageTag: IMAGE_TAG, imageSize: getImageSize(IMAGE_TAG), buildTimeMs: Date.now() - startTime, cached: false };\n   108в†’}\n   109в†’\n   110в†’function buildNodeImage(projectDir: string): void {\n   111в†’  const packOutput = execFileSync('npm', ['pack', '--pack-destination', '/tmp'], {\n   112в†’    cwd: projectDir, stdio: 'pipe', timeout: 60_000,\n   113в†’  }).toString().trim();\n   114в†’  const lastLine = packOutput.split('\\n').pop()?.trim();\n   115в†’  if (!lastLine) throw new Error('npm pack produced no output вЂ” cannot determine tarball filename.');\n   116в†’  const tarballName = basename(lastLine);\n   117в†’  const tarballPath = join('/tmp', tarballName);\n   118в†’  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   119в†’  mkdirSync(buildContext, { recursive: true });\n   120в†’  try {\n   121в†’    cpSync(tarballPath, join(buildContext, tarballName));\n   122в†’    cpSync(resolveDockerfileTemplate(projectDir), join(buildContext, 'Dockerfile'));"}]},"parent_tool_use_id":"toolu_01QhGcCpAcaboC3HghX1odd7","session_id":"51b9d113-d480-4846-9e18-693f5f89566d","uuid":"64e23a7e-fe8a-4956-a2d9-8c18caec32b7","timestamp":"2026-03-23T07:13:37.651Z"}
