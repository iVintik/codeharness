Mock).toHaveBeenCalled();\n484\t    });\n485\t\n486\t    it('--resume resets circuit-breaker phase: triggered/reason/phase reset, score_history and evaluator_scores preserved', async () => {\n487\t      mockPaths({ '.claude': true });\n488\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n489\t      readWorkflowStateMock.mockReturnValue({\n490\t        workflow_name: 'implement -> verify',\n491\t        started: new Date().toISOString(),\n492\t        iteration: 5,\n493\t        phase: 'circuit-breaker',\n494\t        tasks_completed: ['implement:1', 'verify:1'],\n495\t        evaluator_scores: [\n496\t          { iteration: 1, passed: 3, failed: 2, unknown: 0, total: 5, timestamp: '2026-04-03T00:00:00.000Z' },\n497\t          { iteration: 2, passed: 3, failed: 2, unknown: 0, total: 5, timestamp: '2026-04-03T00:01:00.000Z' },\n498\t        ],\n499\t        circuit_breaker: {\n500\t          triggered: true,\n501\t          reason: 'Stagnation detected: no improvement for 2 consecutive iterations',\n502\t          score_history: [3, 3],\n503\t        },\n504\t        trace_ids: ['trace-1'],\n505\t      });\n506\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n507\t\n508\t      await runCommand(['--resume']);\n509\t\n510\t      expect(writeWorkflowStateMock).toHaveBeenCalledWith(\n511\t        expect.objectContaining({\n512\t          phase: 'idle',\n513\t          circuit_breaker: expect.objectContaining({\n514\t            triggered: false,\n515\t            reason: null,\n516\t            score_history: [3, 3],\n517\t          }),\n518\t          evaluator_scores: [\n519\t            { iteration: 1, passed: 3, failed: 2, unknown: 0, total: 5, timestamp: '2026-04-03T00:00:00.000Z' },\n520\t            { iteration: 2, passed: 3, failed: 2, unknown: 0, total: 5, timestamp: '2026-04-03T00:01:00.000Z' },\n521\t          ],\n522\t          tasks_completed: ['implement:1', 'verify:1'],\n523\t          iteration: 5,\n524\t        }),\n525\t        expect.any(String),\n526\t      );\n527\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Resuming after circuit breaker — previous findings preserved'));\n528\t      expect(executeWorkflowMock).toHaveBeenCalled();\n529\t    });\n530\t\n531\t    it('--resume with circuit-breaker logs appropriate info message', async () => {\n532\t      mockPaths({ '.claude': true });\n533\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n534\t      readWorkflowStateMock.mockReturnValue({\n535\t        workflow_name: '',\n536\t        started: '',\n537\t        iteration: 2,\n538\t        phase: 'circuit-breaker',\n539\t        tasks_completed: [],\n540\t        evaluator_scores: [],\n541\t        circuit_breaker: { triggered: true, reason: 'stagnation', score_history: [1] },\n542\t        trace_ids: [],\n543\t      });\n544\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n545\t\n546\t      await runCommand(['--resume']);\n547\t\n548\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Resuming after circuit breaker'));\n549\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('previous findings preserved'));\n550\t    });\n551\t\n552\t    it('--resume with completed phase still works as before (regression)', async () => {\n553\t      mockPaths({ '.claude': true });\n554\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n555\t      readWorkflowStateMock.mockReturnValue({\n556\t        workflow_name: 'implement -> verify',\n557\t        started: new Date().toISOString(),\n558\t        iteration: 3,\n559\t        phase: 'completed',\n560\t        tasks_completed: [],\n561\t        evaluator_scores: [],\n562\t        circuit_breaker: { triggered: false, reason: null, score_history: [] },\n563\t        trace_ids: [],\n564\t      });\n565\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n5