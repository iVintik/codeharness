 = { type: 'story-complete' as const, key: '1-1-foo', details: 'DONE — verified' };\n   600→      mockDriverInstance.parseOutput.mockReturnValueOnce(storyCompleteEvent);\n   601→\n   602→      const p = runCommand();\n   603→      await vi.waitFor(() => expect(mockDriverInstance.spawn).toHaveBeenCalled());\n   604→\n   605→      const stderr = mockDriverInstance._getStderrEmitter();\n   606→      stderr!.emit('data', Buffer.from('[SUCCESS] Story 1-1-foo: DONE — verified\\n'));\n   607→\n   608→      mockDriverInstance._getChildOnHandlers()['close'](0);\n   609→      await p;\n   610→\n   611→      expect(rendererAddMessageMock).toHaveBeenCalledWith({\n   612→        type: 'ok',\n   613→        key: '1-1-foo',\n   614→        message: 'DONE — verified',\n   615→      });\n   616→    });\n   617→\n   618→    it('dispatches story-failed events to renderer.addMessage', async () => {\n   619→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   620→      mockPaths({ '.claude': true });\n   621→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   622→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   623→\n   624→      const storyFailedEvent = { type: 'story-failed' as const, key: '2-1-bar', reason: 'exceeded retry limit' };\n   625→      mockDriverInstance.parseOutput.mockReturnValueOnce(storyFailedEvent);\n   626→\n   627→      const p = runCommand();\n   628→      await vi.waitFor(() => expect(mockDriverInstance.spawn).toHaveBeenCalled());\n   629→\n   630→      const stderr = mockDriverInstance._getStderrEmitter();\n   631→      stderr!.emit('data', Buffer.from('[WARN] Story 2-1-bar exceeded retry limit\\n'));\n   632→\n   633→      mockDriverInstance._getChildOnHandlers()['close'](0);\n   634→      await p;\n   635→\n   636→      expect(rendererAddMessageMock).toHaveBeenCalledWith({\n   637→        type: 'fail',\n   638→        key: '2-1-bar',\n   639→        message: 'exceeded retry limit',\n   640→      });\n   641→    });\n   642→\n   643→    it('dispatches iteration events to state tracker', async () => {\n   644→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   645→      mockPaths({ '.claude': true });\n   646→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   647→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   648→\n   649→      const iterationEvent = { type: 'iteration' as const, count: 5 };\n   650→      mockDriverInstance.parseOutput.mockReturnValueOnce(iterationEvent);\n   651→\n   652→      const p = runCommand();\n   653→      await vi.waitFor(() => expect(mockDriverInstance.spawn).toHaveBeenCalled());\n   654→\n   655→      const stderr = mockDriverInstance._getStderrEmitter();\n   656→      stderr!.emit('data', Buffer.from('[LOOP] iteration 5\\n'));\n   657→\n   658→      mockDriverInstance._getChildOnHandlers()['close'](0);\n   659→      await p;\n   660→\n   661→      // Iteration events don't call renderer.update or addMessage\n   662→      // They update internal state used by the polling interval\n   663→      expect(rendererUpdateMock).not.toHaveBeenCalled();\n   664→      expect(rendererAddMessageMock).not.toHaveBeenCalled();\n   665→    });\n   666→\n   667→    it('skips null events from driver.parseOutput (unrecognized lines)', async () => {\n   668→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   669→      mockPaths({ '.claude': true });\n   670→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   671→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   672→\n   673→      mockDriverInstance.parseOutput.mockReturnValue(null);\n   674→\n   675→      const p = runCommand();\n   676→      await vi.waitFor(() => expect(mockDriverInstance.spawn).toHaveBeenCalled());\n   677→\n   678→      const stdout = mockDriverInstance._getStdoutEmitter();\n   679→      stdout!.emit('data', Buffer.from('some unrecognized line\\n'));\n   680→\n   681→      mockDriverInstance._getChildOn