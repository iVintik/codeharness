alled();\n314\t      const config = executeWorkflowMock.mock.calls[0][0];\n315\t      expect(config.maxIterations).toBe(10);\n316\t      expect(config.runId).toMatch(/^run-\\d+$/);\n317\t      expect(config.workflow).toBeDefined();\n318\t      expect(config.agents).toBeDefined();\n319\t      expect(config.sprintStatusPath).toContain('sprint-status.yaml');\n320\t    });\n321\t\n322\t    it('exits 1 on workflow failure (AC #2)', async () => {\n323\t      mockPaths({ '.claude': true });\n324\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n325\t      executeWorkflowMock.mockResolvedValue({\n326\t        success: false,\n327\t        tasksCompleted: 1,\n328\t        storiesProcessed: 1,\n329\t        errors: [{ taskName: 'implement', storyKey: '1-1-story', code: 'UNKNOWN', message: 'dispatch failed' }],\n330\t        durationMs: 5000,\n331\t      });\n332\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n333\t\n334\t      await runCommand();\n335\t\n336\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Workflow failed'));\n337\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('dispatch failed'));\n338\t      expect(process.exitCode).toBe(1);\n339\t    });\n340\t\n341\t    it('exits 1 when executeWorkflow throws', async () => {\n342\t      mockPaths({ '.claude': true });\n343\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n344\t      executeWorkflowMock.mockRejectedValue(new Error('engine crashed'));\n345\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n346\t\n347\t      await runCommand();\n348\t\n349\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Workflow engine error'));\n350\t      expect(process.exitCode).toBe(1);\n351\t    });\n352\t\n353\t    it('exits 1 when workflow resolution fails', async () => {\n354\t      mockPaths({ '.claude': true });\n355\t      readSprintStatusMock.mockRet