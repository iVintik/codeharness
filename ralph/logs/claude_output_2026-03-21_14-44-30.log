{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RSahm88nJP6RmVEoZ51JKR","type":"tool_result","content":"     1→/**\n     2→ * Ink UI components — activity display (tools, thoughts, retry, messages).\n     3→ *\n     4→ * Split from ink-components.tsx to comply with NFR9 (max 300 lines per file).\n     5→ * Types are defined in ink-components.tsx and imported here.\n     6→ */\n     7→\n     8→import React from 'react';\n     9→import { Text, Box } from 'ink';\n    10→import { Spinner } from '@inkjs/ui';\n    11→import type { CompletedToolEntry, RetryInfo, StoryMessage } from './ink-components.js';\n    12→\n    13→// --- Message Styles ---\n    14→\n    15→const MESSAGE_STYLE: Record<StoryMessage['type'], { prefix: string; color: string }> = {\n    16→  ok: { prefix: '[OK]', color: 'green' },\n    17→  warn: { prefix: '[WARN]', color: 'yellow' },\n    18→  fail: { prefix: '[FAIL]', color: 'red' },\n    19→};\n    20→\n    21→// --- Components ---\n    22→\n    23→export function StoryMessageLine({ msg }: { msg: StoryMessage }) {\n    24→  const style = MESSAGE_STYLE[msg.type];\n    25→  return (\n    26→    <Box flexDirection=\"column\">\n    27→      <Text>\n    28→        <Text color={style.color} bold>{style.prefix}</Text>\n    29→        <Text>{` Story ${msg.key}: ${msg.message}`}</Text>\n    30→      </Text>\n    31→      {msg.details?.map((d, j) => (\n    32→        <Text key={j} dimColor>{`  └ ${d}`}</Text>\n    33→      ))}\n    34→    </Box>\n    35→  );\n    36→}\n    37→\n    38→export function CompletedTool({ entry }: { entry: CompletedToolEntry }) {\n    39→  const argsSummary = entry.args.length > 60\n    40→    ? entry.args.slice(0, 60) + '…'\n    41→    : entry.args;\n    42→  return (\n    43→    <Text wrap=\"truncate-end\">\n    44→      <Text color=\"green\">{'✓ '}</Text>\n    45→      <Text dimColor>{'['}</Text>\n    46→      <Text>{entry.name}</Text>\n    47→      <Text dimColor>{'] '}</Text>\n    48→      <Text dimColor>{argsSummary}</Text>\n    49→    </Text>\n    50→  );\n    51→}\n    52→\n    53→/** Show only the last N completed tools to keep output compact. */\n    54→const VISIBLE_COMPLETED_TOOLS = 5;\n    55→\n    56→export function CompletedTools({ tools }: { tools: CompletedToolEntry[] }) {\n    57→  const visible = tools.slice(-VISIBLE_COMPLETED_TOOLS);\n    58→  const hidden = tools.length - visible.length;\n    59→  return (\n    60→    <Box flexDirection=\"column\">\n    61→      {hidden > 0 && <Text dimColor>{`  … ${hidden} earlier tools`}</Text>}\n    62→      {visible.map((entry, i) => (\n    63→        <CompletedTool key={i} entry={entry} />\n    64→      ))}\n    65→    </Box>\n    66→  );\n    67→}\n    68→\n    69→export function ActiveTool({ name }: { name: string }) {\n    70→  return (\n    71→    <Box>\n    72→      <Text color=\"yellow\">{'⚡ '}</Text>\n    73→      <Text dimColor>{'['}</Text>\n    74→      <Text bold>{name}</Text>\n    75→      <Text dimColor>{'] '}</Text>\n    76→      <Spinner label=\"\" />\n    77→    </Box>\n    78→  );\n    79→}\n    80→\n    81→export function LastThought({ text }: { text: string }) {\n    82→  return (\n    83→    <Text wrap=\"truncate-end\">\n    84→      <Text>{'💭 '}</Text>\n    85→      <Text dimColor>{text}</Text>\n    86→    </Text>\n    87→  );\n    88→}\n    89→\n    90→export function RetryNotice({ info }: { info: RetryInfo }) {\n    91→  return (\n    92→    <Text color=\"yellow\">\n    93→      {'⏳ API retry '}\n    94→      {info.attempt}\n    95→      {' (waiting '}\n    96→      {info.delay}\n    97→      {'ms)'}\n    98→    </Text>\n    99→  );\n   100→}\n   101→"}]},"parent_tool_use_id":"toolu_01AJ1yqSdiBA5zE85QQabyAz","session_id":"3e8c45fc-a757-4d77-9a55-f32a41bfdb65","uuid":"05b91c29-ba39-4ef2-8326-1800a0e68f81","timestamp":"2026-03-21T10:58:00.009Z"}
