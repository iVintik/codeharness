g file', () => {\n    44ŌåÆ    writeFileSync(join(testDir, 'package.json'), JSON.stringify({ name: 'test' }));\n    45ŌåÆ    writeFileSync(join(testDir, 'vitest.config.ts'), 'export default {}');\n    46ŌåÆ\n    47ŌåÆ    const result = detectCoverageTool(testDir);\n    48ŌåÆ    expect(result.tool).toBe('c8');\n    49ŌåÆ    expect(result.reportFormat).toBe('vitest-json');\n    50ŌåÆ  });\n    51ŌåÆ\n    52ŌåÆ  it('detects c8 from @vitest/coverage-v8 in devDependencies', () => {\n    53ŌåÆ    writeFileSync(\n    54ŌåÆ      join(testDir, 'package.json'),\n    55ŌåÆ      JSON.stringify({\n    56ŌåÆ        name: 'test',\n    57ŌåÆ        devDependencies: { '@vitest/coverage-v8': '^1.0.0' },\n    58ŌåÆ      }),\n    59ŌåÆ    );\n    60ŌåÆ\n    61ŌåÆ    const result = detectCoverageTool(testDir);\n    62ŌåÆ    expect(result.tool).toBe('c8');\n    63ŌåÆ  });\n    64ŌåÆ\n    65ŌåÆ  it('detects c8 from @vitest/coverage-istanbul in devDependencies', () => {\n    66ŌåÆ    writeFileSync(\n    67ŌåÆ      join(testDir, 'package.json'),\n    68ŌåÆ      JSON.stringify({\n    69ŌåÆ        name: 'test',\n    70ŌåÆ        devDependencies: { '@vitest/coverage-istanbul': '^1.0.0' },\n    71ŌåÆ      }),\n    72ŌåÆ    );\n    73ŌåÆ\n    74ŌåÆ    const result = detectCoverageTool(testDir);\n    75ŌåÆ    expect(result.tool).toBe('c8');\n    76ŌåÆ  });\n    77ŌåÆ\n    78ŌåÆ  it('detects c8 from c8 in devDependencies', () => {\n    79ŌåÆ    writeFileSync(\n    80ŌåÆ      join(testDir, 'package.json'),\n    81ŌåÆ      JSON.stringify({\n    82ŌåÆ        name: 'test',\n    83ŌåÆ        devDependencies: { c8: '^7.0.0' },\n    84ŌåÆ      }),\n    85ŌåÆ    );\n    86ŌåÆ\n    87ŌåÆ    const result = detectCoverageTool(testDir);\n    88ŌåÆ    expect(result.tool).toBe('c8');\n    89ŌåÆ  });\n    90ŌåÆ\n    91ŌåÆ  it('detects jest coverage for jest projects', () => {\n    92ŌåÆ    writeFileSync(\n    93ŌåÆ      join(testDir, 'package.json'),\n    94ŌåÆ      JSON.stringify({\n    95ŌåÆ        name: 'test