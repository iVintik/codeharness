{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RsTgQxtQxLPZiyyW6ffW2q","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { existsSync } from 'node:fs';\n3\timport { resolve } from 'node:path';\n4\timport { parseWorkflow, type ResolvedWorkflow, type LoopBlock } from '../workflow-parser.js';\n5\t\n6\tconst defaultWorkflowPath = resolve(__dirname, '../../../templates/workflows/default.yaml');\n7\t\n8\tdescribe('default embedded workflow', () => {\n9\t  describe('file existence (AC #1)', () => {\n10\t    it('templates/workflows/default.yaml exists on disk', () => {\n11\t      expect(existsSync(defaultWorkflowPath)).toBe(true);\n12\t    });\n13\t  });\n14\t\n15\t  describe('schema validation via parseWorkflow (AC #4)', () => {\n16\t    it('passes schema validation and returns a ResolvedWorkflow', () => {\n17\t      const result = parseWorkflow(defaultWorkflowPath);\n18\t      expect(result).toBeDefined();\n19\t      expect(result.tasks).toBeDefined();\n20\t      expect(result.flow).toBeDefined();\n21\t    });\n22\t  });\n23\t\n24\t  describe('task definitions (AC #2)', () => {\n25\t    let workflow: ResolvedWorkflow;\n26\t\n27\t    it('defines implement, verify, and retry tasks', () => {\n28\t      workflow = parseWorkflow(defaultWorkflowPath);\n29\t      const taskNames = Object.keys(workflow.tasks);\n30\t      expect(taskNames).toContain('implement');\n31\t      expect(taskNames).toContain('verify');\n32\t      expect(taskNames).toContain('retry');\n33\t    });\n34\t\n35\t    it('implement task has correct properties', () => {\n36\t      workflow = parseWorkflow(defaultWorkflowPath);\n37\t      const task = workflow.tasks.implement;\n38\t      expect(task.agent).toBe('dev');\n39\t      expect(task.scope).toBe('per-story');\n40\t      expect(task.session).toBe('fresh');\n41\t      expect(task.source_access).toBe(true);\n42\t    });\n43\t\n44\t    it('verify task has source_access false and scope per-run (AC #5)', () => {\n45\t      workflow = parseWorkflow(defaultWorkflowPath);\n46\t      const task = workflow.tasks.verify;\n47\t      expect(task.agent).toBe('evaluator');\n48\t      expect(task.scope).toBe('per-run');\n49\t      expect(task.session).toBe('fresh');\n50\t      expect(task.source_access).toBe(false);\n51\t    });\n52\t\n53\t    it('retry task has source_access true and scope per-story (AC #6)', () => {\n54\t      workflow = parseWorkflow(defaultWorkflowPath);\n55\t      const task = workflow.tasks.retry;\n56\t      expect(task.agent).toBe('dev');\n57\t      expect(task.scope).toBe('per-story');\n58\t      expect(task.session).toBe('fresh');\n59\t      expect(task.source_access).toBe(true);\n60\t    });\n61\t  });\n62\t\n63\t  describe('flow structure (AC #3)', () => {\n64\t    it('flow order is implement, verify, then loop:[retry, verify]', () => {\n65\t      const workflow = parseWorkflow(defaultWorkflowPath);\n66\t      expect(workflow.flow).toHaveLength(3);\n67\t      expect(workflow.flow[0]).toBe('implement');\n68\t      expect(workflow.flow[1]).toBe('verify');\n69\t\n70\t      const loopStep = workflow.flow[2] as LoopBlock;\n71\t      expect(loopStep).toHaveProperty('loop');\n72\t      expect(loopStep.loop).toEqual(['retry', 'verify']);\n73\t    });\n74\t  });\n75\t});\n76\t"}]},"parent_tool_use_id":"toolu_01RY7q13vLychfMFt1hid4aL","session_id":"819d45f9-7092-4252-80a7-82eddd3933c2","uuid":"daa89b5e-1a69-494a-8e5a-f9d30061d5ba","timestamp":"2026-04-02T14:10:17.348Z"}
