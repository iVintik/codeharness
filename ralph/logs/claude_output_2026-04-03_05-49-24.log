{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SeFwYtZBq4RY2871xSR9xP","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n2\timport { mkdtempSync, rmSync, mkdirSync, writeFileSync } from 'node:fs';\n3\timport { tmpdir } from 'node:os';\n4\timport { join } from 'node:path';\n5\timport { Command } from 'commander';\n6\t\n7\t// Mock issue-tracker to control the directory used\n8\tvi.mock('../../lib/issue-tracker.js', async (importOriginal) => {\n9\t  const actual = await importOriginal() as Record<string, unknown>;\n10\t  return actual;\n11\t});\n12\t\n13\timport { registerIssueCommand } from '../issue.js';\n14\timport { readIssues, writeIssues, type IssuesFile } from '../../lib/issue-tracker.js';\n15\t\n16\tlet testDir: string;\n17\tlet logSpy: ReturnType<typeof vi.spyOn>;\n18\t\n19\tbeforeEach(() => {\n20\t  testDir = mkdtempSync(join(tmpdir(), 'ch-issue-cmd-test-'));\n21\t  logSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n22\t  // Override process.cwd to use our test dir\n23\t  vi.spyOn(process, 'cwd').mockReturnValue(testDir);\n24\t  process.exitCode = undefined;\n25\t});\n26\t\n27\tafterEach(() => {\n28\t  rmSync(testDir, { recursive: true, force: true });\n29\t  logSpy.mockRestore();\n30\t  vi.restoreAllMocks();\n31\t  process.exitCode = undefined;\n32\t});\n33\t\n34\tfunction makeProgram(): Command {\n35\t  const program = new Command();\n36\t  program.option('--json', 'JSON output');\n37\t  registerIssueCommand(program);\n38\t  return program;\n39\t}\n40\t\n41\tasync function run(args: string[]): Promise<void> {\n42\t  const program = makeProgram();\n43\t  program.exitOverride(); // throw instead of process.exit\n44\t  try {\n45\t    await program.parseAsync(['node', 'codeharness', ...args]);\n46\t  } catch {\n47\t    // Commander may throw on exitOverride — that's fine\n48\t  }\n49\t}\n50\t\n51\tdescribe('issue create', () => {\n52\t  it('creates issues.yaml and outputs OK', async () => {\n53\t    await run(['issue', 'create', 'Fix Docker timeout', '--priority', 'high', '--source', 'retro-sprint-1']);\n54\t\n55\t    const data = readIssues(testDir);\n56\t    expect(data.issues).toHaveLength(1);\n57\t    expect(data.issues[0].title).toBe('Fix Docker timeout');\n58\t    expect(data.issues[0].priority).toBe('high');\n59\t    expect(data.issues[0].source).toBe('retro-sprint-1');\n60\t    expect(logSpy).toHaveBeenCalledWith(expect.stringContaining('[OK]'));\n61\t  });\n62\t\n63\t  it('uses default priority and source', async () => {\n64\t    await run(['issue', 'create', 'Simple bug']);\n65\t\n66\t    const data = readIssues(testDir);\n67\t    expect(data.issues[0].priority).toBe('medium');\n68\t    expect(data.issues[0].source).toBe('manual');\n69\t  });\n70\t});\n71\t\n72\tdescribe('issue list', () => {\n73\t  it('displays issues', async () => {\n74\t    // Pre-populate\n75\t    const issueData: IssuesFile = {\n76\t      issues: [\n77\t        { id: 'issue-001', title: 'Bug A', source: 'manual', priority: 'high', status: 'backlog', created_at: '2026-01-01T00:00:00.000Z' },\n78\t      ],\n79\t    };\n80\t    mkdirSync(join(testDir, '.codeharness'), { recursive: true });\n81\t    writeIssues(issueData, testDir);\n82\t\n83\t    await run(['issue', 'list']);\n84\t\n85\t    expect(logSpy).toHaveBeenCalledWith(expect.stringContaining('issue-001'));\n86\t    expect(logSpy).toHaveBeenCalledWith(expect.stringContaining('Bug A'));\n87\t  });\n88\t\n89\t  it('with --json outputs JSON', async () => {\n90\t    const issueData: IssuesFile = {\n91\t      issues: [\n92\t        { id: 'issue-001', title: 'Bug A', source: 'manual', priority: 'high', status: 'backlog', created_at: '2026-01-01T00:00:00.000Z' },\n93\t      ],\n94\t    };\n95\t    mkdirSync(join(testDir, '.codeharness'), { recursive: true });\n96\t    writeIssues(issueData, testDir);\n97\t\n98\t    await run(['--json', 'issue', 'list']);\n99\t\n100\t    const lastCall = logSpy.mock.calls[logSpy.mock.calls.length - 1][0] as string;\n101\t    const parsed = JSON.parse(lastCall);\n102\t    expect(parsed.issues).toHaveLength(1);\n103\t    expect(parsed.issues[0].id).toBe('issue-001');\n104\t  });\n105\t\n106\t  it('with no issues prints info message', async () => {\n107\t    await run(['issue', 'list']);\n108\t\n109\t    expect(logSpy).toHaveBeenCalledWith(expect.stringContaining('No issues found'));\n110\t  });\n111\t});\n112\t\n113\tdescribe('issue close', () => {\n114\t  it('updates status to done', async () => {\n115\t    // Create an issue first\n116\t    await run(['issue', 'create', 'To close']);\n117\t\n118\t    await run(['issue', 'close', 'issue-001']);\n119\t\n120\t    const data = readIssues(testDir);\n121\t    expect(data.issues[0].status).toBe('done');\n122\t    // The last log should be OK\n123\t    const okCalls = logSpy.mock.calls.filter((c) => (c[0] as string).includes('[OK]'));\n124\t    expect(okCalls.length).toBeGreaterThanOrEqual(1);\n125\t  });\n126\t\n127\t  it('with bad id returns error', async () => {\n128\t    await run(['issue', 'create', 'Exists']);\n129\t\n130\t    await run(['issue', 'close', 'issue-999']);\n131\t\n132\t    expect(logSpy).toHaveBeenCalledWith(expect.stringContaining('[FAIL]'));\n133\t    expect(process.exitCode).toBe(1);\n134\t  });\n135\t});\n136\t"}]},"parent_tool_use_id":"toolu_01CMZbq8RrvXCKSwd18t2Hto","session_id":"2800a04b-8151-4215-bf66-1f43973b9365","uuid":"85d8d628-375a-4d65-8394-55bd78af7ed4","timestamp":"2026-04-03T02:00:57.135Z"}
