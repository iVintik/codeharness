{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CFk3rDWPgWLZz55DU7YFox","type":"tool_result","content":"     1→/**\n     2→ * Documentation scaffolding for project initialization.\n     3→ * Generates AGENTS.md, docs/ directory structure, and README.md.\n     4→ */\n     5→\n     6→import { existsSync, readFileSync } from 'node:fs';\n     7→import { join, basename } from 'node:path';\n     8→import { ok as okOutput } from '../../lib/output.js';\n     9→import { generateFile } from '../../lib/templates.js';\n    10→import { readmeTemplate } from '../../templates/readme.js';\n    11→import type { Result } from '../../types/result.js';\n    12→import { ok, fail } from '../../types/result.js';\n    13→import type { InitDocumentationResult } from './types.js';\n    14→\n    15→const DO_NOT_EDIT_HEADER = '<!-- DO NOT EDIT MANUALLY -->\\n';\n    16→\n    17→export function getProjectName(projectDir: string): string {\n    18→  try {\n    19→    const pkgPath = join(projectDir, 'package.json');\n    20→    if (existsSync(pkgPath)) {\n    21→      const pkg = JSON.parse(readFileSync(pkgPath, 'utf-8')) as Record<string, unknown>;\n    22→      if (pkg.name && typeof pkg.name === 'string') {\n    23→        return pkg.name;\n    24→      }\n    25→    }\n    26→  } catch {\n    27→    // Fall through to Cargo.toml check\n    28→  }\n    29→\n    30→  // Cargo.toml fallback for Rust projects\n    31→  try {\n    32→    const cargoPath = join(projectDir, 'Cargo.toml');\n    33→    if (existsSync(cargoPath)) {\n    34→      const content = readFileSync(cargoPath, 'utf-8');\n    35→      const packageMatch = content.match(/\\[package\\]([\\s\\S]*?)(?=\\n\\[|$)/s);\n    36→      if (packageMatch) {\n    37→        const nameMatch = packageMatch[1].match(/^\\s*name\\s*=\\s*[\"']([^\"']+)[\"']/m);\n    38→        if (nameMatch) {\n    39→          return nameMatch[1];\n    40→        }\n    41→      }\n    42→    }\n    43→  } catch {\n    44→    // Fall through to basename\n    45→  }\n    46→\n    47→  return basename(projectDir);\n    48→}\n    49→\n    50→export function getStackLabel(stack: string | string[] | null): string {\n    51→  if (Array.isArray(stack)) {\n    52→    if (stack.length === 0) return 'Unknown';\n    53→    return stack.map(s => getStackLabel(s)).join(' + ');\n    54→  }\n    55→  if (stack === 'nodejs') return 'Node.js (package.json)';\n    56→  if (stack === 'python') return 'Python';\n    57→  if (stack === 'rust') return 'Rust (Cargo.toml)';\n    58→  return 'Unknown';\n    59→}\n    60→\n    61→export function getCoverageTool(stack: string | null): 'c8' | 'coverage.py' | 'cargo-tarpaulin' | 'unknown' {\n    62→  if (stack === 'python') return 'coverage.py';\n    63→  if (stack === 'rust') return 'cargo-tarpaulin';\n    64→  return 'c8';\n    65→}\n    66→\n    67→export function generateAgentsMdContent(projectDir: string, stack: string | null): string {\n    68→  const projectName = basename(projectDir);\n    69→  const stackLabel = stack === 'nodejs' ? 'Node.js' : stack === 'python' ? 'Python' : stack === 'rust' ? 'Rust' : 'Unknown';\n    70→\n    71→  const lines = [\n    72→    `# ${projectName}`,\n    73→    '',\n    74→    '## Stack',\n    75→    '',\n    76→    `- **Language/Runtime:** ${stackLabel}`,\n    77→    '',\n    78→    '## Build & Test Commands',\n    79→    '',\n    80→  ];\n    81→\n    82→  if (stack === 'nodejs') {\n    83→    lines.push(\n    84→      '```bash',\n    85→      'npm install    # Install dependencies',\n    86→      'npm run build  # Build the project',\n    87→      'npm test       # Run tests',\n    88→      '```',\n    89→    );\n    90→  } else if (stack === 'python') {\n    91→    lines.push(\n    92→      '```bash',\n    93→      'pip install -r requirements.txt  # Install dependencies',\n    94→      'python -m pytest                 # Run tests',\n    95→      '```',\n    96→    );\n    97→  } else if (stack === 'rust') {\n    98→    lines.push(\n    99→      '```bash',\n   100→      'cargo build    # Build the project',\n   101→      'cargo test     # Run tests',\n   102→      'cargo tarpaulin --out json  # Run coverage',\n   103→      '```',\n   104→    );\n   105→  } else {\n   106→    lines.push('```bash', '# No recognized stack — add build/test commands here', '```');\n   107→  }\n   108→\n   109→  lines.push(\n   110→    '',\n   111→    '## Project Structure',\n   112→    '',\n   113→    '```',\n   114→    `${projectName}/`,\n   115→    '├── src/           # Source code',\n   116→    '├── tests/         # Test files',\n   117→    '├── docs/          # Documentation',\n   118→    '└── .claude/       # Codeharness state',\n   119→    '```',\n   120→    '',\n   121→    '## Conventions',\n   122→    '',\n   123→    '- All changes must pass tests before commit',\n   124→    '- Maintain test coverage targets',\n   125→    '- Follow existing code style and patterns',\n   126→    '',\n   127→  );\n   128→\n   129→  return lines.join('\\n');\n   130→}\n   131→\n   132→export function generateDocsIndexContent(): string {\n   133→  return [\n   134→    '# Project Documentation',\n   135→    '',\n   136→    '## Planning Artifacts',\n   137→    '- [Product Requirements](../_bmad-output/planning-artifacts/prd.md)',\n   138→    '- [Architecture](../_bmad-output/planning-artifacts/architecture.md)',\n   139→    '- [Epics & Stories](../_bmad-output/planning-artifacts/epics.md)',\n   140→    '',\n   141→    '## Execution',\n   142→    '- [Active Exec Plans](exec-plans/active/)',\n   143→    '- [Completed Exec Plans](exec-plans/completed/)',\n   144→    '',\n   145→    '## Quality',\n   146→    '- [Quality Reports](quality/)',\n   147→    '- [Generated Reports](generated/)',\n   148→    '',\n   149→  ].join('\\n');\n   150→}\n   151→\n   152→interface ScaffoldDocsOptions {\n   153→  readonly projectDir: string;\n   154→  readonly stack: string | null;\n   155→  readonly isJson: boolean;\n   156→}\n   157→\n   158→export async function scaffoldDocs(opts: ScaffoldDocsOptions): Promise<Result<InitDocumentationResult>> {\n   159→  try {\n   160→    let agentsMd: 'created' | 'exists' | 'skipped' = 'skipped';\n   161→    let docsScaffold: 'created' | 'exists' | 'skipped' = 'skipped';\n   162→    let readme: 'created' | 'exists' | 'skipped' = 'skipped';\n   163→\n   164→    // AGENTS.md\n   165→    const agentsMdPath = join(opts.projectDir, 'AGENTS.md');\n   166→    if (!existsSync(agentsMdPath)) {\n   167→      const content = generateAgentsMdContent(opts.projectDir, opts.stack);\n   168→      generateFile(agentsMdPath, content);\n   169→      agentsMd = 'created';\n   170→    } else {\n   171→      agentsMd = 'exists';\n   172→    }\n   173→\n   174→    // docs/ scaffold\n   175→    const docsDir = join(opts.projectDir, 'docs');\n   176→    if (!existsSync(docsDir)) {\n   177→      generateFile(join(docsDir, 'index.md'), generateDocsIndexContent());\n   178→      generateFile(join(docsDir, 'exec-plans', 'active', '.gitkeep'), '');\n   179→      generateFile(join(docsDir, 'exec-plans', 'completed', '.gitkeep'), '');\n   180→      generateFile(join(docsDir, 'quality', '.gitkeep'), DO_NOT_EDIT_HEADER);\n   181→      generateFile(join(docsDir, 'generated', '.gitkeep'), DO_NOT_EDIT_HEADER);\n   182→      docsScaffold = 'created';\n   183→    } else {\n   184→      docsScaffold = 'exists';\n   185→    }\n   186→\n   187→    // README.md\n   188→    const readmePath = join(opts.projectDir, 'README.md');\n   189→    if (!existsSync(readmePath)) {\n   190→      let cliHelpOutput = '';\n   191→      try {\n   192→        const { execFileSync } = await import('node:child_process');\n   193→        cliHelpOutput = execFileSync(process.execPath, [process.argv[1], '--help'], {\n   194→          stdio: 'pipe',\n   195→          timeout: 10_000,\n   196→        }).toString();\n   197→      } catch {\n   198→        cliHelpOutput = 'Run: codeharness --help';\n   199→      }\n   200→\n   201→      const readmeContent = readmeTemplate({\n   202→        projectName: getProjectName(opts.projectDir),\n   203→        stack: opts.stack,\n   204→        cliHelpOutput,\n   205→      });\n   206→      generateFile(readmePath, readmeContent);\n   207→      readme = 'created';\n   208→    } else {\n   209→      readme = 'exists';\n   210→    }\n   211→\n   212→    const result: InitDocumentationResult = { agents_md: agentsMd, docs_scaffold: docsScaffold, readme };\n   213→\n   214→    if (!opts.isJson) {\n   215→      if (result.agents_md === 'created' || result.docs_scaffold === 'created') {\n   216→        okOutput('Documentation: AGENTS.md + docs/ scaffold created');\n   217→      }\n   218→      if (result.readme === 'created') {\n   219→        okOutput('Documentation: README.md created');\n   220→      }\n   221→    }\n   222→\n   223→    return ok(result);\n   224→  } catch (err) {\n   225→    const message = err instanceof Error ? err.message : String(err);\n   226→    return fail(`Documentation scaffold failed: ${message}`);\n   227→  }\n   228→}\n   229→"}]},"parent_tool_use_id":"toolu_01RW3DvRwuMditE8CiVokyWA","session_id":"46c7b24e-5b3f-4eb1-bc5a-20f6a0336cfe","uuid":"381c77bd-17b6-4f87-ba0b-2548f07748e1","timestamp":"2026-03-23T14:56:16.027Z"}
