{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FYEUtdAYrKZ3cX1ejW2NHc","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';\n2\timport { mkdtempSync, mkdirSync, writeFileSync, rmSync, existsSync } from 'node:fs';\n3\timport { tmpdir } from 'node:os';\n4\timport { join } from 'node:path';\n5\timport { Command } from 'commander';\n6\timport { registerStatsCommand } from '../stats.js';\n7\t\n8\tlet testDir: string;\n9\tlet originalCwd: string;\n10\t\n11\tbeforeEach(() => {\n12\t  testDir = mkdtempSync(join(tmpdir(), 'ch-cmd-stats-'));\n13\t  originalCwd = process.cwd();\n14\t  process.chdir(testDir);\n15\t});\n16\t\n17\tafterEach(() => {\n18\t  process.chdir(originalCwd);\n19\t  rmSync(testDir, { recursive: true, force: true });\n20\t});\n21\t\n22\tfunction createCli(): Command {\n23\t  const program = new Command();\n24\t  program.option('--json', 'JSON output');\n25\t  registerStatsCommand(program);\n26\t  return program;\n27\t}\n28\t\n29\tasync function runCli(args: string[]): Promise<{ stdout: string; exitCode: number | undefined }> {\n30\t  const logs: string[] = [];\n31\t  const consoleSpy = vi.spyOn(console, 'log').mockImplementation((...a: unknown[]) => {\n32\t    logs.push(a.map(String).join(' '));\n33\t  });\n34\t  process.exitCode = undefined;\n35\t\n36\t  const program = createCli();\n37\t  await program.parseAsync(['node', 'codeharness', ...args]);\n38\t\n39\t  consoleSpy.mockRestore();\n40\t  const exitCode = process.exitCode;\n41\t  process.exitCode = undefined;\n42\t\n43\t  return { stdout: logs.join('\\n'), exitCode };\n44\t}\n45\t\n46\tfunction createLogDir(): string {\n47\t  const logsDir = join(testDir, 'session-logs');\n48\t  mkdirSync(logsDir, { recursive: true });\n49\t  return logsDir;\n50\t}"}]},"parent_tool_use_id":"toolu_0188XVEoVFKE3hey9xp8FV9P","session_id":"cf16e575-8267-4c58-a992-20b07458710f","uuid":"7b029cb5-9950-4db1-89fd-f932d0a1147a","timestamp":"2026-04-03T13:25:34.935Z"}
