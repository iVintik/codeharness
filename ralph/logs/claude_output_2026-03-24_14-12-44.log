{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012nRwRroLSrZ3UrEYJPkwyE","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n     2→import { mkdtempSync, rmSync, writeFileSync, readFileSync } from 'node:fs';\n     3→import { tmpdir } from 'node:os';\n     4→import { join } from 'node:path';\n     5→import { Command } from 'commander';\n     6→import { registerRetryCommand } from '../retry.js';\n     7→import { retriesPath, flaggedPath } from '../../lib/retry-state.js';\n     8→\n     9→// The retry command uses 'ralph' as its dir. We need to create that inside\n    10→// the temp dir and chdir to the temp dir.\n    11→let testDir: string;\n    12→let ralphDir: string;\n    13→let originalCwd: string;\n    14→\n    15→beforeEach(() => {\n    16→  testDir = mkdtempSync(join(tmpdir(), 'ch-retry-cmd-'));\n    17→  ralphDir = join(testDir, 'ralph');\n    18→  const { mkdirSync } = require('node:fs');\n    19→  mkdirSync(ralphDir, { recursive: true });\n    20→  originalCwd = process.cwd();\n    21→  process.chdir(testDir);\n    22→});\n    23→\n    24→afterEach(() => {\n    25→  process.chdir(originalCwd);\n    26→  rmSync(testDir, { recursive: true, force: true });\n    27→  vi.restoreAllMocks();\n    28→});\n    29→\n    30→function createCli(): Command {\n    31→  const program = new Command();\n    32→  program.option('--json', 'JSON output');\n    33→  registerRetryCommand(program);\n    34→  return program;\n    35→}\n    36→\n    37→async function runCli(args: string[]): Promise<{ stdout: string }> {\n    38→  const logs: string[] = [];\n    39→  const consoleSpy = vi.spyOn(console, 'log').mockImplementation((...a: unknown[]) => {\n    40→    logs.push(a.map(String).join(' '));\n    41→  });\n    42→\n    43→  const program = createCli();\n    44→  await program.parseAsync(['node', 'codeharness', ...args]);\n    45→\n    46→  consoleSpy.mockRestore();\n    47→  return { stdout: logs.join('\\n') };\n    48→}\n    49→\n    50→// ─── --status ─────────────────────────────────────────────────────────────────\n    51→\n    52→describe('retry --status', () => {\n    53→  it('shows \"No retry entries.\" when no files exist', async () => {\n    54→    const { stdout } = await runCli(['retry', '--status']);\n    55→    expect(stdout).toContain('No retry entries.');\n    56→  });\n    57→\n    58→  it('shows table with retry counts and flagged status', async () => {\n    59→    writeFileSync(retriesPath(ralphDir), 'story-a=3\\nstory-b=1\\n');\n    60→    writeFileSync(flaggedPath(ralphDir), 'story-a\\n');\n    61→\n    62→    const { stdout } = await runCli(['retry', '--status']);\n    63→    expect(stdout).toContain('story-a');\n    64→    expect(stdout).toContain('3');\n    65→    expect(stdout).toContain('yes');\n    66→    expect(stdout).toContain('story-b');\n    67→    expect(stdout).toContain('1');\n    68→  });\n    69→\n    70→  it('includes flagged-only stories (no retry entry)', async () => {\n    71→    writeFileSync(flaggedPath(ralphDir), 'story-c\\n');\n    72→\n    73→    const { stdout } = await runCli(['retry', '--status']);\n    74→    expect(stdout).toContain('story-c');\n    75→    expect(stdout).toContain('yes');\n    76→  });\n    77→\n    78→  it('shows header line', async () => {\n    79→    writeFileSync(retriesPath(ralphDir), 'story-a=1\\n');\n    80→\n    81→    const { stdout } = await runCli(['retry', '--status']);\n    82→    expect(stdout).toContain('Story');\n    83→    expect(stdout).toContain('Retries');\n    84→    expect(stdout).toContain('Flagged');\n    85→  });\n    86→});\n    87→\n    88→// ─── --status --json ──────────────────────────────────────────────────────────\n    89→\n    90→describe('retry --status --json', () => {\n    91→  it('outputs JSON with entries', async () => {\n    92→    writeFileSync(retriesPath(ralphDir), 'story-a=3\\nstory-b=1\\n');\n    93→    writeFileSync(flaggedPath(ralphDir), 'story-a\\n');\n    94→\n    95→    const { stdout } = await runCli(['--json', 'retry', '--status']);\n    96→    const parsed = JSON.parse(stdout);\n    97→    expect(parsed.status).toBe('ok');\n    98→    expect(parsed.entries['story-a']).toEqual({ count: 3, flagged: true });\n    99→    expect(parsed.entries['story-b']).toEqual({ count: 1, flagged: false });\n   100→  });\n   101→\n   102→  it('outputs JSON with empty entries when no data', async () => {\n   103→    const { stdout } = await runCli(['--json', 'retry', '--status']);\n   104→    const parsed = JSON.parse(stdout);\n   105→    expect(parsed.status).toBe('ok');\n   106→    expect(parsed.entries).toEqual({});\n   107→  });\n   108→\n   109→  it('includes flagged-only stories in JSON', async () => {\n   110→    writeFileSync(flaggedPath(ralphDir), 'story-x\\n');\n   111→\n   112→    const { stdout } = await runCli(['--json', 'retry', '--status']);\n   113→    const parsed = JSON.parse(stdout);\n   114→    expect(parsed.entries['story-x']).toEqual({ count: 0, flagged: true });\n   115→  });\n   116→});\n   117→\n   118→// ─── --reset ──────────────────────────────────────────────────────────────────\n   119→\n   120→describe('retry --reset', () => {\n   121→  it('clears all retries and flagged stories', async () => {\n   122→    writeFileSync(retriesPath(ralphDir), 'story-a=3\\nstory-b=1\\n');\n   123→    writeFileSync(flaggedPath(ralphDir), 'story-a\\n');\n   124→\n   125→    const { stdout } = await runCli(['retry', '--reset']);\n   126→    expect(stdout).toContain('[OK] All retry counters and flagged stories cleared');\n   127→    expect(readFileSync(retriesPath(ralphDir), 'utf-8')).toBe('');\n   128→    expect(readFileSync(flaggedPath(ralphDir), 'utf-8')).toBe('');\n   129→  });\n   130→\n   131→  it('JSON output for reset all', async () => {\n   132→    const { stdout } = await runCli(['--json', 'retry', '--reset']);\n   133→    const parsed = JSON.parse(stdout);\n   134→    expect(parsed.status).toBe('ok');\n   135→    expect(parsed.action).toBe('reset_all');\n   136→  });\n   137→});\n   138→\n   139→// ─── --reset --story ──────────────────────────────────────────────────────────\n   140→\n   141→describe('retry --reset --story', () => {\n   142→  it('clears only the specified story', async () => {\n   143→    writeFileSync(retriesPath(ralphDir), 'story-a=3\\nstory-b=1\\n');\n   144→    writeFileSync(flaggedPath(ralphDir), 'story-a\\nstory-b\\n');\n   145→\n   146→    const { stdout } = await runCli(['retry', '--reset', '--story', 'story-a']);\n   147→    expect(stdout).toContain('[OK] Retry counter and flagged status cleared for story-a');\n   148→\n   149→    const content = readFileSync(retriesPath(ralphDir), 'utf-8');\n   150→    expect(content).toContain('story-b=1');\n   151→    expect(content).not.toContain('story-a');\n   152→\n   153→    const flagged = readFileSync(flaggedPath(ralphDir), 'utf-8');\n   154→    expect(flagged).toContain('story-b');\n   155→    expect(flagged).not.toContain('story-a');\n   156→  });\n   157→\n   158→  it('JSON output for single story reset', async () => {\n   159→    writeFileSync(retriesPath(ralphDir), 'story-a=3\\n');\n   160→\n   161→    const { stdout } = await runCli(['--json', 'retry', '--reset', '--story', 'story-a']);\n   162→    const parsed = JSON.parse(stdout);\n   163→    expect(parsed.status).toBe('ok');\n   164→    expect(parsed.action).toBe('reset');\n   165→    expect(parsed.story).toBe('story-a');\n   166→  });\n   167→});\n   168→\n   169→// ─── --status --story (filter) ────────────────────────────────────────────────\n   170→\n   171→describe('retry --status --story', () => {\n   172→  it('filters table to specified story', async () => {\n   173→    writeFileSync(retriesPath(ralphDir), 'story-a=3\\nstory-b=1\\n');\n   174→    writeFileSync(flaggedPath(ralphDir), 'story-a\\n');\n   175→\n   176→    const { stdout } = await runCli(['retry', '--status', '--story', 'story-a']);\n   177→    expect(stdout).toContain('story-a');\n   178→    expect(stdout).not.toContain('story-b');\n   179→  });\n   180→\n   181→  it('shows \"No retry entries.\" when filtered story not found', async () => {\n   182→    writeFileSync(retriesPath(ralphDir), 'story-a=3\\n');\n   183→\n   184→    const { stdout } = await runCli(['retry', '--status', '--story', 'nonexistent']);\n   185→    expect(stdout).toContain('No retry entries.');\n   186→  });\n   187→\n   188→  it('filters JSON output to specified story', async () => {\n   189→    writeFileSync(retriesPath(ralphDir), 'story-a=3\\nstory-b=1\\n');\n   190→\n   191→    const { stdout } = await runCli(['--json', 'retry', '--status', '--story', 'story-a']);\n   192→    const parsed = JSON.parse(stdout);\n   193→    expect(parsed.entries['story-a']).toEqual({ count: 3, flagged: false });\n   194→    expect(parsed.entries['story-b']).toBeUndefined();\n   195→  });\n   196→});\n   197→\n   198→// ─── input validation ─────────────────────────────────────────────────────────\n   199→\n   200→describe('retry input validation', () => {\n   201→  it('rejects story key with path traversal', async () => {\n   202→    const { stdout } = await runCli(['retry', '--reset', '--story', '../etc/passwd']);\n   203→    expect(stdout).toContain('[WARN] Invalid story key');\n   204→  });\n   205→\n   206→  it('rejects story key with slashes', async () => {\n   207→    const { stdout } = await runCli(['retry', '--reset', '--story', 'foo/bar']);\n   208→    expect(stdout).toContain('[WARN] Invalid story key');\n   209→  });\n   210→\n   211→  it('rejects story key with special characters', async () => {\n   212→    const { stdout } = await runCli(['retry', '--reset', '--story', 'story key=bad']);\n   213→    expect(stdout).toContain('[WARN] Invalid story key');\n   214→  });\n   215→\n   216→  it('returns fail status in JSON for invalid key', async () => {\n   217→    const { stdout } = await runCli(['--json', 'retry', '--reset', '--story', '../bad']);\n   218→    const parsed = JSON.parse(stdout);\n   219→    expect(parsed.status).toBe('fail');\n   220→    expect(parsed.message).toContain('Invalid story key');\n   221→  });\n   222→});\n   223→\n   224→// ─── --story without --reset ──────────────────────────────────────────────────\n   225→\n   226→describe('retry --story without --reset', () => {\n   227→  it('warns and shows status for that story', async () => {\n   228→    writeFileSync(retriesPath(ralphDir), 'story-a=3\\nstory-b=1\\n');\n   229→\n   230→    const { stdout } = await runCli(['retry', '--story', 'story-a']);\n   231→    expect(stdout).toContain('[WARN]');\n   232→    expect(stdout).toContain('story-a');\n   233→    expect(stdout).not.toContain('story-b');\n   234→  });\n   235→});\n   236→\n   237→// ─── default behavior ─────────────────────────────────────────────────────────\n   238→\n   239→describe('retry (default)', () => {\n   240→  it('shows status when no flags provided', async () => {\n   241→    const { stdout } = await runCli(['retry']);\n   242→    expect(stdout).toContain('No retry entries.');\n   243→  });\n   244→});\n   245→"}]},"parent_tool_use_id":"toolu_01EPL4eJAP5W5qUxFXY5uuFc","session_id":"6707468c-554d-4568-9ea5-0d04d4a85f59","uuid":"c321941e-fbcd-42d5-b4f0-a11102cd78c1","timestamp":"2026-03-24T10:21:05.436Z"}
