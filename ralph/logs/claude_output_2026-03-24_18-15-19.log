{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01H6RJLx4hz2smYSBoia44LY","type":"tool_result","content":"     1→/**\n     2→ * Builder factories for SprintState and related test data.\n     3→ *\n     4→ * Produces valid SprintStateV2 objects with sensible defaults.\n     5→ * Use `buildSprintState(overrides)` for top-level state and\n     6→ * `buildStoryEntry(overrides)` for individual story entries.\n     7→ */\n     8→\n     9→import type {\n    10→  SprintState,\n    11→  StoryState,\n    12→  StoryStatus,\n    13→  EpicState,\n    14→  SessionState,\n    15→  ObservabilityState,\n    16→  ActionItem,\n    17→} from '../../../types/state.js';\n    18→\n    19→/** Default story state with \"backlog\" status and zero attempts */\n    20→const DEFAULT_STORY_STATE: StoryState = {\n    21→  status: 'backlog',\n    22→  attempts: 0,\n    23→  lastAttempt: null,\n    24→  lastError: null,\n    25→  proofPath: null,\n    26→  acResults: null,\n    27→};\n    28→\n    29→/** Default session state — inactive */\n    30→const DEFAULT_SESSION_STATE: SessionState = {\n    31→  active: false,\n    32→  startedAt: null,\n    33→  iteration: 0,\n    34→  elapsedSeconds: 0,\n    35→};\n    36→\n    37→/** Default observability state — no coverage data */\n    38→const DEFAULT_OBSERVABILITY_STATE: ObservabilityState = {\n    39→  statementCoverage: null,\n    40→  branchCoverage: null,\n    41→  functionCoverage: null,\n    42→  lineCoverage: null,\n    43→};\n    44→\n    45→/** Default run state — inactive */\n    46→const DEFAULT_RUN_STATE: SprintState['run'] = {\n    47→  active: false,\n    48→  startedAt: null,\n    49→  iteration: 0,\n    50→  cost: 0,\n    51→  completed: [],\n    52→  failed: [],\n    53→  currentStory: null,\n    54→  currentPhase: null,\n    55→  lastAction: null,\n    56→  acProgress: null,\n    57→};\n    58→\n    59→/**\n    60→ * Build a valid SprintStateV2 object with sensible defaults.\n    61→ * Pass partial overrides to customize specific fields.\n    62→ */\n    63→export function buildSprintState(overrides?: Partial<SprintState>): SprintState {\n    64→  return {\n    65→    version: 2,\n    66→    sprint: {\n    67→      total: 0,\n    68→      done: 0,\n    69→      failed: 0,\n    70→      blocked: 0,\n    71→      inProgress: null,\n    72→      ...overrides?.sprint,\n    73→    },\n    74→    stories: overrides?.stories ?? {},\n    75→    retries: overrides?.retries ?? {},\n    76→    flagged: overrides?.flagged ?? [],\n    77→    epics: overrides?.epics ?? {},\n    78→    session: { ...DEFAULT_SESSION_STATE, ...overrides?.session },\n    79→    observability: { ...DEFAULT_OBSERVABILITY_STATE, ...overrides?.observability },\n    80→    run: { ...DEFAULT_RUN_STATE, ...overrides?.run },\n    81→    actionItems: overrides?.actionItems ?? [],\n    82→  };\n    83→}\n    84→\n    85→/**\n    86→ * Build a valid StoryState object with sensible defaults.\n    87→ * Pass partial overrides to customize specific fields.\n    88→ */\n    89→export function buildStoryEntry(overrides?: Partial<StoryState>): StoryState {\n    90→  return {\n    91→    ...DEFAULT_STORY_STATE,\n    92→    ...overrides,\n    93→  };\n    94→}\n    95→\n    96→/**\n    97→ * Build a valid EpicState object with sensible defaults.\n    98→ */\n    99→export function buildEpicState(overrides?: Partial<EpicState>): EpicState {\n   100→  return {\n   101→    status: 'in-progress',\n   102→    storiesTotal: 0,\n   103→    storiesDone: 0,\n   104→    ...overrides,\n   105→  };\n   106→}\n   107→\n   108→/**\n   109→ * Build a valid ActionItem object.\n   110→ */\n   111→export function buildActionItem(overrides?: Partial<ActionItem>): ActionItem {\n   112→  return {\n   113→    id: 'ai-1',\n   114→    story: '1-1-test',\n   115→    description: 'Test action item',\n   116→    source: 'manual',\n   117→    resolved: false,\n   118→    ...overrides,\n   119→  };\n   120→}\n   121→\n   122→/**\n   123→ * Build a SprintState with a single story pre-populated.\n   124→ * Convenience wrapper for the common test pattern.\n   125→ */\n   126→export function buildSprintStateWithStory(\n   127→  storyKey: string,\n   128→  storyOverrides?: Partial<StoryState>,\n   129→  stateOverrides?: Partial<SprintState>,\n   130→): SprintState {\n   131→  return buildSprintState({\n   132→    ...stateOverrides,\n   133→    sprint: { total: 1, done: 0, failed: 0, blocked: 0, inProgress: null, ...stateOverrides?.sprint },\n   134→    stories: {\n   135→      [storyKey]: buildStoryEntry(storyOverrides),\n   136→      ...stateOverrides?.stories,\n   137→    },\n   138→  });\n   139→}\n   140→"}]},"parent_tool_use_id":"toolu_01E4d2UoNxdYuxQTG5Dezgge","session_id":"8c35c2f7-0e10-4994-a438-2b5cecce3396","uuid":"06088d50-fd67-4afb-8ef5-c8800ff3df73","timestamp":"2026-03-24T14:16:18.414Z"}
