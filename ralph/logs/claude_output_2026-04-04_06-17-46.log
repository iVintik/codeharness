{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LnC5hrBeJWtaWS8eCgpDMm","type":"tool_result","content":"1\t/**\n2\t * Ink App root component — composes layout and activity components.\n3\t *\n4\t * Separated from ink-components.tsx to avoid circular imports\n5\t * (ink-components exports types, ink-activity-components imports them,\n6\t * and this file imports from both).\n7\t */\n8\t\n9\timport React from 'react';\n10\timport { Box, Static } from 'ink';\n11\timport { Header, Separator, StoryBreakdown, type RendererState } from './ink-components.js';\n12\timport { CompletedTools, ActiveTool, LastThought, RetryNotice, StoryMessageLine, DriverCostSummary } from './ink-activity-components.js';\n13\timport { WorkflowGraph } from './ink-workflow.js';\n14\timport { LaneContainer } from './ink-lane-container.js';\n15\timport type { LaneData } from './ink-lane-container.js';\n16\t\n17\texport function App({ state }: { state: RendererState }) {\n18\t  const lanes: LaneData[] | undefined = state.lanes;\n19\t  const laneCount = lanes?.length ?? 0;\n20\t  const terminalWidth = process.stdout.columns || 80;\n21\t\n22\t  return (\n23\t    <Box flexDirection=\"column\">\n24\t      <Static items={state.messages}>\n25\t        {(msg, i) => <StoryMessageLine key={i} msg={msg} />}\n26\t      </Static>\n27\t      <Header info={state.sprintInfo} laneCount={laneCount > 1 ? laneCount : undefined} />\n28\t      {laneCount > 1 ? (\n29\t        <LaneContainer lanes={lanes!} terminalWidth={terminalWidth} />\n30\t      ) : (\n31\t        <>\n32\t          <WorkflowGraph flow={state.workflowFlow} currentTask={state.currentTaskName} taskStates={state.taskStates} taskMeta={state.taskMeta} />\n33\t          <StoryBreakdown stories={state.stories} sprintInfo={state.sprintInfo} />\n34\t          <DriverCostSummary driverCosts={state.driverCosts} />\n35\t        </>\n36\t      )}\n37\t      {state.stories.length > 0 && <Separator />}\n38\t      <Box flexDirection=\"column\" paddingLeft={1}>\n39\t        <CompletedTools tools={state.completedTools} />\n40\t        {state.activeTool && <ActiveTool name={state.activeTool.name} driverName={state.activeDriverName} />}\n41\t        {state.lastThought && <LastThought text={state.lastThought} />}\n42\t        {state.retryInfo && <RetryNotice info={state.retryInfo} />}\n43\t      </Box>\n44\t    </Box>\n45\t  );\n46\t}\n47\t"}]},"parent_tool_use_id":"toolu_01LF9uJNPtHNwmRNh99eK7QX","session_id":"0c112080-0896-4e32-96a0-f82adec16922","uuid":"ffd8cd70-ff27-4cf4-b4ef-3bcae354afcc","timestamp":"2026-04-04T02:26:14.309Z"}
