{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MVwK2EionEzgmuwPkigh89","type":"tool_result","content":"     1→import { spawn } from 'node:child_process';\n     2→import { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n     3→import { join, dirname } from 'node:path';\n     4→import { fileURLToPath } from 'node:url';\n     5→import { StringDecoder } from 'node:string_decoder';\n     6→import { Command } from 'commander';\n     7→import { fail, info, jsonOutput } from '../lib/output.js';\n     8→import { readSprintStatus } from '../lib/beads-sync.js';\n     9→import { generateRalphPrompt } from '../templates/ralph-prompt.js';\n    10→import { parseStreamLine } from '../lib/stream-parser.js';\n    11→import { startRenderer, type SprintInfo } from '../lib/ink-renderer.js';\n    12→import { getSprintState } from '../modules/sprint/index.js';\n    13→import { formatElapsed, mapSprintStatuses, parseRalphMessage, countStories, buildSpawnArgs } from '../lib/run-helpers.js';\n    14→\n    15→const SPRINT_STATUS_REL = '_bmad-output/implementation-artifacts/sprint-status.yaml';\n    16→\n    17→/** Resolves the path to ralph/ralph.sh relative to the package root. */\n    18→export function resolveRalphPath(): string {\n    19→  const currentFile = fileURLToPath(import.meta.url);\n    20→  const currentDir = dirname(currentFile);\n    21→  let root = dirname(currentDir);\n    22→  if (root.endsWith('/src') || root.endsWith('\\\\src')) {\n    23→    root = dirname(root);\n    24→  }\n    25→  return join(root, 'ralph', 'ralph.sh');\n    26→}\n    27→\n    28→/** Resolves the plugin directory path (.claude/ in project root). */\n    29→export function resolvePluginDir(): string {\n    30→  return join(process.cwd(), '.claude');\n    31→}\n    32→\n    33→// Re-export helpers that tests import from run.ts\n    34→export { countStories, buildSpawnArgs } from '../lib/run-helpers.js';\n    35→\n    36→export function registerRunCommand(program: Command): void {\n    37→  program\n    38→    .command('run')\n    39→    .description('Execute the autonomous coding loop')\n    40→    .option('--max-iterations <n>', 'Maximum loop iterations', '50')\n    41→    .option('--timeout <seconds>', 'Total loop timeout in seconds', '43200')\n    42→    .option('--iteration-timeout <minutes>', 'Per-iteration timeout in minutes', '30')\n    43→    .option('--quiet', 'Suppress terminal output (background mode)', false)\n    44→    .option('--calls <n>', 'Max API calls per hour', '100')\n    45→    .option('--max-story-retries <n>', 'Max retries per story before flagging', '10')\n    46→    .option('--reset', 'Clear retry counters, flagged stories, and circuit breaker before starting', false)\n    47→    .action(async (options, cmd) => {\n    48→      const globalOpts = cmd.optsWithGlobals();\n    49→      const isJson = !!globalOpts.json;\n    50→      const outputOpts = { json: isJson };\n    51→\n    52→      // 1. Resolve Ralph script path\n    53→      const ralphPath = resolveRalphPath();\n    54→      if (!existsSync(ralphPath)) {\n    55→        fail('Ralph loop not found — reinstall codeharness', outputOpts);\n    56→        process.exitCode = 1;\n    57→        return;\n    58→      }\n    59→\n    60→      // 2. Resolve plugin directory\n    61→      const pluginDir = resolvePluginDir();\n    62→      if (!existsSync(pluginDir)) {\n    63→        fail('Plugin directory not found — run codeharness init first', outputOpts);\n    64→        process.exitCode = 1;\n    65→        return;\n    66→      }\n    67→\n    68→      // 3. Read sprint status for story count\n    69→      const projectDir = process.cwd();\n    70→      const sprintStatusPath = join(projectDir, SPRINT_STATUS_REL);\n    71→      const statuses = readSprintStatus(projectDir);\n    72→      const counts = countStories(statuses);\n    73→\n    74→      if (counts.total === 0) {\n    75→        fail('No stories found in sprint-status.yaml — nothing to execute', outputOpts);\n    76→        process.exitCode = 1;\n    77→        return;\n    78→      }\n    79→\n    80→      info(`Starting autonomous execution — ${counts.ready} ready, ${counts.inProgress} in progress, ${counts.verified} verified, ${counts.done}/${counts.total} done`, outputOpts);\n    81→\n    82→      // 4. Parse and validate numeric options\n    83→      const maxIterations = parseInt(options.maxIterations, 10);\n    84→      const timeout = parseInt(options.timeout, 10);\n    85→      const iterationTimeout = parseInt(options.iterationTimeout, 10);\n    86→      const calls = parseInt(options.calls, 10);\n    87→      const maxStoryRetries = parseInt(options.maxStoryRetries, 10);\n    88→\n    89→      if (isNaN(maxIterations) || isNaN(timeout) || isNaN(iterationTimeout) || isNaN(calls) || isNaN(maxStoryRetries)) {\n    90→        fail('Invalid numeric option — --max-iterations, --timeout, --iteration-timeout, --calls, and --max-story-retries must be numbers', outputOpts);\n    91→        process.exitCode = 1;\n    92→        return;\n    93→      }\n    94→\n    95→      // 5. Generate prompt file (with flagged stories context if available)\n    96→      const promptFile = join(projectDir, 'ralph', '.harness-prompt.md');\n    97→      const flaggedFilePath = join(projectDir, 'ralph', '.flagged_stories');\n    98→      let flaggedStories: string[] | undefined;\n    99→      if (existsSync(flaggedFilePath)) {\n   100→        try {\n   101→          const flaggedContent = readFileSync(flaggedFilePath, 'utf-8');\n   102→          flaggedStories = flaggedContent.split('\\n').filter(s => s.trim().length > 0);\n   103→        } catch {\n   104→          // Ignore read errors\n   105→        }\n   106→      }\n   107→      const promptContent = generateRalphPrompt({\n   108→        projectDir,\n   109→        sprintStatusPath,\n   110→        flaggedStories,\n   111→      });\n   112→      try {\n   113→        mkdirSync(dirname(promptFile), { recursive: true });\n   114→        writeFileSync(promptFile, promptContent, 'utf-8');\n   115→      } catch (err) {\n   116→        const message = err instanceof Error ? err.message : String(err);\n   117→        fail(`Failed to write prompt file: ${message}`, outputOpts);\n   118→        process.exitCode = 1;\n   119→        return;\n   120→      }\n   121→\n   122→      // 6. Build spawn arguments\n   123→      const args = buildSpawnArgs({\n   124→        ralphPath,\n   125→        pluginDir,\n   126→        promptFile,\n   127→        maxIterations,\n   128→        timeout,\n   129→        iterationTimeout,\n   130→        calls,\n   131→        quiet: options.quiet,\n   132→        maxStoryRetries,\n   133→        reset: options.reset,\n   134→      });\n   135→\n   136→      // 7. Set environment — stream-json is always the output format\n   137→      const env = { ...process.env };\n   138→      if (isJson) {\n   139→        env.CLAUDE_OUTPUT_FORMAT = 'stream-json';\n   140→      }\n   141→\n   142→      // 8. Spawn Ralph — pipe stdout/stderr through stream parser → Ink renderer\n   143→      // Declare renderer handle outside try so cleanup is always reachable\n   144→      const quiet = options.quiet;\n   145→      const rendererHandle = startRenderer({ quiet });\n   146→      let sprintStateInterval: ReturnType<typeof setInterval> | null = null;\n   147→      const sessionStartTime = Date.now();\n   148→\n   149→      try {\n   150→        // Read initial sprint state for the renderer header\n   151→        const initialState = getSprintState();\n   152→        if (initialState.success) {\n   153→          const s = initialState.data;\n   154→          const sprintInfo: SprintInfo = {\n   155→            storyKey: s.run.currentStory ?? '',\n   156→            phase: s.run.currentPhase ?? '',\n   157→            done: s.sprint.done,\n   158→            total: s.sprint.total,\n   159→            elapsed: formatElapsed(Date.now() - sessionStartTime),\n   160→          };\n   161→          rendererHandle.updateSprintState(sprintInfo);\n   162→        }\n   163→\n   164→        // Feed initial per-story statuses to the renderer\n   165→        const initialStatuses = readSprintStatus(projectDir);\n   166→        const initialStories = mapSprintStatuses(initialStatuses);\n   167→        if (initialStories.length > 0) {\n   168→          rendererHandle.updateStories(initialStories);\n   169→        }\n   170→\n   171→        const child = spawn('bash', args, {\n   172→          stdio: quiet ? 'ignore' : ['inherit', 'pipe', 'pipe'],\n   173→          cwd: projectDir,\n   174→          env,\n   175→        });\n   176→\n   177→        if (!quiet && child.stdout && child.stderr) {\n   178→          // Buffer partial lines and feed through stream parser → Ink renderer.\n   179→          // StringDecoder handles multi-byte UTF-8 chars split across Buffer boundaries.\n   180→          const makeLineHandler = (opts?: { parseRalph?: boolean }): ((data: Buffer) => void) => {\n   181→            let partial = '';\n   182→            const decoder = new StringDecoder('utf8');\n   183→            return (data: Buffer): void => {\n   184→              const text = partial + decoder.write(data);\n   185→              const parts = text.split('\\n');\n   186→              partial = parts.pop() ?? '';\n   187→              for (const line of parts) {\n   188→                if (line.trim().length === 0) continue;\n   189→                const event = parseStreamLine(line);\n   190→                if (event) {\n   191→                  rendererHandle.update(event);\n   192→                }\n   193→                // Parse ralph structured output for story messages (AC #8)\n   194→                if (opts?.parseRalph) {\n   195→                  const msg = parseRalphMessage(line);\n   196→                  if (msg) {\n   197→                    rendererHandle.addMessage(msg);\n   198→                  }\n   199→                }\n   200→              }\n   201→            };\n   202→          };\n   203→          child.stdout.on('data', makeLineHandler());\n   204→          child.stderr.on('data', makeLineHandler({ parseRalph: true }));\n   205→\n   206→          // Periodically refresh sprint state for the header display\n   207→          sprintStateInterval = setInterval(() => {\n   208→            try {\n   209→              const stateResult = getSprintState();\n   210→              if (stateResult.success) {\n   211→                const s = stateResult.data;\n   212→                const sprintInfo: SprintInfo = {\n   213→                  storyKey: s.run.currentStory ?? '',\n   214→                  phase: s.run.currentPhase ?? '',\n   215→                  done: s.sprint.done,\n   216→                  total: s.sprint.total,\n   217→                  elapsed: formatElapsed(Date.now() - sessionStartTime),\n   218→                };\n   219→                rendererHandle.updateSprintState(sprintInfo);\n   220→              }\n   221→              // Refresh per-story statuses (AC #7)\n   222→              const currentStatuses = readSprintStatus(projectDir);\n   223→              const storyEntries = mapSprintStatuses(currentStatuses);\n   224→              rendererHandle.updateStories(storyEntries);\n   225→            } catch {\n   226→              // Ignore read errors during polling\n   227→            }\n   228→          }, 5_000);\n   229→        }\n   230→\n   231→        const exitCode = await new Promise<number>((resolve, reject) => {\n   232→          child.on('error', (err) => {\n   233→            if (sprintStateInterval) clearInterval(sprintStateInterval);\n   234→            rendererHandle.cleanup();\n   235→            reject(err);\n   236→          });\n   237→          child.on('close', (code) => {\n   238→            if (sprintStateInterval) clearInterval(sprintStateInterval);\n   239→            rendererHandle.cleanup();\n   240→            resolve(code ?? 1);\n   241→          });\n   242→        });\n   243→\n   244→        // 9. Handle JSON output on exit\n   245→        if (isJson) {\n   246→          const statusFile = join(projectDir, 'ralph', 'status.json');\n   247→          if (existsSync(statusFile)) {\n   248→            try {\n   249→              const statusData = JSON.parse(readFileSync(statusFile, 'utf-8'));\n   250→              const finalStatuses = readSprintStatus(projectDir);\n   251→              const finalCounts = countStories(finalStatuses);\n   252→              jsonOutput({\n   253→                status: statusData.status ?? (exitCode === 0 ? 'completed' : 'stopped'),\n   254→                iterations: statusData.loop_count ?? 0,\n   255→                storiesCompleted: finalCounts.done,\n   256→                storiesTotal: finalCounts.total,\n   257→                storiesRemaining: finalCounts.total - finalCounts.done,\n   258→                elapsedSeconds: statusData.elapsed_seconds ?? 0,\n   259→                flaggedStories: statusData.flagged_stories ?? [],\n   260→                exitReason: statusData.exit_reason ?? '',\n   261→              });\n   262→            } catch {\n   263→              jsonOutput({\n   264→                status: exitCode === 0 ? 'completed' : 'stopped',\n   265→                iterations: 0,\n   266→                storiesCompleted: 0,\n   267→                storiesTotal: counts.total,\n   268→                storiesRemaining: counts.total,\n   269→                elapsedSeconds: 0,\n   270→                flaggedStories: [],\n   271→                exitReason: 'status_file_unreadable',\n   272→              });\n   273→            }\n   274→          } else {\n   275→            // status.json not created (Ralph crashed early or never started)\n   276→            const finalStatuses = readSprintStatus(projectDir);\n   277→            const finalCounts = countStories(finalStatuses);\n   278→            jsonOutput({\n   279→              status: exitCode === 0 ? 'completed' : 'stopped',\n   280→              iterations: 0,\n   281→              storiesCompleted: finalCounts.done,\n   282→              storiesTotal: finalCounts.total,\n   283→              storiesRemaining: finalCounts.total - finalCounts.done,\n   284→              elapsedSeconds: 0,\n   285→              flaggedStories: [],\n   286→              exitReason: 'status_file_missing',\n   287→            });\n   288→          }\n   289→        }\n   290→\n   291→        process.exitCode = exitCode;\n   292→      } catch (err) {\n   293→        if (sprintStateInterval) clearInterval(sprintStateInterval);\n   294→        rendererHandle.cleanup();\n   295→        const message = err instanceof Error ? err.message : String(err);\n   296→        fail(`Failed to start Ralph: ${message}`, outputOpts);\n   297→        process.exitCode = 1;\n   298→      }\n   299→    });\n   300→}\n   301→"}]},"parent_tool_use_id":"toolu_01XRogrWXmkjb8B4r8U8sFo4","session_id":"64c1e9b9-a641-40be-ae67-07aee0c47965","uuid":"988f55a6-7ddd-4e67-a098-7c6a7c1c5576","timestamp":"2026-03-20T08:14:31.809Z"}
