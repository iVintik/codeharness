s).toBe(false);\n1842\t    expect(result.errors).toHaveLength(1);\n1843\t    expect(result.errors[0].code).toBe('RATE_LIMIT');\n1844\t    expect(result.errors[0].taskName).toBe('verify');\n1845\t  });\n1846\t\n1847\t  it('clears stale verdict after non-halt per-run error so next iteration retries all items', async () => {\n1848\t    const { DispatchError } = await import('../agent-dispatch.js');\n1849\t    let callCount = 0;\n1850\t\n1851\t    mockDriverDispatch.mockImplementation(() => {\n1852\t      callCount++;\n1853\t      if (callCount === 1) {\n1854\t        // First retry succeeds (iteration 1)\n1855\t        return makeDriverStream('ok', 'sess-r');\n1856\t      }\n1857\t      if (callCount === 2) {\n1858\t        // First verify throws non-halt UNKNOWN error (iteration 1)\n1859\t        return makeDriverStreamError(new DispatchError('unknown err', 'UNKNOWN', 'dev', new Error('inner')));\n1860\t      }\n1861\t      if (callCount === 3) {\n1862\t        // Verify re-dispatched (iteration 1 — error checkpoint doesn't count as completion,\n1863\t        // so the loop stays on iteration 1 and re-dispatches verify)\n1864\t        return makeDriverStream(makeFailVerdict(), 'sess-v');\n1865\t      }\n1866\t      if (callCount === 4) {\n1867\t        // Second retry (iteration 2 — all items retried since stale verdict cleared)\n1868\t        return makeDriverStream('ok', 'sess-r');\n1869\t      }\n1870\t      // Second verify passes (iteration 2)\n1871\t      return makeDriverStream(makePassVerdict(), 'sess-v');\n1872\t    });\n1873\t\n1874\t    mockParse.mockReturnValue({\n1875\t      development_status: { '3-1-foo': 'ready-for-dev' },\n1876\t    });\n1877\t\n1878\t    const config = makeConfig({\n1879\t      workflow: {\n1880\t        tasks: {\n1881\t          retry: makeTask({ scope: 'per-story' }),\n1882\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n1883\t        },\n1884\t        flow: [{ loop: ['retry', 'verify'] }],\n1885\t      },\n1886\t    });\n1887\t\n1888\t    const result = await executeWorkflow(config);\n1889\t\n1890\t    // Loop should eventually succeed (pass verdict on iteration 2 verify)\n1891\t    expect(result.errors).toHaveLength(1);\n1892\t    expect(result.errors[0].code).toBe('UNKNOWN');\n1893\t    // 5 dispatches: retry1 + verify1(error) + verify1-retry(ok) + retry2 + verify2(pass)\n1894\t    expect(mockDriverDispatch).toHaveBeenCalledTimes(5);\n1895\t  });\n1896\t\n1897\t  it('non-halt per-run error records error and continues to next iteration', async () => {\n1898\t    const { DispatchError } = await import('../agent-dispatch.js');\n1899\t    let callCount = 0;\n1900\t\n1901\t    mockDriverDispatch.mockImplementation((opts: { prompt: string }) => {\n1902\t      callCount++;\n1903\t      if (opts.prompt.includes('Execute task')) {\n1904\t        if (callCount <= 2) {\n1905\t          // First verify: non-halt error\n1906\t          return makeDriverStreamError(new DispatchError('bad response', 'UNKNOWN', 'dev', new Error('inner')));\n1907\t        }\n1908\t        // Second verify: pass\n1909\t        return makeDriverStream(makePassVerdict(), 'sess-v');\n1910\t      }\n1911\t      return makeDriverStream('ok', 'sess-r');\n1912\t    });\n1913\t\n1914\t    mockParse.mockReturnValue({\n1915\t      development_status: { '3-1-foo': 'ready-for-dev' },\n1916\t    });\n1917\t\n1918\t    const config = makeConfig({\n1919\t      workflow: {\n1920\t        tasks: {\n1921\t          retry: makeTask({ scope: 'per-story' }),\n1922\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n1923\t        },\n1924\t        flow: [{ loop: ['retry', 'verify'] }],\n1925\t      },\n1926\t    });\n1927\t\n1928\t    const result = await executeWorkflow(config);\n1929\t\n1930\t    // Error from first verify recorded, but loop continued and eventually passed\n1931\t    expect(result.errors).toHaveLength(1);\n1932\t    expect(result.errors[0].code).toBe('UNKNOWN');\n1933\t  });\n1934\t});\n1935\t\n1936\t// ============================================================\n1937\t// Story 5-3: Crash Recovery & Resume Tests\n1938\t// ============================================================\n1939\t\n1940\tdescribe('isTaskCompleted', () => {\n1941\t  it('returns true when (taskName, storyKey) tuple matches a checkpoint', () => {\n1942\t    const state = makeDefaultState({\n1943\t      tasks_completed: [\n1944\t        { task_name: 'implement', story_key: '3-1-foo', completed_at: '2026-04-03T00:00:00Z' },\n1945\t      ],\n1946\t    });\n1947\t    expect(isTaskCompleted(state, 'implement', '3-1-foo')).toBe(true);\n1948\t  });\n1949\t\n1950\t  it('returns false when taskName matches but storyKey does not', () => {\n1951\t    const state = makeDefaultState({\n1952\t      tasks_completed: [\n1953\t        { task_name: 'implement', story_key: '3-1-foo', completed_at: '2026-04-03T00:00:00Z' },\n1954\t      ],\n1955\t    });\n1956\t    expect(isTaskCompleted(state, 'implement', '3-2-bar')).toBe(false);\n1957\t  });\n1958\t\n1959\t  it('returns false when storyKey matches but taskName does not (AC #7)', () => {\n1960\t    const state = makeDefaultState({\n1961\t      tasks_completed: [\n1962\t        { task_name: 'implement', story_key: '3-1-foo', completed_at: '2026-04-03T00:00:00Z' },\n1963\t      ],\n1964\t    });\n1965\t    // (\"implement\", \"3-1-foo\") does NOT cause (\"verify\", \"3-1-foo\") to be skipped\n1966\t    expect(isTaskCompleted(state, 'verify', '3-1-foo')).toBe(false);\n1967\t  });\n1968\t\n1969\t  it('returns false when tasks_completed is empty (AC #5)', () => {\n1970\t    const state = makeDefaultState({ tasks_completed: [] });\n1971\t    expect(isTaskCompleted(state, 'implement', '3-1-foo')).toBe(false);\n1972\t  });\n1973\t\n1974\t  it('returns true for per-run sentinel key', () => {\n1975\t    const state = makeDefaultState({\n1976\t      tasks_completed: [\n1977\t        { task_name: 'verify', story_key: '__run__', completed_at: '2026-04-03T00:00:00Z' },\n1978\t      ],\n1979\t    });\n1980\t    expect(isTaskCompleted(state, 'verify', PER_RUN_SENTINEL)).toBe(true);\n1981\t  });\n1982\t});\n1983\t\n1984\tdescribe('isLoopTaskCompleted', () => {\n1985\t  it('returns true when checkpoint count >= iteration', () => {\n1986\t    const state = makeDefaultState({\n1987\t      tasks_completed: [\n1988\t        { task_name: 'retry', story_key: '3-1-foo', completed_at: '2026-04-03T00:00:00Z' },\n1989\t        { task_name: 'retry', story_key: '3-1-foo', completed_at: '2026-04-03T00:01:00Z' },\n1990\t      ],\n1991\t    });\n1992\t    expect(isLoopTaskCompleted(state, 'retry', '3-1-foo', 2)).toBe(true);\n1993\t    expect(isLoopTaskCompleted(state, 'retry', '3-1-foo', 1)).toBe(true);\n1994\t  });\n1995\t\n1996\t  it('returns false when checkpoint count < iteration', () => {\n1997\t    const state = makeDefaultState({\n1998\t      tasks_completed: [\n1999\t        { task_name: 'retry', story_key: '3-1-foo', completed_at: '2026-04-03T00:00:00Z' },\n2000\t      ],\n2001\t    });\n2002\t    expect(isLoopTaskCompleted(state, 'retry', '3-1-foo', 2)).toBe(false);\n2003\t  });\n2004\t\n2005\t  it('returns false when no checkpoints exist', () => {\n2006\t    const state = makeDefaultState({ tasks_completed: [] });\n2007\t    expect(isLoopTaskCompleted(state, 'retry', '3-1-foo', 1)).toBe(false);\n2008\t  });\n2009\t});\n2010\t\n2011\tdescribe('crash recovery & resume', () => {\n2012\t  beforeEach(() => {\n2013\t    vi.clearAllMocks();\n2014\t    setupDefaultMocks();\n2015\t  });\n2016\t\n2017\t  it('skips completed sequential per-story task (AC #1)', async () => {\n2018\t    // Pre-populate: implement for 5-1-foo already done, 5-2-bar not done\n2019\t    mockReadWorkflowState.mockReturnValue(\n2020\t      makeDefaultState({\n2021\t        phase: 'executing',\n2022\t        started: '2026-04-03T00:00:00Z',\n2023\t        tasks_completed: [\n2024\t          { task_name: 'implement', story_key: '5-1-foo', completed_at: '