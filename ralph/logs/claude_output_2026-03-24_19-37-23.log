{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VaqEDn4WMFt1wcDCDUEtE4","type":"tool_result","content":"     1→/**\n     2→ * Helper functions for the run command.\n     3→ *\n     4→ * Extracted from run.ts to comply with NFR9 (max 300 lines per file).\n     5→ * Contains: elapsed time formatting, sprint status → story status mapping,\n     6→ * and ralph stderr → story message parsing.\n     7→ */\n     8→\n     9→import { StringDecoder } from 'node:string_decoder';\n    10→import { parseStreamLine } from './stream-parser.js';\n    11→import type { StreamEvent } from './stream-parser.js';\n    12→import type { StoryStatusEntry, StoryStatusValue, StoryMessage } from './ink-components.js';\n    13→\n    14→// --- Story Counting ---\n    15→\n    16→/** Story key pattern: digit-digit-name */\n    17→const STORY_KEY_PATTERN = /^\\d+-\\d+-/;\n    18→\n    19→/**\n    20→ * Counts stories by status from sprint-status.yaml.\n    21→ */\n    22→export function countStories(statuses: Record<string, string>): {\n    23→  total: number;\n    24→  ready: number;\n    25→  done: number;\n    26→  inProgress: number;\n    27→  // eslint-disable-next-line @typescript-eslint/naming-convention\n    28→  verified: number;\n    29→} {\n    30→  let total = 0;\n    31→  let ready = 0;\n    32→  let done = 0;\n    33→  let inProgress = 0;\n    34→  // eslint-disable-next-line @typescript-eslint/naming-convention\n    35→  let verified = 0;\n    36→\n    37→  for (const [key, status] of Object.entries(statuses)) {\n    38→    if (!STORY_KEY_PATTERN.test(key)) continue;\n    39→    total++;\n    40→    if (status === 'backlog' || status === 'ready-for-dev') ready++;\n    41→    else if (status === 'done') done++;\n    42→    else if (status === 'in-progress' || status === 'review') inProgress++;\n    43→    else if (status === 'verifying') verified++;\n    44→  }\n    45→\n    46→  return { total, ready, done, inProgress, verified };\n    47→}\n    48→\n    49→// --- Spawn Args Builder ---\n    50→\n    51→/**\n    52→ * Builds the argument array for spawning Ralph.\n    53→ */\n    54→export function buildSpawnArgs(opts: {\n    55→  ralphPath: string;\n    56→  pluginDir: string;\n    57→  promptFile: string;\n    58→  maxIterations: number;\n    59→  timeout: number;\n    60→  iterationTimeout: number;\n    61→  calls: number;\n    62→  quiet: boolean;\n    63→  maxStoryRetries?: number;\n    64→  reset?: boolean;\n    65→}): string[] {\n    66→  const args = [\n    67→    opts.ralphPath,\n    68→    '--plugin-dir', opts.pluginDir,\n    69→    '--max-iterations', String(opts.maxIterations),\n    70→    '--timeout', String(opts.timeout),\n    71→    '--iteration-timeout', String(opts.iterationTimeout),\n    72→    '--calls', String(opts.calls),\n    73→    '--prompt', opts.promptFile,\n    74→  ];\n    75→\n    76→  // When not quiet, pass --live so ralph tees Claude's stream-json to stdout.\n    77→  // The Ink renderer reads stdout to show live tool calls and thoughts.\n    78→  if (!opts.quiet) {\n    79→    args.push('--live');\n    80→  }\n    81→\n    82→  if (opts.maxStoryRetries !== undefined) {\n    83→    args.push('--max-story-retries', String(opts.maxStoryRetries));\n    84→  }\n    85→\n    86→  if (opts.reset) {\n    87→    args.push('--reset');\n    88→  }\n    89→\n    90→  return args;\n    91→}\n    92→\n    93→// --- Elapsed Time Formatting (AC #6) ---\n    94→\n    95→/**\n    96→ * Format elapsed milliseconds as \"Xm\" or \"XhYm\".\n    97→ * Matches the UX spec format (not the DashboardFormatter \"Xm Ys\" format).\n    98→ */\n    99→export function formatElapsed(ms: number): string {\n   100→  const totalMinutes = Math.max(0, Math.floor(ms / 60_000));\n   101→  const hours = Math.floor(totalMinutes / 60);\n   102→  const minutes = totalMinutes % 60;\n   103→  if (hours > 0) {\n   104→    return `${hours}h${minutes}m`;\n   105→  }\n   106→  return `${totalMinutes}m`;\n   107→}\n   108→\n   109→// --- Sprint Status → Story Status Mapping (AC #7) ---\n   110→\n   111→/**\n   112→ * Maps a sprint-status.yaml status value to a StoryStatusValue for the Ink renderer.\n   113→ *\n   114→ * Mapping:\n   115→ *   done → done\n   116→ *   in-progress, review, verifying → in-progress\n   117→ *   backlog, ready-for-dev → pending\n   118→ *   failed → failed\n   119→ *   blocked, exhausted → blocked\n   120→ */\n   121→export function mapSprintStatus(status: string): StoryStatusValue {\n   122→  switch (status) {\n   123→    case 'done':\n   124→      return 'done';\n   125→    case 'in-progress':\n   126→    case 'review':\n   127→    case 'verifying':\n   128→      return 'in-progress';\n   129→    case 'backlog':\n   130→    case 'ready-for-dev':\n   131→      return 'pending';\n   132→    case 'failed':\n   133→      return 'failed';\n   134→    case 'blocked':\n   135→    case 'exhausted':\n   136→      return 'blocked';\n   137→    default:\n   138→      return 'pending';\n   139→  }\n   140→}\n   141→\n   142→/**\n   143→ * Converts sprint-status.yaml entries to StoryStatusEntry[] for the Ink renderer.\n   144→ * Filters out epic keys, retrospective keys, and optional entries.\n   145→ */\n   146→export function mapSprintStatuses(statuses: Record<string, string>): StoryStatusEntry[] {\n   147→  const entries: StoryStatusEntry[] = [];\n   148→  for (const [key, status] of Object.entries(statuses)) {\n   149→    if (!STORY_KEY_PATTERN.test(key)) continue;\n   150→    if (status === 'optional') continue;\n   151→    entries.push({ key, status: mapSprintStatus(status) });\n   152→  }\n   153→  return entries;\n   154→}\n   155→\n   156→// --- Ralph Stderr → Story Messages (AC #8) ---\n   157→\n   158→/** Strip ANSI color codes */\n   159→const ANSI_ESCAPE = /\\x1b\\[[0-9;]*m/g;\n   160→\n   161→/** Strip timestamp prefix from ralph output lines */\n   162→const TIMESTAMP_PREFIX = /^\\[[\\d-]+\\s[\\d:]+\\]\\s*/;\n   163→\n   164→/** Matches: [SUCCESS] Story {key}: DONE ... */\n   165→const SUCCESS_STORY = /\\[SUCCESS\\]\\s+Story\\s+([\\w-]+):\\s+DONE(.*)/;\n   166→\n   167→/** Matches: [WARN] Story {key} exceeded retry limit ... flagging */\n   168→const WARN_STORY_RETRY = /\\[WARN\\]\\s+Story\\s+([\\w-]+)\\s+exceeded retry limit/;\n   169→\n   170→/** Matches: [WARN] Story {key} ... retry N/M */\n   171→const WARN_STORY_RETRYING = /\\[WARN\\]\\s+Story\\s+([\\w-]+)\\s+.*retry\\s+(\\d+)\\/(\\d+)/;\n   172→\n   173→/** Matches: [LOOP] iteration N */\n   174→const LOOP_ITERATION = /\\[LOOP\\]\\s+iteration\\s+(\\d+)/;\n   175→\n   176→/** Matches: [ERROR] ... */\n   177→const ERROR_LINE = /\\[ERROR\\]\\s+(.+)/;\n   178→\n   179→/**\n   180→ * Parse a ralph output line and return a StoryMessage if it matches\n   181→ * a story completion, failure, or warning pattern.\n   182→ * Returns null for non-matching lines.\n   183→ */\n   184→export function parseRalphMessage(rawLine: string): StoryMessage | null {\n   185→  const clean = rawLine.replace(ANSI_ESCAPE, '').replace(TIMESTAMP_PREFIX, '').trim();\n   186→  if (clean.length === 0) return null;\n   187→\n   188→  // [SUCCESS] Story {key}: DONE ...\n   189→  const success = SUCCESS_STORY.exec(clean);\n   190→  if (success) {\n   191→    const key = success[1];\n   192→    const rest = success[2].trim().replace(/^—\\s*/, '');\n   193→    return {\n   194→      type: 'ok',\n   195→      key,\n   196→      message: rest ? `DONE — ${rest}` : 'DONE',\n   197→    };\n   198→  }\n   199→\n   200→  // [WARN] Story {key} exceeded retry limit\n   201→  const retryExceeded = WARN_STORY_RETRY.exec(clean);\n   202→  if (retryExceeded) {\n   203→    return {\n   204→      type: 'fail',\n   205→      key: retryExceeded[1],\n   206→      message: 'exceeded retry limit',\n   207→    };\n   208→  }\n   209→\n   210→  // [WARN] Story {key} — retry N/M\n   211→  const retrying = WARN_STORY_RETRYING.exec(clean);\n   212→  if (retrying) {\n   213→    return {\n   214→      type: 'warn',\n   215→      key: retrying[1],\n   216→      message: `retry ${retrying[2]}/${retrying[3]}`,\n   217→    };\n   218→  }\n   219→\n   220→  // [ERROR] ... — surface as a generic error message\n   221→  const errorMatch = ERROR_LINE.exec(clean);\n   222→  if (errorMatch) {\n   223→    // Try to extract story key from error message\n   224→    const keyMatch = errorMatch[1].match(/Story\\s+([\\w-]+)/);\n   225→    if (keyMatch) {\n   226→      return {\n   227→        type: 'fail',\n   228→        key: keyMatch[1],\n   229→        message: errorMatch[1].trim(),\n   230→      };\n   231→    }\n   232→    // Generic error without a story key — skip (no key to associate)\n   233→    return null;\n   234→  }\n   235→\n   236→  return null;\n   237→}\n   238→\n   239→/**\n   240→ * Parse a ralph stderr line for [LOOP] iteration messages.\n   241→ * Returns the iteration number if found, or null otherwise.\n   242→ */\n   243→export function parseIterationMessage(rawLine: string): number | null {\n   244→  const clean = rawLine.replace(ANSI_ESCAPE, '').replace(TIMESTAMP_PREFIX, '').trim();\n   245→  if (clean.length === 0) return null;\n   246→  const match = LOOP_ITERATION.exec(clean);\n   247→  if (match) {\n   248→    return parseInt(match[1], 10);\n   249→  }\n   250→  return null;\n   251→}\n   252→\n   253→// --- Line Processor (extracted from run.ts for testability) ---\n   254→\n   255→export interface LineProcessorCallbacks {\n   256→  onEvent: (event: StreamEvent) => void;\n   257→  onMessage?: (msg: StoryMessage) => void;\n   258→  onIteration?: (iteration: number) => void;\n   259→}\n   260→\n   261→/**\n   262→ * Creates a Buffer-to-lines processor that splits on newlines, handles\n   263→ * partial-line buffering across chunk boundaries, and feeds complete\n   264→ * lines through the stream parser and optional ralph message parser.\n   265→ *\n   266→ * This is the exact logic used in run.ts's makeLineHandler, extracted\n   267→ * so integration tests can exercise the real production code path.\n   268→ */\n   269→export function createLineProcessor(\n   270→  callbacks: LineProcessorCallbacks,\n   271→  opts?: { parseRalph?: boolean },\n   272→): (data: Buffer) => void {\n   273→  let partial = '';\n   274→  const decoder = new StringDecoder('utf8');\n   275→  return (data: Buffer): void => {\n   276→    const text = partial + decoder.write(data);\n   277→    const parts = text.split('\\n');\n   278→    partial = parts.pop() ?? '';\n   279→    for (const line of parts) {\n   280→      if (line.trim().length === 0) continue;\n   281→      const event = parseStreamLine(line);\n   282→      if (event) {\n   283→        callbacks.onEvent(event);\n   284→      }\n   285→      if (opts?.parseRalph) {\n   286→        const msg = parseRalphMessage(line);\n   287→        if (msg && callbacks.onMessage) {\n   288→          callbacks.onMessage(msg);\n   289→        }\n   290→        const iteration = parseIterationMessage(line);\n   291→        if (iteration !== null && callbacks.onIteration) {\n   292→          callbacks.onIteration(iteration);\n   293→        }\n   294→      }\n   295→    }\n   296→  };\n   297→}\n   298→"}]},"parent_tool_use_id":"toolu_01SHktkuCBrV1tHtE9gQXR6g","session_id":"3ce6f3e2-c583-4074-ab3d-bf1fc6d87b66","uuid":"0610b229-ac6a-49bc-9a61-1972f384d347","timestamp":"2026-03-24T15:52:33.381Z"}
