{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KWbV3tbTPZD2jebYD7Y3eD","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→\n     3→vi.mock('../../../lib/docker/index.js', () => ({\n     4→  isDockerAvailable: vi.fn(() => true),\n     5→  isSharedStackRunning: vi.fn(() => false),\n     6→  startSharedStack: vi.fn(() => ({\n     7→    started: true,\n     8→    services: [\n     9→      { name: 'victoria-logs', status: 'running', port: '9428' },\n    10→      { name: 'otel-collector', status: 'running', port: '4317,4318' },\n    11→    ],\n    12→  })),\n    13→  startCollectorOnly: vi.fn(() => ({\n    14→    started: true,\n    15→    services: [\n    16→      { name: 'otel-collector', status: 'running', port: '4317,4318' },\n    17→    ],\n    18→  })),\n    19→}));\n    20→\n    21→vi.mock('../../../lib/stack-path.js', () => ({\n    22→  getComposeFilePath: vi.fn(() => '/mock/.codeharness/stack/docker-compose.harness.yml'),\n    23→  ensureStackDir: vi.fn(),\n    24→}));\n    25→\n    26→vi.mock('../../../lib/state.js', () => ({\n    27→  writeState: vi.fn(),\n    28→  readState: vi.fn(() => ({})),\n    29→}));\n    30→\n    31→import {\n    32→  isDockerAvailable,\n    33→  isSharedStackRunning,\n    34→  startSharedStack,\n    35→  startCollectorOnly,\n    36→} from '../../../lib/docker/index.js';\n    37→import { writeState } from '../../../lib/state.js';\n    38→import { checkDocker, setupDocker } from '../docker-setup.js';\n    39→import type { HarnessState } from '../../../lib/state.js';\n    40→\n    41→const mockIsDockerAvailable = vi.mocked(isDockerAvailable);\n    42→const mockIsSharedStackRunning = vi.mocked(isSharedStackRunning);\n    43→const mockStartSharedStack = vi.mocked(startSharedStack);\n    44→const mockStartCollectorOnly = vi.mocked(startCollectorOnly);\n    45→\n    46→const baseState: HarnessState = {\n    47→  harness_version: '0.0.0-dev',\n    48→  initialized: true,\n    49→  stack: 'nodejs',\n    50→  enforcement: { frontend: true, database: true, api: true },\n    51→  coverage: { target: 90, baseline: null, current: null, tool: 'c8' },\n    52→  session_flags: { logs_queried: false, tests_passed: false, coverage_met: false, verification_run: false },\n    53→  verification_log: [],\n    54→  otlp: { enabled: true, endpoint: 'http://localhost:4318', service_name: 'test', mode: 'local-shared' },\n    55→};\n    56→\n    57→beforeEach(() => {\n    58→  vi.clearAllMocks();\n    59→  vi.spyOn(console, 'log').mockImplementation(() => {});\n    60→  mockIsDockerAvailable.mockReturnValue(true);\n    61→  mockIsSharedStackRunning.mockReturnValue(false);\n    62→  mockStartSharedStack.mockReturnValue({\n    63→    started: true,\n    64→    services: [\n    65→      { name: 'victoria-logs', status: 'running', port: '9428' },\n    66→      { name: 'otel-collector', status: 'running', port: '4317,4318' },\n    67→    ],\n    68→  });\n    69→  mockStartCollectorOnly.mockReturnValue({\n    70→    started: true,\n    71→    services: [{ name: 'otel-collector', status: 'running', port: '4317,4318' }],\n    72→  });\n    73→});\n    74→\n    75→describe('checkDocker', () => {\n    76→  it('returns available=true when Docker is available', () => {\n    77→    const result = checkDocker({ observability: true, isJson: false });\n    78→    expect(result.success).toBe(true);\n    79→    if (result.success) {\n    80→      expect(result.data.available).toBe(true);\n    81→      expect(result.data.criticalFailure).toBe(false);\n    82→    }\n    83→  });\n    84→\n    85→  it('returns critical failure when Docker missing and observability on', () => {\n    86→    mockIsDockerAvailable.mockReturnValue(false);\n    87→    const result = checkDocker({ observability: true, isJson: false });\n    88→    expect(result.success).toBe(true);\n    89→    if (result.success) {\n    90→      expect(result.data.available).toBe(false);\n    91→      expect(result.data.criticalFailure).toBe(true);\n    92→      expect(result.data.dockerResult).toBeDefined();\n    93→    }\n    94→  });\n    95→\n    96→  it('returns non-critical when Docker missing and observability off', () => {\n    97→    mockIsDockerAvailable.mockReturnValue(false);\n    98→    const result = checkDocker({ observability: false, isJson: false });\n    99→    expect(result.success).toBe(true);\n   100→    if (result.success) {\n   101→      expect(result.data.available).toBe(false);\n   102→      expect(result.data.criticalFailure).toBe(false);\n   103→    }\n   104→  });\n   105→\n   106→  it('skips Docker check for remote-direct mode', () => {\n   107→    mockIsDockerAvailable.mockReturnValue(false);\n   108→    const result = checkDocker({ observability: true, otelEndpoint: 'http://remote:4318', isJson: false });\n   109→    expect(result.success).toBe(true);\n   110→    if (result.success) {\n   111→      expect(result.data.available).toBe(true);\n   112→      expect(result.data.criticalFailure).toBe(false);\n   113→    }\n   114→  });\n   115→});\n   116→\n   117→describe('setupDocker', () => {\n   118→  it('skips Docker when observability off', () => {\n   119→    const result = setupDocker({\n   120→      observability: false,\n   121→      isJson: false,\n   122→      dockerAvailable: true,\n   123→      state: { ...baseState },\n   124→      projectDir: '/tmp/test',\n   125→    });\n   126→    expect(result.success).toBe(true);\n   127→    if (result.success) {\n   128→      expect(result.data.docker).toBeNull();\n   129→    }\n   130→  });\n   131→\n   132→  it('configures remote-direct mode', () => {\n   133→    const result = setupDocker({\n   134→      observability: true,\n   135→      otelEndpoint: 'http://remote:4318',\n   136→      isJson: false,\n   137→      dockerAvailable: false,\n   138→      state: { ...baseState },\n   139→      projectDir: '/tmp/test',\n   140→    });\n   141→    expect(result.success).toBe(true);\n   142→    if (result.success) {\n   143→      expect(result.data.docker).toBeNull();\n   144→      expect(result.data.state.otlp!.mode).toBe('remote-direct');\n   145→      expect(result.data.state.otlp!.endpoint).toBe('http://remote:4318');\n   146→    }\n   147→  });\n   148→\n   149→  it('configures remote-routed mode', () => {\n   150→    const result = setupDocker({\n   151→      observability: true,\n   152→      logsUrl: 'http://logs:9428',\n   153→      metricsUrl: 'http://metrics:8428',\n   154→      tracesUrl: 'http://traces:16686',\n   155→      isJson: false,\n   156→      dockerAvailable: true,\n   157→      state: { ...baseState },\n   158→      projectDir: '/tmp/test',\n   159→    });\n   160→    expect(result.success).toBe(true);\n   161→    if (result.success) {\n   162→      expect(result.data.docker!.stack_running).toBe(true);\n   163→      expect(result.data.state.otlp!.mode).toBe('remote-routed');\n   164→    }\n   165→    expect(mockStartCollectorOnly).toHaveBeenCalledWith(\n   166→      'http://logs:9428', 'http://metrics:8428', 'http://traces:16686',\n   167→    );\n   168→  });\n   169→\n   170→  it('starts local-shared stack', () => {\n   171→    const result = setupDocker({\n   172→      observability: true,\n   173→      isJson: false,\n   174→      dockerAvailable: true,\n   175→      state: { ...baseState },\n   176→      projectDir: '/tmp/test',\n   177→    });\n   178→    expect(result.success).toBe(true);\n   179→    if (result.success) {\n   180→      expect(result.data.docker!.stack_running).toBe(true);\n   181→      expect(result.data.state.otlp!.mode).toBe('local-shared');\n   182→    }\n   183→    expect(mockStartSharedStack).toHaveBeenCalled();\n   184→  });\n   185→\n   186→  it('detects already running shared stack', () => {\n   187→    mockIsSharedStackRunning.mockReturnValue(true);\n   188→    const result = setupDocker({\n   189→      observability: true,\n   190→      isJson: false,\n   191→      dockerAvailable: true,\n   192→      state: { ...baseState },\n   193→      projectDir: '/tmp/test',\n   194→    });\n   195→    expect(result.success).toBe(true);\n   196→    if (result.success) {\n   197→      expect(result.data.docker!.stack_running).toBe(true);\n   198→    }\n   199→    expect(mockStartSharedStack).not.toHaveBeenCalled();\n   200→  });\n   201→\n   202→  it('reports failure when stack fails to start', () => {\n   203→    mockStartSharedStack.mockReturnValue({ started: false, services: [], error: 'timeout' });\n   204→    const result = setupDocker({\n   205→      observability: true,\n   206→      isJson: false,\n   207→      dockerAvailable: true,\n   208→      state: { ...baseState },\n   209→      projectDir: '/tmp/test',\n   210→    });\n   211→    expect(result.success).toBe(true);\n   212→    if (result.success) {\n   213→      expect(result.data.docker!.stack_running).toBe(false);\n   214→    }\n   215→  });\n   216→\n   217→  it('handles Docker not available with deferred observability', () => {\n   218→    const result = setupDocker({\n   219→      observability: true,\n   220→      isJson: false,\n   221→      dockerAvailable: false,\n   222→      state: { ...baseState },\n   223→      projectDir: '/tmp/test',\n   224→    });\n   225→    expect(result.success).toBe(true);\n   226→    if (result.success) {\n   227→      expect(result.data.docker!.stack_running).toBe(false);\n   228→    }\n   229→  });\n   230→\n   231→  it('writes state to disk', () => {\n   232→    setupDocker({\n   233→      observability: true,\n   234→      isJson: false,\n   235→      dockerAvailable: true,\n   236→      state: { ...baseState },\n   237→      projectDir: '/tmp/test',\n   238→    });\n   239→    expect(writeState).toHaveBeenCalled();\n   240→  });\n   241→});\n   242→"}]},"parent_tool_use_id":"toolu_01GEPRaZucE7UgpGJiPm4ARu","session_id":"790cd04c-5c91-45bb-998d-78a56b65af9a","uuid":"21775c11-a561-4caf-8436-dc8a80329f6e","timestamp":"2026-03-24T23:06:46.306Z"}
