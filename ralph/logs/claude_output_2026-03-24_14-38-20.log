{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QfgD9G5ze64va5Jh1t6XNm","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, afterEach } from 'vitest';\n     2→import {\n     3→  readFileSync,\n     4→  writeFileSync,\n     5→  unlinkSync,\n     6→  existsSync,\n     7→} from 'node:fs';\n     8→import { join } from 'node:path';\n     9→import { migrateFromOldFormat, migrateV1ToV2 } from '../migration.js';\n    10→import type { SprintStateV1 } from '../../../types/state.js';\n    11→\n    12→const ROOT = process.cwd();\n    13→const STATE_FILE = join(ROOT, 'sprint-state.json');\n    14→const TMP_FILE = join(ROOT, '.sprint-state.json.tmp');\n    15→const RALPH_DIR = join(ROOT, 'ralph');\n    16→const BMAD_DIR = join(\n    17→  ROOT,\n    18→  '_bmad-output',\n    19→  'implementation-artifacts',\n    20→);\n    21→\n    22→// We need to test with actual old file paths, so we'll create/cleanup them\n    23→const REAL_RETRIES = join(RALPH_DIR, '.story_retries');\n    24→const REAL_FLAGGED = join(RALPH_DIR, '.flagged_stories');\n    25→const REAL_STATUS = join(RALPH_DIR, 'status.json');\n    26→const REAL_YAML = join(BMAD_DIR, 'sprint-status.yaml');\n    27→const REAL_ISSUES = join(BMAD_DIR, '.session-issues.md');\n    28→\n    29→// Store original contents for restoration\n    30→let originalRetries: string | null = null;\n    31→let originalFlagged: string | null = null;\n    32→let originalStatus: string | null = null;\n    33→let originalYaml: string | null = null;\n    34→let originalIssues: string | null = null;\n    35→let originalState: string | null = null;\n    36→\n    37→function readSafe(path: string): string | null {\n    38→  try { return readFileSync(path, 'utf-8'); } catch { return null; }\n    39→}\n    40→\n    41→function saveOriginals(): void {\n    42→  originalRetries = readSafe(REAL_RETRIES);\n    43→  originalFlagged = readSafe(REAL_FLAGGED);\n    44→  originalStatus = readSafe(REAL_STATUS);\n    45→  originalYaml = readSafe(REAL_YAML);\n    46→  originalIssues = readSafe(REAL_ISSUES);\n    47→  originalState = readSafe(STATE_FILE);\n    48→}\n    49→\n    50→function restoreOriginals(): void {\n    51→  // Clean up sprint-state.json\n    52→  if (originalState !== null) {\n    53→    writeFileSync(STATE_FILE, originalState, 'utf-8');\n    54→  } else if (existsSync(STATE_FILE)) {\n    55→    unlinkSync(STATE_FILE);\n    56→  }\n    57→  if (existsSync(TMP_FILE)) unlinkSync(TMP_FILE);\n    58→\n    59→  // Restore originals\n    60→  if (originalRetries !== null) writeFileSync(REAL_RETRIES, originalRetries, 'utf-8');\n    61→  else if (existsSync(REAL_RETRIES)) unlinkSync(REAL_RETRIES);\n    62→  if (originalFlagged !== null) writeFileSync(REAL_FLAGGED, originalFlagged, 'utf-8');\n    63→  else if (existsSync(REAL_FLAGGED)) unlinkSync(REAL_FLAGGED);\n    64→  if (originalStatus !== null) writeFileSync(REAL_STATUS, originalStatus, 'utf-8');\n    65→  if (originalYaml !== null) writeFileSync(REAL_YAML, originalYaml, 'utf-8');\n    66→  if (originalIssues !== null) writeFileSync(REAL_ISSUES, originalIssues, 'utf-8');\n    67→}\n    68→\n    69→function removeOldFiles(): void {\n    70→  for (const f of [REAL_RETRIES, REAL_FLAGGED, REAL_STATUS, REAL_YAML, REAL_ISSUES]) {\n    71→    if (existsSync(f)) unlinkSync(f);\n    72→  }\n    73→}\n    74→\n    75→describe('migrateFromOldFormat', () => {\n    76→  beforeEach(() => {\n    77→    saveOriginals();\n    78→    if (existsSync(STATE_FILE)) unlinkSync(STATE_FILE);\n    79→    removeOldFiles();\n    80→  });\n    81→\n    82→  afterEach(() => {\n    83→    restoreOriginals();\n    84→  });\n    85→\n    86→  it('returns fail when no old files exist', () => {\n    87→    const result = migrateFromOldFormat();\n    88→    expect(result.success).toBe(false);\n    89→    if (!result.success) {\n    90→      expect(result.error).toContain('No old format files');\n    91→    }\n    92→  });\n    93→\n    94→  it('migrates story retries into attempts', () => {\n    95→    writeFileSync(\n    96→      REAL_RETRIES,\n    97→      'story-a 3\\nstory-b 1\\n',\n    98→      'utf-8',\n    99→    );\n   100→\n   101→    const result = migrateFromOldFormat();\n   102→    expect(result.success).toBe(true);\n   103→    if (result.success) {\n   104→      expect(result.data.stories['story-a'].attempts).toBe(3);\n   105→      expect(result.data.stories['story-b'].attempts).toBe(1);\n   106→    }\n   107→  });\n   108→\n   109→  it('migrates sprint-status.yaml into story statuses', () => {\n   110→    writeFileSync(\n   111→      REAL_YAML,\n   112→      [\n   113→        '# Sprint Status',\n   114→        'development_status:',\n   115→        '  epic-1: done',\n   116→        '  1-1-result-type: done',\n   117→        '  1-2-module-skeleton: backlog',\n   118→        '  2-1-sprint-state: in-progress',\n   119→      ].join('\\n'),\n   120→      'utf-8',\n   121→    );\n   122→\n   123→    const result = migrateFromOldFormat();\n   124→    expect(result.success).toBe(true);\n   125→    if (result.success) {\n   126→      expect(result.data.stories['1-1-result-type'].status).toBe('done');\n   127→      expect(result.data.stories['1-2-module-skeleton'].status).toBe('backlog');\n   128→      expect(result.data.stories['2-1-sprint-state'].status).toBe('in-progress');\n   129→      // epic-level entries should be skipped\n   130→      expect(result.data.stories['epic-1']).toBeUndefined();\n   131→    }\n   132→  });\n   133→\n   134→  it('migrates ralph/status.json into run section', () => {\n   135→    writeFileSync(\n   136→      REAL_STATUS,\n   137→      JSON.stringify({\n   138→        loop_count: 5,\n   139→        stories_total: 25,\n   140→        stories_completed: 3,\n   141→        elapsed_seconds: 1200,\n   142→        status: 'running',\n   143→      }),\n   144→      'utf-8',\n   145→    );\n   146→\n   147→    const result = migrateFromOldFormat();\n   148→    expect(result.success).toBe(true);\n   149→    if (result.success) {\n   150→      expect(result.data.run.iteration).toBe(5);\n   151→      expect(result.data.run.active).toBe(true);\n   152→    }\n   153→  });\n   154→\n   155→  it('migrates flagged stories as blocked', () => {\n   156→    writeFileSync(REAL_FLAGGED, 'story-x\\nstory-y\\n', 'utf-8');\n   157→\n   158→    const result = migrateFromOldFormat();\n   159→    expect(result.success).toBe(true);\n   160→    if (result.success) {\n   161→      expect(result.data.stories['story-x'].status).toBe('blocked');\n   162→      expect(result.data.stories['story-y'].status).toBe('blocked');\n   163→    }\n   164→  });\n   165→\n   166→  it('migrates session issues into action items', () => {\n   167→    writeFileSync(\n   168→      REAL_ISSUES,\n   169→      [\n   170→        '# Session Issues',\n   171→        '',\n   172→        '### story-abc — dev-story (2026-03-18)',\n   173→        '',\n   174→        '- Something went wrong',\n   175→        '- Another concern',\n   176→        '',\n   177→        '### story-def — code-review (2026-03-18)',\n   178→        '',\n   179→        '- Review finding',\n   180→      ].join('\\n'),\n   181→      'utf-8',\n   182→    );\n   183→\n   184→    const result = migrateFromOldFormat();\n   185→    expect(result.success).toBe(true);\n   186→    if (result.success) {\n   187→      expect(result.data.actionItems.length).toBe(3);\n   188→      expect(result.data.actionItems[0].story).toBe('story-abc');\n   189→      expect(result.data.actionItems[0].description).toBe('Something went wrong');\n   190→      expect(result.data.actionItems[2].story).toBe('story-def');\n   191→    }\n   192→  });\n   193→\n   194→  it('handles missing old files gracefully (partial migration)', () => {\n   195→    // Only retries file exists\n   196→    writeFileSync(REAL_RETRIES, 'only-story 2\\n', 'utf-8');\n   197→\n   198→    const result = migrateFromOldFormat();\n   199→    expect(result.success).toBe(true);\n   200→    if (result.success) {\n   201→      expect(result.data.stories['only-story'].attempts).toBe(2);\n   202→      expect(result.data.run.active).toBe(false); // no status.json\n   203→    }\n   204→  });\n   205→\n   206→  it('writes sprint-state.json after migration', () => {\n   207→    writeFileSync(REAL_RETRIES, 'migrated-story 1\\n', 'utf-8');\n   208→\n   209→    const result = migrateFromOldFormat();\n   210→    expect(result.success).toBe(true);\n   211→    expect(existsSync(STATE_FILE)).toBe(true);\n   212→  });\n   213→\n   214→  it('handles invalid JSON in ralph/status.json gracefully', () => {\n   215→    writeFileSync(REAL_STATUS, '{not valid json!!!', 'utf-8');\n   216→\n   217→    const result = migrateFromOldFormat();\n   218→    expect(result.success).toBe(true);\n   219→    if (result.success) {\n   220→      expect(result.data.run.active).toBe(false);\n   221→      expect(result.data.run.iteration).toBe(0);\n   222→    }\n   223→  });\n   224→\n   225→  it('handles retries file with malformed lines', () => {\n   226→    writeFileSync(\n   227→      REAL_RETRIES,\n   228→      'story-a 3\\nmalformed-no-count\\n\\nstory-b notanumber\\nstory-c 5\\n',\n   229→      'utf-8',\n   230→    );\n   231→\n   232→    const result = migrateFromOldFormat();\n   233→    expect(result.success).toBe(true);\n   234→    if (result.success) {\n   235→      expect(result.data.stories['story-a'].attempts).toBe(3);\n   236→      expect(result.data.stories['story-c'].attempts).toBe(5);\n   237→      expect(result.data.stories['malformed-no-count']).toBeUndefined();\n   238→      expect(result.data.stories['story-b']).toBeUndefined();\n   239→    }\n   240→  });\n   241→\n   242→  it('computes sprint counts correctly', () => {\n   243→    writeFileSync(\n   244→      REAL_YAML,\n   245→      [\n   246→        'development_status:',\n   247→        '  s1: done',\n   248→        '  s2: done',\n   249→        '  s3: failed',\n   250→        '  s4: blocked',\n   251→        '  s5: backlog',\n   252→      ].join('\\n'),\n   253→      'utf-8',\n   254→    );\n   255→\n   256→    const result = migrateFromOldFormat();\n   257→    expect(result.success).toBe(true);\n   258→    if (result.success) {\n   259→      expect(result.data.sprint.total).toBe(5);\n   260→      expect(result.data.sprint.done).toBe(2);\n   261→      expect(result.data.sprint.failed).toBe(1);\n   262→      expect(result.data.sprint.blocked).toBe(1);\n   263→    }\n   264→  });\n   265→\n   266→  it('outputs version 2 from migrateFromOldFormat', () => {\n   267→    writeFileSync(REAL_RETRIES, 'story-a 1\\n', 'utf-8');\n   268→\n   269→    const result = migrateFromOldFormat();\n   270→    expect(result.success).toBe(true);\n   271→    if (result.success) {\n   272→      expect(result.data.version).toBe(2);\n   273→    }\n   274→  });\n   275→\n   276→  it('populates v2 retries field from .story_retries', () => {\n   277→    writeFileSync(REAL_RETRIES, 'story-a 3\\nstory-b 1\\n', 'utf-8');\n   278→\n   279→    const result = migrateFromOldFormat();\n   280→    expect(result.success).toBe(true);\n   281→    if (result.success) {\n   282→      expect(result.data.retries).toEqual({ 'story-a': 3, 'story-b': 1 });\n   283→    }\n   284→  });\n   285→\n   286→  it('populates v2 flagged field from .flagged_stories', () => {\n   287→    writeFileSync(REAL_FLAGGED, 'story-x\\nstory-y\\n', 'utf-8');\n   288→\n   289→    const result = migrateFromOldFormat();\n   290→    expect(result.success).toBe(true);\n   291→    if (result.success) {\n   292→      expect(result.data.flagged).toEqual(['story-x', 'story-y']);\n   293→    }\n   294→  });\n   295→\n   296→  it('populates v2 session from ralph/status.json', () => {\n   297→    writeFileSync(\n   298→      REAL_STATUS,\n   299→      JSON.stringify({\n   300→        loop_count: 3,\n   301→        elapsed_seconds: 3698,\n   302→        status: 'running',\n   303→      }),\n   304→      'utf-8',\n   305→    );\n   306→\n   307→    const result = migrateFromOldFormat();\n   308→    expect(result.success).toBe(true);\n   309→    if (result.success) {\n   310→      expect(result.data.session.active).toBe(true);\n   311→      expect(result.data.session.iteration).toBe(3);\n   312→      expect(result.data.session.elapsedSeconds).toBe(3698);\n   313→    }\n   314→  });\n   315→\n   316→  it('initializes v2 epics as empty and observability as null', () => {\n   317→    writeFileSync(REAL_RETRIES, 'story-a 1\\n', 'utf-8');\n   318→\n   319→    const result = migrateFromOldFormat();\n   320→    expect(result.success).toBe(true);\n   321→    if (result.success) {\n   322→      expect(result.data.epics).toEqual({});\n   323→      expect(result.data.observability).toEqual({\n   324→        statementCoverage: null,\n   325→        branchCoverage: null,\n   326→        functionCoverage: null,\n   327→        lineCoverage: null,\n   328→      });\n   329→    }\n   330→  });\n   331→\n   332→  it('does NOT delete .story_retries or .flagged_stories after migration', () => {\n   333→    writeFileSync(REAL_RETRIES, 'story-a 1\\n', 'utf-8');\n   334→    writeFileSync(REAL_FLAGGED, 'story-b\\n', 'utf-8');\n   335→\n   336→    const result = migrateFromOldFormat();\n   337→    expect(result.success).toBe(true);\n   338→    // Files should still exist (deletion deferred to story 11-3)\n   339→    expect(existsSync(REAL_RETRIES)).toBe(true);\n   340→    expect(existsSync(REAL_FLAGGED)).toBe(true);\n   341→  });\n   342→});\n   343→\n   344→// ─── migrateV1ToV2 ──────────────────────────────────────────────────────────\n   345→\n   346→describe('migrateV1ToV2', () => {\n   347→  beforeEach(() => {\n   348→    saveOriginals();\n   349→    removeOldFiles();\n   350→  });\n   351→\n   352→  afterEach(() => {\n   353→    restoreOriginals();\n   354→  });\n   355→\n   356→  it('converts v1 state with retries/flagged files to v2', () => {\n   357→    writeFileSync(REAL_RETRIES, '10-3-python-provider 2\\n10-5-migrate-consumers 1\\n', 'utf-8');\n   358→    writeFileSync(REAL_FLAGGED, '9-5-multi-stack\\n10-3-python-provider\\n', 'utf-8');\n   359→\n   360→    const v1: SprintStateV1 = {\n   361→      version: 1,\n   362→      sprint: { total: 5, done: 3, failed: 0, blocked: 0, inProgress: null },\n   363→      stories: {\n   364→        'story-a': { status: 'done', attempts: 1, lastAttempt: null, lastError: null, proofPath: null, acResults: null },\n   365→      },\n   366→      run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n   367→      actionItems: [],\n   368→    };\n   369→\n   370→    const v2 = migrateV1ToV2(v1);\n   371→    expect(v2.version).toBe(2);\n   372→    expect(v2.retries).toEqual({ '10-3-python-provider': 2, '10-5-migrate-consumers': 1 });\n   373→    expect(v2.flagged).toEqual(['9-5-multi-stack', '10-3-python-provider']);\n   374→    expect(v2.stories).toEqual(v1.stories);\n   375→    expect(v2.sprint).toEqual(v1.sprint);\n   376→    expect(v2.run).toEqual(v1.run);\n   377→    expect(v2.actionItems).toEqual(v1.actionItems);\n   378→  });\n   379→\n   380→  it('converts v1 state without retries/flagged files to v2 with empty defaults', () => {\n   381→    const v1: SprintStateV1 = {\n   382→      version: 1,\n   383→      sprint: { total: 0, done: 0, failed: 0, blocked: 0, inProgress: null },\n   384→      stories: {},\n   385→      run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n   386→      actionItems: [],\n   387→    };\n   388→\n   389→    const v2 = migrateV1ToV2(v1);\n   390→    expect(v2.version).toBe(2);\n   391→    expect(v2.retries).toEqual({});\n   392→    expect(v2.flagged).toEqual([]);\n   393→    expect(v2.epics).toEqual({});\n   394→    expect(v2.session).toEqual({ active: false, startedAt: null, iteration: 0, elapsedSeconds: 0 });\n   395→    expect(v2.observability).toEqual({\n   396→      statementCoverage: null,\n   397→      branchCoverage: null,\n   398→      functionCoverage: null,\n   399→      lineCoverage: null,\n   400→    });\n   401→  });\n   402→\n   403→  it('reads session data from ralph/status.json during migration', () => {\n   404→    writeFileSync(\n   405→      REAL_STATUS,\n   406→      JSON.stringify({ status: 'running', loop_count: 3, elapsed_seconds: 3698 }),\n   407→      'utf-8',\n   408→    );\n   409→\n   410→    const v1: SprintStateV1 = {\n   411→      version: 1,\n   412→      sprint: { total: 0, done: 0, failed: 0, blocked: 0, inProgress: null },\n   413→      stories: {},\n   414→      run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n   415→      actionItems: [],\n   416→    };\n   417→\n   418→    const v2 = migrateV1ToV2(v1);\n   419→    expect(v2.session.active).toBe(true);\n   420→    expect(v2.session.iteration).toBe(3);\n   421→    expect(v2.session.elapsedSeconds).toBe(3698);\n   422→  });\n   423→\n   424→  it('handles missing version field (treated as v1)', () => {\n   425→    // Simulate a state with no version field\n   426→    const noVersion = {\n   427→      sprint: { total: 0, done: 0, failed: 0, blocked: 0, inProgress: null },\n   428→      stories: {},\n   429→      run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n   430→      actionItems: [],\n   431→    } as unknown as SprintStateV1;\n   432→\n   433→    const v2 = migrateV1ToV2(noVersion);\n   434→    expect(v2.version).toBe(2);\n   435→    expect(v2.retries).toEqual({});\n   436→    expect(v2.flagged).toEqual([]);\n   437→  });\n   438→\n   439→  it('handles retries file with malformed lines gracefully', () => {\n   440→    writeFileSync(REAL_RETRIES, 'good-story 3\\nbad-line\\n\\nanother-bad abc\\nok-story 5\\n', 'utf-8');\n   441→\n   442→    const v1: SprintStateV1 = {\n   443→      version: 1,\n   444→      sprint: { total: 0, done: 0, failed: 0, blocked: 0, inProgress: null },\n   445→      stories: {},\n   446→      run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n   447→      actionItems: [],\n   448→    };\n   449→\n   450→    const v2 = migrateV1ToV2(v1);\n   451→    expect(v2.retries).toEqual({ 'good-story': 3, 'ok-story': 5 });\n   452→    // Malformed lines should be skipped\n   453→    expect(v2.retries['bad-line']).toBeUndefined();\n   454→    expect(v2.retries['another-bad']).toBeUndefined();\n   455→  });\n   456→\n   457→  it('does NOT delete source files after migration', () => {\n   458→    writeFileSync(REAL_RETRIES, 'story-a 1\\n', 'utf-8');\n   459→    writeFileSync(REAL_FLAGGED, 'story-b\\n', 'utf-8');\n   460→\n   461→    const v1: SprintStateV1 = {\n   462→      version: 1,\n   463→      sprint: { total: 0, done: 0, failed: 0, blocked: 0, inProgress: null },\n   464→      stories: {},\n   465→      run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n   466→      actionItems: [],\n   467→    };\n   468→\n   469→    migrateV1ToV2(v1);\n   470→    expect(existsSync(REAL_RETRIES)).toBe(true);\n   471→    expect(existsSync(REAL_FLAGGED)).toBe(true);\n   472→  });\n   473→\n   474→  it('rejects negative retry counts', () => {\n   475→    writeFileSync(REAL_RETRIES, 'story-a -1\\nstory-b 3\\nstory-c -99\\n', 'utf-8');\n   476→\n   477→    const v1: SprintStateV1 = {\n   478→      version: 1,\n   479→      sprint: { total: 0, done: 0, failed: 0, blocked: 0, inProgress: null },\n   480→      stories: {},\n   481→      run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n   482→      actionItems: [],\n   483→    };\n   484→\n   485→    const v2 = migrateV1ToV2(v1);\n   486→    expect(v2.retries).toEqual({ 'story-b': 3 });\n   487→    expect(v2.retries['story-a']).toBeUndefined();\n   488→    expect(v2.retries['story-c']).toBeUndefined();\n   489→  });\n   490→\n   491→  it('deduplicates flagged stories', () => {\n   492→    writeFileSync(REAL_FLAGGED, 'story-a\\nstory-b\\nstory-a\\nstory-c\\nstory-b\\n', 'utf-8');\n   493→\n   494→    const v1: SprintStateV1 = {\n   495→      version: 1,\n   496→      sprint: { total: 0, done: 0, failed: 0, blocked: 0, inProgress: null },\n   497→      stories: {},\n   498→      run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n   499→      actionItems: [],\n   500→    };\n   501→\n   502→    const v2 = migrateV1ToV2(v1);\n   503→    expect(v2.flagged).toEqual(['story-a', 'story-b', 'story-c']);\n   504→  });\n   505→});\n   506→"}]},"parent_tool_use_id":null,"session_id":"0e449f80-823c-4489-a784-b43b6c7039d6","uuid":"b93fb935-dead-4643-b7ac-c6e9b02c906c","timestamp":"2026-03-24T10:51:46.403Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ivintik/dev/personal/codeharness/src/modules/sprint/__tests__/migration.test.ts","content":"import { describe, it, expect, beforeEach, afterEach } from 'vitest';\nimport {\n  readFileSync,\n  writeFileSync,\n  unlinkSync,\n  existsSync,\n} from 'node:fs';\nimport { join } from 'node:path';\nimport { migrateFromOldFormat, migrateV1ToV2 } from '../migration.js';\nimport type { SprintStateV1 } from '../../../types/state.js';\n\nconst ROOT = process.cwd();\nconst STATE_FILE = join(ROOT, 'sprint-state.json');\nconst TMP_FILE = join(ROOT, '.sprint-state.json.tmp');\nconst RALPH_DIR = join(ROOT, 'ralph');\nconst BMAD_DIR = join(\n  ROOT,\n  '_bmad-output',\n  'implementation-artifacts',\n);\n\n// We need to test with actual old file paths, so we'll create/cleanup them\nconst REAL_RETRIES = join(RALPH_DIR, '.story_retries');\nconst REAL_FLAGGED = join(RALPH_DIR, '.flagged_stories');\nconst REAL_STATUS = join(RALPH_DIR, 'status.json');\nconst REAL_YAML = join(BMAD_DIR, 'sprint-status.yaml');\nconst REAL_ISSUES = join(BMAD_DIR, '.session-issues.md');\n\n// Store original contents for restoration\nlet originalRetries: string | null = null;\nlet originalFlagged: string | null = null;\nlet originalStatus: string | null = null;\nlet originalYaml: string | null = null;\nlet originalIssues: string | null = null;\nlet originalState: string | null = null;\n\nfunction readSafe(path: string): string | null {\n  try { return readFileSync(path, 'utf-8'); } catch { return null; }\n}\n\nfunction saveOriginals(): void {\n  originalRetries = readSafe(REAL_RETRIES);\n  originalFlagged = readSafe(REAL_FLAGGED);\n  originalStatus = readSafe(REAL_STATUS);\n  originalYaml = readSafe(REAL_YAML);\n  originalIssues = readSafe(REAL_ISSUES);\n  originalState = readSafe(STATE_FILE);\n}\n\nfunction restoreOriginals(): void {\n  // Clean up sprint-state.json\n  if (originalState !== null) {\n    writeFileSync(STATE_FILE, originalState, 'utf-8');\n  } else if (existsSync(STATE_FILE)) {\n    unlinkSync(STATE_FILE);\n  }\n  if (existsSync(TMP_FILE)) unlinkSync(TMP_FILE);\n\n  // Restore originals\n  if (originalRetries !== null) writeFileSync(REAL_RETRIES, originalRetries, 'utf-8');\n  else if (existsSync(REAL_RETRIES)) unlinkSync(REAL_RETRIES);\n  if (originalFlagged !== null) writeFileSync(REAL_FLAGGED, originalFlagged, 'utf-8');\n  else if (existsSync(REAL_FLAGGED)) unlinkSync(REAL_FLAGGED);\n  if (originalStatus !== null) writeFileSync(REAL_STATUS, originalStatus, 'utf-8');\n  if (originalYaml !== null) writeFileSync(REAL_YAML, originalYaml, 'utf-8');\n  if (originalIssues !== null) writeFileSync(REAL_ISSUES, originalIssues, 'utf-8');\n}\n\nfunction removeOldFiles(): void {\n  for (const f of [REAL_RETRIES, REAL_FLAGGED, REAL_STATUS, REAL_YAML, REAL_ISSUES]) {\n    if (existsSync(f)) unlinkSync(f);\n  }\n}\n\ndescribe('migrateFromOldFormat', () => {\n  beforeEach(() => {\n    saveOriginals();\n    if (existsSync(STATE_FILE)) unlinkSync(STATE_FILE);\n    removeOldFiles();\n  });\n\n  afterEach(() => {\n    restoreOriginals();\n  });\n\n  it('returns fail when no old files exist', () => {\n    const result = migrateFromOldFormat();\n    expect(result.success).toBe(false);\n    if (!result.success) {\n      expect(result.error).toContain('No old format files');\n    }\n  });\n\n  it('migrates story retries into attempts', () => {\n    writeFileSync(\n      REAL_RETRIES,\n      'story-a 3\\nstory-b 1\\n',\n      'utf-8',\n    );\n\n    const result = migrateFromOldFormat();\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.stories['story-a'].attempts).toBe(3);\n      expect(result.data.stories['story-b'].attempts).toBe(1);\n    }\n  });\n\n  it('migrates sprint-status.yaml into story statuses', () => {\n    writeFileSync(\n      REAL_YAML,\n      [\n        '# Sprint Status',\n        'development_status:',\n        '  epic-1: done',\n        '  1-1-result-type: done',\n        '  1-2-module-skeleton: backlog',\n        '  2-1-sprint-state: in-progress',\n      ].join('\\n'),\n      'utf-8',\n    );\n\n    const result = migrateFromOldFormat();\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.stories['1-1-result-type'].status).toBe('done');\n      expect(result.data.stories['1-2-module-skeleton'].status).toBe('backlog');\n      expect(result.data.stories['2-1-sprint-state'].status).toBe('in-progress');\n      // epic-level entries should be skipped\n      expect(result.data.stories['epic-1']).toBeUndefined();\n    }\n  });\n\n  it('migrates ralph/status.json into run section', () => {\n    writeFileSync(\n      REAL_STATUS,\n      JSON.stringify({\n        loop_count: 5,\n        stories_total: 25,\n        stories_completed: 3,\n        elapsed_seconds: 1200,\n        status: 'running',\n      }),\n      'utf-8',\n    );\n\n    const result = migrateFromOldFormat();\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.run.iteration).toBe(5);\n      expect(result.data.run.active).toBe(true);\n    }\n  });\n\n  it('migrates flagged stories as blocked', () => {\n    writeFileSync(REAL_FLAGGED, 'story-x\\nstory-y\\n', 'utf-8');\n\n    const result = migrateFromOldFormat();\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.stories['story-x'].status).toBe('blocked');\n      expect(result.data.stories['story-y'].status).toBe('blocked');\n    }\n  });\n\n  it('migrates session issues into action items', () => {\n    writeFileSync(\n      REAL_ISSUES,\n      [\n        '# Session Issues',\n        '',\n        '### story-abc — dev-story (2026-03-18)',\n        '',\n        '- Something went wrong',\n        '- Another concern',\n        '',\n        '### story-def — code-review (2026-03-18)',\n        '',\n        '- Review finding',\n      ].join('\\n'),\n      'utf-8',\n    );\n\n    const result = migrateFromOldFormat();\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.actionItems.length).toBe(3);\n      expect(result.data.actionItems[0].story).toBe('story-abc');\n      expect(result.data.actionItems[0].description).toBe('Something went wrong');\n      expect(result.data.actionItems[2].story).toBe('story-def');\n    }\n  });\n\n  it('handles missing old files gracefully (partial migration)', () => {\n    // Only retries file exists\n    writeFileSync(REAL_RETRIES, 'only-story 2\\n', 'utf-8');\n\n    const result = migrateFromOldFormat();\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.stories['only-story'].attempts).toBe(2);\n      expect(result.data.run.active).toBe(false); // no status.json\n    }\n  });\n\n  it('writes sprint-state.json after migration', () => {\n    writeFileSync(REAL_RETRIES, 'migrated-story 1\\n', 'utf-8');\n\n    const result = migrateFromOldFormat();\n    expect(result.success).toBe(true);\n    expect(existsSync(STATE_FILE)).toBe(true);\n  });\n\n  it('handles invalid JSON in ralph/status.json gracefully', () => {\n    writeFileSync(REAL_STATUS, '{not valid json!!!', 'utf-8');\n\n    const result = migrateFromOldFormat();\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.run.active).toBe(false);\n      expect(result.data.run.iteration).toBe(0);\n    }\n  });\n\n  it('handles retries file with malformed lines', () => {\n    writeFileSync(\n      REAL_RETRIES,\n      'story-a 3\\nmalformed-no-count\\n\\nstory-b notanumber\\nstory-c 5\\n',\n      'utf-8',\n    );\n\n    const result = migrateFromOldFormat();\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.stories['story-a'].attempts).toBe(3);\n      expect(result.data.stories['story-c'].attempts).toBe(5);\n      expect(result.data.stories['malformed-no-count']).toBeUndefined();\n      expect(result.data.stories['story-b']).toBeUndefined();\n    }\n  });\n\n  it('computes sprint counts correctly', () => {\n    writeFileSync(\n      REAL_YAML,\n      [\n        'development_status:',\n        '  s1: done',\n        '  s2: done',\n        '  s3: failed',\n        '  s4: blocked',\n        '  s5: backlog',\n      ].join('\\n'),\n      'utf-8',\n    );\n\n    const result = migrateFromOldFormat();\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.sprint.total).toBe(5);\n      expect(result.data.sprint.done).toBe(2);\n      expect(result.data.sprint.failed).toBe(1);\n      expect(result.data.sprint.blocked).toBe(1);\n    }\n  });\n\n  it('outputs version 2 from migrateFromOldFormat', () => {\n    writeFileSync(REAL_RETRIES, 'story-a 1\\n', 'utf-8');\n\n    const result = migrateFromOldFormat();\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.version).toBe(2);\n    }\n  });\n\n  it('populates v2 retries field from .story_retries', () => {\n    writeFileSync(REAL_RETRIES, 'story-a 3\\nstory-b 1\\n', 'utf-8');\n\n    const result = migrateFromOldFormat();\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.retries).toEqual({ 'story-a': 3, 'story-b': 1 });\n    }\n  });\n\n  it('populates v2 flagged field from .flagged_stories', () => {\n    writeFileSync(REAL_FLAGGED, 'story-x\\nstory-y\\n', 'utf-8');\n\n    const result = migrateFromOldFormat();\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.flagged).toEqual(['story-x', 'story-y']);\n    }\n  });\n\n  it('populates v2 session from ralph/status.json', () => {\n    writeFileSync(\n      REAL_STATUS,\n      JSON.stringify({\n        loop_count: 3,\n        elapsed_seconds: 3698,\n        status: 'running',\n      }),\n      'utf-8',\n    );\n\n    const result = migrateFromOldFormat();\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.session.active).toBe(true);\n      expect(result.data.session.iteration).toBe(3);\n      expect(result.data.session.elapsedSeconds).toBe(3698);\n    }\n  });\n\n  it('initializes v2 epics as empty and observability as null', () => {\n    writeFileSync(REAL_RETRIES, 'story-a 1\\n', 'utf-8');\n\n    const result = migrateFromOldFormat();\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.epics).toEqual({});\n      expect(result.data.observability).toEqual({\n        statementCoverage: null,\n        branchCoverage: null,\n        functionCoverage: null,\n        lineCoverage: null,\n      });\n    }\n  });\n\n  it('does NOT delete .story_retries or .flagged_stories after migration', () => {\n    writeFileSync(REAL_RETRIES, 'story-a 1\\n', 'utf-8');\n    writeFileSync(REAL_FLAGGED, 'story-b\\n', 'utf-8');\n\n    const result = migrateFromOldFormat();\n    expect(result.success).toBe(true);\n    // Files should still exist (deletion deferred to story 11-3)\n    expect(existsSync(REAL_RETRIES)).toBe(true);\n    expect(existsSync(REAL_FLAGGED)).toBe(true);\n  });\n});\n\n// ─── migrateV1ToV2 ──────────────────────────────────────────────────────────\n\ndescribe('migrateV1ToV2', () => {\n  beforeEach(() => {\n    saveOriginals();\n    removeOldFiles();\n  });\n\n  afterEach(() => {\n    restoreOriginals();\n  });\n\n  it('converts v1 state with retries/flagged files to v2', () => {\n    writeFileSync(REAL_RETRIES, '10-3-python-provider 2\\n10-5-migrate-consumers 1\\n', 'utf-8');\n    writeFileSync(REAL_FLAGGED, '9-5-multi-stack\\n10-3-python-provider\\n', 'utf-8');\n\n    const v1: SprintStateV1 = {\n      version: 1,\n      sprint: { total: 5, done: 3, failed: 0, blocked: 0, inProgress: null },\n      stories: {\n        'story-a': { status: 'done', attempts: 1, lastAttempt: null, lastError: null, proofPath: null, acResults: null },\n      },\n      run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n      actionItems: [],\n    };\n\n    const v2 = migrateV1ToV2(v1);\n    expect(v2.version).toBe(2);\n    expect(v2.retries).toEqual({ '10-3-python-provider': 2, '10-5-migrate-consumers': 1 });\n    expect(v2.flagged).toEqual(['9-5-multi-stack', '10-3-python-provider']);\n    expect(v2.stories).toEqual(v1.stories);\n    expect(v2.sprint).toEqual(v1.sprint);\n    expect(v2.run).toEqual(v1.run);\n    expect(v2.actionItems).toEqual(v1.actionItems);\n  });\n\n  it('converts v1 state without retries/flagged files to v2 with empty defaults', () => {\n    const v1: SprintStateV1 = {\n      version: 1,\n      sprint: { total: 0, done: 0, failed: 0, blocked: 0, inProgress: null },\n      stories: {},\n      run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n      actionItems: [],\n    };\n\n    const v2 = migrateV1ToV2(v1);\n    expect(v2.version).toBe(2);\n    expect(v2.retries).toEqual({});\n    expect(v2.flagged).toEqual([]);\n    expect(v2.epics).toEqual({});\n    expect(v2.session).toEqual({ active: false, startedAt: null, iteration: 0, elapsedSeconds: 0 });\n    expect(v2.observability).toEqual({\n      statementCoverage: null,\n      branchCoverage: null,\n      functionCoverage: null,\n      lineCoverage: null,\n    });\n  });\n\n  it('reads session data from ralph/status.json during migration', () => {\n    writeFileSync(\n      REAL_STATUS,\n      JSON.stringify({ status: 'running', loop_count: 3, elapsed_seconds: 3698 }),\n      'utf-8',\n    );\n\n    const v1: SprintStateV1 = {\n      version: 1,\n      sprint: { total: 0, done: 0, failed: 0, blocked: 0, inProgress: null },\n      stories: {},\n      run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n      actionItems: [],\n    };\n\n    const v2 = migrateV1ToV2(v1);\n    expect(v2.session.active).toBe(true);\n    expect(v2.session.iteration).toBe(3);\n    expect(v2.session.elapsedSeconds).toBe(3698);\n  });\n\n  it('handles missing version field (treated as v1)', () => {\n    // Simulate a state with no version field\n    const noVersion = {\n      sprint: { total: 0, done: 0, failed: 0, blocked: 0, inProgress: null },\n      stories: {},\n      run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n      actionItems: [],\n    } as unknown as SprintStateV1;\n\n    const v2 = migrateV1ToV2(noVersion);\n    expect(v2.version).toBe(2);\n    expect(v2.retries).toEqual({});\n    expect(v2.flagged).toEqual([]);\n  });\n\n  it('handles retries file with malformed lines gracefully', () => {\n    writeFileSync(REAL_RETRIES, 'good-story 3\\nbad-line\\n\\nanother-bad abc\\nok-story 5\\n', 'utf-8');\n\n    const v1: SprintStateV1 = {\n      version: 1,\n      sprint: { total: 0, done: 0, failed: 0, blocked: 0, inProgress: null },\n      stories: {},\n      run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n      actionItems: [],\n    };\n\n    const v2 = migrateV1ToV2(v1);\n    expect(v2.retries).toEqual({ 'good-story': 3, 'ok-story': 5 });\n    // Malformed lines should be skipped\n    expect(v2.retries['bad-line']).toBeUndefined();\n    expect(v2.retries['another-bad']).toBeUndefined();\n  });\n\n  it('does NOT delete source files after migration', () => {\n    writeFileSync(REAL_RETRIES, 'story-a 1\\n', 'utf-8');\n    writeFileSync(REAL_FLAGGED, 'story-b\\n', 'utf-8');\n\n    const v1: SprintStateV1 = {\n      version: 1,\n      sprint: { total: 0, done: 0, failed: 0, blocked: 0, inProgress: null },\n      stories: {},\n      run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n      actionItems: [],\n    };\n\n    migrateV1ToV2(v1);\n    expect(existsSync(REAL_RETRIES)).toBe(true);\n    expect(existsSync(REAL_FLAGGED)).toBe(true);\n  });\n\n  it('rejects negative retry counts', () => {\n    writeFileSync(REAL_RETRIES, 'story-a -1\\nstory-b 3\\nstory-c -99\\n', 'utf-8');\n\n    const v1: SprintStateV1 = {\n      version: 1,\n      sprint: { total: 0, done: 0, failed: 0, blocked: 0, inProgress: null },\n      stories: {},\n      run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n      actionItems: [],\n    };\n\n    const v2 = migrateV1ToV2(v1);\n    expect(v2.retries).toEqual({ 'story-b': 3 });\n    expect(v2.retries['story-a']).toBeUndefined();\n    expect(v2.retries['story-c']).toBeUndefined();\n  });\n\n  it('deduplicates flagged stories', () => {\n    writeFileSync(REAL_FLAGGED, 'story-a\\nstory-b\\nstory-a\\nstory-c\\nstory-b\\n', 'utf-8');\n\n    const v1: SprintStateV1 = {\n      version: 1,\n      sprint: { total: 0, done: 0, failed: 0, blocked: 0, inProgress: null },\n      stories: {},\n      run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n      actionItems: [],\n    };\n\n    const v2 = migrateV1ToV2(v1);\n    expect(v2.flagged).toEqual(['story-a', 'story-b', 'story-c']);\n  });\n});\n","numLines":506,"startLine":1,"totalLines":506}}}
