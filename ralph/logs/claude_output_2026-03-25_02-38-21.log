   87→\n    88→    const result = cleanupContainers();\n    89→    expect(result.success).toBe(true);\n    90→    if (result.success) {\n    91→      expect(result.data.containersRemoved).toBe(1);\n    92→      expect(result.data.names).toContain('codeharness-collector-otel-1');\n    93→    }\n    94→  });\n    95→\n    96→  it('continues if individual container removal fails', () => {\n    97→    let rmCallCount = 0;\n    98→    mockExecFileSync.mockImplementation((cmd: string, args?: readonly string[]) => {\n    99→      const argsArray = args as string[];\n   100→      if (cmd === 'docker' && argsArray?.[0] === 'ps' && argsArray?.includes('name=codeharness-shared-')) {\n   101→        return Buffer.from('container-a\\ncontainer-b\\n');\n   102→      }\n   103→      if (cmd === 'docker' && argsArray?.[0] === 'ps' && argsArray?.includes('name=codeharness-collector-')) {\n   104→        return Buffer.from('');\n   105→      }\n   106→      if (cmd === 'docker' && argsArray?.[0] === 'rm') {\n   107→        rmCallCount++;\n   108→        if (rmCallCount === 1) {\n   109→          throw new Error('removal failed');\n   110→        }\n   111→        return Buffer.from('');\n   112→      }\n   113→      return Buffer.from('');\n   114→    });\n   115→\n   116→    const result = cleanupContainers();\n   117→    expect(result.success).toBe(true);\n   118→    if (result.success) {\n   119→      // Only the second one succeeded\n   120→      expect(result.data.containersRemoved).toBe(1);\n   121→      expect(result.data.names).toContain('container-b');\n   122→    }\n   123→  });\n   124→\n   125→  it('handles docker ps failure gracefully for a pattern', () => {\n   126→    mockExecFileSync.mockImplementation((cmd: string, args?: readonly string[]) => {\n   127→      const argsArray = args as string[];\n   128→      if (cmd === 'docker' && argsArray?.[0] === 'ps' && argsArray?.includes('name=codeharness-shared-')) {\n   129→        throw new Error('docker ps failed');\n   130→      }\n   131→      if (cmd === 'docker' && argsArray?.[0] === 'ps' && argsArray?.includes('name=codeharness-collector-')) {\n   132→        return Buffer.from('codeharness-collector-otel-1\\n');\n   133→      }\n   134→      if (cmd === 'docker' && argsArray?.[0] === 'rm') {\n   135→        return Buffer.from('');\n   136→      }\n   137→      return Buffer.from('');\n   138→    });\n   139→\n   140→    const result = cleanupContainers();\n   141→    expect(result.success).toBe(true);\n   142→    if (result.success) {\n   143→      expect(result.data.containersRemoved).toBe(1);\n   144→    }\n   145→  });\n   146→});\n   147→"}]},"parent_tool_use_id":"toolu_01LE7RFzUgPSCiom8nKkvXNg","session_id":"174e0897-5fbc-4ae0-bbc6-8b881d5c7525","uuid":"f4225825-ca15-413c-a8c5-86cf027c633c","timestamp":"2026-03-24T22:42:23.181Z"}
