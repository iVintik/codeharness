{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013UW7M2fjkGqqiAXTXf7tvA","type":"tool_result","content":"1\timport type { WorkflowState, TaskCheckpoint } from './workflow-state.js';\n2\t\n3\t// --- Types ---\n4\t\n5\t/** Session boundary mode as defined in workflow YAML schema. */\n6\texport type SessionBoundary = 'fresh' | 'continue';\n7\t\n8\t/** Key that uniquely identifies a task+story combination for session lookup. */\n9\texport interface SessionLookupKey {\n10\t  taskName: string;\n11\t  storyKey: string;\n12\t}\n13\t\n14\t// --- Functions ---\n15\t\n16\t/**\n17\t * Resolve the session ID to use for a dispatch call.\n18\t *\n19\t * - `fresh`: always returns undefined (new session).\n20\t * - `continue`: returns the most recent session ID for the task+story pair,\n21\t *    or undefined if none exists (first invocation falls back to fresh).\n22\t *\n23\t * Does NOT cache — always reads from the supplied WorkflowState for crash-recovery safety.\n24\t */\n25\texport function resolveSessionId(\n26\t  boundary: SessionBoundary,\n27\t  key: SessionLookupKey,\n28\t  state: WorkflowState,\n29\t): string | undefined {\n30\t  if (boundary === 'fresh') {\n31\t    return undefined;\n32\t  }\n33\t\n34\t  if (boundary !== 'continue') {\n35\t    // Defensive: unknown boundary value treated as fresh (safe default).\n36\t    return undefined;\n37\t  }\n38\t\n39\t  return getLastSessionId(state, key.taskName, key.storyKey);\n40\t}\n41\t\n42\t/**\n43\t * Record a session ID on a new TaskCheckpoint in the workflow state.\n44\t *\n45\t * Returns a **new** WorkflowState (does not mutate the input).\n46\t *\n47\t * Appends a new checkpoint entry with `session_id`, `task_name`, `story_key`,\n48\t * and `completed_at` (set to current time). The workflow engine (story 5-1)\n49\t * may enrich the checkpoint with additional fields after creation.\n50\t *\n51\t * Throws if `sessionId` is empty — an empty session ID indicates an SDK bug\n52\t * and must not be silently recorded.\n53\t */\n54\texport function recordSessionId(\n55\t  key: SessionLookupKey,\n56\t  sessionId: string,\n57\t  state: WorkflowState,\n58\t): WorkflowState {\n59\t  if (!sessionId) {\n60\t    throw new Error('recordSessionId: sessionId must be a non-empty string');\n61\t  }\n62\t\n63\t  const checkpoint: TaskCheckpoint = {\n64\t    task_name: key.taskName,\n65\t    story_key: key.storyKey,\n66\t    completed_at: new Date().toISOString(),\n67\t    session_id: sessionId,\n68\t  };\n69\t\n70\t  return {\n71\t    ...state,\n72\t    tasks_completed: [...state.tasks_completed, checkpoint],\n73\t  };\n74\t}\n75\t\n76\t/**\n77\t * Find the most recent session ID for a given task+story pair.\n78\t *\n79\t * Searches `tasks_completed` in reverse order so the most recent checkpoint\n80\t * (including from loop iterations) is found first.\n81\t *\n82\t * Returns undefined when no matching checkpoint exists.\n83\t */\n84\texport function getLastSessionId(\n85\t  state: WorkflowState,\n86\t  taskName: string,\n87\t  storyKey: string,\n88\t): string | undefined {\n89\t  const tasks = state.tasks_completed;\n90\t\n91\t  for (let i = tasks.length - 1; i >= 0; i--) {\n92\t    const cp = tasks[i];\n93\t    if (cp.task_name === taskName && cp.story_key === storyKey && cp.session_id !== undefined) {\n94\t      return cp.session_id;\n95\t    }\n96\t  }\n97\t\n98\t  return undefined;\n99\t}\n100\t"}]},"parent_tool_use_id":"toolu_01CbLWtVmWF61E7hNafuWso7","session_id":"1d3ed03d-179a-4015-85c3-0be0521b6265","uuid":"c9239cb6-1b3b-436f-a437-88ef8cfea122","timestamp":"2026-04-02T21:13:46.733Z"}
