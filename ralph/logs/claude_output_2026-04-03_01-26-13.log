{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RkoAo9udkMfN2GwLVRAMiY","type":"tool_result","content":"1\timport type { WorkflowState } from './workflow-state.js';\n2\t\n3\t// --- Functions ---\n4\t\n5\t/**\n6\t * Sanitize a string segment for use in a trace ID.\n7\t *\n8\t * Replaces non-alphanumeric characters (except hyphens) with hyphens,\n9\t * collapses consecutive hyphens, and trims leading/trailing hyphens.\n10\t */\n11\texport function sanitizeSegment(segment: string): string {\n12\t  return segment\n13\t    .replace(/[^a-zA-Z0-9-]/g, '-')\n14\t    .replace(/-{2,}/g, '-')\n15\t    .replace(/^-+|-+$/g, '');\n16\t}\n17\t\n18\t/** Maximum length for individual segments (runId, taskName) after sanitization. */\n19\tconst MAX_SEGMENT_LENGTH = 128;\n20\t\n21\t/**\n22\t * Generate a trace ID for a workflow iteration.\n23\t *\n24\t * Format: `ch-{runId}-{iteration}-{taskName}`\n25\t *\n26\t * The `runId` and `taskName` segments are sanitized to be safe for logs,\n27\t * metrics labels, HTTP headers, and YAML serialization.\n28\t *\n29\t * Throws if `iteration` is not a non-negative integer.\n30\t */\n31\texport function generateTraceId(\n32\t  runId: string,\n33\t  iteration: number,\n34\t  taskName: string,\n35\t): string {\n36\t  if (!Number.isInteger(iteration) || iteration < 0) {\n37\t    throw new Error(\n38\t      `generateTraceId: iteration must be a non-negative integer, got ${iteration}`,\n39\t    );\n40\t  }\n41\t\n42\t  const safeRunId = sanitizeSegment(runId).slice(0, MAX_SEGMENT_LENGTH);\n43\t  const safeTask = sanitizeSegment(taskName).slice(0, MAX_SEGMENT_LENGTH);\n44\t  return `ch-${safeRunId}-${iteration}-${safeTask}`;\n45\t}\n46\t\n47\t/**\n48\t * Format a trace ID as a system prompt fragment for agent injection.\n49\t *\n50\t * Returns a structured block that an agent can include in log/metric/trace output.\n51\t *\n52\t * Throws if `traceId` is empty.\n53\t */\n54\texport function formatTracePrompt(traceId: string): string {\n55\t  if (!traceId) {\n56\t    throw new Error('formatTracePrompt: traceId must be a non-empty string');\n57\t  }\n58\t  return `[TRACE] trace_id=${traceId}\\nInclude this trace ID in all log output, metric labels, and trace spans for correlation.`;\n59\t}\n60\t\n61\t/**\n62\t * Record a trace ID in workflow state.\n63\t *\n64\t * Returns a **new** WorkflowState with the trace ID appended to `trace_ids`.\n65\t * Does not mutate the input state.\n66\t *\n67\t * Throws if `traceId` is empty.\n68\t */\n69\texport function recordTraceId(\n70\t  traceId: string,\n71\t  state: WorkflowState,\n72\t): WorkflowState {\n73\t  if (!traceId) {\n74\t    throw new Error('recordTraceId: traceId must be a non-empty string');\n75\t  }\n76\t\n77\t  return {\n78\t    ...state,\n79\t    trace_ids: [...(state.trace_ids ?? []), traceId],\n80\t  };\n81\t}\n82\t"}]},"parent_tool_use_id":"toolu_017i6AU21x7rH4bBTJ7j8yGD","session_id":"02876edc-b40e-4eff-87e1-ceab09778e92","uuid":"b012c87b-d434-4edc-b4ce-f325f5de432a","timestamp":"2026-04-02T21:39:00.666Z"}
