{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0164DHcCcNJ4mFcWrvnRq3GQ","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { render } from 'ink-testing-library';\n3\timport React from 'react';\n4\timport { MergeStatus } from '../ink-merge-status.js';\n5\timport type { MergeState, MergeStatusProps, MergeTestResults } from '../ink-merge-status.js';\n6\t\n7\tdescribe('MergeStatus component', () => {\n8\t  it('exports MergeStatus as a function component', () => {\n9\t    expect(MergeStatus).toBeDefined();\n10\t    expect(typeof MergeStatus).toBe('function');\n11\t  });\n12\t\n13\t  it('renders nothing when mergeState is null', () => {\n14\t    const { lastFrame } = render(<MergeStatus mergeState={null} />);\n15\t    expect(lastFrame()).toBe('');\n16\t  });\n17\t\n18\t  it('renders clean merge in green', () => {\n19\t    const mergeState: MergeState = {\n20\t      epicId: 'epic-14',\n21\t      outcome: 'clean',\n22\t      conflictCount: 0,\n23\t    };\n24\t    const { lastFrame } = render(<MergeStatus mergeState={mergeState} />);\n25\t    const frame = lastFrame()!;\n26\t    expect(frame).toContain('[OK] Merge epic-14');\n27\t    expect(frame).toContain('\\u2192 main: clean (0 conflicts)');\n28\t  });\n29\t\n30\t  it('renders resolved merge with file paths', () => {\n31\t    const mergeState: MergeState = {\n32\t      epicId: 'epic-11',\n33\t      outcome: 'resolved',\n34\t      conflictCount: 1,\n35\t      conflicts: ['src/lib/workflow-engine.ts: additive changes in different functions'],\n36\t    };\n37\t    const { lastFrame } = render(<MergeStatus mergeState={mergeState} />);\n38\t    const frame = lastFrame()!;\n39\t    expect(frame).toContain('[OK] Merge epic-11');\n40\t    expect(frame).toContain('1 conflict auto-resolved');\n41\t    expect(frame).toContain('src/lib/workflow-engine.ts');\n42\t  });\n43\t\n44\t  it('renders resolved merge with plural conflicts', () => {\n45\t    const mergeState: MergeState = {\n46\t      epicId: 'epic-11',\n47\t      outcome: 'resolved',\n48\t      conflictCount: 3,\n49\t      conflicts: ['file1.ts', 'file2.ts', 'file3.ts'],\n50\t    };\n51\t    const { lastFrame } = render(<MergeStatus mergeState={mergeState} />);\n52\t    const frame = lastFrame()!;\n53\t    expect(frame).toContain('3 conflicts auto-resolved');\n54\t    expect(frame).toContain('file1.ts');\n55\t    expect(frame).toContain('file2.ts');\n56\t    expect(frame).toContain('file3.ts');\n57\t  });\n58\t\n59\t  it('renders escalated merge in red with worktree path', () => {\n60\t    const mergeState: MergeState = {\n61\t      epicId: 'epic-11',\n62\t      outcome: 'escalated',\n63\t      reason: 'conflict unresolvable after 3 attempts',\n64\t      conflicts: ['src/lib/workflow-engine.ts: semantic conflict in dispatchTaskWithResult()'],\n65\t      worktreePath: '/tmp/codeharness-wt-epic-11',\n66\t    };\n67\t    const { lastFrame } = render(<MergeStatus mergeState={mergeState} />);\n68\t    const frame = lastFrame()!;\n69\t    expect(frame).toContain('[FAIL] Merge epic-11');\n70\t    expect(frame).toContain('conflict unresolvable after 3 attempts');\n71\t    expect(frame).toContain('src/lib/workflow-engine.ts');\n72\t    expect(frame).toContain('Manual resolution required');\n73\t    expect(frame).toContain('Worktree preserved: /tmp/codeharness-wt-epic-11');\n74\t  });\n75\t\n76\t  it('renders escalated merge without worktree path', () => {\n77\t    const mergeState: MergeState = {\n78\t      epicId: 'epic-11',\n79\t      outcome: 'escalated',\n80\t      reason: 'merge failed',\n81\t    };\n82\t    const { lastFrame } = render(<MergeStatus mergeState={mergeState} />);\n83\t    const frame = lastFrame()!;\n84\t    expect(frame).toContain('[FAIL] Merge epic-11');\n85\t    expect(frame).toContain('merge failed');\n86\t    expect(frame).toContain('Manual resolution required');\n87\t    expect(frame).not.toContain('Worktree preserved');\n88\t  });\n89\t\n90\t  it('renders passing test results in green', () => {\n91\t    const mergeState: MergeState = {\n92\t      epicId: 'epic-14',\n93\t      outcome: 'clean',\n94\t      conflictCount: 0,\n95\t      testResults: {\n96\t        passed: 1650,\n97\t        failed: 0,\n98\t        total: 1650,\n99\t        durationSecs: 18,\n100\t        coverage: null,\n101\t      },\n102\t    };\n103\t    const { lastFrame } = render(<MergeStatus mergeState={mergeState} />);\n104\t    const frame = lastFrame()!;\n105\t    expect(frame).toContain('[OK] Tests: 1650/1650 passed (18s)');\n106\t  });\n107\t\n108\t  it('renders failing test results in red', () => {\n109\t    const mergeState: MergeState = {\n110\t      epicId: 'epic-14',\n111\t      outcome: 'clean',\n112\t      conflictCount: 0,\n113\t      testResults: {\n114\t        passed: 1648,\n115\t        failed: 2,\n116\t        total: 1650,\n117\t        durationSecs: 19,\n118\t        coverage: null,\n119\t      },\n120\t    };\n121\t    const { lastFrame } = render(<MergeStatus mergeState={mergeState} />);\n122\t    const frame = lastFrame()!;\n123\t    expect(frame).toContain('[FAIL] Tests: 1648/1650 passed (19s)');\n124\t  });\n125\t\n126\t  it('renders test results with coverage when available', () => {\n127\t    const mergeState: MergeState = {\n128\t      epicId: 'epic-14',\n129\t      outcome: 'clean',\n130\t      testResults: {\n131\t        passed: 1650,\n132\t        failed: 0,\n133\t        total: 1650,\n134\t        durationSecs: 18,\n135\t        coverage: 94,\n136\t      },\n137\t    };\n138\t    const { lastFrame } = render(<MergeStatus mergeState={mergeState} />);\n139\t    const frame = lastFrame()!;\n140\t    expect(frame).toContain('[OK] Tests: 1650/1650 passed (18s) 94% coverage');\n141\t  });\n142\t\n143\t  it('renders in-progress merge', () => {\n144\t    const mergeState: MergeState = {\n145\t      epicId: 'epic-14',\n146\t      outcome: 'in-progress',\n147\t    };\n148\t    const { lastFrame } = render(<MergeStatus mergeState={mergeState} />);\n149\t    const frame = lastFrame()!;\n150\t    expect(frame).toContain('Merging epic-14');\n151\t    expect(frame).toContain('\\u2192 main');\n152\t    expect(frame).toContain('\\u25CC');\n153\t  });\n154\t\n155\t  it('exports correct types', () => {\n156\t    // Type-level check: ensure interfaces are importable\n157\t    const state: MergeState = {\n158\t      epicId: 'epic-14',\n159\t      outcome: 'clean',\n160\t      conflictCount: 0,\n161\t      testResults: { passed: 100, failed: 0, total: 100, durationSecs: 5, coverage: 90 },\n162\t      worktreePath: '/tmp/wt',\n163\t      reason: 'test',\n164\t      conflicts: ['file.ts'],\n165\t    };\n166\t    const props: MergeStatusProps = { mergeState: state };\n167\t    expect(props.mergeState).not.toBeNull();\n168\t  });\n169\t\n170\t  it('renders escalated with default reason when reason is missing', () => {\n171\t    const mergeState: MergeState = {\n172\t      epicId: 'epic-11',\n173\t      outcome: 'escalated',\n174\t    };\n175\t    const { lastFrame } = render(<MergeStatus mergeState={mergeState} />);\n176\t    const frame = lastFrame()!;\n177\t    expect(frame).toContain('[FAIL] Merge epic-11');\n178\t    expect(frame).toContain('unknown error');\n179\t  });\n180\t\n181\t  it('renders resolved merge deriving count from conflicts array when conflictCount absent', () => {\n182\t    const mergeState: MergeState = {\n183\t      epicId: 'epic-11',\n184\t      outcome: 'resolved',\n185\t      conflicts: ['file1.ts', 'file2.ts'],\n186\t    };\n187\t    const { lastFrame } = render(<MergeStatus mergeState={mergeState} />);\n188\t    const frame = lastFrame()!;\n189\t    expect(frame).toContain('2 conflicts auto-resolved');\n190\t  });\n191\t});\n192\t"}]},"parent_tool_use_id":"toolu_01TzQwpEV7uekTzzh7pB5DWd","session_id":"7e3ded59-6184-4f8b-8f55-ba5e63dae51f","uuid":"328b8774-2a97-446f-a11e-79a3ca8b2030","timestamp":"2026-04-04T02:49:40.652Z"}
