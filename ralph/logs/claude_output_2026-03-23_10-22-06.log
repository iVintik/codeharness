{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01T8arxy1yP9n5DMW4rQs9Dk","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→\n     3→vi.mock('node:child_process', () => ({\n     4→  execFileSync: vi.fn(),\n     5→}));\n     6→\n     7→import { execFileSync } from 'node:child_process';\n     8→import {\n     9→  checkInstalled,\n    10→  installDependency,\n    11→  installAllDependencies,\n    12→  parseVersion,\n    13→  CriticalDependencyError,\n    14→  DEPENDENCY_REGISTRY,\n    15→} from '../deps.js';\n    16→import type { DependencySpec } from '../deps.js';\n    17→\n    18→const mockExecFileSync = vi.mocked(execFileSync);\n    19→\n    20→beforeEach(() => {\n    21→  vi.restoreAllMocks();\n    22→  // Suppress console output during tests\n    23→  vi.spyOn(console, 'log').mockImplementation(() => {});\n    24→});\n    25→\n    26→describe('parseVersion', () => {\n    27→  it('extracts version from simple output', () => {\n    28→    expect(parseVersion('1.2.3')).toBe('1.2.3');\n    29→  });\n    30→\n    31→  it('extracts version from \"tool v1.2.3\" format', () => {\n    32→    expect(parseVersion('showboat v0.6.1')).toBe('0.6.1');\n    33→  });\n    34→\n    35→  it('extracts version from \"tool version 1.2.3\" format', () => {\n    36→    expect(parseVersion('bd version 2.0.0-beta.1')).toBe('2.0.0-beta.1');\n    37→  });\n    38→\n    39→  it('returns null when no version found', () => {\n    40→    expect(parseVersion('no version here')).toBeNull();\n    41→  });\n    42→\n    43→  it('returns null for empty string', () => {\n    44→    expect(parseVersion('')).toBeNull();\n    45→  });\n    46→});\n    47→\n    48→describe('checkInstalled', () => {\n    49→  const spec: DependencySpec = {\n    50→    name: 'test-tool',\n    51→    displayName: 'TestTool',\n    52→    installCommands: [{ cmd: 'pip', args: ['install', 'test-tool'] }],\n    53→    checkCommand: { cmd: 'test-tool', args: ['--version'] },\n    54→    critical: false,\n    55→  };\n    56→\n    57→  it('returns installed=true with version when command succeeds', () => {\n    58→    mockExecFileSync.mockReturnValue(Buffer.from('test-tool 1.0.0'));\n    59→    const result = checkInstalled(spec);\n    60→    expect(result.installed).toBe(true);\n    61→    expect(result.version).toBe('1.0.0');\n    62→    expect(mockExecFileSync).toHaveBeenCalledWith('test-tool', ['--version'], { stdio: 'pipe', timeout: 15_000 });\n    63→  });\n    64→\n    65→  it('returns installed=false when command fails', () => {\n    66→    mockExecFileSync.mockImplementation(() => {\n    67→      throw new Error('command not found');\n    68→    });\n    69→    const result = checkInstalled(spec);\n    70→    expect(result.installed).toBe(false);\n    71→    expect(result.version).toBeNull();\n    72→  });\n    73→\n    74→  it('returns installed=true with null version when output has no version', () => {\n    75→    mockExecFileSync.mockReturnValue(Buffer.from('some output without version'));\n    76→    const result = checkInstalled(spec);\n    77→    expect(result.installed).toBe(true);\n    78→    expect(result.version).toBeNull();\n    79→  });\n    80→});\n    81→\n    82→describe('installDependency', () => {\n    83→  const nonCriticalSpec: DependencySpec = {\n    84→    name: 'showboat',\n    85→    displayName: 'Showboat',\n    86→    installCommands: [\n    87→      { cmd: 'pip', args: ['install', 'showboat'] },\n    88→      { cmd: 'pipx', args: ['install', 'showboat'] },\n    89→    ],\n    90→    checkCommand: { cmd: 'showboat', args: ['--version'] },\n    91→    critical: false,\n    92→  };\n    93→\n    94→  it('returns already-installed when tool is already present', () => {\n    95→    mockExecFileSync.mockReturnValue(Buffer.from('showboat 0.6.1'));\n    96→    const result = installDependency(nonCriticalSpec);\n    97→    expect(result.status).toBe('already-installed');\n    98→    expect(result.version).toBe('0.6.1');\n    99→  });\n   100→\n   101→  it('installs via primary command and returns installed', () => {\n   102→    let checkCount = 0;\n   103→    mockExecFileSync.mockImplementation((cmd) => {\n   104→      const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   105→      // Version check: first fails, then succeeds\n   106→      if (cmdStr === 'showboat') {\n   107→        checkCount++;\n   108→        if (checkCount === 1) throw new Error('not found');\n   109→        return Buffer.from('showboat 0.6.1');\n   110→      }\n   111→      // Install command succeeds\n   112→      return Buffer.from('');\n   113→    });\n   114→\n   115→    const result = installDependency(nonCriticalSpec);\n   116→    expect(result.status).toBe('installed');\n   117→    expect(result.version).toBe('0.6.1');\n   118→  });\n   119→\n   120→  it('falls back to secondary command when primary fails', () => {\n   121→    let checkCount = 0;\n   122→    mockExecFileSync.mockImplementation((cmd) => {\n   123→      const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   124→      if (cmdStr === 'showboat') {\n   125→        checkCount++;\n   126→        if (checkCount === 1) throw new Error('not found');\n   127→        return Buffer.from('showboat 0.6.1');\n   128→      }\n   129→      if (cmdStr === 'pip') throw new Error('pip not found');\n   130→      // pipx install succeeds\n   131→      return Buffer.from('');\n   132→    });\n   133→\n   134→    const result = installDependency(nonCriticalSpec);\n   135→    expect(result.status).toBe('installed');\n   136→    expect(result.version).toBe('0.6.1');\n   137→  });\n   138→\n   139→  it('returns failed when all install commands fail', () => {\n   140→    mockExecFileSync.mockImplementation(() => {\n   141→      throw new Error('command failed');\n   142→    });\n   143→\n   144→    const result = installDependency(nonCriticalSpec);\n   145→    expect(result.status).toBe('failed');\n   146→    expect(result.version).toBeNull();\n   147→    expect(result.error).toContain('Install failed');\n   148→    expect(result.error).toContain('pip install showboat');\n   149→    expect(result.error).toContain('pipx install showboat');\n   150→  });\n   151→\n   152→  it('returns failed when install succeeds but post-check fails', () => {\n   153→    mockExecFileSync.mockImplementation((cmd) => {\n   154→      const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   155→      if (cmdStr === 'showboat') throw new Error('not found');\n   156→      // Install commands succeed but version check always fails\n   157→      return Buffer.from('');\n   158→    });\n   159→\n   160→    const result = installDependency(nonCriticalSpec);\n   161→    expect(result.status).toBe('failed');\n   162→  });\n   163→\n   164→  describe('semgrep entry', () => {\n   165→    // Use actual registry entry to catch regressions if the registry changes\n   166→    const semgrepSpec = DEPENDENCY_REGISTRY.find(d => d.name === 'semgrep')!;\n   167→\n   168→    it('returns already-installed when semgrep is present', () => {\n   169→      mockExecFileSync.mockReturnValue(Buffer.from('1.56.0'));\n   170→      const result = installDependency(semgrepSpec);\n   171→      expect(result.status).toBe('already-installed');\n   172→      expect(result.version).toBe('1.56.0');\n   173→    });\n   174→\n   175→    it('installs semgrep via pipx (primary) and returns installed', () => {\n   176→      let checkCount = 0;\n   177→      mockExecFileSync.mockImplementation((cmd) => {\n   178→        const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   179→        if (cmdStr === 'semgrep') {\n   180→          checkCount++;\n   181→          if (checkCount === 1) throw new Error('not found');\n   182→          return Buffer.from('1.56.0');\n   183→        }\n   184→        return Buffer.from('');\n   185→      });\n   186→\n   187→      const result = installDependency(semgrepSpec);\n   188→      expect(result.status).toBe('installed');\n   189→      expect(result.version).toBe('1.56.0');\n   190→    });\n   191→\n   192→    it('falls back to pip when pipx fails', () => {\n   193→      let checkCount = 0;\n   194→      mockExecFileSync.mockImplementation((cmd) => {\n   195→        const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   196→        if (cmdStr === 'semgrep') {\n   197→          checkCount++;\n   198→          if (checkCount === 1) throw new Error('not found');\n   199→          return Buffer.from('1.56.0');\n   200→        }\n   201→        if (cmdStr === 'pipx') throw new Error('pipx not found');\n   202→        return Buffer.from('');\n   203→      });\n   204→\n   205→      const result = installDependency(semgrepSpec);\n   206→      expect(result.status).toBe('installed');\n   207→      expect(result.version).toBe('1.56.0');\n   208→    });\n   209→\n   210→    it('returns failed when both pipx and pip fail', () => {\n   211→      mockExecFileSync.mockImplementation(() => {\n   212→        throw new Error('command failed');\n   213→      });\n   214→\n   215→      const result = installDependency(semgrepSpec);\n   216→      expect(result.status).toBe('failed');\n   217→      expect(result.error).toContain('pipx install semgrep');\n   218→      expect(result.error).toContain('pip install semgrep');\n   219→    });\n   220→  });\n   221→\n   222→  describe('bats entry', () => {\n   223→    const batsSpec = DEPENDENCY_REGISTRY.find(d => d.name === 'bats')!;\n   224→\n   225→    it('returns already-installed when bats is present', () => {\n   226→      mockExecFileSync.mockReturnValue(Buffer.from('Bats 1.11.0'));\n   227→      const result = installDependency(batsSpec);\n   228→      expect(result.status).toBe('already-installed');\n   229→      expect(result.version).toBe('1.11.0');\n   230→    });\n   231→\n   232→    it('installs bats via brew (primary) and returns installed', () => {\n   233→      let checkCount = 0;\n   234→      mockExecFileSync.mockImplementation((cmd) => {\n   235→        const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   236→        if (cmdStr === 'bats') {\n   237→          checkCount++;\n   238→          if (checkCount === 1) throw new Error('not found');\n   239→          return Buffer.from('Bats 1.11.0');\n   240→        }\n   241→        return Buffer.from('');\n   242→      });\n   243→\n   244→      const result = installDependency(batsSpec);\n   245→      expect(result.status).toBe('installed');\n   246→      expect(result.version).toBe('1.11.0');\n   247→    });\n   248→\n   249→    it('falls back to npm when brew fails', () => {\n   250→      let checkCount = 0;\n   251→      mockExecFileSync.mockImplementation((cmd) => {\n   252→        const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   253→        if (cmdStr === 'bats') {\n   254→          checkCount++;\n   255→          if (checkCount === 1) throw new Error('not found');\n   256→          return Buffer.from('Bats 1.11.0');\n   257→        }\n   258→        if (cmdStr === 'brew') throw new Error('brew not found');\n   259→        return Buffer.from('');\n   260→      });\n   261→\n   262→      const result = installDependency(batsSpec);\n   263→      expect(result.status).toBe('installed');\n   264→      expect(result.version).toBe('1.11.0');\n   265→    });\n   266→\n   267→    it('returns failed when both brew and npm fail', () => {\n   268→      mockExecFileSync.mockImplementation(() => {\n   269→        throw new Error('command failed');\n   270→      });\n   271→\n   272→      const result = installDependency(batsSpec);\n   273→      expect(result.status).toBe('failed');\n   274→      expect(result.error).toContain('brew install bats-core');\n   275→      expect(result.error).toContain('npm install -g bats');\n   276→    });\n   277→  });\n   278→\n   279→  describe('cargo-tarpaulin entry', () => {\n   280→    const cargoTarpaulinSpec = DEPENDENCY_REGISTRY.find(d => d.name === 'cargo-tarpaulin')!;\n   281→\n   282→    it('returns already-installed when cargo tarpaulin --version succeeds', () => {\n   283→      mockExecFileSync.mockReturnValue(Buffer.from('cargo-tarpaulin 0.27.3'));\n   284→      const result = installDependency(cargoTarpaulinSpec);\n   285→      expect(result.status).toBe('already-installed');\n   286→      expect(result.version).toBe('0.27.3');\n   287→    });\n   288→\n   289→    it('installs via cargo install cargo-tarpaulin and returns installed', () => {\n   290→      let checkCount = 0;\n   291→      mockExecFileSync.mockImplementation((cmd, args) => {\n   292→        const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   293→        const argsArr = Array.isArray(args) ? args.map(String) : [];\n   294→        if (cmdStr === 'cargo' && argsArr[0] === 'tarpaulin') {\n   295→          checkCount++;\n   296→          if (checkCount === 1) throw new Error('not found');\n   297→          return Buffer.from('cargo-tarpaulin 0.27.3');\n   298→        }\n   299→        // cargo install succeeds\n   300→        return Buffer.from('');\n   301→      });\n   302→\n   303→      const result = installDependency(cargoTarpaulinSpec);\n   304→      expect(result.status).toBe('installed');\n   305→      expect(result.version).toBe('0.27.3');\n   306→    });\n   307→\n   308→    it('returns failed when cargo command not found (graceful failure)', () => {\n   309→      mockExecFileSync.mockImplementation(() => {\n   310→        throw new Error('command failed');\n   311→      });\n   312→\n   313→      const result = installDependency(cargoTarpaulinSpec);\n   314→      expect(result.status).toBe('failed');\n   315→      expect(result.error).toContain('cargo install cargo-tarpaulin');\n   316→    });\n   317→\n   318→    it('cargo-tarpaulin is not critical', () => {\n   319→      expect(cargoTarpaulinSpec.critical).toBe(false);\n   320→    });\n   321→\n   322→    it('has single install command via cargo', () => {\n   323→      expect(cargoTarpaulinSpec.installCommands).toHaveLength(1);\n   324→      expect(cargoTarpaulinSpec.installCommands[0].cmd).toBe('cargo');\n   325→      expect(cargoTarpaulinSpec.installCommands[0].args).toEqual(['install', 'cargo-tarpaulin']);\n   326→    });\n   327→\n   328→    it('check command is cargo tarpaulin --version', () => {\n   329→      expect(cargoTarpaulinSpec.checkCommand.cmd).toBe('cargo');\n   330→      expect(cargoTarpaulinSpec.checkCommand.args).toEqual(['tarpaulin', '--version']);\n   331→    });\n   332→  });\n   333→});\n   334→\n   335→describe('installAllDependencies', () => {\n   336→  it('installs all dependencies and returns results', () => {\n   337→    // All tools already installed\n   338→    mockExecFileSync.mockReturnValue(Buffer.from('tool 1.0.0'));\n   339→\n   340→    const results = installAllDependencies({});\n   341→    expect(results).toHaveLength(DEPENDENCY_REGISTRY.length);\n   342→    expect(results.every(r => r.status === 'already-installed')).toBe(true);\n   343→  });\n   344→\n   345→  it('does not throw when all deps fail (none are critical)', () => {\n   346→    mockExecFileSync.mockImplementation(() => {\n   347→      throw new Error('command failed');\n   348→    });\n   349→\n   350→    const results = installAllDependencies({});\n   351→    expect(results.every(r => r.status === 'failed')).toBe(true);\n   352→  });\n   353→\n   354→  it('throws CriticalDependencyError when a critical dep fails to install', () => {\n   355→    // Temporarily mutate the first registry entry to be critical\n   356→    const registry = DEPENDENCY_REGISTRY as unknown as Array<{ critical: boolean }>;\n   357→    const originalCritical = registry[0].critical;\n   358→    registry[0].critical = true;\n   359→\n   360→    try {\n   361→      // All commands fail — first dep (showboat) is now critical\n   362→      mockExecFileSync.mockImplementation(() => {\n   363→        throw new Error('command failed');\n   364→      });\n   365→\n   366→      expect(() => installAllDependencies({})).toThrow(CriticalDependencyError);\n   367→      expect(() => installAllDependencies({})).toThrow(/Showboat/);\n   368→    } finally {\n   369→      // Restore original value\n   370→      registry[0].critical = originalCritical;\n   371→    }\n   372→  });\n   373→\n   374→  it('continues when non-critical dep fails', () => {\n   375→    mockExecFileSync.mockImplementation((cmd, args) => {\n   376→      const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   377→      const argsArr = Array.isArray(args) ? args.map(String) : [];\n   378→\n   379→      // showboat check and install both fail\n   380→      if (cmdStr === 'showboat') throw new Error('not found');\n   381→      // agent-browser check and install both fail\n   382→      if (cmdStr === 'agent-browser') throw new Error('not found');\n   383→      // npm install commands fail (for agent-browser and bats)\n   384→      if (cmdStr === 'npm') throw new Error('not found');\n   385→      // semgrep check and install both fail\n   386→      if (cmdStr === 'semgrep') throw new Error('not found');\n   387→      // bats check fails, brew fails (npm already covered above)\n   388→      if (cmdStr === 'bats') throw new Error('not found');\n   389→      if (cmdStr === 'brew') throw new Error('not found');\n   390→      // cargo-tarpaulin check and install both fail\n   391→      if (cmdStr === 'cargo') throw new Error('not found');\n   392→      // pip/pipx for showboat/semgrep fail, for beads we don't reach (already installed)\n   393→      if ((cmdStr === 'pip' || cmdStr === 'pipx') && argsArr.some(a => a.includes('showboat') || a.includes('semgrep'))) {\n   394→        throw new Error('not found');\n   395→      }\n   396→      // beads check succeeds\n   397→      if (cmdStr === 'bd') {\n   398→        return Buffer.from('bd 1.0.0');\n   399→      }\n   400→      throw new Error('unexpected');\n   401→    });\n   402→\n   403→    // Should not throw because showboat, agent-browser, semgrep, and bats are non-critical,\n   404→    // and beads is already installed\n   405→    const results = installAllDependencies({});\n   406→    const failed = results.filter(r => r.status === 'failed');\n   407→    expect(failed.length).toBeGreaterThanOrEqual(1);\n   408→    const beadsResult = results.find(r => r.name === 'beads');\n   409→    expect(beadsResult?.status).toBe('already-installed');\n   410→  });\n   411→\n   412→  it('prints OK messages for installed dependencies (non-json mode)', () => {\n   413→    const logSpy = vi.spyOn(console, 'log');\n   414→    mockExecFileSync.mockReturnValue(Buffer.from('tool 1.0.0'));\n   415→\n   416→    installAllDependencies({ json: false });\n   417→\n   418→    const calls = logSpy.mock.calls.map(c => c[0]);\n   419→    expect(calls.some(c => typeof c === 'string' && c.includes('[OK]'))).toBe(true);\n   420→  });\n   421→\n   422→  it('prints installed (not already-installed) message for freshly installed deps', () => {\n   423→    const logSpy = vi.spyOn(console, 'log');\n   424→    let showboatCheckCount = 0;\n   425→    mockExecFileSync.mockImplementation((cmd) => {\n   426→      const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   427→      // For showboat: first version check fails, install succeeds, post-check succeeds\n   428→      if (cmdStr === 'showboat') {\n   429→        showboatCheckCount++;\n   430→        if (showboatCheckCount === 1) throw new Error('not found');\n   431→        return Buffer.from('showboat 0.6.1');\n   432→      }\n   433→      if (cmdStr === 'pip') return Buffer.from('');\n   434→      // Everything else: already installed\n   435→      return Buffer.from('tool 1.0.0');\n   436→    });\n   437→\n   438→    const results = installAllDependencies({ json: false });\n   439→    const showboat = results.find(r => r.name === 'showboat');\n   440→    expect(showboat?.status).toBe('installed');\n   441→    expect(showboat?.version).toBe('0.6.1');\n   442→\n   443→    const calls = logSpy.mock.calls.map(c => String(c[0]));\n   444→    expect(calls.some(c => c.includes('Showboat: installed (v0.6.1)'))).toBe(true);\n   445→  });\n   446→\n   447→  it('prints OK without version when version is null (already-installed)', () => {\n   448→    const logSpy = vi.spyOn(console, 'log');\n   449→    // Return output that has no parseable version\n   450→    mockExecFileSync.mockReturnValue(Buffer.from('some output without version'));\n   451→\n   452→    installAllDependencies({ json: false });\n   453→\n   454→    const calls = logSpy.mock.calls.map(c => String(c[0]));\n   455→    // Should print \"already installed\" without \"(vX.Y.Z)\" suffix\n   456→    expect(calls.some(c => c.includes('already installed') && !c.includes('(v'))).toBe(true);\n   457→  });\n   458→\n   459→  it('prints OK without version when version is null (freshly installed)', () => {\n   460→    const logSpy = vi.spyOn(console, 'log');\n   461→    let showboatCheckCount = 0;\n   462→    mockExecFileSync.mockImplementation((cmd) => {\n   463→      const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   464→      // showboat: first check fails, install succeeds, post-check returns no-version output\n   465→      if (cmdStr === 'showboat') {\n   466→        showboatCheckCount++;\n   467→        if (showboatCheckCount === 1) throw new Error('not found');\n   468→        return Buffer.from('ready');\n   469→      }\n   470→      if (cmdStr === 'pip') return Buffer.from('');\n   471→      // Everything else: already installed with version\n   472→      return Buffer.from('tool 1.0.0');\n   473→    });\n   474→\n   475→    const results = installAllDependencies({ json: false });\n   476→    const showboat = results.find(r => r.name === 'showboat');\n   477→    expect(showboat?.status).toBe('installed');\n   478→    expect(showboat?.version).toBeNull();\n   479→\n   480→    const calls = logSpy.mock.calls.map(c =