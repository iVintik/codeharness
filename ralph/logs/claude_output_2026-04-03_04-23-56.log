{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DJDhpvt1a9tFuscUJ2AJu7","type":"tool_result","content":"1\timport type { SubagentDefinition } from './agent-resolver.js';\n2\timport type { DispatchResult } from './agent-dispatch.js';\n3\timport { dispatchAgent } from './agent-dispatch.js';\n4\timport { createIsolatedWorkspace } from './source-isolation.js';\n5\timport type { IsolatedWorkspace } from './source-isolation.js';\n6\timport { isDockerAvailable } from './docker/index.js';\n7\timport { formatTracePrompt } from './trace-id.js';\n8\t\n9\t// --- Interfaces ---\n10\t\n11\t/**\n12\t * Options for running the blind evaluator.\n13\t */\n14\texport interface EvaluatorOptions {\n15\t  /** Unique run identifier — used in workspace path and tracing. */\n16\t  runId: string;\n17\t  /** Absolute paths to story files containing acceptance criteria. */\n18\t  storyFiles: string[];\n19\t  /** Pre-compiled subagent definition for the evaluator agent. */\n20\t  agentDefinition: SubagentDefinition;\n21\t  /** Timeout in milliseconds for the evaluator dispatch. Default: 300000 (5 minutes). */\n22\t  timeoutMs?: number;\n23\t  /** Optional trace ID for correlation in logs/metrics. */\n24\t  traceId?: string;\n25\t}\n26\t\n27\t/**\n28\t * Result of an evaluator run.\n29\t */\n30\texport interface EvaluatorResult {\n31\t  /** Raw agent output (or synthesized JSON for fallback cases). */\n32\t  output: string;\n33\t  /** Whether the evaluator completed successfully. */\n34\t  success: boolean;\n35\t  /** Wall-clock duration of the evaluator run in milliseconds. */\n36\t  durationMs: number;\n37\t  /** Whether Docker was available at the time of the run. */\n38\t  dockerAvailable: boolean;\n39\t  /** Whether the evaluator timed out. */\n40\t  timedOut: boolean;\n41\t}\n42\t\n43\t// --- Constants ---\n44\t\n45\tconst DEFAULT_TIMEOUT_MS = 300_000; // 5 minutes\n46\t\n47\tconst EVALUATOR_PROMPT =\n48\t  'Read the acceptance criteria in ./story-files/. For each AC, determine if it passes by running commands and checking output. Report your findings as JSON.';\n49\t\n50\t// --- Helpers ---\n51\t\n52\t/**\n53\t * Build a fallback output JSON string with all ACs scored UNKNOWN.\n54\t */\n55\tfunction buildUnknownOutput(storyFiles: string[], reasoning: string): string {\n56\t  // We don't know how many ACs each story file has, so we produce\n57\t  // a single finding per story file with status unknown.\n58\t  const findings = storyFiles.map((_, index) => ({\n59\t    ac: index + 1,\n60\t    description: `AC #${index + 1}`,\n61\t    status: 'unknown' as const,\n62\t    evidence: {\n63\t      commands_run: [],\n64\t      output_observed: '',\n65\t      reasoning,\n66\t    },\n67\t  }));\n68\t\n69\t  return JSON.stringify({\n70\t    verdict: 'fail',\n71\t    score: {\n72\t      passed: 0,\n73\t      failed: 0,\n74\t      unknown: findings.length,\n75\t      total: findings.length,\n76\t    },\n77\t    findings,\n78\t  });\n79\t}\n80\t\n81\t// --- Main Function ---\n82\t\n83\t/**\n84\t * Run the blind evaluator lifecycle:\n85\t *   1. Check Docker availability\n86\t *   2. Create isolated workspace\n87\t *   3. Dispatch evaluator agent (with timeout)\n88\t *   4. Collect result\n89\t *   5. Cleanup workspace\n90\t *\n91\t * Returns raw output for downstream parsing (story 6-2).\n92\t * Does NOT throw on Docker unavailability or timeout — returns graceful UNKNOWN results.\n93\t */\n94\texport async function runEvaluator(options: EvaluatorOptions): Promise<EvaluatorResult> {\n95\t  const startMs = Date.now();\n96\t  const timeoutMs = options.timeoutMs ?? DEFAULT_TIMEOUT_MS;\n97\t\n98\t  // Step 1: Check Docker availability\n99\t  const dockerAvailable = isDockerAvailable();\n100\t  if (!dockerAvailable) {\n101\t    return {\n102\t      output: buildUnknownOutput(\n103\t        options.storyFiles,\n104\t        'Docker is not available — cannot run verification commands.',\n105\t      ),\n106\t      success: false,\n107\t      durationMs: Date.now() - startMs,\n108\t      dockerAvailable: false,\n109\t      timedOut: false,\n110\t    };\n111\t  }\n112\t\n113\t  // Step 2: Create isolated workspace\n114\t  let workspace: IsolatedWorkspace | undefined;\n115\t  try {\n116\t    workspace = await createIsolatedWorkspace({\n117\t      runId: options.runId,\n118\t      storyFiles: options.storyFiles,\n119\t    });\n120\t\n121\t    // Step 3: Build dispatch options\n122\t    const dispatchOptions = workspace.toDispatchOptions();\n123\t    if (options.traceId) {\n124\t      dispatchOptions.appendSystemPrompt = formatTracePrompt(options.traceId);\n125\t    }\n126\t\n127\t    // Step 4: Race dispatch against timeout\n128\t    const dispatchPromise = dispatchAgent(\n129\t      options.agentDefinition,\n130\t      EVALUATOR_PROMPT,\n131\t      dispatchOptions,\n132\t    );\n133\t\n134\t    let timeoutTimer: ReturnType<typeof setTimeout> | undefined;\n135\t    const timeoutPromise = new Promise<never>((_, reject) => {\n136\t      timeoutTimer = setTimeout(() => reject(new Error('Evaluator timeout')), timeoutMs);\n137\t    });\n138\t\n139\t    let result: DispatchResult;\n140\t    try {\n141\t      result = await Promise.race([dispatchPromise, timeoutPromise]);\n142\t    } catch (err: unknown) {\n143\t      const message = err instanceof Error ? err.message : String(err);\n144\t      if (message === 'Evaluator timeout') {\n145\t        return {\n146\t          output: buildUnknownOutput(\n147\t            options.storyFiles,\n148\t            `Evaluator timed out after ${timeoutMs}ms.`,\n149\t          ),\n150\t          success: false,\n151\t          durationMs: Date.now() - startMs,\n152\t          dockerAvailable: true,\n153\t          timedOut: true,\n154\t        };\n155\t      }\n156\t      // Re-throw non-timeout errors\n157\t      throw err;\n158\t    } finally {\n159\t      // Clear the timeout timer to prevent Node.js process from hanging\n160\t      if (timeoutTimer) {\n161\t        clearTimeout(timeoutTimer);\n162\t      }\n163\t    }\n164\t\n165\t    return {\n166\t      output: result.output,\n167\t      success: result.success,\n168\t      durationMs: Date.now() - startMs,\n169\t      dockerAvailable: true,\n170\t      timedOut: false,\n171\t    };\n172\t  } finally {\n173\t    // Step 5: Cleanup workspace (always)\n174\t    if (workspace) {\n175\t      await workspace.cleanup();\n176\t    }\n177\t  }\n178\t}\n179\t"}]},"parent_tool_use_id":"toolu_01YJLjcRuVdyxUPAHpAV3CXA","session_id":"52ded6f4-857c-404a-a480-19bb12459ee1","uuid":"f2bc56b5-9ccc-41a1-93f7-0976a363110b","timestamp":"2026-04-03T00:25:59.145Z"}
