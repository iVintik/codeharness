{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014j4Cv1h1PgrtaHBRiQVkG9","type":"tool_result","content":"     1→/**\n     2→ * Sprint phase time budget awareness.\n     3→ * Estimates whether there is enough remaining session time\n     4→ * to complete a given phase, and defers if not.\n     5→ */\n     6→\n     7→/** Phase time estimates in minutes (from architecture-v3.md). */\n     8→export const PHASE_ESTIMATES: Record<string, number> = {\n     9→  'create-story': 5,\n    10→  'dev-story': 15,\n    11→  'code-review': 10,\n    12→  'verification': 20,\n    13→  'retro': 5,\n    14→};\n    15→\n    16→/** Default estimate for unknown phases. */\n    17→const DEFAULT_ESTIMATE_MINUTES = 10;\n    18→\n    19→/**\n    20→ * Returns true if the phase should be deferred to the next session.\n    21→ * A phase should be deferred when the remaining session time is\n    22→ * less than the estimated time needed to complete the phase.\n    23→ *\n    24→ * @param phase - The sprint phase name (e.g. 'dev-story', 'verification')\n    25→ * @param remainingMinutes - Minutes remaining in the session budget\n    26→ * @returns true if the phase should be deferred\n    27→ */\n    28→export function shouldDeferPhase(phase: string, remainingMinutes: number): boolean {\n    29→  if (Number.isNaN(remainingMinutes)) return true;\n    30→  const estimate = PHASE_ESTIMATES[phase] ?? DEFAULT_ESTIMATE_MINUTES;\n    31→  return remainingMinutes < estimate;\n    32→}\n    33→\n    34→/**\n    35→ * Get the time estimate for a given phase.\n    36→ *\n    37→ * @param phase - The sprint phase name\n    38→ * @returns Estimated minutes to complete the phase\n    39→ */\n    40→export function getPhaseEstimate(phase: string): number {\n    41→  return PHASE_ESTIMATES[phase] ?? DEFAULT_ESTIMATE_MINUTES;\n    42→}\n    43→\n    44→/**\n    45→ * Compute remaining session minutes from start time and total budget.\n    46→ *\n    47→ * @param sessionStartMs - Session start time in milliseconds (Date.now())\n    48→ * @param totalBudgetMinutes - Total session budget in minutes\n    49→ * @returns Remaining minutes (floored, minimum 0)\n    50→ */\n    51→export function computeRemainingMinutes(sessionStartMs: number, totalBudgetMinutes: number): number {\n    52→  const elapsedMs = Date.now() - sessionStartMs;\n    53→  const elapsedMinutes = elapsedMs / 60_000;\n    54→  const remaining = totalBudgetMinutes - elapsedMinutes;\n    55→  return Math.max(0, Math.floor(remaining));\n    56→}\n    57→"}]},"parent_tool_use_id":null,"session_id":"97e0b69d-7780-4d92-a428-95a4b19f3ed1","uuid":"349f986c-b150-4a4e-aadd-810dba2da3fe","timestamp":"2026-03-25T06:44:03.173Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ivintik/dev/personal/codeharness/src/modules/sprint/budget.ts","content":"/**\n * Sprint phase time budget awareness.\n * Estimates whether there is enough remaining session time\n * to complete a given phase, and defers if not.\n */\n\n/** Phase time estimates in minutes (from architecture-v3.md). */\nexport const PHASE_ESTIMATES: Record<string, number> = {\n  'create-story': 5,\n  'dev-story': 15,\n  'code-review': 10,\n  'verification': 20,\n  'retro': 5,\n};\n\n/** Default estimate for unknown phases. */\nconst DEFAULT_ESTIMATE_MINUTES = 10;\n\n/**\n * Returns true if the phase should be deferred to the next session.\n * A phase should be deferred when the remaining session time is\n * less than the estimated time needed to complete the phase.\n *\n * @param phase - The sprint phase name (e.g. 'dev-story', 'verification')\n * @param remainingMinutes - Minutes remaining in the session budget\n * @returns true if the phase should be deferred\n */\nexport function shouldDeferPhase(phase: string, remainingMinutes: number): boolean {\n  if (Number.isNaN(remainingMinutes)) return true;\n  const estimate = PHASE_ESTIMATES[phase] ?? DEFAULT_ESTIMATE_MINUTES;\n  return remainingMinutes < estimate;\n}\n\n/**\n * Get the time estimate for a given phase.\n *\n * @param phase - The sprint phase name\n * @returns Estimated minutes to complete the phase\n */\nexport function getPhaseEstimate(phase: string): number {\n  return PHASE_ESTIMATES[phase] ?? DEFAULT_ESTIMATE_MINUTES;\n}\n\n/**\n * Compute remaining session minutes from start time and total budget.\n *\n * @param sessionStartMs - Session start time in milliseconds (Date.now())\n * @param totalBudgetMinutes - Total session budget in minutes\n * @returns Remaining minutes (floored, minimum 0)\n */\nexport function computeRemainingMinutes(sessionStartMs: number, totalBudgetMinutes: number): number {\n  const elapsedMs = Date.now() - sessionStartMs;\n  const elapsedMinutes = elapsedMs / 60_000;\n  const remaining = totalBudgetMinutes - elapsedMinutes;\n  return Math.max(0, Math.floor(remaining));\n}\n","numLines":57,"startLine":1,"totalLines":57}}}
