t    mockDriverDispatch.mockImplementation((opts: { prompt: string }) => {\n1356\t      if (opts.prompt.includes('Execute task')) {\n1357\t        return makeDriverStream(makePassVerdict(), 'sess-v');\n1358\t      }\n1359\t      return makeDriverStream('ok', 'sess-r');\n1360\t    });\n1361\t\n1362\t    mockParse.mockReturnValue({\n1363\t      development_status: { '3-1-foo': 'ready-for-dev' },\n1364\t    });\n1365\t\n1366\t    const config = makeConfig({\n1367\t      workflow: {\n1368\t        tasks: {\n1369\t          retry: makeTask({ scope: 'per-story' }),\n1370\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n1371\t        },\n1372\t        flow: [{ loop: ['retry', 'verify'] }],\n1373\t      },\n1374\t    });\n1375\t\n1376\t    const result = await executeWorkflow(config);\n1377\t\n1378\t    expect(result.success).toBe(true);\n1379\t    expect(result.tasksCompleted).toBe(2); // 1 retry + 1 verify\n1380\t  });\n1381\t\n1382\t  it('terminates loop when maxIterations reached (AC #3)', async () => {\n1383\t    // Verify always fails but with increasing passed count to avoid circuit breaker\n1384\t    let iterCount = 0;\n1385\t    mockDriverDispatch.mockImplementation((opts: { prompt: string }) => {\n1386\t      if (opts.prompt.includes('Execute task')) {\n1387\t        iterCount++;\n1388\t        return makeDriverStream(makeProgressingFailVerdict(iterCount), 'sess-v');\n1389\t      }\n1390\t      return makeDriverStream('ok', 'sess-r');\n1391\t    });\n1392\t\n1393\t    mockParse.mockReturnValue({\n1394\t      development_status: { '3-1-foo': 'ready-for-dev' },\n1395\t    });\n1396\t\n1397\t    const config = makeConfig({\n1398\t      workflow: {\n1399\t        tasks: {"}]},"parent_tool_use_id":"toolu_01WzzY2TpSn4HBX8Gw2yuQNF","session_id":"f83470b7-c271-483e-ae93-7fe9bce4b683","uuid":"3aafee10-dc04-4105-8fb0-a4bccaadd2a1","timestamp":"2026-04-03T07:55:26.183Z"}
