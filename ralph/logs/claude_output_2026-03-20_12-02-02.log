{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019Hwj1kKXPtYSYcF5LGbiCc","type":"tool_result","content":"     1→/**\n     2→ * Ink Terminal Renderer — live terminal UI for Claude activity display.\n     3→ *\n     4→ * Exports a controller API: startRenderer(), which returns a RendererHandle\n     5→ * with update(), updateSprintState(), and cleanup() methods.\n     6→ *\n     7→ * The renderer accumulates state from StreamEvent objects and renders\n     8→ * tool calls, thoughts, and sprint progress using Ink (React for terminals).\n     9→ */\n    10→\n    11→import React from 'react';\n    12→import { render as inkRender } from 'ink';\n    13→import type { StreamEvent } from './stream-parser.js';\n    14→import {\n    15→  App,\n    16→  type SprintInfo,\n    17→  type CompletedToolEntry,\n    18→  type RetryInfo,\n    19→  type RendererState,\n    20→  type StoryStatusEntry,\n    21→  type StoryMessage,\n    22→} from './ink-components.js';\n    23→\n    24→// --- Public Types ---\n    25→\n    26→export interface RendererOptions {\n    27→  quiet?: boolean;\n    28→  sprintState?: SprintInfo;\n    29→  /** @internal Force TTY mode for testing. Not part of the public API. */\n    30→  _forceTTY?: boolean;\n    31→}\n    32→\n    33→export interface RendererHandle {\n    34→  update(event: StreamEvent): void;\n    35→  updateSprintState(state: SprintInfo | undefined): void;\n    36→  updateStories(stories: StoryStatusEntry[]): void;\n    37→  addMessage(msg: StoryMessage): void;\n    38→  cleanup(): void;\n    39→}\n    40→\n    41→// --- No-op handle for quiet mode ---\n    42→\n    43→const noopHandle: RendererHandle = {\n    44→  update() {},\n    45→  updateSprintState() {},\n    46→  updateStories() {},\n    47→  addMessage() {},\n    48→  cleanup() {},\n    49→};\n    50→\n    51→/** Maximum number of completed tools to retain in the display list. */\n    52→const MAX_COMPLETED_TOOLS = 50;\n    53→\n    54→// --- Controller ---\n    55→\n    56→/**\n    57→ * Start the Ink terminal renderer.\n    58→ *\n    59→ * If `quiet` is true or stdout is not a TTY, returns a no-op handle\n    60→ * (no Ink instance created).\n    61→ * Otherwise, mounts the component tree and returns a handle for feeding events.\n    62→ */\n    63→export function startRenderer(options?: RendererOptions): RendererHandle {\n    64→  if (options?.quiet || (!process.stdout.isTTY && !options?._forceTTY)) {\n    65→    return noopHandle;\n    66→  }\n    67→\n    68→  // Mutable state that drives re-renders\n    69→  let state: RendererState = {\n    70→    sprintInfo: options?.sprintState ?? null,\n    71→    stories: [],\n    72→    messages: [],\n    73→    completedTools: [],\n    74→    activeTool: null,\n    75→    activeToolArgs: '',\n    76→    lastThought: null,\n    77→    retryInfo: null,\n    78→  };\n    79→\n    80→  let cleaned = false;\n    81→\n    82→  // Mount Ink\n    83→  const inkInstance = inkRender(<App state={state} />, {\n    84→    exitOnCtrlC: false,\n    85→    patchConsole: false,\n    86→  });\n    87→\n    88→  function rerender() {\n    89→    if (!cleaned) {\n    90→      // Create a new state object reference to trigger React re-render\n    91→      state = { ...state };\n    92→      inkInstance.rerender(<App state={state} />);\n    93→    }\n    94→  }\n    95→\n    96→  function cleanup() {\n    97→    if (cleaned) return;\n    98→    cleaned = true;\n    99→    try {\n   100→      inkInstance.unmount();\n   101→    } catch {\n   102→      // Ignore — may already be unmounted\n   103→    }\n   104→    try {\n   105→      inkInstance.cleanup();\n   106→    } catch {\n   107→      // Ignore\n   108→    }\n   109→    // Remove our signal handlers\n   110→    process.removeListener('SIGINT', onSigint);\n   111→    process.removeListener('SIGTERM', onSigterm);\n   112→  }\n   113→\n   114→  function onSigint() {\n   115→    cleanup();\n   116→    // Re-raise signal so the default handler runs (allows caller to handle exit)\n   117→    process.kill(process.pid, 'SIGINT');\n   118→  }\n   119→\n   120→  function onSigterm() {\n   121→    cleanup();\n   122→    process.kill(process.pid, 'SIGTERM');\n   123→  }\n   124→\n   125→  // Register signal handlers\n   126→  process.on('SIGINT', onSigint);\n   127→  process.on('SIGTERM', onSigterm);\n   128→\n   129→  function update(event: StreamEvent): void {\n   130→    if (cleaned) return;\n   131→\n   132→    switch (event.type) {\n   133→      case 'tool-start':\n   134→        state.activeTool = { name: event.name };\n   135→        state.activeToolArgs = '';\n   136→        state.lastThought = null;\n   137→        state.retryInfo = null;\n   138→        break;\n   139→\n   140→      case 'tool-input':\n   141→        state.activeToolArgs += event.partial;\n   142→        break;\n   143→\n   144→      case 'tool-complete':\n   145→        // CRITICAL: Only promote if there's an active tool.\n   146→        // The parser emits tool-complete for ALL content_block_stop events\n   147→        // (both tool and text blocks). Ignore if no activeTool is set.\n   148→        if (state.activeTool) {\n   149→          const entry: CompletedToolEntry = {\n   150→            name: state.activeTool.name,\n   151→            args: state.activeToolArgs,\n   152→          };\n   153→          const updated = [...state.completedTools, entry];\n   154→          // Bound the list to prevent unbounded memory growth in long sessions\n   155→          state.completedTools = updated.length > MAX_COMPLETED_TOOLS\n   156→            ? updated.slice(updated.length - MAX_COMPLETED_TOOLS)\n   157→            : updated;\n   158→          state.activeTool = null;\n   159→          state.activeToolArgs = '';\n   160→        }\n   161→        break;\n   162→\n   163→      case 'text':\n   164→        state.lastThought = event.text;\n   165→        state.retryInfo = null;\n   166→        break;\n   167→\n   168→      case 'retry':\n   169→        state.retryInfo = { attempt: event.attempt, delay: event.delay };\n   170→        break;\n   171→\n   172→      case 'result':\n   173→        // No rendering change — handled by caller\n   174→        break;\n   175→    }\n   176→\n   177→    rerender();\n   178→  }\n   179→\n   180→  function updateSprintState(sprintState: SprintInfo | undefined): void {\n   181→    if (cleaned) return;\n   182→    state.sprintInfo = sprintState ?? null;\n   183→    rerender();\n   184→  }\n   185→\n   186→  function updateStories(stories: StoryStatusEntry[]): void {\n   187→    if (cleaned) return;\n   188→    state.stories = [...stories];\n   189→    rerender();\n   190→  }\n   191→\n   192→  function addMessage(msg: StoryMessage): void {\n   193→    if (cleaned) return;\n   194→    state.messages = [...state.messages, msg];\n   195→    rerender();\n   196→  }\n   197→\n   198→  return { update, updateSprintState, updateStories, addMessage, cleanup };\n   199→}\n   200→\n   201→// Re-export types that consumers may need\n   202→export type { SprintInfo, CompletedToolEntry, RetryInfo, RendererState, StoryStatusEntry, StoryStatusValue, StoryMessage } from './ink-components.js';\n   203→"}]},"parent_tool_use_id":"toolu_01J5AdAMYAsRdio1YgdnbwDy","session_id":"64c1e9b9-a641-40be-ae67-07aee0c47965","uuid":"2e4961e1-1e24-43a9-bfba-d07c81991dd8","timestamp":"2026-03-20T08:03:19.109Z"}
