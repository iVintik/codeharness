pYaml = `\n71\ttasks:\n72\t  implement:\n73\t    agent: dev\n74\t  verify:\n75\t    agent: evaluator\n76\t  retry:\n77\t    agent: dev\n78\tflow:\n79\t  - implement\n80\t  - verify\n81\t  - loop:\n82\t      - retry\n83\t      - verify\n84\t`;\n85\t\n86\tconst emptyYaml = `\n87\ttasks: {}\n88\tflow: []\n89\t`;\n90\t\n91\t// --- Tests ---\n92\t\n93\tdescribe('parseWorkflow', () => {\n94\t  describe('valid workflows (AC #1)', () => {\n95\t    it('parses a minimal valid workflow and returns ResolvedWorkflow', () => {\n96\t      const filePath = writeYaml('minimal.yaml', minimalYaml);\n97\t      const result = parseWorkflow(filePath);\n98\t\n99\t      expect(result.tasks).toBeDefined();\n100\t      expect(result.flow).toBeDefined();"}]},"parent_tool_use_id":"toolu_01EPUyrKtMjV9xapMgmPR8xK","session_id":"9c9fe147-c536-4d36-9f64-8249f0c68839","uuid":"e411be5c-a78d-43da-ab1a-068de3f8d703","timestamp":"2026-04-03T16:42:14.660Z"}
