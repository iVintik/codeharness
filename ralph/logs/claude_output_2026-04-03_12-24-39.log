{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018GtcDhCJz2ofTaw3CwWJWG","type":"tool_result","content":"300\t      parseWorkflow(filePath);\n301\t      const elapsed = performance.now() - start;\n302\t\n303\t      expect(elapsed).toBeLessThan(500);\n304\t    });\n305\t  });\n306\t\n307\t  describe('file not found (AC #7)', () => {\n308\t    it('throws WorkflowParseError for non-existent file', () => {\n309\t      const fakePath = join(testDir, 'does-not-exist.yaml');\n310\t\n311\t      expect(() => parseWorkflow(fakePath)).toThrow(WorkflowParseError);\n312\t      try {\n313\t        parseWorkflow(fakePath);\n314\t      } catch (err) {\n315\t        const pe = err as WorkflowParseError;\n316\t        expect(pe.message).toContain('File not found');\n317\t        expect(pe.errors.length).toBeGreaterThan(0);\n318\t      }\n319\t    });\n320\t\n321\t    it('throws WorkflowParseError when path is a directory', () => {\n322\t      const dirPath = join(testDir, 'subdir');\n323\t      mkdirSync(dirPath);\n324\t\n325\t      expect(() => parseWorkflow(dirPath)).toThrow(WorkflowParseError);\n326\t      try {\n327\t        parseWorkflow(dirPath);\n328\t      } catch (err) {\n329\t        const pe = err as WorkflowParseError;\n330\t        expect(pe.message).toContain('Path is a directory');\n331\t      }\n332\t    });\n333\t  });\n334\t\n335\t  describe('typed interfaces (AC #8)', () => {\n336\t    it('ResolvedWorkflow has correct structure', () => {\n337\t      const filePath = writeYaml('typed.yaml', fullYaml);\n338\t      const result: ResolvedWorkflow = parseWorkflow(filePath);\n339\t\n340\t      // tasks is Record<string, ResolvedTask>\n341\t      const taskKeys = Object.keys(result.tasks);\n342\t      expect(taskKeys).toContain('implement');\n343\t      expect(taskKeys).toContain('verify');\n344\t\n345\t      // flow is FlowStep[]\n346\t      expect(Array.isArray(result.flow)).toBe(true);\n347\t\n348\t      // Each task has ResolvedTask properties\n349\t      const task: ResolvedTask = result.tasks.implement;\n350\t      expect(typeof task.agent).toBe('string');\n351\t      expect(typeof task.scope).toBe('string');\n352\t      expect(typeof task.session).toBe('string');\n353\t      expect(typeof task.source_access).toBe('boolean');\n354\t    });\n355\t\n356\t    it('FlowStep is a union of string | LoopBlock', () => {\n357\t      const filePath = writeYaml('flow-types.yaml', loopYaml);\n358\t      const result = parseWorkflow(filePath);\n359\t\n360\t      // String flow step\n361\t      const stringStep: FlowStep = result.flow[0];\n362\t      expect(typeof stringStep).toBe('string');\n363\t\n364\t      // LoopBlock flow step\n365\t      const loopStep: FlowStep = result.flow[2];\n366\t      expect(typeof loopStep).toBe('object');\n367\t      expect((loopStep as LoopBlock).loop).toBeDefined();\n368\t    });\n369\t  });\n370\t\n371\t  describe('driver, model, and plugins fields (Story 11-1)', () => {\n372\t    it('minimal workflow without new fields parses successfully — backward compat (AC #2)', () => {\n373\t      const filePath = writeYaml('compat.yaml', minimalYaml);\n374\t      const result = parseWorkflow(filePath);\n375\t\n376\t      expect(result.tasks.implement.driver).toBeUndefined();\n377\t      expect(result.tasks.implement.model).toBeUndefined();\n378\t      expect(result.tasks.implement.plugins).toBeUndefined();\n379\t    });\n380\t\n381\t    it('task with driver: codex parses into ResolvedTask.driver === \"codex\" (AC #3)', () => {\n382\t      const yaml = `\n383\ttasks:\n384\t  implement:\n385\t    agent: dev\n386\t    driver: codex\n387\tflow:\n388\t  - implement\n389\t`;\n390\t      const filePath = writeYaml('driver.yaml', yaml);\n391\t      const result = parseWorkflow(filePath);\n392\t\n393\t      expect(result.tasks.implement.driver).toBe('codex');\n394\t      expect(result.tasks.implement.model).toBeUndefined();\n395\t      expect(result.tasks.implement.plugins).toBeUndefined();\n396\t    });\n397\t\n398\t    it('task with model: claude-opus-4 parses into ResolvedTask.model (AC #3)', () => {\n399\t      const yaml = `\n400\ttasks:\n401\t  implement:\n402\t    agent: dev\n403\t    model: claude-opus-4\n404\tflow:\n405\t  - implement\n406\t`;\n407\t      const filePath = writeYaml('model.yaml', yaml);\n408\t      const result = parseWorkflow(filePath);\n409\t\n410\t      expect(result.tasks.implement.model).toBe('claude-opus-4');\n411\t      expect(result.tasks.implement.driver).toBeUndefined();\n412\t    });\n413\t\n414\t    it('task with plugins: [gstack, omo] parses into ResolvedTask.plugins (AC #3)', () => {\n415\t      const yaml = `\n416\ttasks:\n417\t  implement:\n418\t    agent: dev\n419\t    plugins:\n420\t      - gstack\n421\t      - omo\n422\tflow:\n423\t  - implement\n424\t`;\n425\t      const filePath = writeYaml('plugins.yaml', yaml);\n426\t      const result = parseWorkflow(filePath);\n427\t\n428\t      expect(result.tasks.implement.plugins).toEqual(['gstack', 'omo']);\n429\t    });\n430\t\n431\t    it('task with all three new fields parses correctly (AC #3)', () => {\n432\t      const yaml = `\n433\ttasks:\n434\t  implement:\n435\t    agent: dev\n436\t    driver: codex\n437\t    model: codex-mini\n438\t    plugins:\n439\t      - gstack\n440\tflow:\n441\t  - implement\n442\t`;\n443\t      const filePath = writeYaml('all-new.yaml', yaml);\n444\t      const result = parseWorkflow(filePath);\n445\t\n446\t      expect(result.tasks.implement.driver).toBe('codex');\n447\t      expect(result.tasks.implement.model).toBe('codex-mini');\n448\t      expect(result.tasks.implement.plugins).toEqual(['gstack']);\n449\t    });\n450\t\n451\t    it('driver: 123 (wrong type) fails schema validation (AC #8)', () => {\n452\t      const yaml = `\n453\ttasks:\n454\t  implement:\n455\t    agent: dev\n456\t    driver: 123\n457\tflow:\n458\t  - implement\n459\t`;\n460\t      const filePath = writeYaml('bad-driver.yaml', yaml);\n461\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n462\t      try {\n463\t        parseWorkflow(filePath);\n464\t      } catch (err) {\n465\t        const pe = err as WorkflowParseError;\n466\t        expect(pe.message).toContain('Schema validation failed');\n467\t      }\n468\t    });\n469\t\n470\t    it('model: true (wrong type) fails schema validation (AC #8)', () => {\n471\t      const yaml = `\n472\ttasks:\n473\t  implement:\n474\t    agent: dev\n475\t    model: true\n476\tflow:\n477\t  - implement\n478\t`;\n479\t      const filePath = writeYaml('bad-model.yaml', yaml);\n480\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n481\t      try {\n482\t        parseWorkflow(filePath);\n483\t      } catch (err) {\n484\t        const pe = err as WorkflowParseError;\n485\t        expect(pe.message).toContain('Schema validation failed');\n486\t      }\n487\t    });\n488\t\n489\t    it('plugins: \"not-array\" (wrong type) fails schema validation (AC #8)', () => {\n490\t      const yaml = `\n491\ttasks:\n492\t  implement:\n493\t    agent: dev\n494\t    plugins: not-array\n495\tflow:\n496\t  - implement\n497\t`;\n498\t      const filePath = writeYaml('bad-plugins.yaml', yaml);\n499\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n500\t      try {\n501\t        parseWorkflow(filePath);\n502\t      } catch (err) {\n503\t        const pe = err as WorkflowParseError;\n504\t        expect(pe.message).toContain('Schema validation failed');\n505\t      }\n506\t    });\n507\t\n508\t    it('new fields alongside agent pass schema validation — not rejected as additionalProperties (AC #6)', () => {\n509\t      const yaml = `\n510\ttasks:\n511\t  implement:\n512\t    agent: dev\n513\t    driver: codex\n514\t    model: codex-mini\n515\t    plugins:\n516\t      - gstack\n517\tflow:\n518\t  - implement\n519\t`;\n520\t      const filePath = writeYaml('additional-props.yaml', yaml);\n521\t      // Should NOT throw — new fields are recognized by schema\n522\t      const result = parseWorkflow(filePath);\n523\t      expect(result.tasks.implement.agent).toBe('dev');\n524\t      expect(result.tasks.implement.driver).toBe('codex');\n525\t    });\n526\t\n527\t    it('ResolvedTask type exposes optional driver, model, plugins fields (AC #4)', () => {\n528\t      const filePath = writeYaml('type-check.yaml', minimalYaml);\n529\t      const result = parseWorkflow(filePath);\n530\t      const task: ResolvedTask = result.tasks.implement;\n531\t\n532\t      // TypeScript compile-time check: these fields exist on ResolvedTask\n533\t      const _driver: string | undefined = task.driver;\n534\t      const _model: string | undefined = task.model;\n535\t      const _plugins: string[] | undefined = task.plugins;\n536\t\n537\t      // Runtime: they are undefined when not set\n538\t      expect(_driver).toBeUndefined();\n539\t      expect(_model).toBeUndefined();\n540\t      expect(_plugins).toBeUndefined();\n541\t    });\n542\t\n543\t    it('plugins: [123] (non-string array items) fails schema validation', () => {\n544\t      const yaml = `\n545\ttasks:\n546\t  implement:\n547\t    agent: dev\n548\t    plugins:\n549\t      - 123\n550\tflow:\n551\t  - implement\n552\t`;\n553\t      const filePath = writeYaml('bad-plugins-items.yaml', yaml);\n554\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n555\t      try {\n556\t        parseWorkflow(filePath);\n557\t      } catch (err) {\n558\t        const pe = err as WorkflowParseError;\n559\t        expect(pe.message).toContain('Schema validation failed');\n560\t      }\n561\t    });\n562\t\n563\t    it('empty plugins array is valid', () => {\n564\t      const yaml = `\n565\ttasks:\n566\t  implement:\n567\t    agent: dev\n568\t    plugins: []\n569\tflow:\n570\t  - implement\n571\t`;\n572\t      const filePath = writeYaml('empty-plugins.yaml', yaml);\n573\t      const result = parseWorkflow(filePath);\n574\t      expect(result.tasks.implement.plugins).toEqual([]);\n575\t    });\n576\t  });\n577\t\n578\t  describe('WorkflowParseError structure (AC #8)', () => {\n579\t    it('extends Error and has name and errors array', () => {\n580\t      const err = new WorkflowParseError('test error', [\n581\t        { path: '/tasks', message: 'missing' },\n582\t      ]);\n583\t\n584\t      expect(err).toBeInstanceOf(Error);\n585\t      expect(err.name).toBe('WorkflowParseError');\n586\t      expect(err.message).toBe('test error');\n587\t      expect(err.errors).toHaveLength(1);\n588\t      expect(err.errors[0]).toEqual({ path: '/tasks', message: 'missing' });\n589\t    });\n590\t\n591\t    it('defaults errors to empty array when not provided', () => {\n592\t      const err = new WorkflowParseError('test error');\n593\t      expect(err.errors).toEqual([]);\n594\t    });\n595\t  });\n596\t});\n597\t\n598\t// --- Patch Resolution Tests ---\n599\t\n600\tdescribe('loadWorkflowPatch', () => {\n601\t  it('returns null for non-existent file', () => {\n602\t    const result = loadWorkflowPatch(join(testDir, 'does-not-exist.patch.yaml'));\n603\t    expect(result).toBeNull();\n604\t  });\n605\t\n606\t  it('throws WorkflowParseError for invalid YAML', () => {\n607\t    const filePath = writeYaml('bad.patch.yaml', '{{{{not yaml');\n608\t    expect(() => loadWorkflowPatch(filePath)).toThrow(WorkflowParseError);\n609\t    try {\n610\t      loadWorkflowPatch(filePath);\n611\t    } catch (err) {\n612\t      const pe = err as WorkflowParseError;\n613\t      expect(pe.message).toContain('Invalid YAML in patch file');\n614\t      expect(pe.message).toContain(filePath);\n615\t    }\n616\t  });\n617\t\n618\t  it('throws WorkflowParseError for non-object YAML (scalar)', () => {\n619\t    const filePath = writeYaml('scalar.patch.yaml', '42');\n620\t    expect(() => loadWorkflowPatch(filePath)).toThrow(WorkflowParseError);\n621\t    try {\n622\t      loadWorkflowPatch(filePath);\n623\t    } catch (err) {\n624\t      const pe = err as WorkflowParseError;\n625\t      expect(pe.message).toContain('not a valid object');\n626\t    }\n627\t  });\n628\t\n629\t  it('loads a valid patch file', () => {\n630\t    const patchContent = `\n631\textends: embedded://default\n632\toverrides:\n633\t  tasks:\n634\t    implement:\n635\t      session: continue\n636\t`;\n637\t    const filePath = writeYaml('valid.patch.yaml', patchContent);\n638\t    const result = loadWorkflowPatch(filePath);\n639\t    expect(result).not.toBeNull();\n640\t    expect(result!.extends).toBe('embedded://default');\n641\t    expect(result!.overrides).toBeDefined();\n642\t    expect((result!.overrides!.tasks as Record<string, unknown>).implement).toBeDefined();\n643\t  });\n644\t});\n645\t\n646\tdescribe('mergeWorkflowPatch', () => {\n647\t  const base: Record<string, unknown> = {\n648\t    tasks: {\n649\t      implement: { agent: 'dev', scope: 'per-story', session: 'fresh', source_access: true },\n650\t      verify: { agent: 'evaluator', scope: 'per-run', session: 'fresh', source_access: false },\n651\t    },\n652\t    flow: ['implement', 'verify'],\n653\t  };\n654\t\n655\t  it('handles overrides-only patch (deep merge)', () => {\n656\t    const patch: WorkflowPatch = {\n657\t      overrides: {\n658\t        tasks: {\n659\t          implement: { session: 'continue', max_budget_usd: 5.0 },\n660\t        },\n661\t      },\n662\t    };\n663\t    const result = mergeWorkflowPatch(base, patch);\n664\t    const tasks = result.tasks as Record<string, Record<string, unknown>>;\n665\t\n666\t    // Deep-merged: implement gets new session and max_budget_usd, keeps agent/scope/source_access\n667\t    expect(tasks.implement.agent).toBe('dev');\n668\t    expect(tasks.implement.scope).toBe('per-story');\n669\t    expect(tasks.implement.session).toBe('continue');\n670\t    expect(tasks.implement.max_budget_usd).toBe(5.0);\n671\t    expect(tasks.implement.source_access).toBe(true);\n672\t\n673\t    // verify unchanged\n674\t    expect(tasks.verify.agent).toBe('evaluator');\n675\t\n676\t    // flow unchanged\n677\t    expect(result.flow).toEqual(['implement', 'verify']);\n678\t  });\n679\t\n680\t  it('handles replace-only patch (full replacement)', () => {\n681\t    const patch: WorkflowPatch = {\n682\t      replace: {\n683\t        flow: ['implement'],\n684\t      },\n685\t    };\n686\t    const result = mergeWorkflowPatch(base, patch);\n687\t\n688\t    // flow fully replaced\n689\t    expect(result.flow).toEqual(['implement']);\n690\t\n691\t    // tasks unchanged\n692\t    const tasks = result.tasks as Record<string, Record<string, unknown>>;\n693\t    expect(tasks.implement.agent).toBe('dev');\n694\t    expect(tasks.verify.agent).toBe('evaluator');\n695\t  });\n696\t\n697\t  it('handles patch with both overrides and replace', () => {\n698\t    const patch: WorkflowPatch = {\n699\t      overrides: {\n700\t        tasks: {\n701\t          implement: { session: 'continue' },\n702\t        },\n703\t      },\n704\t      replace: {\n705\t        flow: ['implement'],\n706\t      },\n707\t    };\n708\t    const result = mergeWorkflowPatch(base, patch);\n709\t    const tasks = result.tasks as Record<string, Record<string, unknown>>;\n710\t\n711\t    // overrides applied\n712\t    expect(tasks.implement.session).toBe('continue');\n713\t    expect(tasks.implement.agent).toBe('dev');\n714\t\n715\t    // replace applied after overrides\n716\t    expect(result.flow).toEqual(['implement']);\n717\t  });\n718\t\n719\t  it('replace overwrites even if overrides also touched the same key', () => {\n720\t    const patch: WorkflowPatch = {\n721\t      overrides: {\n722\t        flow: ['implement', 'verify', 'extra'],\n723\t      },\n724\t      replace: {\n725\t        flow: ['only-this'],\n726\t      },\n727\t    };\n728\t    const result = mergeWorkflowPatch(base, patch);\n729\t    // replace wins because it runs after overrides\n730\t    expect(result.flow).toEqual(['only-this']);\n731\t  });\n732\t});\n733\t\n734\tdescribe('resolveWorkflow', () => {\n735\t  it('returns embedded workflow when no patches exist', () => {\n736\t    // Use a cwd with no .codeharness directory\n737\t    const result = resolveWorkflow({ cwd: testDir });\n738\t\n739\t    // Should return the embedded default workflow\n740\t    expect(result.tasks).toBeDefined();\n741\t    expect(result.tasks.implement).toBeDefined();\n742\t    expect(result.tasks.implement.agent).toBe('dev');\n743\t    expect(result.tasks.verify).toBeDefined();\n744\t    expect(result.tasks.verify.agent).toBe('evaluator');\n745\t    expect(result.flow.length).toBeGreaterThan(0);\n746\t  });\n747\t\n748\t  it('deep-merges overrides from project patch onto embedded base', () => {\n749\t    // Create project patch directory\n750\t    const patchDir = join(testDir, '.codeharness', 'workflows');\n751\t    mkdirSync(patchDir, { recursive: true });\n752\t\n753\t    const patchContent = `\n754\textends: embedded://default\n755\toverrides:\n756\t  tasks:\n757\t    implement:\n758\t      session: continue\n759\t      max_budget_usd: 10.0\n760\t`;\n761\t    writeFileSync(join(patchDir, 'default.patch.yaml'), patchContent, 'utf-8');\n762\t\n763\t    const result = resolveWorkflow({ cwd: testDir });\n764\t\n765\t    expect(result.tasks.implement.session).toBe('continue');\n766\t    expect(result.tasks.implement.max_budget_usd).toBe(10.0);\n767\t    // Preserved from base\n768\t    expect(result.tasks.implement.agent).toBe('dev');\n769\t    expect(result.tasks.implement.scope).toBe('per-story');\n770\t    expect(result.tasks.implement.source_access).toBe(true);\n771\t  });\n772\t\n773\t  it('deep-merges driver, model, plugins via project patch onto embedded base (Story 11-1)', () => {\n774\t    const patchDir = join(testDir, '.codeharness', 'workflows');\n775\t    mkdirSync(patchDir, { recursive: true });\n776\t\n777\t    const patchContent = `\n778\textends: embedded://default\n779\toverrides:\n780\t  tasks:\n781\t    implement:\n782\t      driver: codex\n783\t      model: codex-mini\n784\t      plugins:\n785\t        - gstack\n786\t`;\n787\t    writeFileSync(join(patchDir, 'default.patch.yaml'), patchContent, 'utf-8');\n788\t\n789\t    const result = resolveWorkflow({ cwd: testDir });\n790\t\n791\t    expect(result.tasks.implement.driver).toBe('codex');\n792\t    expect(result.tasks.implement.model).toBe('codex-mini');\n793\t    expect(result.tasks.implement.plugins).toEqual(['gstack']);\n794\t    // Preserved from base\n795\t    expect(result.tasks.implement.agent).toBe('dev');\n796\t    expect(result.tasks.implement.scope).toBe('per-story');\n797\t  });\n798\t\n799\t  it('applies replace sections as full replacement (not deep merge)', () => {\n800\t    const patchDir = join(testDir, '.codeharness', 'workflows');\n801\t    mkdirSync(patchDir, { recursive: true });\n802\t\n803\t    const patchContent = `\n804\textends: embedded://default\n805\treplace:\n806\t  flow:\n807\t    - implement\n808\t    - verify\n809\t`;\n810\t    writeFileSync(join(patchDir, 'default.patch.yaml'), patchContent, 'utf-8');\n811\t\n812\t    const result = resolveWorkflow({ cwd: testDir });\n813\t\n814\t    // flow fully replaced — no loop block from embedded default\n815\t    expect(result.flow).toEqual(['implement', 'verify']);\n816\t  });\n817\t\n818\t  it('applies user patch before project patch (ordering)', () => {\n819\t    // Create user-level patch\n820\t    const userPatchDir = join(os.homedir(), '.codeharness', 'workflows');\n821\t    const userPatchPath = join(userPatchDir, 'default.patch.yaml');\n822\t    let userPatchExisted = false;\n823\t    let originalUserPatch: string | undefined;\n824\t\n825\t    try {\n826\t      originalUserPatch = readFileSync(userPatchPath, 'utf-8');\n827\t      userPatchExisted = true;\n828\t    } catch { /* no existing patch */ }\n829\t\n830\t    try {\n831\t      mkdirSync(userPatchDir, { recursive: true });\n832\t      writeFileSync(userPatchPath, `\n833\textends: embedded://default\n834\toverrides:\n835\t  tasks:\n836\t    implement:\n837\t      session: continue\n838\t      max_budget_usd: 3.0\n839\t`, 'utf-8');\n840\t\n841\t      // Create project-level patch that overrides the user patch\n842\t      const projectPatchDir = join(testDir, '.codeharness', 'workflows');\n843\t      mkdirSync(projectPatchDir, { recursive: true });\n844\t      writeFileSync(join(projectPatchDir, 'default.patch.yaml'), `\n845\textends: embedded://default\n846\toverrides:\n847\t  tasks:\n848\t    implement:\n849\t      max_budget_usd: 7.0\n850\t`, 'utf-8');\n851\t\n852\t      const result = resolveWorkflow({ cwd: testDir });\n853\t\n854\t      // User patch: session=continue, max_budget_usd=3.0\n855\t      // Project patch overrides: max_budget_usd=7.0\n856\t      expect(result.tasks.implement.session).toBe('continue');\n857\t      expect(result.tasks.implement.max_budget_usd).toBe(7.0);\n858\t    } finally {\n859\t      // Cleanup user patch\n860\t      if (userPatchExisted && originalUserPatch !== undefined) {\n861\t        writeFileSync(userPatchPath, originalUserPatch, 'utf-8');\n862\t      } else {\n863\t        try { rmSync(userPatchPath); } catch { /* ignore */ }\n864\t      }\n865\t    }\n866\t  });\n867\t\n868\t  it('throws WorkflowParseError for malformed YAML patch', () => {\n869\t    const patchDir = join(testDir, '.codeharness', 'workflows');\n870\t    mkdirSync(patchDir, { recursive: true });\n871\t    writeFileSync(join(patchDir, 'default.patch.yaml'), '{{{{not yaml', 'utf-8');\n872\t\n873\t    expect(() => resolveWorkflow({ cwd: testDir })).toThrow(WorkflowParseError);\n874\t    try {\n875\t      resolveWorkflow({ cwd: testDir });\n876\t    } catch (err) {\n877\t      const pe = err as WorkflowParseError;\n878\t      expect(pe.message).toContain('Invalid YAML');\n879\t    }\n880\t  });\n881\t\n882\t  it('throws WorkflowParseError when merged result fails schema validation', () => {\n883\t    const patchDir = join(testDir, '.codeharness', 'workflows');\n884\t    mkdirSync(patchDir, { recursive: true });\n885\t\n886\t    // Replace tasks with invalid structure (agent missing)\n887\t    const patchContent = `\n888\textends: embedded://default\n889\treplace:\n890\t  tasks:\n891\t    broken:\n892\t      scope: per-story\n893\t`;\n894\t    writeFileSync(join(patchDir, 'default.patch.yaml'), patchContent, 'utf-8');\n895\t\n896\t    expect(() => resolveWorkflow({ cwd: testDir })).toThrow(WorkflowParseError);\n897\t    try {\n898\t      resolveWorkflow({ cwd: testDir });\n899\t    } catch (err) {\n900\t      const pe = err as WorkflowParseError;\n901\t      expect(pe.message).toContain('Schema validation failed');\n902\t    }\n903\t  });\n904\t\n905\t  it('throws WorkflowParseError when merged result has dangling task refs in flow', () => {\n906\t    const patchDir = join(testDir, '.codeharness', 'workflows');\n907\t    mkdirSync(patchDir, { recursive: true });\n908\t\n909\t    // Replace flow with ref to non-existent task, but keep tasks valid\n910\t    const patchContent = `\n911\textends: embedded://default\n912\treplace:\n913\t  flow:\n914\t    - implement\n915\t    - nonexistent_task\n916\t`;\n917\t    writeFileSync(join(patchDir, 'default.patch.yaml'), patchContent, 'utf-8');\n918\t\n919\t    expect(() => resolveWorkflow({ cwd: testDir })).toThrow(WorkflowParseError);\n920\t    try {\n921\t      resolveWorkflow({ cwd: testDir });\n922\t    } catch (err) {\n923\t      const pe = err as WorkflowParseError;\n924\t      expect(pe.message).toContain('Dangling task references');\n925\t      expect(pe.errors.some((e) => e.message.includes('nonexistent_task'))).toBe(true);\n926\t    }\n927\t  });\n928\t\n929\t  it('silently skips missing patch files', () => {\n930\t    // testDir has no .codeharness directory\n931\t    const result = resolveWorkflow({ cwd: testDir });\n932\t    // Should not throw, should return embedded workflow\n933\t    expect(result.tasks.implement).toBeDefined();\n934\t  });\n935\t\n936\t  it('uses cwd option to find project patches', () => {\n937\t    const projectA = join(testDir, 'project-a');\n938\t    const patchDir = join(projectA, '.codeharness', 'workflows');\n939\t    mkdirSync(patchDir, { recursive: true });\n940\t\n941\t    writeFileSync(join(patchDir, 'default.patch.yaml'), `\n942\textends: embedded://default\n943\toverrides:\n944\t  tasks:\n945\t    implement:\n946\t      max_budget_usd: 99.0\n947\t`, 'utf-8');\n948\t\n949\t    const result = resolveWorkflow({ cwd: projectA });\n950\t    expect(result.tasks.implement.max_budget_usd).toBe(99.0);\n951\t  });\n952\t\n953\t  it('throws WorkflowParseError for non-existent embedded workflow name', () => {\n954\t    expect(() => resolveWorkflow({ cwd: testDir, name: 'nonexistent-workflow' })).toThrow(WorkflowParseError);\n955\t    try {\n956\t      resolveWorkflow({ cwd: testDir, name: 'nonexistent-workflow' });\n957\t    } catch (err) {\n958\t      const pe = err as WorkflowParseError;\n959\t      expect(pe.message).toContain('Embedded workflow not found: nonexistent-workflow');\n960\t    }\n961\t  });\n962\t\n963\t  it('loads full custom workflow at project level when no extends', () => {\n964\t    const customDir = join(testDir, '.codeharness', 'workflows');\n965\t    mkdirSync(customDir, { recursive: true });\n966\t\n967\t    // Full custom workflow (not a patch)\n968\t    writeFileSync(join(customDir, 'default.yaml'), `\n969\ttasks:\n970\t  custom-task:\n971\t    agent: custom-agent\n972\tflow:\n973\t  - custom-task\n974\t`, 'utf-8');\n975\t\n976\t    const result = resolveWorkflow({ cwd: testDir });\n977\t    expect(result.tasks['custom-task']).toBeDefined();\n978\t    expect(result.tasks['custom-task'].agent).toBe('custom-agent');\n979\t  });\n980\t\n981\t  // --- Story 9.2: Custom Workflow Creation ---\n982\t\n983\t  describe('custom workflow by name (Story 9.2)', () => {\n984\t    it('loads a custom workflow from .codeharness/workflows/{name}.yaml by name', () => {\n985\t      const customDir = join(testDir, '.codeharness', 'workflows');\n986\t      mkdirSync(customDir, { recursive: true });\n987\t\n988\t      writeFileSync(join(customDir, 'my-workflow.yaml'), `\n989\ttasks:\n990\t  deploy:\n991\t    agent: deployer\n992\tflow:\n993\t  - deploy\n994\t`, 'utf-8');\n995\t\n996\t      const result = resolveWorkflow({ cwd: testDir, name: 'my-workflow' });\n997\t      expect(result.tasks.deploy).toBeDefined();\n998\t      expect(result.tasks.deploy.agent).toBe('deployer');\n999\t      expect(result.flow).toEqual(['deploy']);\n1000\t    });\n1001\t\n1002\t    it('custom workflow fails schema validation — throws WorkflowParseError', () => {\n1003\t      const customDir = join(testDir, '.codeharness', 'workflows');\n1004\t      mkdirSync(customDir, { recursive: true });\n1005\t\n1006\t      // Missing tasks key entirely\n1007\t      writeFileSync(join(customDir, 'bad-schema.yaml'), `\n1008\tflow:\n1009\t  - deploy\n1010\t`, 'utf-8');\n1011\t\n1012\t      expect(() => resolveWorkflow({ cwd: testDir, name: 'bad-schema' })).toThrow(WorkflowParseError);\n1013\t      try {\n1014\t        resolveWorkflow({ cwd: testDir, name: 'bad-schema' });\n1015\t      } catch (err) {\n1016\t        const pe = err as WorkflowParseError;\n1017\t        expect(pe.message).toContain('Schema validation failed');\n1018\t        expect(pe.errors.length).toBeGreaterThan(0);\n1019\t      }\n1020\t    });\n1021\t\n1022\t    it('custom workflow passes schema but has dangling flow refs — throws WorkflowParseError', () => {\n1023\t      const customDir = join(testDir, '.codeharness', 'workflows');\n1024\t      mkdirSync(customDir, { recursive: true });\n1025\t\n1026\t      writeFileSync(join(customDir, 'dangling.yaml'), `\n1027\ttasks:\n1028\t  deploy:\n1029\t    agent: deployer\n1030\tflow:\n1031\t  - deploy\n1032\t  - nonexistent\n1033\t`, 'utf-8');\n1034\t\n1035\t      expect(() => resolveWorkflow({ cwd: testDir, name: 'dangling' })).toThrow(WorkflowParseError);\n1036\t      try {\n1037\t        resolveWorkflow({ cwd: testDir, name: 'dangling' });\n1038\t      } catch (err) {\n1039\t        const pe = err as WorkflowParseError;\n1040\t        expect(pe.message).toContain('Dangling task references');\n1041\t        expect(pe.errors.some((e) => e.message.includes('nonexistent'))).toBe(true);\n1042\t      }\n1043\t    });\n1044\t\n1045\t    it('resolveWorkflow({ name: \"nonexistent\" }) with no matching file throws clear error', () => {\n1046\t      expect(() => resolveWorkflow({ cwd: testDir, name: 'nonexistent' })).toThrow(WorkflowParseError);\n1047\t      try {\n1048\t        resolveWorkflow({ cwd: testDir, name: 'nonexistent' });\n1049\t      } catch (err) {\n1050\t        const pe = err as WorkflowParseError;\n1051\t        expect(pe.message).toContain('Embedded workflow not found: nonexistent');\n1052\t      }\n1053\t    });\n1054\t\n1055\t    it('resolveWorkflow() with no name defaults to \"default\" — backward-compatible', () => {\n1056\t      const result = resolveWorkflow({ cwd: testDir });\n1057\t      // Should load embedded default without error\n1058\t      expect(result.tasks).toBeDefined();\n1059\t      expect(result.tasks.implement).toBeDefined();\n1060\t      expect(result.flow.length).toBeGreaterThan(0);\n1061\t    });\n1062\t\n1063\t    it('custom workflow with extends key is NOT treated as full custom (falls to patch resolution)', () => {\n1064\t      const customDir = join(testDir, '.codeharness', 'workflows');\n1065\t      mkdirSync(customDir, { recursive: true });\n1066\t\n1067\t      // This has extends, so it should be treated as a patch-like file, not a full custom workflow\n1068\t      // Since the name is 'ci' and there is no embedded 'ci' template, this should throw\n1069\t      writeFileSync(join(customDir, 'ci.yaml'), `\n1070\textends: embedded://default\n1071\toverrides:\n1072\t  tasks:\n1073\t    implement:\n1074\t      session: continue\n1075\t`, 'utf-8');\n1076\t\n1077\t      // With extends, it's not treated as a full custom workflow.\n1078\t      // It tries to load embedded 'ci' template which doesn't exist => error\n1079\t      expect(() => resolveWorkflow({ cwd: testDir, name: 'ci' })).toThrow(WorkflowParseError);\n1080\t      try {\n1081\t        resolveWorkflow({ cwd: testDir, name: 'ci' });\n1082\t      } catch (err) {\n1083\t        const pe = err as WorkflowParseError;\n1084\t        expect(pe.message).toContain('Embedded workflow not found: ci');\n1085\t      }\n1086\t    });\n1087\t\n1088\t    it('custom workflow alongside patch file: patch is ignored for full custom workflows', () => {\n1089\t      const customDir = join(testDir, '.codeharness', 'workflows');\n1090\t      mkdirSync(customDir, { recursive: true });\n1091\t\n1092\t      // Full custom workflow (no extends)\n1093\t      writeFileSync(join(customDir, 'ci.yaml'), `\n1094\ttasks:\n1095\t  build:\n1096\t    agent: builder\n1097\tflow:\n1098\t  - build\n1099\t`, 'utf-8');\n1100\t\n1101\t      // Patch file that would change agent — should be ignored\n1102\t      writeFileSync(join(customDir, 'ci.patch.yaml'), `\n1103\textends: embedded://default\n1104\toverrides:\n1105\t  tasks:\n1106\t    build:\n1107\t      agent: patched-builder\n1108\t`, 'utf-8');\n1109\t\n1110\t      const result = resolveWorkflow({ cwd: testDir, name: 'ci' });\n1111\t      expect(result.tasks.build.agent).toBe('builder'); // Not patched\n1112\t    });\n1113\t\n1114\t    it('custom workflow with custom agent names resolves agent field correctly', () => {\n1115\t      const customDir = join(testDir, '.codeharness', 'workflows');\n1116\t      mkdirSync(customDir, { recursive: true });\n1117\t\n1118\t      writeFileSync(join(customDir, 'multi-agent.yaml'), `\n1119\ttasks:\n1120\t  build:\n1121\t    agent: my-custom-builder\n1122\t  test:\n1123\t    agent: my-custom-tester\n1124\t  deploy:\n1125\t    agent: my-custom-deployer\n1126\tflow:\n1127\t  - build\n1128\t  - test\n1129\t  - deploy\n1130\t`, 'utf-8');\n1131\t\n1132\t      const result = resolveWorkflow({ cwd: testDir, name: 'multi-agent' });\n1133\t      expect(result.tasks.build.agent).toBe('my-custom-builder');\n1134\t      expect(result.tasks.test.agent).toBe('my-custom-tester');\n1135\t      expect(result.tasks.deploy.agent).toBe('my-custom-deployer');\n1136\t    });\n1137\t  });\n1138\t});\n1139\t"}]},"parent_tool_use_id":"toolu_01K9WPLAQDFLLNWtkamPogoK","session_id":"4b1f7711-6ed7-4488-a0af-b261e761b450","uuid":"5ac8c69e-2d8e-4117-82f8-6b23a22c90b3","timestamp":"2026-04-03T08:30:25.467Z"}
