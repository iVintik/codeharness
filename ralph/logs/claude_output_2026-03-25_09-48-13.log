y installed\n   405→    const results = installAllDependencies({});\n   406→    const failed = results.filter(r => r.status === 'failed');\n   407→    expect(failed.length).toBeGreaterThanOrEqual(1);\n   408→    const beadsResult = results.find(r => r.name === 'beads');\n   409→    expect(beadsResult?.status).toBe('already-installed');\n   410→  });\n   411→\n   412→  it('prints OK messages for installed dependencies (non-json mode)', () => {\n   413→    const logSpy = vi.spyOn(console, 'log');\n   414→    mockExecFileSync.mockReturnValue(Buffer.from('tool 1.0.0'));\n   415→\n   416→    installAllDependencies({ json: false });\n   417→\n   418→    const calls = logSpy.mock.calls.map(c => c[0]);\n   419→    expect(calls.some(c => typeof c === 'string' && c.includes('[OK]'))).toBe(true);\n   420→  });\n   421→\n   422→  it('prints installed (not already-installed) message for freshly installed deps', () => {\n   423→    const logSpy = vi.spyOn(console, 'log');\n   424→    let showboatCheckCount = 0;\n   425→    mockExecFileSync.mockImplementation(((cmd: string) => {\n   426→      const cmdStr = typeof cmd === 'string' ? cmd : String(cmd);\n   427→      // For showboat: first version check fails, install succeeds, post-check succeeds\n   428→      if (cmdStr === 'showboat') {\n   429→        showboatCheckCount++;"}]},"parent_tool_use_id":"toolu_01WkMxZtPiPNmfZs5KGPn8sb","session_id":"ff429d75-7a8f-4551-b5e9-f4da09d39b92","uuid":"b7b305f4-286e-4858-b930-2da3ca21e5b7","timestamp":"2026-03-25T06:02:18.691Z"}
