{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MTDj2oPvCWzjWN1fHFxBRY","type":"tool_result","content":"60\t *\n61\t * Driver validation is skipped when the driver registry is empty (parse can\n62\t * be called independently of engine startup).\n63\t *\n64\t * Agent validation tries resolveAgent() first (covers embedded, user-level,\n65\t * and project-level agents). Distinguishes between \"not found\" errors and\n66\t * other failures (corrupt YAML, schema errors) to provide accurate messages.\n67\t */\n68\tfunction validateReferentialIntegrity(\n69\t  data: { tasks: Record<string, Record<string, unknown>> },\n70\t  errors: Array<{ path: string; message: string }>,\n71\t): void {\n72\t  // Driver validation — only when registry is populated\n73\t  const registeredDrivers = listDrivers();\n74\t  const driverRegistryPopulated = registeredDrivers.length > 0;\n75\t\n76\t  // Agent list for error messages\n77\t  const embeddedAgents = listEmbeddedAgents();\n78\t\n79\t  for (const [taskName, task] of Object.entries(data.tasks)) {\n80\t    // Validate driver field if present\n81\t    if (task.driver !== undefined && typeof task.driver === 'string' && driverRegistryPopulated) {\n82\t      if (!registeredDrivers.includes(task.driver)) {\n83\t        errors.push({\n84\t          path: `/tasks/${taskName}/driver`,\n85\t          message: `Driver \"${task.driver}\" not found in task \"${taskName}\". Registered drivers: ${registeredDrivers.join(', ')}`,\n86\t        });\n87\t      }\n88\t    }\n89\t\n90\t    // Validate agent field if present\n91\t    if (task.agent !== undefined && typeof task.agent === 'string') {\n92\t      try {\n93\t        resolveAgent(task.agent);\n94\t      } catch (err: unknown) {\n95\t        // Distinguish \"not found\" from \"found but broken\" (corrupt YAML, schema errors)\n96\t        if (err instanceof AgentResolveError && err.message.startsWith('Embedded agent not found:')) {\n97\t          const available = embeddedAgents.length > 0 ? embeddedAgents.join(', ') : '(none)';\n98\t          errors.push({\n99\t            path: `/tasks/${taskName}/agent`,\n100\t            message: `Agent \"${task.agent}\" not found in task \"${taskName}\". Available agents: ${available}`,\n101\t          });\n102\t        } else if (err instanceof AgentResolveError) {\n103\t          // Agent exists but is broken (corrupt YAML, schema validation failure, etc.)\n104\t          errors.push({\n105\t            path: `/tasks/${taskName}/agent`,\n106\t            message: `Agent \"${task.agent}\" in task \"${taskName}\" failed to resolve: ${err.message}`,\n107\t          });\n108\t        } else {\n109\t          // Unexpected error — still report it instead of silently swallowing"}]},"parent_tool_use_id":"toolu_01NbvnX8QKy5nChzR2X7gMdM","session_id":"4b1f7711-6ed7-4488-a0af-b261e761b450","uuid":"59d48b8c-5d87-40f7-8007-7a08b7e4799f","timestamp":"2026-04-03T08:42:47.942Z"}
