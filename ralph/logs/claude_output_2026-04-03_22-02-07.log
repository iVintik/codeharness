{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JoYzd3tc5YyVVPWnnWh97T","type":"tool_result","content":"100\t};\n101\t\n102\texport function getDefaultCoverageTool(stack?: string | null): HarnessState['coverage']['tool'] {\n103\t  if (stack && COVERAGE_TOOL_DEFAULTS[stack]) return COVERAGE_TOOL_DEFAULTS[stack];\n104\t  return 'c8';\n105\t}\n106\t\n107\texport function getDefaultState(stack?: string | null): HarnessState {\n108\t  return {\n109\t    harness_version: '0.1.0',\n110\t    initialized: false,\n111\t    stack: stack ?? null,\n112\t    stacks: stack ? [stack as StackName] : [],\n113\t    enforcement: {\n114\t      frontend: true,\n115\t      database: true,\n116\t      api: true,\n117\t    },\n118\t    coverage: {\n119\t      target: 90,\n120\t      baseline: null,\n121\t      current: null,\n122\t      tool: getDefaultCoverageTool(stack),\n123\t    },\n124\t    session_flags: {\n125\t      logs_queried: false,\n126\t      tests_passed: false,\n127\t      coverage_met: false,\n128\t      verification_run: false,\n129\t    },\n130\t    verification_log: [],\n131\t  };\n132\t}\n133\t\n134\texport function getStatePath(dir: string): string {\n135\t  return join(dir, STATE_DIR, STATE_FILE);\n136\t}\n137\t\n138\texport function writeState(state: HarnessState, dir?: string, body?: string): void {\n139\t  const baseDir = dir ?? process.cwd();\n140\t  const claudeDir = join(baseDir, STATE_DIR);\n141\t  mkdirSync(claudeDir, { recursive: true });\n142\t\n143\t  // Sync stack from stacks[0] for backward compat (shallow copy to avoid mutating caller's object)\n144\t  const toWrite = { ...state };\n145\t  if (toWrite.stacks && toWrite.stacks.length > 0) {\n146\t    toWrite.stack = toWrite.stacks[0];\n147\t  }\n148\t\n149\t  const yamlContent = stringify(toWrite, { nullStr: 'null' });\n150\t  const markdownBody = body ?? DEFAULT_BODY;\n151\t  const fileContent = `---\\n${yamlContent}---\\n${markdownBody}`;\n152\t\n153\t  writeFileSync(join(claudeDir, STATE_FILE), fileContent, 'utf-8');\n154\t}\n155\t\n156\texport function readState(dir?: string): HarnessState {\n157\t  const baseDir = dir ?? process.cwd();\n158\t  const filePath = getStatePath(baseDir);\n159\t\n160\t  if (!existsSync(filePath)) {\n161\t    throw new StateFileNotFoundError();\n162\t  }\n163\t\n164\t  const raw = readFileSync(filePath, 'utf-8');\n165\t  const parts = raw.split('---');\n166\t\n167\t  // parts[0] is empty (before first ---), parts[1] is YAML, rest is body\n168\t  if (parts.length < 3) {\n169\t    return recoverCorruptedState(baseDir);\n170\t  }\n171\t\n172\t  try {\n173\t    const state = parse(parts[1]) as HarnessState;\n174\t    if (!isValidState(state)) {\n175\t      return recoverCorruptedState(baseDir);\n176\t    }\n177\t    return migrateState(state);\n178\t  } catch {\n179\t    // IGNORE: corrupted state file, recover gracefully"}]},"parent_tool_use_id":"toolu_017cqb76qurL8ij6LsD8qadk","session_id":"9476bbd2-ee0a-4a5e-ac2a-0ed5228c47bf","uuid":"40b7bbc1-fb46-4310-a485-0adb2de9be8a","timestamp":"2026-04-03T18:07:01.031Z"}
