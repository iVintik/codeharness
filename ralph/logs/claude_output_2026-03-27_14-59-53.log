{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Wo8fnWEQtvkLdJn2gpPrDF","type":"tool_result","content":"     1→/** Proof quality validation and black-box enforcement. */\n     2→import { existsSync, readFileSync } from 'node:fs';\n     3→import type { ProofQuality, ClassifiedCommand, EvidenceCommandType, BlackBoxEnforcementResult } from './types.js';\n     4→\n     5→/** Extracts commands from ```bash/```shell blocks and classifies each. */\n     6→export function classifyEvidenceCommands(proofContent: string): ClassifiedCommand[] {\n     7→  const results: ClassifiedCommand[] = [];\n     8→\n     9→  const codeBlockPattern = /```(?:bash|shell)\\n([\\s\\S]*?)```/g;\n    10→  for (const match of proofContent.matchAll(codeBlockPattern)) {\n    11→    const block = match[1].trim();\n    12→    const lines = block.split('\\n').filter(l => l.trim().length > 0);\n    13→    for (const line of lines) {\n    14→      const cmd = line.trim();\n    15→      if (!cmd) continue;\n    16→      results.push({ command: cmd, type: classifyCommand(cmd) });\n    17→    }\n    18→  }\n    19→\n    20→  return results;\n    21→}\n    22→\n    23→function classifyCommand(cmd: string): EvidenceCommandType {\n    24→  if (/docker\\s+exec\\b/.test(cmd)) {\n    25→    return 'docker-exec';\n    26→  }\n    27→\n    28→  if (/docker\\s+(ps|logs|inspect|stats|top|port)\\b/.test(cmd)) {\n    29→    return 'docker-host';\n    30→  }\n    31→\n    32→  if (/curl\\b/.test(cmd) && /localhost:(9428|8428|16686)\\b/.test(cmd)) {\n    33→    return 'observability';\n    34→  }\n    35→\n    36→  if (/\\bgrep\\b/.test(cmd) && /\\bsrc\\//.test(cmd)) {\n    37→    return 'grep-src';\n    38→  }\n    39→\n    40→  return 'other';\n    41→}\n    42→\n    43→/** Checks black-box enforcement: rejects >50% grep src/ or missing docker exec per AC. */\n    44→export function checkBlackBoxEnforcement(proofContent: string): BlackBoxEnforcementResult {\n    45→  const commands = classifyEvidenceCommands(proofContent);\n    46→\n    47→  const grepSrcCount = commands.filter(c => c.type === 'grep-src').length;\n    48→  const dockerExecCount = commands.filter(c => c.type === 'docker-exec').length;\n    49→  const observabilityCount = commands.filter(c => c.type === 'observability').length;\n    50→  const otherCount = commands.filter(c => c.type === 'other').length;\n    51→  const totalCommands = commands.length;\n    52→\n    53→  const grepRatio = totalCommands > 0 ? grepSrcCount / totalCommands : 0;\n    54→\n    55→  // Check per-AC docker exec presence\n    56→  const acsMissingDockerExec: number[] = [];\n    57→  const acHeaderPattern = /^## AC ?(\\d+):/gm;\n    58→  const acMatches = [...proofContent.matchAll(acHeaderPattern)];\n    59→\n    60→  if (acMatches.length > 0) {\n    61→    for (let i = 0; i < acMatches.length; i++) {\n    62→      const acNum = parseInt(acMatches[i][1], 10);\n    63→      const start = acMatches[i].index!;\n    64→      const end = i + 1 < acMatches.length ? acMatches[i + 1].index! : proofContent.length;\n    65→      const section = proofContent.slice(start, end);\n    66→\n    67→      // Skip escalated ACs\n    68→      if (section.includes('[ESCALATE]')) continue;\n    69→\n    70→      const sectionCommands = classifyEvidenceCommands(section);\n    71→      const hasBlackBoxEvidence = sectionCommands.some(c =>\n    72→        c.type === 'docker-exec' || c.type === 'docker-host' || c.type === 'observability'\n    73→      );\n    74→      if (!hasBlackBoxEvidence) {\n    75→        acsMissingDockerExec.push(acNum);\n    76→      }\n    77→    }\n    78→  }\n    79→\n    80→  const grepTooHigh = grepRatio > 0.5;\n    81→  const missingDockerExec = acsMissingDockerExec.length > 0;\n    82→  const hasExtractableCommands = totalCommands > 0;\n    83→\n    84→  return {\n    85→    blackBoxPass: !hasExtractableCommands || (!grepTooHigh && !missingDockerExec),\n    86→    grepSrcCount,\n    87→    dockerExecCount,\n    88→    observabilityCount,\n    89→    otherCount,\n    90→    grepRatio,\n    91→    acsMissingDockerExec,\n    92→  };\n    93→}\n    94→\n    95→/** Checks if [FAIL] appears outside code blocks and inline code. */\n    96→function hasFailVerdict(section: string): boolean {\n    97→  return section.replace(/```[\\s\\S]*?```/g, '').replace(/`[^`]+`/g, '').includes('[FAIL]');\n    98→}\n    99→\n   100→/** Validates proof quality. `passed` is true when `pending === 0 && verified > 0`. */\n   101→export function validateProofQuality(proofPath: string): ProofQuality {\n   102→  const emptyResult: ProofQuality = {\n   103→    verified: 0, pending: 0, escalated: 0, total: 0, passed: false,\n   104→    grepSrcCount: 0, dockerExecCount: 0, observabilityCount: 0, otherCount: 0,\n   105→    blackBoxPass: false,\n   106→  };\n   107→\n   108→  if (!existsSync(proofPath)) {\n   109→    return emptyResult;\n   110→  }\n   111→\n   112→  const content = readFileSync(proofPath, 'utf-8');\n   113→\n   114→  // Compute black-box enforcement metrics once\n   115→  // Skip Docker enforcement for tiers that don't require container evidence\n   116→  const bbTierMatch = /\\*\\*Tier:\\*\\*\\s*(test-provable|runtime-provable|environment-provable|escalate|unit-testable|black-box)/i.exec(content);\n   117→  const tierValue = bbTierMatch ? bbTierMatch[1].toLowerCase() : null;\n   118→  // Skip Docker enforcement for tiers that don't need Docker\n   119→  const skipDockerEnforcement = tierValue === 'test-provable'\n   120→    || tierValue === 'runtime-provable'\n   121→    || tierValue === 'escalate'\n   122→    || tierValue === 'unit-testable'; // backward compat\n   123→  const bbEnforcement = skipDockerEnforcement\n   124→    ? { blackBoxPass: true, grepSrcCount: 0, dockerExecCount: 0, observabilityCount: 0, otherCount: 0, grepRatio: 0, acsMissingDockerExec: [] as number[] }\n   125→    : checkBlackBoxEnforcement(content);\n   126→\n   127→  /** Helper: merge base counts with black-box metrics */\n   128→  function buildResult(base: {\n   129→    verified: number; pending: number; escalated: number; total: number;\n   130→  }): ProofQuality {\n   131→    const basePassed = base.pending === 0 && base.verified > 0;\n   132→    return {\n   133→      ...base,\n   134→      passed: basePassed && bbEnforcement.blackBoxPass,\n   135→      grepSrcCount: bbEnforcement.grepSrcCount,\n   136→      dockerExecCount: bbEnforcement.dockerExecCount,\n   137→      observabilityCount: bbEnforcement.observabilityCount,\n   138→      otherCount: bbEnforcement.otherCount,\n   139→      blackBoxPass: bbEnforcement.blackBoxPass,\n   140→    };\n   141→  }\n   142→\n   143→  // Format 1: ## AC N: section headers\n   144→  const acHeaderPattern = /^## AC ?(\\d+):/gm;\n   145→  const matches = [...content.matchAll(acHeaderPattern)];\n   146→\n   147→  // Find all ## headings that are NOT AC headers (e.g. ## Summary, ## Test Evidence)\n   148→  // These bound the last AC section so it doesn't bleed into trailing sections\n   149→  const nonAcHeadingPattern = /^## (?!AC ?\\d+:)/gm;\n   150→  const nonAcHeadings = [...content.matchAll(nonAcHeadingPattern)].map(m => m.index!);\n   151→\n   152→  let verified = 0;\n   153→  let pending = 0;\n   154→  let escalated = 0;\n   155→\n   156→  if (matches.length > 0) {\n   157→    for (let i = 0; i < matches.length; i++) {\n   158→      const start = matches[i].index!;\n   159→      // End at the next ## AC header or any non-AC ## heading (e.g. ## Summary), whichever comes first\n   160→      const nextAcEnd = i + 1 < matches.length ? matches[i + 1].index! : content.length;\n   161→      const nextNonAcHeading = nonAcHeadings.find(h => h > start);\n   162→      const end = nextNonAcHeading !== undefined && nextNonAcHeading < nextAcEnd\n   163→        ? nextNonAcHeading\n   164→        : nextAcEnd;\n   165→      const section = content.slice(start, end);\n   166→\n   167→      if (section.includes('[ESCALATE]')) {\n   168→        escalated++;\n   169→        continue;\n   170→      }\n   171→\n   172→      if (hasFailVerdict(section)) {\n   173→        pending++;\n   174→        continue;\n   175→      }\n   176→\n   177→      const hasEvidence =\n   178→        section.includes('<!-- /showboat exec -->') ||\n   179→        section.includes('<!-- showboat image:') ||\n   180→        /```(?:bash|shell)\\n[\\s\\S]*?```\\n+```output\\n/m.test(section);\n   181→\n   182→      if (hasEvidence) {\n   183→        verified++;\n   184→      } else {\n   185→        pending++;\n   186→      }\n   187→    }\n   188→  } else {\n   189→    // Format 2: showboat native — inline --- ACN: markers\n   190→    const inlineAcPattern = /--- AC ?(\\d+):/g;\n   191→    const inlineMatches = [...content.matchAll(inlineAcPattern)];\n   192→    const acNumbers = new Set(inlineMatches.map(m => m[1]));\n   193→\n   194→    if (acNumbers.size === 0) {\n   195→      // Format 3: narrative proofs with === AC N: markers\n   196→      const narrativeAcPattern = /=== AC ?(\\d+):/g;\n   197→      const narrativeMatches = [...content.matchAll(narrativeAcPattern)];\n   198→      const narrativeAcNumbers = new Set(narrativeMatches.map(m => m[1]));\n   199→\n   200→      if (narrativeAcNumbers.size === 0) {\n   201→        // Format 4: bullet-list AC summaries\n   202→        const bulletAcPattern = /^- AC ?(\\d+)[^:\\n]*:/gm;\n   203→        const bulletMatches = [...content.matchAll(bulletAcPattern)];\n   204→        const bulletAcNumbers = new Set(bulletMatches.map(m => m[1]));\n   205→\n   206→        if (bulletAcNumbers.size === 0) {\n   207→          return buildResult({ verified: 0, pending: 0, escalated: 0, total: 0 });\n   208→        }\n   209→\n   210→        let bVerified = 0;\n   211→        let bPending = 0;\n   212→        let bEscalated = 0;\n   213→\n   214→        for (const acNum of bulletAcNumbers) {\n   215→          const bulletPattern = new RegExp(`^- AC ?${acNum}[^:\\\\n]*:(.*)$`, 'm');\n   216→          const bulletMatch = content.match(bulletPattern);\n   217→          if (!bulletMatch) { bPending++; continue; }\n   218→\n   219→          const bulletText = bulletMatch[1].toLowerCase();\n   220→          if (bulletText.includes('n/a') || bulletText.includes('escalat') || bulletText.includes('superseded')) {\n   221→            bEscalated++;\n   222→          } else if (bulletText.includes('fail')) {\n   223→            bPending++;\n   224→          } else {\n   225→            bVerified++;\n   226→          }\n   227→        }\n   228→\n   229→        const hasAnyEvidence = /```output\\n/m.test(content);\n   230→        if (!hasAnyEvidence) {\n   231→          bPending += bVerified;\n   232→          bVerified = 0;\n   233→        }\n   234→\n   235→        const bTotal = bVerified + bPending + bEscalated;\n   236→        return buildResult({\n   237→          verified: bVerified,\n   238→          pending: bPending,\n   239→          escalated: bEscalated,\n   240→          total: bTotal,\n   241→        });\n   242→      }\n   243→\n   244→      // Sort AC markers by position for region-based analysis\n   245→      const sortedAcs = narrativeMatches\n   246→        .map(m => ({ num: m[1], idx: m.index! }))\n   247→        .filter((v, i, a) => a.findIndex(x => x.num === v.num) === i)\n   248→        .sort((a, b) => a.idx - b.idx);\n   249→\n   250→      for (let i = 0; i < sortedAcs.length; i++) {\n   251→        const regionStart = i > 0 ? sortedAcs[i - 1].idx : 0;\n   252→        const regionEnd = i + 1 < sortedAcs.length ? sortedAcs[i + 1].idx : content.length;\n   253→        const section = content.slice(regionStart, regionEnd);\n   254→\n   255→        if (section.includes('[ESCALATE]')) {\n   256→          escalated++;\n   257→        } else if (hasFailVerdict(section)) {\n   258→          pending++;\n   259→        } else if (/```output/m.test(section)) {\n   260→          verified++;\n   261→        } else {\n   262→          pending++;\n   263→        }\n   264→      }\n   265→\n   266→      const narrativeTotal = verified + pending + escalated;\n   267→      return buildResult({\n   268→        verified,\n   269→        pending,\n   270→        escalated,\n   271→        total: narrativeTotal,\n   272→      });\n   273→    }\n   274→\n   275→    for (const acNum of acNumbers) {\n   276→      const acPattern2 = new RegExp(`--- AC ?${acNum}:`, 'g');\n   277→      const acIdx = content.search(acPattern2);\n   278→      if (acIdx === -1) { pending++; continue; }\n   279→\n   280→      const nextAcPattern = new RegExp(`--- AC ?(?!${acNum})\\\\d+:`, 'g');\n   281→      nextAcPattern.lastIndex = acIdx + 1;\n   282→      const nextMatch = nextAcPattern.exec(content);\n   283→      const section = content.slice(acIdx, nextMatch ? nextMatch.index : content.length);\n   284→\n   285→      if (section.includes('[ESCALATE]')) {\n   286→        escalated++;\n   287→      } else if (hasFailVerdict(section)) {\n   288→        pending++;\n   289→      } else if (/```output\\n/m.test(section)) {\n   290→        verified++;\n   291→      } else {\n   292→        pending++;\n   293→      }\n   294→    }\n   295→  }\n   296→\n   297→  const total = verified + pending + escalated;\n   298→  return buildResult({ verified, pending, escalated, total });\n   299→}\n   300→\n   301→/** @deprecated Use `validateProofQuality()` instead. */\n   302→export function proofHasContent(proofPath: string): boolean {\n   303→  return validateProofQuality(proofPath).passed;\n   304→}\n   305→"}]},"parent_tool_use_id":"toolu_01FBYb3WSC17Tg6VaiRjwb3D","session_id":"43e58b5f-4801-4d1c-b71e-1cb2980b19a0","uuid":"37096e4d-f22d-4d72-89b9-b661a5190846","timestamp":"2026-03-27T11:09:51.676Z"}
