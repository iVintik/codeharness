skName: string, storyKey: string): EngineError {\n915\t  if (err instanceof DispatchError) {\n916\t    return {\n917\t      taskName,\n918\t      storyKey,\n919\t      code: err.code,\n920\t      message: err.message,\n921\t    };\n922\t  }\n923\t\n924\t  const message = err instanceof Error ? err.message : String(err);\n925\t  return {\n926\t    taskName,\n927\t    storyKey,\n928\t    code: 'UNKNOWN',\n929\t    message,\n930\t  };\n931\t}\n932\t"}]},"parent_tool_use_id":"toolu_01LQLKYZKtmy4cEq7pgn6KQD","session_id":"90f775a4-0bf0-4884-b410-4d7f1f50684d","uuid":"b2ab8823-5ace-457c-aa6f-d9cfe74ac768","timestamp":"2026-04-03T08:14:41.040Z"}
