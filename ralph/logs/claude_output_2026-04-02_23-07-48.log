{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015xMPo7VUcdomeHZCXmW15x","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { resolve, join } from 'node:path';\n3\timport os from 'node:os';\n4\timport { parse } from 'yaml';\n5\timport { validateAgentSchema } from './schema-validate.js';\n6\t\n7\t// --- Interfaces ---\n8\t\n9\t/**\n10\t * Agent config shape matching agent.schema.json, plus optional prompt_patches\n11\t * accumulated from patch files.\n12\t */\n13\texport interface ResolvedAgent {\n14\t  name: string;\n15\t  role: {\n16\t    title: string;\n17\t    purpose: string;\n18\t  };\n19\t  persona: {\n20\t    identity: string;\n21\t    communication_style: string;\n22\t    principles: string[];\n23\t  };\n24\t  personality?: {\n25\t    traits: Record<string, number>;\n26\t  };\n27\t  disallowedTools?: string[];\n28\t  prompt_patches?: {\n29\t    append?: string;\n30\t  };\n31\t}\n32\t\n33\t/**\n34\t * Compiled subagent definition ready for Agent SDK dispatch.\n35\t */\n36\texport interface SubagentDefinition {\n37\t  name: string;\n38\t  model: string;\n39\t  instructions: string;\n40\t  disallowedTools: string[];\n41\t  bare: true;\n42\t}\n43\t\n44\t/**\n45\t * Patch file structure: extends identifies base, overrides deep-merged,\n46\t * prompt_patches preserved separately.\n47\t */\n48\texport interface AgentPatch {\n49\t  extends?: string;\n50\t  overrides?: Record<string, unknown>;\n51\t  prompt_patches?: {\n52\t    append?: string;\n53\t  };\n54\t}\n55\t\n56\t// --- Error Class ---\n57\t\n58\texport class AgentResolveError extends Error {\n59\t  public readonly filePath: string;\n60\t  public readonly errors: Array<{ path: string; message: string }>;\n61\t\n62\t  constructor(\n63\t    message: string,\n64\t    filePath: string,\n65\t    errors?: Array<{ path: string; message: string }>,\n66\t  ) {\n67\t    super(message);\n68\t    this.name = 'AgentResolveError';\n69\t    this.filePath = filePath;\n70\t    this.errors = errors ?? [];\n71\t  }\n72\t}\n73\t\n74\t// --- Constants ---\n75\t\n76\tconst TEMPLATES_DIR = resolve(__dirname, '../../templates/agents');\n77\tconst DEFAULT_MODEL = 'claude-sonnet-4-20250514';\n78\t\n79\t// --- Deep Merge ---\n80\t\n81\t/**\n82\t * Deep merge strategy: objects merge recursively, arrays replace, scalars replace.\n83\t */\n84\tfunction deepMerge(base: Record<string, unknown>, patch: Record<string, unknown>): Record<string, unknown> {\n85\t  const result: Record<string, unknown> = { ...base };\n86\t\n87\t  for (const key of Object.keys(patch)) {\n88\t    const baseVal = base[key];\n89\t    const patchVal = patch[key];\n90\t\n91\t    if (\n92\t      patchVal !== null &&\n93\t      typeof patchVal === 'object' &&\n94\t      !Array.isArray(patchVal) &&\n95\t      baseVal !== null &&\n96\t      typeof baseVal === 'object' &&\n97\t      !Array.isArray(baseVal)\n98\t    ) {\n99\t      result[key] = deepMerge(\n100\t        baseVal as Record<string, unknown>,\n101\t        patchVal as Record<string, unknown>,\n102\t      );\n103\t    } else {\n104\t      result[key] = patchVal;\n105\t    }\n106\t  }\n107\t\n108\t  return result;\n109\t}\n110\t\n111\t// --- Embedded Agent Loading ---\n112\t\n113\t/**\n114\t * Load an embedded agent template from templates/agents/{name}.yaml.\n115\t * Throws AgentResolveError if not found or invalid.\n116\t */\n117\texport function loadEmbeddedAgent(name: string): ResolvedAgent {\n118\t  const filePath = join(TEMPLATES_DIR, `${name}.yaml`);\n119\t\n120\t  let raw: string;\n121\t  try {\n122\t    raw = readFileSync(filePath, 'utf-8');\n123\t  } catch { // IGNORE: rethrow as AgentResolveError with context\n124\t    throw new AgentResolveError(\n125\t      `Embedded agent not found: ${name}`,\n126\t      filePath,\n127\t      [{ path: filePath, message: `File not found: ${filePath}` }],\n128\t    );\n129\t  }\n130\t\n131\t  let parsed: unknown;\n132\t  try {\n133\t    parsed = parse(raw);\n134\t  } catch (err: unknown) {\n135\t    const msg = err instanceof Error ? err.message : String(err);\n136\t    throw new AgentResolveError(\n137\t      `Invalid YAML in embedded agent ${name}: ${msg}`,\n138\t      filePath,\n139\t      [{ path: filePath, message: msg }],\n140\t    );\n141\t  }\n142\t\n143\t  const result = validateAgentSchema(parsed);\n144\t  if (!result.valid) {\n145\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n146\t    throw new AgentResolveError(\n147\t      `Schema validation failed for embedded agent ${name}: ${details}`,\n148\t      filePath,\n149\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n150\t    );\n151\t  }\n152\t\n153\t  return parsed as ResolvedAgent;\n154\t}\n155\t\n156\t// --- Patch Loading ---\n157\t\n158\t/**\n159\t * Load a patch file. Returns null if the file does not exist (silent skip).\n160\t * Throws AgentResolveError on malformed YAML.\n161\t */\n162\texport function loadPatch(filePath: string): AgentPatch | null {\n163\t  if (!existsSync(filePath)) {\n164\t    return null;\n165\t  }\n166\t\n167\t  let raw: string;\n168\t  try {\n169\t    raw = readFileSync(filePath, 'utf-8');\n170\t  } catch { // IGNORE: file unreadable ŌĆö treat as missing patch\n171\t    return null;\n172\t  }\n173\t\n174\t  let parsed: unknown;\n175\t  try {\n176\t    parsed = parse(raw);\n177\t  } catch (err: unknown) {\n178\t    const msg = err instanceof Error ? err.message : String(err);\n179\t    throw new AgentResolveError(\n180\t      `Invalid YAML in patch file: ${msg}`,\n181\t      filePath,\n182\t      [{ path: filePath, message: msg }],\n183\t    );\n184\t  }\n185\t\n186\t  if (parsed === null || typeof parsed !== 'object') {\n187\t    throw new AgentResolveError(\n188\t      `Patch file is not a valid object`,\n189\t      filePath,\n190\t      [{ path: filePath, message: 'Patch must be a YAML object' }],\n191\t    );\n192\t  }\n193\t\n194\t  return parsed as AgentPatch;\n195\t}\n196\t\n197\t// --- Patch Merging ---\n198\t\n199\t/**\n200\t * Merge a patch onto a base config. Deep-merges overrides, preserves prompt_patches separately.\n201\t */\n202\texport function mergePatch(\n203\t  base: Record<string, unknown>,\n204\t  patch: AgentPatch,\n205\t): Record<string, unknown> {\n206\t  let result = { ...base };\n207\t\n208\t  if (patch.overrides) {\n209\t    result = deepMerge(result, patch.overrides);\n210\t  }\n211\t\n212\t  if (patch.prompt_patches) {\n213\t    const existing = result.prompt_patches as { append?: string } | undefined;\n214\t    const existingAppend = existing?.append ?? '';\n215\t    const newAppend = patch.prompt_patches.append ?? '';\n216\t\n217\t    if (newAppend) {\n218\t      result.prompt_patches = {\n219\t        append: existingAppend ? `${existingAppend}\\n${newAppend}` : newAppend,\n220\t      };\n221\t    }\n222\t  }\n223\t\n224\t  return result;\n225\t}\n226\t\n227\t// --- Main Resolution ---\n228\t\n229\t/**\n230\t * Resolve an agent through the embedded -> user -> project patch chain.\n231\t * For custom agents (no embedded match, found at project/user level without extends), loads directly.\n232\t */\n233\texport function resolveAgent(name: string, options?: { cwd?: string }): ResolvedAgent {\n234\t  const cwd = options?.cwd ?? process.cwd();\n235\t  const userPatchPath = join(os.homedir(), '.codeharness', 'agents', `${name}.patch.yaml`);\n236\t  const projectPatchPath = join(cwd, '.codeharness', 'agents', `${name}.patch.yaml`);\n237\t\n238\t  // Check for custom agent (project-level full config, no extends)\n239\t  const projectCustomPath = join(cwd, '.codeharness', 'agents', `${name}.yaml`);\n240\t  const userCustomPath = join(os.homedir(), '.codeharness', 'agents', `${name}.yaml`);\n241\t\n242\t  // Try custom agent at project level first, then user level\n243\t  for (const customPath of [projectCustomPath, userCustomPath]) {\n244\t    if (existsSync(customPath)) {\n245\t      const patch = loadPatch(customPath);\n246\t      if (patch && !patch.extends) {\n247\t        // This is a full custom agent, not a patch ŌĆö load and validate directly\n248\t        const parsed = patch as unknown as Record<string, unknown>;\n249\t        const result = validateAgentSchema(parsed);\n250\t        if (!result.valid) {\n251\t          const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n252\t          throw new AgentResolveError(\n253\t            `Schema validation failed for custom agent ${name}: ${details}`,\n254\t            customPath,\n255\t            result.errors.map((e) => ({ path: e.path, message: e.message })),\n256\t          );\n257\t        }\n258\t        return parsed as ResolvedAgent;\n259\t      }\n260\t    }\n261\t  }\n262\t\n263\t  // Load embedded base\n264\t  const base = loadEmbeddedAgent(name);\n265\t  let merged: Record<string, unknown> = base as unknown as Record<string, unknown>;\n266\t\n267\t  // Apply user patch\n268\t  const userPatch = loadPatch(userPatchPath);\n269\t  if (userPatch) {\n270\t    merged = mergePatch(merged, userPatch);\n271\t  }\n272\t\n273\t  // Apply project patch\n274\t  const projectPatch = loadPatch(projectPatchPath);\n275\t  if (projectPatch) {\n276\t    merged = mergePatch(merged, projectPatch);\n277\t  }\n278\t\n279\t  // Validate merged result (strip prompt_patches for schema validation since it's not in schema)\n280\t  const { prompt_patches, ...forValidation } = merged as Record<string, unknown> & { prompt_patches?: unknown };\n281\t  const result = validateAgentSchema(forValidation);\n282\t  if (!result.valid) {\n283\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n284\t    const errorPath = projectPatch ? projectPatchPath : userPatch ? userPatchPath : 'merged';\n285\t    throw new AgentResolveError(\n286\t      `Schema validation failed after merging patches for ${name}: ${details}`,\n287\t      errorPath,\n288\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n289\t    );\n290\t  }\n291\t\n292\t  // Re-attach prompt_patches if present\n293\t  if (prompt_patches) {\n294\t    (forValidation as Record<string, unknown>).prompt_patches = prompt_patches;\n295\t  }\n296\t\n297\t  return (prompt_patches ? { ...forValidation, prompt_patches } : forValidation) as ResolvedAgent;\n298\t}\n299\t\n300\t// --- Subagent Compilation ---\n301\t\n302\t/**\n303\t * Compile a ResolvedAgent into a SubagentDefinition for Agent SDK dispatch.\n304\t */\n305\texport function compileSubagentDefinition(agent: ResolvedAgent): SubagentDefinition {\n306\t  const parts: string[] = [];\n307\t\n308\t  parts.push(`You are ${agent.persona.identity}`);\n309\t  parts.push(`Communication style: ${agent.persona.communication_style}`);\n310\t\n311\t  if (agent.persona.principles.length > 0) {\n312\t    const bullets = agent.persona.principles.map((p) => `- ${p}`).join('\\n');\n313\t    parts.push(`Principles:\\n${bullets}`);\n314\t  }\n315\t\n316\t  if (agent.prompt_patches?.append) {\n317\t    parts.push(agent.prompt_patches.append);\n318\t  }\n319\t\n320\t  return {\n321\t    name: agent.name,\n322\t    model: DEFAULT_MODEL,\n323\t    instructions: parts.join('\\n\\n'),\n324\t    disallowedTools: agent.disallowedTools ?? [],\n325\t    bare: true,\n326\t  };\n327\t}\n328\t"}]},"parent_tool_use_id":"toolu_01RPJXyu9D3EThP26t2M9i1U","session_id":"605a3302-c654-40ea-969b-1ce171500852","uuid":"4339d2b5-e519-47ac-b36a-a709c8191b1d","timestamp":"2026-04-02T19:08:49.095Z"}
