{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HP8SzwndkYvJGd1HYnbPA4","type":"tool_result","content":"848\t\n849\t  const result = await Promise.race([healthChecks, timeoutPromise]);\n850\t\n851\t  if (result === 'timeout') {\n852\t    // Report only the drivers that did NOT respond (AC #6)\n853\t    const pending = [...driverNames].filter((n) => !responded.has(n));\n854\t    const names = pending.length > 0 ? pending.join(', ') : [...driverNames].join(', ');\n855\t    throw new Error(\n856\t      `Driver health check timed out after ${effectiveTimeout}ms. Drivers that did not respond: ${names}`,\n857\t    );\n858\t  }\n859\t\n860\t  // Health checks completed before timeout — clear the timer\n861\t  clearTimeout(timer!);\n862\t\n863\t  // 5. Check for failures\n864\t  const failures = result.filter((r) => !r.health.available);\n865\t  if (failures.length > 0) {\n866\t    const details = failures\n867\t      .map((f) => `${f.name}: ${f.health.error ?? 'unavailable'}`)\n868\t      .join('; ');\n869\t    throw new Error(`Driver health check failed: ${details}`);\n870\t  }\n871\t}\n872\t\n873\t// --- Main Execution ---\n874\t\n875\t/**\n876\t * Execute a workflow sequentially: iterate through flow steps, dispatch tasks\n877\t * per-story or per-run, checkpoint state after each dispatch.\n878\t *\n879\t * Loop blocks execute iteratively until pass, max-iterations, or circuit-breaker.\n880\t *\n881\t * Returns an EngineResult summarizing the execution.\n882\t */\n883\texport async function executeWorkflow(config: EngineConfig): Promise<EngineResult> {\n884\t  const startMs = Date.now();\n885\t  const projectDir = config.projectDir ?? process.cwd();\n886\t  const errors: EngineError[] = [];\n887\t  let tasksCompleted = 0;\n888\t  const processedStories = new Set<string>();\n889\t\n890\t  // 1. Read or initialize workflow state\n891\t  let state = readWorkflowState(projectDir);\n892\t\n893\t  // Early exit: workflow already completed (AC #6)\n894\t  if (state.phase === 'completed') {\n895\t    return {\n896\t      success: true,\n897\t      tasksCompleted: 0,\n898\t      storiesProcessed: 0,\n899\t      errors: [],\n900\t      durationMs: 0,\n901\t    };\n902\t  }\n903\t\n904\t  state = {\n905\t    ...state,\n906\t    phase: 'executing',\n907\t    started: state.started || new Date().toISOString(),\n908\t    workflow_name: config.workflow.flow.filter((s) => typeof s === 'string').join(' -> '),\n909\t  };\n910\t  writeWorkflowState(state, projectDir);\n911\t\n912\t  // 1b. Pre-flight driver health check\n913\t  try {\n914\t    await checkDriverHealth(config.workflow);\n915\t  } catch (err: unknown) { // IGNORE: health check failure — record and abort\n916\t    const message = err instanceof Error ? err.message : String(err);\n917\t    state = { ...state, phase: 'failed' };\n918\t    const engineError: EngineError = {\n919\t      taskName: '__health_check__',\n920\t      storyKey: '__health_check__',\n921\t      code: 'HEALTH_CHECK',\n922\t      message,\n923\t    };\n924\t    errors.push(engineError);\n925\t    writeWorkflowState(state, projectDir);\n926\t    return {\n927\t      success: false,\n928\t      tasksCompleted: 0,\n929\t      storiesProcessed: 0,\n930\t      errors,\n931\t      durationMs: Date.now() - startMs,\n932\t    };\n933\t  }\n934\t\n935\t  // 2. Load work items\n936\t  const workItems = loadWorkItems(config.sprintStatusPath, config.issuesPath);\n937\t\n938\t  // 3. Iterate through flow steps\n939\t  let halted = false;\n940\t  let lastOutputContract: OutputContract | null = null;\n941\t  for (const step of config.workflow.flow) {\n942\t    if (halted) break;\n943\t\n944\t    // Execute loop blocks\n945\t    if (isLoopBlock(step)) {\n946\t      const loopResult = await executeLoopBlock(step, state, config, workItems, lastOutputContract);\n947\t      state = loopResult.state;\n948\t      errors.push(...loopResult.errors);\n949\t      tasksCompleted += loopResult.tasksCompleted;\n950\t      lastOutputContract = loopResult.lastContract;\n951\t\n952\t      // Track processed stories from loop\n953\t      for (const item of workItems) {\n954\t        processedStories.add(item.key);\n955\t      }\n956\t\n957\t      if (loopResult.halted) {\n958\t        halted = true;\n959\t      }\n960\t\n961\t      // If loop ended with max-iterations or circuit-breaker, treat as failure\n962\t      if (state.phase === 'max-iterations' || state.phase === 'circuit-breaker') {\n963\t        halted = true;\n964\t      }\n965\t      continue;\n966\t    }\n967\t\n968\t    // step is a string task name\n969\t    const taskName = step;\n970\t    const task = config.workflow.tasks[taskName];\n971\t\n972\t    if (!task) {\n973\t      warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n974\t      continue;\n975\t    }\n976\t\n977\t    // Look up the agent definition\n978\t    const definition = config.agents[task.agent];\n979\t    if (!definition) {\n980\t      warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n981\t      continue;\n982\t    }\n983\t\n984\t    if (task.scope === 'per-run') {\n985\t      // Skip if already completed (crash recovery — AC #3)\n986\t      if (isTaskCompleted(state, taskName, PER_RUN_SENTINEL)) {\n987\t        warn(`workflow-engine: skipping completed task ${taskName} for ${PER_RUN_SENTINEL}`);\n988\t        continue;\n989\t      }\n990\t\n991\t      // Per-run: dispatch once with sentinel key\n992\t      try {\n993\t        const dispatchResult = await dispatchTaskWithResult(\n994\t          task, taskName, PER_RUN_SENTINEL, definition, state, config, undefined, lastOutputContract ?? undefined,\n995\t        );\n996\t        state = dispatchResult.updatedState;\n997\t        lastOutputContract = dispatchResult.contract;\n998\t        tasksCompleted++;\n999\t      } catch (err: unknown) {\n1000\t        const engineError = handleDispatchError(err, taskName, PER_RUN_SENTIN