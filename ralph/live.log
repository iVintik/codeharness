{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RXD2vWhj7DrFBJycY8bsu5","type":"tool_result","content":"     1→/**\n     2→ * Sprint module — story selection, status tracking, reporting.\n     3→ */\n     4→\n     5→import { ok, fail } from '../../types/result.js';\n     6→import type { Result } from '../../types/result.js';\n     7→import type { StoryStatus } from '../../types/state.js';\n     8→import type { SprintState } from '../../types/state.js';\n     9→import type {\n    10→  StorySelection,\n    11→  StoryDetail,\n    12→  StatusReport,\n    13→  SelectionResult,\n    14→  FailedStoryDetail,\n    15→  LabeledActionItem,\n    16→  RunSummary,\n    17→  StoryDrillDown,\n    18→  TimeoutReport,\n    19→  TimeoutCapture,\n    20→  FeedbackResult,\n    21→  FailingAc,\n    22→  TimeoutSummary,\n    23→  RunProgressUpdate,\n    24→} from './types.js';\n    25→import {\n    26→  getSprintState as getSprintStateImpl,\n    27→  updateStoryStatus as updateStoryStatusImpl,\n    28→  writeStateAtomic as writeStateAtomicImpl,\n    29→  computeSprintCounts as computeSprintCountsImpl,\n    30→  updateRunProgress as updateRunProgressImpl,\n    31→  clearRunProgress as clearRunProgressImpl,\n    32→  generateSprintStatusYaml as generateSprintStatusYamlImpl,\n    33→  getStoryStatusesFromState as getStoryStatusesFromStateImpl,\n    34→  reconcileState as reconcileStateImpl,\n    35→} from './state.js';\n    36→import type { ReconciliationResult } from './state.js';\n    37→import { selectNextStory } from './selector.js';\n    38→import { generateReport as generateReportImpl, getStoryDrillDown as getStoryDrillDownImpl } from './reporter.js';\n    39→import { captureTimeoutReport as captureTimeoutReportImpl, findLatestTimeoutReport as findLatestTimeoutReportImpl } from './timeout.js';\n    40→import { processVerifyResult as processVerifyResultImpl } from './feedback.js';\n    41→import { validateStateConsistency as validateStateConsistencyImpl } from './validator.js';\n    42→import type { ValidationReport, ValidationIssue } from './validator.js';\n    43→\n    44→export type {\n    45→  StorySelection,\n    46→  StoryDetail,\n    47→  StatusReport,\n    48→  SelectionResult,\n    49→  FailedStoryDetail,\n    50→  LabeledActionItem,\n    51→  RunSummary,\n    52→  StoryDrillDown,\n    53→  TimeoutReport,\n    54→  TimeoutCapture,\n    55→  TimeoutSummary,\n    56→  FeedbackResult,\n    57→  FailingAc,\n    58→  RunProgressUpdate,\n    59→};\n    60→\n    61→export type { ValidationReport, ValidationIssue };\n    62→export type { ReconciliationResult };\n    63→\n    64→/**\n    65→ * Select the next actionable story.\n    66→ * Also marks retry-exhausted stories as blocked (AC #2).\n    67→ */\n    68→export function getNextStory(): Result<SelectionResult> {\n    69→  const stateResult = getSprintStateImpl();\n    70→  if (!stateResult.success) {\n    71→    return fail(stateResult.error);\n    72→  }\n    73→\n    74→  const selectionResult = selectNextStory(stateResult.data);\n    75→  if (!selectionResult.success) {\n    76→    return fail(selectionResult.error);\n    77→  }\n    78→\n    79→  // Side-effect: mark retry-exhausted stories as blocked (AC #2)\n    80→  for (const exhausted of selectionResult.data.retryExhausted) {\n    81→    updateStoryStatusImpl(exhausted.key, 'blocked', {\n    82→      error: 'retry-exhausted',\n    83→    });\n    84→  }\n    85→\n    86→  return ok(selectionResult.data);\n    87→}\n    88→\n    89→export function updateStoryStatus(\n    90→  key: string,\n    91→  status: StoryStatus,\n    92→  detail?: StoryDetail,\n    93→): Result<void> {\n    94→  return updateStoryStatusImpl(key, status, detail);\n    95→}\n    96→\n    97→export function getSprintState(): Result<SprintState> {\n    98→  return getSprintStateImpl();\n    99→}\n   100→\n   101→export function generateReport(): Result<StatusReport> {\n   102→  const stateResult = getSprintStateImpl();\n   103→  if (!stateResult.success) {\n   104→    return fail(stateResult.error);\n   105→  }\n   106→  return generateReportImpl(stateResult.data);\n   107→}\n   108→\n   109→export function getStoryDrillDown(key: string): Result<StoryDrillDown> {\n   110→  const stateResult = getSprintStateImpl();\n   111→  if (!stateResult.success) {\n   112→    return fail(stateResult.error);\n   113→  }\n   114→\n   115→  // Look up latest timeout report for this story\n   116→  const timeoutResult = findLatestTimeoutReportImpl(key);\n   117→  const timeoutSummary = timeoutResult.success ? timeoutResult.data : null;\n   118→\n   119→  return getStoryDrillDownImpl(stateResult.data, key, { timeoutSummary });\n   120→}\n   121→\n   122→export function captureTimeoutReport(opts: {\n   123→  storyKey: string;\n   124→  iteration: number;\n   125→  durationMinutes: number;\n   126→  outputFile: string;\n   127→  stateSnapshotPath: string;\n   128→}): Result<TimeoutReport> {\n   129→  return captureTimeoutReportImpl(opts);\n   130→}\n   131→\n   132→export function processVerifyResult(\n   133→  storyKey: string,\n   134→  opts?: { maxAttempts?: number },\n   135→): Result<FeedbackResult> {\n   136→  return processVerifyResultImpl(storyKey, opts);\n   137→}\n   138→\n   139→export function validateStateConsistency(\n   140→  statePath: string,\n   141→  sprintStatusPath: string,\n   142→): Result<ValidationReport> {\n   143→  return validateStateConsistencyImpl(statePath, sprintStatusPath);\n   144→}\n   145→\n   146→export function writeStateAtomic(state: SprintState): Result<void> {\n   147→  return writeStateAtomicImpl(state);\n   148→}\n   149→\n   150→export function computeSprintCounts(\n   151→  stories: Record<string, import('../../types/state.js').StoryState>,\n   152→): SprintState['sprint'] {\n   153→  return computeSprintCountsImpl(stories);\n   154→}\n   155→\n   156→export function updateRunProgress(update: RunProgressUpdate): Result<void> {\n   157→  return updateRunProgressImpl(update);\n   158→}\n   159→\n   160→export function clearRunProgress(): Result<void> {\n   161→  return clearRunProgressImpl();\n   162→}\n   163→\n   164→export function generateSprintStatusYaml(state: SprintState): string {\n   165→  return generateSprintStatusYamlImpl(state);\n   166→}\n   167→\n   168→export function getStoryStatusesFromState(state: SprintState): Record<string, string> {\n   169→  return getStoryStatusesFromStateImpl(state);\n   170→}\n   171→\n   172→/**\n   173→ * Reconcile sprint state on session start.\n   174→ * Merges orphaned files, validates epic consistency, regenerates YAML.\n   175→ */\n   176→export function reconcileState(): Result<ReconciliationResult> {\n   177→  return reconcileStateImpl();\n   178→}\n   179→\n   180→/**\n   181→ * Read sprint state and derive story statuses as a flat map.\n   182→ * Drop-in replacement for the old readSprintStatus() that parsed YAML.\n   183→ */\n   184→export function readSprintStatusFromState(): Record<string, string> {\n   185→  const stateResult = getSprintStateImpl();\n   186→  if (!stateResult.success) return {};\n   187→  return getStoryStatusesFromStateImpl(stateResult.data);\n   188→}\n   189→"}]},"parent_tool_use_id":"toolu_0184tJvxCPux1RS3fH2NtyBW","session_id":"01503c00-15e6-46f1-b837-b4628ff69656","uuid":"e07ea856-562d-45f0-9bff-4ab997707b1b","timestamp":"2026-03-24T11:46:26.038Z"}
