{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LBDMnCCJMxqe267yL66gHP","type":"tool_result","content":"     1→/**\n     2→ * Builder factories for SprintState and related test data.\n     3→ *\n     4→ * Produces valid SprintStateV2 objects with sensible defaults.\n     5→ * Use `buildSprintState(overrides)` for top-level state and\n     6→ * `buildStoryEntry(overrides)` for individual story entries.\n     7→ */\n     8→\n     9→import type {\n    10→  SprintState,\n    11→  StoryState,\n    12→  EpicState,\n    13→  SessionState,\n    14→  ObservabilityState,\n    15→  ActionItem,\n    16→} from '../../../types/state.js';\n    17→\n    18→/** Default story state with \"backlog\" status and zero attempts */\n    19→const DEFAULT_STORY_STATE: StoryState = {\n    20→  status: 'backlog',\n    21→  attempts: 0,\n    22→  lastAttempt: null,\n    23→  lastError: null,\n    24→  proofPath: null,\n    25→  acResults: null,\n    26→};\n    27→\n    28→/** Default session state — inactive */\n    29→const DEFAULT_SESSION_STATE: SessionState = {\n    30→  active: false,\n    31→  startedAt: null,\n    32→  iteration: 0,\n    33→  elapsedSeconds: 0,\n    34→};\n    35→\n    36→/** Default observability state — no coverage data */\n    37→const DEFAULT_OBSERVABILITY_STATE: ObservabilityState = {\n    38→  statementCoverage: null,\n    39→  branchCoverage: null,\n    40→  functionCoverage: null,\n    41→  lineCoverage: null,\n    42→};\n    43→\n    44→/** Default run state — inactive */\n    45→const DEFAULT_RUN_STATE: SprintState['run'] = {\n    46→  active: false,\n    47→  startedAt: null,\n    48→  iteration: 0,\n    49→  cost: 0,\n    50→  completed: [],\n    51→  failed: [],\n    52→  currentStory: null,\n    53→  currentPhase: null,\n    54→  lastAction: null,\n    55→  acProgress: null,\n    56→};\n    57→\n    58→/**\n    59→ * Build a valid SprintStateV2 object with sensible defaults.\n    60→ * Pass partial overrides to customize specific fields.\n    61→ */\n    62→export function buildSprintState(overrides?: Partial<SprintState>): SprintState {\n    63→  return {\n    64→    version: 2,\n    65→    sprint: {\n    66→      total: 0,\n    67→      done: 0,\n    68→      failed: 0,\n    69→      blocked: 0,\n    70→      inProgress: null,\n    71→      ...overrides?.sprint,\n    72→    },\n    73→    stories: overrides?.stories ?? {},\n    74→    retries: overrides?.retries ?? {},\n    75→    flagged: overrides?.flagged ?? [],\n    76→    epics: overrides?.epics ?? {},\n    77→    session: { ...DEFAULT_SESSION_STATE, ...overrides?.session },\n    78→    observability: { ...DEFAULT_OBSERVABILITY_STATE, ...overrides?.observability },\n    79→    run: { ...DEFAULT_RUN_STATE, ...overrides?.run },\n    80→    actionItems: overrides?.actionItems ?? [],\n    81→  };\n    82→}\n    83→\n    84→/**\n    85→ * Build a valid StoryState object with sensible defaults.\n    86→ * Pass partial overrides to customize specific fields.\n    87→ */\n    88→export function buildStoryEntry(overrides?: Partial<StoryState>): StoryState {\n    89→  return {\n    90→    ...DEFAULT_STORY_STATE,\n    91→    ...overrides,\n    92→  };\n    93→}\n    94→\n    95→/**\n    96→ * Build a valid EpicState object with sensible defaults.\n    97→ */\n    98→export function buildEpicState(overrides?: Partial<EpicState>): EpicState {\n    99→  return {\n   100→    status: 'in-progress',\n   101→    storiesTotal: 0,\n   102→    storiesDone: 0,\n   103→    ...overrides,\n   104→  };\n   105→}\n   106→\n   107→/**\n   108→ * Build a valid ActionItem object.\n   109→ */\n   110→export function buildActionItem(overrides?: Partial<ActionItem>): ActionItem {\n   111→  return {\n   112→    id: 'ai-1',\n   113→    story: '1-1-test',\n   114→    description: 'Test action item',\n   115→    source: 'manual',\n   116→    resolved: false,\n   117→    ...overrides,\n   118→  };\n   119→}\n   120→\n   121→/**\n   122→ * Build a SprintState with a single story pre-populated.\n   123→ * Convenience wrapper for the common test pattern.\n   124→ */\n   125→export function buildSprintStateWithStory(\n   126→  storyKey: string,\n   127→  storyOverrides?: Partial<StoryState>,\n   128→  stateOverrides?: Partial<SprintState>,\n   129→): SprintState {\n   130→  return buildSprintState({\n   131→    ...stateOverrides,\n   132→    sprint: { total: 1, done: 0, failed: 0, blocked: 0, inProgress: null, ...stateOverrides?.sprint },\n   133→    stories: {\n   134→      [storyKey]: buildStoryEntry(storyOverrides),\n   135→      ...stateOverrides?.stories,\n   136→    },\n   137→  });\n   138→}\n   139→"}]},"parent_tool_use_id":"toolu_014CxpRCwC7G8ESMTZo9TkWy","session_id":"e0c38769-c734-43c9-928b-954c93aa963e","uuid":"ac8ed78a-337e-42da-8aa6-75b195cbddd6","timestamp":"2026-03-24T22:09:29.058Z"}
