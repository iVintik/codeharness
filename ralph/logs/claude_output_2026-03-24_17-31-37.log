{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GmZLGz7pDPHwvdSD8ajsEk","type":"tool_result","content":"     1→/**\n     2→ * Status drill-down — presentation layer for story detail view.\n     3→ * Handles formatting of story drill-down data for both human-readable and JSON output.\n     4→ */\n     5→\n     6→import { fail, jsonOutput } from '../../lib/output.js';\n     7→import { getStoryDrillDown } from '../sprint/index.js';\n     8→import type { StoryDrillDown } from '../sprint/index.js';\n     9→\n    10→/**\n    11→ * Handle the --story <key> drill-down sub-command.\n    12→ * Fetches drill-down data from sprint module and formats output.\n    13→ */\n    14→export function handleStoryDrillDown(storyId: string, isJson: boolean): void {\n    15→  const result = getStoryDrillDown(storyId);\n    16→  if (!result.success) {\n    17→    if (isJson) {\n    18→      jsonOutput({ status: 'fail', message: result.error });\n    19→    } else {\n    20→      fail(result.error);\n    21→    }\n    22→    process.exitCode = 1;\n    23→    return;\n    24→  }\n    25→\n    26→  const d = result.data;\n    27→\n    28→  if (isJson) {\n    29→    formatDrillDownJson(d);\n    30→    return;\n    31→  }\n    32→\n    33→  formatDrillDownHuman(d);\n    34→}\n    35→\n    36→function formatDrillDownJson(d: StoryDrillDown): void {\n    37→  jsonOutput({\n    38→    key: d.key,\n    39→    status: d.status,\n    40→    epic: d.epic,\n    41→    attempts: d.attempts,\n    42→    maxAttempts: d.maxAttempts,\n    43→    lastAttempt: d.lastAttempt,\n    44→    acResults: d.acDetails,\n    45→    attemptHistory: d.attemptHistory,\n    46→    proof: d.proofSummary,\n    47→    ...(d.timeoutSummary ? { timeout: d.timeoutSummary } : {}),\n    48→  });\n    49→}\n    50→\n    51→function formatDrillDownHuman(d: StoryDrillDown): void {\n    52→  // Header\n    53→  console.log(`Story: ${d.key}`);\n    54→  console.log(`Status: ${d.status} (attempt ${d.attempts}/${d.maxAttempts})`);\n    55→  console.log(`Epic: ${d.epic}`);\n    56→  console.log(`Last attempt: ${d.lastAttempt ?? 'none'}`);\n    57→\n    58→  // Timeout summary\n    59→  if (d.timeoutSummary) {\n    60→    const ts = d.timeoutSummary;\n    61→    console.log(`Last timeout: iteration ${ts.iteration}, ${ts.durationMinutes}m, ${ts.filesChanged} files changed`);\n    62→    console.log(`Report: ${ts.reportPath}`);\n    63→  }\n    64→\n    65→  // AC Results\n    66→  console.log('');\n    67→  console.log('-- AC Results -------------------------------------------------------');\n    68→\n    69→  if (d.acDetails.length === 0) {\n    70→    console.log('No AC results recorded');\n    71→  } else {\n    72→    for (const ac of d.acDetails) {\n    73→      const tag = ac.verdict.toUpperCase();\n    74→      console.log(`${ac.id}: [${tag}]`);\n    75→      if (ac.verdict === 'fail') {\n    76→        if (ac.command) console.log(`  Command:  ${ac.command}`);\n    77→        if (ac.expected) console.log(`  Expected: ${ac.expected}`);\n    78→        if (ac.actual) console.log(`  Actual:   ${ac.actual}`);\n    79→        if (ac.reason) console.log(`  Reason:   ${ac.reason}`);\n    80→        if (ac.suggestedFix) console.log(`  Suggest:  ${ac.suggestedFix}`);\n    81→      }\n    82→    }\n    83→  }\n    84→\n    85→  // History\n    86→  if (d.attemptHistory.length > 0) {\n    87→    console.log('');\n    88→    console.log('-- History ----------------------------------------------------------');\n    89→    for (const attempt of d.attemptHistory) {\n    90→      const acPart = attempt.failingAc ? ` (${attempt.failingAc})` : '';\n    91→      console.log(`Attempt ${attempt.number}: ${attempt.outcome}${acPart}`);\n    92→    }\n    93→  }\n    94→\n    95→  // Proof\n    96→  if (d.proofSummary) {\n    97→    console.log('');\n    98→    const p = d.proofSummary;\n    99→    const total = p.passCount + p.failCount + p.escalateCount + p.pendingCount;\n   100→    console.log(\n   101→      `Proof: ${p.path} (${p.passCount}/${total} pass, ${p.failCount} fail, ${p.escalateCount} escalate)`,\n   102→    );\n   103→  }\n   104→}\n   105→"}]},"parent_tool_use_id":"toolu_01LpBFDE1KxDokaruyokqTrj","session_id":"a74f233b-d75f-4731-af98-d5f8de661326","uuid":"54aaf724-88f7-48de-86dc-0da346131a53","timestamp":"2026-03-24T13:49:08.458Z"}
