→    });\n   471→\n   472→    it('--max-story-retries defaults to 3', async () => {\n   473→      const { registerRunCommand } = await import('../run.js');\n   474→      const program = new Command();\n   475→      program.option('--json', 'JSON output');\n   476→      registerRunCommand(program);\n   477→\n   478→      const runCmd = program.commands.find(c => c.name() === 'run');\n   479→      const retryOpt = runCmd!.options.find(o => o.long === '--max-story-retries');\n   480→      expect(retryOpt!.defaultValue).toBe('10');\n   481→    });\n   482→  });\n   483→\n   484→  describe('Ink renderer integration (AC #1, #2, #3)', () => {\n   485→    it('starts Ink renderer before spawning ralph', async () => {\n   486→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   487→      mockPaths({ 'ralph.sh': true, '.claude': true, '.flagged_stories': false });\n   488→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   489→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   490→\n   491→      const p = runCommand();\n   492→      await vi.waitFor(() => expect(spawnMock).toHaveBeenCalled());\n   493→      getChildOnHandlers()['close'](0);\n   494→      await p;\n   495→\n   496→      // startRenderer should have been called before spawn\n   497→      expect(startRendererMock).toHaveBeenCalledTimes(1);\n   498→      expect(startRendererMock).toHaveBeenCalledWith({ quiet: false });\n   499→    });\n   500→\n   501→    it('pipes stdout NDJSON lines through parseStreamLine to renderer.update', async () => {\n   502→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   503→      mockPaths({ 'ralph.sh': true, '.claude': true, '.flagged_stories': false });\n   504→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   505→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   506→\n   507→      const toolStartEvent = { type: 'tool-start', name: 'Read', id: 'abc' };\n   508→      parseStreamLineMock.mockReturnValueOnce(toolStartEvent);\n   509→\n   510→      const p = runCommand();\n   511→      await vi.waitFor(() => expect(spawnMock).toHaveBeenCalled());\n   512→\n   513→      // Emit NDJSON on stdout\n   514→      const stdout = getStdoutEmitter();\n   515→      stdout!.emit('data', Buffer.from('{\"type\":\"stream_event\",\"event\":{\"type\":\"content_block_start\"}}\\n'));\n   516→\n   517→      getChildOnHandlers()['close'](0);\n   518→      await p;\n   519→\n   520→      expect(parseStreamLineMock).toHaveBeenCalled();\n   521→      expect(rendererUpdateMock).toHaveBeenCalledWith(toolStartEvent);\n   522→    });\n   523→\n   524→    it('pipes stderr lines through parseStreamLine to renderer.update', async () => {\n   525→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   526→      mockPaths({ 'ralph.sh': true, '.claude': true, '.flagged_stories': false });\n   527→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   528→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   529→\n   530→      const textEvent = { type: 'text', text: 'thinking...' };\n   531→      parseStreamLineMock.mockReturnValueOnce(textEvent);\n   532→\n   533→      const p = runCommand();\n   534→      await vi.waitFor(() => expect(spawnMock).toHaveBeenCalled());\n   535→\n   536→      const stderr = getStderrEmitter();\n   537→      stderr!.emit('data', Buffer.from('{\"type\":\"stream_event\",\"event\":{\"type\":\"content_block_delta\"}}\\n'));\n   538→\n   539→      getChildOnHandlers()['close'](0);\n   540→      await p;\n   541→\n   542→      expect(rendererUpdateMock).toHaveBeenCalledWith(textEvent);\n   543→    });\n   544→\n   545→    it('skips null events from parseStreamLine (unrecognized lines)', async () => {\n   546→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   547→      mockPaths({ 'ralph.sh': true, '.claude': true, '.flagged_stories': false });\n   548→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog