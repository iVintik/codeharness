{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MXB4QWx1cLbHPrLF6SfhsP","type":"tool_result","content":"     1→/**\n     2→ * Dockerfile template generator — creates stack-appropriate Dockerfiles for user projects.\n     3→ * Returns Result<DockerfileTemplateResult> following the project's Result<T> pattern.\n     4→ *\n     5→ * FR22 (Dockerfile template based on project type).\n     6→ * Supports single-stack and multi-stage (multi-stack) Dockerfile generation.\n     7→ */\n     8→\n     9→import { existsSync, writeFileSync } from 'node:fs';\n    10→import { join } from 'node:path';\n    11→import { ok, fail } from '../../types/result.js';\n    12→import type { Result } from '../../types/result.js';\n    13→import type { StackDetection } from '../../lib/stacks/index.js';\n    14→import { getStackProvider } from '../../lib/stacks/index.js';\n    15→import type { StackName } from '../../lib/stacks/index.js';\n    16→\n    17→/** Result returned by generateDockerfileTemplate */\n    18→export interface DockerfileTemplateResult {\n    19→  readonly path: string;\n    20→  readonly stack: string;\n    21→  readonly stacks: string[];\n    22→}\n    23→\n    24→// ─── Template content generators ────────────────────────────────────────────\n    25→\n    26→function nodejsTemplate(): string {\n    27→  return `# Base image — pinned version for reproducibility\n    28→FROM node:22-slim\n    29→\n    30→ARG TARBALL=package.tgz\n    31→\n    32→# System utilities for verification\n    33→RUN apt-get update && apt-get install -y --no-install-recommends curl jq && rm -rf /var/lib/apt/lists/*\n    34→\n    35→# Install project from tarball (black-box: no source code)\n    36→COPY \\${TARBALL} /tmp/\\${TARBALL}\n    37→RUN npm install -g /tmp/\\${TARBALL} && rm /tmp/\\${TARBALL}\n    38→\n    39→# Run as non-root user\n    40→USER node\n    41→\n    42→WORKDIR /workspace\n    43→`;\n    44→}\n    45→\n    46→function pythonTemplate(): string {\n    47→  return `# Base image — pinned version for reproducibility\n    48→FROM python:3.12-slim\n    49→\n    50→# System utilities for verification\n    51→RUN apt-get update && apt-get install -y --no-install-recommends curl jq && rm -rf /var/lib/apt/lists/*\n    52→\n    53→# Install project from wheel or sdist\n    54→COPY dist/ /tmp/dist/\n    55→RUN pip install /tmp/dist/*.whl && rm -rf /tmp/dist/ && pip cache purge\n    56→\n    57→# Run as non-root user\n    58→USER nobody\n    59→\n    60→WORKDIR /workspace\n    61→`;\n    62→}\n    63→\n    64→function rustTemplate(): string {\n    65→  return `# === Builder stage ===\n    66→FROM rust:1.82-slim AS builder\n    67→\n    68→WORKDIR /build\n    69→\n    70→# Copy project files\n    71→COPY . .\n    72→\n    73→# Build release binary\n    74→RUN cargo build --release\n    75→\n    76→# === Runtime stage ===\n    77→FROM debian:bookworm-slim\n    78→\n    79→# System utilities for verification\n    80→RUN apt-get update && apt-get install -y --no-install-recommends curl jq && rm -rf /var/lib/apt/lists/*\n    81→\n    82→# Install compiled binary from builder (update 'myapp' to your binary name)\n    83→COPY --from=builder /build/target/release/myapp /usr/local/bin/myapp\n    84→\n    85→# Run as non-root user\n    86→USER nobody\n    87→\n    88→WORKDIR /workspace\n    89→`;\n    90→}\n    91→\n    92→function genericTemplate(): string {\n    93→  return `# Base image — pinned version for reproducibility\n    94→FROM node:22-slim\n    95→\n    96→# System utilities for verification\n    97→RUN apt-get update && apt-get install -y --no-install-recommends bash curl jq git && rm -rf /var/lib/apt/lists/*\n    98→\n    99→# Install project binary (update this for your project)\n   100→RUN npm install -g placeholder && npm cache clean --force\n   101→\n   102→# Run as non-root user\n   103→USER node\n   104→\n   105→WORKDIR /workspace\n   106→`;\n   107→}\n   108→\n   109→// ─── Multi-stage build-stage content extractors ─────────────────────────────\n   110→\n   111→/** Build-stage content for nodejs in a multi-stage Dockerfile */\n   112→function nodejsBuildStage(): string {\n   113→  return `# === Build stage: nodejs ===\n   114→FROM node:22-slim AS build-nodejs\n   115→WORKDIR /build\n   116→COPY package*.json ./\n   117→RUN npm ci --production\n   118→COPY . .\n   119→`;\n   120→}\n   121→\n   122→/** Build-stage content for python in a multi-stage Dockerfile */\n   123→function pythonBuildStage(): string {\n   124→  return `# === Build stage: python ===\n   125→FROM python:3.12-slim AS build-python\n   126→WORKDIR /build\n   127→COPY . .\n   128→RUN pip install --target=/build/dist .\n   129→`;\n   130→}\n   131→\n   132→/** Build-stage content for rust in a multi-stage Dockerfile */\n   133→function rustBuildStage(): string {\n   134→  return `# === Build stage: rust ===\n   135→FROM rust:1.82-slim AS build-rust\n   136→WORKDIR /build\n   137→COPY . .\n   138→RUN cargo build --release\n   139→`;\n   140→}\n   141→\n   142→/** COPY directives for each stack in the runtime stage */\n   143→function runtimeCopyDirectives(stacks: string[]): string {\n   144→  const lines: string[] = [];\n   145→  for (const stack of stacks) {\n   146→    const provider = getStackProvider(stack as StackName);\n   147→    if (provider) {\n   148→      lines.push(provider.getRuntimeCopyDirectives());\n   149→    }\n   150→  }\n   151→  return lines.join('\\n');\n   152→}\n   153→\n   154→/** Compose a multi-stage Dockerfile from multiple stack detections */\n   155→function multiStageTemplate(detections: StackDetection[]): string {\n   156→  // Filter to only stacks with a registered provider (all registered providers support multi-stage)\n   157→  const supported = detections.filter(d => getStackProvider(d.stack) !== undefined);\n   158→  if (supported.length === 0) {\n   159→    // All stacks unknown — fall back to generic-like runtime-only Dockerfile\n   160→    return genericTemplate();\n   161→  }\n   162→  const buildStages: string[] = [];\n   163→  const stacks = supported.map(d => d.stack);\n   164→\n   165→  for (const stack of stacks) {\n   166→    const provider = getStackProvider(stack as StackName);\n   167→    if (provider) {\n   168→      buildStages.push(provider.getDockerBuildStage());\n   169→    }\n   170→  }\n   171→\n   172→  const copyLines = runtimeCopyDirectives(stacks);\n   173→\n   174→  return `# NOTE: Customize COPY paths for your monorepo layout. Each build stage should only copy its own sources.\n   175→${buildStages.join('\\n')}\n   176→# === Runtime stage ===\n   177→FROM debian:bookworm-slim\n   178→\n   179→# System utilities for verification\n   180→RUN apt-get update && apt-get install -y --no-install-recommends curl jq && rm -rf /var/lib/apt/lists/*\n   181→\n   182→# Install artifacts from build stages\n   183→${copyLines}\n   184→\n   185→# Run as non-root user\n   186→USER nobody\n   187→\n   188→WORKDIR /workspace\n   189→`;\n   190→}\n   191→\n   192→// ─── Main generator ─────────────────────────────────────────────────────────\n   193→\n   194→/**\n   195→ * Generate a Dockerfile template based on detected stack type.\n   196→ * Accepts either a string stack name (backward compat) or StackDetection[] for multi-stack.\n   197→ * Returns fail() if a Dockerfile already exists — caller handles messaging.\n   198→ */\n   199→export function generateDockerfileTemplate(\n   200→  projectDir: string,\n   201→  stackOrDetections: string | null | StackDetection[],\n   202→): Result<DockerfileTemplateResult> {\n   203→  if (!projectDir) {\n   204→    return fail('projectDir is required');\n   205→  }\n   206→\n   207→  const dockerfilePath = join(projectDir, 'Dockerfile');\n   208→\n   209→  if (existsSync(dockerfilePath)) {\n   210→    return fail('Dockerfile already exists');\n   211→  }\n   212→\n   213→  // Multi-stack path: StackDetection[] with >1 entry\n   214→  if (Array.isArray(stackOrDetections) && stackOrDetections.length > 1) {\n   215→    const content = multiStageTemplate(stackOrDetections);\n   216→    const stacks = stackOrDetections.map(d => d.stack);\n   217→    try {\n   218→      writeFileSync(dockerfilePath, content, 'utf-8');\n   219→    } catch (err) {\n   220→      const message = err instanceof Error ? err.message : String(err);\n   221→      return fail(`Failed to write Dockerfile: ${message}`);\n   222→    }\n   223→    return ok({ path: dockerfilePath, stack: stacks[0], stacks });\n   224→  }\n   225→\n   226→  // Resolve single stack from StackDetection[] or string\n   227→  const stack: string | null = Array.isArray(stackOrDetections)\n   228→    ? (stackOrDetections.length === 1 ? stackOrDetections[0].stack : null)\n   229→    : stackOrDetections;\n   230→\n   231→  let content: string;\n   232→  let resolvedStack: string;\n   233→\n   234→  const provider = stack ? getStackProvider(stack as StackName) : undefined;\n   235→  if (provider) {\n   236→    content = provider.getDockerfileTemplate();\n   237→    resolvedStack = provider.name;\n   238→  } else {\n   239→    content = genericTemplate();\n   240→    resolvedStack = 'generic';\n   241→  }\n   242→\n   243→  try {\n   244→    writeFileSync(dockerfilePath, content, 'utf-8');\n   245→  } catch (err) {\n   246→    const message = err instanceof Error ? err.message : String(err);\n   247→    return fail(`Failed to write Dockerfile: ${message}`);\n   248→  }\n   249→\n   250→  return ok({ path: dockerfilePath, stack: resolvedStack, stacks: [resolvedStack] });\n   251→}\n   252→"}]},"parent_tool_use_id":"toolu_01ARb5KJHwvTVWjSi4hskh96","session_id":"7c5953f4-1d55-4aa9-825f-60bc73601e00","uuid":"915e31e0-adf4-4ad6-833a-f0fa77f1a158","timestamp":"2026-03-25T01:53:51.067Z"}
