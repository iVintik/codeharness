it('does not introduce blank lines when appending to file ending with newline', () => {\n   804→    writeFileSync(join(testDir, '.env.codeharness'), 'OTHER_VAR=value\\n', 'utf-8');\n   805→\n   806→    ensureServiceNameEnvVar(testDir, 'my-project');\n   807→\n   808→    const content = readFileSync(join(testDir, '.env.codeharness'), 'utf-8');\n   809→    expect(content).toBe('OTHER_VAR=value\\nOTEL_SERVICE_NAME=my-project\\n');\n   810→    expect(content).not.toContain('\\n\\n');\n   811→  });\n   812→});\n   813→\n   814→describe('configureOtlpEnvVars creates .env.codeharness', () => {\n   815→  it('writes .env.codeharness when configuring OTLP env vars', () => {\n   816→    initState('nodejs');\n   817→\n   818→    configureOtlpEnvVars(testDir, 'nodejs');\n   819→\n   820→    expect(existsSync(join(testDir, '.env.codeharness'))).toBe(true);\n   821→    const content = readFileSync(join(testDir, '.env.codeharness'), 'utf-8');\n   822→    expect(content).toContain('OTEL_SERVICE_NAME=');\n   823→  });\n   824→});\n   825→"}]},"parent_tool_use_id":"toolu_0171dfRPdau3d9vdSdBsjERK","session_id":"8e4c6a49-a8f5-4820-a234-101957ee0803","uuid":"d364beca-d2a8-4e09-9d45-c8b9b5769122","timestamp":"2026-03-23T07:34:11.426Z"}
