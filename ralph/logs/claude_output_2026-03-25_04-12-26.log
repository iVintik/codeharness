{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XUL6PJ2fQwLx59GCYLybeA","type":"tool_result","content":"   230→get_current_task() {\n   231→    # No-op — task picking is done by the /harness-run skill, not Ralph.\n   232→    echo \"\"\n   233→    return 0\n   234→}\n   235→\n   236→# codeharness: Check if all stories in sprint-status.yaml are done.\n   237→# Reads development_status entries matching N-N-slug pattern (story keys).\n   238→# Returns 0 (true) if ALL story entries have status \"done\", 1 otherwise.\n   239→check_sprint_complete() {\n   240→    if [[ ! -f \"$SPRINT_STATUS_FILE\" ]]; then\n   241→        return 1\n   242→    fi\n   243→\n   244→    local total=0\n   245→    local done_count=0\n   246→\n   247→    while IFS=: read -r key value; do\n   248→        # Trim whitespace\n   249→        key=$(echo \"$key\" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')\n   250→        value=$(echo \"$value\" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')\n   251→\n   252→        # Skip comments and empty lines\n   253→        [[ -z \"$key\" || \"$key\" == \\#* ]] && continue\n   254→\n   255→        # Match story keys: N-N-slug (e.g. 5-1-ralph-loop-integration)\n   256→        if [[ \"$key\" =~ ^[0-9]+-[0-9]+- ]]; then\n   257→            total=$((total + 1))\n   258→            if [[ \"$value\" == \"done\" ]]; then\n   259→                done_count=$((done_count + 1))"}]},"parent_tool_use_id":"toolu_01KNQnUKBFtzFzrosUg6K7qd","session_id":"7d2c764f-deb1-4354-ad31-e0a846d19ae3","uuid":"28d42770-e6be-437e-ac23-2669f7212193","timestamp":"2026-03-25T00:20:41.724Z"}
