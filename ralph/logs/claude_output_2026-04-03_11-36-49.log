{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AfxMm5WYCy9mwAYGbq2YZc","type":"tool_result","content":"2552\tdescribe('driver integration (story 10-5)', () => {\n2553\t  beforeEach(() => {\n2554\t    vi.clearAllMocks();\n2555\t    setupDefaultMocks();\n2556\t  });\n2557\t\n2558\t  it('calls getDriver with \"claude-code\" when task has no driver field (AC #1, #2)', async () => {\n2559\t    const task = makeTask();\n2560\t    const definition = makeDefinition();\n2561\t    const state = makeDefaultState();\n2562\t    const config = makeConfig();\n2563\t\n2564\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n2565\t\n2566\t    expect(mockGetDriver).toHaveBeenCalledWith('claude-code');\n2567\t  });\n2568\t\n2569\t  it('calls getDriver with task.driver when present (forward-compat)', async () => {\n2570\t    const task = { ...makeTask(), driver: 'opencode' } as ResolvedTask & { driver: string };\n2571\t    const definition = makeDefinition();\n2572\t    const state = makeDefaultState();\n2573\t    const config = makeConfig();\n2574\t\n2575\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n2576\t\n2577\t    expect(mockGetDriver).toHaveBeenCalledWith('opencode');\n2578\t  });\n2579\t\n2580\t  it('calls driver.dispatch() with properly constructed DispatchOpts (AC #7)', async () => {\n2581\t    const task = makeTask({ source_access: true });\n2582\t    const definition = makeDefinition();\n2583\t    const state = makeDefaultState();\n2584\t    const config = makeConfig({ projectDir: '/my-project' });\n2585\t\n2586\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n2587\t\n2588\t    expect(mockDriverDispatch).toHaveBeenCalledWith(\n2589\t      expect.objectContaining({\n2590\t        prompt: 'Implement story 5-1-foo',\n2591\t        model: 'claude-sonnet-4-20250514',\n2592\t        cwd: '/my-project',\n2593\t        sourceAccess: true,\n2594\t      }),\n2595\t    );\n2596\t  });\n2597\t\n2598\t  it('calls resolveModel with (task, agentModelSource, driver) (AC #4)', async () => {\n2599\t    const task = makeTask();\n2600\t    const definition = makeDefinition({ model: 'claude-haiku-35' });\n2601\t    const state = makeDefaultState();\n2602\t    const config = makeConfig();\n2603\t\n2604\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n2605\t\n2606\t    expect(mockResolveModel).toHaveBeenCalledWith(\n2607\t      task,\n2608\t      { model: 'claude-haiku-35' },\n2609\t      expect.objectContaining({ name: 'claude-code', defaultModel: 'claude-sonnet-4-20250514' }),\n2610\t    );\n2611\t  });\n2612\t\n2613\t  it('consumes AsyncIterable<StreamEvent> and extracts result data (AC #3)', async () => {\n2614\t    mockDriverDispatch.mockImplementation(() => {\n2615\t      return (async function* () {\n2616\t        yield { type: 'text', text: 'Hello ' };\n2617\t        yield { type: 'text', text: 'World' };\n2618\t        yield { type: 'result', cost: 0.12, sessionId: 'sess-driver-1' };\n2619\t      })();\n2620\t    });\n2621\t\n2622\t    const task = makeTask();\n2623\t    const definition = makeDefinition();\n2624\t    const state = makeDefaultState();\n2625\t    const config = makeConfig();\n2626\t\n2627\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n2628\t\n2629\t    // Session ID was extracted from result event and recorded\n2630\t    expect(mockRecordSessionId).toHaveBeenCalledWith(\n2631\t      { taskName: 'implement', storyKey: '5-1-foo' },\n2632\t      'sess-driver-1',\n2633\t      state,\n2634\t    );\n2635\t  });\n2636\t\n2637\t  it('maps error result events to DispatchError (AC #5)', async () => {\n2638\t    mockDriverDispatch.mockImplementation(() => {\n2639\t      return (async function* () {\n2640\t        yield { type: 'text', text: 'partial output' };\n2641\t        yield {\n2642\t          type: 'result',\n2643\t          cost: 0,\n2644\t          sessionId: 'sess-err',\n2645\t          error: 'Rate limit exceeded',\n2646\t          errorCategory: 'RATE_LIMIT',\n2647\t        };\n2648\t      })();\n2649\t    });\n2650\t\n2651\t    const task = makeTask();"}]},"parent_tool_use_id":"toolu_01CynUeQoL6d5xdNwRWAfZQm","session_id":"f83470b7-c271-483e-ae93-7fe9bce4b683","uuid":"7ec783b8-8768-4d4a-9afe-b888ef301f68","timestamp":"2026-04-03T08:02:39.920Z"}
