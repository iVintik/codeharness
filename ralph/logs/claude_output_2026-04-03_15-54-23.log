{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XcZ26sGnqmn4cjVhjKJmnM","type":"tool_result","content":"1\t/**\n2\t * Ink UI components — activity display (tools, thoughts, retry, messages).\n3\t *\n4\t * Split from ink-components.tsx to comply with NFR9 (max 300 lines per file).\n5\t * Types are defined in ink-components.tsx and imported here.\n6\t */\n7\t\n8\timport React from 'react';\n9\timport { Text, Box } from 'ink';\n10\timport { Spinner } from '@inkjs/ui';\n11\timport type { CompletedToolEntry, RetryInfo, StoryMessage } from './ink-components.js';\n12\t\n13\t// --- Message Styles ---\n14\t\n15\tconst MESSAGE_STYLE: Record<StoryMessage['type'], { prefix: string; color: string }> = {\n16\t  ok: { prefix: '[OK]', color: 'green' },\n17\t  warn: { prefix: '[WARN]', color: 'yellow' },\n18\t  fail: { prefix: '[FAIL]', color: 'red' },\n19\t};\n20\t\n21\t// --- Components ---\n22\t\n23\texport function StoryMessageLine({ msg }: { msg: StoryMessage }) {\n24\t  const style = MESSAGE_STYLE[msg.type];\n25\t  return (\n26\t    <Box flexDirection=\"column\">\n27\t      <Text>\n28\t        <Text color={style.color} bold>{style.prefix}</Text>\n29\t        <Text>{` Story ${msg.key}: ${msg.message}`}</Text>\n30\t      </Text>\n31\t      {msg.details?.map((d, j) => (\n32\t        <Text key={j} dimColor>{`  └ ${d}`}</Text>\n33\t      ))}\n34\t    </Box>\n35\t  );\n36\t}\n37\t\n38\texport function CompletedTool({ entry }: { entry: CompletedToolEntry }) {\n39\t  const argsSummary = entry.args.length > 60\n40\t    ? entry.args.slice(0, 60) + '…'\n41\t    : entry.args;\n42\t  return (\n43\t    <Text wrap=\"truncate-end\">\n44\t      <Text color=\"green\">{'✓ '}</Text>\n45\t      <Text dimColor>{'['}</Text>\n46\t      <Text>{entry.name}</Text>\n47\t      <Text dimColor>{'] '}</Text>\n48\t      <Text dimColor>{argsSummary}</Text>\n49\t      {entry.driver && <Text dimColor>{` (${entry.driver})`}</Text>}\n50\t    </Text>\n51\t  );\n52\t}\n53\t\n54\t/** Show only the last N completed tools to keep output compact. */\n55\tconst VISIBLE_COMPLETED_TOOLS = 5;\n56\t\n57\texport function CompletedTools({ tools }: { tools: CompletedToolEntry[] }) {\n58\t  const visible = tools.slice(-VISIBLE_COMPLETED_TOOLS);\n59\t  const hidden = tools.length - visible.length;\n60\t  return (\n61\t    <Box flexDirection=\"column\">\n62\t      {hidden > 0 && <Text dimColor>{`  … ${hidden} earlier tools`}</Text>}\n63\t      {visible.map((entry, i) => (\n64\t        <CompletedTool key={i} entry={entry} />\n65\t      ))}\n66\t    </Box>\n67\t  );\n68\t}\n69\t\n70\texport function ActiveTool({ name, driverName }: { name: string; driverName?: string | null }) {\n71\t  return (\n72\t    <Box>\n73\t      <Text color=\"yellow\">{'⚡ '}</Text>\n74\t      <Text dimColor>{'['}</Text>\n75\t      <Text bold>{name}</Text>\n76\t      <Text dimColor>{'] '}</Text>\n77\t      {driverName && <Text dimColor>{`(${driverName}) `}</Text>}\n78\t      <Spinner label=\"\" />\n79\t    </Box>\n80\t  );\n81\t}\n82\t\n83\texport function LastThought({ text }: { text: string }) {\n84\t  return (\n85\t    <Text wrap=\"truncate-end\">\n86\t      <Text>{'💭 '}</Text>\n87\t      <Text dimColor>{text}</Text>\n88\t    </Text>\n89\t  );\n90\t}\n91\t\n92\texport function RetryNotice({ info }: { info: RetryInfo }) {\n93\t  return (\n94\t    <Text color=\"yellow\">\n95\t      {'⏳ API retry '}\n96\t      {info.attempt}\n97\t      {' (waiting '}\n98\t      {info.delay}\n99\t      {'ms)'}\n100\t    </Text>\n101\t  );\n102\t}\n103\t\n104\texport function DriverCostSummary({ driverCosts }: { driverCosts: Record<string, number> }) {\n105\t  if (!driverCosts) return null;\n106\t  const entries = Object.entries(driverCosts).sort(([a], [b]) => a.localeCompare(b));\n107\t  if (entries.length === 0) return null;\n108\t  const parts = entries.map(([driver, cost]) => `${driver} $${cost.toFixed(2)}`).join(', ');\n109\t  return <Text dimColor>{`Cost: ${parts}`}</Text>;\n110\t}\n111\t"}]},"parent_tool_use_id":"toolu_0117vDhwD8YtdmVSBCbGt4wb","session_id":"a29ee53b-c2b0-4802-9455-7215112648b1","uuid":"eefac0df-86ac-4b65-b9f3-684af2b1dd6f","timestamp":"2026-04-03T12:09:33.373Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KxGpByb1GijgrgGstx4HBc","type":"tool_result","content":"1\t/**\n2\t * Ink App root component — composes layout and activity components.\n3\t *\n4\t * Separated from ink-components.tsx to avoid circular imports\n5\t * (ink-components exports types, ink-activity-components imports them,\n6\t * and this file imports from both).\n7\t */\n8\t\n9\timport React from 'react';\n10\timport { Box, Static } from 'ink';\n11\timport { Header, Separator, StoryBreakdown, type RendererState } from './ink-components.js';\n12\timport { CompletedTools, ActiveTool, LastThought, RetryNotice, StoryMessageLine, DriverCostSummary } from './ink-activity-components.js';\n13\timport { WorkflowGraph } from './ink-workflow.js';\n14\t\n15\texport function App({ state }: { state: RendererState }) {\n16\t  return (\n17\t    <Box flexDirection=\"column\">\n18\t      <Static items={state.messages}>\n19\t        {(msg, i) => <StoryMessageLine key={i} msg={msg} />}\n20\t      </Static>\n21\t      <Header info={state.sprintInfo} />\n22\t      <WorkflowGraph flow={state.workflowFlow} currentTask={state.currentTaskName} taskStates={state.taskStates} taskMeta={state.taskMeta} />\n23\t      <StoryBreakdown stories={state.stories} sprintInfo={state.sprintInfo} />\n24\t      <DriverCostSummary driverCosts={state.driverCosts} />\n25\t      {state.stories.length > 0 && <Separator />}\n26\t      <Box flexDirection=\"column\" paddingLeft={1}>\n27\t        <CompletedTools tools={state.completedTools} />\n28\t        {state.activeTool && <ActiveTool name={state.activeTool.name} driverName={state.activeDriverName} />}\n29\t        {state.lastThought && <LastThought text={state.lastThought} />}\n30\t        {state.retryInfo && <RetryNotice info={state.retryInfo} />}\n31\t      </Box>\n32\t    </Box>\n33\t  );\n34\t}\n35\t"}]},"parent_tool_use_id":"toolu_0117vDhwD8YtdmVSBCbGt4wb","session_id":"a29ee53b-c2b0-4802-9455-7215112648b1","uuid":"2a78a749-fa31-498f-9459-fa06d35bd25f","timestamp":"2026-04-03T12:09:33.372Z"}
