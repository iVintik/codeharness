ery.mock.calls[0][0];\n508\t      expect(call.options.model).toBe('claude-opus-4-20250514');\n509\t    });\n510\t\n511\t    it('passes cwd from opts', async () => {\n512\t      mockQuery.mockReturnValue(fakeStream([makeResultMessage()]));\n513\t\n514\t      await collectEvents(driver.dispatch(makeOpts({ cwd: '/my/project' })));\n515\t\n516\t      const call = mockQuery.mock.calls[0][0];\n517\t      expect(call.options.cwd).toBe('/my/project');\n518\t    });\n519\t\n520\t    it('sets bypassPermissions when sourceAccess is true', async () => {\n521\t      mockQuery.mockReturnValue(fakeStream([makeResultMessage()]));\n522\t\n523\t      await collectEvents(driver.dispatch(makeOpts({ sourceAccess: true })));\n524\t\n525\t      const call = mockQuery.mock.calls[0][0];\n526\t      expect(call.options.permissionMode).toBe('bypassPermissions');\n527\t      expect(call.options.allowDangerouslySkipPermissions).toBe(true);\n528\t    });\n529\t\n530\t    it('sets default permissionMode when sourceAccess is false', async () => {\n531\t      mockQuery.mockReturnValue(fakeStream([makeResultMessage()]));\n532\t\n533\t      await collectEvents(driver.dispatch(makeOpts({ sourceAccess: false })));\n534\t\n535\t      const call = mockQuery.mock.calls[0][0];\n536\t      expect(call.options.permissionMode).toBe('default');\n537\t      expect(call.options.allowDangerouslySkipPermissions).toBeUndefined();\n538\t    });\n539\t  });\n540\t\n541\t  describe('error during stream consumption', () => {\n542\t    it('classifies errors thrown mid-stream and yields result', async () => {\n543\t      async function* throwingStream() {\n544\t        yield {\n545\t          type: 'stream_event',\n546\t          event: {\n547\t            type: 'content_block_delta',\n548\t            delta: { type: 'text_delta', text: 'partial...' },\n549\t          },\n550\t        };\n551\t        throw Object.assign(new Error('connection reset'), { code: 'ECONNRESET' });\n552\t      }\n553\t\n554\t      mockQuery.mo