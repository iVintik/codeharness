Command(program);\n\n  return program;\n}\n\n// Only parse when running as CLI entry point, not when imported in tests\nif (!process.env['VITEST']) {\n  const program = createProgram();\n  program.parse(process.argv);\n}\n","structuredPatch":[{"oldStart":23,"oldLines":6,"newStart":23,"newLines":10,"lines":[" import { registerObservabilityGateCommand } from './commands/observability-gate.js';"," import { registerAuditCommand } from './commands/audit.js';"," ","+// Library exports — available to consumers via `import { parseStreamLine } from 'codeharness'`","+export { parseStreamLine } from './lib/stream-parser.js';","+export type { StreamEvent, ToolStartEvent, ToolInputEvent, ToolCompleteEvent, TextEvent, RetryEvent, ResultEvent } from './lib/stream-parser.js';","+"," declare const __PKG_VERSION__: string;"," const VERSION = typeof __PKG_VERSION__ !== 'undefined' ? __PKG_VERSION__ : '0.0.0-dev';"," "]}],"userModified":false,"replaceAll":false}}
