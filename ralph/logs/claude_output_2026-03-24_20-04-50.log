n    54→      type: 'content_block_start',\n    55→      content_block: { type: 'text', text: '' },\n    56→    });\n    57→    expect(parseStreamLine(input)).toBeNull();\n    58→  });\n    59→\n    60→  it('returns null when content_block is missing', () => {\n    61→    const input = streamEvent({ type: 'content_block_start' });\n    62→    expect(parseStreamLine(input)).toBeNull();\n    63→  });\n    64→\n    65→  it('returns null when tool_use name is missing', () => {\n    66→    const input = streamEvent({\n    67→      type: 'content_block_start',\n    68→      content_block: { type: 'tool_use', id: 'toolu_xxx' },\n    69→    });\n    70→    expect(parseStreamLine(input)).toBeNull();\n    71→  });\n    72→\n    73→  it('returns null when tool_use id is missing', () => {\n    74→    const input = streamEvent({\n    75→      type: 'content_block_start',\n    76→      content_block: { type: 'tool_use', name: 'Bash' },\n    77→    });\n    78→    expect(parseStreamLine(input)).toBeNull();\n    79→  });\n    80→});\n    81→\n    82→// --- AC #2: content_block_delta with input_json_delta → tool-input ---\n    83→\n    84→describe('AC #2: tool-input', () => {\n    85→  it('parses input_json_delta', () => {\n    86→    const input = streamEvent({\n    87→      type: 'content_block_delta',\n    88→      delta: { type: 'input_json_delta', partial_json: '{\"command\":\"npm test\"}' },\n    89→    });\n    90→    const result = parseStreamLine(input) as ToolInputEvent;\n    91→    expect(result).toEqual({\n    92→      type: 'tool-input',\n    93→      partial: '{\"command\":\"npm test\"}',\n    94→    });\n    95→  });\n    96→\n    97→  it('handles empty partial_json', () => {\n    98→    const input = streamEvent({\n    99→      type: 'content_block_delta',\n   100→      delta: { type: 'input_json_delta', partial_json: '' },\n   101→    });\n   102→    const result = parseStreamLine(input) as ToolInputEvent;\n   103→    expect(result).toEqual({ type: 'tool-input', partial: '' });\n   104→  });\n   105→\n   106→  it('returns null when partial_json is not a string', () => {\n   107→    const input = streamEvent({\n   108→      type: 'content_block_delta',\n   109→      delta: { type: 'input_json_delta', partial_json: 42 },\n   110→    });\n   111→    expect(parseStreamLine(input)).toBeNull();\n   112→  });\n   113→\n   114→  it('returns null when delta is missing', () => {\n   115→    const input = streamEvent({ type: 'content_block_delta' });\n   116→    expect(parseStreamLine(input)).toBeNull();\n   117→  });\n   118→});\n   119→\n   120→// --- AC #3: content_block_stop → tool-complete ---\n   121→\n   122→describe('AC #3: tool-complete', () => {\n   123→  it('parses content_block_stop', () => {\n   124→    const input = streamEvent({ type: 'content_block_stop' });\n   125→    const result = parseStreamLine(input) as ToolCompleteEvent;\n   126→    expect(result).toEqual({ type: 'tool-complete' });\n   127→  });\n   128→\n   129→  it('ignores extra fields on content_block_stop', () => {\n   130→    const input = streamEvent({ type: 'content_block_stop', index: 0 });\n   131→    const result = parseStreamLine(input) as ToolCompleteEvent;\n   132→    expect(result).toEqual({ type: 'tool-complete' });\n   133→  });\n   134→});\n   135→\n   136→// --- AC #4: content_block_delta with text_delta → text ---\n   137→\n   138→describe('AC #4: text', () => {\n   139→  it('parses text_delta', () => {\n   140→    const input = streamEvent({\n   141→      type: 'content_block_delta',\n   142→      delta: { type: 'text_delta', text: \"I'll read the file...\" },\n   143→    });\n   144→    const result = parseStreamLine(input) as TextEvent;\n   145→    expect(result).toEqual({ type: 'text', text: \"I'll read the file...\" });\n   146→  });\n   147→\n   148→  it('handles empty text', () => {\n   149→    const input = streamEvent({\n   150→      type: 'content_block_delta',\n   151→      delta: { type: 'text_delta', text: '' },\n   152→    });\n   153→    const result = parseStreamLine(input) as TextEvent;\n   154→    expect(result).toEqual({ type: 'text', text: '' });\n   155→  });\n   156→\n   157→  it('returns null when text is not a string', () => {\n   158→    const input = streamEvent({\n   159→      type: 'content_block_delta',\n   160→      delta: { type: 'text_delta', text: 123 },\n   161→    });\n   162→    expect(parseStreamLine(input)).toBeNull();\n   163→  });\n   164→});\n   165→\n   166→// --- AC #5: system/api_retry → retry ---\n   167→\n   168→describe('AC #5: retry', () => {\n   169→  it('parses api_retry event', () => {\n   170→    const input = line({\n   171→      type: 'system',\n   172→      subtype: 'api_retry',\n   173→      attempt: 2,\n   174→      max_retries: 5,\n   175→      retry_delay_ms: 3000,\n   176→      error: 'overloaded_error',\n   177→    });\n   178→    const result = parseStreamLine(input) as RetryEvent;\n   179→    expect(result).toEqual({ type: 'retry', attempt: 2, delay: 3000 });\n   180→  });\n   181→\n   182→  it('returns null for system events without api_retry subtype', () => {\n   183→    const input = line({ type: 'system', subtype: 'init' });\n   184→    expect(parseStreamLine(input)).toBeNull();\n   185→  });\n   186→\n   187→  it('returns null when attempt is missing', () => {\n   188→    const input = line({\n   189→      type: 'system',\n   190→      subtype: 'api_retry',\n   191→      retry_delay_ms: 1000,\n   192→    });\n   193→    expect(parseStreamLine(input)).toBeNull();\n   194→  });\n   195→\n   196→  it('returns null when retry_delay_ms is missing', () => {\n   197→    const input = line({\n   198→      type: 'system',\n   199→      subtype: 'api_retry',\n   200→      attempt: 1,\n   201→    });\n   202→    expect(parseStreamLine(input)).toBeNull();\n   203→  });\n   204→});\n   205→\n   206→// --- AC #6: result → result ---\n   207→\n   208→describe('AC #6: result', () => {\n   209→  it('parses result event', () => {\n   210→    const input = line({\n   211→      type: 'result',\n   212→      cost_usd: 4.2,\n   213→      session_id: 'sess_abc123',\n   214→      result: 'All tasks completed successfully.',\n   215→    });\n   216→    const result = parseStreamLine(input) as ResultEvent;\n   217→    expect(result).toEqual({\n   218→      type: 'result',\n   219→      cost: 4.2,\n   220→      sessionId: 'sess_abc123',\n   221→    });\n   222→  });\n   223→\n   224→  it('handles zero cost', () => {\n   225→    const input = line({\n   226→      type: 'result',\n   227→      cost_usd: 0,\n   228→      session_id: 'sess_zero',\n   229→      result: '',\n   230→    });\n   231→    const result = parseStreamLine(input) as ResultEvent;\n   232→    expect(result).toEqual({ type: 'result', cost: 0, sessionId: 'sess_zero' });\n   233→  });\n   234→\n   235→  it('returns null when cost_usd is missing', () => {\n   236→    const input = line({ type: 'result', session_id: 'sess_xxx' });\n   237→    expect(parseStreamLine(input)).toBeNull();\n   238→  });\n   239→\n   240→  it('returns null when session_id is missing', () => {\n   241→    const input = line({ type: 'result', cost_usd: 1.5 });\n   242→    expect(parseStreamLine(input)).toBeNull();\n   243→  });\n   244→});\n   245→\n   246→// --- Edge Cases ---\n   247→\n   248→describe('edge cases', () => {\n   249→  it('returns null for empty string', () => {\n   250→    expect(parseStreamLine('')).toBeNull();\n   251→  });\n   252→\n   253→  it('returns null for whitespace-only string', () => {\n   254→    expect(parseStreamLine('   \\t  ')).toBeNull();\n   255→  });\n   256→\n   257→  it('returns null for invalid JSON', () => {\n   258→    expect(parseStreamLine('{invalid json}')).toBeNull();\n   259→  });\n   260→\n   261→  it('returns null for JSON primitive', () => {\n   262→    expect(parseStreamLine('\"just a string\"')).toBeNull();\n   263→  });\n   264→\n   265→  it('returns null for JSON array', () => {\n   266→    expect(parseStreamLine('[1, 2, 3]')).toBeNull();\n   267→  });\n   268→\n   269→  it('returns null for JSON number', () => {\n   270→    expect(parseStreamLine('42')).toBeNull();\n   271→  });\n   272→\n   273→  it('returns null for JSON boolean', () => {\n   274→    expect(parseStreamLine('true')).toBeNull();\n   275→  });\n   276→\n   277→  it('returns null for JSON null', () => {\n   278→    expect(parseStreamLine('null')).toBeNull();\n   279→  });\n   280→\n   281→  it('returns null for truncated JSON', () => {\n   282→    expect(parseStreamLine('{\"type\": \"stream_ev')).toBeNull();\n   283→  });\n   284→\n   285→  it('returns null for message_start', () => {\n   286→    const input = streamEvent({ type: 'message_start', message: {} });\n   287→    expect(parseStreamLine(input)).toBeNull();\n   288→  });\n   289→\n   290→  it('returns null for message_stop', () => {\n   291→    const input = streamEvent({ type: 'message_stop' });\n   292→    expect(parseStreamLine(input)).toBeNull();\n   293→  });\n   294→\n   295→  it('returns null for message_delta', () => {\n   296→    const input = streamEvent({\n   297→      type: 'message_delta',\n   298→      delta: { stop_reason: 'end_turn' },\n   299→    });\n   300→    expect(parseStreamLine(input)).toBeNull();\n   301→  });\n   302→\n   303→  it('returns null for unknown wrapper type', () => {\n   304→    const input = line({ type: 'ping' });\n   305→    expect(parseStreamLine(input)).toBeNull();\n   306→  });\n   307→\n   308→  it('returns null for stream_event without event field', () => {\n   309→    const input = line({ type: 'stream_event' });\n   310→    expect(parseStreamLine(input)).toBeNull();\n   311→  });\n   312→\n   313→  it('returns null for unknown delta type', () => {\n   314→    const input = streamEvent({\n   315→      type: 'content_block_delta',\n   316→      delta: { type: 'thinking_delta', thinking: 'hmm' },\n   317→    });\n   318→    expect(parseStreamLine(input)).toBeNull();\n   319→  });\n   320→\n   321→  it('handles line with trailing newline', () => {\n   322→    const input = streamEvent({\n   323→      type: 'content_block_stop',\n   324→    }) + '\\n';\n   325→    const result = parseStreamLine(input);\n   326→    expect(result).toEqual({ type: 'tool-complete' });\n   327→  });\n   328→});\n   329→\n   330→// --- Type exhaustiveness check ---\n   331→\n   332→describe('type safety', () => {\n   333→  it('StreamEvent type covers all variants', () => {\n   334→    // This is a compile-time check. If a new variant is added to StreamEvent\n   335→    // without being handled, TypeScript will error on exhaustive switches.\n   336→    const events: StreamEvent[] = [\n   337→      { type: 'tool-start', name: 'Bash', id: 'x' },\n   338→      { type: 'tool-input', partial: '{}' },\n   339→      { type: 'tool-complete' },\n   340→      { type: 'text', text: 'hello' },\n   341→      { type: 'retry', attempt: 1, delay: 1000 },\n   342→      { type: 'result', cost: 1.0, sessionId: 's' },\n   343→    ];\n   344→    expect(events).toHaveLength(6);\n   345→  });\n   346→});\n   347→"}]},"parent_tool_use_id":"toolu_01RmTRSciNZ4m4Rj6YrMRu8q","session_id":"110312c9-09eb-45d4-bc39-1124b22b5753","uuid":"d2cbbc21-f9f0-4480-839d-03289dbeb80f","timestamp":"2026-03-24T16:06:24.723Z"}
