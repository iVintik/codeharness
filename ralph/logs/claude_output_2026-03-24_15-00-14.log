{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01N7YmrrP9XYWgK5WryEqAUp","type":"tool_result","content":"     1→import { spawn } from 'node:child_process';\n     2→import { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n     3→import { join, dirname } from 'node:path';\n     4→import { fileURLToPath } from 'node:url';\n     5→import { Command } from 'commander';\n     6→import { fail, info, jsonOutput } from '../lib/output.js';\n     7→import { readSprintStatus } from '../lib/beads-sync.js';\n     8→import { generateRalphPrompt } from '../templates/ralph-prompt.js';\n     9→import { startRenderer, type SprintInfo } from '../lib/ink-renderer.js';\n    10→import { getSprintState } from '../modules/sprint/index.js';\n    11→import { formatElapsed, mapSprintStatuses, countStories, buildSpawnArgs, createLineProcessor } from '../lib/run-helpers.js';\n    12→\n    13→const SPRINT_STATUS_REL = '_bmad-output/implementation-artifacts/sprint-status.yaml';\n    14→\n    15→/** Resolves the path to ralph/ralph.sh relative to the package root. */\n    16→export function resolveRalphPath(): string {\n    17→  const currentFile = fileURLToPath(import.meta.url);\n    18→  const currentDir = dirname(currentFile);\n    19→  let root = dirname(currentDir);\n    20→  if (root.endsWith('/src') || root.endsWith('\\\\src')) {\n    21→    root = dirname(root);\n    22→  }\n    23→  return join(root, 'ralph', 'ralph.sh');\n    24→}\n    25→\n    26→/** Resolves the plugin directory path (.claude/ in project root). */\n    27→export function resolvePluginDir(): string {\n    28→  return join(process.cwd(), '.claude');\n    29→}\n    30→\n    31→// Re-export helpers that tests import from run.ts\n    32→export { countStories, buildSpawnArgs } from '../lib/run-helpers.js';\n    33→\n    34→export function registerRunCommand(program: Command): void {\n    35→  program\n    36→    .command('run')\n    37→    .description('Execute the autonomous coding loop')\n    38→    .option('--max-iterations <n>', 'Maximum loop iterations', '50')\n    39→    .option('--timeout <seconds>', 'Total loop timeout in seconds', '43200')\n    40→    .option('--iteration-timeout <minutes>', 'Per-iteration timeout in minutes', '30')\n    41→    .option('--quiet', 'Suppress terminal output (background mode)', false)\n    42→    .option('--calls <n>', 'Max API calls per hour', '100')\n    43→    .option('--max-story-retries <n>', 'Max retries per story before flagging', '10')\n    44→    .option('--reset', 'Clear retry counters, flagged stories, and circuit breaker before starting', false)\n    45→    .action(async (options, cmd) => {\n    46→      const globalOpts = cmd.optsWithGlobals();\n    47→      const isJson = !!globalOpts.json;\n    48→      const outputOpts = { json: isJson };\n    49→\n    50→      // 1. Resolve Ralph script path\n    51→      const ralphPath = resolveRalphPath();\n    52→      if (!existsSync(ralphPath)) {\n    53→        fail('Ralph loop not found — reinstall codeharness', outputOpts);\n    54→        process.exitCode = 1;\n    55→        return;\n    56→      }\n    57→\n    58→      // 2. Resolve plugin directory\n    59→      const pluginDir = resolvePluginDir();\n    60→      if (!existsSync(pluginDir)) {\n    61→        fail('Plugin directory not found — run codeharness init first', outputOpts);\n    62→        process.exitCode = 1;\n    63→        return;\n    64→      }\n    65→\n    66→      // 3. Read sprint status for story count\n    67→      const projectDir = process.cwd();\n    68→      const sprintStatusPath = join(projectDir, SPRINT_STATUS_REL);\n    69→      const statuses = readSprintStatus(projectDir);\n    70→      const counts = countStories(statuses);\n    71→\n    72→      if (counts.total === 0) {\n    73→        fail('No stories found in sprint-status.yaml — nothing to execute', outputOpts);\n    74→        process.exitCode = 1;\n    75→        return;\n    76→      }\n    77→\n    78→      info(`Starting autonomous execution — ${counts.ready} ready, ${counts.inProgress} in progress, ${counts.verified} verified, ${counts.done}/${counts.total} done`, outputOpts);\n    79→\n    80→      // 4. Parse and validate numeric options\n    81→      const maxIterations = parseInt(options.maxIterations, 10);\n    82→      const timeout = parseInt(options.timeout, 10);\n    83→      const iterationTimeout = parseInt(options.iterationTimeout, 10);\n    84→      const calls = parseInt(options.calls, 10);\n    85→      const maxStoryRetries = parseInt(options.maxStoryRetries, 10);\n    86→\n    87→      if (isNaN(maxIterations) || isNaN(timeout) || isNaN(iterationTimeout) || isNaN(calls) || isNaN(maxStoryRetries)) {\n    88→        fail('Invalid numeric option — --max-iterations, --timeout, --iteration-timeout, --calls, and --max-story-retries must be numbers', outputOpts);\n    89→        process.exitCode = 1;\n    90→        return;\n    91→      }\n    92→\n    93→      // 5. Generate prompt file (with flagged stories context if available)\n    94→      const promptFile = join(projectDir, 'ralph', '.harness-prompt.md');\n    95→      const flaggedFilePath = join(projectDir, 'ralph', '.flagged_stories');\n    96→      let flaggedStories: string[] | undefined;\n    97→      if (existsSync(flaggedFilePath)) {\n    98→        try {\n    99→          const flaggedContent = readFileSync(flaggedFilePath, 'utf-8');\n   100→          flaggedStories = flaggedContent.split('\\n').filter(s => s.trim().length > 0);\n   101→        } catch {\n   102→          // Ignore read errors\n   103→        }\n   104→      }\n   105→      const promptContent = generateRalphPrompt({\n   106→        projectDir,\n   107→        sprintStatusPath,\n   108→        flaggedStories,\n   109→      });\n   110→      try {\n   111→        mkdirSync(dirname(promptFile), { recursive: true });\n   112→        writeFileSync(promptFile, promptContent, 'utf-8');\n   113→      } catch (err) {\n   114→        const message = err instanceof Error ? err.message : String(err);\n   115→        fail(`Failed to write prompt file: ${message}`, outputOpts);\n   116→        process.exitCode = 1;\n   117→        return;\n   118→      }\n   119→\n   120→      // 6. Build spawn arguments\n   121→      const args = buildSpawnArgs({\n   122→        ralphPath,\n   123→        pluginDir,\n   124→        promptFile,\n   125→        maxIterations,\n   126→        timeout,\n   127→        iterationTimeout,\n   128→        calls,\n   129→        quiet: options.quiet,\n   130→        maxStoryRetries,\n   131→        reset: options.reset,\n   132→      });\n   133→\n   134→      // 7. Set environment — stream-json is always the output format\n   135→      const env = { ...process.env };\n   136→      if (isJson) {\n   137→        env.CLAUDE_OUTPUT_FORMAT = 'stream-json';\n   138→      }\n   139→\n   140→      // 8. Spawn Ralph — pipe stdout/stderr through stream parser → Ink renderer\n   141→      // Declare renderer handle outside try so cleanup is always reachable\n   142→      const quiet = options.quiet;\n   143→      const rendererHandle = startRenderer({ quiet });\n   144→      let sprintStateInterval: ReturnType<typeof setInterval> | null = null;\n   145→      const sessionStartTime = Date.now();\n   146→      let currentIterationCount = 0;\n   147→\n   148→      try {\n   149→        // Read initial sprint state for the renderer header\n   150→        const initialState = getSprintState();\n   151→        if (initialState.success) {\n   152→          const s = initialState.data;\n   153→          const sprintInfo: SprintInfo = {\n   154→            storyKey: s.run.currentStory ?? '',\n   155→            phase: s.run.currentPhase ?? '',\n   156→            done: s.sprint.done,\n   157→            total: s.sprint.total,\n   158→            elapsed: formatElapsed(Date.now() - sessionStartTime),\n   159→            iterationCount: currentIterationCount,\n   160→          };\n   161→          rendererHandle.updateSprintState(sprintInfo);\n   162→        }\n   163→\n   164→        // Feed initial per-story statuses to the renderer\n   165→        const initialStatuses = readSprintStatus(projectDir);\n   166→        const initialStories = mapSprintStatuses(initialStatuses);\n   167→        if (initialStories.length > 0) {\n   168→          rendererHandle.updateStories(initialStories);\n   169→        }\n   170→\n   171→        const child = spawn('bash', args, {\n   172→          stdio: quiet ? 'ignore' : ['inherit', 'pipe', 'pipe'],\n   173→          cwd: projectDir,\n   174→          env,\n   175→        });\n   176→\n   177→        if (!quiet && child.stdout && child.stderr) {\n   178→          // Wire up stream parser → Ink renderer via extracted createLineProcessor.\n   179→          const stdoutHandler = createLineProcessor({\n   180→            onEvent: (event) => rendererHandle.update(event),\n   181→          });\n   182→          const stderrHandler = createLineProcessor({\n   183→            onEvent: (event) => rendererHandle.update(event),\n   184→            onMessage: (msg) => rendererHandle.addMessage(msg),\n   185→            onIteration: (iteration) => { currentIterationCount = iteration; },\n   186→          }, { parseRalph: true });\n   187→          child.stdout.on('data', stdoutHandler);\n   188→          child.stderr.on('data', stderrHandler);\n   189→\n   190→          // Periodically refresh sprint state for the header display\n   191→          sprintStateInterval = setInterval(() => {\n   192→            try {\n   193→              const stateResult = getSprintState();\n   194→              if (stateResult.success) {\n   195→                const s = stateResult.data;\n   196→                const sprintInfo: SprintInfo = {\n   197→                  storyKey: s.run.currentStory ?? '',\n   198→                  phase: s.run.currentPhase ?? '',\n   199→                  done: s.sprint.done,\n   200→                  total: s.sprint.total,\n   201→                  elapsed: formatElapsed(Date.now() - sessionStartTime),\n   202→                  iterationCount: currentIterationCount,\n   203→                };\n   204→                rendererHandle.updateSprintState(sprintInfo);\n   205→              }\n   206→              // Refresh per-story statuses (AC #7)\n   207→              const currentStatuses = readSprintStatus(projectDir);\n   208→              const storyEntries = mapSprintStatuses(currentStatuses);\n   209→              rendererHandle.updateStories(storyEntries);\n   210→            } catch {\n   211→              // Ignore read errors during polling\n   212→            }\n   213→          }, 5_000);\n   214→        }\n   215→\n   216→        const exitCode = await new Promise<number>((resolve, reject) => {\n   217→          child.on('error', (err) => {\n   218→            if (sprintStateInterval) clearInterval(sprintStateInterval);\n   219→            rendererHandle.cleanup();\n   220→            reject(err);\n   221→          });\n   222→          child.on('close', (code) => {\n   223→            if (sprintStateInterval) clearInterval(sprintStateInterval);\n   224→            rendererHandle.cleanup();\n   225→            resolve(code ?? 1);\n   226→          });\n   227→        });\n   228→\n   229→        // 9. Handle JSON output on exit\n   230→        if (isJson) {\n   231→          const statusFile = join(projectDir, 'ralph', 'status.json');\n   232→          if (existsSync(statusFile)) {\n   233→            try {\n   234→              const statusData = JSON.parse(readFileSync(statusFile, 'utf-8'));\n   235→              const finalStatuses = readSprintStatus(projectDir);\n   236→              const finalCounts = countStories(finalStatuses);\n   237→              jsonOutput({\n   238→                status: statusData.status ?? (exitCode === 0 ? 'completed' : 'stopped'),\n   239→                iterations: statusData.loop_count ?? 0,\n   240→                storiesCompleted: finalCounts.done,\n   241→                storiesTotal: finalCounts.total,\n   242→                storiesRemaining: finalCounts.total - finalCounts.done,\n   243→                elapsedSeconds: statusData.elapsed_seconds ?? 0,\n   244→                flaggedStories: statusData.flagged_stories ?? [],\n   245→                exitReason: statusData.exit_reason ?? '',\n   246→              });\n   247→            } catch {\n   248→              jsonOutput({\n   249→                status: exitCode === 0 ? 'completed' : 'stopped',\n   250→                iterations: 0,\n   251→                storiesCompleted: 0,\n   252→                storiesTotal: counts.total,\n   253→                storiesRemaining: counts.total,\n   254→                elapsedSeconds: 0,\n   255→                flaggedStories: [],\n   256→                exitReason: 'status_file_unreadable',\n   257→              });\n   258→            }\n   259→          } else {\n   260→            // status.json not created (Ralph crashed early or never started)\n   261→            const finalStatuses = readSprintStatus(projectDir);\n   262→            const finalCounts = countStories(finalStatuses);\n   263→            jsonOutput({\n   264→              status: exitCode === 0 ? 'completed' : 'stopped',\n   265→              iterations: 0,\n   266→              storiesCompleted: finalCounts.done,\n   267→              storiesTotal: finalCounts.total,\n   268→              storiesRemaining: finalCounts.total - finalCounts.done,\n   269→              elapsedSeconds: 0,\n   270→              flaggedStories: [],\n   271→              exitReason: 'status_file_missing',\n   272→            });\n   273→          }\n   274→        }\n   275→\n   276→        process.exitCode = exitCode;\n   277→      } catch (err) {\n   278→        if (sprintStateInterval) clearInterval(sprintStateInterval);\n   279→        rendererHandle.cleanup();\n   280→        const message = err instanceof Error ? err.message : String(err);\n   281→        fail(`Failed to start Ralph: ${message}`, outputOpts);\n   282→        process.exitCode = 1;\n   283→      }\n   284→    });\n   285→}\n   286→"}]},"parent_tool_use_id":"toolu_01WHShw3WenWAwXLiDPJ4eCA","session_id":"bd5543f6-f408-4218-88bd-6e3bcdc37563","uuid":"69621cc8-036c-49b0-bd8e-63d399d0ef61","timestamp":"2026-03-24T11:02:02.521Z"}
