━/g) || []).length;\n448\t    expect(separatorCount).toBeGreaterThanOrEqual(2); // header separator + bottom separator\n449\t  });\n450\t});\n451\t\n452\t// --- Controller API Tests ---\n453\t\n454\tdescribe('startRenderer', () => {\n455\t  let handle: RendererHandle | null = null;\n456\t\n457\t  afterEach(() => {\n458\t    if (handle) {\n459\t      handle.cleanup();\n460\t      handle = null;\n461\t    }\n462\t  });\n463\t\n464\t  describe('quiet mode (AC #8)', () => {\n465\t    it('returns no-op handle when quiet is true', () => {\n466\t      handle = startRenderer({ quiet: true });\n467\t      handle.update({ type: 'tool-start', name: 'Bash', id: 'x' });\n468\t      handle.update({ type: 'tool-complete' });\n469\t      handle.update({ type: 'text', text: 'hello' });\n470\t      handle.updateSprintState({ storyKey: 'a', phase: 'b', done: 1, total: 2 });\n471\t      handle.updateStories([{ key: '1-1', status: 'done' }]);\n472\t      handle.addMessage({ type: 'ok', key: '1-1', message: 'DONE' });\n473\t      handle.cleanup();\n474\t      handle.cleanup();\n475\t    });\n476\t  });\n477\t\n478\t  describe('event handling', () => {\n479\t    it('handles tool-start event', () => {\n480\t      handle = startRenderer({ _forceTTY: true });\n481\t      handle.update({ type: 'tool-start', name: 'Bash', id: 'tool1' });\n482\t    });\n483\t\n484\t    it('handles tool-complete after tool-start (moves to completed)', () => {\n485\t      handle = startRenderer({ _forceTTY: true });\n486\t      handle.update({ type: 'tool-start', name: 'Bash', id: 'tool1' });\n487\t      handle.update({ type: 'tool-input', partial: '{\"command\":' });\n488\t      handle.update({ type: 'tool-input', partial: '\"ls\"}' });\n489\t      handle.update({ type: 'tool-complete' });\n490\t    });\n491\t\n492\t    it('handles tool-complete when no activeTool (text block stop)', () => {\n493\t      handle = startRenderer({ _forceTTY: true });\n494\t      handle.update({ type: 'tool-complete' });\n495\t    });\n496\t\n497\t    it('handles text event', () => {\n498\t      handle = startRenderer({ _forceTTY: true });\n499\t      handle.update({ type: 'text', text: 'thinking...' });\n500\t    });\n501\t\n502\t    it('handles retry event', () => {\n503\t      handle = startRenderer({ _forceTTY: true });\n504\t      handle.update({ type: 'retry', attempt: 1, delay: 5000 });\n505\t    });\n506\t\n507\t    it('handles result event and accumulates cost', () => {\n508\t      handle = startRenderer({\n509\t        sprintState: { storyKey: 'a', phase: 'b', done: 1, total: 2 },\n510\t        _forceTTY: true,\n511\t      });\n512\t      handle.update({ type: 'result', cost: 0.05, sessionId: 'sess_123' });\n513\t      // Cost should be accumulated in sprintInfo\n514\t    });\n515\t\n516\t    it('preserves accumulated cost when updateSprintState is called without cost', () => {\n517\t      handle = startRenderer({\n518\t        sprintState: { storyKey: 'a', phase: 'b', done: 1, total: 2 },\n519\t        _forceTTY: true,\n520\t      });\n521\t      // Accumulate cost via result events\n522\t      handle.update({ type: 'result', cost: 0.05, sessionId: 'sess_1' });\n523\t      handle.update({ type: 'result', cost: 0.10, sessionId: 'sess_2' });\n524\t      // Sprint state refresh (simulating the 5s polling interval) should NOT wipe cost\n525\t      handle.updateSprintState({ storyKey: 'a', phase: 'b', done: 2, total: 5, elapsed: '5m', iterationCount: 2 });\n526\t      // Cost should still be preserved (0.15 total) — this test ensures the bug fix works\n527\t    });\n528\t\n529\t    it('clears retry on next tool-start', () => {\n530\t      handle = startRenderer({ _forceTTY: true });\n531\t      handle.update({ type: 'retry', attempt: 1, delay: 5000 });\n532\t      handle.update({ type: 'tool-start', name: 'Bash', id: 'tool1' });\n533\t    });\n534\t\n535\t    it('clears retry on next text event', () => {\n536\t      handle = startRenderer({ _forceTTY: true });\n537\t      handle.update({ type: 'retry', attempt: 1, delay: 5000 });\n538\t      handle.update({ type: 'text', text: 'thinking...' });\n539\t    });\n540\t\n541\t    it('clears lastThought on tool-start', () => {\n542\t      handle = startRenderer({ _forceTTY: true });\n543\t      handle.update({ type: 'text', text: 'old thought' });\n544\t      handle.update({ type: 'tool-start', name: 'Bash', id: 'tool1' });\n545\t    });\n546\t\n547\t    it('text event overwrites previous thought (not append)', () => {\n548\t      handle = startRenderer({ _forceTTY: true });\n549\t      handle.update({ type: 'text', text: 'first thought' });\n550\t      handle.update({ type: 'text', text: 'second thought' });\n551\t    });\n552\t\n553\t    it('accumulates tool input args', () => {\n554\t      handle = startRenderer({ _forceTTY: true });\n555\t      handle.update({ type: 'tool-start', name: 'Write', id: 'tool1' });\n556\t      handle.update({ type: 'tool-input', partial: '{\"path\":' });\n557\t      handle.update({ type: 'tool-input', partial: '\"/tmp/test.ts\",' });\n558\t      handle.update({ type: 'tool-input', partial: '\"content\":\"hello\"}' });\n559\t      handle.update({ type: 'tool-complete' });\n560\t    });\n561\t\n562\t    it('bounds completed tools list at MAX_COMPLETED_TOOLS (50)', () => {\n563\t      handle = startRenderer({ _forceTTY: true });\n564\t      for (let i = 0; i < 55; i++) {\n565\t        handle.update({ type: 'tool-start', name: `Tool${i}`, id: `t${i}` });\n566\t        handle.update({ type: 'tool-input', partial: `arg${i}` });\n567\t        handle.update({ type: 'tool-complete' });\n568\t      }\n569\t    });\n570\t\n571\t    it('handles multiple tool cycles', () => {\n572\t      handle = startRenderer({ _forceTTY: true });\n573\t      handle.update({ type: 'tool-start', name: 'Read', id: 'tool1' });\n574\t      handle.update({ type: 'tool-input', partial: '{\"path\":\"/a\"}' });\n575\t      handle.update({ type: 'tool-complete' });\n576\t      handle.update({ type: 'tool-start', name: 'Write', id: 'tool2' });\n577\t      handle.update({ type: 'tool-input', partial: '{\"path\":\"/b\"}' });\n578\t      handle.update({ type: 'tool-complete' });\n579\t    });\n580\t  });\n581\t\n582\t  describe('updateSprintState', () => {\n583\t    it('updates sprint state', () => {\n584\t      handle = startRenderer({ _forceTTY: true });\n585\t      handle.updateSprintState({\n586\t        storyKey: '0-5-3',\n587\t        phase: 'dev',\n588\t        done: 5,\n589\t        total: 12,\n590\t      });\n591\t    });\n592\t\n593\t    it('clears sprint state with undefined', () => {\n594\t      handle = startRenderer({\n595\t        sprintState: { storyKey: 'x', phase: 'dev', done: 1, total: 2 },\n596\t        _forceTTY: true,\n597\t      });\n598\t      handle.updateSprintState(undefined);\n599\t    });\n600\t  });\n601\t\n602\t  describe('updateStories (AC #4)', () => {\n603\t    it('updates story statuses', () => {\n604\t      handle = startRenderer({ _forceTTY: true });\n605\t      handle.updateStories([\n606\t        { key: '3-1', status: 'done' },\n607\t        { key: '3-2', status: 'in-progress' },\n608\t      ]);\n609\t    });\n610\t\n611\t    it('clears stories with empty array', () => {\n612\t      handle = startRenderer({ _forceTTY: true });\n613\t      handle.updateStories([{ key: '1-1', status: 'done' }]);\n614\t      handle.updateStories([]);\n615\t    });\n616\t  });\n617\t\n618\t  describe('addMessage (AC #5, #6)', () => {\n619\t    it('adds story completion message', () => {\n620\t      handle = startRenderer({ _forceTTY: true });\n621\t      handle.addMessage({ type: 'ok', key: '3-2', message: 'DONE — 12/12 ACs verified' });\n622\t    });\n623\t\n624\t    it('adds story failure message with details', () => {\n625\t      handle = startRenderer({ _forceTTY: true });\n626\t      handle.addMessage({\n627\t        type: 'warn',\n628\t        key: '3-3',\n629\t        message: 'verification found 2 failing ACs',\n630\t        details: ['AC 3: missing headers', 'AC 7: duplicate issues'],\n631\t      });\n632\t    });\n633\t\n634\t    it('accumulates multiple messages', () => {\n635\t      handle = startRenderer({ _forceTTY: true });\n636\t      handle.addMessage({ type: 'ok', key: '3-1', message: 'DONE' });\n637\t      handle.addMessage({ type: 'warn', key: '3-2', message: 'failing' });\n638\t      handle.addMessage({ type: 'fail', key: '2-3', message: 'failed' });\n639\t    });\n640\t  });\n641\t\n642\t  describe('updateWorkflowState', () => {\n643\t    it('updates workflow graph state', () => {\n644\t      handle = startRenderer({ _forceTTY: true });\n645\t      handle.updateWorkflowState(\n646\t        ['create-story', 'implement', 'verify'],\n647\t        'implement',\n648\t        { 'create-story': 'done', 'implement': 'active', 'verify': 'pending' },\n649\t      );\n650\t    });\n651\t\n652\t    it('ignores updates after cleanup', () => {\n653\t      handle = startRenderer({ _forceTTY: true });\n654\t      handle.cleanup();\n655\t      handle.updateWorkflowState(\n656\t        ['task1'],\n657\t        'task1',\n658\t        { task1: 'active' },\n659\t      );\n660\t      handle = null;\n661\t    });\n662\t  });\n663\t\n664\t  describe('quiet mode includes new methods', () => {\n665\t    it('no-op handle has updateStories, addMessage, and updateWorkflowState', () => {\n666\t      handle = startRenderer({ quiet: true });\n667\t      handle.updateStories([{ key: '1-1', status: 'done' }]);\n668\t      handle.addMessage({ type: 'ok', key: '1-1', message: 'DONE' });\n669\t      handle.updateWorkflowState(['task1'], 'task1', { task1: 'active' });\n670\t    });\n671\t  });\n672\t\n673\t  describe('cleanup (AC #6)', () => {\n674\t    it('can be called multiple times without error', () => {\n675\t      handle = startRenderer({ _forceTTY: true });\n676\t      handle.cleanup();\n677\t      handle.cleanup();\n678\t      handle.cleanup();\n679\t      handle = null;\n680\t    });\n681\t\n682\t    it('ignores updates after cleanup', () => {\n683\t      handle = startRenderer({ _forceTTY: true });\n684\t      handle.cleanup();\n685\t      handle.update({ type: 'tool-start', name: 'Bash', id: 'x' });\n686\t      handle.update({ type: 'text', text: 'hello' });\n687\t      handle.updateSprintState({ storyKey: 'a', phase: 'b', done: 1, total: 2 });\n688\t      handle.updateStories([{ key: '1-1', status: 'done' }]);\n689\t      handle.addMessage({ type: 'ok', key: '1-1', message: 'DONE' });\n690\t      handle = null;\n691\t    });\n692\t  });\n693\t\n694\t  describe('signal handling (AC #9)', () => {\n695\t    it('cleans up and re-raises SIGINT', () => {\n696\t      handle = startRenderer({ _forceTTY: true });\n697\t      const killSpy = vi.spyOn(process, 'kill').mockImplementation(() => true);\n698\t      try {\n699\t        process.emit('SIGINT');\n700\t        expect(killSpy).toHaveBeenCalledWith(process.pid, 'SIGINT');\n701\t        handle.update({ type: 'text', text: 'should be ignored' });\n702\t      } finally {\n703\t        killSpy.mockRestore();\n704\t      }\n705\t      handle = null;\n706\t    });\n707\t\n708\t    it('cleans up and re-raises SIGTERM', () => {\n709\t      handle = startRenderer({ _forceTTY: true });\n710\t      const killSpy = vi.spyOn(process, 'kill').mockImplementation(() => true);\n711\t      try {\n712\t        process.emit('SIGTERM');\n713\t        expect(killSpy).toHaveBeenCalledWith(process.pid, 'SIGTERM');\n714\t      } finally {\n715\t        killSpy.mockRestore();\n716\t      }\n717\t      handle = null;\n718\t    });\n719\t  });\n720\t\n721\t  describe('non-TTY fallback (AC #6)', () => {\n722\t    it('returns no-op handle when stdout is not a TTY', () => {\n723\t      handle = startRenderer();\n724\t      handle.update({ type: 'tool-start', name: 'Bash', id: 'x' });\n725\t      handle.update({ type: 'tool-complete' });\n726\t      handle.cleanup();\n727\t      handle = null;\n728\t    });\n729\t  });\n730\t\n731\t  describe('initial sprint state', () => {\n732\t    it('accepts sprint state in options', () => {\n733\t      handle = startRenderer({\n734\t        sprintState: { storyKey: '1-1', phase: 'dev', done: 0, total: 5 },\n735\t        _forceTTY: true,\n736\t      });\n737\t    });\n738\t  });\n739\t});\n740\t\n741\t// --- Integration: full event sequence ---\n742\t\n743\tdescribe('full event sequence', () => {\n744\t  let handle: RendererHandle;\n745\t\n746\t  afterEach(() => {\n747\t    handle?.cleanup();\n748\t  });\n749\t\n750\t  it('processes a realistic stream of events', () => {\n751\t    handle = startRenderer({\n752\t      sprintState: { storyKey: '0-5-3', phase: 'dev', done: 3, total: 10 },\n753\t      _forceTTY: true,\n754\t    });\n755\t\n756\t    const events: StreamEvent[] = [\n757\t      { type: 'text', text: 'Let me analyze...' },\n758\t      { type: 'tool-complete' },\n759\t      { type: 'tool-start', name: 'Read', id: 'tool1' },\n760\t      { type: 'tool-input', partial: '{\"file_path\":\"/src/index.ts\"}' },\n761\t      { type: 'tool-complete' },\n762\t      { type: 'text', text: 'Now I understand the structure' },\n763\t      { type: 'tool-complete' },\n764\t      { type: 'tool-start', name: 'Write', id: 'tool2' },\n765\t      { type: 'tool-input', partial: '{\"file_path\":\"/src/new.ts\",' },\n766\t      { type: 'tool-input', partial: '\"content\":\"export const x = 1;\"}' },\n767\t      { type: 'tool-complete' },\n768\t      { type: 'retry', attempt: 1, delay: 5000 },\n769\t      { type: 'tool-start', name: 'Bash', id: 'tool3' },\n770\t      { type: 'tool-input', partial: '{\"command\":\"npm test\"}' },\n771\t      { type: 'tool-complete' },\n772\t      { type: 'result', cost: 0.15, sessionId: 'sess_abc' },\n773\t    ];\n774\t\n775\t    for (const event of events) {\n776\t      handle.update(event);\n777\t    }\n778\t  });\n779\t});\n780\t\n781\t// --- Visual Snapshot Test (AC #10) ---\n782\t\n783\tdescribe('Visual snapshot: spec-compliant output', () => {\n784\t  it('renders known state matching UX spec format', () => {\n785\t    const state = makeState({\n786\t      sprintInfo: {\n787\t        storyKey: '3-2-bmad-installation-workflow-patching',\n788\t        phase: 'verify',\n789\t        done: 18,\n790\t        total: 65,\n791\t        elapsed: '47m',\n792\t        iterationCount: 3,\n793\t        totalCost: 12.30,\n794\t        acProgress: '8/12',\n795\t        currentCommand: 'docker exec ... codeharness init --json',\n796\t      },\n797\t      stories: [\n798\t        { key: '3-1-first', status: 'done' },\n799\t        { key: '4-1-second', status: 'done' },\n800\t        { key: '4-2-third', status: 'done' },\n801\t        { key: '3-2-bmad-installation-workflow-patching', status: 'in-progress' },\n802\t        { key: '3-3-next', status: 'pending' },\n803\t        { key: '0-1-stuck', status: 'blocked', retryCount: 10, maxRetries: 10 },\n804\t        { key: '13-3-also-stuck', status: 'blocked', retryCount: 10, maxRetries: 10 },\n805\t      ],\n806\t      completedTools: [{ name: 'Bash', args: 'npm test' }],\n807\t      activeTool: null,\n808\t      lastThought: null,\n809\t      retryInfo: null,\n810\t    });\n811\t\n812\t    const { lastFrame } = render(<App state={state} />);\n813\t    const frame = lastFrame()!;\n814\t\n815\t    // Header line: plain text with pipe separators\n816\t    expect(frame).toContain('codeharness run | iteration 3 | 47m elapsed | $12.30 spent');\n817\t\n818\t    // Separator lines (━━━)\n819\t    expect(frame).toContain('━━━');\n820\t\n821\t    // Story and Phase lines\n822\t    expect(frame).toContain('Story: 3-2-bmad-installation-workflow-patching');\n823\t    expect(frame).toContain('Phase: verify');\n824\t    expect(frame).toContain('AC 8/12');\n825\t    expect(frame).toContain('(docker exec ... codeharness init --json)');\n826\t\n827\t    // Labeled story sections\n828\t    expect(frame).toContain('Done:');\n829\t    expect(frame).toContain('3-1 ✓');\n830\t    expect(frame).toContain('4-1 ✓');\n831\t    expect(frame).toContain('4-2 ✓');\n832\t    expect(frame).toContain('This:');\n833\t    expect(frame).toContain('3-2 ◆');\n834\t    expect(frame).toContain('Next:');\n835\t    expect(frame).toContain('3-3');\n836\t    expect(frame).toContain('Blocked:');\n837\t    expect(frame).toContain('0-1 ✕ (10/10)');\n838\t    expect(frame).toContain('13-3 ✕ (10/10)');\n839\t\n840\t    // No Ink Box border artifacts\n841\t    expect(frame).not.toContain('╭');\n842\t    expect(frame).not.toContain('╮');\n843\t    expect(frame).not.toContain('╰');\n844\t    expect(frame).not.toContain('╯');\n845\t    expect(frame).not.toMatch(/│/);\n846\t  });\n847\t\n848\t  it('renders story completion in spec format', () => {\n849\t    const msg: StoryMessage = {\n850\t      type: 'ok',\n851\t      key: '3-2',\n852\t      message: 'DONE — 12/12 ACs verified',\n853\t      details: [\n854\t        'Proof: verification/3-2-proof.md',\n855\t        'Duration: 18m | Cost: $4.20',\n856\t      ],\n857\t    };\n858\t    const { lastFrame } = render(<StoryMessageLine msg={msg} />);\n859\t    const frame = lastFrame()!;\n860\t    expect(frame).toContain('[OK] Story 3-2: DONE — 12/12 ACs verified');\n861\t    expect(frame).toContain('└ Proof: verification/3-2-proof.md');\n862\t    expect(frame).toContain('└ Duration: 18m | Cost: $4.20');\n863\t  });\n864\t\n865\t  it('renders story warning in spec format', () => {\n866\t    const msg: StoryMessage = {\n867\t      type: 'warn',\n868\t      key: '3-3',\n869\t      message: 'verification found 2 failing ACs → returning to dev',\n870\t      details: [\n871\t        'AC 3: bridge --dry-run output missing epic headers',\n872\t        'AC 7: bridge creates duplicate beads issues',\n873\t        'Attempt 2/10 — dev will fix and re-verify',\n874\t      ],\n875\t    };\n876\t    const { lastFrame } = render(<StoryMessageLine msg={msg} />);\n877\t    const frame = lastFrame()!;\n878\t    expect(frame).toContain('[WARN] Story 3-3: verification found 2 failing ACs');\n879\t    expect(frame).toContain('└ AC 3');\n880\t    expect(frame).toContain('└ AC 7');\n881\t    expect(frame).toContain('└ Attempt 2/10');\n882\t  });\n883\t});\n884\t\n885\t// --- Driver Name Integration Tests (via App component rendering) ---\n886\t\n887\tdescribe('driver name in rendered output', () => {\n888\t  it('renders driver name on active tool when activeDriverName is set', () => {\n889\t    const state = makeState({\n890\t      activeTool: { name: 'Bash' },\n891\t      activeToolArgs: '',\n892\t      activeDriverName: 'codex',\n893\t    });\n894\t    const { lastFrame } = render(<App state={state} />);\n895\t    const frame = lastFrame()!;\n896\t    expect(frame).toContain('Bash');\n897\t    expect(frame).toContain('(codex)');\n898\t  });\n899\t\n900\t  it('renders no driver label on active tool when activeDriverName is null', () => {\n901\t    const state = makeState({\n902\t      activeTool: { name: 'Bash' },\n903\t      activeToolArgs: '',\n904\t      activeDriverName: null,\n905\t    });\n906\t    const { lastFrame } = render(<App state={state} />);\n907\t    const frame = lastFrame()!;\n908\t    expect(frame).toContain('Bash');\n909\t    expect(frame).not.toContain('(codex)');\n910\t    expect(frame).not.toContain('(null)');\n911\t    expect(frame).not.toContain('(undefined)');\n912\t  });\n913\t\n914\t  it('renders driver name on completed tool entry', () => {\n915\t    const state = makeState({\n916\t      completedTools: [{ name: 'Edit', args: 'src/foo.ts', driver: 'codex' }],\n917\t    });\n918\t    const { lastFrame } = render(<App state={state} />);\n919\t    const frame = lastFrame()!;\n920\t    expect(frame).toContain('Edit');\n921\t    expect(frame).toContain('(codex)');\n922\t  });\n923\t\n924\t  it('renders no driver on completed tool when driver is undefined', () => {\n925\t    const state = makeState({\n926\t      completedTools: [{ name: 'Edit', args: 'src/foo.ts' }],\n927\t    });\n928\t    const { lastFrame } = render(<App state={stat