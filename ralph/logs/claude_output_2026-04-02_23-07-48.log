{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BZsmVXHybo62mqihmUkxSt","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n2\timport fs from 'node:fs';\n3\timport path from 'node:path';\n4\timport os from 'node:os';\n5\timport YAML from 'yaml';\n6\timport {\n7\t  loadEmbeddedAgent,\n8\t  loadPatch,\n9\t  mergePatch,\n10\t  resolveAgent,\n11\t  compileSubagentDefinition,\n12\t  AgentResolveError,\n13\t} from '../agent-resolver.js';\n14\timport type { ResolvedAgent, AgentPatch } from '../agent-resolver.js';\n15\t\n16\tconst TEMPLATES_DIR = path.resolve(__dirname, '../../../templates/agents');\n17\t\n18\tconst EXPECTED_AGENTS = [\n19\t  'dev', 'qa', 'architect', 'pm', 'sm',\n20\t  'analyst', 'ux-designer', 'tech-writer', 'evaluator',\n21\t];\n22\t\n23\t// --- Helpers ---\n24\t\n25\tfunction makeMinimalAgent(overrides?: Partial<ResolvedAgent>): ResolvedAgent {\n26\t  return {\n27\t    name: 'test-agent',\n28\t    role: { title: 'Test Agent', purpose: 'Testing' },\n29\t    persona: {\n30\t      identity: 'A test agent for unit tests',\n31\t      communication_style: 'Direct and clear',\n32\t      principles: ['Be thorough', 'Be honest'],\n33\t    },\n34\t    ...overrides,\n35\t  };\n36\t}\n37\t\n38\tfunction writeTempYaml(dir: string, relativePath: string, content: unknown): string {\n39\t  const filePath = path.join(dir, relativePath);\n40\t  const dirPath = path.dirname(filePath);\n41\t  fs.mkdirSync(dirPath, { recursive: true });\n42\t  fs.writeFileSync(filePath, YAML.stringify(content), 'utf-8');\n43\t  return filePath;\n44\t}\n45\t\n46\t// --- Tests ---\n47\t\n48\tdescribe('agent-resolver', () => {\n49\t  describe('loadEmbeddedAgent', () => {\n50\t    it('loads dev.yaml and returns valid ResolvedAgent (AC #1)', () => {\n51\t      const agent = loadEmbeddedAgent('dev');\n52\t      expect(agent.name).toBe('dev');\n53\t      expect(agent.role.title).toBeDefined();\n54\t      expect(agent.persona.identity).toBeDefined();\n55\t      expect(agent.persona.communication_style).toBeDefined();\n56\t      expect(Array.isArray(agent.persona.principles)).toBe(true);\n57\t    });\n58\t\n59\t    it('loads evaluator.yaml with disallowedTools (AC #7)', () => {\n60\t      const agent = loadEmbeddedAgent('evaluator');\n61\t      expect(agent.name).toBe('evaluator');\n62\t      expect(agent.disallowedTools).toContain('Edit');\n63\t      expect(agent.disallowedTools).toContain('Write');\n64\t    });\n65\t\n66\t    it('throws AgentResolveError for non-existent embedded agent', () => {\n67\t      expect(() => loadEmbeddedAgent('nonexistent-agent')).toThrow(AgentResolveError);\n68\t      try {\n69\t        loadEmbeddedAgent('nonexistent-agent');\n70\t      } catch (err) {\n71\t        const e = err as AgentResolveError;\n72\t        expect(e.filePath).toContain('nonexistent-agent.yaml');\n73\t        expect(e.errors.length).toBeGreaterThan(0);\n74\t      }\n75\t    });\n76\t\n77\t    it.each(EXPECTED_AGENTS)('loads %s.yaml successfully', (name) => {\n78\t      const agent = loadEmbeddedAgent(name);\n79\t      expect(agent.name).toBe(name);\n80\t    });\n81\t  });\n82\t\n83\t  describe('loadPatch', () => {\n84\t    it('returns null for non-existent file (silent skip, AC #4)', () => {\n85\t      const result = loadPatch('/tmp/nonexistent-patch-file-xyz.yaml');\n86\t      expect(result).toBeNull();\n87\t    });\n88\t\n89\t    it('loads a valid patch file', () => {\n90\t      const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'agent-resolver-'));\n91\t      try {\n92\t        const patchContent = {\n93\t          extends: 'embedded://dev',\n94\t          overrides: { personality: { traits: { rigor: 0.9 } } },\n95\t        };\n96\t        const patchPath = writeTempYaml(tmpDir, 'dev.patch.yaml', patchContent);\n97\t        const result = loadPatch(patchPath);\n98\t        expect(result).not.toBeNull();\n99\t        expect(result!.extends).toBe('embedded://dev');\n100\t        expect(result!.overrides).toEqual({ personality: { traits: { rigor: 0.9 } } });\n101\t      } finally {\n102\t        fs.rmSync(tmpDir, { recursive: true, force: true });\n103\t      }\n104\t    });\n105\t\n106\t    it('throws AgentResolveError on malformed YAML (AC #5)', () => {\n107\t      const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'agent-resolver-'));\n108\t      try {\n109\t        const patchPath = path.join(tmpDir, 'bad.patch.yaml');\n110\t        fs.writeFileSync(patchPath, '{ invalid yaml: [unterminated', 'utf-8');\n111\t        expect(() => loadPatch(patchPath)).toThrow(AgentResolveError);\n112\t        try {\n113\t          loadPatch(patchPath);\n114\t        } catch (err) {\n115\t          const e = err as AgentResolveError;\n116\t          expect(e.filePath).toBe(patchPath);\n117\t          expect(e.errors.length).toBeGreaterThan(0);\n118\t        }\n119\t      } finally {\n120\t        fs.rmSync(tmpDir, { recursive: true, force: true });\n121\t      }\n122\t    });\n123\t  });\n124\t\n125\t  describe('mergePatch', () => {\n126\t    it('deep-merges overrides onto base (AC #2)', () => {\n127\t      const base: Record<string, unknown> = {\n128\t        name: 'dev',\n129\t        persona: {\n130\t          identity: 'A developer',\n131\t          communication_style: 'Direct',\n132\t          principles: ['Be thorough'],\n133\t        },\n134\t      };\n135\t      const patch: AgentPatch = {\n136\t        extends: 'embedded://dev',\n137\t        overrides: {\n138\t          personality: { traits: { rigor: 0.9 } },\n139\t        },\n140\t      };\n141\t      const result = mergePatch(base, patch);\n142\t      expect(result.name).toBe('dev');\n143\t      expect((result.personality as Record<string, unknown>)).toEqual({ traits: { rigor: 0.9 } });\n144\t      // Original fields preserved\n145\t      expect((result.persona as Record<string, unknown>)).toEqual(base.persona);\n146\t    });\n147\t\n148\t    it('arrays replace entirely (not concatenate)', () => {\n149\t      const base: Record<string, unknown> = {\n150\t        name: 'dev',\n151\t        persona: {\n152\t          identity: 'A developer',\n153\t          communication_style: 'Direct',\n154\t          principles: ['Original principle 1', 'Original principle 2'],\n155\t        },\n156\t      };\n157\t      const patch: AgentPatch = {\n158\t        overrides: {\n159\t          persona: {\n160\t            principles: ['New principle only'],\n161\t          },\n162\t        },\n163\t      };\n164\t      const result = mergePatch(base, patch);\n165\t      const persona = result.persona as Record<string, unknown>;\n166\t      expect(persona.principles).toEqual(['New principle only']);\n167\t    });\n168\t\n169\t    it('scalars replace', () => {\n170\t      const base: Record<string, unknown> = {\n171\t        name: 'dev',\n172\t        role: { title: 'Original', purpose: 'Original purpose' },\n173\t      };\n174\t      const patch: AgentPatch = {\n175\t        overrides: {\n176\t          role: { title: 'Patched' },\n177\t        },\n178\t      };\n179\t      const result = mergePatch(base, patch);\n180\t      const role = result.role as Record<string, unknown>;\n181\t      expect(role.title).toBe('Patched');\n182\t      expect(role.purpose).toBe('Original purpose');\n183\t    });\n184\t\n185\t    it('preserves prompt_patches separately (AC #3)', () => {\n186\t      const base: Record<string, unknown> = { name: 'dev' };\n187\t      const patch: AgentPatch = {\n188\t        prompt_patches: { append: 'Extra instructions here.' },\n189\t      };\n190\t      const result = mergePatch(base, patch);\n191\t      expect(result.prompt_patches).toEqual({ append: 'Extra instructions here.' });\n192\t    });\n193\t\n194\t    it('concatenates prompt_patches.append from multiple patches', () => {\n195\t      const base: Record<string, unknown> = {\n196\t        name: 'dev',\n197\t        prompt_patches: { append: 'First instruction.' },\n198\t      };\n199\t      const patch: AgentPatch = {\n200\t        prompt_patches: { append: 'Second instruction.' },\n201\t      };\n202\t      const result = mergePatch(base, patch);\n203\t      const pp = result.prompt_patches as { append: string };\n204\t      expect(pp.append).toContain('First instruction.');\n205\t      expect(pp.append).toContain('Second instruction.');\n206\t    });\n207\t  });\n208\t\n209\t  describe('resolveAgent', () => {\n210\t    let tmpDir: string;\n211\t\n212\t    beforeEach(() => {\n213\t      tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'agent-resolver-'));\n214\t    });\n215\t\n216\t    afterEach(() => {\n217\t      fs.rmSync(tmpDir, { recursive: true, force: true });\n218\t      vi.restoreAllMocks();\n219\t    });\n220\t\n221\t    it('loads embedded dev.yaml with no patches and returns unchanged (AC #1, #4)', () => {\n222\t      // Point to a cwd with no patches\n223\t      const agent = resolveAgent('dev', { cwd: tmpDir });\n224\t      expect(agent.name).toBe('dev');\n225\t      expect(agent.role.title).toBe('Developer Agent');\n226\t      expect(agent.persona.identity).toBeDefined();\n227\t    });\n228\t\n229\t    it('missing user and project patches are silently skipped (AC #4)', () => {\n230\t      // No patches exist in tmpDir or mocked homedir\n231\t      vi.spyOn(os, 'homedir').mockReturnValue(tmpDir);\n232\t      const agent = resolveAgent('dev', { cwd: tmpDir });\n233\t      expect(agent.name).toBe('dev');\n234\t    });\n235\t\n236\t    it('applies user patch with overrides (AC #2)', () => {\n237\t      const userHome = path.join(tmpDir, 'home');\n238\t      vi.spyOn(os, 'homedir').mockReturnValue(userHome);\n239\t\n240\t      writeTempYaml(userHome, '.codeharness/agents/dev.patch.yaml', {\n241\t        extends: 'embedded://dev',\n242\t        overrides: {\n243\t          personality: { traits: { rigor: 0.9 } },\n244\t        },\n245\t      });\n246\t\n247\t      const agent = resolveAgent('dev', { cwd: tmpDir });\n248\t      expect(agent.name).toBe('dev');\n249\t      expect(agent.personality?.traits.rigor).toBe(0.9);\n250\t    });\n251\t\n252\t    it('applies project patch on top of user patch (AC #3)', () => {\n253\t      const userHome = path.join(tmpDir, 'home');\n254\t      const projectDir = path.join(tmpDir, 'project');\n255\t      vi.spyOn(os, 'homedir').mockReturnValue(userHome);\n256\t\n257\t      writeTempYaml(userHome, '.codeharness/agents/dev.patch.yaml', {\n258\t        extends: 'embedded://dev',\n259\t        overrides: {\n260\t          personality: { traits: { rigor: 0.9 } },\n261\t        },\n262\t      });\n263\t\n264\t      writeTempYaml(projectDir, '.codeharness/agents/dev.patch.yaml', {\n265\t        extends: 'embedded://dev',\n266\t        prompt_patches: { append: 'Use React + Vite.' },\n267\t      });\n268\t\n269\t      const agent = resolveAgent('dev', { cwd: projectDir });\n270\t      expect(agent.name).toBe('dev');\n271\t      expect(agent.personality?.traits.rigor).toBe(0.9);\n272\t      expect(agent.prompt_patches?.append).toBe('Use React + Vite.');\n273\t    });\n274\t\n275\t    it('full 3-layer chain: embedded + user + project (AC #2, #3)', () => {\n276\t      const userHome = path.join(tmpDir, 'home');\n277\t      const projectDir = path.join(tmpDir, 'project');\n278\t      vi.spyOn(os, 'homedir').mockReturnValue(userHome);\n279\t\n280\t      writeTempYaml(userHome, '.codeharness/agents/dev.patch.yaml', {\n281\t        extends: 'embedded://dev',\n282\t        overrides: {\n283\t          personality: { traits: { rigor: 0.85 } },\n284\t        },\n285\t        prompt_patches: { append: 'User-level instruction.' },\n286\t      });\n287\t\n288\t      writeTempYaml(projectDir, '.codeharness/agents/dev.patch.yaml', {\n289\t        extends: 'embedded://dev',\n290\t        overrides: {\n291\t          personality: { traits: { directness: 0.7 } },\n292\t        },\n293\t        prompt_patches: { append: 'Project-level instruction.' },\n294\t      });\n295\t\n296\t      const agent = resolveAgent('dev', { cwd: projectDir });\n297\t      expect(agent.personality?.traits.rigor).toBe(0.85);\n298\t      expect(agent.personality?.traits.directness).toBe(0.7);\n299\t      expect(agent.prompt_patches?.append).toContain('User-level instruction.');\n300\t      expect(agent.prompt_patches?.append).toContain('Project-level instruction.');\n301\t    });\n302\t\n303\t    it('throws AgentResolveError for malformed patch (AC #5)', () => {\n304\t      const userHome = path.join(tmpDir, 'home');\n305\t      vi.spyOn(os, 'homedir').mockReturnValue(userHome);\n306\t\n307\t      const patchDir = path.join(userHome, '.codeharness', 'agents');\n308\t      fs.mkdirSync(patchDir, { recursive: true });\n309\t      fs.writeFileSync(path.join(patchDir, 'dev.patch.yaml'), '{ bad yaml [[[', 'utf-8');\n310\t\n311\t      expect(() => resolveAgent('dev', { cwd: tmpDir })).toThrow(AgentResolveError);\n312\t    });\n313\t\n314\t    it('throws AgentResolveError when patch produces schema-invalid result (AC #5)', () => {\n315\t      const userHome = path.join(tmpDir, 'home');\n316\t      vi.spyOn(os, 'homedir').mockReturnValue(userHome);\n317\t\n318\t      // Patch that adds an invalid field (additionalProperties: false in schema)\n319\t      writeTempYaml(userHome, '.codeharness/agents/dev.patch.yaml', {\n320\t        extends: 'embedded://dev',\n321\t        overrides: {\n322\t          unknownTopLevelField: 'this should fail validation',\n323\t        },\n324\t      });\n325\t\n326\t      expect(() => resolveAgent('dev', { cwd: tmpDir })).toThrow(AgentResolveError);\n327\t    });\n328\t\n329\t    it('loads custom agent directly without patch chain (AC #8)', () => {\n330\t      const projectDir = path.join(tmpDir, 'project');\n331\t      vi.spyOn(os, 'homedir').mockReturnValue(path.join(tmpDir, 'home'));\n332\t\n333\t      const customAgent = makeMinimalAgent({ name: 'my-agent' });\n334\t      writeTempYaml(projectDir, '.codeharness/agents/my-agent.yaml', customAgent);\n335\t\n336\t      const agent = resolveAgent('my-agent', { cwd: projectDir });\n337\t      expect(agent.name).toBe('my-agent');\n338\t      expect(agent.role.title).toBe('Test Agent');\n339\t    });\n340\t\n341\t    it('throws AgentResolveError for invalid custom agent (AC #8, #5)', () => {\n342\t      const projectDir = path.join(tmpDir, 'project');\n343\t      vi.spyOn(os, 'homedir').mockReturnValue(path.join(tmpDir, 'home'));\n344\t\n345\t      // Custom agent missing required fields\n346\t      writeTempYaml(projectDir, '.codeharness/agents/bad-agent.yaml', {\n347\t        name: 'bad-agent',\n348\t        // missing role and persona\n349\t      });\n350\t\n351\t      expect(() => resolveAgent('bad-agent', { cwd: projectDir })).toThrow(AgentResolveError);\n352\t    });\n353\t\n354\t    it('resolving all 9 embedded agents completes in <200ms (AC #9)', () => {\n355\t      vi.spyOn(os, 'homedir').mockReturnValue(path.join(tmpDir, 'home'));\n356\t\n357\t      const start = performance.now();\n358\t      for (const name of EXPECTED_AGENTS) {\n359\t        resolveAgent(name, { cwd: tmpDir });\n360\t      }\n361\t      const elapsed = performance.now() - start;\n362\t      expect(elapsed).toBeLessThan(200);\n363\t    });\n364\t  });\n365\t\n366\t  describe('compileSubagentDefinition', () => {\n367\t    it('produces correct instructions string (AC #6)', () => {\n368\t      const agent = makeMinimalAgent();\n369\t      const result = compileSubagentDefinition(agent);\n370\t\n371\t      expect(result.name).toBe('test-agent');\n372\t      expect(result.model).toBe('claude-sonnet-4-20250514');\n373\t      expect(result.bare).toBe(true);\n374\t      expect(result.instructions).toContain('You are A test agent for unit tests');\n375\t      expect(result.instructions).toContain('Communication style: Direct and clear');\n376\t      expect(result.instructions).toContain('Principles:');\n377\t      expect(result.instructions).toContain('- Be thorough');\n378\t      expect(result.instructions).toContain('- Be honest');\n379\t    });\n380\t\n381\t    it('includes prompt_patches.append in instructions (AC #6)', () => {\n382\t      const agent = makeMinimalAgent({\n383\t        prompt_patches: { append: 'Run npm build first.' },\n384\t      });\n385\t      const result = compileSubagentDefinition(agent);\n386\t      expect(result.instructions).toContain('Run npm build first.');\n387\t    });\n388\t\n389\t    it('preserves disallowedTools for evaluator (AC #7)', () => {\n390\t      const agent = loadEmbeddedAgent('evaluator');\n391\t      const result = compileSubagentDefinition(agent);\n392\t      expect(result.disallowedTools).toContain('Edit');\n393\t      expect(result.disallowedTools).toContain('Write');\n394\t      expect(result.disallowedTools).toHaveLength(2);\n395\t    });\n396\t\n397\t    it('returns empty disallowedTools when not present', () => {\n398\t      const agent = makeMinimalAgent();\n399\t      const result = compileSubagentDefinition(agent);\n400\t      expect(result.disallowedTools).toEqual([]);\n401\t    });\n402\t\n403\t    it('sets bare: true always (AD2)', () => {\n404\t      const agent = makeMinimalAgent();\n405\t      const result = compileSubagentDefinition(agent);\n406\t      expect(result.bare).toBe(true);\n407\t    });\n408\t\n409\t    it('sets default model', () => {\n410\t      const agent = makeMinimalAgent();\n411\t      const result = compileSubagentDefinition(agent);\n412\t      expect(result.model).toBe('claude-sonnet-4-20250514');\n413\t    });\n414\t\n415\t    it('compiles real embedded dev agent correctly', () => {\n416\t      const agent = loadEmbeddedAgent('dev');\n417\t      const result = compileSubagentDefinition(agent);\n418\t      expect(result.name).toBe('dev');\n419\t      expect(result.instructions).toContain('You are');\n420\t      expect(result.instructions).toContain('Communication style:');\n421\t      expect(result.instructions).toContain('Principles:');\n422\t      expect(result.disallowedTools).toEqual([]);\n423\t    });\n424\t  });\n425\t\n426\t  describe('AgentResolveError', () => {\n427\t    it('has correct name, filePath, and errors', () => {\n428\t      const err = new AgentResolveError('test error', '/tmp/test.yaml', [\n429\t        { path: '/name', message: 'missing' },\n430\t      ]);\n431\t      expect(err.name).toBe('AgentResolveError');\n432\t      expect(err.filePath).toBe('/tmp/test.yaml');\n433\t      expect(err.errors).toHaveLength(1);\n434\t      expect(err.message).toBe('test error');\n435\t    });\n436\t\n437\t    it('defaults errors to empty array', () => {\n438\t      const err = new AgentResolveError('test', '/tmp/x.yaml');\n439\t      expect(err.errors).toEqual([]);\n440\t    });\n441\t  });\n442\t\n443\t  describe('no regressions', () => {\n444\t    it('existing schema validation still works', async () => {\n445\t      const { validateAgentSchema } = await import('../schema-validate.js');\n446\t      const result = validateAgentSchema(makeMinimalAgent());\n447\t      expect(result.valid).toBe(true);\n448\t    });\n449\t\n450\t    it('existing workflow parser still works', async () => {\n451\t      const { parseWorkflow } = await import('../workflow-parser.js');\n452\t      expect(typeof parseWorkflow).toBe('function');\n453\t    });\n454\t  });\n455\t});\n456\t"}]},"parent_tool_use_id":"toolu_01RPJXyu9D3EThP26t2M9i1U","session_id":"605a3302-c654-40ea-969b-1ce171500852","uuid":"2d91f089-05f2-4e11-af2a-9c57f55e4819","timestamp":"2026-04-02T19:08:49.665Z"}
