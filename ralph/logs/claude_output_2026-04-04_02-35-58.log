{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011kbneSYKCC7dTgLqq1s6me","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { join } from 'node:path';\n3\timport { parse } from 'yaml';\n4\timport { warn } from './output.js';\n5\timport { DispatchError } from './agent-dispatch.js';\n6\timport type { DispatchErrorCode } from './agent-dispatch.js';\n7\t// Note: dispatchAgent is no longer imported — dispatch goes through the driver factory\n8\timport { getDriver } from './agents/drivers/factory.js';\n9\timport { checkCapabilityConflicts } from './agents/capability-check.js';\n10\timport { resolveModel } from './agents/model-resolver.js';\n11\timport type { DispatchOpts, DriverHealth, OutputContract } from './agents/types.js';\n12\timport type { ResultEvent, ToolStartEvent } from './agents/stream-parser.js';\n13\timport type { SubagentDefinition } from './agent-resolver.js';\n14\timport type { ResolvedWorkflow, ResolvedTask, FlowStep, LoopBlock } from './workflow-parser.js';\n15\timport {\n16\t  readWorkflowState,\n17\t  writeWorkflowState,\n18\t} from './workflow-state.js';\n19\timport { buildPromptWithContractContext, writeOutputContract } from './agents/output-contract.js';\n20\timport type { WorkflowState, TaskCheckpoint } from './workflow-state.js';\n21\timport { createIsolatedWorkspace } from './source-isolation.js';\n22\timport { generateTraceId, formatTracePrompt, recordTraceId } from './trace-id.js';\n23\timport { resolveSessionId, recordSessionId } from './session-manager.js';\n24\timport type { SessionLookupKey } from './session-manager.js';\n25\timport { parseVerdict, VerdictParseError } from './verdict-parser.js';\n26\timport type { EvaluatorVerdict } from './verdict-parser.js';\n27\timport { evaluateProgress } from './circuit-breaker.js';\n28\timport { getNullTask, listNullTasks } from './null-task-registry.js';\n29\timport type { TaskContext, NullTaskResult } from './null-task-registry.js';\n30\timport { readStateWithBody, writeState } from './state.js';\n31\timport { formatCoverageContextMessage } from './evaluator.js';\n32\t\n33\t// Re-export EvaluatorVerdict for downstream consumers that import from workflow-engine\n34\texport type { EvaluatorVerdict } from './verdict-parser.js';\n35\texport { parseVerdict } from './verdict-parser.js';\n36\t\n37\t// --- Interfaces ---\n38\t\n39\t/**\n40\t * Configuration for the workflow engine.\n41\t */\n42\texport interface EngineConfig {\n43\t  /** The resolved workflow with tasks and flow steps. */\n44\t  workflow: ResolvedWorkflow;\n45\t  /** Pre-compiled agent definitions keyed by agent name. */\n46\t  agents: Record<string, SubagentDefinition>;\n47\t  /** Path to sprint-status.yaml for work item discovery. */\n48\t  sprintStatusPath: string;\n49\t  /** Optional path to issues.yaml for additional work items. */\n50\t  issuesPath?: string;\n51\t  /** Unique identifier for this engine run. */\n52\t  runId: string;\n53\t  /** Project root directory. Defaults to process.cwd(). */\n54\t  projectDir?: string;\n55\t  /** Maximum loop iterations before termination. Defaults to 5. */\n56\t  maxIterations?: number;\n57\t}\n58\t\n59\t/**\n60\t * Result returned by executeWorkflow().\n61\t */\n62\texport interface EngineResult {\n63\t  /** Whether the workflow completed without errors. */\n64\t  success: boolean;\n65\t  /** Number of task dispatches completed. */\n66\t  tasksCompleted: number;\n67\t  /** Number of work items (stories/issues) processed. */\n68\t  storiesProcessed: number;\n69\t  /** Errors encountered during execution. */\n70\t  errors: EngineError[];\n71\t  /** Wall-clock duration of the entire workflow in milliseconds. */\n72\t  durationMs: number;\n73\t}\n74\t\n75\t/**\n76\t * Structured error recorded during workflow execution.\n77\t */\n78\texport interface EngineError {\n79\t  taskName: string;\n80\t  storyKey: string;"}]},"parent_tool_use_id":"toolu_01Wi8Uj7WejzqFXgoz9DLLYw","session_id":"463