heckSemgrepInstalled\n    57→// ============================================================\n    58→\n    59→describe('checkSemgrepInstalled', () => {\n    60→  it('returns true when semgrep --version succeeds', () => {\n    61→    mockExecFileSync.mockReturnValue(Buffer.from('1.50.0'));\n    62→    expect(checkSemgrepInstalled()).toBe(true);\n    63→    expect(mockExecFileSync).toHaveBeenCalledWith(\n    64→      'semgrep',\n    65→      ['--version'],\n    66→      expect.objectContaining({ encoding: 'utf-8', timeout: 5_000 }),\n    67→    );\n    68→  });\n    69→\n    70→  it('returns false when semgrep is not installed', () => {\n    71→    mockExecFileSync.mockImplementation(() => {\n    72→      throw new Error('ENOENT');\n    73→    });\n    74→    expect(checkSemgrepInstalled()).toBe(false);\n    75→  });\n    76→});\n    77→\n    78→// ============================================================\n    79→// runSemgrep\n    80→// ============================================================\n    81→\n    82→describe('runSemgrep', () => {\n    83→  it('spawns semgrep with correct arguments and parses JSON output', () => {\n    84→    const rawOutput = makeSemgrepOutput([makeSemgrepResult()]);\n    85→    mockExecFileSync.mockReturnValue(JSON.stringify(rawOutput));\n    86→\n    87→    const result = runSemgrep('/project', '/project/patches/observability/');\n    88→    expect(result.success).toBe(true);\n    89→    if (result.success) {\n    90→      expect(result.data.results).toHaveLength(1);\n    91→      expect(result.data.results[0].check_id).toBe('catch-without-logging');\n    92→    }\n    93→\n    94→    expect(mockExecFileSync).toHaveBeenCalledWith(\n    95→      'semgrep',\n    96→      ['scan', '--config', '/project/patches/observability/', '--json', '/project'],\n    97→      expect.objectContaining({ encoding: 'utf-8', timeout: 60_000 }),\n    98→    );\n    99→  });\n   100→\n   101→  it('returns fail when semgrep crashes', () => {\n   102→    mockExecFileSync.mockImplementation(() => {\n   103→      throw new Error('semgrep crashed');\n   104→    });\n   105→\n   106→    const result = runSemgrep('/project', '/rules');\n   107→    expect(result.success).toBe(false);\n   108→    if (!result.success) {\n   109→      expect(result.error).toContain('Semgrep scan failed');\n   110→    }\n   111→  });\n   112→\n   113→  it('accepts a custom timeout', () => {\n   114→    mockExecFileSync.mockReturnValue(JSON.stringify(makeSemgrepOutput([])));\n   115→\n   116→    runSemgrep('/project', '/rules', 30_000);\n   117→    expect(mockExecFileSync).toHaveBeenCalledWith(\n   118→      'semgrep',\n   119→      expect.any(Array),\n   120→      expect.objectContaining({ timeout: 30_000 }),\n   121→    );\n   122→  });\n   123→\n   124→  it('returns fail when semgrep returns invalid JSON without results array', () => {\n   125→    mockExecFileSync.mockReturnValue(JSON.stringify({ errors: [] }));\n   126→\n   127→    const result = runSemgrep('/project', '/rules');\n   128→    expect(result.success).toBe(false);\n   129→    if (!result.success) {\n   130→      expect(result.error).toContain('invalid JSON: missing results array');\n   131→    }\n   132→  });\n   133→\n   134→  it('returns fail when semgrep returns non-object JSON', () => {\n   135→    mockExecFileSync.mockReturnValue('\"just a string\"');\n   136→\n   137→    const result = runSemgrep('/project', '/rules');\n   138→    expect(result.success).toBe(false);\n   139→    if (!result.success) {\n   140→      expect(result.error).toContain('invalid JSON: missing results array');\n   141→    }\n   142→  });\n   143→\n   144→  it('returns fail when semgrep returns null JSON', () => {\n   145→    mockExecFileSync.mockReturnValue('null');\n   146→\n   147→    const result = runSemgrep('/project', '/rules');\n   148→    expect(result.success).toBe(false);\n   149→    if (!result.success) {\n   150→      expect(result.error).toContain('invalid JSON: missing results array');\n   151→    }\n   152→  });\n   153→});\n   154→\n   155→// ============================================================\n   156→// parseSemgrepOutput\n   157→// ============================================================\n   158→\n   159→describe('parseSemgrepOutput', () => {\n   160→  it('maps Semgrep JSON results to ObservabilityGap[]', () => {\n   161→    const raw = makeSemgrepOutput([\n   162→      makeSemgrepResult({\n   163→        check_id: 'catch-without-logging',\n   164→        path: 'src/lib/docker.ts',\n   165→        start: { line: 42, col: 5 },\n   166→        extra: { message: 'Catch block without error logging', severity: 'WARNING' },\n   167→      }),\n   168→      makeSemgrepResult({\n   169→        check_id: 'function-no-debug-log',\n   170→        path: 'src/lib/scanner.ts',\n   171→        start: { line: 10, col: 1 },\n   172→        extra: { message: 'Function without debug log', severity: 'INFO' },\n   173→      }),\n   174→    ]);\n   175→\n   176→    const gaps = parseSemgrepOutput(raw);\n   177→    expect(gaps).toHaveLength(2);\n   178→\n   179→    expect(gaps[0]).toEqual({\n   180→      file: 'src/lib/docker.ts',\n   181→      line: 42,\n   182→      type: 'catch-without-logging',\n   183→      description: 'Catch block without error logging',\n   184→      severity: 'warning',\n   185→    });\n   186→\n   187→    expect(gaps[1]).toEqual({\n   188→      file: 'src/lib/scanner.ts',\n   189→      line: 10,\n   190→      type: 'function-no-debug-log',\n   191→      description: 'Function without debug log',\n   192→      severity: 'info',\n   193→    });\n   194→  });\n   195→\n   196→  it('normalizes ERROR severity to error', () => {\n   197→    const raw = makeSemgrepOutput([\n   198→      makeSemgrepResult({\n   199→        extra: { message: 'bad', severity: 'ERROR' },\n   200→      }),\n   201→    ]);\n   202→    const gaps = parseSemgrepOutput(raw);\n   203→    expect(gaps[0].severity).toBe('error');\n   204→  });\n   205→\n   206→  it('normalizes unknown severity to info', () => {\n   207→    const raw = makeSemgrepOutput([\n   208→      makeSemgrepResult({\n   209→        extra: { message: 'note', severity: 'NOTE' },\n   210→      }),\n   211→    ]);\n   212→    const gaps = parseSemgrepOutput(raw);\n   213→    expect(gaps[0].severity).toBe('info');\n   214→  });\n   215→\n   216→  it('returns empty array for empty results', () => {\n   217→    const raw = makeSemgrepOutput([]);\n   218→    expect(parseSemgrepOutput(raw)).toEqual([]);\n   219→  });\n   220→\n   221→  it('returns empty array when results is undefined', () => {\n   222→    // Defensive: handle malformed input even though types say otherwise\n   223→    const raw = {} as SemgrepRawOutput;\n   224→    expect(parseSemgrepOutput(raw)).toEqual([]);\n   225→  });\n   226→\n   227→  it('returns empty array when results is not an array', () => {\n   228→    const raw = { results: 'not-an-array' } as unknown as SemgrepRawOutput;\n   229→    expect(parseSemgrepOutput(raw)).toEqual([]);\n   230→  });\n   231→});\n   232→\n   233→// ============================================================\n   234→// computeSummary\n   235→// ============================================================\n   236→\n   237→describe('computeSummary', () => {\n   238→  it('computes 75% coverage for 20 functions with 15 having logs (AC #5)', () => {\n   239→    // 5 functions without logs = 5 function-no-debug-log matches\n   240→    const gaps = Array.from({ length: 5 }, (_, i) => ({\n   241→      file: `src/file${i}.ts`,\n   242→      line: i + 1,\n   243→      type: 'function-no-debug-log' as const,\n   244→      description: 'Function without debug log',\n   245→      severity: 'warning' as const,\n   246→    }));\n   247→\n   248→    const summary = computeSummary(gaps, { totalFunctions: 20 });\n   249→    expect(summary.totalFunctions).toBe(20);\n   250→    expect(summary.functionsWithLogs).toBe(15);\n   251→    expect(summary.coveragePercent).toBe(75);\n   252→  });\n   253→\n   254→  it('returns 100% coverage when totalFunctions is 0 (no functions = no gaps)', () => {\n   255→    const summary = computeSummary([]);\n   256→    expect(summary.totalFunctions).toBe(0);\n   257→    expect(summary.functionsWithLogs).toBe(0);\n   258→    expect(summary.coveragePercent).toBe(100);\n   259→  });\n   260→\n   261→  it('counts error handlers without logs', () => {\n   262→    const gaps = [\n   263→      {\n   264→        file: 'a.ts', line: 1, type: 'catch-without-logging',\n   265→        description: 'catch', severity: 'warning' as const,\n   266→      },\n   267→      {\n   268→        file: 'b.ts', line: 2, type: 'error-path-no-log',\n   269→        description: 'err', severity: 'warning' as const,\n   270→      },\n   271→      {\n   272→        file: 'c.ts', line: 3, type: 'function-no-debug-log',\n   273→        description: 'fn', severity: 'info' as const,\n   274→      },\n   275→    ];\n   276→\n   277→    const summary = computeSummary(gaps);\n   278→    expect(summary.errorHandlersWithoutLogs).toBe(2);\n   279→  });\n   280→\n   281→  it('builds level distribution from gap severities', () => {\n   282→    const gaps = [\n   283→      { file: 'a.ts', line: 1, type: 'x', description: '', severity: 'warning' as const },\n   284→      { file: 'b.ts', line: 2, type: 'y', description: '', severity: 'warning' as const },\n   285→      { file: 'c.ts', line: 3, type: 'z', description: '', severity: 'error' as const },\n   286→    ];\n   287→\n   288→    const summary = computeSummary(gaps);\n   289→    expect(summary.levelDistribution).toEqual({ warning: 2, error: 1 });\n   290→  });\n   291→\n   292→  it('without totalFunctions override, uses functionsWithoutLogs count', () => {\n   293→    const gaps = [\n   294→      {\n   295→        file: 'a.ts', line: 1, type: 'function-no-debug-log',\n   296→        description: 'fn', severity: 'warning' as const,\n   297→      },\n   298→      {\n   299→        file: 'b.ts', line: 2, type: 'function-no-debug-log',\n   300→        description: 'fn', severity: 'warning' as const,\n   301→      },\n   302→    ];\n   303→\n   304→    const summary = computeSummary(gaps);\n   305→    // 2 functions without logs, no override, so totalFunctions = 2, functionsWithLogs = 0\n   306→    expect(summary.totalFunctions).toBe(2);\n   307→    expect(summary.functionsWithLogs).toBe(0);\n   308→    expect(summary.coveragePercent).toBe(0);\n   309→  });\n   310→\n   311→  it('handles path-prefixed rule IDs from Semgrep (e.g., tmp.foo.patches.observability.function-no-debug-log)', () => {\n   312→    // Semgrep produces check_ids with path prefixes when rules are loaded from local paths\n   313→    const gaps = [\n   314→      {\n   315→        file: 'a.ts', line: 1,\n   316→        type: 'tmp.test-ac5c.patches.observability.function-no-debug-log',\n   317→        description: 'fn', severity: 'warning' as const,\n   318→      },\n   319→      {\n   320→        file: 'b.ts', line: 2,\n   321→        type: 'tmp.test-ac5c.patches.observability.function-no-debug-log',\n   322→        description: 'fn', severity: 'warning' as const,\n   323→      },\n   324→      {\n   325→        file: 'c.ts', line: 3,\n   326→        type: 'tmp.test-ac5c.patches.observability.function-no-debug-log',\n   327→        description: 'fn', severity: 'warning' as const,\n   328→      },\n   329→      {\n   330→        file: 'd.ts', line: 4,\n   331→        type: 'tmp.test-ac5c.patches.observability.function-no-debug-log',\n   332→        description: 'fn', severity: 'warning' as const,\n   333→      },\n   334→      {\n   335→        file: 'e.ts', line: 5,\n   336→        type: 'tmp.test-ac5c.patches.observability.function-no-debug-log',\n   337→        description: 'fn', severity: 'warning' as const,\n   338→      },\n   339→    ];\n   340→\n   341→    const summary = computeSummary(gaps, { totalFunctions: 20 });\n   342→    expect(summary.totalFunctions).toBe(20);\n   343→    expect(summary.functionsWithLogs).toBe(15);\n   344→    expect(summary.coveragePercent).toBe(75);\n   345→  });\n   346→\n   347→  it('handles path-prefixed error handler rule IDs', () => {\n   348→    const gaps = [\n   349→      {\n   350→        file: 'a.ts', line: 1,\n   351→        type: 'tmp.foo.patches.observability.catch-without-logging',\n   352→        description: 'catch', severity: 'warning' as const,\n   353→      },\n   354→      {\n   355→        file: 'b.ts', line: 2,\n   356→        type: 'tmp.foo.patches.observability.error-path-no-log',\n   357→        description: 'err', severity: 'warning' as const,\n   358→      },\n   359→    ];\n   360→\n   361→    const summary = computeSummary(gaps);\n   362→    expect(summary.errorHandlersWithoutLogs).toBe(2);\n   363→  });\n   364→});\n   365→\n   366→// ============================================================\n   367→// analyze (integration of all pieces)\n   368→// ============================================================\n   369→\n   370→describe('analyze', () => {\n   371→  it('returns Result<AnalyzerResult> with correct structure', () => {\n   372→    // Mock semgrep installed\n   373→    mockExecFileSync\n   374→      .mockReturnValueOnce(Buffer.from('1.50.0')) // checkSemgrepInstalled\n   375→      .mockReturnValueOnce(\n   376→        JSON.stringify(\n   377→          makeSemgrepOutput([\n   378→            makeSemgrepResult({\n   379→              check_id: 'catch-without-logging',\n   380→              path: 'src/app.ts',\n   381→              start: { line: 10, col: 1 },\n   382→              extra: { message: 'Missing log', severity: 'WARNING' },\n   383→            }),\n   384→          ]),\n   385→        ),\n   386→      ); // runSemgrep\n   387→\n   388→    const result = analyze('/project');\n   389→    expect(result.success).toBe(true);\n   390→    if (result.success) {\n   391→      expect(result.data.tool).toBe('semgrep');\n   392→      expect(result.data.gaps).toHaveLength(1);\n   393→      expect(result.data.summary).toBeDefined();\n   394→      expect(result.data.summary.coveragePercent).toBeDefined();\n   395→      expect(result.data.skipped).toBeUndefined();\n   396→    }\n   397→  });\n   398→\n   399→  it('spawns semgrep with correct arguments', () => {\n   400→    mockExecFileSync\n   401→      .mockReturnValueOnce(Buffer.from('1.50.0'))\n   402→      .mockReturnValueOnce(JSON.stringify(makeSemgrepOutput([])));\n   403→\n   404→    analyze('/my/project');\n   405→\n   406→    // Second call is the scan (includes both observability and error-handling rules)\n   407→    expect(mockExecFileSync).toHaveBeenCalledWith(\n   408→      'semgrep',\n   409→      ['scan', '--config', '/my/project/patches/observability/', '--config', '/my/project/patches/error-handling/', '--json', '/my/project'],\n   410→      expect.objectContaining({ encoding: 'utf-8' }),\n   411→    );\n   412→  });\n   413→\n   414→  it('returns ok result with skip warning when semgrep is not installed (AC #3)', () => {\n   415→    mockExecFileSync.mockImplementation(() => {\n   416→      throw new Error('ENOENT');\n   417→    });\n   418→\n   419→    const result = analyze('/project');\n   420→    expect(result.success).toBe(true);\n   421→    if (result.success) {\n   422→      expect(result.data.skipped).toBe(true);\n   423→      expect(result.data.skipReason).toBe(\n   424→        'static analysis skipped -- install semgrep',\n   425→      );\n   426→      expect(result.data.gaps).toEqual([]);\n   427→      expect(result.data.summary.coveragePercent).toBe(0);\n   428→    }\n   429→  });\n   430→\n   431→  it('returns fail when projectDir is empty', () => {\n   432→    const result = analyze('');\n   433→    expect(result.success).toBe(false);\n   434→    if (!result.success) {\n   435→      expect(result.error).toContain('projectDir is required');\n   436→    }\n   437→  });\n   438→\n   439→  it('returns fail for unsupported tool', () => {\n   440→    const result = analyze('/project', { tool: 'eslint' });\n   441→    expect(result.success).toBe(false);\n   442→    if (!result.success) {\n   443→      expect(result.error).toContain('Unsupported analyzer tool: eslint');\n   444→    }\n   445→  });\n   446→\n   447→  it('returns fail when semgrep scan fails', () => {\n   448→    // semgrep installed\n   449→    mockExecFileSync\n   450→      .mockReturnValueOnce(Buffer.from('1.50.0'))\n   451→      .mockImplementationOnce(() => {\n   452→        throw new Error('scan error');\n   453→      });\n   454→\n   455→    const result = analyze('/project');\n   456→    expect(result.success).toBe(false);\n   457→    if (!result.success) {\n   458→      expect(result.error).toContain('Semgrep scan failed');\n   459→    }\n   460→  });\n   461→\n   462→  it('passes totalFunctions from config to computeSummary for accurate coverage', () => {\n   463→    const gaps = Array.from({ length: 5 }, (_, i) =>\n   464→      makeSemgrepResult({\n   465→        check_id: 'function-no-debug-log',\n   466→        path: `src/file${i}.ts`,\n   467→        start: { line: i + 1, col: 1 },\n   468→        extra: { message: 'Function without debug log', severity: 'INFO' },\n   469→      }),\n   470→    );\n   471→    mockExecFileSync\n   472→      .mockReturnValueOnce(Buffer.from('1.50.0'))\n   473→      .mockReturnValueOnce(JSON.stringify(makeSemgrepOutput(gaps)));\n   474→\n   475→    const result = analyze('/project', { totalFunctions: 20 });\n   476→    expect(result.success).toBe(true);\n   477→    if (result.success) {\n   478→      expect(result.data.summary.totalFunctions).toBe(20);\n   479→      expect(result.data.summary.functionsWithLogs).toBe(15);\n   480→      expect(result.data.summary.coveragePercent).toBe(75);\n   481→    }\n   482→  });\n   483→\n   484→  it('defaults to conservative 0% coverage when totalFunctions not provided', () => {\n   485→    const gaps = [\n   486→      makeSemgrepResult({\n   487→        check_id: 'function-no-debug-log',\n   488→        path: 'src/file.ts',\n   489→        start: { line: 1, col: 1 },\n   490→        extra: { message: 'fn', severity: 'INFO' },\n   491→      }),\n   492→    ];\n   493→    mockExecFileSync\n   494→      .mockReturnValueOnce(Buffer.from('1.50.0'))\n   495→      .mockReturnValueOnce(JSON.stringify(makeSemgrepOutput(gaps)));\n   496→\n   497→    const result = analyze('/project');\n   498→    expect(result.success).toBe(true);\n   499→    if (result.success) {\n   500→      // Without totalFunctions, defaults to functionsWithoutLogs count\n   501→      expect(result.data.summary.totalFunctions).toBe(1);\n   502→      expect(result.data.summary.functionsWithLogs).toBe(0);\n   503→      expect(result.data.summary.coveragePercent).toBe(0);\n   504→    }\n   505→  });\n   506→\n   507→  it('uses custom rulesDir and timeout from config', () => {\n   508→    mockExecFileSync\n   509→      .mockReturnValueOnce(Buffer.from('1.50.0'))\n   510→      .mockReturnValueOnce(JSON.stringify(makeSemgrepOutput([])));\n   511→\n   512→    analyze('/project', { rulesDir: 'custom/rules/', timeout: 30_000 });\n   513→\n   514→    expect(mockExecFileSync).toHaveBeenCalledWith(\n   515→      'semgrep',\n   516→      ['scan', '--config', '/project/custom/rules/', '--config', '/project/patches/error-handling/', '--json', '/project'],\n   517→      expect.objectContaining({ timeout: 30_000 }),\n   518→    );\n   519→  });\n   520→});\n   521→"}]},"parent_tool_use_id":"toolu_01RaXV75NMTprbvd4KMPDvjb","session_id":"3fcb2b1c-e710-401b-91ab-b64a3e9a3996","uuid":"bbd213ea-f725-47ba-8a8d-93e6478550a5","timestamp":"2026-03-25T06:58:39.845Z"}
