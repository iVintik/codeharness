);\n644\t    });\n645\t  });\n646\t\n647\t  describe('cleanup (AC #6)', () => {\n648\t    it('can be called multiple times without error', () => {\n649\t      handle = startRenderer({ _forceTTY: true });\n650\t      handle.cleanup();\n651\t      handle.cleanup();\n652\t      handle.cleanup();\n653\t      handle = null;\n654\t    });\n655\t\n656\t    it('ignores updates after cleanup', () => {\n657\t      handle = startRenderer({ _forceTTY: true });\n658\t      handle.cleanup();\n659\t      handle.update({ type: 'tool-start', name: 'Bash', id: 'x' });\n660\t      handle.update({ type: 'text', text: 'hello' });\n661\t      handle.updateSprintState({ storyKey: 'a', phase: 'b', done: 1, total: 2 });\n662\t      handle.updateStories([{ key: '1-1', status: 'done' }]);\n663\t      handle.addMessage({ type: 'ok', key: '1-1', message: 'DONE' });\n664\t      handle = null;\n665\t    });\n666\t  });\n667\t\n668\t  describe('signal handling (AC #9)', () => {\n669\t    it('cleans up and re-raises SIGINT', () => {\n670\t      handle = startRenderer({ _forceTTY: true });\n671\t      const killSpy = vi.spyOn(process, 'kill').mockImplementation(() => true);\n672\t      try {\n673\t        process.emit('SIGINT');\n674\t        expect(killSpy).toHaveBeenCalledWith(process.pid, 'SIGINT');\n675\t        handle.update({ type: 'text', text: 'should be ignored' });\n676\t      } finally {\n677\t        killSpy.mockRestore();\n678\t      }\n679\t      handle = null;\n680\t    });\n681\t\n682\t    it('cleans up and re-raises SIGTERM', () => {\n683\t      handle = startRenderer({ _forceTTY: true });\n684\t      const killSpy = vi.spyOn(process, 'kill').mockImplementation(() => true);\n685\t      try {\n686\t        process.emit('SIGTERM');\n687\t        expect(killSpy).toHaveBeenCalledWith(process.pid, 'SIGTERM');\n688\t      } finally {\n689\t        killSpy.mockRestore();\n690\t      }\n691\t      handle = null;\n692\t    });\n693\t  });\n694\t\n695\t  describe('non-TTY fallback (AC #6)', (