{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Tg4qPHBjFk1srmssmwP7LH","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach } from 'vitest';\n2\t\n3\t// --- Hoisted Mocks ---\n4\t\n5\tconst {\n6\t  mockGetDriver,\n7\t  mockReadWorkflowState,\n8\t  mockWriteWorkflowState,\n9\t  mockWarn,\n10\t  mockReadFileSync,\n11\t  mockExistsSync,\n12\t  mockParse,\n13\t  mockResolveModel,\n14\t  mockDriverDispatch,\n15\t  mockDispatchAgent,\n16\t  mockCreateIsolatedWorkspace,\n17\t  mockGenerateTraceId,\n18\t  mockFormatTracePrompt,\n19\t  mockRecordTraceId,\n20\t  mockResolveSessionId,\n21\t  mockRecordSessionId,\n22\t} = vi.hoisted(() => ({\n23\t  mockGetDriver: vi.fn(),\n24\t  mockReadWorkflowState: vi.fn(),\n25\t  mockWriteWorkflowState: vi.fn(),\n26\t  mockWarn: vi.fn(),\n27\t  mockReadFileSync: vi.fn(),\n28\t  mockExistsSync: vi.fn(),\n29\t  mockParse: vi.fn(),\n30\t  mockResolveModel: vi.fn(),\n31\t  mockDriverDispatch: vi.fn(),\n32\t  mockDispatchAgent: vi.fn(),\n33\t  mockCreateIsolatedWorkspace: vi.fn(),\n34\t  mockGenerateTraceId: vi.fn(),\n35\t  mockFormatTracePrompt: vi.fn(),\n36\t  mockRecordTraceId: vi.fn(),\n37\t  mockResolveSessionId: vi.fn(),\n38\t  mockRecordSessionId: vi.fn(),\n39\t}));\n40\t\n41\tvi.mock('../agents/drivers/factory.js', () => ({\n42\t  getDriver: mockGetDriver,\n43\t}));\n44\t\n45\tvi.mock('../agents/model-resolver.js', () => ({\n46\t  resolveModel: mockResolveModel,\n47\t}));\n48\t\n49\tvi.mock('../agent-dispatch.js', () => ({\n50\t  dispatchAgent: mockDispatchAgent,\n51\t  DispatchError: class DispatchError extends Error {\n52\t    public readonly code: string;\n53\t    public readonly agentName: string;\n54\t    public readonly cause: unknown;\n55\t    constructor(message: string, code: string, agentName: string, cause: unknown) {\n56\t      super(message);\n57\t      this.name = 'DispatchError';\n58\t      this.code = code;\n59\t      this.agentName = agentName;\n60\t      this.cause = cause;\n61\t    }\n62\t  },\n63\t}));\n64\t\n65\tvi.mock('../workflow-state.js', () => ({\n66\t  readWorkflowState: mockReadWorkflowState,\n67\t  writeWorkflowState: mockWriteWorkflowState,\n68\t  getDefaultWorkflowState: () => ({\n69\t    workflow_name: '',\n70\t    started: '',\n71\t    iteration: 0,\n72\t    phase: 'idle',\n73\t    tasks_completed: [],\n74\t    evaluator_scores: [],\n75\t    circuit_breaker: { triggered: false, reason: null, score_history: [] },\n76\t    trace_ids: [],\n77\t  }),\n78\t}));\n79\t\n80\tvi.mock('../source-isolation.js', () => ({\n81\t  createIsolatedWorkspace: mockCreateIsolatedWorkspace,\n82\t}));\n83\t\n84\tvi.mock('../trace-id.js', () => ({\n85\t  generateTraceId: mockGenerateTraceId,\n86\t  formatTracePrompt: mockFormatTracePrompt,\n87\t  recordTraceId: mockRecordTraceId,\n88\t}));\n89\t\n90\tvi.mock('../session-manager.js', () => ({\n91\t  resolveSessionId: mockResolveSessionId,\n92\t  recordSessionId: mockRecordSessionId,\n93\t}));\n94\t\n95\tvi.mock('../output.js', () => ({\n96\t  warn: mockWarn,\n97\t}));\n98\t\n99\tvi.mock('node:fs', () => ({\n100\t  readFileSync: mockReadFileSync,\n101\t  existsSync: mockExistsSync,\n102\t}));\n103\t\n104\tvi.mock('yaml', () => ({\n105\t  parse: mockParse,\n106\t}));\n107\t\n108\timport { checkDriverHealth, executeWorkflow } from '../workflow-engine.js';\n109\timport type { EngineConfig } from '../workflow-engine.js';\n110\timport type { ResolvedWorkflow, ResolvedTask } from '../workflow-parser.js';\n111\timport type { DriverHealth } from '../agents/types.js';\n112\t\n113\t// --- Helpers ---\n114\t\n115\tfunction makeTask(overrides?: Partial<ResolvedTask>): ResolvedTask {\n116\t  return {\n117\t    agent: 'dev',\n118\t    scope: 'per-story',\n119\t    session: 'fresh',\n120\t    source_access: true,\n121\t    ...overrides,\n122\t  };\n123\t}\n124\t\n125\tfunction makeMockDriver(name: string, health: DriverHealth) {\n126\t  return {\n127\t    name,\n128\t    defaultModel: 'test-model',\n129\t    capabilities: { supportsPlugins: false, supportsStreaming: true, costReporting: true },\n130\t    healthCheck: vi.fn().mockResolvedValue(health),\n131\t    dispatch: vi.fn(),\n132\t    getLastCost: vi.fn().mockReturnValue(null),\n133\t  };\n134\t}\n135\t\n136\tfunction makeHealthy(): DriverHealth {\n137\t  return { available: true, authenticated: true, version: '1.0.0' };\n138\t}\n139\t\n140\tfunction makeUnhealthy(error: string): DriverHealth {\n141\t  return { available: false, authenticated: false, version: null, error };\n142\t}\n143\t\n144\t// --- Tests ---\n145\t\n146\tdescribe('checkDriverHealth', () => {\n147\t  beforeEach(() => {\n148\t    vi.clearAllMocks();\n149\t  });\n150\t\n151\t  it('succeeds when a single driver passes health check', async () => {\n152\t    const workflow: ResolvedWorkflow = {\n153\t      tasks: { implement: makeTask({ driver: 'claude-code' }) },\n154\t      flow: ['implement'],\n155\t    };\n156\t\n157\t    const driver = makeMockDriver('claude-code', makeHealthy());\n158\t    mockGetDriver.mockReturnValue(driver);\n159\t\n160\t    await expect(checkDriverHealth(workflow)).resolves.toBeUndefined();\n161\t    expect(driver.healthCheck).toHaveBeenCalledOnce();\n162\t  });\n163\t\n164\t  it('succeeds when multiple unique drivers all pass', async () => {\n165\t    const workflow: ResolvedWorkflow = {\n166\t      tasks: {\n167\t        implement: makeTask({ driver: 'claude-code' }),\n168\t        codexTask: makeTask({ driver: 'codex' }),\n169\t      },\n170\t      flow: ['implement', 'codexTask'],\n171\t    };\n172\t\n173\t    const claudeDriver = makeMockDriver('claude-code', makeHealthy());\n174\t    const codexDriver = makeMockDriver('codex', makeHealthy());\n175\t    mockGetDriver.mockImplementation((name: string) => {\n176\t      if (name === 'claude-code') return claudeDriver;\n177\t      if (name === 'codex') return codexDriver;\n178\t      throw new Error(`Unknown driver: ${name}`);\n179\t    });\n180\t\n181\t    await expect(checkDriverHealth(workflow)).resolves.toBeUndefined();\n182\t    expect(claudeDriver.healthCheck).toHaveBeenCalledOnce();\n183\t    expect(codexDriver.healthCheck).toHaveBeenCalledOnce();\n184\t  });\n185\t\n186\t  it('deduplicates drivers — healthCheck called once per unique driver', async () => {\n187\t    const workflow: ResolvedWorkflow = {\n188\t      tasks: {\n189\t        task1: makeTask({ driver: 'claude-code' }),\n190\t        task2: makeTask({ driver: 'claude-code' }),\n191\t        task3: makeTask({ driver: 'claude-code' }),\n192\t      },\n193\t      flow: ['task1', 'task2', 'task3'],\n194\t    };\n195\t\n196\t    const driver = makeMockDriver('claude-code', makeHealthy());\n197\t    mockGetDriver.mockReturnValue(driver);\n198\t\n199\t    await expect(checkDriverHealth(workflow)).resolves.toBeUndefined();\n200\t    expect(mockGetDriver).toHaveBeenCalledTimes(1);\n201\t    expect(driver.healthCheck).toHaveBeenCalledOnce();\n202\t  });\n203\t\n204\t  it('throws when one driver fails, listing the failing driver and error', async () => {\n205\t    const workflow: ResolvedWorkflow = {\n206\t      tasks: {\n207\t        implement: makeTask({ driver: 'claude-code' }),\n208\t        codexTask: makeTask({ driver: 'codex' }),\n209\t      },\n210\t      flow: ['implement', 'codexTask'],\n211\t    };\n212\t\n213\t    const claudeDriver = makeMockDriver('claude-code', makeHealthy());\n214\t    const codexDriver = makeMockDriver('codex', makeUnhealthy('codex CLI not found'));\n215\t    mockGetDriver.mockImplementation((name: string) => {\n216\t      if (name === 'claude-code') return claudeDriver;\n217\t      if (name === 'codex') return codexDriver;\n218\t      throw new Error(`Unknown driver: ${name}`);\n219\t    });\n220\t\n221\t    await expect(checkDriverHealth(workflow)).rejects.toThrow('Driver health check failed');\n222\t    await expect(checkDriverHealth(workflow)).rejects.toThrow('codex: codex CLI not found');\n223\t  });\n224\t\n225\t  it('throws listing ALL failing drivers when multiple fail', async () => {\n226\t    const workflow: ResolvedWorkflow = {\n227\t      tasks: {\n228\t        task1: makeTask({ driver: 'claude-code' }),\n229\t        task2: makeTask({ driver: 'codex' }),\n230\t        task3: makeTask({ driver: 'opencode' }),\n231\t      },\n232\t      flow: ['task1', 'task2', 'task3'],\n233\t    };\n234\t\n235\t    const claudeDriver = makeMockDriver('claude-code', makeUnhealthy('claude not found'));\n236\t    const codexDriver = makeMockDriver('codex', makeUnhealthy('codex not found'));\n237\t    const opencodeDriver = makeMockDriver('opencode', makeHealthy());\n238\t    mockGetDriver.mockImplementation((name: string) => {\n239\t      if (name === 'claude-code') return claudeDriver;\n240\t      if (name === 'codex') return codexDriver;\n241\t      if (name === 'opencode') return opencodeDriver;\n242\t      throw new Error(`Unknown driver: ${name}`);\n243\t    });\n244\t\n245\t    try {\n246\t      await checkDriverHealth(workflow);\n247\t      expect.fail('Should have thrown');\n248\t    } catch (err: unknown) {\n249\t      const message = (err as Error).message;\n250\t      expect(message).toContain('claude-code: claude not found');\n251\t      expect(message).toContain('codex: codex not found');\n252\t    }\n253\t  });\n254\t\n255\t  it('defaults to claude-code when task has no driver field', async () => {\n256\t    const workflow: ResolvedWorkflow = {\n257\t      tasks: {\n258\t        task1: makeTask(), // no driver field — defaults to claude-code\n259\t        task2: makeTask(), // also no driver field\n260\t      },\n261\t      flow: ['task1', 'task2'],\n262\t    };\n263\t\n264\t    const driver = makeMockDriver('claude-code', makeHealthy());\n265\t    mockGetDriver.mockReturnValue(driver);\n266\t\n267\t    await expect(checkDriverHealth(workflow)).resolves.toBeUndefined();\n268\t    expect(mockGetDriver).toHaveBeenCalledTimes(1);\n269\t    expect(mockGetDriver).toHaveBeenCalledWith('claude-code');\n270\t    expect(driver.healthCheck).toHaveBeenCalledOnce();\n271\t  });\n272\t\n273\t  it('throws on timeout when health check hangs', async () => {\n274\t    const workflow: ResolvedWorkflow = {\n275\t      tasks: { implement: makeTask({ driver: 'claude-code' }) },\n276\t      flow: ['implement'],\n277\t    };\n278\t\n279\t    const hangingDriver = {\n280\t      name: 'claude-code',\n281\t      defaultModel: 'test-model',\n282\t      capabilities: { supportsPlugins: false, supportsStreaming: true, costReporting: true },\n283\t      // Resolves after 200ms — longer than the 50ms timeout we'll pass\n284\t      healthCheck: vi.fn().mockImplementation(() => new Promise((resolve) => {\n285\t        setTimeout(() => resolve(makeHealthy()), 200);\n286\t      })),\n287\t      dispatch: vi.fn(),\n288\t      getLastCost: vi.fn().mockReturnValue(null),\n289\t    };\n290\t    mockGetDriver.mockReturnValue(hangingDriver);\n291\t\n292\t    // Use a very short timeout (50ms) to test the timeout path without fake timers\n293\t    await expect(checkDriverHealth(workflow, 50)).rejects.toThrow('Driver health check timed out');\n294\t  });\n295\t});\n296\t\n297\tdescribe('executeWorkflow — health check integration', () => {\n298\t  beforeEach(() => {\n299\t    vi.clearAllMocks();\n300\t    vi.useRealTimers();\n301\t  });\n302\t\n303\t  it('skips health checks for completed workflows', async () => {\n304\t    mockReadWorkflowState.mockReturnValue({\n305\t      workflow_name: '',\n306\t      started: '',\n307\t      iteration: 0,\n308\t      phase: 'completed',\n309\t      tasks_completed: [],\n310\t      evaluator_scores: [],\n311\t      circuit_breaker: { triggered: false, reason: null, score_history: [] },\n312\t      trace_ids: [],\n313\t    });\n314\t\n315\t    const config: EngineConfig = {\n316\t      workflow: {\n317\t        tasks: { implement: makeTask({ driver: 'claude-code' }) },\n318\t        flow: ['implement'],\n319\t      },\n320\t      agents: { dev: { name: 'dev', model: 'test', instructions: '', disallowedTools: [], bare: true } },\n321\t      sprintStatusPath: '/tmp/sprint-status.yaml',\n322\t      runId: 'test-run',\n323\t      projectDir: '/tmp/test',\n324\t    };\n325\t\n326\t    const result = await executeWorkflow(config);\n327\t\n328\t    expect(result.success).toBe(true);\n329\t    expect(result.tasksCompleted).toBe(0);\n330\t    // getDriver should NOT have been called (no health check)\n331\t    expect(mockGetDriver).not.toHaveBeenCalled();\n332\t  });\n333\t\n334\t  it('aborts with success=false when health check fails', async () => {\n335\t    mockReadWorkflowState.mockReturnValue({\n336\t      workflow_name: '',\n337\t      started: '',\n338\t      iteration: 0,\n339\t      phase: 'idle',\n340\t      tasks_completed: [],\n341\t      evaluator_scores: [],\n342\t      circuit_breaker: { triggered: false, reason: null, score_history: [] },\n343\t      trace_ids: [],\n344\t    });\n345\t\n346\t    const failingDriver = makeMockDriver('claude-code', makeUnhealthy('CLI not found'));\n347\t    mockGetDriver.mockReturnValue(failingDriver);\n348\t\n349\t    const config: EngineConfig = {\n350\t      workflow: {\n351\t        tasks: { implement: makeTask({ driver: 'claude-code' }) },\n352\t        flow: ['implement'],\n353\t      },\n354\t      agents: { dev: { name: 'dev', model: 'test', instructions: '', disallowedTools: [], bare: true } },\n355\t      sprintStatusPath: '/tmp/sprint-status.yaml',\n356\t      runId: 'test-run',\n357\t      projectDir: '/tmp/test',\n358\t    };\n359\t\n360\t    const result = await executeWorkflow(config);\n361\t\n362\t    expect(result.success).toBe(false);\n363\t    expect(result.tasksCompleted).toBe(0);\n364\t    expect(result.storiesProcessed).toBe(0);\n365\t    expect(result.errors).toHaveLength(1);\n366\t    expect(result.errors[0].code).toBe('HEALTH_CHECK');\n367\t    expect(result.errors[0].message).toContain('CLI not found');\n368\t\n369\t    // Verify state was written as 'failed'\n370\t    const writeStateCalls = mockWriteWorkflowState.mock.calls;\n371\t    const lastState = writeStateCalls[writeStateCalls.length - 1][0];\n372\t    expect(lastState.phase).toBe('failed');\n373\t  });\n374\t\n375\t  it('proceeds normally when all health checks pass', async () => {\n376\t    mockReadWorkflowState.mockReturnValue({\n377\t      workflow_name: '',\n378\t      started: '',\n379\t      iteration: 0,\n380\t      phase: 'idle',\n381\t      tasks_completed: [],\n382\t      evaluator_scores: [],\n383\t      circuit_breaker: { triggered: false, reason: null, score_history: [] },\n384\t      trace_ids: [],\n385\t    });\n386\t\n387\t    const healthyDriver = makeMockDriver('claude-code', makeHealthy());\n388\t    // Make dispatch return a valid stream for actual task execution\n389\t    healthyDriver.dispatch.mockReturnValue((async function* () {\n390\t      yield { type: 'text' as const, text: 'done' };\n391\t      yield { type: 'result' as const, cost: 0.01, sessionId: 'sess-1' };\n392\t    })());\n393\t    mockGetDriver.mockReturnValue(healthyDriver);\n394\t    mockResolveModel.mockReturnValue('test-model');\n395\t    mockGenerateTraceId.mockReturnValue('trace-1');\n396\t    mockFormatTracePrompt.mockReturnValue('');\n397\t    mockResolveSessionId.mockReturnValue(null);\n398\t    mockRecordTraceId.mockImplementation((_, s) => s);\n399\t    mockRecordSessionId.mockImplementation((_, __, s) => s);\n400\t\n401\t    // No work items (empty sprint status)\n402\t    mockExistsSync.mockReturnValue(false);\n403\t\n404\t    const config: EngineConfig = {\n405\t      workflow: {\n406\t        tasks: { implement: makeTask({ driver: 'claude-code', scope: 'per-run' }) },\n407\t        flow: ['implement'],\n408\t      },\n409\t      agents: { dev: { name: 'dev', model: 'test', instructions: '', disallowedTools: [], bare: true } },\n410\t      sprintStatusPath: '/tmp/sprint-status.yaml',\n411\t      runId: 'test-run',\n412\t      projectDir: '/tmp/test',\n413\t    };\n414\t\n415\t    const result = await executeWorkflow(config);\n416\t\n417\t    // Health check should have been called\n418\t    expect(healthyDriver.healthCheck).toHaveBeenCalledOnce();\n419\t    // Workflow should have proceeded (dispatch was called for per-run task)\n420\t    expect(healthyDriver.dispatch).toHaveBeenCalled();\n421\t    expect(result.success).toBe(true);\n422\t  });\n423\t});\n424\t"}]},"parent_tool_use_id":"toolu_01Pu3wXi4pA6EPLQcEQK8Uxb","session_id":"b101ea9e-2f9e-4377-9c5a-f109fa318b32","uuid":"883d2821-ca1d-4111-901a-019f5dac8543","timestamp":"2026-04-03T09:47:27.571Z"}
