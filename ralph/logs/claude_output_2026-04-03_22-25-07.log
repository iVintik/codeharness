     vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n194\t      vi.mocked(dispatchAgent).mockResolvedValue(makeDispatchResult());\n195\t      vi.mocked(formatTracePrompt).mockReturnValue('[TRACE] trace_id=ch-run-0-verify');\n196\t\n197\t      await runEvaluator(makeOptions({ traceId: 'ch-run-0-verify' }));\n198\t\n199\t      expect(formatTracePrompt).toHaveBeenCalledWith('ch-run-0-verify');\n200\t      expect(dispatchAgent).toHaveBeenCalledWith(\n201\t        expect.anything(),\n202\t        expect.anything(),\n203\t        expect.objectContaining({\n204\t          appendSystemPrompt: '[TRACE] trace_id=ch-run-0-verify',\n205\t        }),\n206\t      );\n207\t    });\n208\t\n209\t    it('does not set appendSystemPrompt when no traceId', async () => {\n210\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n211\t      const mockWorkspace = makeMockWorkspace();\n212\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n213\t      vi.mocked(dispatchAgent).mockResolvedValue(makeDispatchResult());\n214\t\n215\t      await runEvaluator(makeOptions({ traceId: undefined }));\n216\t\n217\t      expect(formatTracePrompt).not.toHaveBeenCalled();\n218\t      const callArgs = vi.mocked(dispatchAgent).mock.calls[0][2];\n219\t      expect(callArgs?.appendSystemPrompt).toBeUndefined();\n220\t    });\n221\t  });\n222\t\n223\t  describe('timeout handling', () => {\n224\t    it('returns UNKNOWN result with timedOut=true on timeout', async () => {\n225\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n226\t      const mockWorkspace = makeMockWorkspace();\n227\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n228\t\n229\t      // dispatchAgent never resolves\n230\t      vi.mocked(dispatchAgent).mockReturnValue(new Promise(() => {}));\n231\t\n232\t      vi.useFakeTimers();\n233\t\n234\t      const resultPromise = runEvaluator(makeOptions({ timeoutMs: 1000 }));\n235\t\n236\t      // Advance time past the timeout\n237\t      await vi.advanceTimersByTimeAsync(1001);\n238\t\n239\t      const result = await resultPromise;\n240\t\n241\t      expect(result.timedOut).toBe(true);\n242\t      expect(result.success).toBe(false);\n243\t      expect(result.dockerAvailable).toBe(true);\n244\t\n245\t      const parsed = JSON.parse(result.output);\n246\t      expect(parsed.verdict).toBe('fail');\n247\t      expect(parsed.findings[0].status).toBe('unknown');\n248\t      expect(parsed.findings[0].evidence.reasoning).toContain('timed out');\n249\t    });\n250\t\n251\t    it('uses default timeout of 300000ms when timeoutMs not specified', async () => {\n252\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n253\t      const mockWorkspace = makeMockWorkspace();\n254\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n255\t      vi.mocked(dispatchAgent).mockReturnValue(new Promise(() => {}));\n256\t\n257\t      vi.useFakeTimers();\n258\t\n259\t      const resultPromise = runEvaluator(makeOptions());\n260\t\n261\t      // Should not have timed out at 299999ms\n262\t      await vi.advanceTimersByTimeAsync(299_999);\n263\t      // Verify still pending — we can't directly check, but advancing past 300000 should resolve it\n264\t      await vi.advanceTimersByTimeAsync(2);\n265\t\n266\t      const result = await resultPromise;\n267\t      expect(result.timedOut).toBe(true);\n268\t    });\n269\t  });\n270\t\n271\t  describe('cleanup', () => {\n272\t    it('calls cleanup on successful dispatch', async () => {\n273\t      vi.mocked(isDockerAvailable).mockReturnValue(true);\n274\t      const mockWorkspace = makeMockWorkspace();\n275\t      vi.mocked(createIsolatedWorkspace).mockResolvedValue(mockWorkspace);\n276\t      vi.mocked(dispatchAgent).mockResolvedValue(makeDispatchResult());\n277\t\n278\t      await runEvaluator(makeOptions());\n279\t\n280\t      expect(mockWorkspace.cleanup).toHaveBeenCalledTimes(1);\n281\t    });\n282\t\n283\t    it('calls cleanup 