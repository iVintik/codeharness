{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SmYiSkmnWwmRHKfWoQtHuY","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n2\timport { EventEmitter, Readable } from 'node:stream';\n3\t\n4\t// --- Mock child_process ---\n5\t\n6\tconst mockSpawn = vi.fn();\n7\tconst mockExecFile = vi.fn();\n8\t\n9\tvi.mock('node:child_process', () => ({\n10\t  spawn: (...args: unknown[]) => mockSpawn(...args),\n11\t  execFile: (...args: unknown[]) => mockExecFile(...args),\n12\t}));\n13\t\n14\timport { CodexDriver, parseLine, classifyError } from '../drivers/codex.js';\n15\timport type { DispatchOpts } from '../types.js';\n16\timport type { StreamEvent, ResultEvent } from '../stream-parser.js';\n17\t\n18\t// --- Helpers ---\n19\t\n20\tfunction makeOpts(overrides?: Partial<DispatchOpts>): DispatchOpts {\n21\t  return {\n22\t    prompt: 'Do the thing',\n23\t    model: 'codex-mini',\n24\t    cwd: '/tmp/test',\n25\t    sourceAccess: true,\n26\t    ...overrides,\n27\t  };\n28\t}\n29\t\n30\tasync function collectEvents(iterable: AsyncIterable<StreamEvent>): Promise<StreamEvent[]> {\n31\t  const events: StreamEvent[] = [];\n32\t  for await (const event of iterable) {\n33\t    events.push(event);\n34\t  }\n35\t  return events;\n36\t}\n37\t\n38\t/**\n39\t * Create a mock child process that emits given stdout lines and exits with given code.\n40\t */\n41\tfunction createMockProcess(stdoutLines: string[], exitCode = 0, stderrData = ''): {\n42\t  proc: EventEmitter & {\n43\t    stdout: Readable;\n44\t    stderr: EventEmitter & { on: ReturnType<typeof vi.fn> };\n45\t    kill: ReturnType<typeof vi.fn>;\n46\t  };\n47\t} {\n48\t  const stdout = new Readable({ read() {} });\n49\t  const stderr = new EventEmitter();\n50\t  const proc = new EventEmitter() as EventEmitter & {\n51\t    stdout: Readable;\n52\t    stderr: EventEmitter & { on: ReturnType<typeof vi.fn> };\n53\t    kill: ReturnType<typeof vi.fn>;\n54\t  };\n55\t  proc.stdout = stdout;\n56\t  proc.stderr = stderr as EventEmitter & { on: ReturnType<typeof vi.fn> };\n57\t  proc.kill = vi.fn(() => {\n58\t    // When killed, close the process\n59\t    setTimeout(() => {\n60\t      stdout.push(null);\n61\t      proc.emit('close', 1);\n62\t    }, 5);\n63\t  });\n64\t\n65\t  // Push stderr data\n66\t  if (stderrData) {\n67\t    setTimeout(() => {\n68\t      stderr.emit('data', Buffer.from(stderrData));\n69\t    }, 1);\n70\t  }\n71\t\n72\t  // Push lines to stdout, then close\n73\t  setTimeout(() => {\n74\t    for (const line of stdoutLines) {\n75\t      stdout.push(line + '\\n');\n76\t    }\n77\t    stdout.push(null);\n78\t\n79\t    // Emit close after stdout is consumed\n80\t    setTimeout(() => {\n81\t      proc.emit('close', exitCode);\n82\t    }, 10);\n83\t  }, 1);\n84\t\n85\t  return { proc };\n86\t}\n87\t\n88\t// --- Fixtures as inline data ---\n89\t\n90\tconst SUCCESS_LINES = [\n91\t  '{\"type\":\"tool_call\",\"name\":\"file_read\",\"call_id\":\"call_001\"}',\n92\t  '{\"type\":\"tool_input\",\"call_id\":\"call_001\",\"input\":\"{\\\\\"path\\\\\":\\\\\"/src/index.ts\\\\\"}\"}',\n93\t  '{\"type\":\"tool_result\",\"call_id\":\"call_001\",\"output\":\"file contents here\"}',\n94\t  '{\"type\":\"message\",\"content\":\"I\\'ve read the file and will now make changes.\"}',\n95\t  '{\"type\":\"tool_call\",\"name\":\"file_write\",\"call_id\":\"call_002\"}',\n96\t  '{\"type\":\"tool_input\",\"call_id\":\"call_002\",\"input\":\"{\\\\\"path\\\\\":\\\\\"/src/index.ts\\\\\",\\\\\"content\\\\\":\\\\\"updated\\\\\"}\"}',\n97\t  '{\"type\":\"tool_result\",\"call_id\":\"call_002\",\"output\":\"File written successfully.\"}',\n98\t  '{\"type\":\"message\",\"content\":\"Done. I updated the file.\"}',\n99\t  '{\"type\":\"result\",\"status\":\"completed\",\"cost_usd\":0.0034,\"session_id\":\"codex-sess-abc123\"}',\n100\t];\n101\t\n102\tconst UNPARSEABLE_LINES = [\n103\t  'Loading codex v0.1.2...',\n104\t  'Connecting to OpenAI API...',\n105\t  '[spinner] Working...',\n106\t  'not json at all {{{',\n107\t];\n108\t\n109\t// --- Tests ---\n110\t\n111\tdescribe('CodexDriver', () => {\n112\t  let driver: CodexDriver;\n113\t\n114\t  beforeEach(() => {\n115\t    vi.clearAllMocks();\n116\t    driver = new CodexDriver();\n117\t  });\n118\t\n119\t  afterEach(() => {\n120\t    vi.restoreAllMocks();\n121\t  });\n122\t\n123\t  describe('class properties (AC #1)', () => {\n124\t    it('has name \"codex\"', () => {\n125\t      expect(driver.name).toBe('codex');\n126\t    });\n127\t\n128\t    it('has defaultModel \"codex-mini\"', () => {\n129\t      expect(driver.defaultModel).toBe('codex-mini');\n130\t    });\n131\t\n132\t    it('has correct capabilities', () => {\n133\t      expect(driver.capabilities).toEqual({\n134\t        supportsPlugins: false,\n135\t        supportsStreaming: true,\n136\t        costReporting: true,\n137\t      });\n138\t    });\n139\t  });\n140\t\n141\t  describe('parseLine (AC #2)', () => {\n142\t    it('parses tool_call to tool-start event', () => {\n143\t      const event = parseLine('{\"type\":\"tool_call\",\"name\":\"file_read\",\"call_id\":\"call_001\"}');\n144\t      expect(event).toEqual({ type: 'tool-start', name: 'file_read', id: 'call_001' });\n145\t    });\n146\t\n147\t    it('parses tool_input to tool-input event', () => {\n148\t      const event = parseLine('{\"type\":\"tool_input\",\"call_id\":\"c1\",\"input\":\"{\\\\\"path\\\\\":\\\\\"/a\\\\\"}\"}');\n149\t      expect(event).toEqual({ type: 'tool-input', partial: '{\"path\":\"/a\"}' });\n150\t    });\n151\t\n152\t    it('parses tool_result to tool-complete event', () => {\n153\t      const event = parseLine('{\"type\":\"tool_result\",\"call_id\":\"c1\",\"output\":\"ok\"}');\n154\t      expect(event).toEqual({ type: 'tool-complete' });\n155\t    });\n156\t\n157\t    it('parses message to text event', () => {\n158\t      const event = parseLine('{\"type\":\"message\",\"content\":\"Hello\"}');\n159\t      expect(event).toEqual({ type: 'text', text: 'Hello' });\n160\t    });\n161\t\n162\t    it('parses retry to retry event', () => {\n163\t      const event = parseLine('{\"type\":\"retry\",\"attempt\":2,\"delay_ms\":5000}');\n164\t      expect(event).toEqual({ type: 'retry', attempt: 2, delay: 5000 });\n165\t    });\n166\t\n167\t    it('parses result with cost', () => {\n168\t      const event = parseLine('{\"type\":\"result\",\"cost_usd\":0.0034,\"session_id\":\"sess-123\"}');\n169\t      expect(event).toEqual({\n170\t        type: 'result',\n171\t        cost: 0.0034,\n172\t        sessionId: 'sess-123',\n173\t        cost_usd: 0.0034,\n174\t      });\n175\t    });\n176\t\n177\t    it('parses result without cost (cost_usd is null)', () => {\n178\t      const event = parseLine('{\"type\":\"result\",\"status\":\"completed\",\"session_id\":\"sess-123\"}');\n179\t      expect(event).toEqual({\n180\t        type: 'result',\n181\t        cost: 0,\n182\t        sessionId: 'sess-123',\n183\t        cost_usd: null,\n184\t      });\n185\t    });\n186\t\n187\t    it('returns null for empty lines', () => {\n188\t      expect(parseLine('')).toBeNull();\n189\t      expect(parseLine('   ')).toBeNull();\n190\t    });\n191\t\n192\t    it('returns null for invalid JSON', () => {\n193\t      expect(parseLine('not json at all {{{')).toBeNull();\n194\t    });\n195\t\n196\t    it('returns null for unrecognized type', () => {\n197\t      expect(parseLine('{\"type\":\"unknown_event\",\"data\":\"foo\"}')).toBeNull();\n198\t    });\n199\t\n200\t    it('returns null for arrays', () => {\n201\t      expect(parseLine('[1,2,3]')).toBeNull();\n202\t    });\n203\t\n204\t    it('returns null for primitives', () => {\n205\t      expect(parseLine('\"hello\"')).toBeNull();\n206\t      expect(parseLine('42')).toBeNull();\n207\t    });\n208\t\n209\t    it('returns null for tool_call missing name', () => {\n210\t      expect(parseLine('{\"type\":\"tool_call\",\"call_id\":\"c1\"}')).toBeNull();\n211\t    });\n212\t\n213\t    it('returns null for tool_call missing call_id', () => {\n214\t      expect(parseLine('{\"type\":\"tool_call\",\"name\":\"file_read\"}')).toBeNull();\n215\t    });\n216\t\n217\t    it('returns null for tool_input with non-string input', () => {\n218\t      expect(parseLine('{\"type\":\"tool_input\",\"call_id\":\"c1\",\"input\":42}')).toBeNull();\n219\t    });\n220\t\n221\t    it('returns null for message with non-string content', () => {\n222\t      expect(parseLine('{\"type\":\"message\",\"content\":42}')).toBeNull();\n223\t    });\n224\t\n225\t    it('returns null for message with missing content', () => {\n226\t      expect(parseLine('{\"type\":\"message\"}')).toBeNull();\n227\t    });\n228\t\n229\t    it('returns null for retry with non-number attempt', () => {\n230\t      expect(parseLine('{\"type\":\"retry\",\"attempt\":\"two\",\"delay_ms\":5000}')).toBeNull();\n231\t    });\n232\t\n233\t    it('returns null for retry with non-number delay', () => {\n234\t      expect(parseLine('{\"type\":\"retry\",\"attempt\":2,\"delay_ms\":\"slow\"}')).toBeNull();\n235\t    });\n236\t  });\n237\t\n238\t  describe('classifyError (AC #4)', () => {\n239\t    it('classifies 429 status as RATE_LIMIT', () => {\n240\t      const err = Object.assign(new Error('Rate limit'), { status: 429 });\n241\t      expect(classifyError(err)).toBe('RATE_LIMIT');\n242\t    });\n243\t\n244\t    it('classifies \"rate limit\" in message as RATE_LIMIT', () => {\n245\t      expect(classifyError('You have exceeded your rate limit')).toBe('RATE_LIMIT');\n246\t    });\n247\t\n248\t    it('classifies ECONNREFUSED code as NETWORK', () => {\n249\t      const err = Object.assign(new Error('connect failed'), { code: 'ECONNREFUSED' });\n250\t      expect(classifyError(err)).toBe('NETWORK');\n251\t    });\n252\t\n253\t    it('classifies ECONNREFUSED in message string as NETWORK (via fetch match)', () => {\n254\t      expect(classifyError('fetch failed: connect ECONNREFUSED 127.0.0.1:443')).toBe('NETWORK');\n255\t    });\n256\t\n257\t    it('classifies ECONNREFUSED in message string as NETWORK (via code regex)', () => {\n258\t      expect(classifyError('connect ECONNREFUSED 127.0.0.1:443')).toBe('NETWORK');\n259\t    });\n260\t\n261\t    it('classifies ETIMEDOUT code as NETWORK', () => {\n262\t      const err = Object.assign(new Error('request timed out'), { code: 'ETIMEDOUT' });\n263\t      expect(classifyError(err)).toBe('NETWORK');\n264\t    });\n265\t\n266\t    it('classifies fetch failure message as NETWORK', () => {\n267\t      expect(classifyError('fetch failed: DNS resolution error')).toBe('NETWORK');\n268\t    });\n269\t\n270\t    it('classifies 401 status as AUTH', () => {\n271\t      const err = Object.assign(new Error('Unauthorized'), { status: 401 });\n272\t      expect(classifyError(err)).toBe('AUTH');\n273\t    });\n274\t\n275\t    it('classifies 403 status as AUTH', () => {\n276\t      const err = Object.assign(new Error('Forbidden'), { status: 403 });\n277\t      expect(classifyError(err)).toBe('AUTH');\n278\t    });\n279\t\n280\t    it('classifies \"unauthorized\" in message as AUTH', () => {\n281\t      expect(classifyError('Unauthorized. Please check your API key')).toBe('AUTH');\n282\t    });\n283\t\n284\t    it('classifies timeout in message as TIMEOUT', () => {\n285\t      expect(classifyError('operation timed out')).toBe('TIMEOUT');\n286\t    });\n287\t\n288\t    it('classifies unknown errors as UNKNOWN', () => {\n289\t      expect(classifyError('Something unexpected happened')).toBe('UNKNOWN');\n290\t    });\n291\t\n292\t    it('follows priority order: rate limit before network', () => {\n293\t      // An error with both rate limit message and network code\n294\t      const err = Object.assign(new Error('rate limit reached'), { code: 'ECONNRESET' });\n295\t      expect(classifyError(err)).toBe('RATE_LIMIT');\n296\t    });\n297\t\n298\t    it('follows priority order: network before auth', () => {\n299\t      const err = Object.assign(new Error('forbidden'), { code: 'ECONNREFUSED' });\n300\t      expect(classifyError(err)).toBe('NETWORK');\n301\t    });\n302\t  });\n303\t\n304\t  describe('dispatch — successful flow (AC #2, #3, #8)', () => {\n305\t    it('produces correct StreamEvent sequence from fixture lines', async () => {\n306\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n307\t      mockSpawn.mockReturnValue(proc);\n308\t\n309\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n310\t      const types = events.map((e) => e.type);\n311\t\n312\t      expect(types).toEqual([\n313\t        'tool-start',\n314\t        'tool-input',\n315\t        'tool-complete',\n316\t        'text',\n317\t        'tool-start',\n318\t        'tool-input',\n319\t        'tool-complete',\n320\t        'text',\n321\t        'result',\n322\t      ]);\n323\t    });\n324\t\n325\t    it('result event is always the last event', async () => {\n326\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n327\t      mockSpawn.mockReturnValue(proc);\n328\t\n329\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n330\t      expect(events[events.length - 1].type).toBe('result');\n331\t    });\n332\t\n333\t    it('captures cost from CLI output', async () => {\n334\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n335\t      mockSpawn.mockReturnValue(proc);\n336\t\n337\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n338\t      const resultEvent = events.find((e) => e.type === 'result') as ResultEvent;\n339\t      expect(resultEvent.cost_usd).toBe(0.0034);\n340\t      expect(resultEvent.cost).toBe(0.0034);\n341\t    });\n342\t\n343\t    it('getLastCost returns cost after dispatch', async () => {\n344\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n345\t      mockSpawn.mockReturnValue(proc);\n346\t\n347\t      await collectEvents(driver.dispatch(makeOpts()));\n348\t      expect(driver.getLastCost()).toBe(0.0034);\n349\t    });\n350\t  });\n351\t\n352\t  describe('dispatch — cost handling (AC #3)', () => {\n353\t    it('cost_usd is null when CLI does not report cost', async () => {\n354\t      const lines = [\n355\t        '{\"type\":\"message\",\"content\":\"Done.\"}',\n356\t        '{\"type\":\"result\",\"status\":\"completed\",\"session_id\":\"sess-no-cost\"}',\n357\t      ];\n358\t      const { proc } = createMockProcess(lines, 0);\n359\t      mockSpawn.mockReturnValue(proc);\n360\t\n361\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n362\t      const resultEvent = events.find((e) => e.type === 'result') as ResultEvent;\n363\t      expect(resultEvent.cost_usd).toBeNull();\n364\t    });\n365\t\n366\t    it('getLastCost returns null before any dispatch', () => {\n367\t      expect(driver.getLastCost()).toBeNull();\n368\t    });\n369\t\n370\t    it('getLastCost resets on new dispatch', async () => {\n371\t      // First dispatch with cost\n372\t      const { proc: proc1 } = createMockProcess(SUCCESS_LINES, 0);\n373\t      mockSpawn.mockReturnValue(proc1);\n374\t      await collectEvents(driver.dispatch(makeOpts()));\n375\t      expect(driver.getLastCost()).toBe(0.0034);\n376\t\n377\t      // Second dispatch without cost\n378\t      const lines = ['{\"type\":\"result\",\"status\":\"completed\",\"session_id\":\"s\"}'];\n379\t      const { proc: proc2 } = createMockProcess(lines, 0);\n380\t      mockSpawn.mockReturnValue(proc2);\n381\t      await collectEvents(driver.dispatch(makeOpts()));\n382\t      expect(driver.getLastCost()).toBeNull();\n383\t    });\n384\t  });\n385\t\n386\t  describe('dispatch — error handling (AC #4)', () => {\n387\t    it('yields result with RATE_LIMIT on rate limit stderr', async () => {\n388\t      const { proc } = createMockProcess(\n389\t        [],\n390\t        1,\n391\t        'Error: Request failed with status 429: You have exceeded your rate limit.',\n392\t      );\n393\t      mockSpawn.mockReturnValue(proc);\n394\t\n395\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n396\t      const resultEvent = events.find((e) => e.type === 'result') as ResultEvent;\n397\t      expect(resultEvent.errorCategory).toBe('RATE_LIMIT');\n398\t    });\n399\t\n400\t    it('yields result with AUTH on auth failure stderr', async () => {\n401\t      const { proc } = createMockProcess(\n402\t        [],\n403\t        1,\n404\t        'Error: Request failed with status 401: Unauthorized.',\n405\t      );\n406\t      mockSpawn.mockReturnValue(proc);\n407\t\n408\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n409\t      const resultEvent = events.find((e) => e.type === 'result') as ResultEvent;\n410\t      expect(resultEvent.errorCategory).toBe('AUTH');\n411\t    });\n412\t\n413\t    it('yields result with NETWORK on network failure stderr', async () => {\n414\t      const { proc } = createMockProcess(\n415\t        [],\n416\t        1,\n417\t        'Error: fetch failed: connect ECONNREFUSED 127.0.0.1:443',\n418\t      );\n419\t      mockSpawn.mockReturnValue(proc);\n420\t\n421\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n422\t      const resultEvent = events.find((e) => e.type === 'result') as ResultEvent;\n423\t      expect(resultEvent.errorCategory).toBe('NETWORK');\n424\t    });\n425\t\n426\t    it('yields result with UNKNOWN on unrecognized error', async () => {\n427\t      const { proc } = createMockProcess([], 1, 'Something went wrong');\n428\t      mockSpawn.mockReturnValue(proc);\n429\t\n430\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n431\t      const resultEvent = events.find((e) => e.type === 'result') as ResultEvent;\n432\t      expect(resultEvent.errorCategory).toBe('UNKNOWN');\n433\t    });\n434\t\n435\t    it('always yields exactly one result event on error', async () => {\n436\t      const { proc } = createMockProcess([], 1, 'kaboom');\n437\t      mockSpawn.mockReturnValue(proc);\n438\t\n439\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n440\t      const resultEvents = events.filter((e) => e.type === 'result');\n441\t      expect(resultEvents).toHaveLength(1);\n442\t    });\n443\t  });\n444\t\n445\t  describe('dispatch — result guarantee (AC #2)', () => {\n446\t    it('yields result even when stdout is empty and exit code is 0', async () => {\n447\t      const { proc } = createMockProcess([], 0);\n448\t      mockSpawn.mockReturnValue(proc);\n449\t\n450\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n451\t      const resultEvents = events.filter((e) => e.type === 'result');\n452\t      expect(resultEvents).toHaveLength(1);\n453\t    });\n454\t\n455\t    it('yields exactly one result from normal flow', async () => {\n456\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n457\t      mockSpawn.mockReturnValue(proc);\n458\t\n459\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n460\t      const resultEvents = events.filter((e) => e.type === 'result');\n461\t      expect(resultEvents).toHaveLength(1);\n462\t    });\n463\t  });\n464\t\n465\t  describe('dispatch — timeout (AC #6)', () => {\n466\t    it('kills process on timeout and yields TIMEOUT result', async () => {\n467\t      // Create a process that never completes on its own\n468\t      const stdout = new Readable({ read() {} });\n469\t      const stderr = new EventEmitter();\n470\t      const proc = new EventEmitter() as EventEmitter & {\n471\t        stdout: Readable;\n472\t        stderr: EventEmitter;\n473\t        kill: ReturnType<typeof vi.fn>;\n474\t      };\n475\t      proc.stdout = stdout;\n476\t      proc.stderr = stderr;\n477\t      proc.kill = vi.fn(() => {\n478\t        // When killed, end the streams and emit close\n479\t        setTimeout(() => {\n480\t          stdout.push(null);\n481\t          proc.emit('close', 1);\n482\t        }, 5);\n483\t      });\n484\t\n485\t      mockSpawn.mockReturnValue(proc);\n486\t\n487\t      const events = await collectEvents(driver.dispatch(makeOpts({ timeout: 50 })));\n488\t      const resultEvent = events.find((e) => e.type === 'result') as ResultEvent;\n489\t\n490\t      expect(proc.kill).toHaveBeenCalled();\n491\t      expect(resultEvent).toBeDefined();\n492\t      expect(resultEvent.errorCategory).toBe('TIMEOUT');\n493\t    });\n494\t  });\n495\t\n496\t  describe('dispatch — plugins warning (AC #7)', () => {\n497\t    it('logs warning when plugins are provided', async () => {\n498\t      const warnSpy = vi.spyOn(console, 'warn').mockImplementation(() => {});\n499\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n500\t      mockSpawn.mockReturnValue(proc);\n501\t\n502\t      await collectEvents(driver.dispatch(makeOpts({ plugins: ['some-plugin'] })));\n503\t\n504\t      expect(warnSpy).toHaveBeenCalledWith(\n505\t        '[CodexDriver] Codex does not support plugins. Ignoring plugins:',\n506\t        ['some-plugin'],\n507\t      );\n508\t      warnSpy.mockRestore();\n509\t    });\n510\t\n511\t    it('proceeds normally despite plugins', async () => {\n512\t      vi.spyOn(console, 'warn').mockImplementation(() => {});\n513\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n514\t      mockSpawn.mockReturnValue(proc);\n515\t\n516\t      const events = await collectEvents(driver.dispatch(makeOpts({ plugins: ['p1'] })));\n517\t      expect(events.length).toBeGreaterThan(0);\n518\t      expect(events[events.length - 1].type).toBe('result');\n519\t    });\n520\t\n521\t    it('does not warn when plugins is empty', async () => {\n522\t      const warnSpy = vi.spyOn(console, 'warn').mockImplementation(() => {});\n523\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n524\t      mockSpawn.mockReturnValue(proc);\n525\t\n526\t      await collectEvents(driver.dispatch(makeOpts({ plugins: [] })));\n527\t\n528\t      expect(warnSpy).not.toHaveBeenCalled();\n529\t      warnSpy.mockRestore();\n530\t    });\n531\t  });\n532\t\n533\t  describe('dispatch — unparseable lines (AC #2)', () => {\n534\t    it('skips unparseable lines and logs them at debug level', async () => {\n535\t      const debugSpy = vi.spyOn(console, 'debug').mockImplementation(() => {});\n536\t      const lines = [\n537\t        ...UNPARSEABLE_LINES,\n538\t        '{\"type\":\"result\",\"cost_usd\":0.01,\"session_id\":\"s1\"}',\n539\t      ];\n540\t      const { proc } = createMockProcess(lines, 0);\n541\t      mockSpawn.mockReturnValue(proc);\n542\t\n543\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n544\t\n545\t      // Only the result event should be yielded\n546\t      expect(events).toHaveLength(1);\n547\t      expect(events[0].type).toBe('result');\n548\t\n549\t      // All 4 unparseable lines should be debug-logged\n550\t      expect(debugSpy).toHaveBeenCalledTimes(4);\n551\t      debugSpy.mockRestore();\n552\t    });\n553\t  });\n554\t\n555\t  describe('dispatch — event ordering (AC #8)', () => {\n556\t    it('events follow tool-start -> tool-input -> tool-complete, text, result ordering', async () => {\n557\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n558\t      mockSpawn.mockReturnValue(proc);\n559\t\n560\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n561\t      const types = events.map((e) => e.type);\n562\t\n563\t      // Verify no result event before the end\n564\t      const resultIndex = types.indexOf('result');\n565\t      expect(resultIndex).toBe(types.length - 1);\n566\t\n567\t      // Verify tool sequences are ordered correctly\n568\t      // First tool use: tool-start, tool-input, tool-complete\n569\t      expect(types[0]).toBe('tool-start');\n570\t      expect(types[1]).toBe('tool-input');\n571\t      expect(types[2]).toBe('tool-complete');\n572\t      // Then text\n573\t      expect(types[3]).toBe('text');\n574\t    });\n575\t  });\n576\t\n577\t  describe('healthCheck (AC #5)', () => {\n578\t    it('returns available: true when binary is found', async () => {\n579\t      mockExecFile.mockImplementation(\n580\t        (cmd: string, args: string[], cb: (err: Error | null, result: { stdout: string }) => void) => {\n581\t          if (cmd === 'which') {\n582\t            cb(null, { stdout: '/usr/local/bin/codex\\n' });\n583\t          } else if (args[0] === '--version') {\n584\t            cb(null, { stdout: '0.1.2\\n' });\n585\t          } else if (args[0] === 'auth') {\n586\t            cb(null, { stdout: 'authenticated\\n' });\n587\t          }\n588\t        },\n589\t      );\n590\t\n591\t      const health = await driver.healthCheck();\n592\t      expect(health.available).toBe(true);\n593\t      expect(health.version).toBe('0.1.2');\n594\t      expect(health.authenticated).toBe(true);\n595\t    });\n596\t\n597\t    it('returns available: false when binary is not found', async () => {\n598\t      mockExecFile.mockImplementation(\n599\t        (_cmd: string, _args: string[], cb: (err: Error | null) => void) => {\n600\t          cb(new Error('not found'));\n601\t        },\n602\t      );\n603\t\n604\t      const health = await driver.healthCheck();\n605\t      expect(health.available).toBe(false);\n606\t      expect(health.authenticated).toBe(false);\n607\t      expect(health.version).toBeNull();\n608\t      expect(health.error).toBe('codex CLI not found. Install: npm install -g @openai/codex');\n609\t    });\n610\t\n611\t    it('returns authenticated: false when auth check fails', async () => {\n612\t      let callCount = 0;\n613\t      mockExecFile.mockImplementation(\n614\t        (cmd: string, args: string[], cb: (err: Error | null, result?: { stdout: string }) => void) => {\n615\t          callCount++;\n616\t          if (cmd === 'which') {\n617\t            cb(null, { stdout: '/usr/local/bin/codex\\n' });\n618\t          } else if (args[0] === '--version') {\n619\t            cb(null, { stdout: '0.1.2\\n' });\n620\t          } else if (args[0] === 'auth') {\n621\t            cb(new Error('not authenticated'));\n622\t          }\n623\t        },\n624\t      );\n625\t\n626\t      const health = await driver.healthCheck();\n627\t      expect(health.available).toBe(true);\n628\t      expect(health.authenticated).toBe(false);\n629\t    });\n630\t  });\n631\t\n632\t  describe('dispatch — CLI args', () => {\n633\t    it('passes model and cwd to spawn', async () => {\n634\t      const { proc } = createMockProcess(\n635\t        ['{\"type\":\"result\",\"cost_usd\":0.01,\"session_id\":\"s\"}'],\n636\t        0,\n637\t      );\n638\t      mockSpawn.mockReturnValue(proc);\n639\t\n640\t      await collectEvents(\n641\t        driver.dispatch(makeOpts({ model: 'codex-mini', cwd: '/my/project', prompt: 'hello' })),\n642\t      );\n643\t\n644\t      expect(mockSpawn).toHaveBeenCalledWith(\n645\t        'codex',\n646\t        ['--model', 'codex-mini', '--cwd', '/my/project', 'hello'],\n647\t        { stdio: ['ignore', 'pipe', 'pipe'] },\n648\t      );\n649\t    });\n650\t  });\n651\t\n652\t  describe('dispatch — exception during readline (catch block)', () => {\n653\t    it('yields result with error when readline throws', async () => {\n654\t      const stdout = new Readable({\n655\t        read() {\n656\t          // Emit an error instead of data to trigger the catch block\n657\t          process.nextTick(() => this.destroy(new Error('stream exploded')));\n658\t        },\n659\t      });\n660\t      const stderr = new EventEmitter();\n661\t      const proc = new EventEmitter() as EventEmitter & {\n662\t        stdout: Readable;\n663\t        stderr: EventEmitter;\n664\t        kill: ReturnType<typeof vi.fn>;\n665\t      };\n666\t      proc.stdout = stdout;\n667\t      proc.stderr = stderr;\n668\t      proc.kill = vi.fn();\n669\t\n670\t      // Need to emit close after the error\n671\t      stdout.on('error', () => {\n672\t        setTimeout(() => proc.emit('close', 1), 5);\n673\t      });\n674\t\n675\t      mockSpawn.mockReturnValue(proc);\n676\t\n677\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n678\t      const resultEvent = events.find((e) => e.type === 'result') as ResultEvent;\n679\t\n680\t      expect(resultEvent).toBeDefined();\n681\t      expect(resultEvent.error).toContain('stream exploded');\n682\t      expect(resultEvent.errorCategory).toBe('UNKNOWN');\n683\t    });\n684\t  });\n685\t\n686\t  describe('dispatch — no model or cwd in opts', () => {\n687\t    it('does not pass --model or --cwd when opts omit them', async () => {\n688\t      const { proc } = createMockProcess(\n689\t        ['{\"type\":\"result\",\"cost_usd\":0.01,\"session_id\":\"s\"}'],\n690\t        0,\n691\t      );\n692\t      mockSpawn.mockReturnValue(proc);\n693\t\n694\t      await collectEvents(\n695\t        driver.dispatch({ prompt: 'hello', model: '', cwd: '', sourceAccess: true }),\n696\t      );\n697\t\n698\t      expect(mockSpawn).toHaveBeenCalledWith(\n699\t        'codex',\n700\t        ['hello'],\n701\t        { stdio: ['ignore', 'pipe', 'pipe'] },\n702\t      );\n703\t    });\n704\t  });\n705\t\n706\t  describe('barrel export (AC #9)', () => {\n707\t    it('CodexDriver is re-exported from drivers/index.ts', async () => {\n708\t      const mod = await import('../drivers/index.js');\n709\t      expect(mod.CodexDriver).toBe(CodexDriver);\n710\t    });\n711\t  });\n712\t});\n713\t"}]},"parent_tool_use_id":"toolu_01BAKd4fh9zsWfjMmggZc9Jp","session_id":"65932dfc-6881-4906-8881-56eaa8ade510","uuid":"de43a53d-ce1b-4a18-8240-5a5b1f4237f4","timestamp":"2026-04-03T09:27:53.351Z"}
