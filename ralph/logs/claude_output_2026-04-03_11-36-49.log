{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UEaGrcApjmJzxtY1RPeRBf","type":"tool_result","content":"600\t\n601\t    await dispatchTask(task, 'verify', '__run__', definition, state, config);\n602\t\n603\t    expect(mockDriverDispatch).toHaveBeenCalledWith(\n604\t      expect.objectContaining({\n605\t        prompt: 'Execute task \"verify\" for the current run.',\n606\t      }),\n607\t    );\n608\t  });\n609\t});\n610\t\n611\tdescribe('executeWorkflow', () => {\n612\t  beforeEach(() => {\n613\t    vi.clearAllMocks();\n614\t    setupDefaultMocks();\n615\t  });\n616\t\n617\t  it('executes flow steps sequentially in order (AC #2)', async () => {\n618\t    const callOrder: string[] = [];\n619\t    mockDriverDispatch.mockImplementation((opts: { prompt: string }) => {\n620\t      callOrder.push(opts.prompt);\n621\t      return makeDriverStream('ok', 'sess-1');\n622\t    });\n623\t\n624\t    // Two stories, flow: [implement, verify]\n625\t    mockParse.mockReturnValue({\n626\t      development_status: {\n627\t        '3-1-foo': 'ready-for-dev',\n628\t        '3-2-bar': 'backlog',\n629\t      },\n630\t    });\n631\t\n632\t    const config = makeConfig();\n633\t    const result = await executeWorkflow(config);\n634\t\n635\t    expect(result.success).toBe(true);\n636\t    // implement dispatched for each story, then verify once\n637\t    expect(callOrder).toEqual([\n638\t      'Implement story 3-1-foo',\n639\t      'Implement story 3-2-bar',\n640\t      'Execute task \"verify\" for the current run.',\n641\t    ]);\n642\t  });\n643\t\n644\t  it('dispatches per-story task once per story (AC #3)', async () => {\n645\t    mockParse.mockReturnValue({\n646\t      development_status: {\n647\t        '3-1-foo': 'ready-for-dev',\n648\t        '3-2-bar': 'backlog',\n649\t      },\n650\t    });\n651\t\n652\t    const config = makeConfig({\n653\t      workflow: {\n654\t        tasks: { implement: makeTask() },\n655\t        flow: ['implement'],\n656\t      },\n657\t    });\n658\t\n659\t    const result = await executeWorkflow(config);\n660\t\n661\t    expect(mockDriverDispatch).toHaveBeenCalledTimes(2);\n662\t    expect(result.tasksCompleted).toBe(2);\n663\t    expect(result.storiesProcessed).toBe(2);\n664\t  });\n665\t\n666\t  it('dispatches per-run task exactly once with sentinel key (AC #7)', async () => {\n667\t    mockParse.mockReturnValue({\n668\t      development_status: {\n669\t        '3-1-foo': 'ready-for-dev',\n670\t        '3-2-bar': 'backlog',\n671\t      },\n672\t    });\n673\t\n674\t    const config = makeConfig({\n675\t      workflow: {\n676\t        tasks: { verify: makeTask({ scope: 'per-run' }) },\n677\t        flow: ['verify'],\n678\t      },\n679\t    });\n680\t\n681\t    const result = await executeWorkflow(config);\n682\t\n683\t    expect(mockDriverDispatch).toHaveBeenCalledTimes(1);\n684\t    expect(result.tasksCompleted).toBe(1);\n685\t  });\n686\t\n687\t  it('writes state after each task completion (AC #4)', async () => {\n688\t    mockParse.mockReturnValue({\n689\t      development_status: {\n690\t        '3-1-foo': 'ready-for-dev',\n691\t      },\n692\t    });\n693\t\n694\t    const config = makeConfig({\n695\t      workflow: {\n696\t        tasks: { implement: makeTask() },\n697\t        flow: ['implement'],\n698\t      },\n699\t    });\n700\t\n701\t    await executeWorkflow(config);\n702\t\n703\t    // writeWorkflowState called: initial state + after dispatch + final completed state\n704\t    expect(mockWriteWorkflowState).toHaveBeenCalledTimes(3);\n705\t  });\n706\t\n707\t  it('executes loop blocks instead of skipping them', async () => {\n708\t    // Loop with retry (per-story) + verify (per-run) — verify returns pass on first try\n709\t    mockDriverDispatch.mockImplementation((opts: { prompt: string }) => {\n710\t      if (opts.prompt.includes('Execute task')) {\n711\t        return makeDriverStream(JSON.stringify({\n712\t          verdict: 'pass',\n713\t          score: { passed: 1, failed: 0, unknown: 0, total: 1 },\n714\t          findings: [],\n715\t        }), 'sess-v');\n716\t      }\n717\t      return makeDriverStream('ok', 'sess-r');\n718\t    });\n719\t\n720\t    mockParse.mockReturnValue({\n721\t      development_status: { '3-1-foo': 'ready-for-dev' },\n722\t    });\n723\t\n724\t    const config = makeConfig({\n725\t      workflow: {\n726\t        tasks: {\n727\t          retry: makeTask({ scope: 'per-story' }),\n728\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n729\t        },\n730\t        flow: [{ loop: ['retry', 'verify'] }],\n731\t      },\n732\t    });\n733\t\n734\t    const result = await executeWorkflow(config);\n735\t\n736\t    // Should have dispatched: retry for 1 story + verify once\n737\t    expect(mockDriverDispatch).toHaveBeenCalledTimes(2);\n738\t    expect(result.tasksCompleted).toBe(2);\n739\t  });\n740\t\n741\t  it('handles DispatchError and records in result (AC #13)', async () => {\n742\t    const { DispatchError } = await import('../agent-dispatch.js');\n743\t    mockDriverDispatch.mockImplementation(() => makeDriverStreamError(\n744\t      new DispatchError('rate limited', 'UNKNOWN', 'dev', new Error('inner')),\n745\t    ));\n746\t\n747\t    mockParse.mockReturnValue({\n748\t      development_status: { '3-1-foo': 'ready-for-dev' },\n749\t    });\n750\t\n751\t    const config = makeConfig({\n752\t      workflow: {\n753\t        tasks: { implement: makeTask() },\n754\t        flow: ['implement'],\n755\t      },\n756\t    });\n757\t\n758\t    const result = await executeWorkflow(config);\n759\t\n760\t    expect(result.success).toBe(false);\n761\t    expect(result.errors).toHaveLength(1);\n762\t    expect(result.errors[0].code).toBe('UNKNOWN');\n763\t    expect(result.errors[0].taskName).toBe('implement');\n764\t    expect(result.errors[0].storyKey).toBe('3-1-foo');\n765\t  });\n766\t\n767\t  it('halts on RATE_LIMIT dispatch errors (AC #13)', async () => {\n768\t    const { DispatchError } = await import('../agent-dispatch.js');\n769\t    mockDriverDispatch.mockImplementation(() => makeDriverStreamError(\n770\t      new DispatchError('rate limited', 'RATE_LIMIT', 'dev', new Error('inner')),\n771\t    ));\n772\t\n773\t    mockParse.mockReturnValue({\n774\t      development_status: {\n775\t        '3-1-foo': 'ready-for-dev',\n776\t        '3-2-bar': 'backlog',\n777\t      },\n778\t    });\n779\t\n780\t    const config = makeConfig({\n781\t      workflow: {\n782\t        tasks: { implement: makeTask() },\n783\t        flow: ['implement'],\n784\t      },\n785\t    });\n786\t\n787\t    const result = await executeWorkflow(config);\n788\t\n789\t    expect(result.success).toBe(false);\n790\t    // Should halt after first error — only one dispatch attempted\n791\t    expect(mockDriverDispatch).toHaveBeenCalledTimes(1);\n792\t    expect(result.errors).toHaveLength(1);\n793\t  });\n794\t\n795\t  it('continues on UNKNOWN errors for per-story tasks (AC #13)', async () => {\n796\t    const { DispatchError } = await import('../agent-dispatch.js');\n797\t    let callCount = 0;\n798\t    mockDriverDispatch.mockImplementation(() => {\n799\t      callCount++;"}]},"parent_tool_use_id":"toolu_01WzzY2TpSn4HBX8Gw2yuQNF","session_id":"f83470b7-c271-483e-ae93-7fe9bce4b683","uuid":"875935fc-02f5-4441-a6b0-0352239b0629","timestamp":"2026-04-03T07:55:12.982Z"}
