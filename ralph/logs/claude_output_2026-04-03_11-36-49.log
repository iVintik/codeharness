{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XCy7GnGLnoMbdM8q5LKKAx","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { parse } from 'yaml';\n3\timport { warn } from './output.js';\n4\timport { DispatchError } from './agent-dispatch.js';\n5\timport type { DispatchErrorCode } from './agent-dispatch.js';\n6\t// Note: dispatchAgent is no longer imported — dispatch goes through the driver factory\n7\timport { getDriver } from './agents/drivers/factory.js';\n8\timport { resolveModel } from './agents/model-resolver.js';\n9\timport type { DispatchOpts } from './agents/types.js';\n10\timport type { ResultEvent } from './agents/stream-parser.js';\n11\timport type { SubagentDefinition } from './agent-resolver.js';\n12\timport type { ResolvedWorkflow, ResolvedTask, FlowStep, LoopBlock } from './workflow-parser.js';\n13\timport {\n14\t  readWorkflowState,\n15\t  writeWorkflowState,\n16\t} from './workflow-state.js';\n17\timport type { WorkflowState, TaskCheckpoint } from './workflow-state.js';\n18\timport { createIsolatedWorkspace } from './source-isolation.js';\n19\timport { generateTraceId, formatTracePrompt, recordTraceId } from './trace-id.js';\n20\timport { resolveSessionId, recordSessionId } from './session-manager.js';\n21\timport type { SessionLookupKey } from './session-manager.js';\n22\timport { parseVerdict, VerdictParseError } from './verdict-parser.js';\n23\timport type { EvaluatorVerdict } from './verdict-parser.js';\n24\timport { evaluateProgress } from './circuit-breaker.js';\n25\t\n26\t// Re-export EvaluatorVerdict for downstream consumers that import from workflow-engine\n27\texport type { EvaluatorVerdict } from './verdict-parser.js';\n28\texport { parseVerdict } from './verdict-parser.js';\n29\t\n30\t// --- Interfaces ---\n31\t\n32\t/**\n33\t * Configuration for the workflow engine.\n34\t */\n35\texport interface EngineConfig {\n36\t  /** The resolved workflow with tasks and flow steps. */\n37\t  workflow: ResolvedWorkflow;\n38\t  /** Pre-compiled agent definitions keyed by agent name. */\n39\t  agents: Record<string, SubagentDefinition>;\n40\t  /** Path to sprint-status.yaml for work item discovery. */\n41\t  sprintStatusPath: string;\n42\t  /** Optional path to issues.yaml for additional work items. */\n43\t  issuesPath?: string;\n44\t  /** Unique identifier for this engine run. */\n45\t  runId: string;\n46\t  /** Project root directory. Defaults to process.cwd(). */\n47\t  projectDir?: string;\n48\t  /** Maximum loop iterations before termination. Defaults to 5. */\n49\t  maxIterations?: number;\n50\t}\n51\t\n52\t/**\n53\t * Result returned by executeWorkflow().\n54\t */\n55\texport interface EngineResult {\n56\t  /** Whether the workflow completed without errors. */\n57\t  success: boolean;\n58\t  /** Number of task dispatches completed. */\n59\t  tasksCompleted: number;\n60\t  /** Number of work items (stories/issues) processed. */\n61\t  storiesProcessed: number;\n62\t  /** Errors encountered during execution. */\n63\t  errors: EngineError[];\n64\t  /** Wall-clock duration of the entire workflow in milliseconds. */\n65\t  durationMs: number;\n66\t}\n67\t\n68\t/**\n69\t * Structured error recorded during workflow execution.\n70\t */\n71\texport interface EngineError {\n72\t  taskName: string;\n73\t  storyKey: string;\n74\t  code: string;\n75\t  message: string;\n76\t}\n77\t\n78\t/**\n79\t * A work item (story or issue) ready for execution.\n80\t */\n81\texport interface WorkItem {\n82\t  key: string;\n83\t  title?: string;\n84\t  source: 'sprint' | 'issues';\n85\t}\n86\t\n87\t// --- Constants ---\n88\t\n89\t/** Sentinel story key for per-run tasks. */\n90\texport const PER_RUN_SENTINEL = '__run__';\n91\t\n92\t/** DispatchError codes that should halt execution immediately. */\n93\tconst HALT_ERROR_CODES = new Set(['RATE_LIMIT', 'NETWORK', 'SDK_INIT']);\n94\t\n95\t/** Default maximum loop iterations before termination. */\n96\tconst DEFAULT_MAX_ITERATIONS = 5;\n97\t\n98\t// --- Crash Recovery: Task Completion Check ---\n99\t\n100\t/**\n101\t * Check whether a (taskName, storyKey) combination is already recorded\n102\t * in the workflow state's tasks_completed array.\n103\t *\n104\t * Both fields must match for the task to be considered completed.\n105\t * Used by the resume logic to skip already-completed dispatches.\n106\t */\n107\texport function isTaskCompleted(\n108\t  state: WorkflowState,\n109\t  taskName: string,\n110\t  storyKey: string,\n111\t): boolean {\n112\t  return state.tasks_completed.some(\n113\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey && !cp.error,\n114\t  );\n115\t}\n116\t\n117\t/**\n118\t * Check whether a (taskName, storyKey) combination has been completed\n119\t * enough times to cover the current iteration in a loop block.\n120\t *\n121\t * Loop tasks execute the same (taskName, storyKey) pair each iteration,\n122\t * recording a new checkpoint each time. To determine if a task is done\n123\t * for the current iteration, we count how many matching checkpoints exist\n124\t * and compare to the current iteration number.\n125\t */\n126\texport function isLoopTaskCompleted(\n127\t  state: WorkflowState,\n128\t  taskName: string,\n129\t  storyKey: string,\n130\t  iteration: number,\n131\t): boolean {\n132\t  const count = state.tasks_completed.filter(\n133\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey && !cp.error,\n134\t  ).length;\n135\t  return count >= iteration;\n136\t}\n137\t\n138\t// --- Work Item Loading ---\n139\t\n140\t/**\n141\t * Load work items from sprint-status.yaml and optionally issues.yaml.\n142\t *\n143\t * Stories are extracted from the `development_status` section of sprint-status.yaml.\n144\t * Issues are extracted from the `issues` array of issues.yaml.\n145\t *\n146\t * Only items with status `backlog` or `ready-for-dev` are included.\n147\t * Epic keys (`epic-*`) and retrospective keys (`*-retrospective`) are excluded.\n148\t *\n149\t * If issues.yaml does not exist, returns only stories (no error).\n150\t */\n151\texport function loadWorkItems(sprintStatusPath: string, issuesPath?: string): WorkItem[] {\n152\t  const items: WorkItem[] = [];\n153\t\n154\t  // --- Load stories from sprint-status.yaml ---\n155\t  if (existsSync(sprintStatusPath)) {\n156\t    let raw: string;\n157\t    try {\n158\t      raw = readFileSync(sprintStatusPath, 'utf-8');\n159\t    } catch { // IGNORE: unreadable file — warn and return empty\n160\t      warn(`workflow-engine: could not read sprint-status.yaml at ${sprintStatusPath}`);\n161\t      return items;\n162\t    }\n163\t\n164\t    let parsed: unknown;\n165\t    try {\n166\t      parsed = parse(raw);\n167\t    } catch { // IGNORE: malformed YAML — warn and return empty\n168\t      warn(`workflow-engine: invalid YAML in sprint-status.yaml at ${sprintStatusPath}`);\n169\t      return items;\n170\t    }\n171\t\n172\t    if (parsed && typeof parsed === 'object') {\n173\t      const data = parsed as Record<string, unknown>;\n174\t      const devStatus = data.development_status as Record<string, unknown> | undefined;\n175\t\n176\t      if (devStatus && typeof devStatus === 'object') {\n177\t        for (const [key, status] of Object.entries(devStatus)) {\n178\t          // Skip epic keys and retrospective keys\n179\t          if (key.startsWith('epic-')) continue;\n180\t          if (key.endsWith('-retrospective')) continue;\n181\t\n182\t          // Only include backlog or ready-for-dev\n183\t          if (status === 'backlog' || status === 'ready-for-dev') {\n184\t            items.push({ key, source: 'sprint' });\n185\t          }\n186\t        }\n187\t      }\n188\t    }\n189\t  }\n190\t\n191\t  // --- Load issues from issues.yaml ---\n192\t  if (issuesPath && existsSync(issuesPath)) {\n193\t    let raw: string;\n194\t    try {\n195\t      raw = readFileSync(issuesPath, 'utf-8');\n196\t    } catch { // IGNORE: unreadable issues file — warn and return what we have\n197\t      warn(`workflow-engine: could not read issues.yaml at ${issuesPath}`);\n198\t      return items;\n199\t    }\n200\t\n201\t    let parsed: unknown;\n202\t    try {\n203\t      parsed = parse(raw);\n204\t    } catch { // IGNORE: malformed issues YAML — warn and return what we have\n205\t      warn(`workflow-engine: invalid YAML in issues.yaml at ${issuesPath}`);\n206\t      return items;\n207\t    }\n208\t\n209\t    if (parsed && typeof parsed === 'object') {\n210\t      const data = parsed as Record<string, unknown>;\n211\t      const issuesList = data.issues as Array<Record<string, unknown>> | undefined;\n212\t\n213\t      if (Array.isArray(issuesList)) {\n214\t        for (const issue of issuesList) {\n215\t          if (issue && typeof issue === 'object') {\n216\t            const status = issue.status as string | undefined;\n217\t            if (status === 'backlog' || status === 'ready-for-dev') {\n218\t              items.push({\n219\t                key: issue.id as string,\n220\t                title: issue.title as string | undefined,\n221\t                source: 'issues',\n222\t              });\n223\t            }\n224\t          }\n225\t        }\n226\t      }\n227\t    }\n228\t  }\n229\t\n230\t  return items;\n231\t}\n232\t\n233\t// --- Single Task Dispatch ---\n234\t\n235\t/**\n236\t * Dispatch a single task for a specific work item (or per-run sentinel).\n237\t *\n238\t * Handles: trace ID generation, session resolution, source isolation,\n239\t * agent dispatch, state checkpointing, and cleanup.\n240\t *\n241\t * Returns the updated workflow state after recording the dispatch.\n242\t */\n243\texport async function dispatchTask(\n244\t  task: ResolvedTask,\n245\t  taskName: string,\n246\t  storyKey: string,\n247\t  definition: SubagentDefinition,\n248\t  state: WorkflowState,\n249\t  config: EngineConfig,\n250\t  customPrompt?: string,\n251\t): Promise<WorkflowState> {\n252\t  const { updatedState } = await dispatchTaskWithResult(\n253\t    task, taskName, storyKey, definition, state, config, customPrompt,\n254\t  );\n255\t  return updatedState;\n256\t}\n257\t\n258\t// --- Flow Step Type Guard ---\n259\t\n260\tfunction isLoopBlock(step: FlowStep): step is LoopBlock {\n261\t  return typeof step === 'object' && step !== null && 'loop' in step;\n262\t}\n263\t\n264\t// --- Core Dispatch (shared by dispatchTask and loop block execution) ---\n265\t\n266\t/**\n267\t * Dispatch a task and return both the updated state and the raw dispatch output.\n268\t * This is the single implementation of task dispatch logic. Both `dispatchTask()`\n269\t * and loop block execution delegate here.\n270\t */\n271\tasync function dispatchTaskWithResult(\n272\t  task: ResolvedTask,\n273\t  taskName: string,\n274\t  storyKey: string,\n275\t  definition: SubagentDefinition,\n276\t  state: WorkflowState,\n277\t  config: EngineConfig,\n278\t  customPrompt?: string,\n279\t): Promise<{ updatedState: WorkflowState; output: string }> {\n280\t  const projectDir = config.projectDir ?? process.cwd();\n281\t\n282\t  // 1. Generate trace ID\n283\t  const traceId = generateTraceId(config.runId, state.iteration, taskName);\n284\t\n285\t  // 2. Format trace prompt (kept for state recording, no longer injected into driver)\n286\t  formatTracePrompt(traceId);\n287\t\n288\t  // 3. Resolve session ID\n289\t  const sessionKey: SessionLookupKey = { taskName, storyKey };\n290\t  const sessionId = resolveSessionId(task.session, sessionKey, state);\n291\t\n292\t  // 4. Resolve driver — forward-compat: task.driver field comes in story 11-1\n293\t  const driverName = (task as { driver?: string }).driver ?? 'claude-code';\n294\t  const driver = getDriver(driverName);\n295\t\n296\t  // 5. Resolve model via cascade: task → agent → driver\n297\t  const agentAsModelSource = { model: definition.model };\n298\t  const model = resolveModel(task as { model?: string }, agentAsModelSource, driver);\n299\t\n300\t  // 6. Determine cwd based on source_access\n301\t  let cwd: string;\n302\t  let workspace: Awaited<ReturnType<typeof createIsolatedWorkspace>> | null = null;\n303\t\n304\t  if (task.source_access === false) {\n305\t    workspace = await createIsolatedWorkspace({ runId: config.runId, storyFiles: [] });\n306\t    cwd = workspace.toDispatchOptions().cwd ?? projectDir;\n307\t  } else {\n308\t    cwd = projectDir;\n309\t  }\n310\t\n311\t  // 7. Construct prompt\n312\t  const prompt = customPrompt\n313\t    ?? (storyKey === PER_RUN_SENTINEL\n314\t      ? `Execute task \"${taskName}\" for the current run.`\n315\t      : `Implement story ${storyKey}`);\n316\t\n317\t  // 8. Build DispatchOpts for the driver\n318\t  const dispatchOpts: DispatchOpts = {\n319\t    prompt,\n320\t    model,\n321\t    cwd,\n322\t    sourceAccess: task.source_access !== false,\n323\t    ...(((task as { plugins?: readonly string[] }).plugins) ? { plugins: (task as { plugins?: readonly string[] }).plugins } : {}),\n324\t    ...(task.max_budget_usd != null ? { timeout: task.max_budget_usd } : {}),\n325\t  };\n326\t\n327\t  // 9. Dispatch through the driver and consume AsyncIterable<StreamEvent>\n328\t  let output = '';\n329\t  let resultSessionId = '';\n330\t  let cost = 0;\n331\t  let errorEvent: { error: string; errorCategory?: string } | null = null;\n332\t\n333\t  try {\n334\t    for await (const event of driver.dispatch(dispatchOpts)) {\n335\t      if (event.type === 'text') {\n336\t        output += event.text;\n337\t      }\n338\t      if (event.type === 'result') {\n339\t        const resultEvt = event as ResultEvent;\n340\t        resultSessionId = resultEvt.sessionId;\n341\t        cost = resultEvt.cost;\n342\t        if (resultEvt.error) {\n343\t          errorEvent = { error: resultEvt.error, errorCategory: resultEvt.errorCategory };\n344\t        }\n345\t      }\n346\t    }\n347\t  } finally {\n348\t    // Cleanup workspace regardless of dispatch success/failure\n349\t    if (workspace) {\n350\t      await workspace.cleanup();\n351\t    }\n352\t  }\n353\t\n354\t  // 10. If the driver reported an error in the result event, throw DispatchError\n355\t  if (errorEvent) {\n356\t    // Map ErrorCategory to DispatchErrorCode\n357\t    const categoryToCode: Record<string, string> = {\n358\t      RATE_LIMIT: 'RATE_LIMIT',\n359\t      NETWORK: 'NETWORK',\n360\t      AUTH: 'UNKNOWN',\n361\t      TIMEOUT: 'UNKNOWN',\n362\t      UNKNOWN: 'UNKNOWN',\n363\t    };\n364\t    const code = categoryToCode[errorEvent.errorCategory ?? 'UNKNOWN'] ?? 'UNKNOWN';\n365\t    throw new DispatchError(\n366\t      errorEvent.error,\n367\t      code as DispatchErrorCode,\n368\t      definition.name,\n369\t      errorEvent,\n370\t    );\n371\t  }\n372\t\n373\t  // 11. Record session ID (if dispatch returned one)\n374\t  let updatedState = state;\n375\t  if (resultSessionId) {\n376\t    updatedState = recordSessionId(sessionKey, resultSessionId, updatedState);\n377\t  } else {\n378\t    // Append checkpoint manually when no session ID is returned\n379\t    const checkpoint: TaskCheckpoint = {\n380\t      task_name: taskName,\n381\t      story_key: storyKey,\n382\t      completed_at: new Date().toISOString(),\n383\t    };\n384\t    updatedState = {\n385\t      ...updatedState,\n386\t      tasks_completed: [...updatedState.tasks_completed, checkpoint],\n387\t    };\n388\t  }\n389\t\n390\t  // 12. Record trace ID\n391\t  updatedState = recordTraceId(traceId, updatedState);\n392\t\n393\t  // 13. Write state to disk\n394\t  writeWorkflowState(updatedState, projectDir);\n395\t\n396\t  return { updatedState, output };\n397\t}\n398\t\n399\t// --- Retry Prompt Construction (Task 3) ---\n400\t\n401\t/**\n402\t * Build a retry prompt with evaluator findings injected.\n403\t * Includes only failed/unknown findings.\n404\t */\n405\texport function buildRetryPrompt(storyKey: string, findings: EvaluatorVerdict['findings']): string {\n406\t  const failedFindings = findings.filter(\n407\t    (f) => f.status === 'fail' || f.status === 'unknown',\n408\t  );\n409\t\n410\t  if (failedFindings.length === 0) {\n411\t    return `Implement story ${storyKey}`;\n412\t  }\n413\t\n414\t  const formattedFindings = failedFindings\n415\t    .map((f) => {\n416\t      const status = f.status.toUpperCase();\n417\t      let entry = `AC #${f.ac} (${status}): ${f.description}`;\n418\t      if (f.evidence?.reasoning) {\n419\t        entry += `\\n  Evidence: ${f.evidence.reasoning}`;\n420\t      }\n421\t      return entry;\n422\t    })\n423\t    .join('\\n\\n');\n424\t\n425\t  return `Retry story ${storyKey}. Previous evaluator findings:\\n\\n${formattedFindings}\\n\\nFocus on fixing the failed criteria above.`;\n426\t}\n427\t\n428\t// --- All-UNKNOWN Verdict Builder ---\n429\t\n430\t/**\n431\t * Build an all-UNKNOWN EvaluatorVerdict as fallback when the evaluator\n432\t * fails to produce valid JSON after retry.\n433\t */\n434\texport function buildAllUnknownVerdict(\n435\t  workItems: WorkItem[],\n436\t  reasoning: string,\n437\t): EvaluatorVerdict {\n438\t  const findings = workItems.map((_, index) => ({\n439\t    ac: index + 1,\n440\t    description: `AC #${index + 1}`,\n441\t    status: 'unknown' as const,\n442\t    evidence: {\n443\t      commands_run: [] as string[],\n444\t      output_observed: '',\n445\t      reasoning,\n446\t    },\n447\t  }));\n448\t\n449\t  return {\n450\t    verdict: 'fail',\n451\t    score: {\n452\t      passed: 0,\n453\t      failed: 0,\n454\t      unknown: findings.length,\n455\t      total: findings.length,\n456\t    },\n457\t    findings,\n458\t  };\n459\t}\n460\t\n461\t// --- Failed Story Filtering (Task 4) ---\n462\t\n463\t/**\n464\t * Determine which work items failed based on evaluator findings.\n465\t * If verdict is null (parse failure), returns all items (conservative fallback).\n466\t */\n467\texport function getFailedItems(\n468\t  verdict: EvaluatorVerdict | null,\n469\t  allItems: WorkItem[],\n470\t): WorkItem[] {\n471\t  if (!verdict) return allItems;\n472\t\n473\t  // If verdict passed, no items need retry\n474\t  if (verdict.verdict === 'pass') return [];\n475\t\n476\t  // All items are retried on failure — per-story filtering based on individual\n477\t  // story results is not possible with the current verdict shape (verdict is per-run).\n478\t  // The findings track ACs, not stories. Conservative: retry all on failure.\n479\t  return allItems;\n480\t}\n481\t\n482\t// --- Loop Block Execution (Task 5) ---\n483\t\n484\t/**\n485\t * Result of loop block execution.\n486\t */\n487\tinterface LoopBlockResult {\n488\t  state: WorkflowState;\n489\t  errors: EngineError[];\n490\t  tasksCompleted: number;\n491\t  halted: boolean;\n492\t}\n493\t\n494\t/**\n495\t * Execute a loop block: iterate tasks until pass, max iterations, or circuit breaker.\n496\t */\n497\texport async function executeLoopBlock(\n498\t  loopBlock: LoopBlock,\n499\t  state: WorkflowState,\n500\t  config: EngineConfig,\n501\t  workItems: WorkItem[],\n502\t): Promise<LoopBlockResult> {\n503\t  const projectDir = config.projectDir ?? process.cwd();\n504\t  const maxIterations = config.maxIterations ?? DEFAULT_MAX_ITERATIONS;\n505\t  const errors: EngineError[] = [];\n506\t  let tasksCompleted = 0;\n507\t  let currentState = state;\n508\t  let lastVerdict: EvaluatorVerdict | null = null;\n509\t\n510\t  // Handle empty loop block\n511\t  if (loopBlock.loop.length === 0) {\n512\t    return { state: currentState, errors, tasksCompleted, halted: false };\n513\t  }\n514\t\n515\t  while (true) {\n516\t    // 1. Determine whether to increment iteration or resume a partial one.\n517\t    //    On fresh start (iteration === 0), always increment.\n518\t    //    On resume (iteration > 0), check if the current iteration is fully done.\n519\t    const nextIteration = currentState.iteration + 1;\n520\t    const allCurrentIterationDone = currentState.iteration > 0 && loopBlock.loop.every((tn) => {\n521\t      const t = config.workflow.tasks[tn];\n522\t      if (!t) return true; // missing task = skip = \"done\"\n523\t      if (t.scope === 'per-story') {\n524\t        return workItems.every((item) =>\n525\t          isLoopTaskCompleted(currentState, tn, item.key, currentState.iteration));\n526\t      }\n527\t      return isLoopTaskCompleted(currentState, tn, PER_RUN_SENTINEL, currentState.iteration);\n528\t    });\n529\t\n530\t    if (currentState.iteration === 0 || allCurrentIterationDone) {\n531\t      // Fresh start or current iteration fully done — advance\n532\t      currentState = {\n533\t        ...currentState,\n534\t        iteration: nextIteration,\n535\t      };\n536\t      writeWorkflowState(currentState, projectDir);\n537\t    }\n538\t    // else: resuming a partially completed iteration — keep current iteration\n539\t\n540\t    let haltedInLoop = false;\n541\t\n542\t    // 2. Execute each task in the loop\n543\t    for (const taskName of loopBlock.loop) {\n544\t      const task = config.workflow.tasks[taskName];\n545\t      if (!task) {\n546\t        warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n547\t        continue;\n548\t      }\n549\t\n550\t      const definition = config.agents[task.agent];\n551\t      if (!definition) {\n552\t        warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n553\t        continue;\n554\t      }\n555\t\n556\t      if (task.scope === 'per-story') {\n557\t        // Determine which items to dispatch for\n558\t        const itemsToRetry = lastVerdict ? getFailedItems(lastVerdict, workItems) : workItems;\n559\t\n560\t        for (const item of itemsToRetry) {\n561\t          // Skip if already completed for this iteration (crash recovery — AC #4)\n562\t          if (isLoopTaskCompleted(currentState, taskName, item.key, currentState.iteration)) {\n563\t            warn(`workflow-engine: skipping completed task ${taskName} for ${item.key}`);\n564\t            continue;\n565\t          }\n566\t\n567\t          // Build prompt: inject findings if we have a previous verdict\n568\t          const prompt = lastVerdict\n569\t            ? buildRetryPrompt(item.key, lastVerdict.findings)\n570\t            : undefined;\n571\t\n572\t          try {\n573\t            currentState = await dispatchTask(\n574\t              task, taskName, item.key, definition, currentState, config, prompt,\n575\t            );\n576\t            tasksCompleted++;\n577\t          } catch (err: unknown) {\n578\t            const engineError = handleDispatchError(err, taskName, item.key);\n579\t            errors.push(engineError);\n580\t            currentState = recordErrorInState(currentState, taskName, item.key, engineError);\n581\t            writeWorkflowState(currentState, projectDir);\n582\t\n583\t            if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n584\t              haltedInLoop = true;\n585\t              break;\n586\t            }\n587\t            continue;\n588\t          }\n589\t        }\n590\t\n591\t        if (haltedInLoop) break;\n592\t      } else {\n593\t        // per-run task (e.g., verify)\n594\t        // Skip if already completed for this iteration (crash recovery — AC #4)\n595\t        if (isLoopTaskCompleted(currentState, taskName, PER_RUN_SENTINEL, currentState.iteration)) {\n596\t          warn(`workflow-engine: skipping completed task ${taskName} for ${PER_RUN_SENTINEL}`);\n597\t          continue;\n598\t        }\n599\t\n600\t        try {\n601\t          // We need the dispatch result output to parse verdict\n602\t          // dispatchTask doesn't return the DispatchResult directly, so we\n603\t          // intercept via a wrapper that captures the output\n604\t          const dispatchResult = await dispatchTaskWithResult(\n605\t            task, taskName, PER_RUN_SENTINEL, definition, currentState, config,\n606\t          );\n607\t          currentState = dispatchResult.updatedState;\n608\t          tasksCompleted++;\n609\t\n610\t          // Attempt to parse verdict from output with retry semantics (story 6-2)\n611\t          let verdict: EvaluatorVerdict | null = null;\n612\t          try {\n613\t            verdict = parseVerdict(dispatchResult.output);\n614\t          } catch (parseErr: unknown) {\n615\t            if (parseErr instanceof VerdictParseError && parseErr.retryable) {\n616\t              // Re-dispatch evaluator for one retry attempt\n617\t              warn(`workflow-engine: verdict parse failed, retrying evaluator for ${taskName}`);\n618\t              try {\n619\t                const retryResult = await dispatchTaskWithResult(\n620\t                  task, taskName, PER_RUN_SENTINEL, definition, currentState, config,\n621\t                );\n622\t                currentState = retryResult.updatedState;\n623\t                tasksCompleted++;\n624\t                verdict = parseVerdict(retryResult.output);\n625\t              } catch { // IGNORE: retry failed — fall back to all-UNKNOWN verdict\n626\t                // Second failure: generate all-UNKNOWN verdict\n627\t                verdict = buildAllUnknownVerdict(\n628\t                  workItems,\n629\t                  'Evaluator failed to produce valid JSON after retry',\n630\t                );\n631\t              }\n632\t            }\n633\t            // If not a VerdictParseError or not retryable, verdict stays null\n634\t          }\n635\t          lastVerdict = verdict;\n636\t\n637\t          // Record score in state\n638\t          if (verdict) {\n639\t            const score = {\n640\t              iteration: currentState.iteration,\n641\t              passed: verdict.score.passed,\n642\t              failed: verdict.score.failed,\n643\t              unknown: verdict.score.unknown,\n644\t              total: verdict.score.total,\n645\t              timestamp: new Date().toISOString(),\n646\t            };\n647\t            currentState = {\n648\t              ...currentState,\n649\t              evaluator_scores: [...currentState.evaluator_scores, score],\n650\t            };\n651\t          } else {\n652\t            // Parse failure: record all-UNKNOWN score\n653\t            const totalItems = workItems.length;\n654\t            const score = {\n655\t              iteration: currentState.iteration,\n656\t              passed: 0,\n657\t              failed: 0,\n658\t              unknown: totalItems,\n659\t              total: totalItems,\n660\t              timestamp: new Date().toISOString(),\n661\t            };\n662\t            currentState = {\n663\t              ...currentState,\n664\t              evaluator_scores: [...currentState.evaluator_scores, score],\n665\t            };\n666\t          }\n667\t          writeWorkflowState(currentState, projectDir);\n668\t\n669\t          // Circuit breaker: evaluate progress after recording score\n670\t          const cbDecision = evaluateProgress(currentState.evaluator_scores);\n671\t          if (cbDecision.halt) {\n672\t            currentState = {\n673\t              ...currentState,\n674\t              circuit_breaker: {\n675\t                triggered: true,\n676\t                reason: cbDecision.reason,\n677\t                score_history: cbDecision.scoreHistory,\n678\t              },\n679\t            };\n680\t            writeWorkflowState(currentState, projectDir);\n681\t          }\n682\t        } catch (err: unknown) {\n683\t          const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n684\t          errors.push(engineError);\n685\t          currentState = recordErrorInState(currentState, taskName, PER_RUN_SENTINEL, engineError);\n686\t          writeWorkflowState(currentState, projectDir);\n687\t\n688\t          // Clear stale verdict so next iteration retries all items\n689\t          lastVerdict = null;\n690\t\n691\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n692\t            haltedInLoop = true;\n693\t            break;\n694\t          }\n695\t          continue;\n696\t        }\n697\t      }\n698\t    }\n699\t\n700\t    if (haltedInLoop) {\n701\t      return { state: currentState, errors, tasksCompleted, halted: true };\n702\t    }\n703\t\n704\t    // 3. Check termination conditions\n705\t    if (lastVerdict?.verdict === 'pass') {\n706\t      // Success: loop passes\n707\t      return { state: currentState, errors, tasksCompleted, halted: false };\n708\t    }\n709\t\n710\t    if (currentState.iteration >= maxIterations) {\n711\t      currentState = { ...currentState, phase: 'max-iterations' };\n712\t      writeWorkflowState(currentState, projectDir);\n713\t      return { state: currentState, errors, tasksCompleted, halted: false };\n714\t    }\n715\t\n716\t    if (currentState.circuit_breaker.triggered) {\n717\t      currentState = { ...currentState, phase: 'circuit-breaker' };\n718\t      writeWorkflowState(currentState, projectDir);\n719\t      return { state: currentState, errors, tasksCompleted, halted: false };\n720\t    }\n721\t  }\n722\t}\n723\t\n724\t\n725\t// --- Main Execution ---\n726\t\n727\t/**\n728\t * Execute a workflow sequentially: iterate through flow steps, dispatch tasks\n729\t * per-story or per-run, checkpoint state after each dispatch.\n730\t *\n731\t * Loop blocks execute iteratively until pass, max-iterations, or circuit-breaker.\n732\t *\n733\t * Returns an EngineResult summarizing the execution.\n734\t */\n735\texport async function executeWorkflow(config: EngineConfig): Promise<EngineResult> {\n736\t  const startMs = Date.now();\n737\t  const projectDir = config.projectDir ?? process.cwd();\n738\t  const errors: EngineError[] = [];\n739\t  let tasksCompleted = 0;\n740\t  const processedStories = new Set<string>();\n741\t\n742\t  // 1. Read or initialize workflow state\n743\t  let state = readWorkflowState(projectDir);\n744\t\n745\t  // Early exit: workflow already completed (AC #6)\n746\t  if (state.phase === 'completed') {\n747\t    return {\n748\t      success: true,\n749\t      tasksCompleted: 0,\n750\t      storiesProcessed: 0,\n751\t      errors: [],\n752\t      durationMs: 0,\n753\t    };\n754\t  }\n755\t\n756\t  state = {\n757\t    ...state,\n758\t    phase: 'executing',\n759\t    started: state.started || new Date().toISOString(),\n760\t    workflow_name: config.workflow.flow.filter((s) => typeof s === 'string').join(' -> '),\n761\t  };\n762\t  writeWorkflowState(state, projectDir);\n763\t\n764\t  // 2. Load work items\n765\t  const workItems = loadWorkItems(config.sprintStatusPath, config.issuesPath);\n766\t\n767\t  // 3. Iterate through flow steps\n768\t  let halted = false;\n769\t  for (const step of config.workflow.flow) {\n770\t    if (halted) break;\n771\t\n772\t    // Execute loop blocks\n773\t    if (isLoopBlock(step)) {\n774\t      const loopResult = await executeLoopBlock(step, state, config, workItems);\n775\t      state = loopResult.state;\n776\t      errors.push(...loopResult.errors);\n777\t      tasksCompleted += loopResult.tasksCompleted;\n778\t\n779\t      // Track processed stories from loop\n780\t      for (const item of workItems) {\n781\t        processedStories.add(item.key);\n782\t      }\n783\t\n784\t      if (loopResult.halted) {\n785\t        halted = true;\n786\t      }\n787\t\n788\t      // If loop ended with max-iterations or circuit-breaker, treat as failure\n789\t      if (state.phase === 'max-iterations' || state.phase === 'circuit-breaker') {\n790\t        halted = true;\n791\t      }\n792\t      continue;\n793\t    }\n794\t\n795\t    // step is a string task name\n796\t    const taskName = step;\n797\t    const task = config.workflow.tasks[taskName];\n798\t\n799\t    if (!task) {\n800\t      warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n801\t      continue;\n802\t    }\n803\t\n804\t    // Look up the agent definition\n805\t    const definition = config.agents[task.agent];\n806\t    if (!definition) {\n807\t      warn(`workflow-engine: agent \"${task.agent}\" not found 