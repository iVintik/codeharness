{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YMdL97pE1pQvvvt5HJVHyW","type":"tool_result","content":"1\timport { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n2\timport { join } from 'node:path';\n3\timport { parse, stringify } from 'yaml';\n4\timport { warn } from './output.js';\n5\t\n6\t// --- Interfaces ---\n7\t\n8\texport interface TaskCheckpoint {\n9\t  task_name: string;\n10\t  story_key: string;\n11\t  completed_at: string;\n12\t  session_id?: string;\n13\t}\n14\t\n15\texport interface EvaluatorScore {\n16\t  iteration: number;\n17\t  passed: number;\n18\t  failed: number;\n19\t  unknown: number;\n20\t  total: number;\n21\t  timestamp: string;\n22\t}\n23\t\n24\texport interface CircuitBreakerState {\n25\t  triggered: boolean;\n26\t  reason: string | null;\n27\t  score_history: number[];\n28\t}\n29\t\n30\texport interface WorkflowState {\n31\t  workflow_name: string;\n32\t  started: string;\n33\t  iteration: number;\n34\t  phase: string;\n35\t  tasks_completed: TaskCheckpoint[];\n36\t  evaluator_scores: EvaluatorScore[];\n37\t  circuit_breaker: CircuitBreakerState;\n38\t  trace_ids?: string[];\n39\t}\n40\t\n41\t// --- Constants ---\n42\t\n43\tconst STATE_DIR = '.codeharness';\n44\tconst STATE_FILE = 'workflow-state.yaml';\n45\t\n46\t// --- Functions ---\n47\t\n48\texport function getDefaultWorkflowState(): WorkflowState {\n49\t  return {\n50\t    workflow_name: '',\n51\t    started: '',\n52\t    iteration: 0,\n53\t    phase: 'idle',\n54\t    tasks_completed: [],\n55\t    evaluator_scores: [],\n56\t    circuit_breaker: {\n57\t      triggered: false,\n58\t      reason: null,\n59\t      score_history: [],\n60\t    },"}]},"parent_tool_use_id":"toolu_011dV6c9xFAQaHP6KDdoVM36","session_id":"7bb08296-a865-42eb-9710-ebdb6ccedbda","uuid":"6f3da196-ed97-4b6c-bd73-f51d4d446b06","timestamp":"2026-04-02T21:55:21.155Z"}
