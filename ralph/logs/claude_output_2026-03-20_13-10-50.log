{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JDjWKJHkwecQvQ8EHZaGfs","type":"tool_result","content":"     1→/**\n     2→ * Onboarding epic generation from scan findings.\n     3→ *\n     4→ * Story 6.2: Maps scan results, coverage gaps, and doc audit findings\n     5→ * into an onboarding epic with stories, writes markdown, handles approval,\n     6→ * and imports into beads.\n     7→ */\n     8→\n     9→import { createInterface } from 'node:readline';\n    10→import { existsSync, mkdirSync, writeFileSync } from 'node:fs';\n    11→import { dirname, join } from 'node:path';\n    12→import { parseEpicsFile, importStoriesToBeads } from './bmad.js';\n    13→import type { ParsedStory, BridgeImportResult } from './bmad.js';\n    14→import { appendGapId } from './beads.js';\n    15→import type { BeadsIssue } from './beads.js';\n    16→import type { ScanResult, CoverageGapReport, DocAuditResult } from './scanner.js';\n    17→// ─── Types ──────────────────────────────────────────────────────────────────\n    18→\n    19→export interface OnboardingStory {\n    20→  key: string;\n    21→  title: string;\n    22→  type: 'coverage' | 'agents-md' | 'architecture' | 'doc-freshness' | 'verification' | 'observability';\n    23→  module?: string;\n    24→  storyKey?: string;\n    25→  acceptanceCriteria: string[];\n    26→}\n    27→\n    28→export interface EpicSummary {\n    29→  totalStories: number;\n    30→  coverageStories: number;\n    31→  docStories: number;\n    32→  verificationStories: number;\n    33→  observabilityStories: number;\n    34→}\n    35→\n    36→export interface OnboardingEpic {\n    37→  title: string;\n    38→  generatedAt: string;\n    39→  stories: OnboardingStory[];\n    40→  summary: EpicSummary;\n    41→}\n    42→\n    43→// ─── Priority Mapping ───────────────────────────────────────────────────────\n    44→\n    45→const PRIORITY_BY_TYPE: Record<OnboardingStory['type'], number> = {\n    46→  observability: 1,\n    47→  coverage: 2,\n    48→  verification: 2,\n    49→  'agents-md': 3,\n    50→  architecture: 3,\n    51→  'doc-freshness': 3,\n    52→};\n    53→\n    54→// ─── Epic Generation ────────────────────────────────────────────────────────\n    55→\n    56→/**\n    57→ * Generates an onboarding epic from scan findings.\n    58→ * Maps coverage gaps, missing docs, stale docs, and bmalph artifacts to stories.\n    59→ *\n    60→ * @param rootDir - Project root directory (defaults to cwd)\n    61→ */\n    62→export function generateOnboardingEpic(\n    63→  scan: ScanResult,\n    64→  coverage: CoverageGapReport,\n    65→  audit: DocAuditResult,\n    66→  rootDir?: string,\n    67→): OnboardingEpic {\n    68→  const root = rootDir ?? process.cwd();\n    69→  const stories: OnboardingStory[] = [];\n    70→  let storyNum = 1;\n    71→\n    72→  // README.md story — verification gate requires it (Epic 13, story 13-2)\n    73→  const readmeDoc = audit.documents.find(d => d.name === 'README.md');\n    74→  if (readmeDoc && readmeDoc.grade === 'missing') {\n    75→    stories.push({\n    76→      key: `0.${storyNum}`,\n    77→      title: 'Create README.md',\n    78→      type: 'doc-freshness',\n    79→      acceptanceCriteria: [\n    80→        '**Given** no README.md exists\\n**When** the agent runs `codeharness init`\\n**Then** README.md is created with project name, installation command, Quick Start section, and CLI reference',\n    81→      ],\n    82→    });\n    83→    storyNum++;\n    84→  }\n    85→\n    86→  // Architecture story — if ARCHITECTURE.md is missing\n    87→  const archDoc = audit.documents.find(d => d.name === 'ARCHITECTURE.md');\n    88→  if (archDoc && archDoc.grade === 'missing') {\n    89→    stories.push({\n    90→      key: `0.${storyNum}`,\n    91→      title: 'Create ARCHITECTURE.md',\n    92→      type: 'architecture',\n    93→      acceptanceCriteria: [\n    94→        '**Given** no ARCHITECTURE.md exists\\n**When** the agent analyzes the codebase\\n**Then** ARCHITECTURE.md is created with module overview and dependencies',\n    95→      ],\n    96→    });\n    97→    storyNum++;\n    98→  }\n    99→\n   100→  // AGENTS.md stories — one per module missing AGENTS.md\n   101→  for (const mod of scan.modules) {\n   102→    const agentsPath = join(root, mod.path, 'AGENTS.md');\n   103→    if (!existsSync(agentsPath)) {\n   104→      stories.push({\n   105→        key: `0.${storyNum}`,\n   106→        title: `Create ${mod.path}/AGENTS.md`,\n   107→        type: 'agents-md',\n   108→        module: mod.path,\n   109→        acceptanceCriteria: [\n   110→          `**Given** ${mod.path} has ${mod.sourceFiles} source files and no AGENTS.md\\n**When** the agent reads the module\\n**Then** ${mod.path}/AGENTS.md is created with module purpose and key files`,\n   111→        ],\n   112→      });\n   113→      storyNum++;\n   114→    }\n   115→  }\n   116→\n   117→  // Coverage stories — one per module below 100%\n   118→  for (const mod of coverage.modules) {\n   119→    if (mod.coveragePercent < 100) {\n   120→      stories.push({\n   121→        key: `0.${storyNum}`,\n   122→        title: `Add test coverage for ${mod.path}`,\n   123→        type: 'coverage',\n   124→        module: mod.path,\n   125→        acceptanceCriteria: [\n   126→          `**Given** ${mod.path} has ${mod.uncoveredFileCount} uncovered files at ${mod.coveragePercent}% coverage\\n**When** the agent writes tests\\n**Then** ${mod.path} has 100% test coverage`,\n   127→        ],\n   128→      });\n   129→      storyNum++;\n   130→    }\n   131→  }\n   132→\n   133→  // Doc freshness stories — one story listing all stale documents\n   134→  const staleDocs = audit.documents.filter(d => d.grade === 'stale');\n   135→  if (staleDocs.length > 0) {\n   136→    const staleNames = staleDocs.map(d => d.name).join(', ');\n   137→    stories.push({\n   138→      key: `0.${storyNum}`,\n   139→      title: 'Update stale documentation',\n   140→      type: 'doc-freshness',\n   141→      acceptanceCriteria: [\n   142→        `**Given** the following documents are stale: ${staleNames}\\n**When** the agent reviews them against current source\\n**Then** all stale documents are updated to reflect the current codebase`,\n   143→      ],\n   144→    });\n   145→    storyNum++;\n   146→  }\n   147→\n   148→  // Build summary\n   149→  const coverageStories = stories.filter(s => s.type === 'coverage').length;\n   150→  const docStories = stories.filter(\n   151→    s => s.type === 'agents-md' || s.type === 'architecture' || s.type === 'doc-freshness',\n   152→  ).length;\n   153→  const verificationStories = stories.filter(s => s.type === 'verification').length;\n   154→  const observabilityStories = stories.filter(s => s.type === 'observability').length;\n   155→\n   156→  return {\n   157→    title: 'Onboarding Epic: Bring Project to Harness Compliance',\n   158→    generatedAt: new Date().toISOString().replace(/\\.\\d{3}Z$/, 'Z'),\n   159→    stories,\n   160→    summary: {\n   161→      totalStories: stories.length,\n   162→      coverageStories,\n   163→      docStories,\n   164→      verificationStories,\n   165→      observabilityStories,\n   166→    },\n   167→  };\n   168→}\n   169→\n   170→// ─── Markdown Writing ───────────────────────────────────────────────────────\n   171→\n   172→/**\n   173→ * Writes the onboarding epic to a markdown file.\n   174→ * Creates parent directories if needed (Task 4).\n   175→ */\n   176→export function writeOnboardingEpic(epic: OnboardingEpic, outputPath: string): void {\n   177→  mkdirSync(dirname(outputPath), { recursive: true });\n   178→\n   179→  const lines: string[] = [];\n   180→  lines.push(`# ${epic.title}`);\n   181→  lines.push('');\n   182→  lines.push(`Generated: ${epic.generatedAt}`);\n   183→  lines.push('');\n   184→  lines.push('## Epic 0: Onboarding');\n   185→  lines.push('');\n   186→\n   187→  for (const story of epic.stories) {\n   188→    lines.push(`### Story ${story.key}: ${story.title}`);\n   189→    lines.push('');\n   190→\n   191→    // User story\n   192→    if (story.type === 'coverage') {\n   193→      lines.push(`As a developer, I want tests for ${story.module} to ensure correctness.`);\n   194→    } else if (story.type === 'agents-md') {\n   195→      lines.push(`As an agent, I want AGENTS.md for ${story.module} so I have local context.`);\n   196→    } else if (story.type === 'architecture') {\n   197→      lines.push(\"As a developer, I want an ARCHITECTURE.md documenting the project's architecture.\");\n   198→    } else if (story.type === 'doc-freshness') {\n   199→      lines.push('As a developer, I want up-to-date documentation reflecting the current codebase.');\n   200→    } else if (story.type === 'verification') {\n   201→      lines.push(`As a developer, I want verification proof for ${story.storyKey} to ensure it's properly documented.`);\n   202→    } else if (story.type === 'observability') {\n   203→      lines.push('As a developer, I want observability infrastructure configured so the harness can monitor runtime behavior.');\n   204→    }\n   205→    lines.push('');\n   206→\n   207→    // Acceptance criteria\n   208→    for (const ac of story.acceptanceCriteria) {\n   209→      lines.push(ac);\n   210→    }\n   211→    lines.push('');\n   212→  }\n   213→\n   214→  lines.push('---');\n   215→  lines.push('');\n   216→  lines.push(`**Total stories:** ${epic.stories.length}`);\n   217→  lines.push('');\n   218→  lines.push('Review and approve before execution.');\n   219→  lines.push('');\n   220→\n   221→  writeFileSync(outputPath, lines.join('\\n'), 'utf-8');\n   222→}\n   223→\n   224→// ─── Summary Formatting ─────────────────────────────────────────────────────\n   225→\n   226→/**\n   227→ * Returns a human-readable summary string for the epic.\n   228→ */\n   229→export function formatEpicSummary(epic: OnboardingEpic): string {\n   230→  const { totalStories, coverageStories, docStories, verificationStories, observabilityStories } = epic.summary;\n   231→  return `Onboarding plan: ${totalStories} stories (${coverageStories} coverage, ${docStories} documentation, ${verificationStories} verification, ${observabilityStories} observability)`;\n   232→}\n   233→\n   234→// ─── Interactive Approval ───────────────────────────────────────────────────\n   235→\n   236→/**\n   237→ * Prompts the user for approval via readline.\n   238→ * Returns true on Y, y, or empty input. Returns false otherwise.\n   239→ */\n   240→export function promptApproval(): Promise<boolean> {\n   241→  return new Promise((resolve) => {\n   242→    let answered = false;\n   243→    const rl = createInterface({\n   244→      input: process.stdin,\n   245→      output: process.stdout,\n   246→    });\n   247→\n   248→    rl.on('close', () => {\n   249→      if (!answered) {\n   250→        answered = true;\n   251→        resolve(false);\n   252→      }\n   253→    });\n   254→\n   255→    rl.question('Review the onboarding plan. Approve? [Y/n] ', (answer) => {\n   256→      answered = true;\n   257→      rl.close();\n   258→      const trimmed = answer.trim().toLowerCase();\n   259→      resolve(trimmed === '' || trimmed === 'y');\n   260→    });\n   261→  });\n   262→}\n   263→\n   264→// ─── Beads Import ───────────────────────────────────────────────────────────\n   265→\n   266→/**\n   267→ * Imports the onboarding epic into beads by parsing the markdown file\n   268→ * and calling importStoriesToBeads. Sets type='task' and priority by story type.\n   269→ */\n   270→export function importOnboardingEpic(\n   271→  epicPath: string,\n   272→  beadsFns: {\n   273→    listIssues: () => BeadsIssue[];\n   274→    createIssue: (title: string, opts?: {\n   275→      type?: string;\n   276→      priority?: number;\n   277→      description?: string;\n   278→      deps?: string[];\n   279→    }) => BeadsIssue;\n   280→  },\n   281→): BridgeImportResult[] {\n   282→  const epics = parseEpicsFile(epicPath);\n   283→\n   284→  // Flatten all stories from all epics\n   285→  const allStories: ParsedStory[] = [];\n   286→  for (const epic of epics) {\n   287→    for (const story of epic.stories) {\n   288→      allStories.push(story);\n   289→    }\n   290→  }\n   291→\n   292→  if (allStories.length === 0) {\n   293→    return [];\n   294→  }\n   295→\n   296→  // Wrap beadsFns to override type='task', set priority by story type pattern,\n   297→  // and append gap-id tags for onboarding deduplication (story 8-2).\n   298→  const wrappedBeadsFns = {\n   299→    listIssues: beadsFns.listIssues,\n   300→    createIssue: (title: string, opts?: {\n   301→      type?: string;\n   302→      priority?: number;\n   303→      description?: string;\n   304→      deps?: string[];\n   305→    }) => {\n   306→      const priority = getPriorityFromTitle(title);\n   307→      const gapId = getGapIdFromTitle(title);\n   308→      const description = gapId\n   309→        ? appendGapId(opts?.description, gapId)\n   310→        : opts?.description;\n   311→      return beadsFns.createIssue(title, {\n   312→        ...opts,\n   313→        type: 'task',\n   314→        priority,\n   315→        description,\n   316→      });\n   317→    },\n   318→  };\n   319→\n   320→  return importStoriesToBeads(allStories, {}, wrappedBeadsFns);\n   321→}\n   322→\n   323→/**\n   324→ * Maps story title to priority based on the story type pattern.\n   325→ */\n   326→function getPriorityFromTitle(title: string): number {\n   327→  if (title.startsWith('Add test coverage for ')) return PRIORITY_BY_TYPE.coverage;\n   328→  if (title.startsWith('Create ') && title.endsWith('AGENTS.md')) return PRIORITY_BY_TYPE['agents-md'];\n   329→  if (title === 'Create README.md') return PRIORITY_BY_TYPE['doc-freshness'];\n   330→  if (title === 'Create ARCHITECTURE.md') return PRIORITY_BY_TYPE.architecture;\n   331→  if (title === 'Update stale documentation') return PRIORITY_BY_TYPE['doc-freshness'];\n   332→  if (title.startsWith('Create verification proof for ')) return PRIORITY_BY_TYPE.verification;\n   333→  if (title === 'Configure OTLP instrumentation' || title === 'Start Docker observability stack') return PRIORITY_BY_TYPE.observability;\n   334→  return 3; // default\n   335→}\n   336→\n   337→/**\n   338→ * Derives a gap-id from an onboarding story title.\n   339→ * Returns the gap-id string, or null if the title doesn't match a known pattern.\n   340→ * Uses the same mapping as storyToGapId (in onboard-checks.ts) but works from title strings\n   341→ * (needed because importOnboardingEpic receives ParsedStory, not OnboardingStory).\n   342→ */\n   343→function getGapIdFromTitle(title: string): string | null {\n   344→  // coverage: \"Add test coverage for <module>\"\n   345→  if (title.startsWith('Add test coverage for ')) {\n   346→    const mod = title.slice('Add test coverage for '.length);\n   347→    return `[gap:coverage:${mod}]`;\n   348→  }\n   349→  // agents-md: \"Create <module>/AGENTS.md\"\n   350→  if (title.startsWith('Create ') && title.endsWith('/AGENTS.md')) {\n   351→    const mod = title.slice('Create '.length);\n   352→    return `[gap:docs:${mod}]`;\n   353→  }\n   354→  // readme\n   355→  if (title === 'Create README.md') {\n   356→    return '[gap:docs:README.md]';\n   357→  }\n   358→  // architecture\n   359→  if (title === 'Create ARCHITECTURE.md') {\n   360→    return '[gap:docs:ARCHITECTURE.md]';\n   361→  }\n   362→  // doc-freshness\n   363→  if (title === 'Update stale documentation') {\n   364→    return '[gap:docs:stale-docs]';\n   365→  }\n   366→  // verification: \"Create verification proof for <key>\"\n   367→  if (title.startsWith('Create verification proof for ')) {\n   368→    const key = title.slice('Create verification proof for '.length);\n   369→    return `[gap:verification:${key}]`;\n   370→  }\n   371→  // observability\n   372→  if (title === 'Configure OTLP instrumentation') {\n   373→    return '[gap:observability:otlp-config]';\n   374→  }\n   375→  if (title === 'Start Docker observability stack') {\n   376→    return '[gap:observability:docker-stack]';\n   377→  }\n   378→  return null;\n   379→}\n   380→"}]},"parent_tool_use_id":"toolu_01GUR1dsNVzUTLzShG1rFUcD","session_id":"0deb1693-f450-4ee3-ba9f-130c7ba0aec5","uuid":"fc8040f8-1e95-45d3-af3e-8198304206ca","timestamp":"2026-03-20T09:12:53.419Z"}
