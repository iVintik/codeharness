{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BmSRZ21LBML2oKhnFGUUpX","type":"tool_result","content":"1\timport { readFileSync } from 'node:fs';\n2\timport { parse } from 'yaml';\n3\timport { validateWorkflowSchema } from './schema-validate.js';\n4\t\n5\t// --- Interfaces ---\n6\t\n7\texport interface ResolvedTask {\n8\t  agent: string;\n9\t  scope: 'per-story' | 'per-run';\n10\t  session: 'fresh' | 'continue';\n11\t  source_access: boolean;\n12\t  prompt_template?: string;\n13\t  input_contract?: Record<string, unknown>;\n14\t  output_contract?: Record<string, unknown>;\n15\t  max_budget_usd?: number;\n16\t}\n17\t\n18\texport interface LoopBlock {\n19\t  loop: string[];\n20\t}\n21\t\n22\texport type FlowStep = string | LoopBlock;\n23\t\n24\texport interface ResolvedWorkflow {\n25\t  tasks: Record<string, ResolvedTask>;\n26\t  flow: FlowStep[];\n27\t}\n28\t\n29\t// --- Error Class ---\n30\t\n31\texport class WorkflowParseError extends Error {\n32\t  public readonly errors: Array<{ path: string; message: string }>;\n33\t\n34\t  constructor(message: string, errors?: Array<{ path: string; message: string }>) {\n35\t    super(message);\n36\t    this.name = 'WorkflowParseError';\n37\t    this.errors = errors ?? [];\n38\t  }\n39\t}\n40\t\n41\t// --- Parser ---\n42\t\n43\t/**\n44\t * Parse a workflow YAML file from disk, validate it against the JSON schema,\n45\t * check referential integrity, apply defaults, and return a typed ResolvedWorkflow.\n46\t */\n47\texport function parseWorkflow(filePath: string): ResolvedWorkflow {\n48\t  // 1. Read file\n49\t  let raw: string;\n50\t  try {\n51\t    raw = readFileSync(filePath, 'utf-8');\n52\t  } catch (err: unknown) {\n53\t    const code = err instanceof Error && 'code' in err ? (err as NodeJS.ErrnoException).code : undefined;\n54\t    const detail = code === 'ENOENT'\n55\t      ? 'File not found'\n56\t      : code === 'EACCES'\n57\t        ? 'Permission denied'\n58\t        : code === 'EISDIR'\n59\t          ? 'Path is a directory'\n60\t          : 'File not found or unreadable';\n61\t    throw new WorkflowParseError(`${detail}: ${filePath}`, [\n62\t      { path: filePath, message: detail },\n63\t    ]);\n64\t  }\n65\t\n66\t  // 2. Parse YAML\n67\t  let parsed: unknown;\n68\t  try {\n69\t    parsed = parse(raw);\n70\t  } catch (err: unknown) {\n71\t    const yamlMsg = err instanceof Error ? err.message : String(err);\n72\t    throw new WorkflowParseError(`Invalid YAML syntax: ${yamlMsg}`, [\n73\t      { path: filePath, message: yamlMsg },\n74\t    ]);\n75\t  }\n76\t\n77\t  // 3. Validate against JSON schema\n78\t  const result = validateWorkflowSchema(parsed);\n79\t  if (!result.valid) {\n80\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n81\t    throw new WorkflowParseError(\n82\t      `Schema validation failed: ${details}`,\n83\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n84\t    );\n85\t  }\n86\t\n87\t  // At this point, parsed has passed schema validation — safe to cast\n88\t  const data = parsed as { tasks: Record<string, Record<string, unknown>>; flow: unknown[] };\n89\t\n90\t  // 4. Referential integrity check\n91\t  const taskNames = new Set(Object.keys(data.tasks));\n92\t  const danglingRefs: Array<{ path: string; message: string }> = [];\n93\t\n94\t  for (let i = 0; i < data.flow.length; i++) {\n95\t    const step = data.flow[i];\n96\t    if (typeof step === 'string') {\n97\t      if (!taskNames.has(step)) {\n98\t        danglingRefs.push({\n99\t          path: `/flow/${i}`,\n100\t          message: `Task \"${step}\" referenced in flow but not defined in tasks`,\n101\t        });\n102\t      }\n103\t    } else if (typeof step === 'object' && step !== null && 'loop' in step) {\n104\t      const loopBlock = step as { loop: string[] };\n105\t      for (let j = 0; j < loopBlock.loop.length; j++) {\n106\t        const ref = loopBlock.loop[j];\n107\t        if (!taskNames.has(ref)) {\n108\t          danglingRefs.push({\n109\t            path: `/flow/${i}/loop/${j}`,\n110\t            message: `Task \"${ref}\" referenced in loop but not defined in tasks`,\n111\t          });\n112\t        }\n113\t      }\n114\t    }\n115\t  }\n116\t\n117\t  if (danglingRefs.length > 0) {\n118\t    const details = danglingRefs.map((e) => e.message).join('; ');\n119\t    throw new WorkflowParseError(`Dangling task references: ${details}`, danglingRefs);\n120\t  }\n121\t\n122\t  // 5. Apply defaults and build resolved tasks\n123\t  const resolvedTasks: Record<string, ResolvedTask> = {};\n124\t  for (const [name, task] of Object.entries(data.tasks)) {\n125\t    const resolved: ResolvedTask = {\n126\t      agent: task.agent as string,\n127\t      scope: (task.scope as ResolvedTask['scope']) ?? 'per-story',\n128\t      session: (task.session as ResolvedTask['session']) ?? 'fresh',\n129\t      source_access: (task.source_access as boolean) ?? true,\n130\t    };\n131\t    if (task.prompt_template !== undefined) {\n132\t      resolved.prompt_template = task.prompt_template as string;\n133\t    }\n134\t    if (task.input_contract !== undefined) {\n135\t      resolved.input_contract = task.input_contract as Record<string, unknown>;\n136\t    }\n137\t    if (task.output_contract !== undefined) {\n138\t      resolved.output_contract = task.output_contract as Record<string, unknown>;\n139\t    }\n140\t    if (task.max_budget_usd !== undefined) {\n141\t      resolved.max_budget_usd = task.max_budget_usd as number;\n142\t    }\n143\t    resolvedTasks[name] = resolved;\n144\t  }\n145\t\n146\t  // 6. Build resolved flow\n147\t  const resolvedFlow: FlowStep[] = data.flow.map((step) => {\n148\t    if (typeof step === 'string') {\n149\t      return step;\n150\t    }\n151\t    return step as LoopBlock;\n152\t  });\n153\t\n154\t  return { tasks: resolvedTasks, flow: resolvedFlow };\n155\t}\n156\t"}]},"parent_tool_use_id":"toolu_01ELiUhcroCmkW9Cb6Be3ouH","session_id":"452c48b4-eed2-4c96-83e9-8c71df0bbdac","uuid":"581b917a-fe20-4386-90ce-8c77079f6b1c","timestamp":"2026-04-02T23:18:05.300Z"}
