{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016CRnB5LtDZWsvrZ5y8tugg","type":"tool_result","content":"60\t * Pattern: `{epicNum}-{storyNum}-{slug}` -> `{epicNum}`.\n61\t * Sentinel `__run__` -> `\"unknown\"`.\n62\t */\n63\tfunction extractEpicId(storyKey: string): string {\n64\t  if (storyKey === '__run__') return 'unknown';\n65\t  const dash = storyKey.indexOf('-');\n66\t  if (dash === -1) return storyKey;\n67\t  return storyKey.slice(0, dash);\n68\t}\n69\t\n70\t/**\n71\t * Write a telemetry entry after a story completes.\n72\t *\n73\t * Appends one NDJSON line to `.codeharness/telemetry.jsonl`.\n74\t * Creates the `.codeharness/` directory if it does not exist.\n75\t */\n76\texport async function writeTelemetryEntry(ctx: TaskContext): Promise<NullTaskResult> {\n77\t  const epicId = extractEpicId(ctx.storyKey);\n78\t  const contract = ctx.outputContract;\n79\t\n80\t  const entry: TelemetryEntry = {\n81\t    version: 1,\n82\t    timestamp: new Date().toISOString(),\n83\t    storyKey: ctx.storyKey,\n84\t    epicId,\n85\t    duration_ms: ctx.durationMs,\n86\t    cost_usd: ctx.cost ?? null,\n87\t    attempts: null,\n88\t    acResults: contract?.acceptanceCriteria\n89\t      ? (contract.acceptanceCriteria as readonly ACStatus[]).map((ac) => ({"}]},"parent_tool_use_id":"toolu_01EThU22wRDbXmvukgem8PY8","session_id":"3330d992-072a-4898-af8b-5f3f7e12cbac","uuid":"02c0feea-b59a-4c72-a897-4e6c3303557c","timestamp":"2026-04-03T17:49:58.728Z"}
