{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01S25FDtcm7yekitNgNawx9z","type":"tool_result","content":"     1→import { existsSync, readFileSync } from 'node:fs';\n     2→import { join } from 'node:path';\n     3→import { warn } from './output.js';\n     4→\n     5→export type AppType = 'server' | 'cli' | 'web' | 'agent' | 'generic';\n     6→\n     7→export function detectStack(dir: string = process.cwd()): string | null {\n     8→  if (existsSync(join(dir, 'package.json'))) return 'nodejs';\n     9→  if (existsSync(join(dir, 'requirements.txt'))) return 'python';\n    10→  if (existsSync(join(dir, 'pyproject.toml'))) return 'python';\n    11→  if (existsSync(join(dir, 'setup.py'))) return 'python';\n    12→  if (existsSync(join(dir, 'Cargo.toml'))) return 'rust';\n    13→  warn('No recognized stack detected');\n    14→  return null;\n    15→}\n    16→\n    17→const AGENT_DEPS_NODE = ['anthropic', '@anthropic-ai/sdk', 'openai', 'langchain', '@langchain/core', 'llamaindex'];\n    18→const AGENT_DEPS_PYTHON = ['anthropic', 'openai', 'langchain', 'llama-index', 'traceloop-sdk'];\n    19→const WEB_FRAMEWORK_DEPS = ['react', 'vue', 'svelte', 'angular', '@angular/core', 'next', 'nuxt', 'vite', 'webpack'];\n    20→const PYTHON_WEB_FRAMEWORKS = ['flask', 'django', 'fastapi', 'streamlit'];\n    21→const RUST_WEB_FRAMEWORKS = ['actix-web', 'axum', 'rocket', 'tide', 'warp'];\n    22→const RUST_AGENT_DEPS = ['async-openai', 'anthropic', 'llm-chain'];\n    23→\n    24→function readJsonSafe(path: string): Record<string, unknown> | null {\n    25→  try {\n    26→    if (!existsSync(path)) return null;\n    27→    return JSON.parse(readFileSync(path, 'utf-8')) as Record<string, unknown>;\n    28→  } catch {\n    29→    return null;\n    30→  }\n    31→}\n    32→\n    33→function readTextSafe(path: string): string | null {\n    34→  try {\n    35→    if (!existsSync(path)) return null;\n    36→    return readFileSync(path, 'utf-8');\n    37→  } catch {\n    38→    return null;\n    39→  }\n    40→}\n    41→\n    42→function getNodeDeps(pkg: Record<string, unknown>): Set<string> {\n    43→  const deps = new Set<string>();\n    44→  for (const field of ['dependencies', 'devDependencies']) {\n    45→    const section = pkg[field] as Record<string, string> | undefined;\n    46→    if (section && typeof section === 'object') {\n    47→      for (const key of Object.keys(section)) {\n    48→        deps.add(key);\n    49→      }\n    50→    }\n    51→  }\n    52→  return deps;\n    53→}\n    54→\n    55→function hasPythonDep(content: string, dep: string): boolean {\n    56→  // Match dep name as a standalone package, not as a substring of another package.\n    57→  // Handles requirements.txt lines like \"openai>=1.0\", pyproject.toml entries like '\"openai\"',\n    58→  // and extras like \"openai[all]\". Uses word boundary or common delimiters to avoid\n    59→  // matching \"not-openai\" or \"myopenai\".\n    60→  const escaped = dep.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n    61→  const pattern = new RegExp(`(?:^|[\\\\s\"',])${escaped}(?:[\\\\[>=<~!;\\\\s\"',]|$)`, 'm');\n    62→  return pattern.test(content);\n    63→}\n    64→\n    65→function getPythonDepsContent(dir: string): string {\n    66→  const files = ['requirements.txt', 'pyproject.toml', 'setup.py'];\n    67→  const parts: string[] = [];\n    68→  for (const file of files) {\n    69→    const content = readTextSafe(join(dir, file));\n    70→    if (content) parts.push(content);\n    71→  }\n    72→  return parts.join('\\n');\n    73→}\n    74→\n    75→export function detectAppType(dir: string, stack: string | null): AppType {\n    76→  if (stack === 'nodejs') {\n    77→    const pkg = readJsonSafe(join(dir, 'package.json'));\n    78→    if (!pkg) return 'generic';\n    79→\n    80→    const deps = getNodeDeps(pkg);\n    81→\n    82→    // Priority 1: Agent detection\n    83→    if (AGENT_DEPS_NODE.some(d => deps.has(d))) {\n    84→      return 'agent';\n    85→    }\n    86→\n    87→    // Priority 2: Web detection\n    88→    if (WEB_FRAMEWORK_DEPS.some(d => deps.has(d))) {\n    89→      return 'web';\n    90→    }\n    91→    if (\n    92→      existsSync(join(dir, 'index.html')) ||\n    93→      existsSync(join(dir, 'public', 'index.html')) ||\n    94→      existsSync(join(dir, 'src', 'index.html'))\n    95→    ) {\n    96→      return 'web';\n    97→    }\n    98→\n    99→    // Priority 3: CLI detection\n   100→    const bin = pkg['bin'];\n   101→    const scripts = pkg['scripts'] as Record<string, string> | undefined;\n   102→    const hasStart = scripts?.['start'] !== undefined;\n   103→    if (bin && !hasStart) {\n   104→      return 'cli';\n   105→    }\n   106→\n   107→    // Priority 4: Server detection\n   108→    if (hasStart) {\n   109→      return 'server';\n   110→    }\n   111→\n   112→    return 'generic';\n   113→  }\n   114→\n   115→  if (stack === 'python') {\n   116→    const content = getPythonDepsContent(dir);\n   117→\n   118→    // Priority 1: Agent detection\n   119→    if (AGENT_DEPS_PYTHON.some(d => hasPythonDep(content, d))) {\n   120→      return 'agent';\n   121→    }\n   122→\n   123→    // Priority 2: Web detection (framework + templates/static dirs)\n   124→    const hasWebFramework = PYTHON_WEB_FRAMEWORKS.some(d => hasPythonDep(content, d));\n   125→    if (hasWebFramework) {\n   126→      const hasTemplates = existsSync(join(dir, 'templates'));\n   127→      const hasStatic = existsSync(join(dir, 'static'));\n   128→      if (hasTemplates || hasStatic) {\n   129→        return 'web';\n   130→      }\n   131→      // Bare Flask/Django/FastAPI without templates => server\n   132→      return 'server';\n   133→    }\n   134→\n   135→    // Priority 4: Server detection (has main entry point)\n   136→    if (\n   137→      existsSync(join(dir, 'app.py')) ||\n   138→      existsSync(join(dir, 'main.py')) ||\n   139→      existsSync(join(dir, 'manage.py'))\n   140→    ) {\n   141→      return 'server';\n   142→    }\n   143→\n   144→    return 'generic';\n   145→  }\n   146→\n   147→  if (stack === 'rust') {\n   148→    const cargoContent = readTextSafe(join(dir, 'Cargo.toml'));\n   149→    if (!cargoContent) return 'generic';\n   150→\n   151→    // Priority 1: Agent detection\n   152→    if (RUST_AGENT_DEPS.some(d => cargoContent.includes(d))) {\n   153→      return 'agent';\n   154→    }\n   155→\n   156→    // Priority 2: Server detection (web framework)\n   157→    if (RUST_WEB_FRAMEWORKS.some(d => cargoContent.includes(d))) {\n   158→      return 'server';\n   159→    }\n   160→\n   161→    // Priority 3: CLI detection ([[bin]] without web framework)\n   162→    if (cargoContent.includes('[[bin]]')) {\n   163→      return 'cli';\n   164→    }\n   165→\n   166→    // Priority 4: Library detection ([lib] without [[bin]])\n   167→    if (cargoContent.includes('[lib]')) {\n   168→      return 'generic';\n   169→    }\n   170→\n   171→    return 'generic';\n   172→  }\n   173→\n   174→  return 'generic';\n   175→}\n   176→"}]},"parent_tool_use_id":"toolu_01UrsWACEgNx3cQjKftiWn4D","session_id":"6b184f1a-3a3f-4307-8da0-d8cf52066851","uuid":"9fc2fac5-b6c8-4402-ae4d-f222267bb653","timestamp":"2026-03-23T05:11:58.432Z"}
