{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BtPfPS8QkZK93tfSxHwsof","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n2\timport fs from 'node:fs';\n3\timport path from 'node:path';\n4\timport os from 'node:os';\n5\timport YAML from 'yaml';\n6\timport {\n7\t  loadEmbeddedAgent,\n8\t  loadPatch,\n9\t  mergePatch,\n10\t  resolveAgent,\n11\t  compileSubagentDefinition,\n12\t  AgentResolveError,\n13\t} from '../agent-resolver.js';\n14\timport type { ResolvedAgent, AgentPatch } from '../agent-resolver.js';\n15\t\n16\tconst TEMPLATES_DIR = path.resolve(__dirname, '../../../templates/agents');\n17\t\n18\tconst EXPECTED_AGENTS = [\n19\t  'dev', 'qa', 'architect', 'pm', 'sm',\n20\t  'analyst', 'ux-designer', 'tech-writer', 'evaluator',\n21\t];\n22\t\n23\t// --- Helpers ---\n24\t\n25\tfunction makeMinimalAgent(overrides?: Partial<ResolvedAgent>): ResolvedAgent {\n26\t  return {\n27\t    name: 'test-agent',\n28\t    role: { title: 'Test Agent', purpose: 'Testing' },\n29\t    persona: {\n30\t      identity: 'A test agent for unit tests',\n31\t      communication_style: 'Direct and clear',\n32\t      principles: ['Be thorough', 'Be honest'],\n33\t    },\n34\t    ...overrides,\n35\t  };\n36\t}\n37\t\n38\tfunction writeTempYaml(dir: string, relativePath: string, content: unknown): string {\n39\t  const filePath = path.join(dir, relativePath);\n40\t  const dirPath = path.dirname(filePath);\n41\t  fs.mkdirSync(dirPath, { recursive: true });\n42\t  fs.writeFileSync(filePath, YAML.stringify(content), 'utf-8');\n43\t  return filePath;\n44\t}\n45\t\n46\t// --- Tests ---\n47\t\n48\tdescribe('agent-resolver', () => {\n49\t  describe('loadEmbeddedAgent', () => {\n50\t    it('loads dev.yaml and returns valid ResolvedAgent (AC #1)', () => {\n51\t      const agent = loadEmbeddedAgent('dev');\n52\t      expect(agent.name).toBe('dev');\n53\t      expect(agent.role.title).toBeDefined();\n54\t      expect(agent.persona.identity).toBeDefined();\n55\t      expect(agent.persona.communication_style).toBeDefined();\n56\t      expect(Array.isArray(agent.persona.principles)).toBe(true);\n57\t    });\n58\t\n59\t    it('loads evaluator.yaml with disallowedTools (AC #7)', () => {\n60\t      const agent = loadEmbeddedAgent('evaluator');\n61\t      expect(agent.name).toBe('evaluator');\n62\t      expect(agent.disallowedTools).toContain('Edit');\n63\t      expect(agent.disallowedTools).toContain('Write');\n64\t    });\n65\t\n66\t    it('throws AgentResolveError for non-existent embedded agent', () => {\n67\t      expect(() => loadEmbeddedAgent('nonexistent-agent')).toThrow(AgentResolveError);\n68\t      try {\n69\t        loadEmbeddedAgent('nonexistent-agent');\n70\t      } catch (err) {\n71\t        const e = err as AgentResolveError;\n72\t        expect(e.filePath).toContain('nonexistent-agent.yaml');\n73\t        expect(e.errors.length).toBeGreaterThan(0);\n74\t      }\n75\t    });\n76\t\n77\t    it.each(EXPECTED_AGENTS)('loads %s.yaml successfully', (name) => {\n78\t      const agent = loadEmbeddedAgent(name);\n79\t      expect(agent.name).toBe(name);\n80\t    });"}]},"parent_tool_use_id":"toolu_01WKqZRgBCkcgk47tCVdMRvD","session_id":"84c2a87f-6818-4ede-b88c-dde16fd6e99b","uuid":"1c94f921-5252-4693-a7c2-236236c4429d","timestamp":"2026-04-02T19:43:11.922Z"}
