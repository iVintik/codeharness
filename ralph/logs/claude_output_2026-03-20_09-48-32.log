h')) { process.exit(1); }\n   295→    \"\n   296→    [ \"$status\" -eq 0 ]\n   297→}\n   298→\n   299→@test \"hooks.json: registers PreToolUse for Bash\" {\n   300→    run node -e \"\n   301→        const hooks = JSON.parse(require('fs').readFileSync('$HOOKS_DIR/hooks.json','utf8'));\n   302→        if (!hooks.PreToolUse) { process.exit(1); }\n   303→        const bash = hooks.PreToolUse.find(h => h.matcher === 'Bash');\n   304→        if (!bash) { process.exit(1); }\n   305→        if (!bash.hooks[0].command.includes('pre-commit-gate.sh')) { process.exit(1); }\n   306→    \"\n   307→    [ \"$status\" -eq 0 ]\n   308→}\n   309→\n   310→@test \"hooks.json: registers PostToolUse for Write and Edit\" {\n   311→    run node -e \"\n   312→        const hooks = JSON.parse(require('fs').readFileSync('$HOOKS_DIR/hooks.json','utf8'));\n   313→        if (!hooks.PostToolUse) { process.exit(1); }\n   314→        const write = hooks.PostToolUse.find(h => h.matcher === 'Write');\n   315→        const edit = hooks.PostToolUse.find(h => h.matcher === 'Edit');\n   316→        if (!write) { process.exit(1); }\n   317→        if (!edit) { process.exit(1); }\n   318→        if (!write.hooks[0].command.includes('post-write-check.sh')) { process.exit(1); }\n   319→        if (!edit.hooks[0].command.includes('post-write-check.sh')) { process.exit(1); }\n   320→    \"\n   321→    [ \"$status\" -eq 0 ]\n   322→}\n   323→\n   324→@test \"hooks.json: registers PostToolUse for Bash with post-test-verify\" {\n   325→    run node -e \"\n   326→        const hooks = JSON.parse(require('fs').readFileSync('$HOOKS_DIR/hooks.json','utf8'));\n   327→        const bash = hooks.PostToolUse.find(h => h.matcher === 'Bash');\n   328→        if (!bash) { process.exit(1); }\n   329→        if (!bash.hooks[0].command.includes('post-test-verify.sh')) { process.exit(1); }\n   330→    \"\n   331→    [ \"$status\" -eq 0 ]\n   332→}\n   333→"}]},"parent_tool_use_id":"toolu_01APL3Sm5JEakF5iK2mjDEd8","session_id":"