{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011cr6ajy8GGP6SGbQc75To9","type":"tool_result","content":"1\timport { Command } from 'commander';\n2\timport { registerInitCommand } from './commands/init.js';\n3\timport { registerBridgeCommand } from './commands/bridge.js';\n4\timport { registerRunCommand } from './commands/run.js';\n5\timport { registerVerifyCommand } from './commands/verify.js';\n6\timport { registerStatusCommand } from './commands/status.js';\n7\timport { registerOnboardCommand } from './commands/onboard.js';\n8\timport { registerTeardownCommand } from './commands/teardown.js';\n9\timport { registerStateCommand } from './commands/state.js';\n10\timport { registerSyncCommand } from './commands/sync.js';\n11\timport { registerCoverageCommand } from './commands/coverage.js';\n12\timport { registerDocHealthCommand } from './commands/doc-health.js';\n13\timport { registerStackCommand } from './commands/stack.js';\n14\timport { registerQueryCommand } from './commands/query.js';\n15\timport { registerRetroImportCommand } from './commands/retro-import.js';\n16\timport { registerGithubImportCommand } from './commands/github-import.js';\n17\timport { registerVerifyEnvCommand } from './commands/verify-env.js';\n18\timport { registerTimeoutReportCommand } from './commands/timeout-report.js';\n19\timport { registerValidateStateCommand } from './commands/validate-state.js';\n20\timport { registerValidateCommand } from './commands/validate.js';\n21\timport { registerProgressCommand } from './commands/progress.js';\n22\timport { registerObservabilityGateCommand } from './commands/observability-gate.js';\n23\timport { registerAuditCommand } from './commands/audit.js';\n24\timport { registerStatsCommand } from './commands/stats.js';\n25\timport { registerIssueCommand } from './commands/issue.js';\n26\t\n27\t// Library exports — available to consumers via `import { parseStreamLine } from 'codeharness'`\n28\texport { parseStreamLine } from './lib/agents/stream-parser.js';\n29\texport type { StreamEvent, ToolStartEvent, ToolInputEvent, ToolCompleteEvent, TextEvent, RetryEvent, ResultEvent } from './lib/agents/stream-parser.js';\n30\t\n31\tdeclare const __PKG_VERSION__: string;\n32\tconst VERSION = typeof __PKG_VERSION__ !== 'undefined' ? __PKG_VERSION__ : '0.0.0-dev';\n33\t\n34\texport function createProgram(): Command {\n35\t  const program = new Command();\n36\t\n37\t  program\n38\t    .name('codeharness')\n39\t    .description('Makes autonomous coding agents produce software that actually works')\n40\t    .version(VERSION)\n41\t    .option('--json', 'Output in machine-readable JSON format');\n42\t\n43\t  registerInitCommand(program);\n44\t  registerBridgeCommand(program);\n45\t  registerRunCommand(program);\n46\t  registerVerifyCommand(program);\n47\t  registerStatusCommand(program);\n48\t  registerOnboardCommand(program);\n49\t  registerTeardownCommand(program);\n50\t  registerStateCommand(program);\n51\t  registerSyncCommand(program);\n52\t  registerCoverageCommand(program);\n53\t  registerDocHealthCommand(program);\n54\t  registerStackCommand(program);\n55\t  registerQueryCommand(program);\n56\t  registerRetroImportCommand(program);\n57\t  registerGithubImportCommand(program);\n58\t  registerVerifyEnvCommand(program);\n59\t  // registerRetryCommand removed (Story 1.2) — retry merged into workflow-state (Epic 5)\n60\t  registerTimeoutReportCommand(program);\n61\t  registerValidateStateCommand(program);\n62\t  registerValidateCommand(program);\n63\t  registerProgressCommand(program);\n64\t  registerObservabilityGateCommand(program);\n65\t  registerAuditCommand(program);\n66\t  registerStatsCommand(program);\n67\t  registerIssueCommand(program);\n68\t\n69\t  return program;\n70\t}\n71\t\n72\t// Only parse when running as CLI entry point, not when imported in tests\n73\tif (!process.env['VITEST']) {\n74\t  const program = createProgram();\n75\t  program.parse(process.argv);\n76\t}\n77\t"}]},"parent_tool_use_id":"toolu_01CMZbq8RrvXCKSwd18t2Hto","session_id":"2800a04b-8151-4215-bf66-1f43973b9365","uuid":"bdc6e66c-0c04-40b3-9239-8c1552d9a6ec","timestamp":"2026-04-03T02:01:27.366Z"}
