{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Pu1h9gisiTPKm32eh3Lwe8","type":"tool_result","content":"1\t/**\n2\t * Public API for the agents subsystem.\n3\t *\n4\t * Re-exports types (story 10-1), stream parser functions/types,\n5\t * and the driver factory (story 10-2).\n6\t */\n7\t\n8\t// New types (Epic 10)\n9\texport type {\n10\t  AgentDriver,\n11\t  DriverHealth,\n12\t  DriverCapabilities,\n13\t  DispatchOpts,\n14\t  ErrorCategory,\n15\t  OutputContract,\n16\t  TestResults,\n17\t  ACStatus,\n18\t} from './types.js';\n19\t\n20\t// Deprecated types — kept for backward compatibility until story 10-3\n21\t/** @deprecated Use `DispatchOpts` instead. */\n22\texport type { SpawnOpts } from './types.js';\n23\t/** @deprecated Use `AsyncIterable<StreamEvent>` from `dispatch()` instead. */\n24\texport type { AgentProcess } from './types.js';\n25\t/** @deprecated Use `StreamEvent` from `stream-parser.ts` instead. */\n26\texport type { AgentEvent } from './types.js';\n27\t\n28\t// Stream parser\n29\texport { parseStreamLine } from './stream-parser.js';\n30\texport type {\n31\t  StreamEvent,\n32\t  ToolStartEvent,\n33\t  ToolInputEvent,\n34\t  ToolCompleteEvent,\n35\t  TextEvent,\n36\t  RetryEvent,\n37\t  ResultEvent,\n38\t} from './stream-parser.js';\n39\t\n40\t// --- Driver Factory ---\n41\t\n42\texport { getDriver, registerDriver, listDrivers, resetDrivers } from './drivers/factory.js';\n43\t\n44\t// --- Model Resolution ---\n45\t\n46\texport { resolveModel } from './model-resolver.js';\n47\t"}]},"parent_tool_use_id":"toolu_01LRGwVdnBi8B25YdHRso3f2","session_id":"2c102368-34ec-49f5-8d34-59f136ae42aa","uuid":"90f5d8c7-1ac5-4ec7-a0a1-1392954302f6","timestamp":"2026-04-03T07:25:18.858Z"}
