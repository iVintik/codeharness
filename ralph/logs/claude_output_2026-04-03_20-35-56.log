{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015wowGAhyiAHJkfaJ7BDon1","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach, afterEach } from 'vitest';\n2\timport { mkdtempSync, rmSync, writeFileSync } from 'node:fs';\n3\timport { tmpdir } from 'node:os';\n4\timport { join } from 'node:path';\n5\timport {\n6\t  resolveHierarchicalFlow,\n7\t  HierarchicalFlowError,\n8\t  BUILTIN_EPIC_FLOW_TASKS,\n9\t  EXECUTION_DEFAULTS,\n10\t  type ExecutionConfig,\n11\t} from '../hierarchical-flow.js';\n12\timport {\n13\t  parseWorkflow,\n14\t  WorkflowParseError,\n15\t  type ResolvedWorkflow,\n16\t  type ResolvedTask,\n17\t} from '../workflow-parser.js';\n18\timport { validateWorkflowSchema } from '../schema-validate.js';\n19\t\n20\tlet testDir: string;\n21\t\n22\tbeforeEach(() => {\n23\t  testDir = mkdtempSync(join(tmpdir(), 'ch-hflow-test-'));\n24\t});\n25\t\n26\tafterEach(() => {\n27\t  rmSync(testDir, { recursive: true, force: true });\n28\t});\n29\t\n30\tfunction writeYaml(filename: string, content: string): string {\n31\t  const filePath = join(testDir, filename);\n32\t  writeFileSync(filePath, content, 'utf-8');\n33\t  return filePath;\n34\t}\n35\t\n36\tfunction makeTask(overrides?: Partial<ResolvedTask>): ResolvedTask {\n37\t  return {\n38\t    agent: 'dev',\n39\t    scope: 'per-story',\n40\t    session: 'fresh',\n41\t    source_access: true,\n42\t    ...overrides,\n43\t  };\n44\t}\n45\t\n46\t// --- Schema validation tests (AC #1, #2, #3, #10, #11) ---\n47\t\n48\tdescribe('workflow.schema.json — hierarchical extensions', () => {\n49\t  describe('execution section (AC #1)', () => {\n50\t    it('accepts a valid execution section with all properties', () => {\n51\t      const result = validateWorkflowSchema({\n52\t        tasks: { implement: { agent: 'dev' } },\n53\t        flow: ['implement'],\n54\t        execution: {\n55\t          max_parallel: 4,\n56\t          isolation: 'worktree',\n57\t          merge_strategy: 'rebase',\n58\t          epic_strategy: 'parallel',\n59\t          story_strategy: 'parallel',\n60\t        },\n61\t      });\n62\t      expect(result.valid).toBe(true);\n63\t    });\n64\t\n65\t    it('accepts execution with partial properties (defaults apply)', () => {\n66\t      const result = validateWorkflowSchema({\n67\t        tasks: { implement: { agent: 'dev' } },\n68\t        flow: ['implement'],\n69\t        execution: { max_parallel: 2 },\n70\t      });\n71\t      expect(result.valid).toBe(true);\n72\t    });\n73\t\n74\t    it('accepts empty execution object', () => {\n75\t      const result = validateWorkflowSchema({\n76\t        tasks: { implement: { agent: 'dev' } },\n77\t        flow: ['implement'],\n78\t        execution: {},\n79\t      });\n80\t      expect(result.valid).toBe(true);\n81\t    });\n82\t\n83\t    it('rejects invalid isolation value', () => {\n84\t      const result = validateWorkflowSchema({\n85\t        tasks: { implement: { agent: 'dev' } },\n86\t        flow: ['implement'],\n87\t        execution: { isolation: 'docker' },\n88\t      });\n89\t      expect(result.valid).toBe(false);\n90\t    });\n91\t\n92\t    it('rejects invalid epic_strategy value', () => {\n93\t      const result = validateWorkflowSchema({\n94\t        tasks: { implement: { agent: 'dev' } },\n95\t        flow: ['implement'],\n96\t        execution: { epic_strategy: 'random' },\n97\t      });\n98\t      expect(result.valid).toBe(false);\n99\t    });\n100\t  });\n101\t\n102\t  describe('story_flow section (AC #2)', () => {\n103\t    it('accepts story_flow with task ref strings', () => {\n104\t      const result = validateWorkflowSchema({\n105\t        tasks: { implement: { agent: 'dev' }, verify: { agent: 'qa' } },\n106\t        story_flow: ['implement', 'verify'],\n107\t      });\n108\t      expect(result.valid).toBe(true);\n109\t    });\n110\t\n111\t    it('accepts story_flow with loop blocks', () => {\n112\t      const result = validateWorkflowSchema({\n113\t        tasks: { implement: { agent: 'dev' }, retry: { agent: 'dev' } },\n114\t        story_flow: ['implement', { loop: ['retry'] }],\n115\t      });\n116\t      expect(result.valid).toBe(true);\n117\t    });\n118\t  });\n119\t\n120\t  describe('epic_flow section (AC #3)', () => {\n121\t    it('accepts epic_flow with task ref strings', () => {\n122\t      const result = validateWorkflowSchema({\n123\t        tasks: { plan: { agent: 'pm' } },\n124\t        story_flow: ['plan'],\n125\t        epic_flow: ['plan', 'merge', 'validate'],\n126\t      });\n127\t      expect(result.valid).toBe(true);\n128\t    });\n129\t\n130\t    it('accepts epic_flow with loop blocks', () => {\n131\t      const result = validateWorkflowSchema({\n132\t        tasks: { check: { agent: 'qa' } },\n133\t        story_flow: ['check'],\n134\t        epic_flow: [{ loop: ['check', 'merge'] }],\n135\t      });\n136\t      expect(result.valid).toBe(true);\n137\t    });\n138\t  });\n139\t\n140\t  describe('agent: null (AC #10)', () => {\n141\t    it('accepts agent: null in task definition', () => {\n142\t      const result = validateWorkflowSchema({\n143\t        tasks: { merge: { agent: null } },\n144\t        flow: ['merge'],\n145\t      });\n146\t      expect(result.valid).toBe(true);\n147\t    });\n148\t  });\n149\t\n150\t  describe('scope: per-epic (AC #11)', () => {\n151\t    it('accepts scope: per-epic in task definition', () => {\n152\t      const result = validateWorkflowSchema({\n153\t        tasks: { plan: { agent: 'pm', scope: 'per-epic' } },\n154\t        flow: ['plan'],\n155\t      });\n156\t      expect(result.valid).toBe(true);\n157\t    });\n158\t  });\n159\t});\n160\t\n161\t// --- resolveHierarchicalFlow tests (AC #5, #9) ---\n162\t\n163\tdescribe('resolveHierarchicalFlow', () => {\n164\t  it('normalizes flow to storyFlow when no story_flow present (AC #5)', () => {\n165\t    const tasks = { implement: makeTask(), verify: makeTask() };\n166\t    const parsed = {\n167\t      tasks: { implement: { agent: 'dev' }, verify: { agent: 'dev' } },\n168\t      flow: ['implement', 'verify'],\n169\t    };\n170\t\n171\t    const result = resolveHierarchicalFlow(parsed, tasks);\n172\t\n173\t    expect(result.storyFlow).toEqual(['implement', 'verify']);\n174\t    expect(result.epicFlow).toEqual([]);\n175\t    expect(result.tasks).toBe(tasks);\n176\t  });\n177\t\n178\t  it('uses story_flow directly when present (AC #5)', () => {\n179\t    const tasks = { implement: makeTask() };\n180\t    const parsed = {\n181\t      tasks: { implement: { agent: 'dev' } },\n182\t      story_flow: ['implement'],\n183\t    };\n184\t\n185\t    const result = resolveHierarchicalFlow(parsed, tasks);\n186\t\n187\t    expect(result.storyFlow).toEqual(['implement']);\n188\t  });\n189\t\n190\t  it('applies default execution config when absent (AC #5)', () => {\n191\t    const tasks = { implement: makeTask() };\n192\t    const parsed = {\n193\t      tasks: { implement: { agent: 'dev' } },\n194\t      flow: ['implement'],\n195\t    };\n196\t\n197\t    const result = resolveHierarchicalFlow(parsed, tasks);\n198\t\n199\t    expect(result.execution).toEqual(EXECUTION_DEFAULTS);\n200\t  });\n201\t\n202\t  it('merges partial execution config with defaults', () => {\n203\t    const tasks = { implement: makeTask() };\n204\t    const parsed = {\n205\t      tasks: { implement: { agent: 'dev' } },\n206\t      flow: ['implement'],\n207\t      execution: { max_parallel: 4, isolation: 'worktree' as const },\n208\t    };\n209\t\n210\t    const result = resolveHierarchicalFlow(parsed, tasks);\n211\t\n212\t    expect(result.execution.max_parallel).toBe(4);\n213\t    expect(result.execution.isolation).toBe('worktree');\n214\t    expect(result.execution.merge_strategy).toBe('merge-commit');\n215\t    expect(result.execution.epic_strategy).toBe('sequential');\n216\t    expect(result.execution.story_strategy).toBe('sequential');\n217\t  });\n218\t\n219\t  it('resolves epic_flow when present', () => {\n220\t    const tasks = { plan: makeTask() };\n221\t    const parsed = {\n222\t      tasks: { plan: { agent: 'pm' } },\n223\t      story_flow: ['plan'],\n224\t      epic_flow: ['plan', 'merge', 'validate'],\n225\t    };\n226\t\n227\t    const result = resolveHierarchicalFlow(parsed, tasks);\n228\t\n229\t    expect(result.epicFlow).toEqual(['plan', 'merge', 'validate']);\n230\t  });\n231\t\n232\t  it('rejects coexistence of flow and story_flow (AC #9)', () => {\n233\t    const tasks = { implement: makeTask() };\n234\t    const parsed = {\n235\t      tasks: { implement: { agent: 'dev' } },\n236\t      flow: ['implement'],\n237\t      story_flow: ['implement'],\n238\t    };\n239\t\n240\t    expect(() => resolveHierarchicalFlow(parsed, tasks)).toThrow(HierarchicalFlowError);\n241\t    expect(() => resolveHierarchicalFlow(parsed, tasks)).toThrow(\n242\t      /Cannot have both.*flow.*story_flow|both.*flow.*story_flow/i\n243\t    );\n244\t  });\n245\t});\n246\t\n247\t// --- Integration: parseWorkflow with hierarchical flow ---\n248\t\n249\tdescribe('parseWorkflow — hierarchical flow integration', () => {\n250\t  describe('backward compatibility (AC #4)', () => {\n251\t    it('parses existing workflow with only flow: identically to before', () => {\n252\t      const filePath = writeYaml('legacy.yaml', `\n253\ttasks:\n254\t  implement:\n255\t    agent: dev\n256\t  verify:\n257\t    agent: evaluator\n258\t    scope: per-run\n259\tflow:\n260\t  - implement\n261\t  - verify\n262\t`);\n263\t      const result = parseWorkflow(filePath);\n264\t\n265\t      // Backward compat: flow field still populated\n266\t      expect(result.flow).toEqual(['implement', 'verify']);\n267\t      // New hierarchical fields\n268\t      expect(result.storyFlow).toEqual(['implement', 'verify']);\n269\t      expect(result.epicFlow).toEqual([]);\n270\t      expect(result.execution).toEqual(EXECUTION_DEFAULTS);\n271\t    });\n272\t  });\n273\t\n274\t  describe('hierarchical workflow (AC #6)', () => {\n275\t    it('pars