  expect(result.success).toBe(false);\n1652\t    // 5 iterations × 2 dispatches = 10\n1653\t    expect(mockDispatchAgent).toHaveBeenCalledTimes(10);\n1654\t  });\n1655\t\n1656\t  it('records multiple evaluator scores across iterations', async () => {\n1657\t    let callCount = 0;\n1658\t    mockDispatchAgent.mockImplementation(\n1659\t      async (_def: SubagentDefinition, prompt: string) => {\n1660\t        callCount++;\n1661\t        if (prompt.includes('Execute task')) {\n1662\t          // Fail first, pass second\n1663\t          if (callCount <= 2) {\n1664\t            return { sessionId: 'sess-v', success: true, durationMs: 100, output: makeFailVerdict() };\n1665\t          }\n1666\t          return { sessionId: 'sess-v', success: true, durationMs: 100, output: makePassVerdict() };\n1667\t        }\n1668\t        return { sessionId: 'sess-r', success: true, durationMs: 100, output: 'ok' };\n1669\t      },\n1670\t    );\n1671\t\n1672\t    mockParse.mockReturnValue({\n1673\t      development_status: { '3-1-foo': 'ready-for-dev' },\n1674\t    });\n1675\t\n1676\t    const config = makeConfig({\n1677\t      workflow: {\n1678\t        tasks: {\n1679\t          retry: makeTask({ scope: 'per-story' }),\n1680\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n1681\t        },\n1682\t        flow: [{ loop: ['retry', 'verify'] }],\n1683\t      },\n1684\t    });\n1685\t\n1686\t    await executeWorkflow(config);\n1687\t\n1688\t    // Find final state with evaluator scores\n1689\t    const allWrites = mockWriteWorkflowState.mock.calls.map((c: unknown[]) => c[0] as WorkflowState);\n1690\t    const statesWithScores = allWrites.filter((s) => s.evaluator_scores.length >= 2);\n1691\t    expect(statesWithScores.length).toBeGreaterThan(0);\n1692\t\n1693\t    const finalScored = statesWithScores[statesWithScores.length - 1];\n1694\t    expect(finalScored.evaluator_scores).toHaveLength(2);\n1695\t    expect(finalScored.evaluator_scores[0].failed).toBe(1); // first: fail\n1696\t    expect(finalScored.evaluator_scores[1].passed).toBe(2); // second: pass\n1697\t  });\n1698\t\n1699\t  it('halt error in per-run verify task terminates loop', async () => {\n1700\t    const { DispatchError } = await import('../agent-dispatch.js');\n1701\t\n1702\t    let callCount = 0;\n1703\t    mockDispatchAgent.mockImplementation(async () => {\n1704\t      callCount++;\n1705\t      if (callCount === 1) {\n1706\t        // retry succeeds\n1707\t        return { sessionId: 'sess-r', success: true, durationMs: 100, output: 'ok' };\n1708\t      }\n1709\t      // verify throws RATE_LIMIT\n1710\t      throw new DispatchError('rate limited', 'RATE_LIMIT', 'dev', new Error('inner'));\n1711\t    });\n1712\t\n1713\t    mockParse.mockReturnValue({\n1714\t      development_status: { '3-1-foo': 'ready-for-dev' },\n1715\t    });\n1716\t\n1717\t    const config = makeConfig({\n1718\t      workflow: {\n1719\t        tasks: {\n1720\t          retry: makeTask({ scope: 'per-story' }),\n1721\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n1722\t        },\n1723\t        flow: [{ loop: ['retry', 'verify'] }],\n1724\t      },\n1725\t    });\n1726\t\n1727\t    const result = await executeWorkflow(config);\n1728\t\n1729\t    expect(result.success).toBe(false);\n1730\t    expect(result.errors).toHaveLength(1);\n1731\t    expect(result.errors[0].code).toBe('RATE_LIMIT');\n1732\t    expect(result.errors[0].taskName).toBe('verify');\n1733\t  });\n1734\t\n1735\t  it('clears stale verdict after non-halt per-run error so next iteration retries all items', async () => {\n1736\t    const { DispatchError } = await import('../agent-dispatch.js');\n1737\t    let callCount = 0;\n1738\t\n1739\t    mockDispatchAgent.mockImplementation(async (_def: SubagentDefinition, prompt: string) => {\n1740\t      callCount++;\n1741\t      if (callCount === 1) {\n1742\t        // First retry succeeds\n1743\t        return { sessionId: 'sess-r', success: true, durationMs: 100, output: 'ok' };\n1744\t      }\n1745\t      if (callCount === 2) {\n1746\t        // First verify throws non-halt UNKNOWN error\n1747\t        throw new DispatchError('unknown err', 'UNKNOWN', 'dev', new Error('inner'));\n1748\t      }\n1749\t      if (callCount === 3) {\n1750\t        // Second retry — should dispatch for ALL items (stale verdict cleared)\n1751\t        return { sessionId: 'sess-r', success: true, durationMs: 100, output: 'ok' };\n1752\t      }\n1753\t      // Second verify passes\n1754\t      return { sessionId: 'sess-v', success: true, durationMs: 100, output: makePassVerdict() };\n1755\t    });\n1756\t\n1757\t    mockParse.mockReturnValue({\n1758\t      development_status: { '3-1-foo': 'ready-for-dev' },\n1759\t    });\n1760\t\n1761\t    const config = makeConfig({\n1762\t      workflow: {\n1763\t        tasks: {\n1764\t          retry: makeTask({ scope: 'per-story' }),\n1765\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n1766\t        },\n1767\t        flow: [{ loop: ['retry', 'verify'] }],\n1768\t      },\n1769\t    });\n1770\t\n1771\t    const result = await executeWorkflow(config);\n1772\t\n1773\t    // Loop should eventually succeed (pass verdict on second verify)\n1774\t    expect(result.errors).toHaveLength(1);\n1775\t    expect(result.errors[0].code).toBe('UNKNOWN');\n1776\t    // 4 dispatches: retry1 + verify1(error) + retry2 + verify2(pass)\n1777\t    expect(mockDispatchAgent).toHaveBeenCalledTimes(4);\n1778\t  });\n1779\t\n1780\t  it('non-halt per-run error records error and continues to next iteration', async () => {\n1781\t    const { DispatchError } = await import('../agent-dispatch.js');\n1782\t    let callCount = 0;\n1783\t\n1784\t    mockDispatchAgent.mockImplementation(async (_def: SubagentDefinition, prompt: string) => {\n1785\t      callCount++;\n1786\t      if (prompt.includes('Execute task')) {\n1787\t        if (callCount <= 2) {\n1788\t          // First verify: non-halt error\n1789\t          throw new DispatchError('bad response', 'UNKNOWN', 'dev', new Error('inner'));\n1790\t        }\n1791\t        // Second verify: pass\n1792\t        return { sessionId: 'sess-v', success: true, durationMs: 100, output: makePassVerdict() };\n1793\t      }\n1794\t      return { sessionId: 'sess-r', success: true, durationMs: 100, output: 'ok' };\n1795\t    });\n1796\t\n1797\t    mockParse.mockReturnValue({\n1798\t      development_status: { '3-1-foo': 'ready-for-dev' },\n1799\t    });\n1800\t\n1801\t    const config = makeConfig({\n1802\t      workflow: {\n1803\t        tasks: {\n1804\t          retry: makeTask({ scope: 'per-story' }),\n1805\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n1806\t        },\n1807\t        flow: [{ loop: ['retry', 'verify'] }],\n1808\t      },\n1809\t    });\n1810\t\n1811\t    const result = await executeWorkflow(config);\n1812\t\n1813\t    // Error from first verify recorded, but loop continued and eventually passed\n1814\t    expect(result.errors).toHaveLength(1);\n1815\t    expect(result.errors[0].code).toBe('UNKNOWN');\n1816\t  });\n1817\t});\n1818\t\n1819\t// ============================================================\n1820\t// Story 5-3: Crash Recovery & Resume Tests\n1821\t// ============================================================\n1822\t\n1823\tdescribe('isTaskCompleted', () => {\n1824\t  it('returns true when (taskName, storyKey) tuple matches a checkpoint', () => {\n1825\t    const state = makeDefaultState({\n1826\t      tasks_completed: [\n1827\t        { task_name: 'implement', story_key: '3-1-foo', completed_at: '2026-04-03T00:00:00Z' },\n1828\t      ],\n1829\t    });\n1830\t    expect(isTaskCompleted(state, 'implement', '3-1-foo')).toBe(true);\n1831\t  });\n1832\t\n1833\t  it('returns false when taskName matches but storyKey does not', () => {\n1834\t    const state = makeDefaultState({\n1835\t      tasks_completed: [\n1836\t        { task_name: 'implement', story_key: '3-1-foo', completed_at: '2026-04-03T00:00:00Z' },\n1837\t      ],\n1838\t    });\n1839\t    expect(isTaskCompleted(state, 'implement', '3-2-bar')).toBe(false);\n1840\t  });\n1841\t\n1842\t  it('returns false when storyKey matches but taskName does not (AC #7)', () => {\n1843\t    const state = makeDefaultState({\n1844\t      tasks_completed: [\n1845\t        { task_name: 'implement', story_key: '3-1-foo', completed_at: '2026-04-03T00:00:00Z' },\n1846\t      ],\n1847\t    });\n1848\t    // (\"implement\", \"3-1-foo\") does NOT cause (\"verify\", \"3-1-foo\") to be skipped\n1849\t    expect(isTaskCompleted(state, 'verify', '3-1-foo')).toBe(false);\n1850\t  });\n1851\t\n1852\t  it('returns false when tasks_completed is empty (AC #5)', () => {\n1853\t    const state = makeDefaultState({ tasks_completed: [] });\n1854\t    expect(isTaskCompleted(state, 'implement', '3-1-foo')).toBe(false);\n1855\t  });\n1856\t\n1857\t  it('returns true for per-run sentinel key', () => {\n1858\t    const state = makeDefaultState({\n1859\t      tasks_completed: [\n1860\t        { task_name: 'verify', story_key: '__run__', completed_at: '2026-04-03T00:00:00Z' },\n1861\t      ],\n1862\t    });\n1863\t    expect(isTaskCompleted(state, 'verify', PER_RUN_SENTINEL)).toBe(true);\n1864\t  });\n1865\t});\n1866\t\n1867\tdescribe('isLoopTaskCompleted', () => {\n1868\t  it('returns true when checkpoint count >= iteration', () => {\n1869\t    const state = makeDefaultState({\n1870\t      tasks_completed: [\n1871\t        { task_name: 'retry', story_key: '3-1-foo', completed_at: '2026-04-03T00:00:00Z' },\n1872\t        { task_name: 'retry', story_key: '3-1-foo', completed_at: '2026-04-03T00:01:00Z' },\n1873\t      ],\n1874\t    });\n1875\t    expect(isLoopTaskCompleted(state, 'retry', '3-1-foo', 2)).toBe(true);\n1876\t    expect(isLoopTaskCompleted(state, 'retry', '3-1-foo', 1)).toBe(true);\n1877\t  });\n1878\t\n1879\t  it('returns false when checkpoint count < iteration', () => {\n1880\t    const state = makeDefaultState({\n1881\t      tasks_completed: [\n1882\t        { task_name: 'retry', story_key: '3-1-foo', completed_at: '2026-04-03T00:00:00Z' },\n1883\t      ],\n1884\t    });\n1885\t    expect(isLoopTaskCompleted(state, 'retry', '3-1-foo', 2)).toBe(false);\n1886\t  });\n1887\t\n1888\t  it('returns false when no checkpoints exist', () => {\n1889\t    const state = makeDefaultState({ tasks_completed: [] });\n1890\t    expect(isLoopTaskCompleted(state, 'retry', '3-1-foo', 1)).toBe(false);\n1891\t  });\n1892\t});\n1893\t\n1894\tdescribe('crash recovery & resume', () => {\n1895\t  beforeEach(() => {\n1896\t    vi.clearAllMocks();\n1897\t    setupDefaultMocks();\n1898\t  });\n1899\t"}]},"parent_tool_use_id":"toolu_01GD3dd86R9DYmBSHRKfrVV3","session_id":"8b4a1da7-9e18-4302-ad13-ce7f0aff0314","uuid":"425c567d-8c34-4fca-a011-e73fdae4e726","timestamp":"2026-04-02T22:53:52.714Z"}
