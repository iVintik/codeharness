  continue;\n   395→    }\n   396→\n   397→    // Check staleness — compare against src/ or project source\n   398→    const srcDir = join(root, 'src');\n   399→    const codeDir = existsSync(srcDir) ? srcDir : root;\n   400→    const stale = isDocStale(docPath, codeDir);\n   401→\n   402→    documents.push({\n   403→      name: docName,\n   404→      grade: stale ? 'stale' : 'present',\n   405→      path: docName,\n   406→    });\n   407→  }\n   408→\n   409→  // Check docs/ directory\n   410→  const docsDir = join(root, 'docs');\n   411→  if (existsSync(docsDir)) {\n   412→    try {\n   413→      const stat = statSync(docsDir);\n   414→      if (stat.isDirectory()) {\n   415→        documents.push({ name: 'docs/', grade: 'present', path: 'docs/' });\n   416→      }\n   417→    } catch {\n   418→      documents.push({ name: 'docs/', grade: 'missing', path: null });\n   419→    }\n   420→  } else {\n   421→    documents.push({ name: 'docs/', grade: 'missing', path: null });\n   422→  }\n   423→\n   424→  // Check docs/index.md"}]},"parent_tool_use_id":"toolu_01E6L7Bd8eeBpjKQ16gXWPQk","session_id":"809dbebc-105d-4f42-bb69-c6ae04307c59","uuid":"b3411c2a-f874-46d5-b9c9-f2b89783f5c2","timestamp":"2026-03-25T01:15:39.283Z"}
