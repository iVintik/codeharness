story) + verify (per-run) — verify returns pass on first try\n660\t    mockDispatchAgent.mockImplementation(\n661\t      async (_def: SubagentDefinition, prompt: string) => {\n662\t        if (prompt.includes('Execute task')) {\n663\t          return {\n664\t            sessionId: 'sess-v',\n665\t            success: true,\n666\t            durationMs: 100,\n667\t            output: JSON.stringify({\n668\t              verdict: 'pass',\n669\t              score: { passed: 1, failed: 0, unknown: 0, total: 1 },\n670\t              findings: [],\n671\t            }),\n672\t          };\n673\t        }\n674\t        return { sessionId: 'sess-r', success: true, durationMs: 100, output: 'ok' };\n675\t      },\n676\t    );\n677\t\n678\t    mockParse.mockReturnValue({\n679\t      development_status: { '3-1-foo': 'ready-for-dev' },\n680\t    });\n681\t\n682\t    const config = makeConfig({\n683\t      workflow: {\n684\t        tasks: {\n685\t          retry: makeTask({ scope: 'per-story' }),\n686\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n687\t        },\n688\t        flow: [{ loop: ['retry', 'verify'] }],\n689\t      },\n690\t    });\n691\t\n692\t    const result = await executeWorkflow(config);\n693\t\n694\t    // Should have dispatched: retry for 1 story + verify once\n695\t    expect(mockDispatchAgent).toHaveBeenCalledTimes(2);\n696\t    expect(result.tasksCompleted).toBe(2);\n697\t  });\n698\t\n699\t  it('handles DispatchError and records in result (AC #13)', async () => {\n700\t    const { DispatchError } = await import('../agent-dispatch.js');\n701\t    mockDispatchAgent.mockRejectedValue(\n702\t      new DispatchError('rate limited', 'UNKNOWN', 'dev', new Error('inner')),\n703\t    );\n704\t\n705\t    mockParse.mockReturnValue({\n706\t      development_status: { '3-1-foo': 'ready-for-dev' },\n707\t    });\n708\t\n709\t    const config = makeConfig({\n710\t      workflow: {\n711\t        tasks: { implement: makeTask() },\n712\t        flow: ['implement'],\n713\t      },\n714\t    });\n715\t\n716\t    const result = await executeWorkflow(config);\n717\t\n718\t    expect(result.success).toBe(false);\n719\t    expect(result.errors).toHaveLength(1);\n720\t    expect(result.errors[0].code).toBe('UNKNOWN');\n721\t    expect(result.errors[0].taskName).toBe('implement');\n722\t    expect(result.errors[0].storyKey).toBe('3-1-foo');\n723\t  });\n724\t\n725\t  it('halts on RATE_LIMIT dispatch errors (AC #13)', async () => {\n726\t    const { DispatchError } = await import('../agent-dispatch.js');\n727\t    mockDispatchAgent.mockRejectedValue(\n728\t      new DispatchError('rate limited', 'RATE_LIMIT', 'dev', new Error('inner')),\n729\t    );\n730\t\n731\t    mockParse.mockReturnValue({\n732\t      development_status: {\n733\t        '3-1-foo': 'ready-for-dev',\n734\t        '3-2-bar': 'backlog',\n735\t      },\n736\t    });\n737\t\n738\t    const config = makeConfig({\n739\t      workflow: {\n740\t        tasks: { implement: makeTask() },\n741\t        flow: ['implement'],\n742\t      },\n743\t    });\n744\t\n745\t    const result = await executeWorkflow(config);\n746\t\n747\t    expect(result.success).toBe(false);\n748\t    // Should halt after first error — only one dispatch attempted\n749\t    expect(mockDispatchAgent).toHaveBeenCalledTimes(1);\n750\t    expect(result.errors).toHaveLength(1);\n751\t  });\n752\t\n753\t  it('continues on UNKNOWN errors for per-story tasks (AC #13)', async () => {\n754\t    const { DispatchError } = await import('../agent-dispatch.js');\n755\t    let callCount = 0;\n756\t    mockDispatchAgent.mockImplementation(async () => {\n757\t      callCount++;\n758\t      if (callCount === 1) {\n759\t        throw new DispatchError('unknown error', 'UNKNOWN', 'dev', new Error('inner'));\n760\t      }\n761\t      return { sessionId: 'sess-1', success: true, durationMs: 100, output: 'ok' };\n762\t    });\n763\t\n764\t    mockParse.mockReturnValue({\n765\t      development_status: {\n766\t