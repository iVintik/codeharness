{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01LfSQSM6qLyb1qLfdVDy74u","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01FRUigHfmJiyVZKn3SyFUaz","name":"Write","input":{"file_path":"/Users/ivintik/dev/personal/codeharness/src/modules/infra/dockerfile-validator.ts","content":"/**\n * Dockerfile validator — checks Dockerfiles against the 6 required rule\n * categories defined in patches/infra/dockerfile-rules.md.\n *\n * FR23 (formalized Dockerfile rules), FR24 (audit validates against rules).\n * Uses simple line-by-line regex matching — no Docker build required.\n */\n\nimport { existsSync, readFileSync } from 'node:fs';\nimport { join } from 'node:path';\nimport { ok, fail } from '../../types/result.js';\nimport type { Result } from '../../types/result.js';\n\n/** A single gap found during Dockerfile validation */\nexport interface DockerfileGap {\n  readonly rule: string;\n  readonly description: string;\n  readonly suggestedFix: string;\n  readonly line?: number;\n}\n\n/** Result of validating a Dockerfile */\nexport interface DockerfileValidationResult {\n  readonly passed: boolean;\n  readonly gaps: DockerfileGap[];\n  readonly warnings: string[];\n}\n\n/** Internal rule definitions (hardcoded defaults) */\ninterface DockerfileRules {\n  readonly requiredTools: string[];\n  readonly sourceDirPatterns: RegExp[];\n}\n\nconst DEFAULT_RULES: DockerfileRules = {\n  requiredTools: ['curl', 'jq'],\n  sourceDirPatterns: [/^COPY\\s+(--[^\\s]+\\s+)*src\\//i, /^COPY\\s+(--[^\\s]+\\s+)*lib\\//i, /^COPY\\s+(--[^\\s]+\\s+)*test\\//i],\n};\n\n/**\n * Load rules from patches/infra/dockerfile-rules.md or fall back to defaults.\n * The markdown is documentation only — rules are hardcoded. We just check\n * whether the file exists to decide whether to emit a warning.\n */\nexport function loadRules(projectDir: string): { rules: DockerfileRules; warnings: string[] } {\n  const rulesPath = join(projectDir, 'patches', 'infra', 'dockerfile-rules.md');\n  const warnings: string[] = [];\n\n  if (!existsSync(rulesPath)) {\n    warnings.push('dockerfile-rules.md not found -- using defaults.');\n  }\n\n  return { rules: DEFAULT_RULES, warnings };\n}\n\n/** Check pinned FROM — reject :latest or missing tag/digest */\nfunction checkPinnedFrom(lines: string[]): DockerfileGap[] {\n  const gaps: DockerfileGap[] = [];\n  for (let i = 0; i < lines.length; i++) {\n    const line = lines[i];\n    if (!/^\\s*FROM\\s+/i.test(line)) continue;\n    const ref = line.replace(/^\\s*FROM\\s+/i, '').split(/\\s+/)[0];\n    if (ref === 'scratch') continue;\n    if (ref.endsWith(':latest')) {\n      gaps.push({\n        rule: 'pinned-from',\n        description: 'unpinned base image -- use specific version.',\n        suggestedFix: `Pin ${ref} to a specific version tag`,\n        line: i + 1,\n      });\n    } else if (!ref.includes(':') && !ref.includes('@')) {\n      gaps.push({\n        rule: 'pinned-from',\n        description: 'unpinned base image -- use specific version.',\n        suggestedFix: `Pin ${ref} to a specific version tag (e.g., ${ref}:22-slim)`,\n        line: i + 1,\n      });\n    }\n  }\n  return gaps;\n}\n\n/** Check project binary on PATH */\nfunction checkBinaryInstalled(lines: string[]): DockerfileGap[] {\n  const patterns = [\n    /npm\\s+install\\s+(-g|--global)\\b/i,\n    /pip\\s+install\\b/i,\n    /COPY\\s+--from=/i,\n  ];\n  const found = lines.some(line => patterns.some(p => p.test(line)));\n  if (found) return [];\n  return [{\n    rule: 'binary-installed',\n    description: 'project binary not installed.',\n    suggestedFix: 'Add npm install -g, pip install, or COPY --from= to install the project binary',\n  }];\n}\n\n/** Check verification tools (curl, jq) */\nfunction checkVerificationTools(lines: string[], requiredTools: string[]): DockerfileGap[] {\n  const content = lines.join('\\n');\n  const gaps: DockerfileGap[] = [];\n  for (const tool of requiredTools) {\n    const pattern = new RegExp(`(apt-get\\\\s+install|apk\\\\s+add)[^\\\\n]*\\\\b${tool}\\\\b`, 'i');\n    if (!pattern.test(content)) {\n      gaps.push({\n        rule: 'verification-tools',\n        description: `verification tool \"${tool}\" not installed.`,\n        suggestedFix: `Add ${tool} to your package install command (e.g., apt-get install -y ${tool})`,\n      });\n    }\n  }\n  return gaps;\n}\n\n/** Check no source code COPY */\nfunction checkNoSourceCopy(lines: string[], patterns: RegExp[]): DockerfileGap[] {\n  const gaps: DockerfileGap[] = [];\n  for (let i = 0; i < lines.length; i++) {\n    const line = lines[i];\n    for (const pattern of patterns) {\n      if (pattern.test(line)) {\n        gaps.push({\n          rule: 'no-source-copy',\n          description: 'source code copied into container -- use build artifact instead.',\n          suggestedFix: 'Copy build artifacts (e.g., dist/) instead of source directories',\n          line: i + 1,\n        });\n        break;\n      }\n    }\n  }\n  return gaps;\n}\n\n/** Check non-root USER */\nfunction checkNonRootUser(lines: string[]): DockerfileGap[] {\n  const userLines = lines.filter(l => /^\\s*USER\\s+/i.test(l));\n  const hasNonRoot = userLines.some(l => {\n    const user = l.replace(/^\\s*USER\\s+/i, '').trim();\n    return user !== 'root';\n  });\n  if (hasNonRoot) return [];\n  return [{\n    rule: 'non-root-user',\n    description: 'no non-root USER instruction found.',\n    suggestedFix: 'Add a USER instruction with a non-root user (e.g., USER node)',\n  }];\n}\n\n/** Check cache cleanup */\nfunction checkCacheCleanup(lines: string[]): DockerfileGap[] {\n  const content = lines.join('\\n');\n  const patterns = [\n    /rm\\s+-rf\\s+\\/var\\/lib\\/apt\\/lists/,\n    /npm\\s+cache\\s+clean/i,\n    /pip\\s+cache\\s+purge/i,\n    /--no-cache-dir/i,\n    /apk\\s+add\\s+--no-cache/i,\n  ];\n  const found = patterns.some(p => p.test(content));\n  if (found) return [];\n  return [{\n    rule: 'cache-cleanup',\n    description: 'no cache cleanup detected.',\n    suggestedFix: 'Add cache cleanup (e.g., rm -rf /var/lib/apt/lists/* after apt-get)',\n  }];\n}\n\n/**\n * Validate a Dockerfile against all 6 rule categories.\n * Returns Result<DockerfileValidationResult>.\n */\nexport function validateDockerfile(projectDir: string): Result<DockerfileValidationResult> {\n  try {\n    const dfPath = join(projectDir, 'Dockerfile');\n\n    if (!existsSync(dfPath)) {\n      return fail('No Dockerfile found');\n    }\n\n    let content: string;\n    try {\n      content = readFileSync(dfPath, 'utf-8');\n    } catch {\n      return fail('Dockerfile exists but could not be read');\n    }\n\n    const lines = content.split('\\n');\n    const fromLines = lines.filter(l => /^\\s*FROM\\s+/i.test(l));\n\n    if (fromLines.length === 0) {\n      return fail('Dockerfile has no FROM instruction');\n    }\n\n    const { rules, warnings } = loadRules(projectDir);\n\n    const gaps: DockerfileGap[] = [\n      ...checkPinnedFrom(lines),\n      ...checkBinaryInstalled(lines),\n      ...checkVerificationTools(lines, rules.requiredTools),\n      ...checkNoSourceCopy(lines, rules.sourceDirPatterns),\n      ...checkNonRootUser(lines),\n      ...checkCacheCleanup(lines),\n    ];\n\n    return ok({\n      passed: gaps.length === 0,\n      gaps,\n      warnings,\n    });\n  } catch (err) {\n    const msg = err instanceof Error ? err.message : String(err);\n    return fail(`Dockerfile validation error: ${msg}`);\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":809,"cache_read_input_tokens":34873,"cache_creation":{"ephemeral_5m_input_tokens":809,"ephemeral_1h_input_tokens":0},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01TyVq55huB8WDwxXQnVa2vD","session_id":"d06dabce-ed3c-4abf-ad84-f2845532d39a","uuid":"6678e816-77c8-4df9-ad9c-f0bf7d2e97e3"}
