{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JZGcwa7XMRrajPWNuNyNjL","type":"tool_result","content":"1\timport Ajv from 'ajv';\n2\timport verdictSchema from '../schemas/verdict.schema.json';\n3\t\n4\t// --- Interfaces ---\n5\t\n6\t/**\n7\t * Evaluator verdict returned by a verify task (AD5).\n8\t */\n9\texport interface EvaluatorVerdict {\n10\t  verdict: 'pass' | 'fail';\n11\t  score: {\n12\t    passed: number;\n13\t    failed: number;\n14\t    unknown: number;\n15\t    total: number;\n16\t  };\n17\t  findings: Array<{\n18\t    ac: number;\n19\t    description: string;\n20\t    status: 'pass' | 'fail' | 'unknown';\n21\t    evidence: {\n22\t      commands_run: string[];\n23\t      output_observed: string;\n24\t      reasoning: string;\n25\t    };\n26\t  }>;\n27\t  evaluator_trace_id?: string;\n28\t  duration_seconds?: number;\n29\t}\n30\t\n31\t/**\n32\t * Result of verdict validation.\n33\t */\n34\texport interface VerdictValidationResult {\n35\t  valid: boolean;\n36\t  errors?: string[];\n37\t  verdict?: EvaluatorVerdict;\n38\t}\n39\t\n40\t// --- Errors ---\n41\t\n42\t/**\n43\t * Error thrown when verdict parsing fails.\n44\t * `retryable: true` signals the caller should re-dispatch the evaluator.\n45\t * `retryable: false` signals no further retries should be attempted.\n46\t */\n47\texport class VerdictParseError extends Error {\n48\t  public readonly retryable: boolean;\n49\t  public readonly rawOutput: string;\n50\t  public readonly validationErrors?: string[];\n51\t\n52\t  constructor(\n53\t    message: string,\n54\t    retryable: boolean,\n55\t    rawOutput: string,\n56\t    validationErrors?: string[],\n57\t  ) {\n58\t    super(message);\n59\t    // Restore prototype chain for proper instanceof checks in transpiled output\n60\t    Object.setPrototypeOf(this, VerdictParseError.prototype);\n61\t    this.name = 'VerdictParseError';\n62\t    this.retryable = retryable;\n63\t    this.rawOutput = rawOutput;\n64\t    this.validationErrors = validationErrors;\n65\t  }\n66\t}\n67\t\n68\t// --- Schema Validator (compiled once at module load) ---\n69\t\n70\tconst ajv = new Ajv({ allErrors: true });\n71\tconst validateSchema = ajv.compile(verdictSchema);\n72\t\n73\t// --- Functions ---\n74\t\n75\t/**\n76\t * Validate an unknown value against the verdict JSON schema.\n77\t * Returns a VerdictValidationResult with typed verdict on success,\n78\t * or error messages on failure.\n79\t */\n80\texport function validateVerdict(data: unknown): VerdictValidationResult {\n81\t  const valid = validateSchema(data);\n82\t\n83\t  if (valid) {\n84\t    // Return a deep copy to prevent callers from mutating the original input\n85\t    const verdict = JSON.parse(JSON.stringify(data)) as EvaluatorVerdict;\n86\t    return { valid: true, verdict };\n87\t  }\n88\t\n89\t  const errors = (validateSchema.errors ?? []).map((err) => {\n90\t    const path = err.instancePath || '/';\n91\t    return `${path}: ${err.message ?? 'unknown error'}`;\n92\t  });\n93\t\n94\t  return { valid: false, errors };\n95\t}\n96\t\n97\t/**\n98\t * Parse raw evaluator output into a typed EvaluatorVerdict.\n99\t *\n100\t * On success: returns a fully typed EvaluatorVerdict with PASS-evidence\n101\t * invariant enforced (PASS findings without commands_run are downgraded\n102\t * to UNKNOWN).\n103\t *\n104\t * On failure: throws VerdictParseError with `retryable: true`.\n105\t * The caller (workflow engine) decides whether to retry. On a second\n106\t * failure, the caller should catch and generate an all-UNKNOWN verdict.\n107\t */\n108\texport function parseVerdict(output: string): EvaluatorVerdict {\n109\t  // Step 1: JSON.parse\n110\t  let parsed: unknown;\n111\t  try {\n112\t    parsed = JSON.parse(output);\n113\t  } catch { // IGNORE: invalid JSON — rethrow as VerdictParseError\n114\t    throw new VerdictParseError(\n115\t      'Failed to parse verdict: invalid JSON',\n116\t      true,\n117\t      output,\n118\t    );\n119\t  }\n120\t\n121\t  // Step 2: Schema validation\n122\t  const result = validateVerdict(parsed);\n123\t  if (!result.valid) {\n124\t    throw new VerdictParseError(\n125\t      `Failed to parse verdict: schema validation failed`,\n126\t      true,\n127\t      output,\n128\t      result.errors,\n129\t    );\n130\t  }\n131\t\n132\t  const verdict = result.verdict!;\n133\t\n134\t  // Step 3: Enforce PASS-evidence invariant (AD5 / FR26)\n135\t  // If a finding has status 'pass' but empty commands_run, downgrade to 'unknown'.\n136\t  let passDowngraded = false;\n137\t  for (const finding of verdict.findings) {\n138\t    if (\n139\t      finding.status === 'pass' &&\n140\t      (!finding.evidence.commands_run || finding.evidence.commands_run.length === 0)\n141\t    ) {\n142\t      finding.status = 'unknown';\n143\t      finding.evidence.reasoning +=\n144\t        ' [Downgraded from PASS: no commands_run evidence provided]';\n145\t      passDowngraded = true;\n146\t    }\n147\t  }\n148\t\n149\t  // Step 4: Recalculate score if any findings were downgraded\n150\t  if (passDowngraded) {\n151\t    let passed = 0;\n152\t    let failed = 0;\n153\t    let unknown = 0;\n154\t    for (const finding of verdict.findings) {\n155\t      if (finding.status === 'pass') passed++;\n156\t      else if (finding.status === 'fail') failed++;\n157\t      else unknown++;\n158\t    }\n159\t    verdict.score = {\n160\t      passed,\n161\t      failed,\n162\t      unknown,\n163\t      total: verdict.findings.length,\n164\t    };\n165\t\n166\t    // Flip verdict to 'fail' if no PASSes remain\n167\t    if (passed === 0) {\n168\t      verdict.verdict = 'fail';\n169\t    }\n170\t  }\n171\t\n172\t  return verdict;\n173\t}\n174\t"}]},"parent_tool_use_id":"toolu_01NQ771iCiXCfQFTaESuSBGk","session_id":"64d7a6a2-a6f8-43cb-b618-df314a0f5500","uuid":"ac7e7bda-a9f2-4d77-b1df-fff9c407580f","timestamp":"2026-04-03T00:15:32.103Z"}
