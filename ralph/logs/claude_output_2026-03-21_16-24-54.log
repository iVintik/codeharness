{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014FrBroj2vnEeMXtKHiRwvd","type":"tool_result","content":"     1→/**\n     2→ * Dockerfile validator — checks Dockerfiles against 6 required rule categories.\n     3→ * Returns structured gaps for audit integration.\n     4→ *\n     5→ * FR23 (formalized Dockerfile rules), FR24 (audit validates against rules).\n     6→ */\n     7→\n     8→import { existsSync, readFileSync } from 'node:fs';\n     9→import { join } from 'node:path';\n    10→import { ok, fail } from '../../types/result.js';\n    11→import type { Result } from '../../types/result.js';\n    12→\n    13→/** A single gap found during Dockerfile validation */\n    14→export interface DockerfileGap {\n    15→  readonly rule: string;\n    16→  readonly description: string;\n    17→  readonly suggestedFix: string;\n    18→  readonly line?: number;\n    19→}\n    20→\n    21→/** Result of validating a Dockerfile against all rules */\n    22→export interface DockerfileValidationResult {\n    23→  readonly passed: boolean;\n    24→  readonly gaps: DockerfileGap[];\n    25→  readonly warnings: string[];\n    26→}\n    27→\n    28→/** Internal rules structure */\n    29→interface DockerfileRules {\n    30→  readonly requirePinnedFrom: boolean;\n    31→  readonly requireBinaryOnPath: boolean;\n    32→  readonly verificationTools: string[];\n    33→  readonly forbidSourceCopy: boolean;\n    34→  readonly requireNonRootUser: boolean;\n    35→  readonly requireCacheCleanup: boolean;\n    36→}\n    37→\n    38→const DEFAULT_RULES: DockerfileRules = {\n    39→  requirePinnedFrom: true,\n    40→  requireBinaryOnPath: true,\n    41→  verificationTools: ['curl', 'jq'],\n    42→  forbidSourceCopy: true,\n    43→  requireNonRootUser: true,\n    44→  requireCacheCleanup: true,\n    45→};\n    46→\n    47→function dfGap(rule: string, description: string, suggestedFix: string, line?: number): DockerfileGap {\n    48→  const g: DockerfileGap = { rule, description, suggestedFix };\n    49→  if (line !== undefined) return { ...g, line };\n    50→  return g;\n    51→}\n    52→\n    53→/**\n    54→ * Load rules from patches/infra/dockerfile-rules.md or fall back to defaults.\n    55→ * The markdown is documentation — the actual rules are hardcoded defaults.\n    56→ * Returns rules + any warnings about missing file.\n    57→ */\n    58→export function loadRules(projectDir: string): { rules: DockerfileRules; warnings: string[] } {\n    59→  const rulesPath = join(projectDir, 'patches', 'infra', 'dockerfile-rules.md');\n    60→  if (!existsSync(rulesPath)) {\n    61→    return {\n    62→      rules: DEFAULT_RULES,\n    63→      warnings: ['dockerfile-rules.md not found -- using defaults.'],\n    64→    };\n    65→  }\n    66→  return { rules: DEFAULT_RULES, warnings: [] };\n    67→}\n    68→\n    69→// ─── Rule checkers ──────────────────────────────────────────────────────────\n    70→\n    71→function checkPinnedFrom(lines: string[]): DockerfileGap[] {\n    72→  const gaps: DockerfileGap[] = [];\n    73→  for (let i = 0; i < lines.length; i++) {\n    74→    if (!/^\\s*FROM\\s+/i.test(lines[i])) continue;\n    75→    const ref = lines[i].replace(/^\\s*FROM\\s+/i, '').split(/\\s+/)[0];\n    76→    if (ref.endsWith(':latest')) {\n    77→      gaps.push(dfGap('pinned-from', `unpinned base image -- use specific version.`, `Pin ${ref} to a specific version tag`, i + 1));\n    78→    } else if (!ref.includes(':') && !ref.includes('@')) {\n    79→      gaps.push(dfGap('pinned-from', `unpinned base image -- use specific version.`, `Pin ${ref} to a specific version tag (e.g., ${ref}:22-slim)`, i + 1));\n    80→    }\n    81→  }\n    82→  return gaps;\n    83→}\n    84→\n    85→function checkBinaryOnPath(lines: string[]): DockerfileGap[] {\n    86→  const content = lines.join('\\n');\n    87→  const hasBinary =\n    88→    /npm\\s+install\\s+(-g|--global)\\b/i.test(content) ||\n    89→    /pip\\s+install\\b/i.test(content) ||\n    90→    /COPY\\s+--from=/i.test(content);\n    91→  if (!hasBinary) {\n    92→    return [dfGap('binary-on-path', 'project binary not installed.', 'Add npm install -g, pip install, or COPY --from to install the project binary')];\n    93→  }\n    94→  return [];\n    95→}\n    96→\n    97→function checkVerificationTools(lines: string[], tools: string[]): DockerfileGap[] {\n    98→  const gaps: DockerfileGap[] = [];\n    99→  for (const tool of tools) {\n   100→    let found = false;\n   101→    for (const line of lines) {\n   102→      const lower = line.toLowerCase();\n   103→      const isInstallLine = lower.includes('apt-get install') || lower.includes('apk add');\n   104→      if (isInstallLine && new RegExp(`\\\\b${tool.toLowerCase()}\\\\b`).test(lower)) {\n   105→        found = true;\n   106→        break;\n   107→      }\n   108→    }\n   109→    if (!found) {\n   110→      gaps.push(dfGap('verification-tools', `verification tool missing: ${tool}`, `Install ${tool} via apt-get install or apk add`));\n   111→    }\n   112→  }\n   113→  return gaps;\n   114→}\n   115→\n   116→function checkNoSourceCopy(lines: string[]): DockerfileGap[] {\n   117→  const gaps: DockerfileGap[] = [];\n   118→  const sourcePatterns = [/COPY\\s+(?:--\\S+\\s+)*src\\//i, /COPY\\s+(?:--\\S+\\s+)*lib\\//i, /COPY\\s+(?:--\\S+\\s+)*test\\//i];\n   119→  for (let i = 0; i < lines.length; i++) {\n   120→    for (const pattern of sourcePatterns) {\n   121→      if (pattern.test(lines[i])) {\n   122→        gaps.push(dfGap('no-source-copy', 'source code copied into container -- use build artifact instead.', 'Use COPY --from=builder or COPY dist/ instead of copying source', i + 1));\n   123→      }\n   124→    }\n   125→  }\n   126→  return gaps;\n   127→}\n   128→\n   129→function checkNonRootUser(lines: string[]): DockerfileGap[] {\n   130→  const userLines = lines.filter(l => /^\\s*USER\\s+/i.test(l));\n   131→  if (userLines.length === 0) {\n   132→    return [dfGap('non-root-user', 'no non-root USER instruction found.', 'Add USER <non-root-user> instruction (e.g., USER node)')];\n   133→  }\n   134→  const hasNonRoot = userLines.some(l => {\n   135→    const user = l.replace(/^\\s*USER\\s+/i, '').trim().split(/\\s+/)[0];\n   136→    return user.toLowerCase() !== 'root';\n   137→  });\n   138→  if (!hasNonRoot) {\n   139→    return [dfGap('non-root-user', 'no non-root USER instruction found.', 'Add USER <non-root-user> instruction (e.g., USER node)')];\n   140→  }\n   141→  return [];\n   142→}\n   143→\n   144→function checkCacheCleanup(lines: string[]): DockerfileGap[] {\n   145→  const content = lines.join('\\n');\n   146→  const hasCleanup =\n   147→    /rm\\s+-rf\\s+\\/var\\/lib\\/apt\\/lists/i.test(content) ||\n   148→    /rm\\s+-rf\\s+\\/var\\/cache\\/apk/i.test(content) ||\n   149→    /npm\\s+cache\\s+clean/i.test(content) ||\n   150→    /pip\\s+cache\\s+purge/i.test(content);\n   151→  if (!hasCleanup) {\n   152→    return [dfGap('cache-cleanup', 'no cache cleanup detected.', 'Add cache cleanup: rm -rf /var/lib/apt/lists/*, npm cache clean --force, or pip cache purge')];\n   153→  }\n   154→  return [];\n   155→}\n   156→\n   157→// ─── Main validator ─────────────────────────────────────────────────────────\n   158→\n   159→/**\n   160→ * Validate a Dockerfile against all 6 rule categories.\n   161→ * Returns Result<DockerfileValidationResult>.\n   162→ */\n   163→export function validateDockerfile(projectDir: string): Result<DockerfileValidationResult> {\n   164→  const dfPath = join(projectDir, 'Dockerfile');\n   165→\n   166→  if (!existsSync(dfPath)) {\n   167→    return fail('No Dockerfile found');\n   168→  }\n   169→\n   170→  let content: string;\n   171→  try {\n   172→    content = readFileSync(dfPath, 'utf-8');\n   173→  } catch {\n   174→    return fail('Dockerfile exists but could not be read');\n   175→  }\n   176→\n   177→  const lines = content.split('\\n');\n   178→  const fromLines = lines.filter(l => /^\\s*FROM\\s+/i.test(l));\n   179→  if (fromLines.length === 0) {\n   180→    return fail('Dockerfile has no FROM instruction');\n   181→  }\n   182→\n   183→  const { rules, warnings } = loadRules(projectDir);\n   184→  const gaps: DockerfileGap[] = [];\n   185→\n   186→  if (rules.requirePinnedFrom) gaps.push(...checkPinnedFrom(lines));\n   187→  if (rules.requireBinaryOnPath) gaps.push(...checkBinaryOnPath(lines));\n   188→  gaps.push(...checkVerificationTools(lines, rules.verificationTools));\n   189→  if (rules.forbidSourceCopy) gaps.push(...checkNoSourceCopy(lines));\n   190→  if (rules.requireNonRootUser) gaps.push(...checkNonRootUser(lines));\n   191→  if (rules.requireCacheCleanup) gaps.push(...checkCacheCleanup(lines));\n   192→\n   193→  return ok({\n   194→    passed: gaps.length === 0,\n   195→    gaps,\n   196→    warnings,\n   197→  });\n   198→}\n   199→"}]},"parent_tool_use_id":"toolu_01YEN3iRRgC8DcyUnVcNETs4","session_id":"d92c7bcb-37ff-4aa2-841f-ece7fabef071","uuid":"c0f82799-5cad-4481-a03b-9784cbf7f2b2","timestamp":"2026-03-21T12:29:53.502Z"}
