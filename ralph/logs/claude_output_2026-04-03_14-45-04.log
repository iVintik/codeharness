low: {\n2595\t        tasks: {\n2596\t          retry: makeTask({ scope: 'per-story' }),\n2597\t          verify: makeTask({ scope: 'per-run', agent: 'evaluator' }),\n2598\t        },\n2599\t        flow: [{ loop: ['retry', 'verify'] }],\n2600\t      },\n2601\t      agents: {\n2602\t        dev: makeDefinition(),\n2603\t        // 'evaluator' agent is NOT provided\n2604\t      },\n2605\t      maxIterations: 1,\n2606\t    });\n2607\t\n2608\t    await executeWorkflow(config);\n2609\t\n2610\t    // verify task should be skipped because agent 'evaluator' is missing\n2611\t    expect(mockWarn).toHaveBeenCalledWith(\n2612\t      expect.stringContaining('agent \"evaluator\" not found'),\n2613\t    );\n2614\t  });\n2615\t});\n2616\t\n2617\t// --- Driver Integration Tests (Story 10-5) ---\n2618\t\n2619\tdescribe('driver integration (story 10-5)', () => {\n2620\t  beforeEach(() => {\n2621\t    vi.clearAllMocks();\n2622\t    setupDefaultMocks();\n2623\t  });\n2624\t\n2625\t  it('calls getDriver with \"claude-code\" when task has no driver field (AC #1, #2)', async () => {\n2626\t    const task = makeTask();\n2627\t    const definition = makeDefinition();\n2628\t    const state = makeDefaultState();\n2629\t    const config = makeConfig();\n2630\t\n2631\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n2632\t\n2633\t    expect(mockGetDriver).toHaveBeenCalledWith('claude-code');\n2634\t  });\n2635\t\n2636\t  it('calls getDriver with task.driver when present (forward-compat)', async () => {\n2637\t    const task = { ...makeTask(), driver: 'opencode' } as ResolvedTask & { driver: string };\n2638\t    const definition = makeDefinition();\n2639\t    const state = makeDefaultState();\n2640\t    const config = makeConfig();\n2641\t\n2642\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n2643\t\n2644\t    expect(mockGetDriver).toHaveBeenCalledWith('opencode');\n2645\t  });\n2646\t\n2647\t  it('calls driver.dispatch() with