{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UAu8k4GikoJWpjqG899ASp","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n     2→import { mkdtempSync, rmSync, writeFileSync, existsSync } from 'node:fs';\n     3→import { tmpdir } from 'node:os';\n     4→import { join } from 'node:path';\n     5→\n     6→// Mock all lib modules\n     7→vi.mock('../../../lib/stacks/index.js', async (importOriginal) => {\n     8→  const orig = await importOriginal<typeof import('../../../lib/stacks/index.js')>();\n     9→  return { ...orig, detectStacks: vi.fn(orig.detectStacks), detectAppType: vi.fn(orig.detectAppType) };\n    10→});\n    11→\n    12→vi.mock('../docs-scaffold.js', async (importOriginal) => {\n    13→  const orig = await importOriginal<typeof import('../docs-scaffold.js')>();\n    14→  return { ...orig, getCoverageTool: vi.fn(orig.getCoverageTool), getStackLabel: vi.fn(orig.getStackLabel) };\n    15→});\n    16→\n    17→vi.mock('../../../lib/stack-path.js', () => ({\n    18→  getComposeFilePath: vi.fn(() => '/mock/.codeharness/stack/docker-compose.harness.yml'),\n    19→  ensureStackDir: vi.fn(),\n    20→}));\n    21→\n    22→vi.mock('../../../lib/docker/index.js', () => ({\n    23→  isDockerAvailable: vi.fn(() => true),\n    24→  isSharedStackRunning: vi.fn(() => false),\n    25→  startSharedStack: vi.fn(() => ({\n    26→    started: true,\n    27→    services: [{ name: 'otel-collector', status: 'running', port: '4317,4318' }],\n    28→  })),\n    29→  startCollectorOnly: vi.fn(() => ({\n    30→    started: true,\n    31→    services: [{ name: 'otel-collector', status: 'running', port: '4317,4318' }],\n    32→  })),\n    33→}));\n    34→\n    35→vi.mock('../../../lib/deps.js', () => ({\n    36→  installAllDependencies: vi.fn(() => [\n    37→    { name: 'showboat', displayName: 'Showboat', status: 'already-installed', version: '0.6.1' },\n    38→  ]),\n    39→  checkInstalled: vi.fn(() => ({ installed: true, version: '1.0.0' })),\n    40→  DEPENDENCY_REGISTRY: [\n    41→    {\n    42→      name: 'showboat',\n    43→      displayName: 'Showboat',\n    44→      installCommands: [{ cmd: 'pip', args: ['install', 'showboat'] }],\n    45→      checkCommand: { cmd: 'showboat', args: ['--version'] },\n    46→      critical: false,\n    47→    },\n    48→  ],\n    49→  CriticalDependencyError: class extends Error {\n    50→    constructor(d: string, r: string) { super(`Critical dependency '${d}' failed: ${r}`); this.name = 'CriticalDependencyError'; }\n    51→  },\n    52→}));\n    53→\n    54→vi.mock('../../../lib/beads.js', () => ({\n    55→  isBeadsInitialized: vi.fn(() => false),\n    56→  initBeads: vi.fn(),\n    57→  detectBeadsHooks: vi.fn(() => ({ hasHooks: false, hookTypes: [] })),\n    58→  configureHookCoexistence: vi.fn(),\n    59→  BeadsError: class extends Error {\n    60→    constructor(c: string, m: string) { super(`Beads failed: ${m}`); this.name = 'BeadsError'; }\n    61→  },\n    62→}));\n    63→\n    64→vi.mock('../../../lib/bmad.js', () => ({\n    65→  isBmadInstalled: vi.fn(() => false),\n    66→  installBmad: vi.fn(() => ({ status: 'installed', version: '6.0.0', patches_applied: [] })),\n    67→  applyAllPatches: vi.fn(() => []),\n    68→  detectBmadVersion: vi.fn(() => '6.0.0'),\n    69→  detectBmalph: vi.fn(() => ({ detected: false, files: [] })),\n    70→  BmadError: class extends Error {\n    71→    constructor(c: string, m: string) { super(`BMAD failed: ${m}`); this.name = 'BmadError'; }\n    72→  },\n    73→}));\n    74→\n    75→vi.mock('../../../lib/observability/index.js', () => ({\n    76→  instrumentProject: vi.fn(() => ({\n    77→    status: 'configured',\n    78→    packages_installed: true,\n    79→    start_script_patched: true,\n    80→    env_vars_configured: true,\n    81→  })),\n    82→  configureOtlpEnvVars: vi.fn(),\n    83→}));\n    84→\n    85→vi.mock('../../../lib/templates.js', () => ({\n    86→  generateFile: vi.fn(),\n    87→}));\n    88→\n    89→vi.mock('../../../templates/readme.js', () => ({\n    90→  readmeTemplate: vi.fn(() => '# README'),\n    91→}));\n    92→\n    93→import { isDockerAvailable } from '../../../lib/docker/index.js';\n    94→import { installAllDependencies, CriticalDependencyError } from '../../../lib/deps.js';\n    95→import { isBeadsInitialized, BeadsError } from '../../../lib/beads.js';\n    96→import { readState, writeState, getDefaultState } from '../../../lib/state.js';\n    97→import { detectStacks, detectAppType } from '../../../lib/stacks/index.js';\n    98→import { instrumentProject } from '../../../lib/observability/index.js';\n    99→import { getCoverageTool } from '../docs-scaffold.js';\n   100→import { initProject } from '../init-project.js';\n   101→\n   102→const mockIsDockerAvailable = vi.mocked(isDockerAvailable);\n   103→const mockInstallAll = vi.mocked(installAllDependencies);\n   104→const mockIsBeadsInitialized = vi.mocked(isBeadsInitialized);\n   105→const mockDetectStacks = vi.mocked(detectStacks);\n   106→const mockInstrumentProject = vi.mocked(instrumentProject);\n   107→const mockGetCoverageTool = vi.mocked(getCoverageTool);\n   108→\n   109→let testDir: string;\n   110→let originalCwd: string;\n   111→\n   112→beforeEach(() => {\n   113→  testDir = mkdtempSync(join(tmpdir(), 'ch-init-project-test-'));\n   114→  originalCwd = process.cwd();\n   115→  process.chdir(testDir);\n   116→  vi.spyOn(console, 'log').mockImplementation(() => {});\n   117→  process.exitCode = undefined;\n   118→  // Reset mocks to default implementations\n   119→  mockIsDockerAvailable.mockReturnValue(true);\n   120→  mockInstallAll.mockReturnValue([\n   121→    { name: 'showboat', displayName: 'Showboat', status: 'already-installed', version: '0.6.1' },\n   122→  ]);\n   123→  mockIsBeadsInitialized.mockReturnValue(false);\n   124→});\n   125→\n   126→afterEach(() => {\n   127→  process.chdir(originalCwd);\n   128→  rmSync(testDir, { recursive: true, force: true });\n   129→  vi.restoreAllMocks();\n   130→  process.exitCode = undefined;\n   131→});\n   132→\n   133→describe('initProject — fresh init', () => {\n   134→  it('returns ok result with correct structure', async () => {\n   135→    writeFileSync(join(testDir, 'package.json'), '{}');\n   136→    const result = await initProject({\n   137→      projectDir: testDir,\n   138→      frontend: true,\n   139→      database: true,\n   140→      api: true,\n   141→      observability: false,\n   142→    });\n   143→    expect(result.success).toBe(true);\n   144→    if (result.success) {\n   145→      expect(result.data.status).toBe('ok');\n   146→      expect(result.data.stack).toBe('nodejs');\n   147→      expect(result.data.enforcement).toEqual({ frontend: true, database: true, api: true });\n   148→    }\n   149→  });\n   150→\n   151→  it('creates state file', async () => {\n   152→    writeFileSync(join(testDir, 'package.json'), '{}');\n   153→    await initProject({\n   154→      projectDir: testDir,\n   155→      frontend: true,\n   156→      database: true,\n   157→      api: true,\n   158→      observability: false,\n   159→    });\n   160→    const state = readState(testDir);\n   161→    expect(state.initialized).toBe(true);\n   162→    expect(state.stack).toBe('nodejs');\n   163→  });\n   164→\n   165→  it('includes beads result', async () => {\n   166→    writeFileSync(join(testDir, 'package.json'), '{}');\n   167→    const result = await initProject({\n   168→      projectDir: testDir,\n   169→      frontend: true,\n   170→      database: true,\n   171→      api: true,\n   172→      observability: false,\n   173→    });\n   174→    if (result.success) {\n   175→      expect(result.data.beads).toBeDefined();\n   176→      expect(result.data.beads!.status).toBe('initialized');\n   177→    }\n   178→  });\n   179→\n   180→  it('includes bmad result', async () => {\n   181→    writeFileSync(join(testDir, 'package.json'), '{}');\n   182→    const result = await initProject({\n   183→      projectDir: testDir,\n   184→      frontend: true,\n   185→      database: true,\n   186→      api: true,\n   187→      observability: false,\n   188→    });\n   189→    if (result.success) {\n   190→      expect(result.data.bmad).toBeDefined();\n   191→      expect(result.data.bmad!.status).toBe('installed');\n   192→    }\n   193→  });\n   194→\n   195→  it('includes dependencies result', async () => {\n   196→    writeFileSync(join(testDir, 'package.json'), '{}');\n   197→    const result = await initProject({\n   198→      projectDir: testDir,\n   199→      frontend: true,\n   200→      database: true,\n   201→      api: true,\n   202→      observability: false,\n   203→    });\n   204→    if (result.success) {\n   205→      expect(result.data.dependencies).toBeDefined();\n   206→      expect(result.data.dependencies!.length).toBeGreaterThan(0);\n   207→    }\n   208→  });\n   209→});\n   210→\n   211→describe('initProject — idempotent re-run', () => {\n   212→  it('detects already initialized and returns early', async () => {\n   213→    writeFileSync(join(testDir, 'package.json'), '{}');\n   214→    // First init\n   215→    await initProject({\n   216→      projectDir: testDir,\n   217→      frontend: true,\n   218→      database: true,\n   219→      api: true,\n   220→      observability: false,\n   221→    });\n   222→    // Second init (re-run)\n   223→    const result = await initProject({\n   224→      projectDir: testDir,\n   225→      frontend: true,\n   226→      database: true,\n   227→      api: true,\n   228→      observability: false,\n   229→    });\n   230→    expect(result.success).toBe(true);\n   231→    if (result.success) {\n   232→      expect(result.data.documentation.agents_md).toBe('exists');\n   233→    }\n   234→  });\n   235→});\n   236→\n   237→describe('initProject — critical failures', () => {\n   238→  it('returns ok with fail status when Docker missing and observability on', async () => {\n   239→    writeFileSync(join(testDir, 'package.json'), '{}');\n   240→    mockIsDockerAvailable.mockReturnValue(false);\n   241→    const result = await initProject({\n   242→      projectDir: testDir,\n   243→      frontend: true,\n   244→      database: true,\n   245→      api: true,\n   246→      observability: true,\n   247→    });\n   248→    expect(result.success).toBe(true);\n   249→    if (result.success) {\n   250→      expect(result.data.status).toBe('fail');\n   251→      expect(result.data.error).toBe('Docker not installed');\n   252→    }\n   253→    expect(process.exitCode).toBe(1);\n   254→  });\n   255→\n   256→  it('returns ok with fail status on critical dep failure', async () => {\n   257→    writeFileSync(join(testDir, 'package.json'), '{}');\n   258→    mockInstallAll.mockImplementation(() => {\n   259→      throw new CriticalDependencyError('git', 'not found');\n   260→    });\n   261→    const result = await initProject({\n   262→      projectDir: testDir,\n   263→      frontend: true,\n   264→      database: true,\n   265→      api: true,\n   266→      observability: false,\n   267→    });\n   268→    expect(result.success).toBe(true);\n   269→    if (result.success) {\n   270→      expect(result.data.status).toBe('fail');\n   271→    }\n   272→    expect(process.exitCode).toBe(1);\n   273→  });\n   274→});\n   275→\n   276→describe('initProject — non-critical failures', () => {\n   277→  it('continues when beads fails', async () => {\n   278→    writeFileSync(join(testDir, 'package.json'), '{}');\n   279→    mockIsBeadsInitialized.mockImplementation(() => {\n   280→      throw new BeadsError('init', 'network error');\n   281→    });\n   282→    const result = await initProject({\n   283→      projectDir: testDir,\n   284→      frontend: true,\n   285→      database: true,\n   286→      api: true,\n   287→      observability: false,\n   288→    });\n   289→    expect(result.success).toBe(true);\n   290→    if (result.success) {\n   291