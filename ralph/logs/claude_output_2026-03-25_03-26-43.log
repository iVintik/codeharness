(const p of candidates) {\n   317→      if (existsSync(p)) {\n   318→        reportPath = p;\n   319→        break;\n   320→      }\n   321→    }\n   322→\n   323→    if (!reportPath) return 0;\n   324→\n   325→    try {\n   326→      const report = JSON.parse(readFileSync(reportPath, 'utf-8')) as {\n   327→        total?: {\n   328→          statements?: { pct?: number };\n   329→        };\n   330→      };\n   331→      return report.total?.statements?.pct ?? 0;\n   332→    } catch {\n   333→      return 0;\n   334→    }\n   335→  }\n   336→\n   337→  // ── Task 15: getProjectName ───────────────────────────────────────────\n   338→\n   339→  getProjectName(dir: string): string | null {\n   340→    const pkg = readJsonSafe(join(dir, 'package.json'));\n   341→    if (pkg && typeof pkg.name === 'string') {\n   342→      return pkg.name;\n   343→    }\n   344→    return null;\n   345→  }\n   346→}\n   347→"}]},"parent_tool_use_id":"toolu_01AeWcLgyHoXRPKGkiwoR1Eu","session_id":"38809bab-d371-4c03-b647-b7b7381ee002","uuid":"d3909ee9-2039-496e-a00a-c991ecd78ecd","timestamp":"2026-03-24T23:36:51.362Z"}
