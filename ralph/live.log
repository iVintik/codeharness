{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XU5WCCXmVvjpQc4SVUxJuf","type":"tool_result","content":"     1→import { spawn } from 'node:child_process';\n     2→import { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n     3→import { join, dirname } from 'node:path';\n     4→import { fileURLToPath } from 'node:url';\n     5→import { StringDecoder } from 'node:string_decoder';\n     6→import { Command } from 'commander';\n     7→import { fail, info, jsonOutput } from '../lib/output.js';\n     8→import { readSprintStatus } from '../lib/beads-sync.js';\n     9→import { generateRalphPrompt } from '../templates/ralph-prompt.js';\n    10→import { parseStreamLine } from '../lib/stream-parser.js';\n    11→import { startRenderer, type SprintInfo } from '../lib/ink-renderer.js';\n    12→import { getSprintState } from '../modules/sprint/index.js';\n    13→import { formatElapsed, mapSprintStatuses, parseRalphMessage, parseIterationMessage, countStories, buildSpawnArgs } from '../lib/run-helpers.js';\n    14→\n    15→const SPRINT_STATUS_REL = '_bmad-output/implementation-artifacts/sprint-status.yaml';\n    16→\n    17→/** Resolves the path to ralph/ralph.sh relative to the package root. */\n    18→export function resolveRalphPath(): string {\n    19→  const currentFile = fileURLToPath(import.meta.url);\n    20→  const currentDir = dirname(currentFile);\n    21→  let root = dirname(currentDir);\n    22→  if (root.endsWith('/src') || root.endsWith('\\\\src')) {\n    23→    root = dirname(root);\n    24→  }\n    25→  return join(root, 'ralph', 'ralph.sh');\n    26→}\n    27→\n    28→/** Resolves the plugin directory path (.claude/ in project root). */\n    29→export function resolvePluginDir(): string {\n    30→  return join(process.cwd(), '.claude');\n    31→}\n    32→\n    33→// Re-export helpers that tests import from run.ts\n    34→export { countStories, buildSpawnArgs } from '../lib/run-helpers.js';\n    35→\n    36→export function registerRunCommand(program: Command): void {\n    37→  program\n    38→    .command('run')\n    39→    .description('Execute the autonomous coding loop')\n    40→    .option('--max-iterations <n>', 'Maximum loop iterations', '50')\n    41→    .option('--timeout <seconds>', 'Total loop timeout in seconds', '43200')\n    42→    .option('--iteration-timeout <minutes>', 'Per-iteration timeout in minutes', '30')\n    43→    .option('--quiet', 'Suppress terminal output (background mode)', false)\n    44→    .option('--calls <n>', 'Max API calls per hour', '100')\n    45→    .option('--max-story-retries <n>', 'Max retries per story before flagging', '10')\n    46→    .option('--reset', 'Clear retry counters, flagged stories, and circuit breaker before starting', false)\n    47→    .action(async (options, cmd) => {\n    48→      const globalOpts = cmd.optsWithGlobals();\n    49→      const isJson = !!globalOpts.json;\n    50→      const outputOpts = { json: isJson };\n    51→\n    52→      // 1. Resolve Ralph script path\n    53→      const ralphPath = resolveRalphPath();\n    54→      if (!existsSync(ralphPath)) {\n    55→        fail('Ralph loop not found — reinstall codeharness', outputOpts);\n    56→        process.exitCode = 1;\n    57→        return;\n    58→      }\n    59→\n    60→      // 2. Resolve plugin directory\n    61→      const pluginDir = resolvePluginDir();\n    62→      if (!existsSync(pluginDir)) {\n    63→        fail('Plugin directory not found — run codeharness init first', outputOpts);\n    64→        process.exitCode = 1;\n    65→        return;\n    66→      }\n    67→\n    68→      // 3. Read sprint status for story count\n    69→      const projectDir = process.cwd();\n    70→      const sprintStatusPath = join(projectDir, SPRINT_STATUS_REL);\n    71→      const statuses = readSprintStatus(projectDir);\n    72→      const counts = countStories(statuses);\n    73→\n    74→      if (counts.total === 0) {\n    75→        fail('No stories found in sprint-status.yaml — nothing to execute', outputOpts);\n    76→        process.exitCode = 1;\n    77→        return;\n    78→      }\n    79→\n    80→      info(`Starting autonomous execution — ${counts.ready} ready, ${counts.inProgress} in progress, ${counts.verified} verified, ${counts.done}/${counts.total} done`, outputOpts);\n    81→\n    82→      // 4. Parse and validate numeric options\n    83→      const maxIterations = parseInt(options.maxIterations, 10);\n    84→      const timeout = parseInt(options.timeout, 10);\n    85→      const iterationTimeout = parseInt(options.iterationTimeout, 10);\n    86→      const calls = parseInt(options.calls, 10);\n    87→      const maxStoryRetries = parseInt(options.maxStoryRetries, 10);\n    88→\n    89→      if (isNaN(maxIterations) || isNaN(timeout) || isNaN(iterationTimeout) || isNaN(calls) || isNaN(maxStoryRetries)) {\n    90→        fail('Invalid numeric option — --max-iterations, --timeout, --iteration-timeout, --calls, and --max-story-retries must be numbers', outputOpts);\n    91→        process.exitCode = 1;\n    92→        return;\n    93→      }\n    94→\n    95→      // 5. Generate prompt file (with flagged stories context if available)\n    96→      const promptFile = join(projectDir, 'ralph', '.harness-prompt.md');\n    97→      const flaggedFilePath = join(projectDir, 'ralph', '.flagged_stories');\n    98→      let flaggedStories: string[] | undefined;\n    99→      if (existsSync(flaggedFilePath)) {\n   100→        try {\n   101→          const flaggedContent = readFileSync(flaggedFilePath, 'utf-8');\n   102→          flaggedStories = flaggedContent.split('\\n').filter(s => s.trim().length > 0);\n   103→        } catch {\n   104→          // Ignore read errors\n   105→        }\n   106→      }\n   107→      const promptContent = generateRalphPrompt({\n   108→        projectDir,\n   109→        sprintStatusPath,\n   110→        flaggedStories,\n   111→      });\n   112→      try {\n   113→        mkdirSync(dirname(promptFile), { recursive: true });\n   114→        writeFileSync(promptFile, promptContent, 'utf-8');\n   115→      } catch (err) {\n   116→        const message = err instanceof Error ? err.message : String(err);\n   117→        fail(`Failed to write prompt file: ${message}`, outputOpts);\n   118→        process.exitCode = 1;\n   119→        return;\n   120→      }\n   121→\n   122→      // 6. Build spawn arguments\n   123→      const args = buildSpawnArgs({\n   124→        ralphPath,\n   125→        pluginDir,\n   126→        promptFile,\n   127→        maxIterations,\n   128→        timeout,\n   129→        iterationTimeout,\n   130→        calls,\n   131→        quiet: options.quiet,\n   132→        maxStoryRetries,\n   133→        reset: options.reset,\n   134→      });\n   135→\n   136→      // 7. Set environment — stream-json is always the output format\n   137→      const env = { ...process.env };\n   138→      if (isJson) {\n   139→        env.CLAUDE_OUTPUT_FORMAT = 'stream-json';\n   140→      }\n   141→\n   142→      // 8. Spawn Ralph — pipe stdout/stderr through stream parser → Ink renderer\n   143→      // Declare renderer handle outside try so cleanup is always reachable\n   144→      const quiet = options.quiet;\n   145→      const rendererHandle = startRenderer({ quiet });\n   146→      let sprintStateInterval: ReturnType<typeof setInterval> | null = null;\n   147→      const sessionStartTime = Date.now();\n   148→      let currentIterationCount = 0;\n   149→\n   150→      try {\n   151→        // Read initial sprint state for the renderer header\n   152→        const initialState = getSprintState();\n   153→        if (initialState.success) {\n   154→          const s = initialState.data;\n   155→          const sprintInfo: SprintInfo = {\n   156→            storyKey: s.run.currentStory ?? '',\n   157→            phase: s.run.currentPhase ?? '',\n   158→            done: s.sprint.done,\n   159→            total: s.sprint.total,\n   160→            elapsed: formatElapsed(Date.now() - sessionStartTime),\n   161→            iterationCount: currentIterationCount,\n   162→          };\n   163→          rendererHandle.updateSprintState(sprintInfo);\n   164→        }\n   165→\n   166→        // Feed initial per-story statuses to the renderer\n   167→        const initialStatuses = readSprintStatus(projectDir);\n   168→        const initialStories = mapSprintStatuses(initialStatuses);\n   169→        if (initialStories.length > 0) {\n   170→          rendererHandle.updateStories(initialStories);\n   171→        }\n   172→\n   173→        const child = spawn('bash', args, {\n   174→          stdio: quiet ? 'ignore' : ['inherit', 'pipe', 'pipe'],\n   175→          cwd: projectDir,\n   176→          env,\n   177→        });\n   178→\n   179→        if (!quiet && child.stdout && child.stderr) {\n   180→          // Buffer partial lines and feed through stream parser → Ink renderer.\n   181→          // StringDecoder handles multi-byte UTF-8 chars split across Buffer boundaries.\n   182→          const makeLineHandler = (opts?: { parseRalph?: boolean }): ((data: Buffer) => void) => {\n   183→            let partial = '';\n   184→            const decoder = new StringDecoder('utf8');\n   185→            return (data: Buffer): void => {\n   186→              const text = partial + decoder.write(data);\n   187→              const parts = text.split('\\n');\n   188→              partial = parts.pop() ?? '';\n   189→              for (const line of parts) {\n   190→                if (line.trim().length === 0) continue;\n   191→                const event = parseStreamLine(line);\n   192→                if (event) {\n   193→                  rendererHandle.update(event);\n   194→                }\n   195→                // Parse ralph structured output for story messages (AC #8)\n   196→                if (opts?.parseRalph) {\n   197→                  const msg = parseRalphMessage(line);\n   198→                  if (msg) {\n   199→                    rendererHandle.addMessage(msg);\n   200→                  }\n   201→                  // Parse iteration count from [LOOP] messages (AC #8)\n   202→                  const iteration = parseIterationMessage(line);\n   203→                  if (iteration !== null) {\n   204→                    currentIterationCount = iteration;\n   205→                  }\n   206→                }\n   207→              }\n   208→            };\n   209→          };\n   210→          child.stdout.on('data', makeLineHandler());\n   211→          child.stderr.on('data', makeLineHandler({ parseRalph: true }));\n   212→\n   213→          // Periodically refresh sprint state for the header display\n   214→          sprintStateInterval = setInterval(() => {\n   215→            try {\n   216→              const stateResult = getSprintState();\n   217→              if (stateResult.success) {\n   218→                const s = stateResult.data;\n   219→                const sprintInfo: SprintInfo = {\n   220→                  storyKey: s.run.currentStory ?? '',\n   221→                  phase: s.run.currentPhase ?? '',\n   222→                  done: s.sprint.done,\n   223→                  total: s.sprint.total,\n   224→                  elapsed: formatElapsed(Date.now() - sessionStartTime),\n   225→                  iterationCount: currentIterationCount,\n   226→                };\n   227→                rendererHandle.updateSprintState(sprintInfo);\n   228→              }\n   229→              // Refresh per-story statuses (AC #7)\n   230→              const currentStatuses = readSprintStatus(projectDir);\n   231→              const storyEntries = mapSprintStatuses(currentStatuses);\n   232→              rendererHandle.updateStories(storyEntries);\n   233→            } catch {\n   234→              // Ignore read errors during polling\n   235→            }\n   236→          }, 5_000);\n   237→        }\n   238→\n   239→        const exitCode = await new Promise<number>((resolve, reject) => {\n   240→          child.on('error', (err) => {\n   241→            if (sprintStateInterval) clearInterval(sprintStateInterval);\n   242→            rendererHandle.cleanup();\n   243→            reject(err);\n   244→          });\n   245→          child.on('close', (code) => {\n   246→            if (sprintStateInterval) clearInterval(sprintStateInterval);\n   247→            rendererHandle.cleanup();\n   248→            resolve(code ?? 1);\n   249→          });\n   250→        });\n   251→\n   252→        // 9. Handle JSON output on exit\n   253→        if (isJson) {\n   254→          const statusFile = join(projectDir, 'ralph', 'status.json');\n   255→          if (existsSync(statusFile)) {\n   256→            try {\n   257→              const statusData = JSON.parse(readFileSync(statusFile, 'utf-8'));\n   258→              const finalStatuses = readSprintStatus(projectDir);\n   259→              const finalCounts = countStories(finalStatuses);\n   260→              jsonOutput({\n   261→                status: statusData.status ?? (exitCode === 0 ? 'completed' : 'stopped'),\n   262→                iterations: statusData.loop_count ?? 0,\n   263→                storiesCompleted: finalCounts.done,\n   264→                storiesTotal: finalCounts.total,\n   265→                storiesRemaining: finalCounts.total - finalCounts.done,\n   266→                elapsedSeconds: statusData.elapsed_seconds ?? 0,\n   267→                flaggedStories: statusData.flagged_stories ?? [],\n   268→                exitReason: statusData.exit_reason ?? '',\n   269→              });\n   270→            } catch {\n   271→              jsonOutput({\n   272→                status: exitCode === 0 ? 'completed' : 'stopped',\n   273→                iterations: 0,\n   274→                storiesCompleted: 0,\n   275→                storiesTotal: counts.total,\n   276→                storiesRemaining: counts.total,\n   277→                elapsedSeconds: 0,\n   278→                flaggedStories: [],\n   279→                exitReason: 'status_file_unreadable',\n   280→              });\n   281→            }\n   282→          } else {\n   283→            // status.json not created (Ralph crashed early or never started)\n   284→            const finalStatuses = readSprintStatus(projectDir);\n   285→            const finalCounts = countStories(finalStatuses);\n   286→            jsonOutput({\n   287→              status: exitCode === 0 ? 'completed' : 'stopped',\n   288→              iterations: 0,\n   289→              storiesCompleted: finalCounts.done,\n   290→              storiesTotal: finalCounts.total,\n   291→              storiesRemaining: finalCounts.total - finalCounts.done,\n   292→              elapsedSeconds: 0,\n   293→              flaggedStories: [],\n   294→              exitReason: 'status_file_missing',\n   295→            });\n   296→          }\n   297→        }\n   298→\n   299→        process.exitCode = exitCode;\n   300→      } catch (err) {\n   301→        if (sprintStateInterval) clearInterval(sprintStateInterval);\n   302→        rendererHandle.cleanup();\n   303→        const message = err instanceof Error ? err.message : String(err);\n   304→        fail(`Failed to start Ralph: ${message}`, outputOpts);\n   305→        process.exitCode = 1;\n   306→      }\n   307→    });\n   308→}\n   309→"}]},"parent_tool_use_id":"toolu_01JZ7cmNZZkp82ndK5epjGGA","session_id":"eb26302c-c52a-41c7-9204-5eb8c12a854c","uuid":"1698cd4a-868c-47ed-ab0a-a40bc0655fe7","timestamp":"2026-03-21T11:17:01.184Z"}
