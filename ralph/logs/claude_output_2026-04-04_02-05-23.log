{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JCwDtpowEizP7mxVHdiXvL","type":"tool_result","content":"1\t/**\n2\t * Merge Agent — conflict resolution via driver dispatch with retry loop.\n3\t *\n4\t * Receives a MergeConflictContext with conflicting files, epic descriptions,\n5\t * and an AgentDriver instance. Dispatches the driver to resolve conflicts,\n6\t * validates with the test suite, and retries up to 3 times before escalating.\n7\t *\n8\t * @see Story 18-2: Merge Agent for Conflict Resolution\n9\t */\n10\t\n11\timport { execSync } from 'node:child_process';\n12\timport { readFileSync } from 'node:fs';\n13\timport { join } from 'node:path';\n14\timport { exec } from 'node:child_process';\n15\timport { promisify } from 'node:util';\n16\t\n17\timport type { AgentDriver } from './agents/types.js';\n18\t\n19\tconst execAsync = promisify(exec);\n20\t\n21\t// --- Interfaces ---\n22\t\n23\t/**\n24\t * Context provided to the merge agent for conflict resolution.\n25\t */\n26\texport interface MergeConflictContext {\n27\t  /** Epic identifier. */\n28\t  readonly epicId: string;\n29\t  /** Branch being merged. */\n30\t  readonly branch: string;\n31\t  /** List of conflicting file paths (relative to cwd). */\n32\t  readonly conflicts: string[];\n33\t  /** Description of what the main branch contains. */\n34\t  readonly mainDescription: string;\n35\t  /** Description of what the feature branch was building. */\n36\t  readonly branchDescription: string;\n37\t  /** Working directory (main repo root where merge is in progress). */\n38\t  readonly cwd: string;\n39\t  /** Command to run for test validation. */\n40\t  readonly testCommand: string;\n41\t  /** Driver instance to dispatch for conflict resolution. */\n42\t  readonly driver: AgentDriver;\n43\t}\n44\t\n45\t/**\n46\t * Result of a conflict resolution attempt.\n47\t */\n48\texport interface ConflictResolutionResult {\n49\t  /** Whether all conflicts were resolved and tests pass. */\n50\t  resolved: boolean;\n51\t  /** Number of resolution attempts made. */\n52\t  attempts: number;\n53\t  /** Whether the conflict was escalated for manual resolution. */\n54\t  escalated: boolean;\n55\t  /** Human-readable escalation message with details for manual resolution. */\n56\t  escalationMessage?: string;\n57\t  /** Test suite results from the last successful validation. */\n58\t  testResults?: { passed: number; failed: number; coverage?: number };\n59\t  /** List of files that were resolved. */\n60\t  resolvedFiles?: string[];\n61\t}\n62\t\n63\t// --- Constants ---\n64\t\n65\tconst MAX_ATTEMPTS = 3;\n66\t\n67\t// --- Prompt Construction ---\n68\t\n69\t/**\n70\t * Build the conflict resolution prompt for the driver.\n71\t *\n72\t * Includes file paths with full conflict-marker content, descriptions\n73\t * of both branches, and instructions to resolve preserving both changes.\n74\t */\n75\texport function buildConflictPrompt(ctx: MergeConflictContext, testFailure?: string): string {\n76\t  const conflictSections = ctx.conflicts.map((file) => {\n77\t    try {\n78\t      const content = readFileSync(join(ctx.cwd, file), 'utf-8');\n79\t      return `### ${file}\\n\\`\\`\\`\\n${content}\\n\\`\\`\\``;\n80\t    } catch { // IGNORE: file may be deleted on one side or unreadable — degrade gracefully in prompt\n81\t      return `### ${file}\\n*(File deleted on one side or unreadable)*`;\n82\t    }\n83\t  }).join('\\n\\n');\n84\t\n85\t  let prompt = `Merge conflict in ${ctx.conflicts.length} file(s) between main and ${ctx.branch}.\\n\\n`;\n86\t  prompt += `**Main branch context:** ${ctx.mainDescription}\\n`;\n87\t  prompt += `**Feature branch context:** ${ctx.branchDescription}\\n\\n`;\n88\t  prompt += `**Conflicting files:**\\n\\n${conflictSections}\\n\\n`;\n89\t  prompt += `Resolve ALL conflicts preserving changes from both branches. Both are correct additions.\\n`;\n90\t  prompt += `Write the resolved content to each file, stage with \\`git add\\`, and commit the merge resolution.\\n`;\n91\t\n92\t  if (testFailure) {\n93\t    prompt += `\\n**Previous attempt failed tests:**\\n\\`\\`\\`\\n${testFailure}\\n\\`\\`\\`\\n`;\n94\t    prompt += `Fix the resolution to make all tests pass.\\n`;\n95\t  }\n96\t  return prompt;\n97\t}\n98\t\n99\t// --- Escalation ---\n100\t\n101\t/**\n102\t * Build an escalation message with details for manual resolution.\n103\t */\n104\tfunction buildEscalationMessage(ctx: MergeConflictContext): string {\n105\t  const fileList = ctx.conflicts.map((f) => `  - ${f}`).join('\\n');\n106\t  return [\n107\t    `Merge conflict could not be auto-resolved after ${MAX_ATTEMPTS} attempts.`,\n108\t    ``,\n109\t    `Worktree: ${ctx.cwd}`,\n110\t    `Branch: ${ctx.branch}`,\n111\t    `Epic: ${ctx.epicId}`,\n112\t    ``,\n113\t    `Conflicting files:`,\n114\t    fileList,\n115\t    ``,\n116\t    `To inspect the diff:`,\n117\t    `  git diff ${ctx.branch}`,\n118\t  ].join('\\n');\n119\t}\n120\t\n121\t// --- Test Suite Runner ---\n122\t\n123\t/**\n124\t * Run the test suite and parse results.\n125\t * Returns pass/fail counts, coverage, and raw output for retry context.\n126\t */\n127\tasync function runTestSuite(\n128\t  testCommand: string,\n129\t  cwd: string,\n130\t): Promise<{ passed: number; failed: number; coverage?: number; output: string }> {\n131\t  try {\n132\t    const { stdout } = await execAsync(testCommand, {\n133\t      cwd,\n134\t      timeout: 300_000,\n135\t    });\n136\t    return { ...parseTestOutput(stdout), output: stdout };\n137\t  } catch (err: unknown) {\n138\t    const stdout = (err as { stdout?: string })?.stdout ?? '';\n139\t    const result = parseTestOutput(stdout);\n140\t    if (result.passed === 0 && result.failed === 0) {\n141\t      return { passed: 0, failed: 1, output: stdout || 'Test command failed with no output' };\n142\t    }\n143\t    return { ...result, output: stdout };\n144\t  }\n145\t}\n146\t\n147\t/**\n148\t * Parse test output to extract pass/fail counts and optional coverage.\n149\t */\n150\tfunction parseTestOutput(stdout: string): { passed: number; failed: number; coverage?: number } {\n151\t  let passed = 0;\n152\t  let failed = 0;\n153\t  let coverage: number | undefined;\n154\t\n155\t  const passMatch = stdout.match(/(\\d+)\\s+passed/);\n156\t  const failMatch = stdout.match(/(\\d+)\\s+failed/);\n157\t  if (passMatch) passed = parseInt(passMatch[1], 10);\n158\t  if (failMatch) failed = parseInt(failMatch[1], 10);\n159\t\n160\t  const covMatch = stdout.match(/All files[^|]*\\|\\s*([\\d.]+)/);\n161\t  if (covMatch) coverage = parseFloat(covMatch[1]);\n162\t\n163\t  return { passed, failed, ...(coverage !== undefined && { coverage }) };\n164\t}\n165\t\n166\t// --- Main Entry Point ---\n167\t\n168\t/**\n169\t * Resolve merge conflicts using an agent driver with retry loop.\n170\t *\n171\t * Dispatches the driver with conflict context, validates with the test suite,\n172\t * and retries up to 3 times. After 3 failures, escalates for manual resolution.\n173\t *\n174\t * @param ctx  Merge conflict context with files, descriptions, and driver.\n175\t * @returns Resolution result indicating success, failure, or escalation.\n176\t */\n177\texport async function resolveConflicts(ctx: MergeConflictContext): Promise<ConflictResolutionResult> {\n178\t  // Guard: empty conflict list\n179\t  if (ctx.conflicts.length === 0) {\n180\t    return { resolved: true, attempts: 0, escalated: false };\n181\t  }\n182\t\n183\t  let lastTestFailure: string | undefined;\n184\t\n185\t  for (let attempt = 1; attempt <= MAX_ATTEMPTS; attempt++) {\n186\t    const prompt = buildConflictPrompt(ctx, lastTestFailure);\n187\t\n188\t    // Dispatch driver — consume stream events to completion\n189\t    try {\n190\t      for await (const _event of ctx.driver.dispatch({\n191\t        prompt,\n192\t        model: ctx.driver.defaultModel,\n193\t        cwd: ctx.cwd,\n194\t        sourceAccess: true,\n195\t      })) {\n196\t        // Stream events consumed; merge agent doesn't need to display them\n197\t      }\n198\t    } catch { // IGNORE: driver dispatch failed (network error, rate limit) — treat as failed attempt\n199\t      // Treat as a failed attempt — try to revert and retry\n200\t      try {\n201\t        execSync('git reset --hard HEAD~1', { cwd: ctx.cwd, timeout: 30_000 });\n202\t      } catch { // IGNORE: git reset failed — escalate immediately on corrupted git state\n203\t        return {\n204\t          resolved: false,\n205\t          attempts: attempt,\n206\t          escalated: true,\n207\t          escalationMessage: buildEscalationMessage(ctx),\n208\t        };\n209\t      }\n210\t      lastTestFailure = 'Driver dispatch failed. Retrying with fresh attempt.';\n211\t      continue;\n212\t    }\n213\t\n214\t    // Run test suite\n215\t    const testResults = await runTestSuite(ctx.testCommand, ctx.cwd);\n216\t    if (testResults.failed === 0 && testResults.passed > 0) {\n217\t      return {\n218\t        resolved: true,\n219\t        attempts: attempt,\n220\t        escalated: false,\n221\t        testResults: {\n222\t          passed: testResults.passed,\n223\t          failed: testResults.failed,\n224\t          ...(testResults.coverage !== undefined && { coverage: testResults.coverage }),\n225\t        },\n226\t        resolvedFiles: ctx.conflicts,\n227\t      };\n228\t    }\n229\t\n230\t    // Tests failed — revert and retry\n231\t    lastTestFailure = testResults.output;\n232\t    try {\n233\t      execSync('git reset --hard HEAD~1', { cwd: ctx.cwd, timeout: 30_000 });\n234\t    } catch { // IGNORE: git reset failed after test failure — escalate on corrupted git state\n235\t      return {\n236\t        resolved: false,\n237\t        attempts: attempt,\n238\t        escalated: true,\n239\t        escalationMessage: buildEscalationMessage(ctx),\n240\t      };\n241\t    }\n242\t  }\n243\t\n244\t  // All attempts exhausted — escalate\n245\t  return {\n246\t    resolved: false,\n247\t    attempts: MAX_ATTEMPTS,\n248\t    escalated: true,\n249\t    escalationMessage: buildEscalationMessage(ctx),\n250\t  };\n251\t}\n252\t"}]},"parent_tool_use_id":"toolu_01CHrkgpjhvPg7eJ8iLesM4b","session_id":"22206bba-5847-41b1-b510-883e1dd8c0da","uuid":"46bc803e-aa30-421f-8624-302c372d7f0c","timestamp":"2026-04-03T22:08:08.605Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VThGnFyZMRz31SXL6D645n","type":"tool_result","content":"1\t/**\n2\t * Worktree Manager.\n3\t *\n4\t * Handles git worktree lifecycle for parallel epic execution:\n5\t * create, cleanup, list, and orphan detection. Each epic gets\n6\t * its own git worktree on a dedicated branch under the\n7\t * `codeharness/` namespace.\n8\t *\n9\t * @see Story 17-1: Worktree Manager\n10\t * @see Story 18-2: Merge Agent for Conflict Resolution (onConflict callback)\n11\t */\n12\t\n13\timport { exec, execSync } from 'node:child_process';\n14\timport { existsSync, readFileSync, statSync } from 'node:fs';\n15\timport { join } from 'node:path';\n16\timport { promisify } from 'node:util';\n17\t\n18\timport type { ConflictResolutionResult } from './merge-agent.js';\n19\t\n20\tconst execAsync = promisify(exec);\n21\t\n22\t/**\n23\t * Partial conflict context that mergeWorktree can fill from its own state.\n24\t * The onConflict callback receives this and enriches it with driver/descriptions\n25\t * before calling the merge agent.\n26\t */\n27\texport interface MergeConflictInfo {\n28\t  readonly epicId: string;\n29\t  readonly branch: string;\n30\t  readonly conflicts: string[];\n31\t  readonly cwd: string;\n32\t  readonly testCommand: string;\n33\t}\n34\t\n35\t// --- Constants ---\n36\t\n37\t/** Branch prefix for all codeharness worktree branches. */\n38\texport const BRANCH_PREFIX = 'codeharness/epic-';\n39\t\n40\t/** Base path for worktree directories in /tmp. */\n41\texport const WORKTREE_BASE = '/tmp/codeharness-wt-epic-';\n42\t\n43\t// --- Interfaces ---\n44\t\n45\t/**\n46\t * Information about a codeharness worktree.\n47\t */\n48\texport interface WorktreeInfo {\n49\t  /** Epic identifier extracted from the branch name. */\n50\t  readonly epicId: string;\n51\t  /** Absolute path to the worktree directory. */\n52\t  readonly path: string;\n53\t  /** Full branch name (e.g., `codeharness/epic-17-worktree-manager`). */\n54\t  readonly branch: string;\n55\t  /** Timestamp when the worktree was created. */\n56\t  readonly createdAt: Date;\n57\t}\n58\t\n59\t// --- Error Class ---\n60\t\n61\t/**\n62\t * Error thrown by worktree operations. Includes stderr from git commands.\n63\t */\n64\texport class WorktreeError extends Error {\n65\t  /** Raw stderr output from the failed git command. */\n66\t  readonly stderr: string;\n67\t\n68\t  constructor(message: string, stderr: string) {\n69\t    super(message);\n70\t    this.name = 'WorktreeError';\n71\t    this.stderr = stderr;\n72\t  }\n73\t}\n74\t\n75\t// --- Merge Types ---\n76\t\n77\t/**\n78\t * Strategy used when merging an epic branch into main.\n79\t */\n80\texport type MergeStrategy = 'rebase' | 'merge-commit';\n81\t\n82\t/**\n83\t * Result of a merge operation.\n84\t */\n85\texport interface MergeResult {\n86\t  /** Whether the merge and post-merge validation succeeded. */\n87\t  success: boolean;\n88\t  /** Reason for failure, if any. */\n89\t  reason?: 'conflict' | 'tests-failed' | 'git-error';\n90\t  /** List of conflicting file paths, when reason is 'conflict'. */\n91\t  conflicts?: string[];\n92\t  /** Test suite results from post-merge validation. */\n93\t  testResults?: { passed: number; failed: number; coverage?: number };\n94\t  /** Total wall-clock duration of the merge operation in milliseconds. */\n95\t  durationMs: number;\n96\t}\n97\t\n98\t// --- Async Mutex ---\n99\t\n100\t/**\n101\t * Simple async mutex for serializing merge operations.\n102\t * No external dependencies — uses a promise-based wait queue.\n103\t */\n104\texport class AsyncMutex {\n105\t  private locked = false;\n106\t  private waitQueue: Array<() => void> = [];\n107\t\n108\t  async acquire(): Promise<() => void> {\n109\t    while (this.locked) {\n110\t      await new Promise<void>((resolve) => this.waitQueue.push(resolve));\n111\t    }\n112\t    this.locked = true;\n113\t    return () => {\n114\t      this.locked = false;\n115\t      const next = this.waitQueue.shift();\n116\t      if (next) next();\n117\t    };\n118\t  }\n119\t}\n120\t\n121\t/** Module-level singleton merge mutex shared across all WorktreeManager instances. */\n122\texport const mergeMutex = new AsyncMutex();\n123\t\n124\t/**\n125\t * Callback invoked when merge conflicts are detected.\n126\t * Receives partial conflict info (what mergeWorktree knows), returns resolution result.\n127\t * The caller enriches this with driver and descriptions before calling the merge agent.\n128\t */\n129\texport type OnConflictCallback = (info: MergeConflictInfo) => Promise<ConflictResolutionResult>;\n130\t\n131\t// --- WorktreeManager Class ---\n132\t\n133\t/**\n134\t * Manages git worktrees for parallel epic execution.\n135\t *\n136\t * Creates isolated working directories (worktrees) for each epic,\n137\t * each on its own branch under the `codeharness/` namespace.\n138\t */\n139\texport class WorktreeManager {\n140\t  private readonly mainBranch: string;\n141\t  private readonly cwd: string;\n142\t\n143\t  /**\n144\t   * @param mainBranch  The main branch to base new worktree branches on (default: `'main'`).\n145\t   * @param cwd  The git repository root directory (default: `process.cwd()`).\n146\t   */\n147\t  constructor(mainBranch: string = 'main', cwd?: string) {\n148\t    this.mainBranch = mainBranch;\n149\t    this.cwd = cwd ?? process.cwd();\n150\t  }\n151\t\n152\t  /**\n153\t   * Create a worktree for a parallel epic.\n154\t   *\n155\t   * Creates a branch `codeharness/epic-{epicId}-{slug}` from the main branch HEAD,\n156\t   * then creates a git worktree at `/tmp/codeharness-wt-epic-{epicId}`.\n157\t   *\n158\t   * If a stale branch or worktree exists from a previous crashed run,\n159\t   * it is cleaned up before re-creating (idempotent recovery).\n160\t   *\n161\t   * @param epicId  The epic identifier (numeric or string).\n162\t   * @param slug  A human-readable slug for the branch name (sanitized to `[a-z0-9-]`).\n163\t   * @returns The absolute path to the created worktree directory.\n164\t   * @throws {WorktreeError} If the git command fails.\n165\t   */\n166\t  createWorktree(epicId: string, slug: string): string {\n167\t    this.validateEpicId(epicId);\n168\t    const sanitizedSlug = this.sanitizeSlug(slug);\n169\t    const branchName = `${BRANCH_PREFIX}${epicId}-${sanitizedSlug}`;\n170\t    const worktreePath = `${WORKTREE_BASE}${epicId}`;\n171\t\n172\t    // Clean up stale state from previous crashed runs (AC #9)\n173\t    this.cleanupStale(epicId, branchName, worktreePath);\n174\t\n175\t    let branchCreated = false;\n176\t    try {\n177\t      // Create branch from main branch HEAD\n178\t      this.execGit(`git branch ${branchName} ${this.mainBranch}`);\n179\t      branchCreated = true;\n180\t\n181\t      // Create worktree\n182\t      this.execGit(`git worktree add ${worktreePath} ${branchName}`);\n183\t\n184\t      return worktreePath;\n185\t    } catch (err: unknown) {\n186\t      // Clean up partial state on failure (AC #10)\n187\t      this.cleanupPartial(branchCreated, branchName, worktreePath);\n188\t\n189\t      // execGit always wraps errors as WorktreeError; re-throw directly\n190\t      if (err instanceof WorktreeError) {\n191\t        throw err;\n192\t      }\n193\t\n194\t      // Defensive: handle unexpected non-WorktreeError (should not happen)\n195\t      const message = err instanceof Error ? err.message : String(err);\n196\t      throw new WorktreeError(\n197\t        `Failed to create worktree for epic ${epicId}: ${message}`,\n198\t        '',\n199\t      );\n200\t    }\n201\t  }\n202\t\n203\t  /**\n204\t   * Remove a worktree and its branch for an epic.\n205\t   *\n206\t   * Idempotent: completes without error if the worktree or branch\n207\t   * does not exist (AC #5).\n208\t   *\n209\t   * @param epicId  The epic identifier.\n210\t   */\n211\t  cleanupWorktree(epicId: string): void {\n212\t    this.validateEpicId(epicId);\n213\t    const worktreePath = `${WORKTREE_BASE}${epicId}`;\n214\t\n215\t    // Remove worktree (ignore errors if it doesn't exist)\n216\t    try {\n217\t      this.execGit(`git worktree remove ${worktreePath} --force`);\n218\t    } catch { // IGNORE: idempotent cleanup — worktree may not exist per AC #5\n219\t    }\n220\t\n221\t    // Find and delete the branch matching this epicId\n222\t    const branch = this.findBranchForEpic(epicId);\n223\t    if (branch) {\n224\t      try {\n225\t        this.execGit(`git branch -D ${branch}`);\n226\t      } catch { // IGNORE: idempotent cleanup — branch may not exist per AC #5\n227\t      }\n228\t    }\n229\t  }\n230\t\n231\t  /**\n232\t   * List all codeharness worktrees.\n233\t   *\n234\t   * @returns An array of `WorktreeInfo` objects sorted by epicId.\n235\t   *          Returns an empty array when no codeharness worktrees exist.\n236\t   */\n237\t  listWorktrees(): WorktreeInfo[] {\n238\t    let output: string;\n239\t    try {\n240\t      output = this.execGit('git worktree list --porcelain');\n241\t    } catch { // IGNORE: non-git-repo or corrupt state returns empty list safely\n242\t      return [];\n243\t    }\n244\t\n245\t    const entries = this.parsePorcelainOutput(output);\n246\t    return entries\n247\t      .filter((e) => e.branch.startsWith(`refs/heads/${BRANCH_PREFIX}`))\n248\t      .map((e) => {\n249\t        const branchName = e.branch.replace('refs/heads/', '');\n250\t        const epicId = this.extractEpicId(branchName);\n251\t        return {\n252\t          epicId,\n253\t          path: e.path,\n254\t          branch: branchName,\n255\t          createdAt: this.getWorktreeCreatedAt(e.path),\n256\t        };\n257\t      })\n258\t      .sort((a, b) => a.epicId.localeCompare(b.epicId, undefined, { numeric: true }));\n259\t  }\n260\t\n261\t  /**\n262\t   * Detect orphaned worktrees from previous crashed runs.\n263\t   *\n264\t   * A worktree is considered orphaned if its directory exists on disk\n265\t   * but has no `.codeharness/lane-state.json` file or the file has\n266\t   * no active PID.\n267\t   *\n268\t   * @returns An array of orphaned `WorktreeInfo` entries.\n269\t   */\n270\t  detectOrphans(): WorktreeInfo[] {\n271\t    const worktrees = this.listWorktrees();\n272\t    return worktrees.filter((wt) => this.isOrphaned(wt));\n273\t  }\n274\t\n275\t  /**\n276\t   * Merge an epic branch into the main branch with serialized access.\n277\t   *\n278\t   * Acquires a module-level mutex so only one merge runs at a time.\n279\t   * After a clean merge, runs the test suite. If tests fail, the merge\n280\t   * is reverted. On conflict or git error, the main branch is restored.\n281\t   *\n282\t   * @param epicId  The epic identifier whose branch should be merged.\n283\t   * @param strategy  Merge strategy: `'merge-commit'` (default) or `'rebase'`.\n284\t   * @param testCommand  Command to run for post-merge validation (default: `'npm test'`).\n285\t   * @returns A `MergeResult` describing the outcome.\n286\t   */\n287\t  async mergeWorktree(\n288\t    epicId: string,\n289\t    strategy: MergeStrategy = 'merge-commit',\n290\t    testCommand: string = 'npm test',\n291\t    onConflict?: OnConflictCallback,\n292\t  ): Promise<MergeResult> {\n293\t    const start = Date.now();\n294\t\n295\t    // Validate testCommand to prevent shell injection — only allow safe characters\n296\t    if (!/^[a-zA-Z0-9_./ -]+$/.test(testCommand)) {\n297\t      return {\n298\t        success: false,\n299\t        reason: 'git-error',\n300\t        durationMs: Date.now() - start,\n301\t      };\n302\t    }\n303\t\n304\t    // Find branch for this epicId\n305\t    const branch = this.findBranchForEpic(epicId);\n306\t    if (!branch) {\n307\t      return {\n308\t        success: false,\n309\t        reason: 'git-error',\n310\t        durationMs: Date.now() - start,\n311\t      };\n312\t    }\n313\t\n314\t    // Validate branch name to prevent command injection via malicious branch names\n315\t    if (!/^[a-zA-Z0-9_./-]+$/.test(branch)) {\n316\t      return {\n317\t        success: false,\n318\t        reason: 'git-error',\n319\t        durationMs: Date.now() - start,\n320\t      };\n321\t    }\n322\t\n323\t    const release = await mergeMutex.acquire();\n324\t    try {\n325\t      // Re-verify branch still exists after acquiring mutex (could be deleted while waiting)\n326\t      const branchCheck = this.findBranchForEpic(epicId);\n327\t      if (!branchCheck || branchCheck !== branch) {\n328\t        return {\n329\t          success: false,\n330\t          reason: 'git-error',\n331\t          durationMs: Date.now() - start,\n332\t        };\n333\t      }\n334\t\n335\t      // Verify main branch is clean before merge\n336\t      const status = this.execGit('git status --porcelain');\n337\t      if (status.length > 0) {\n338\t        return {\n339\t          success: false,\n340\t          reason: 'git-error',\n341\t          durationMs: Date.now() - start,\n342\t        };\n343\t      }\n344\t\n345\t      // Attempt merge or rebase\n346\t      try {\n347\t        if (strategy === 'rebase') {\n348\t          this.execGit(`git rebase ${branch}`);\n349\t        } else {\n350\t          this.execGit(`git merge --no-ff ${branch}`);\n351\t        }\n352\t      } catch { // IGNORE: merge/rebase failure is expected — detect conflict vs git-error below\n353\t        const conflicts = this.detectConflicts();\n354\t        if (conflicts.length > 0) {\n355\t          // If onConflict callback is provided, invoke the merge agent\n356\t          if (onConflict) {\n357\t            const result = await onConflict({\n358\t              epicId,\n359\t              branch,\n360\t              conflicts,\n361\t              cwd: this.cwd,\n362\t              testCommand,\n363\t            });\n364\t            if (result.resolved) {\n365\t              // Agent resolved and committed — cleanup worktree\n366\t              this.cleanupWorktree(epicId);\n367\t              return {\n368\t                success: true,\n369\t                testResults: result.testResults,\n370\t                durationMs: Date.now() - start,\n371\t              };\n372\t            }\n373\t            // Escalated — abort merge, preserve worktree\n374\t            this.abortMerge(strategy);\n375\t            return {\n376\t              success: false,\n377\t              reason: 'conflict',\n378\t              conflicts,\n379\t              durationMs: Date.now() - start,\n380\t            };\n381\t          }\n382\t          // No callback — existing behavior\n383\t          this.abortMerge(strategy);\n384\t          return {\n385\t            success: false,\n386\t            reason: 'conflict',\n387\t            conflicts,\n388\t            durationMs: Date.now() - start,\n389\t          };\n390\t        }\n391\t        // Not a conflict — unexpected git error\n392\t        this.abortMerge(strategy);\n393\t        return {\n394\t          success: false,\n395\t          reason: 'git-error',\n396\t          durationMs: Date.now() - start,\n397\t        };\n398\t      }\n399\t\n400\t      // Run test suite after successful merge\n401\t      const testResults = await this.runTestSuite(testCommand);\n402\t      if (testResults.failed > 0) {\n403\t        // Revert merge on test failure\n404\t        try {\n405\t          this.execGit('git reset --hard HEAD~1');\n406\t        } catch { // IGNORE: reset failure indicates corrupted git state; still return tests-failed\n407\t        }\n408\t        return {\n409\t          success: false,\n410\t          reason: 'tests-failed',\n411\t          testResults,\n412\t          durationMs: Date.now() - start,\n413\t        };\n414\t      }\n415\t\n416\t      // Success — cleanup worktree\n417\t      this.cleanupWorktree(epicId);\n418\t      return {\n419\t        success: true,\n420\t        testResults,\n421\t        durationMs: Date.now() - start,\n422\t      };\n423\t    } finally {\n424\t      release();\n425\t    }\n426\t  }\n427\t\n428\t  // --- Private Helpers ---\n429\t\n430\t  /**\n431\t   * Get the creation time of a worktree directory.\n432\t   * Falls back to current time if the directory doesn't exist or stat fails.\n433\t   */\n434\t  private getWorktreeCreatedAt(worktreePath: string): Date {\n435\t    try {\n436\t      const stats = statSync(worktreePath);\n437\t      return stats.birthtime;\n438\t    } catch { // IGNORE: stat failure — worktree dir may not be accessible; fall back to now\n439\t      return new Date();\n440\t    }\n441\t  }\n442\t\n443\t  /**\n444\t   * Validate epicId contains only safe characters `[a-zA-Z0-9-]`.\n445\t   * Prevents command injection via crafted epicId values.\n446\t   */\n447\t  private validateEpicId(epicId: string): void {\n448\t    if (!epicId || !/^[a-zA-Z0-9-]+$/.test(epicId)) {\n449\t      throw new WorktreeError(\n450\t        `Invalid epicId: \"${epicId}\" — must be non-empty and contain only [a-zA-Z0-9-]`,\n451\t        '',\n452\t      );\n453\t    }\n454\t  }\n455\t\n456\t  /**\n457\t   * Sanitize a slug to contain only `[a-z0-9-]`.\n458\t   */\n459\t  private sanitizeSlug(slug: string): string {\n460\t    return slug\n461\t      .toLowerCase()\n462\t      .replace(/[^a-z0-9-]/g, '-')\n463\t      .replace(/-+/g, '-')\n464\t      .replace(/^-|-$/g, '');\n465\t  }\n466\t\n467\t  /**\n468\t   * Execute a git command and return its stdout.\n469\t   * Wraps errors in WorktreeError with captured stderr.\n470\t   */\n471\t  private execGit(cmd: string): string {\n472\t    try {\n473\t      const result = execSync(cmd, {\n474\t        cwd: this.cwd,\n475\t        stdio: ['pipe', 'pipe', 'pipe'],\n476\t        timeout: 30_000,\n477\t      });\n478\t      return result.toString().trim();\n479\t    } catch (err: unknown) {\n480\t      const stderr = (err as { stderr?: Buffer })?.stderr?.toString() ?? '';\n481\t      throw new WorktreeError(`Git command failed: ${cmd} — ${stderr}`, stderr);\n482\t    }\n483\t  }\n484\t\n485\t  /**\n486\t   * Clean up stale branch and worktree from a previous crash (AC #9).\n487\t   */\n488\t  private cleanupStale(epicId: string, branchName: string, worktreePath: string): void {\n489\t    // Check if worktree path exists on disk\n490\t    if (existsSync(worktreePath)) {\n491\t      try {\n492\t        this.execGit(`git worktree remove ${worktreePath} --force`);\n493\t      } catch { // IGNORE: stale worktree removal is best-effort before re-create per AC #9\n494\t        try {\n495\t          this.execGit('git worktree prune');\n496\t        } catch { // IGNORE: prune is best-effort fallback for stale worktree cleanup\n497\t        }\n498\t      }\n499\t    }\n500\t\n501\t    // Check if branch already exists\n502\t    const existingBranch = this.findBranchForEpic(epicId);\n503\t    if (existingBranch) {\n504\t      try {\n505\t        this.execGit(`git branch -D ${existingBranch}`);\n506\t      } catch { // IGNORE: stale branch deletion is best-effort before re-create per AC #9\n507\t      }\n508\t    }\n509\t  }\n510\t\n511\t  /**\n512\t   * Clean up partial state after a failed createWorktree (AC #10).\n513\t   */\n514\t  private cleanupPartial(branchCreated: boolean, branchName: string, worktreePath: string): void {\n515\t    // Try to remove worktree if it was partially created\n516\t    try {\n517\t      this.execGit(`git worktree remove ${worktreePath} --force`);\n518\t    } catch { // IGNORE: partial worktree may not exist during failure cleanup per AC #10\n519\t    }\n520\t\n521\t    // Delete branch if it was created\n522\t    if (branchCreated) {\n523\t      try {\n524\t        this.execGit(`git branch -D ${branchName}`);\n525\t      } catch { // IGNORE: partial branch may not exist during failure cleanup per AC #10\n526\t      }\n527\t    }\n528\t  }\n529\t\n530\t  /**\n531\t   * Find a branch matching `codeharness/epic-{epicId}-*`.\n532\t   */\n533\t  private findBranchForEpic(epicId: string): string | undefined {\n534\t    try {\n535\t      const output = this.execGit(`git branch --list ${BRAN