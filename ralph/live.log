{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LqPMEZiZusPzABXzRe5Ns2","type":"tool_result","content":"     1→import { existsSync, readFileSync, writeFileSync } from 'node:fs';\n     2→import { join } from 'node:path';\n     3→import { parse } from 'yaml';\n     4→import { warn } from '../output.js';\n     5→\n     6→const SPRINT_STATUS_PATH = '_bmad-output/implementation-artifacts/sprint-status.yaml';\n     7→\n     8→/**\n     9→ * Reads sprint-status.yaml and returns the development_status map.\n    10→ */\n    11→export function readSprintStatus(dir?: string): Record<string, string> {\n    12→  const root = dir ?? process.cwd();\n    13→  const filePath = join(root, SPRINT_STATUS_PATH);\n    14→  if (!existsSync(filePath)) {\n    15→    return {};\n    16→  }\n    17→  try {\n    18→    const content = readFileSync(filePath, 'utf-8');\n    19→    const parsed = parse(content) as Record<string, unknown> | null;\n    20→    if (!parsed || typeof parsed !== 'object') {\n    21→      return {};\n    22→    }\n    23→    const devStatus = parsed.development_status;\n    24→    if (!devStatus || typeof devStatus !== 'object') {\n    25→      return {};\n    26→    }\n    27→    return devStatus as Record<string, string>;\n    28→  } catch {\n    29→    // IGNORE: sprint-status.yaml may not exist or be malformed\n    30→    return {};\n    31→  }\n    32→}\n    33→\n    34→/**\n    35→ * Updates a single story's status in sprint-status.yaml while preserving structure and comments.\n    36→ * Uses line-level text replacement to preserve YAML comments.\n    37→ */\n    38→export function updateSprintStatus(storyKey: string, newStatus: string, dir?: string): void {\n    39→  const root = dir ?? process.cwd();\n    40→  const filePath = join(root, SPRINT_STATUS_PATH);"}]},"parent_tool_use_id":null,"session_id":"7513e7c5-481d-406c-8e26-d0526a0df74d","uuid":"04e44be6-3f1e-43f7-afaa-afd022662296","timestamp":"2026-03-27T06:37:56.373Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ivintik/dev/personal/codeharness/src/lib/sync/sprint-yaml.ts","content":"import { existsSync, readFileSync, writeFileSync } from 'node:fs';\nimport { join } from 'node:path';\nimport { parse } from 'yaml';\nimport { warn } from '../output.js';\n\nconst SPRINT_STATUS_PATH = '_bmad-output/implementation-artifacts/sprint-status.yaml';\n\n/**\n * Reads sprint-status.yaml and returns the development_status map.\n */\nexport function readSprintStatus(dir?: string): Record<string, string> {\n  const root = dir ?? process.cwd();\n  const filePath = join(root, SPRINT_STATUS_PATH);\n  if (!existsSync(filePath)) {\n    return {};\n  }\n  try {\n    const content = readFileSync(filePath, 'utf-8');\n    const parsed = parse(content) as Record<string, unknown> | null;\n    if (!parsed || typeof parsed !== 'object') {\n      return {};\n    }\n    const devStatus = parsed.development_status;\n    if (!devStatus || typeof devStatus !== 'object') {\n      return {};\n    }\n    return devStatus as Record<string, string>;\n  } catch {\n    // IGNORE: sprint-status.yaml may not exist or be malformed\n    return {};\n  }\n}\n\n/**\n * Updates a single story's status in sprint-status.yaml while preserving structure and comments.\n * Uses line-level text replacement to preserve YAML comments.\n */\nexport function updateSprintStatus(storyKey: string, newStatus: string, dir?: string): void {\n  const root = dir ?? process.cwd();\n  const filePath = join(root, SPRINT_STATUS_PATH);","numLines":40,"startLine":1,"totalLines":126}}}
