tion\n   129→    expect(result).toContain('rustup');\n   130→    expect(result).toContain('cargo-tarpaulin');\n   131→  });\n   132→\n   133→  it('produces only base + common tools for generic/plugin project (no stacks)', () => {\n   134→    mockDetectStacks.mockReturnValue([]);\n   135→    const result = generateVerifyDockerfile(testDir);\n   136→    expect(result).toContain('FROM ubuntu:22.04');\n   137→    expect(result).toContain('curl jq git python3 pipx');\n   138→    // No stack-specific sections\n   139→    expect(result).not.toContain('nodesource');\n   140→    expect(result).not.toContain('rustup');\n   141→    expect(result).not.toContain('python3-pip');\n   142→  });\n   143→});\n   144→"}]},"parent_tool_use_id":"toolu_01UEcnB3h2gZqmEJqfPaXmt4","session_id":"38809bab-d371-4c03-b647-b7b7381ee002","uuid":"e65874f4-7fc7-4204-800b-71b8b33140c3","timestamp":"2026-03-24T23:42:40.189Z"}
