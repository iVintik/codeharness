{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XrfRuQAnYQUkefDbgper6v","type":"tool_result","content":"     1→/**\n     2→ * Types for the observability analyzer module.\n     3→ *\n     4→ * These interfaces are tool-agnostic: any static analysis tool\n     5→ * (Semgrep, ESLint, custom) can produce conforming output.\n     6→ * See architecture Decision 1 for rationale.\n     7→ */\n     8→\n     9→/** Severity levels for observability gaps */\n    10→export type GapSeverity = 'error' | 'warning' | 'info';\n    11→\n    12→/**\n    13→ * A single observability gap found by static analysis.\n    14→ *\n    15→ * Maps 1:1 from analyzer output. The `type` field carries the\n    16→ * rule ID from the analyzer (e.g., \"catch-without-logging\"),\n    17→ * NOT a Semgrep-specific identifier.\n    18→ */\n    19→export interface ObservabilityGap {\n    20→  /** File path where the gap was found */\n    21→  readonly file: string;\n    22→  /** Line number in the file */\n    23→  readonly line: number;\n    24→  /** Rule identifier from the analyzer */\n    25→  readonly type: string;\n    26→  /** Human-readable description of the gap */\n    27→  readonly description: string;\n    28→  /** Severity of the gap */\n    29→  readonly severity: GapSeverity;\n    30→}\n    31→\n    32→/**\n    33→ * Summary statistics from an analysis run.\n    34→ */\n    35→export interface AnalyzerSummary {\n    36→  /** Total number of functions scanned */\n    37→  readonly totalFunctions: number;\n    38→  /** Number of functions that have log statements */\n    39→  readonly functionsWithLogs: number;\n    40→  /** Number of error handlers without logging */\n    41→  readonly errorHandlersWithoutLogs: number;\n    42→  /** Coverage percentage: functionsWithLogs / totalFunctions * 100 */\n    43→  readonly coveragePercent: number;\n    44→  /** Distribution of log levels found (e.g., { debug: 5, error: 3 }) */\n    45→  readonly levelDistribution: Record<string, number>;\n    46→}\n    47→\n    48→/**\n    49→ * Configuration for the analyzer module.\n    50→ *\n    51→ * Allows callers to specify which tool to use and where rules live.\n    52→ * Defaults are applied when not provided.\n    53→ */\n    54→export interface AnalyzerConfig {\n    55→  /** The analysis tool to use. Default: 'semgrep' */\n    56→  readonly tool?: string;\n    57→  /** Directory containing analysis rules, relative to project root. Default: 'patches/observability/' */\n    58→  readonly rulesDir?: string;\n    59→  /** Timeout for the analysis subprocess in milliseconds. Default: 60000 */\n    60→  readonly timeout?: number;\n    61→  /**\n    62→   * Total number of functions in the project (from an external count or AST scan).\n    63→   * When provided, enables accurate coverage computation:\n    64→   * coveragePercent = (totalFunctions - functionsWithoutLogs) / totalFunctions * 100.\n    65→   * When omitted, totalFunctions defaults to the count of function-no-debug-log matches\n    66→   * (functions lacking logs), producing 0% coverage as the best conservative estimate.\n    67→   */\n    68→  readonly totalFunctions?: number;\n    69→}\n    70→\n    71→/**\n    72→ * The result of an analysis run, independent of the underlying tool.\n    73→ *\n    74→ * Any static analysis tool that produces this shape can be used as\n    75→ * a drop-in replacement for Semgrep.\n    76→ */\n    77→export interface AnalyzerResult {\n    78→  /** The tool that produced this result (e.g., 'semgrep', 'eslint', 'custom') */\n    79→  readonly tool: string;\n    80→  /** Observability gaps found */\n    81→  readonly gaps: ObservabilityGap[];\n    82→  /** Summary statistics */\n    83→  readonly summary: AnalyzerSummary;\n    84→  /** Whether the analysis was skipped (e.g., tool not installed) */\n    85→  readonly skipped?: boolean;\n    86→  /** Reason the analysis was skipped, if applicable */\n    87→  readonly skipReason?: string;\n    88→}\n    89→\n    90→/**\n    91→ * Raw JSON output from Semgrep's --json flag.\n    92→ * Internal type — not part of the public API.\n    93→ */\n    94→export interface SemgrepRawOutput {\n    95→  readonly results: ReadonlyArray<SemgrepResult>;\n    96→  readonly errors?: ReadonlyArray<unknown>;\n    97→}\n    98→\n    99→// ============================================================\n   100→// Coverage state types (Story 1.3)\n   101→// ============================================================\n   102→\n   103→/** A single coverage history entry with timestamp */\n   104→export interface CoverageHistoryEntry {\n   105→  /** Coverage percentage at this point in time */\n   106→  readonly coveragePercent: number;\n   107→  /** ISO 8601 timestamp when this measurement was taken */\n   108→  readonly timestamp: string;\n   109→}\n   110→\n   111→/** Static analysis coverage state persisted in sprint-state.json */\n   112→export interface StaticCoverageState {\n   113→  /** Current coverage percentage */\n   114→  readonly coveragePercent: number;\n   115→  /** ISO 8601 timestamp of last scan */\n   116→  readonly lastScanTimestamp: string;\n   117→  /** Historical coverage entries */\n   118→  readonly history: readonly CoverageHistoryEntry[];\n   119→}\n   120→\n   121→/** Coverage targets configuration */\n   122→export interface CoverageTargets {\n   123→  /** Target coverage percentage for static analysis (default 80) */\n   124→  readonly staticTarget: number;\n   125→  /** Target coverage percentage for runtime observability (default 60) */\n   126→  readonly runtimeTarget?: number;\n   127→}\n   128→\n   129→/**\n   130→ * Top-level observability coverage state in sprint-state.json.\n   131→ *\n   132→ * Contains `static` (Story 1.3) and optional `runtime` (Story 2.1) sections.\n   133→ * Follows architecture Decision 2 (Separate Metrics).\n   134→ */\n   135→export interface ObservabilityCoverageState {\n   136→  /** Static analysis coverage metrics */\n   137→  readonly static: StaticCoverageState;\n   138→  /** Coverage targets */\n   139→  readonly targets: CoverageTargets;\n   140→  /** Runtime observability coverage metrics (Story 2.1) */\n   141→  readonly runtime?: RuntimeCoverageState;\n   142→}\n   143→\n   144→// ============================================================\n   145→// Runtime coverage types (Story 2.1)\n   146→// ============================================================\n   147→\n   148→/** A single AC's runtime coverage entry from verification */\n   149→export interface RuntimeCoverageEntry {\n   150→  /** Acceptance criterion identifier */\n   151→  readonly acId: string;\n   152→  /** Whether log events were detected for this AC */\n   153→  readonly logEventsDetected: boolean;\n   154→  /** Number of log events detected */\n   155→  readonly logEventCount: number;\n   156→  /** Gap note if no log events detected */\n   157→  readonly gapNote?: string;\n   158→}\n   159→\n   160→/** Result of computing runtime coverage from parsed observability gaps */\n   161→export interface RuntimeCoverageResult {\n   162→  /** Per-AC runtime coverage entries */\n   163→  readonly entries: readonly RuntimeCoverageEntry[];\n   164→  /** Total number of ACs evaluated */\n   165→  readonly totalACs: number;\n   166→  /** Number of ACs that produced log events */\n   167→  readonly acsWithLogs: number;\n   168→  /** Runtime coverage percentage: acsWithLogs / totalACs * 100 */\n   169→  readonly coveragePercent: number;\n   170→}\n   171→\n   172→/** Runtime coverage state persisted in sprint-state.json */\n   173→export interface RuntimeCoverageState {\n   174→  /** Runtime coverage percentage */\n   175→  readonly coveragePercent: number;\n   176→  /** ISO 8601 timestamp of last validation */\n   177→  readonly lastValidationTimestamp: string;\n   178→  /** Number of modules with telemetry */\n   179→  readonly modulesWithTelemetry: number;\n   180→  /** Total number of modules */\n   181→  readonly totalModules: number;\n   182→  /** Whether telemetry was detected at all */\n   183→  readonly telemetryDetected: boolean;\n   184→}\n   185→\n   186→/** Trend comparison between latest and previous coverage entries */\n   187→export interface CoverageTrend {\n   188→  /** Latest coverage percentage */\n   189→  readonly current: number;\n   190→  /** Previous coverage percentage, or null if only one entry */\n   191→  readonly previous: number | null;\n   192→  /** Delta: current - previous, or null if only one entry */\n   193→  readonly delta: number | null;\n   194→  /** Timestamp of latest measurement */\n   195→  readonly currentTimestamp: string;\n   196→  /** Timestamp of previous measurement, or null */\n   197→  readonly previousTimestamp: string | null;\n   198→}\n   199→\n   200→/** Result of checking coverage against a target */\n   201→export interface CoverageTargetResult {\n   202→  /** Whether coverage meets or exceeds the target */\n   203→  readonly met: boolean;\n   204→  /** Current coverage percentage */\n   205→  readonly current: number;\n   206→  /** Target coverage percentage */\n   207→  readonly target: number;\n   208→  /** Gap: target - current (0 if met) */\n   209→  readonly gap: number;\n   210→}\n   211→\n   212→/** A single result entry from Semgrep JSON output */\n   213→export interface SemgrepResult {\n   214→  readonly check_id: string;\n   215→  readonly path: string;\n   216→  readonly start: { readonly line: number; readonly col: number };\n   217→  readonly end: { readonly line: number; readonly col: number };\n   218→  readonly extra: {\n   219→    readonly message: string;\n   220→    readonly severity: string;\n   221→    readonly metadata?: Record<string, unknown>;\n   222→  };\n   223→}\n   224→"}]},"parent_tool_use_id":"toolu_01APL3Sm5JEakF5iK2mjDEd8","session_id":"f7a66acd-0cc1-40de-a592-d59e75273c0b","uuid":"b5d116e4-75ee-423f-92f5-367c28de620d","timestamp":"2026-03-20T05:53:07.911Z"}
