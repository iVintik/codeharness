ing) as Record<string, unknown>;\n   211→        return 'epics_parsed' in parsed;\n   212→      } catch {\n   213→        return false;\n   214→      }\n   215→    });\n   216→    expect(jsonCalls).toHaveLength(1);\n   217→    const result = JSON.parse(jsonCalls[0][0] as string) as Record<string, unknown>;\n   218→    expect(result.stories_processed).toBe(0);\n   219→  });\n   220→});\n   221→"}]},"parent_tool_use_id":"toolu_01WkMxZtPiPNmfZs5KGPn8sb","session_id":"ff429d75-7a8f-4551-b5e9-f4da09d39b92","uuid":"fdf12387-d6c9-4b8c-99ae-41f7cef6049d","timestamp":"2026-03-25T05:57:38.756Z"}
