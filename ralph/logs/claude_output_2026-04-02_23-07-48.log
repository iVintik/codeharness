c(path.dirname(badYaml), { recursive: true });\n        fs.writeFileSync(badYaml, '{ broken yaml [[[', 'utf-8');\n\n        // We can't easily test loadEmbeddedAgent with bad YAML because it uses a hardcoded path\n        // but we CAN test the error structure\n        const err = new AgentResolveError(\n          'Schema validation failed for embedded agent test: /name: must be string',\n          '/tmp/test.yaml',\n          [{ path: '/name', message: 'must be string' }],\n        );\n        expect(err.name).toBe('AgentResolveError');\n        expect(err.errors).toHaveLength(1);\n      } finally {\n        fs.rmSync(tmpDir, { recursive: true, force: true });\n      }\n    });\n  });"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1219,"cache_read_input_tokens":39895,"cache_creation":{"ephemeral_5m_input_tokens":1219,"ephemeral_1h_input_tokens":0},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01RPJXyu9D3EThP26t2M9i1U","session_id":"605a3302-c654-40ea-969b-1ce171500852","uuid":"06b88db8-6466-4786-898b-c06df43c0f09"}
