{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GEokv8nprbJYy49cB1eGMt","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport fs from 'node:fs';\n3\timport path from 'node:path';\n4\timport YAML from 'yaml';\n5\timport { validateAgentSchema } from '../schema-validate.js';\n6\t\n7\tconst TEMPLATES_DIR = path.resolve(__dirname, '../../../templates/agents');\n8\t\n9\tconst EXPECTED_AGENTS = [\n10\t  'dev',\n11\t  'qa',\n12\t  'architect',\n13\t  'pm',\n14\t  'sm',\n15\t  'analyst',\n16\t  'ux-designer',\n17\t  'tech-writer',\n18\t  'evaluator',\n19\t];\n20\t\n21\tfunction loadAgent(name: string): Record<string, unknown> {\n22\t  const filePath = path.join(TEMPLATES_DIR, `${name}.yaml`);\n23\t  const content = fs.readFileSync(filePath, 'utf-8');\n24\t  return YAML.parse(content) as Record<string, unknown>;\n25\t}\n26\t\n27\tdescribe('embedded agent templates', () => {\n28\t  describe('directory and file existence (AC #1)', () => {\n29\t    it('templates/agents/ directory exists', () => {\n30\t      expect(fs.existsSync(TEMPLATES_DIR)).toBe(true);\n31\t    });\n32\t\n33\t    it('contains exactly 9 YAML files', () => {\n34\t      const files = fs.readdirSync(TEMPLATES_DIR).filter((f) => f.endsWith('.yaml'));\n35\t      expect(files).toHaveLength(9);\n36\t    });\n37\t\n38\t    it.each(EXPECTED_AGENTS)('%s.yaml exists', (name) => {\n39\t      const filePath = path.join(TEMPLATES_DIR, `${name}.yaml`);\n40\t      expect(fs.existsSync(filePath)).toBe(true);\n41\t    });\n42\t  });\n43\t\n44\t  describe('YAML parsing (AC #2)', () => {\n45\t    it.each(EXPECTED_AGENTS)('%s.yaml parses as valid YAML', (name) => {\n46\t      const agent = loadAgent(name);\n47\t      expect(agent).toBeDefined();\n48\t      expect(typeof agent).toBe('object');\n49\t    });\n50\t\n51\t    it.each(EXPECTED_AGENTS)('%s.yaml has required top-level fields: name, role, persona', (name) => {\n52\t      const agent = loadAgent(name);\n53\t      expect(agent).toHaveProperty('name');\n54\t      expect(agent).toHaveProperty('role');\n55\t      expect(agent).toHaveProperty('persona');\n56\t      expect(typeof agent.name).toBe('string');\n57\t      expect(typeof agent.role).toBe('object');\n58\t      expect(typeof agent.persona).toBe('object');\n59\t\n60\t      const role = agent.role as Record<string, unknown>;\n61\t      expect(role).toHaveProperty('title');\n62\t      expect(role).toHaveProperty('purpose');\n63\t\n64\t      const persona = agent.persona as Record<string, unknown>;\n65\t      expect(persona).toHaveProperty('identity');\n66\t      expect(persona).toHaveProperty('communication_style');\n67\t      expect(persona).toHaveProperty('principles');\n68\t      expect(Array.isArray(persona.principles)).toBe(true);\n69\t    });\n70\t  });\n71\t\n72\t  describe('schema validation (AC #3)', () => {\n73\t    it.each(EXPECTED_AGENTS)('%s.yaml validates against agent.schema.json', (name) => {\n74\t      const agent = loadAgent(name);\n75\t      const result = validateAgentSchema(agent);\n76\t      expect(result).toEqual({ valid: true, errors: [] });\n77\t    });\n78\t  });\n79\t\n80\t  describe('name matches filename (AC #8)', () => {\n81\t    it.each(EXPECTED_AGENTS)('%s.yaml has name field matching filename stem', (name) => {\n82\t      const agent = loadAgent(name);\n83\t      expect(agent.name).toBe(name);\n84\t    });\n85\t  });\n86\t\n87\t  describe('evaluator agent specifics (AC #4, #5)', () => {\n88\t    it('evaluator.yaml contains disallowedTools with Edit and Write', () => {\n89\t      const agent = loadAgent('evaluator');\n90\t      expect(agent.disallowedTools).toBeDefined();\n91\t      expect(Array.isArray(agent.disallowedTools)).toBe(true);\n92\t      const tools = agent.disallowedTools as string[];\n93\t      expect(tools).toContain('Edit');\n94\t      expect(tools).toContain('Write');\n95\t    });\n96\t\n97\t    it('evaluator.yaml persona.principles includes anti-leniency keywords', () => {\n98\t      const agent = loadAgent('evaluator');\n99\t      const persona = agent.persona as Record<string, unknown>;\n100\t      const principles = persona.principles as string[];\n101\t      const joined = principles.join(' ');\n102\t\n103\t      expect(joined).toContain('evidence');\n104\t      expect(joined).toContain('UNKNOWN');\n105\t      expect(joined).toContain('benefit of the doubt');\n106\t    });\n107\t\n108\t    it('evaluator.yaml personality.traits.rigor >= 0.9', () => {\n109\t      const agent = loadAgent('evaluator');\n110\t      const personality = agent.personality as Record<string, unknown>;\n111\t      const traits = personality.traits as Record<string, number>;\n112\t      expect(traits.rigor).toBeGreaterThanOrEqual(0.9);\n113\t    });\n114\t\n115\t    it('evaluator.yaml personality.traits.warmth <= 0.3', () => {\n116\t      const agent = loadAgent('evaluator');\n117\t      const personality = agent.personality as Record<string, unknown>;\n118\t      const traits = personality.traits as Record<string, number>;\n119\t      expect(traits.warmth).toBeLessThanOrEqual(0.3);\n120\t    });\n121\t  });\n122\t\n123\t  describe('BMAD derivation format (AC #6)', () => {\n124\t    const bmadDerived = EXPECTED_AGENTS.filter((n) => n !== 'evaluator');\n125\t\n126\t    it.each(bmadDerived)('%s.yaml uses flat codeharness format (no agent: wrapper)', (name) => {\n127\t      const agent = loadAgent(name);\n128\t      // Must NOT have BMAD-specific sections\n129\t      expect(agent).not.toHaveProperty('agent');\n130\t      expect(agent).not.toHaveProperty('metadata');\n131\t      expect(agent).not.toHaveProperty('menu');\n132\t      expect(agent).not.toHaveProperty('critical_actions');\n133\t      expect(agent).not.toHaveProperty('prompts');\n134\t    });\n135\t\n136\t    it.each(bmadDerived)('%s.yaml does not have personality.traits (only evaluator gets traits)', (name) => {\n137\t      const agent = loadAgent(name);\n138\t      expect(agent).not.toHaveProperty('personality');\n139\t    });\n140\t  });\n141\t\n142\t  describe('no regressions (AC #8)', () => {\n143\t    it('existing schema validation still works for valid agent objects', () => {\n144\t      const result = validateAgentSchema({\n145\t        name: 'test-agent',\n146\t        role: { title: 'Test', purpose: 'Testing' },\n147\t        persona: {\n148\t          identity: 'A test agent',\n149\t          communication_style: 'Direct',\n150\t          principles: ['Be thorough'],\n151\t        },\n152\t      });\n153\t      expect(result).toEqual({ valid: true, errors: [] });\n154\t    });\n155\t\n156\t    it('existing schema validation still rejects invalid agent objects', () => {\n157\t      const result = validateAgentSchema({});\n158\t      expect(result.valid).toBe(false);\n159\t      expect(result.errors.length).toBeGreaterThan(0);\n160\t    });\n161\t  });\n162\t});\n163\t"}]},"parent_tool_use_id":"toolu_0155tz15CzD1ijXDNcEpYygc","session_id":"87824d62-8d3a-42e8-9563-dae1782fbf60","uuid":"4bcadf9e-0c1e-4b5a-9542-469e98fd8013","timestamp":"2026-04-02T15:39:27.375Z"}
