\t    },\n66\t  };\n67\t}\n68\t\n69\tdescribe('getDefaultWorkflowState', () => {\n70\t  it('returns correct default shape and types', () => {\n71\t    const state = getDefaultWorkflowState();\n72\t    expect(state.workflow_name).toBe('');\n73\t    expect(state.started).toBe('');\n74\t    expect(state.iteration).toBe(0);\n75\t    expect(state.phase).toBe('idle');\n76\t    expect(state.tasks_completed).toEqual([]);\n77\t    expect(state.evaluator_scores).toEqual([]);\n78\t    expect(state.circuit_breaker).toEqual({\n79\t      triggered: false,\n80\t      reason: null,\n81\t      score_history: [],\n82\t    });\n83\t  });\n84\t\n85\t  it('returns a new object each call (no shared references)', () => {\n86\t    const a = getDefaultWorkflowState();\n87\t    const b = getDefaultWorkflowState();\n88\t    expect(a).not.toBe(b);\n89\t    expect(a.tasks_completed).not.toBe(b.tasks_completed);\n90\t    expect(a.circuit_breaker).not.toBe(b.circuit_breaker);\n91\t  });\n92\t});\n93\t\n94\tdescribe('writeWorkflowState', () => {\n95\t  it('creates .codeharness/ directory if missing', () => {\n96\t    const state = getDefaultWorkflowState();\n97\t    writeWorkflowState(state, testDir);\n98\t    expect(existsSync(join(testDir, '.codeharness'))).toBe(true);\n99\t    expect(existsSync(join(testDir, '.codeharness', 'workflow-state.yaml'))).toBe(true);\n100\t  });\n101\t\n102\t  it('writes valid YAML that can be parsed', () => {\n103\t    const state = buildFullState();\n104\t    writeWorkflowState(state, testDir);\n105\t    const raw = readFileSync(join(testDir, '.codeharness', 'workflow-state.yaml'), 'utf-8');\n106\t    expect(raw).toContain('workflow_name: default');\n107\t    expect(raw).toContain('phase: verify');\n108\t    expect(raw).toContain('iteration: 2');\n109\t  });\n110\t\n111\t  it('overwrites existing file completely', () => {\n112\t    const state1 = buildFullState();\n113\t    state1.phase = 'first';\n114\t    writeWorkflowState(state1, testDir);\n115\t\n116\t    const state2 = getDefaultWorkflowState();\n117\t    state2.phase = 'second';\n118\t    writeWorkflowState(state2, testDir);\n119\t\n120\t    const raw = readFileSync(join(testDir, '.codeharness', 'workflow-state.yaml'), 'utf-8');\n121\t    expect(raw).toContain('phase: second');\n122\t    expect(raw).not.toContain('phase: first');\n123\t  });\n124\t\n125\t  it('handles nested .codeharness directory already existing', () => {\n126\t    mkdirSync(join(testDir, '.codeharness'), { recursive: true });\n127\t    const state = getDefaultWorkflowState();\n128\t    writeWorkflowState(state, testDir);\n129\t    expect(existsSync(join(testDir, '.codeharness', 'workflow-state.yaml'))).toBe(true);\n130\t  });\n131\t});\n132\t\n133\tdescribe('readWorkflowState', () => {\n134\t  it('returns default state when file does not exist', () => {\n135\t    const state = readWorkflowState(testDir);\n136\t    expect(state).toEqual(getDefaultWorkflowState());\n137\t  });\n138\t\n139\t  it('does not warn when file simply does not exist', () => {\n140\t    readWorkflowState(testDir);\n141\t    expect(warn).not.toHaveBeenCalled();\n142\t  });\n143\t\n144\t  it('returns default state and warns on corrupted YAML', () => {\n145\t    mkdirSync(join(testDir, '.codeharness'), { recursive: true });\n146\t    writeFileSync(join(testDir, '.codeharness', 'workflow-state.yaml'), '{{{{not yaml at all', 'utf-8');\n147\t    const state = readWorkflowState(testDir);\n148\t    expect(state).toEqual(getDefaultWorkflowState());\n149\t    expect(warn).toHaveBeenCalledWith(expect.stringContaining('invalid YAML'));\n150\t  });\n151\t\n152\t  it('returns default state and warns on empty file', () => {\n153\t    mkdirSync(join(testDir, '.codeharness'), { recursive: true });\n154\t    writeFileSync(join(testDir, '.codeharness', 'workflow-state.yaml'), '', 'utf-8');\n155\t    // Empty string parses to null in yaml, which fails shape check\n156\t    const state = readWorkflowState(testDir);\n157\t    expect(state).toEqual(ge