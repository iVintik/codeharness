{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CQfa3uwWLPyJGbMXaEC9xH","type":"tool_result","content":"1\t/**\n2\t * Ink Terminal Renderer — live terminal UI for Claude activity display.\n3\t * Exports startRenderer() which returns a RendererHandle for feeding events.\n4\t */\n5\t\n6\timport React from 'react';\n7\timport { render as inkRender } from 'ink';\n8\timport type { StreamEvent } from './agents/stream-parser.js';\n9\timport {\n10\t  App,\n11\t  type SprintInfo,\n12\t  type CompletedToolEntry,\n13\t  type RetryInfo,\n14\t  type RendererState,\n15\t  type StoryStatusEntry,\n16\t  type StoryMessage,\n17\t  type TaskNodeState,\n18\t  type TaskNodeMeta,\n19\t} from './ink-components.js';\n20\timport type { FlowStep } from './workflow-parser.js';\n21\t\n22\t// --- Public Types ---\n23\t\n24\texport interface RendererOptions {\n25\t  quiet?: boolean;\n26\t  sprintState?: SprintInfo;\n27\t  /** @internal Force TTY mode for testing. Not part of the public API. */\n28\t  _forceTTY?: boolean;\n29\t}\n30\t\n31\texport interface RendererHandle {\n32\t  update(event: StreamEvent, driverName?: string): void;\n33\t  updateSprintState(state: SprintInfo | undefined): void;\n34\t  updateStories(stories: StoryStatusEntry[]): void;\n35\t  addMessage(msg: StoryMessage): void;\n36\t  updateWorkflowState(flow: FlowStep[], currentTask: string | null, taskStates: Record<string, TaskNodeState>, taskMeta?: Record<string, TaskNodeMeta>): void;\n37\t  cleanup(): void;\n38\t}\n39\t\n40\t// --- No-op handle for quiet mode ---\n41\t\n42\tconst noopHandle: RendererHandle = {\n43\t  update(_event: StreamEvent, _driverName?: string) {},\n44\t  updateSprintState() {},\n45\t  updateStories() {},\n46\t  addMessage() {},\n47\t  updateWorkflowState() {},\n48\t  cleanup() {},\n49\t};\n50\t\n51\t/** Maximum number of completed tools to retain in the display list. */\n52\tconst MAX_COMPLETED_TOOLS = 50;\n53\t\n54\t// --- Controller ---\n55\t\n56\t/**\n57\t * Start the Ink terminal renderer.\n58\t *\n59\t * If `quiet` is true or stdout is not a TTY, returns a no-op handle\n60\t * (no Ink instance created).\n61\t * Otherwise, mounts the component tree and returns a handle for feeding events.\n62\t */\n63\texport function startRenderer(options?: RendererOptions): RendererHandle {\n64\t  if (options?.quiet || (!process.stdout.isTTY && !options?._forceTTY)) {\n65\t    return noopHandle;\n66\t  }\n67\t\n68\t  // Mutable state that drives re-renders\n69\t  let state: RendererState = {\n70\t    sprintInfo: options?.sprintState ?? null,\n71\t    stories: [],\n72\t    messages: [],\n73\t    completedTools: [],\n74\t    activeTool: null,\n75\t    activeToolArgs: '',\n76\t    lastThought: null,\n77\t    retryInfo: null,\n78\t    workflowFlow: [],\n79\t    currentTaskName: null,\n80\t    taskStates: {},\n81\t    taskMeta: {},\n82\t    activeDriverName: null,\n83\t    driverCosts: {},\n84\t  };\n85\t\n86\t  // Per-story cost tracking (not part of RendererState — internal to controller)\n87\t  let currentStoryCosts: Record<string, number> = {};\n88\t  let lastStoryKey: string | null = null;\n89\t\n90\t  let cleaned = false;\n91\t\n92\t  // Mount Ink with performance options\n93\t  const inkInstance = inkRender(<App state={state} />, {\n94\t    exitOnCtrlC: false,\n95\t    patchConsole: !options?._forceTTY,\n96\t    maxFps: 15,\n97\t  });\n98\t\n99\t  function rerender() {\n100\t    if (!cleaned) {\n101\t      // Create a new state object reference to trigger React re-render\n102\t      state = { ...state };\n103\t      inkInstance.rerender(<App state={state} />);\n104\t    }\n105\t  }\n106\t\n107\t  function cleanup() {\n108\t    if (cleaned) return;\n109\t    cleaned = true;\n110\t    try {\n111\t      inkInstance.unmount();\n112\t    } catch {\n113\t      // Ignore — may already be unmounted\n114\t    }\n115\t    try {\n116\t      inkInstance.cleanup();\n117\t    } catch {\n118\t      // Ignore\n119\t    }\n120\t    // Remove our signal handlers\n121\t    process.removeListener('SIGINT', onSigint);\n122\t    process.removeListener('SIGTERM', onSigterm);\n123\t  }\n124\t\n125\t  function onSigint() {\n126\t    cleanup();\n127\t    // Re-raise signal so the default handler runs (allows caller to handle exit)\n128\t    process.kill(process.pid, 'SIGINT');\n129\t  }\n130\t\n131\t  function onSigterm() {\n132\t    cleanup();\n133\t    process.kill(process.pid, 'SIGTERM');\n134\t  }\n135\t\n136\t  // Register signal handlers\n137\t  process.on('SIGINT', onSigint);\n138\t  process.on('SIGTERM', onSigterm);\n139\t\n140\t  function update(event: StreamEvent, driverName?: string): void {\n141\t    if (cleaned) return;\n142\t\n143\t    switch (event.type) {\n144\t      case 'tool-start':\n145\t        // If a long-running tool was still active, promote it to completed now\n146\t        if (state.activeTool) {\n147\t          const entry: CompletedToolEntry = {\n148\t            name: state.activeTool.name,\n149\t            args: state.activeToolArgs,\n150\t            driver: state.activeDriverName ?? undefined,\n151\t          };\n152\t          const updated = [...state.completedTools, entry];\n153\t          state.completedTools = updated.length > MAX_COMPLETED_TOOLS\n154\t            ? updated.slice(updated.length - MAX_COMPLETED_TOOLS)\n155\t            : updated;\n156\t        }\n157\t        state.activeTool = { name: event.name };\n158\t        state.activeToolArgs = '';\n159\t        state.activeDriverName = driverName ?? null;\n160\t        state.lastThought = null;\n161\t        state.retryInfo = null;\n162\t        break;\n163\t\n164\t      case 'tool-input':\n165\t        state.activeToolArgs += event.partial;\n166\t        return; // Skip rerender — args only shown on completion\n167\t\n168\t      case 'tool-complete':\n169\t        // CRITICAL: Only promote if there's an active tool.\n170\t        // The parser emits tool-complete for ALL content_block_stop events\n171\t        // (both tool and text blocks). Ignore if no activeTool is set.\n172\t        if (state.activeTool) {\n173\t          // Long-running tools (Agent, Skill) get content_block_stop when their\n174\t          // INPUT is complete, not when they finish executing. Keep them active\n175\t          // so the spinner shows during the entire execution. They'll be promoted\n176\t          // when the next tool-start fires (below in tool-start case).\n177\t          const LONG_RUNNING_TOOLS = ['Agent', 'Skill'];\n178\t          if (LONG_RUNNING_TOOLS.includes(state.activeTool.name)) {\n179\t            break; // Keep as active — don't promote to completed yet\n180\t          }\n181\t          const entry: CompletedToolEntry = {\n182\t            name: state.activeTool.name,\n183\t            args: state.activeToolArgs,\n184\t            driver: state.activeDriverName ?? undefined,\n185\t          };\n186\t          const updated = [...state.completedTools, entry];\n187\t          // Bound the list to prevent unbounded memory growth in long sessions\n188\t          state.completedTools = updated.length > MAX_COMPLETED_TOOLS\n189\t            ? updated.slice(updated.length - MAX_COMPLETED_TOOLS)\n190\t            : updated;\n191\t          state.activeTool = null;\n192\t          state.activeToolArgs = '';\n193\t          state.activeDriverName = null;\n194\t        }\n195\t        break;\n196\t\n197\t      case 'text':\n198\t        state.lastThought = event.text;\n199\t        state.retryInfo = null;\n200\t        break;\n201\t\n202\t      case 'retry':\n203\t        state.retryInfo = { attempt: event.attempt, delay: event.delay };\n204\t        break;\n205\t\n206\t      case 'result':\n207\t        // Accumulate cost from result events (AC #7)\n208\t        if (event.cost > 0 && state.sprintInfo) {\n209\t          state.sprintInfo = {\n210\t            ...state.sprintInfo,\n211\t            totalCost: (state.sprintInfo.totalCost ?? 0) + event.cost,\n212\t          };\n213\t        }\n214\t        // Accumulate per-driver cost (run-level)\n215\t        if (event.cost > 0 && driverName) {\n216\t          state.driverCosts = {\n217\t            ...state.driverCosts,\n218\t            [driverName]: (state.driverCosts[driverName] ?? 0) + event.cost,\n219\t          };\n220\t          // Accumulate per-story cost\n221\t          currentStoryCosts = {\n222\t            ...currentStoryCosts,\n223\t            [driverName]: (currentStoryCosts[driverName] ?? 0) + event.cost,\n224\t          };\n225\t        }\n226\t        break;\n227\t    }\n228\t\n229\t    rerender();\n230\t  }\n231\t\n232\t  function updateSprintState(sprintState: SprintInfo | undefined): void {\n233\t    if (cleaned) return;\n234\t    if (sprintState && state.sprintInfo) {\n235\t      // Preserve accumulated fields (totalCost, acProgress, currentCommand)\n236\t      // that are set by event handlers but not by the polling caller.\n237\t      state.sprintInfo = {\n238\t        ...sprintState,\n239\t        totalCost: sprintState.totalCost ?? state.sprintInfo.totalCost,\n240\t        acProgress: sprintState.acProgress ?? state.sprintInfo.acProgress,\n241\t        currentCommand: sprintState.currentCommand ?? state.sprintInfo.currentCommand,\n242\t      };\n243\t    } else {\n244\t      state.sprintInfo = sprintState ?? null;\n245\t    }\n246\t\n247\t    // Track story key changes for per-story cost reset\n248\t    const newKey = state.sprintInfo?.storyKey ?? null;\n249\t    if (newKey && newKey !== lastStoryKey) {\n250\t      currentStoryCosts = {};\n251\t      lastStoryKey = newKey;\n252\t    }\n253\t\n254\t    rerender();\n255\t  }\n256\t\n257\t  function updateStories(stories: StoryStatusEntry[]): void {\n258\t    if (cleaned) return;\n259\t    const currentKey = state.sprintInfo?.storyKey ?? null;\n260\t    // Snapshot per-story costs onto stories transitioning to done\n261\t    const hasCosts = Object.keys(currentStoryCosts).length > 0;\n262\t    if (hasCosts) {\n263\t      const targetKey = currentKey ?? lastStoryKey;\n264\t      for (const s of stories) {\n265\t        if (s.key === targetKey && s.status === 'done' && !s.costByDriver) {\n266\t          s.costByDriver = { ...currentStoryCosts };\n267\t          currentStoryCosts = {};\n268\t          break;\n269\t        }\n270\t      }\n271\t    }\n272\t    if (currentKey && currentKey !== lastStoryKey) {\n273\t      currentStoryCosts = {};\n274\t      lastStoryKey = currentKey;\n275\t    }\n276\t    state.stories = [...stories];\n277\t    rerender();\n278\t  }\n279\t\n280\t  function addMessage(msg: StoryMessage): void {\n281\t    if (cleaned) return;\n282\t    state.messages = [...state.messages, msg];\n283\t    rerender();\n284\t  }\n285\t\n286\t  function updateWorkflowState(flow: FlowStep[], currentTask: string | null, taskStates: Record<string, TaskNodeState>, taskMeta?: Record<string, TaskNodeMeta>): void {\n287\t    if (cleaned) return;\n288\t    state.workflowFlow = flow;\n289\t    state.currentTaskName = currentTask;\n290\t    state.taskStates = { ...taskStates };\n291\t    state.taskMeta = taskMeta ? { ...taskMeta } : state.taskMeta;\n292\t    rerender();\n293\t  }\n294\t\n295\t  return { update, updateSprintState, updateStories, addMessage, updateWorkflowState, cleanup };\n296\t}\n297\t\n298\t// Re-export types that consumers may need\n299\texport type { SprintInfo, CompletedToolEntry, RetryInfo, RendererState, StoryStatusEntry, StoryStatusValue, StoryMessage, TaskNodeState, TaskNodeMeta } from './ink-components.js';\n300\t"}]},"parent_tool_use_id":"toolu_01FXbxFTW7bzJr4gL7DWdcAa","session_id":"a0646c12-93c6-41a0-9c7a-50683cae7716","uuid":"3ec3aa1d-67ac-4725-b7dd-e5bb8f9bc9d9","timestamp":"2026-04-03T13:00:54.428Z"}
