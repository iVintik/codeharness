{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FDV8ePo4VqarSWoes1oTYb","type":"tool_result","content":"420\t    }\n421\t\n422\t    // Check if branch already exists\n423\t    const existingBranch = this.findBranchForEpic(epicId);\n424\t    if (existingBranch) {\n425\t      try {\n426\t        this.execGit(`git branch -D ${existingBranch}`);\n427\t      } catch { // IGNORE: stale branch deletion is best-effort before re-create per AC #9\n428\t      }\n429\t    }\n430\t  }\n431\t\n432\t  /**\n433\t   * Clean up partial state after a failed createWorktree (AC #10).\n434\t   */\n435\t  private cleanupPartial(branchCreated: boolean, branchName: string, worktreePath: string): void {\n436\t    // Try to remove worktree if it was partially created\n437\t    try {\n438\t      this.execGit(`git worktree remove ${worktreePath} --force`);\n439\t    } catch { // IGNORE: partial worktree may not exist during failure cleanup per AC #10\n440\t    }\n441\t\n442\t    // Delete branch if it was created\n443\t    if (branchCreated) {\n444\t      try {\n445\t        this.execGit(`git branch -D ${branchName}`);\n446\t      } catch { // IGNORE: partial branch may not exist during failure cleanup per AC #10\n447\t      }\n448\t    }\n449\t  }\n450\t\n451\t  /**\n452\t   * Find a branch matching `codeharness/epic-{epicId}-*`.\n453\t   */\n454\t  private findBranchForEpic(epicId: string): string | undefined {\n455\t    try {\n456\t      const output = this.execGit(`git branch --list ${BRANCH_PREFIX}${epicId}-*`);\n457\t      const branches = output\n458\t        .split('\\n')\n459\t        .map((b) => b.trim().replace(/^\\*\\s*/, ''))\n460\t        .filter((b) => b.length > 0);\n461\t      return branches[0];\n462\t    } catch { // IGNORE: branch listing failure means no branch exists — safe to return undefined\n463\t      return undefined;\n464\t    }\n465\t  }\n466\t\n467\t  /**\n468\t   * Parse `git worktree list --porcelain` output into structured entries.\n469\t   */\n470\t  private parsePorcelainOutput(output: string): Array<{ path: string; branch: string }> {\n471\t    if (!output.trim()) return [];\n472\t\n473\t    const blocks = output.split('\\n\\n').filter((b) => b.trim());\n474\t    const entries: Array<{ path: string; branch: string }> = [];\n475\t\n476\t    for (const block of blocks) {\n477\t      const lines = block.split('\\n');\n478\t      let path = '';\n479\t      let branch = '';\n480\t\n481\t      for (const line of lines) {\n482\t        if (line.startsWith('worktree ')) {\n483\t          path = line.slice('worktree '.length);\n484\t        } else if (line.startsWith('branch ')) {\n485\t          branch = line.slice('branch '.length);\n486\t        }\n487\t      }\n488\t\n489\t      if (path && branch) {\n490\t        entries.push({ path, branch });\n491\t      }\n492\t    }\n493\t\n494\t    return entries;\n495\t  }\n496\t\n497\t  /**\n498\t   * Extract epicId from a branch name like `codeharness/epic-17-slug`.\n499\t   */\n500\t  private extractEpicId(branchName: string): string {\n501\t    const withoutPrefix = branchName.slice(BRANCH_PREFIX.length);\n502\t    const dashIndex = withoutPrefix.indexOf('-');\n503\t    if (dashIndex === -1) return withoutPrefix;\n504\t    return withoutPrefix.slice(0, dashIndex);\n505\t  }\n506\t\n507\t  /**\n508\t   * Check if a worktree is orphaned (no active codeharness process).\n509\t   */\n510\t  private isOrphaned(wt: WorktreeInfo): boolean {\n511\t    const laneStatePath = join(wt.path, '.codeharness', 'lane-state.json');\n512\t\n513\t    if (!existsSync(laneStatePath)) {\n514\t      return true;\n515\t    }\n516\t\n517\t    try {\n518\t      const content = readFileSync(laneStatePath, 'utf-8');\n519\t      const state = JSON.parse(content) as { pid?: number };\n520\t\n521\t      if (!state.pid) {\n522\t        return true;\n523\t      }\n524\t\n525\t      // Check if the PID is still running\n526\t      try {\n527\t        process.kill(state.pid, 0);\n528\t        return false; // Process is alive — not orphaned\n529\t      } catch { // IGNORE: ESRCH means process is dead — worktree is orphaned per AC #8\n530\t        return true;\n531\t      }\n532\t    } catch { // IGNORE: unreadable/corrupt lane-state.json means orphaned per AC #8\n533\t      return true;\n534\t    }\n535\t  }\n536\t}\n537\t"}]},"parent_tool_use_id":"toolu_01WUKKW3Fq3oqhMn79vnXB8N","session_id":"80ecde4e-3ccc-44de-925d-a2036bf845d1","uuid":"8c78b331-48d9-4a37-9f7c-e5aa7a847699","timestamp":"2026-04-03T21:18:59.043Z"}
