kImplementation(() => {\n   244→      throw new Error(longStderr);\n   245→    });\n   246→    const result = installRustOtlp(testDir);\n   247→    expect(result.error).toBeDefined();\n   248→    expect(result.error!.length).toBeLessThan(500);\n   249→    expect(result.error).toContain('(truncated)');\n   250→  });\n   251→\n   252→  it('includes all four Rust OTLP packages in cargo add command', () => {\n   253→    mockExecFileSync.mockReturnValue(Buffer.from(''));\n   254→    mockExecFileSync.mockClear();\n   255→    installRustOtlp(testDir);\n   256→    const args = mockExecFileSync.mock.calls[0][1] as string[];\n   257→    expect(args).toContain('opentelemetry');\n   258→    expect(args).toContain('opentelemetry-otlp');\n   259→    expect(args).toContain('tracing-opentelemetry');\n   260→    expect(args).toContain('tracing-subscriber');\n   261→  });\n   262→});\n   263→\n   264→describe('configureOtlpEnvVars', () => {\n   265→  it('writes OTLP config for Node.js to state', () => {\n   266→    initState('nodejs');\n   267→\n   268→    configureOtlpEnvVars(testDir, 'nodejs');\n   269→\n   270→    const state = readState(testDir);\n   271→    expect(state.otlp).toBeDefined();\n   272→    expect(state.otlp!.enabled).toBe(true);\n   273→    expect(state.otlp!.endpoint).toBe('http://localhost:4318');\n   274→    expect(state.otlp!.service_name).toBeTruthy();\n   275→    expect(state.otlp!.node_require).toContain('--require');\n   276→  });\n   277→\n   278→  it('writes OTLP config for Python to state', () => {\n   279→    initState('python');\n   280→\n   281→    configureOtlpEnvVars(testDir, 'python');\n   282→\n   283→    const state = readState(testDir);\n   284→    expect(state.otlp).toBeDefined();\n   285→    expect(state.otlp!.enabled).toBe(true);\n   286→    expect(state.otlp!.python_wrapper).toBe('opentelemetry-instrument');\n   287→    expect(state.otlp!.node_require).toBeUndefined();\n   288→  });\n   289→\n   290→  it('writes OTLP config for Rust with rust