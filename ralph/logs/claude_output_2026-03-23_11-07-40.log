xistsSync(join(workspace, '.git'))).toBe(false);\n   415в†’    expect(existsSync(join(workspace, 'node_modules'))).toBe(false);\n   416в†’\n   417в†’    // Cleanup\n   418в†’    rmSync(workspace, { recursive: true, force: true });\n   419в†’  });\n   420в†’\n   421в†’  it('throws on invalid story key', () => {\n   422в†’    expect(() => prepareVerifyWorkspace('../etc/passwd', testDir)).toThrow('Invalid story key');\n   423в†’  });\n   424в†’\n   425в†’  it('throws when story file does not exist', () => {\n   426в†’    expect(() => prepareVerifyWorkspace('nonexistent-story', testDir)).toThrow('Story file not found');\n   427в†’  });\n   428в†’\n   429в†’  it('handles missing README.md gracefully', () => {\n   430в†’    const storyDir = join(testDir, '_bmad-output', 'implementation-artifacts');\n   431в†’    mkdirSync(storyDir, { recursive: true });\n   432в†’    writeFileSync(join(storyDir, 'no-readme-story.md'), '# Story');\n   433в†’\n   434в†’    const workspace = prepareVerifyWorkspace('no-readme-story', testDir);\n   435в†’    expect(existsSync(join(workspace, 'story.md'))).toBe(true);\n   436в†’    expect(existsSync(join(workspace, 'README.md'))).toBe(false);\n   437в†’\n   438в†’    // Cleanup\n   439в†’    rmSync(workspace, { recursive: true, force: true });\n   440в†’  });\n   441в†’\n   442в†’  it('handles missing docs/ gracefully', () => {\n   443в†’    const storyDir = join(testDir, '_bmad-output', 'implementation-artifacts');\n   444в†’    mkdirSync(storyDir, { recursive: true });\n   445в†’    writeFileSync(join(storyDir, 'no-docs-story.md'), '# Story');\n   446в†’\n   447в†’    const workspace = prepareVerifyWorkspace('no-docs-story', testDir);\n   448в†’    expect(existsSync(join(workspace, 'story.md'))).toBe(true);\n   449в†’    expect(existsSync(join(workspace, 'docs'))).toBe(false);\n   450в†’\n   451в†’    // Cleanup\n   452в†’    rmSync(workspace, { recursive: true, force: true });\n   453в†’  });\n   454в†’\n   455в†’  it('replaces existing workspace', () => {\n   456в†’    const storyDir = join(testDir, '_bmad-output', 'implementation-artifacts');\n   457в†’    mkdirSync(storyDir, { recursive: true });\n   458в†’    writeFileSync(join(storyDir, 'replace-story.md'), '# Story');\n   459в†’\n   460в†’    const workspace1 = prepareVerifyWorkspace('replace-story', testDir);\n   461в†’    writeFileSync(join(workspace1, 'old-file.txt'), 'old');\n   462в†’\n   463в†’    const workspace2 = prepareVerifyWorkspace('replace-story', testDir);\n   464в†’    expect(workspace1).toBe(workspace2);\n   465в†’    expect(existsSync(join(workspace2, 'old-file.txt'))).toBe(false);\n   466в†’\n   467в†’    // Cleanup\n   468в†’    rmSync(workspace2, { recursive: true, force: true });\n   469в†’  });\n   470в†’});\n   471в†’\n   472в†’// в”Ђв”Ђв”Ђ checkVerifyEnv в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n   473в†’\n   474в†’describe('checkVerifyEnv', () => {\n   475в†’  it('returns all false when image does not exist', () => {\n   476в†’    mockExecFileSync.mockImplementation(() => {\n   477в†’      throw new Error('No such image');\n   478в†’    });\n   479в†’\n   480в†’    const result = checkVerifyEnv();\n   481в†’    expect(result.imageExists).toBe(false);\n   482в†’    expect(result.cliWorks).toBe(false);\n   483в†’    expect(result.otelReachable).toBe(false);\n   484в†’  });\n   485в†’\n   486в†’  it('returns imageExists=true, cliWorks=true, otelReachable=false when otel fails', () => {\n   487в†’    let runCallCount = 0;\n   488в†’    mockExecFileSync.mockImplementation((_cmd: unknown, args: unknown) => {\n   489в†’      const argArr = args as string[];\n   490в†’      // image inspect succeeds\n   491в†’      if (argArr.includes('inspect') && argArr.includes('codeharness-verify')) {\n   492в†’        return Buffer.from('[{\"Id\":\"abc\"}]');\n   493в†’      }\n   494в†’      // docker run --rm codeharness-verify codeharness --help succeeds (first run call)\n   495в†’      if (argArr.includes('run') && argArr.includes('--help')) {\n   496в†’        runCallCount++;\n   497в†’        if (runCallCount === 1) {\n   498в†’          return Buffer.from('Usage: codeharness');\n   499в†’        }\n   500в†’      }\n   501в†’      // curl to otel fails (second docker run call)\n   502в†’      if (argArr.includes('run') && argArr.includes('curl')) {\n   503в†’        throw new Error('curl failed');\n   504в†’      }\n   505в†’      return Buffer.from('');\n   506в†’    });\n   507в†’\n   508в†’    const result = checkVerifyEnv();\n   509в†’    expect(result.imageExists).toBe(true);\n   510в†’    expect(result.cliWorks).toBe(true);\n   511в†’    expect(result.otelReachable).toBe(false);\n   512в†’  });\n   513в†’\n   514в†’  it('returns all true when everything succeeds', () => {\n   515в†’    mockExecFileSync.mockReturnValue(Buffer.from('ok'));\n   516в†’\n   517в†’    const result = checkVerifyEnv();\n   518в†’    expect(result.imageExists).toBe(true);\n   519в†’    expect(result.cliWorks).toBe(true);\n   520в†’    expect(result.otelReachable).toBe(true);\n   521в†’  });\n   522в†’\n   523в†’  it('returns cliWorks=false when docker run fails (broken CLI inside container)', () => {\n   524в†’    mockExecFileSync.mockImplementation((_cmd: unknown, args: unknown) => {\n   525в†’      const argArr = args as string[];\n   526в†’      // image inspect succeeds\n   527в†’      if (argArr.includes('inspect') && argArr.includes('codeharness-verify')) {\n   528в†’        return Buffer.from('[{\"Id\":\"abc\"}]');\n   529в†’      }\n   530в†’      // docker run --rm fails вЂ” CLI broken or missing inside image\n   531в†’      if (argArr.includes('run') && argArr.includes('--help')) {\n   532в†’        throw new Error('command not found');\n   533в†’      }\n   534в†’      // otel check вЂ” won't reach this since cliWorks failure doesn't short-circuit\n   535в†’      return Buffer.from('ok');\n   536в†’    });\n   537в†’\n   538в†’    const result = checkVerifyEnv();\n   539в†’    expect(result.imageExists).toBe(true);\n   540в†’    expect(result.cliWorks).toBe(false);\n   541в†’  });\n   542в†’});\n   543в†’\n   544в†’// в”Ђв”Ђв”Ђ cleanupVerifyEnv в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n   545в†’\n   546в†’describe('cleanupVerifyEnv', () => {\n   547в†’  it('throws on invalid story key', () => {\n   548в†’    expect(() => cleanupVerifyEnv('../etc/passwd')).toThrow('Invalid story key');\n   549в†’  });\n   550в†’\n   551в†’  it('is idempotent when workspace does not exist', () => {\n   552в†’    mockExecFileSync.mockImplementation(() => {\n   553в†’      throw new Error('No such container');\n   554в†’    });\n   555в†’\n   556в†’    // Should not throw\n   557в†’    cleanupVerifyEnv('nonexistent-story');\n   558в†’  });\n   559в†’\n   560в†’  it('removes workspace if it exists', () => {\n   561в†’    const workspace = `/tmp/codeharness-verify-cleanup-test-ws`;\n   562в†’    mkdirSync(workspace, { recursive: true });\n   563в†’    writeFileSync(join(workspace, 'test.txt'), 'test');\n   564в†’\n   565в†’    mockExecFileSync.mockImplementation(() => {\n   566в†’      throw new Error('No such container');\n   567в†’    });\n   568в†’\n   569в†’    cleanupVerifyEnv('cleanup-test-ws');\n   570в†’    expect(existsSync(workspace)).toBe(false);\n   571в†’  });\n   572в†’\n   573в†’  it('calls docker stop and docker rm', () => {\n   574в†’    mockExecFileSync.mockReturnValue(Buffer.from(''));\n   575в†’\n   576в†’    cleanupVerifyEnv('my-story');\n   577в†’\n   578в†’    const calls = mockExecFileSync.mock.calls;\n   579в†’    const stopCall = calls.find(c => (c[1] as string[]).includes('stop'));\n   580в†’    const rmCall = calls.find(c => (c[1] as string[]).includes('rm'));\n   581в†’\n   582в†’    expect(stopCall).toBeDefined();\n   583в†’    expect((stopCall![1] as string[])).toContain('codeharness-verify-my-story');\n   584в†’    expect(rmCall).toBeDefined();\n   585в†’    expect((rmCall![1] as string[])).toContain('codeharness-verify-my-story');\n   586в†’  });\n   587в†’});\n   588в†’\n   589в†’// в”Ђв”Ђв”Ђ cleanupStaleContainers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n   590в†’\n   591в†’describe('cleanupStaleContainers', () => {\n   592в†’  it('removes all matching containers', () => {\n   593в†’    mockExecFileSync.mockImplementation((_cmd: unknown, args: unknown) => {\n   594в†’      const argArr = args as string[];\n   595в†’      if (argArr.includes('ps')) {\n   596в†’        return Buffer.from('codeharness-verify-story-1\\ncodeharness-verify-story-2\\n');\n   597в†’      }\n   598в†’      // docker rm -f succeeds\n   599в†’      return Buffer.from('');\n   600в†’    });\n   601в†’\n   602в†’    cleanupStaleContainers();\n   603в†’\n   604в†’    const rmCalls = mockExecFileSync.mock.calls.filter(\n   605в†’      c => (c[1] as string[]).includes('rm'),\n   606в†’    );\n   607в†’    expect(rmCalls.length).toBe(2);\n   608в†’    expect((rmCalls[0][1] as string[])).toContain('codeharness-verify-story-1');\n   609в†’    expect((rmCalls[1][1] as string[])).toContain('codeharness-verify-story-2');\n   610в†’  });\n   611в†’\n   612в†’  it('handles no containers gracefully', () => {\n   613в†’    mockExecFileSync.mockReturnValue(Buffer.from(''));\n   614в†’\n   615в†’    // Should not throw\n   616в†’    cleanupStaleContainers();\n   617в†’  });\n   618в†’\n   619в†’  it('handles docker not available gracefully', () => {\n   620в†’    mockExecFileSync.mockImplementation(() => {\n   621в†’      throw new Error('Docker not available');\n   622в†’    });\n   623в†’\n   624в†’    // Should not throw\n   625в†’    cleanupStaleContainers();\n   626в†’  });\n   627в†’\n   628в†’  it('continues removing other containers if one rm fails', () => {\n   629в†’    let rmCallCount = 0;\n   630в†’    mockExecFileSync.mockImplementation((_cmd: unknown, args: unknown) => {\n   631в†’      const argArr = args as string[];\n   632в†’      if (argArr.includes('ps')) {\n   633в†’        return Buffer.from('codeharness-verify-a\\ncodeharness-verify-b\\n');\n   634в†’      }\n   635в†’      if (argArr.includes('rm')) {\n   636в†’        rmCallCount++;\n   637в†’        if (rmCallCount === 1) throw new Error('container busy');\n   638в†’        return Buffer.from('');\n   639в†’      }\n   640в†’      return Buffer.from('');\n   641в†’    });\n   642в†’\n   643в†’    cleanupStaleContainers();\n   644в†’    expect(rmCallCount).toBe(2); // Both attempted\n   645в†’  });\n   646в†’});\n   647в†’\n   648в†’// в”Ђв”Ђв”Ђ detectProjectType в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n   649в†’\n   650в†’describe('detectProjectType', () => {\n   651в†’  it('returns plugin when .claude-plugin/plugin.json exists and stack is unknown', () => {\n   652в†’    mockDetectStack.mockReturnValue(null);\n   653в†’    mkdirSync(join(testDir, '.claude-plugin'), { recursive: true });\n   654в†’    writeFileSync(join(testDir, '.claude-plugin', 'plugin.json'), '{}');\n   655в†’    expect(detectProjectType(testDir)).toBe('plugin');\n   656в†’  });\n   657в†’\n   658в†’  it('returns nodejs when detectStack returns nodejs', () => {\n   659в†’    mockDetectStack.mockReturnValue('nodejs');\n   660в†’    expect(detectProjectType(testDir)).toBe('nodejs');\n   661в†’  });\n   662в†’\n   663в†’  it('returns python when detectStack returns python', () => {\n   664в†’    mockDetectStack.mockReturnValue('python');\n   665в†’    expect(detectProjectType(testDir)).toBe('python');\n   666в†’  });\n   667в†’\n   668в†’  it('returns generic when detectStack returns null', () => {\n   669в†’    mockDetectStack.mockReturnValue(null);\n   670в†’    expect(detectProjectType(testDir)).toBe('generic');\n   671в†’  });\n   672в†’\n   673в†’  it('returns rust when detectStack returns rust', () => {\n   674в†’    mockDetectStack.mockReturnValue('rust' as ReturnType<typeof detectStack>);\n   675в†’    expect(detectProjectType(testDir)).toBe('rust');\n   676в†’  });\n   677в†’\n   678в†’  it('prioritizes nodejs over plugin when both exist', () => {\n   679в†’    mkdirSync(join(testDir, '.claude-plugin'), { recursive: true });\n   680в†’    writeFileSync(join(testDir, '.claude-plugin', 'plugin.json'), '{}');\n   681в†’    mockDetectStack.mockReturnValue('nodejs');\n   682в†’    expect(detectProjectType(testDir)).toBe('nodejs');\n   683в†’  });\n   684в†’});\n   685в†’\n   686в†’// в”Ђв”Ђв”Ђ buildVerifyImage вЂ” plugin and generic paths в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n   687в†’\n   688в†’describe('buildVerifyImage вЂ” plugin project (AC #2)', () => {\n   689в†’  it('builds plugin image when .claude-plugin/plugin.json exists and stack is unknown', () => {\n   690в†’    mockDetectStack.mockReturnValue(null);\n   691в†’    mkdirSync(join(testDir, '.claude-plugin'), { recursive: true });\n   692в†’    writeFileSync(join(testDir, '.claude-plugin', 'plugin.json'), '{\"name\":\"test\"}');\n   693в†’    mkdirSync(join(testDir, 'commands'), { recursive: true });\n   694в†’    writeFileSync(join(testDir, 'commands', 'test.md'), '# Test command');\n   695в†’\n   696в†’    mockExecFileSync\n   697в†’      .mockReturnValueOnce(Buffer.from('')) // docker build\n   698в†’      .mockReturnValueOnce(Buffer.from('80000000')); // docker image inspect (size)\n   699в†’\n   700в†’    const result = buildVerifyImage({ projectDir: testDir });\n   701в†’    expect(result.cached).toBe(false);\n   702в†’    expect(result.imageTag).toBe('codeharness-verify');\n   703в†’\n   704в†’    const buildCall = mockExecFileSync.mock.calls.find(\n   705в†’      c => (c[1] as string[]).includes('build'),\n   706в†’    );\n   707в†’    expect(buildCall).toBeDefined();\n   708в†’  });\n   709в†’\n   710в†’  it('does not throw for plugin projects without dist/', () => {\n   711в†’    mockDetectStack.mockReturnValue(null);\n   712в†’    mkdirSync(join(testDir, '.claude-plugin'), { recursive: true });\n   713в†’    writeFileSync(join(testDir, '.claude-plugin', 'plugin.json'), '{}');\n   714в†’\n   715в†’    mockExecFileSync\n   716в†’      .mockReturnValueOnce(Buffer.from('')) // docker build\n   717в†’      .mockReturnValueOnce(Buffer.from('50000000')); // docker image inspect (size)\n   718в†’\n   719в†’    expect(() => buildVerifyImage({ projectDir: testDir })).not.toThrow();\n   720в†’  });\n   721в†’});\n   722в†’\n   723в†’// в”Ђв”Ђв”Ђ buildVerifyImage вЂ” Rust project (AC #3, #4, #5, #6) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n   724в†’\n   725в†’describe('buildVerifyImage вЂ” Rust project', () => {\n   726в†’  it('builds Rust image when detectStack returns rust (AC #4)', () => {\n   727в†’    mockDetectStack.mockReturnValue('rust' as ReturnType<typeof detectStack>);\n   728в†’    writeFileSync(join(testDir, 'templates', 'Dockerfile.verify.rust'), 'FROM rust:1.82-slim\\n');\n   729в†’\n   730в†’    mockExecFileSync\n   731в†’      .mockReturnValueOnce(Buffer.from('')) // docker build\n   732в†’      .mockReturnValueOnce(Buffer.from('150000000')); // docker image inspect (size)\n   733в†’\n   734в†’    const result = buildVerifyImage({ projectDir: testDir });\n   735в†’    expect(result.cached).toBe(false);\n   736в†’    expect(result.imageTag).toBe('codeharness-verify');\n   737в†’\n   738в†’    const buildCall = mockExecFileSync.mock.calls.find(\n   739в†’      c => (c[1] as string[]).includes('build'),\n   740в†’    );\n   741в†’    expect(buildCall).toBeDefined();\n   742в†’    // Rust build should NOT have --build-arg TARBALL (no tarball for Rust)\n   743в†’    expect(