{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Kg78hLsZngR3yCaVnexuJN","type":"tool_result","content":"     1→/**\n     2→ * Dockerfile validator — checks Dockerfiles against 6 required rule categories.\n     3→ * Returns structured gaps for audit integration.\n     4→ *\n     5→ * FR23 (formalized Dockerfile rules), FR24 (audit validates against rules).\n     6→ */\n     7→\n     8→import { existsSync, readFileSync } from 'node:fs';\n     9→import { join } from 'node:path';\n    10→import { ok, fail } from '../../types/result.js';\n    11→import type { Result } from '../../types/result.js';\n    12→\n    13→/** A single gap found during Dockerfile validation */\n    14→export interface DockerfileGap {\n    15→  readonly rule: string;\n    16→  readonly description: string;\n    17→  readonly suggestedFix: string;\n    18→  readonly line?: number;\n    19→}\n    20→\n    21→/** Result of validating a Dockerfile against all rules */\n    22→export interface DockerfileValidationResult {\n    23→  readonly passed: boolean;\n    24→  readonly gaps: DockerfileGap[];\n    25→  readonly warnings: string[];\n    26→}\n    27→\n    28→/** Internal rules structure */\n    29→interface DockerfileRules {\n    30→  readonly requirePinnedFrom: boolean;\n    31→  readonly requireBinaryOnPath: boolean;\n    32→  readonly verificationTools: string[];\n    33→  readonly forbidSourceCopy: boolean;\n    34→  readonly requireNonRootUser: boolean;\n    35→  readonly requireCacheCleanup: boolean;\n    36→}\n    37→\n    38→const DEFAULT_RULES: DockerfileRules = {\n    39→  requirePinnedFrom: true,\n    40→  requireBinaryOnPath: true,\n    41→  verificationTools: ['curl', 'jq'],\n    42→  forbidSourceCopy: true,\n    43→  requireNonRootUser: true,\n    44→  requireCacheCleanup: true,\n    45→};\n    46→\n    47→function dfGap(rule: string, description: string, suggestedFix: string, line?: number): DockerfileGap {\n    48→  const g: DockerfileGap = { rule, description, suggestedFix };\n    49→  if (line !== undefined) return { ...g, line };\n    50→  return g;\n    51→}\n    52→\n    53→/**\n    54→ * Load rules from patches/infra/dockerfile-rules.md or fall back to defaults.\n    55→ * The markdown is documentation — the actual rules are hardcoded defaults.\n    56→ * Returns rules + any warnings about missing file.\n    57→ */\n    58→export function loadRules(projectDir: string): { rules: DockerfileRules; warnings: string[] } {\n    59→  const rulesPath = join(projectDir, 'patches', 'infra', 'dockerfile-rules.md');\n    60→  if (!existsSync(rulesPath)) {\n    61→    return {\n    62→      rules: DEFAULT_RULES,\n    63→      warnings: ['dockerfile-rules.md not found -- using defaults.'],\n    64→    };\n    65→  }\n    66→  return { rules: DEFAULT_RULES, warnings: [] };\n    67→}\n    68→\n    69→// ─── Rule checkers ──────────────────────────────────────────────────────────\n    70→\n    71→function checkPinnedFrom(lines: string[]): DockerfileGap[] {\n    72→  const gaps: DockerfileGap[] = [];\n    73→  for (let i = 0; i < lines.length; i++) {\n    74→    if (!/^\\s*FROM\\s+/i.test(lines[i])) continue;\n    75→    const ref = lines[i].replace(/^\\s*FROM\\s+/i, '').split(/\\s+/)[0];\n    76→    if (ref.endsWith(':latest')) {\n    77→      gaps.push(dfGap('pinned-from', `unpinned base image -- use specific version.`, `Pin ${ref} to a specific version tag`, i + 1));\n    78→    } else if (!ref.includes(':') && !ref.includes('@')) {\n    79→      gaps.push(dfGap('pinned-from', `unpinned base image -- use specific version.`, `Pin ${ref} to a specific version tag (e.g., ${ref}:22-slim)`, i + 1));\n    80→    }\n    81→  }\n    82→  return gaps;\n    83→}\n    84→\n    85→function checkBinaryOnPath(lines: string[]): DockerfileGap[] {\n    86→  const content = lines.join('\\n');\n    87→  const hasBinary =\n    88→    /npm\\s+install\\s+(-g|--global)\\b/i.test(content) ||\n    89→    /pip\\s+install\\b/i.test(content) ||\n    90→    /COPY\\s+--from=/i.test(content);\n    91→  if (!hasBinary) {\n    92→    return [dfGap('binary-on-path', 'project binary not installed.', 'Add npm install -g, pip install, or COPY --from to install the project binary')];\n    93→  }\n    94→  return [];\n    95→}\n    96→\n    97→function checkVerificationTools(lines: string[], tools: string[]): DockerfileGap[] {\n    98→  const content = lines.join('\\n').toLowerCase();\n    99→  const gaps: DockerfileGap[] = [];\n   100→  for (const tool of tools) {\n   101→    const installed =\n   102→      content.includes(`apt-get install`) && content.includes(tool) ||\n   103→      content.includes(`apk add`) && content.includes(tool);\n   104→    if (!installed) {\n   105→      gaps.push(dfGap('verification-tools', `verification tool missing: ${tool}`, `Install ${tool} via apt-get install or apk add`));\n   106→    }\n   107→  }\n   108→  return gaps;\n   109→}\n   110→\n   111→function checkNoSourceCopy(lines: string[]): DockerfileGap[] {\n   112→  const gaps: DockerfileGap[] = [];\n   113→  const sourcePatterns = [/COPY\\s+src\\//i, /COPY\\s+lib\\//i, /COPY\\s+test\\//i];\n   114→  for (let i = 0; i < lines.length; i++) {\n   115→    for (const pattern of sourcePatterns) {\n   116→      if (pattern.test(lines[i])) {\n   117→        gaps.push(dfGap('no-source-copy', 'source code copied into container -- use build artifact instead.', 'Use COPY --from=builder or COPY dist/ instead of copying source', i + 1));\n   118→      }\n   119→    }\n   120→  }\n   121→  return gaps;\n   122→}\n   123→\n   124→function checkNonRootUser(lines: string[]): DockerfileGap[] {\n   125→  const userLines = lines.filter(l => /^\\s*USER\\s+/i.test(l));\n   126→  if (userLines.length === 0) {\n   127→    return [dfGap('non-root-user', 'no non-root USER instruction found.', 'Add USER <non-root-user> instruction (e.g., USER node)')];\n   128→  }\n   129→  const hasNonRoot = userLines.some(l => {\n   130→    const user = l.replace(/^\\s*USER\\s+/i, '').trim().split(/\\s+/)[0];\n   131→    return user.toLowerCase() !== 'root';\n   132→  });\n   133→  if (!hasNonRoot) {\n   134→    return [dfGap('non-root-user', 'no non-root USER instruction found.', 'Add USER <non-root-user> instruction (e.g., USER node)')];\n   135→  }\n   136→  return [];\n   137→}\n   138→\n   139→function checkCacheCleanup(lines: string[]): DockerfileGap[] {\n   140→  const content = lines.join('\\n');\n   141→  const hasCleanup =\n   142→    /rm\\s+-rf\\s+\\/var\\/lib\\/apt\\/lists/i.test(content) ||\n   143→    /npm\\s+cache\\s+clean/i.test(content) ||\n   144→    /pip\\s+cache\\s+purge/i.test(content);\n   145→  if (!hasCleanup) {\n   146→    return [dfGap('cache-cleanup', 'no cache cleanup detected.', 'Add cache cleanup: rm -rf /var/lib/apt/lists/*, npm cache clean --force, or pip cache purge')];\n   147→  }\n   148→  return [];\n   149→}\n   150→\n   151→// ─── Main validator ─────────────────────────────────────────────────────────\n   152→\n   153→/**\n   154→ * Validate a Dockerfile against all 6 rule categories.\n   155→ * Returns Result<DockerfileValidationResult>.\n   156→ */\n   157→export function validateDockerfile(projectDir: string): Result<DockerfileValidationResult> {\n   158→  const dfPath = join(projectDir, 'Dockerfile');\n   159→\n   160→  if (!existsSync(dfPath)) {\n   161→    return fail('No Dockerfile found');\n   162→  }\n   163→\n   164→  let content: string;\n   165→  try {\n   166→    content = readFileSync(dfPath, 'utf-8');\n   167→  } catch {\n   168→    return fail('Dockerfile exists but could not be read');\n   169→  }\n   170→\n   171→  const lines = content.split('\\n');\n   172→  const fromLines = lines.filter(l => /^\\s*FROM\\s+/i.test(l));\n   173→  if (fromLines.length === 0) {\n   174→    return fail('Dockerfile has no FROM instruction');\n   175→  }\n   176→\n   177→  const { rules, warnings } = loadRules(projectDir);\n   178→  const gaps: DockerfileGap[] = [];\n   179→\n   180→  if (rules.requirePinnedFrom) gaps.push(...checkPinnedFrom(lines));\n   181→  if (rules.requireBinaryOnPath) gaps.push(...checkBinaryOnPath(lines));\n   182→  gaps.push(...checkVerificationTools(lines, rules.verificationTools));\n   183→  if (rules.forbidSourceCopy) gaps.push(...checkNoSourceCopy(lines));\n   184→  if (rules.requireNonRootUser) gaps.push(...checkNonRootUser(lines));\n   185→  if (rules.requireCacheCleanup) gaps.push(...checkCacheCleanup(lines));\n   186→\n   187→  return ok({\n   188→    passed: gaps.length === 0,\n   189→    gaps,\n   190→    warnings,\n   191→  });\n   192→}\n   193→"}]},"parent_tool_use_id":"toolu_01TyVq55huB8WDwxXQnVa2vD","session_id":"d06dabce-ed3c-4abf-ad84-f2845532d39a","uuid":"10bca071-27cf-45f3-a740-9a281832c678","timestamp":"2026-03-21T05:19:09.100Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TuRwpokjcyABg895ErEjaK","type":"tool_result","content":"     1→/**\n     2→ * Audit dimension checkers — each wraps an existing module and maps\n     3→ * its output to DimensionResult. Each checker catches its own errors\n     4→ * and never throws (AC #6).\n     5→ */\n     6→\n     7→import { existsSync, readFileSync, readdirSync } from 'node:fs';\n     8→import { join } from 'node:path';\n     9→import { ok, isOk } from '../../types/result.js';\n    10→import type { Result } from '../../types/result.js';\n    11→import type { DimensionResult, AuditGap } from './types.js';\n    12→import { analyze, validateRuntime } from '../observability/index.js';\n    13→import type { AnalyzerResult, RuntimeValidationResult } from '../observability/index.js';\n    14→import { checkOnlyCoverage } from '../../lib/coverage.js';\n    15→import { scanDocHealth } from '../../lib/doc-health.js';\n    16→import { parseProof } from '../verify/index.js';\n    17→import { validateDockerfile } from '../infra/index.js';\n    18→\n    19→type Status = 'pass' | 'fail' | 'warn';\n    20→\n    21→function gap(dimension: string, description: string, suggestedFix: string): AuditGap {\n    22→  return { dimension, description, suggestedFix };\n    23→}\n    24→\n    25→function dimOk(name: string, status: Status, metric: string, gaps: AuditGap[] = []): Result<DimensionResult> {\n    26→  return ok({ name, status, metric, gaps });\n    27→}\n    28→\n    29→function dimCatch(name: string, err: unknown): Result<DimensionResult> {\n    30→  const msg = err instanceof Error ? err.message : String(err);\n    31→  return dimOk(name, 'warn', 'error', [gap(name, `${name} check failed: ${msg}`, `Check ${name} configuration`)]);\n    32→}\n    33→\n    34→function worstStatus(...statuses: Status[]): Status {\n    35→  if (statuses.includes('fail')) return 'fail';\n    36→  if (statuses.includes('warn')) return 'warn';\n    37→  return 'pass';\n    38→}\n    39→\n    40→// ─── Observability (Task 2.1) ───────────────────────────────────────────────\n    41→\n    42→export async function checkObservability(projectDir: string): Promise<Result<DimensionResult>> {\n    43→  try {\n    44→    const gaps: AuditGap[] = [];\n    45→    let sStatus: Status = 'pass', sMetric = '';\n    46→    const sr = analyze(projectDir);\n    47→\n    48→    if (isOk(sr)) {\n    49→      const d: AnalyzerResult = sr.data;\n    50→      if (d.skipped) {\n    51→        sStatus = 'warn';\n    52→        sMetric = `static: skipped (${d.skipReason ?? 'unknown'})`;\n    53→        gaps.push(gap('observability', `Static analysis skipped: ${d.skipReason ?? 'Semgrep not installed'}`, 'Install Semgrep: pip install semgrep'));\n    54→      } else {\n    55→        const n = d.gaps.length;\n    56→        sMetric = `static: ${n} gap${n !== 1 ? 's' : ''}`;\n    57→        if (n > 0) {\n    58→          sStatus = 'warn';\n    59→          for (const g of d.gaps) gaps.push(gap('observability', `${g.file}:${g.line} — ${g.message}`, g.fix ?? 'Add observability instrumentation'));\n    60→        }\n    61→      }\n    62→    } else {\n    63→      sStatus = 'warn';\n    64→      sMetric = 'static: skipped (analysis failed)';\n    65→      gaps.push(gap('observability', `Static analysis failed: ${sr.error}`, 'Check Semgrep installation and rules configuration'));\n    66→    }\n    67→\n    68→    let rStatus: Status = 'pass', rMetric = '';\n    69→    try {\n    70→      const rr = await validateRuntime(projectDir);\n    71→      if (isOk(rr)) {\n    72→        const d: RuntimeValidationResult = rr.data;\n    73→        if (d.skipped) {\n    74→          rStatus = 'warn';\n    75→          rMetric = `runtime: skipped (${d.skipReason ?? 'unknown'})`;\n    76→          gaps.push(gap('observability', `Runtime validation skipped: ${d.skipReason ?? 'backend unreachable'}`, 'Start the observability stack: codeharness stack up'));\n    77→        } else {\n    78→          rMetric = `runtime: ${d.coveragePercent}%`;\n    79→          if (d.coveragePercent < 50) {\n    80→            rStatus = 'warn';\n    81→            gaps.push(gap('observability', `Runtime coverage low: ${d.coveragePercent}%`, 'Add telemetry instrumentation to more modules'));\n    82→          }\n    83→        }\n    84→      } else {\n    85→        rStatus = 'warn';\n    86→        rMetric = 'runtime: skipped (validation failed)';\n    87→        gaps.push(gap('observability', `Runtime validation failed: ${rr.error}`, 'Ensure observability backend is running'));\n    88→      }\n    89→    } catch {\n    90→      rStatus = 'warn';\n    91→      rMetric = 'runtime: skipped (error)';\n    92→      gaps.push(gap('observability', 'Runtime validation threw an unexpected error', 'Check observability stack health'));\n    93→    }\n    94→\n    95→    return dimOk('observability', worstStatus(sStatus, rStatus), `${sMetric}, ${rMetric}`, gaps);\n    96→  } catch (err: unknown) { return dimCatch('observability', err); }\n    97→}\n    98→\n    99→// ─── Testing (Task 2.2) ────────────────────────────────────────────────────\n   100→\n   101→export function checkTesting(projectDir: string): Result<DimensionResult> {\n   102→  try {\n   103→    const r = checkOnlyCoverage(projectDir);\n   104→    if (!r.success) return dimOk('testing', 'warn', 'no coverage data', [gap('testing', 'No coverage tool detected or coverage data unavailable', 'Run tests with coverage: npm run test:coverage')]);\n   105→\n   106→    const pct = r.coveragePercent;\n   107→    const gaps: AuditGap[] = [];\n   108→    let status: Status = 'pass';\n   109→    if (pct < 50) { status = 'fail'; gaps.push(gap('testing', `Test coverage critically low: ${pct}%`, 'Add unit tests to increase coverage above 50%')); }\n   110→    else if (pct < 80) { status = 'warn'; gaps.push(gap('testing', `Test coverage below target: ${pct}%`, 'Add tests to reach 80% coverage target')); }\n   111→    return dimOk('testing', status, `${pct}%`, gaps);\n   112→  } catch (err: unknown) { return dimCatch('testing', err); }\n   113→}\n   114→\n   115→// ─── Documentation (Task 2.3) ──────────────────────────────────────────────\n   116→\n   117→export function checkDocumentation(projectDir: string): Result<DimensionResult> {\n   118→  try {\n   119→    const report = scanDocHealth(projectDir);\n   120→    const gaps: AuditGap[] = [];\n   121→    const { fresh, stale, missing } = report.summary;\n   122→    let status: Status = 'pass';\n   123→\n   124→    if (missing > 0) {\n   125→      status = 'fail';\n   126→      for (const doc of report.documents) if (doc.grade === 'missing') gaps.push(gap('documentation', `Missing: ${doc.path} — ${doc.reason}`, `Create ${doc.path}`));\n   127→    }\n   128→    if (stale > 0) {\n   129→      if (status !== 'fail') status = 'warn';\n   130→      for (const doc of report.documents) if (doc.grade === 'stale') gaps.push(gap('documentation', `Stale: ${doc.path} — ${doc.reason}`, `Update ${doc.path} to reflect current code`));\n   131→    }\n   132→    return dimOk('documentation', status, `${fresh} fresh, ${stale} stale, ${missing} missing`, gaps);\n   133→  } catch (err: unknown) { return dimCatch('documentation', err); }\n   134→}\n   135→\n   136→// ─── Verification (Task 2.4) ───────────────────────────────────────────────\n   137→\n   138→export function checkVerification(projectDir: string): Result<DimensionResult> {\n   139→  try {\n   140→    const gaps: AuditGap[] = [];\n   141→    const sprintPath = join(projectDir, '_bmad-output', 'implementation-artifacts', 'sprint-status.yaml');\n   142→    if (!existsSync(sprintPath)) return dimOk('verification', 'warn', 'no sprint data', [gap('verification', 'No sprint-status.yaml found', 'Run sprint planning to create sprint status')]);\n   143→\n   144→    const vDir = join(projectDir, 'verification');\n   145→    let proofCount = 0, totalChecked = 0;\n   146→\n   147→    if (existsSync(vDir)) {\n   148→      for (const file of readdirSafe(vDir)) {\n   149→        if (!file.endsWith('-proof.md')) continue;\n   150→        totalChecked++;\n   151→        const r = parseProof(join(vDir, file));\n   152→        if (isOk(r) && r.data.passed) { proofCount++; }\n   153→        else { gaps.push(gap('verification', `Story ${file.replace('-proof.md', '')} proof incomplete or failing`, `Run codeharness verify ${file.replace('-proof.md', '')}`)); }\n   154→      }\n   155→    }\n   156→\n   157→    let status: Status = 'pass';\n   158→    if (totalChecked === 0) { status = 'warn'; gaps.push(gap('verification', 'No verification proofs found', 'Run codeharness verify for completed stories')); }\n   159→    else if (proofCount < totalChecked) { status = 'warn'; }\n   160→\n   161→    return dimOk('verification', status, totalChecked > 0 ? `${proofCount}/${totalChecked} verified` : 'no proofs', gaps);\n   162→  } catch (err: unknown) { return dimCatch('verification', err); }\n   163→}\n   164→\n   165→// ─── Infrastructure (Task 2.5) ─────────────────────────────────────────────\n   166→\n   167→export function checkInfrastructure(projectDir: string): Result<DimensionResult> {\n   168→  try {\n   169→    const dfPath = join(projectDir, 'Dockerfile');\n   170→    if (!existsSync(dfPath)) return dimOk('infrastructure', 'fail', 'no Dockerfile', [gap('infrastructure', 'No Dockerfile found', 'Create a Dockerfile for containerized deployment')]);\n   171→\n   172→    let content: string;\n   173→    try { content = readFileSync(dfPath, 'utf-8'); }\n   174→    catch { return dimOk('infrastructure', 'warn', 'Dockerfile unreadable', [gap('infrastructure', 'Dockerfile exists but could not be read', 'Check Dockerfile permissions')]); }\n   175→\n   176→    const fromLines = content.split('\\n').filter(l => /^\\s*FROM\\s+/i.test(l));\n   177→    if (fromLines.length === 0) return dimOk('infrastructure', 'fail', 'invalid Dockerfile', [gap('infrastructure', 'Dockerfile has no FROM instruction', 'Add a FROM instruction with a pinned base image')]);\n   178→\n   179→    const result = validateDockerfile(projectDir);\n   180→    if (!result.success) return dimOk('infrastructure', 'fail', 'validation failed', [gap('infrastructure', result.error, 'Fix Dockerfile validation errors')]);\n   181→\n   182→    const gaps: AuditGap[] = result.data.gaps.map(g => gap('infrastructure', g.description, g.suggestedFix));\n   183→    const issueCount = gaps.length;\n   184→    const status: Status = issueCount > 0 ? 'warn' : 'pass';\n   185→    const metric = issueCount > 0 ? `Dockerfile exists (${issueCount} issue${issueCount !== 1 ? 's' : ''})` : 'Dockerfile valid';\n   186→    return dimOk('infrastructure', status, metric, gaps);\n   187→  } catch (err: unknown) { return dimCatch('infrastructure', err); }\n   188→}\n   189→\n   190→// ─── Helpers ────────────────────────────────────────────────────────────────\n   191→\n   192→function readdirSafe(dir: string): string[] {\n   193→  try { return readdirSync(dir) as string[]; }\n   194→  catch { return []; }\n   195→}\n   196→"}]},"parent_tool_use_id":"toolu_01TyVq55huB8WDwxXQnVa2vD","session_id":"d06dabce-ed3c-4abf-ad84-f2845532d39a","uuid":"0e8fb389-b783-4384-861e-93168263a4c4","timestamp":"2026-03-21T05:19:09.103Z"}
