9\t    console.log(`Status: running (iteration ${r.activeRun.iterations}, ${r.activeRun.duration} elapsed)`);\n470\t    console.log(`Current: ${currentStory}`);\n471\t    console.log(`Budget: $${r.activeRun.cost.toFixed(2)} spent`);\n472\t  } else if (r.lastRun) {\n473\t    console.log('');\n474\t    console.log(`\\u2500\\u2500 Last Run Summary \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500`);\n475\t    console.log(`Duration: ${r.lastRun.duration} | Cost: $${r.lastRun.cost.toFixed(2)} | Iterations: ${r.lastRun.iterations}`);\n476\t    console.log(`Completed:  ${r.lastRun.completed.length} stories${r.lastRun.completed.length > 0 ? ` (${r.lastRun.completed.join(', ')})` : ''}`);\n477\t    if (r.failedDetails.length > 0) {\n478\t      console.log(`Failed:     ${r.failedDetails.length} stor${r.failedDetails.length === 1 ? 'y' : 'ies'}`);\n479\t      for (const fd of r.failedDetails) {\n480\t        const acPart = fd.acNumber !== null ? `AC ${fd.acNumber}` : 'unknown AC';\n481\t        console.log(`  \\u2514 ${fd.key}: ${acPart} \\u2014 ${fd.errorLine} (attempt ${fd.attempts}/${fd.maxAttempts})`);\n482\t      }\n483\t    }\n484\t    if (r.lastRun.blocked.length > 0) {\n485\t      console.log(`Blocked:    ${r.lastRun.blocked.length} stories (retry-exhausted)`);\n486\t    }\n487\t  }\n488\t\n489\t  if (r.actionItemsLabeled.length > 0) {\n490\t    console.log('');\n491\t    console.log(`\\u2500\\u2500 Action Items \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500`);\n492\t    for (const la of r.actionItemsLabeled) {\n493\t      console.log(`  [${la.label}] ${la.item.story}: ${la.item.description}`);\n494\t    }\n495\t  }\n496\t\n497\t  console.log('');\n498\t}\n499\t\n500\tfunction printValidationProgress(): void {\n501\t  const result = getValidationProgress();\n502\t  if (!result.success) return;\n503\t  const p = result.data;\n504\t  if (p.total === 0) return;\n505\t  console.log(`Validation: ${p.passed}/${p.total} passed, ${p.failed} failed, ${p.blocked} blocked, ${p.remaining} remaining`);\n506\t}\n507\t\n508\tfunction getSprintReportData(): StatusReport | null {\n509\t  const reportResult = generateReport();\n510\t  if (!reportResult.success) return null;\n511\t  return reportResult.data;\n512\t}\n513\t\n514\t// ─── Beads Helpers (removed — Epic 8 replacement pending) ──────────────────\n515\t\n516\tfunction printOnboardingProgress(): void {\n517\t  const progress = getOnboardingProgress();\n518\t  if (progress) {\n519\t    console.log(`Onboarding: ${progress.resolved}/${progress.total} gaps resolved (${progress.remaining} remaining)`);\n520\t  }\n521\t}\n522\t\n523\tfunction getOnboardingProgressData(): Record<string, unknown> | null {\n524\t  const progress = getOnboardingProgress();\n525\t  if (!progress) {\n526\t    return null;\n527\t  }\n528\t  return {\n529\t    total: progress.total,\n530\t    resolved: progress.resolved,\n531\t    remaining: progress.remaining,\n532\t  };\n533\t}\n534\t\n535\t// TODO: v2 issue tracker (Epic 8) — beads data removed, will be replaced by issue tracker\n536\t"}]},"parent_tool_use_id":"toolu_01ELiUhcroCmkW9Cb6Be3ouH","session_id":"452c48b4-eed2-4c96-83e9-8c71df0bbdac","uuid":"00125210-fe3e-4fca-a822-cfa44b666194","timestamp":"2026-04-02T23:18:03.946Z"}
