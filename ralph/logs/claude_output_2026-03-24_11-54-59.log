: \"Tests:  3 failed, 12 passed, 2 skipped, 17 total\"\n    // Extract each field independently since ordering can vary.\n    const jestPassedMatch = /Tests:.*?(\\d+)\\s+passed/i.exec(output);\n    if (jestPassedMatch) {\n      const passed = parseInt(jestPassedMatch[1], 10);\n      const failedMatch = /Tests:.*?(\\d+)\\s+failed/i.exec(output);\n      const skippedMatch = /Tests:.*?(\\d+)\\s+skipped/i.exec(output);\n      const totalMatch = /Tests:.*?(\\d+)\\s+total/i.exec(output);\n      const failed = failedMatch ? parseInt(failedMatch[1], 10) : 0;\n      const skipped = skippedMatch ? parseInt(skippedMatch[1], 10) : 0;\n      const total = totalMatch ? parseInt(totalMatch[1], 10) : passed + failed + skipped;\n      return { passed, failed, skipped, total };\n    }\n\n    return { passed: 0, failed: 0, skipped: 0, total: 0 };"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1025,"cache_read_input_tokens":58517,"cache_creation":{"ephemeral_5m_input_tokens":1025,"ephemeral_1h_input_tokens":0},"output_tokens":71,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01AYUK9c5QWsnPVHthUcsHao","session_id":"ec2bf7d9-1cd3-4665-9804-65790a3eadb3","uuid":"40509799-431f-42a4-a71e-f49dd637282c"}
