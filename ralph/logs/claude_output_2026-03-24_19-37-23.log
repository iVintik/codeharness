{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RqeLWgGkaxLx22ijTPBWfR","type":"tool_result","content":"     1→import { spawn } from 'node:child_process';\n     2→import { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n     3→import { join, dirname } from 'node:path';\n     4→import { fileURLToPath } from 'node:url';\n     5→import { Command } from 'commander';\n     6→import { fail, info, jsonOutput } from '../lib/output.js';\n     7→import { readSprintStatusFromState, reconcileState } from '../modules/sprint/index.js';\n     8→import { generateRalphPrompt } from '../templates/ralph-prompt.js';\n     9→import { startRenderer, type SprintInfo } from '../lib/ink-renderer.js';\n    10→import { getSprintState } from '../modules/sprint/index.js';\n    11→import { formatElapsed, mapSprintStatuses, countStories, buildSpawnArgs, createLineProcessor } from '../lib/run-helpers.js';\n    12→\n    13→/** Resolves the path to ralph/ralph.sh relative to the package root. */\n    14→export function resolveRalphPath(): string {\n    15→  const currentFile = fileURLToPath(import.meta.url);\n    16→  const currentDir = dirname(currentFile);\n    17→  let root = dirname(currentDir);\n    18→  if (root.endsWith('/src') || root.endsWith('\\\\src')) {\n    19→    root = dirname(root);\n    20→  }\n    21→  return join(root, 'ralph', 'ralph.sh');\n    22→}\n    23→\n    24→/** Resolves the plugin directory path (.claude/ in project root). */\n    25→export function resolvePluginDir(): string {\n    26→  return join(process.cwd(), '.claude');\n    27→}\n    28→\n    29→// Re-export helpers that tests import from run.ts\n    30→export { countStories, buildSpawnArgs } from '../lib/run-helpers.js';\n    31→\n    32→export function registerRunCommand(program: Command): void {\n    33→  program\n    34→    .command('run')\n    35→    .description('Execute the autonomous coding loop')\n    36→    .option('--max-iterations <n>', 'Maximum loop iterations', '50')\n    37→    .option('--timeout <seconds>', 'Total loop timeout in seconds', '43200')\n    38→    .option('--iteration-timeout <minutes>', 'Per-iteration timeout in minutes', '30')\n    39→    .option('--quiet', 'Suppress terminal output (background mode)', false)\n    40→    .option('--calls <n>', 'Max API calls per hour', '100')\n    41→    .option('--max-story-retries <n>', 'Max retries per story before flagging', '10')\n    42→    .option('--reset', 'Clear retry counters, flagged stories, and circuit breaker before starting', false)\n    43→    .action(async (options, cmd) => {\n    44→      const globalOpts = cmd.optsWithGlobals();\n    45→      const isJson = !!globalOpts.json;\n    46→      const outputOpts = { json: isJson };\n    47→\n    48→      // 1. Resolve Ralph script path\n    49→      const ralphPath = resolveRalphPath();\n    50→      if (!existsSync(ralphPath)) {\n    51→        fail('Ralph loop not found — reinstall codeharness', outputOpts);\n    52→        process.exitCode = 1;\n    53→        return;\n    54→      }\n    55→\n    56→      // 2. Resolve plugin directory\n    57→      const pluginDir = resolvePluginDir();\n    58→      if (!existsSync(pluginDir)) {\n    59→        fail('Plugin directory not found — run codeharness init first', outputOpts);\n    60→        process.exitCode = 1;\n    61→        return;\n    62→      }\n    63→\n    64→      // 2b. Reconcile state (best-effort — failures warn but don't abort)\n    65→      const reconciliation = reconcileState();\n    66→      if (reconciliation.success && reconciliation.data.corrections.length > 0) {\n    67→        for (const correction of reconciliation.data.corrections) {\n    68→          info(`[INFO] Reconciled: ${correction}`, outputOpts);\n    69→        }\n    70→      } else if (!reconciliation.success) {\n    71→        info(`[WARN] State reconciliation failed: ${reconciliation.error}`, outputOpts);\n    72→      }\n    73→\n    74→      // 3. Read sprint status for story count (from sprint-state.json)\n    75→      const projectDir = process.cwd();\n    76→      const sprintStatusPath = join(projectDir, '_bmad-output', 'implementation-artifacts', 'sprint-status.yaml');\n    77→      const statuses = readSprintStatusFromState();\n    78→      const counts = countStories(statuses);\n    79→\n    80→      if (counts.total === 0) {\n    81→        fail('No stories found in sprint-state.json — nothing to execute', outputOpts);\n    82→        process.exitCode = 1;\n    83→        return;\n    84→      }\n    85→\n    86→      info(`Starting autonomous execution — ${counts.ready} ready, ${counts.inProgress} in progress, ${counts.verified} verified, ${counts.done}/${counts.total} done`, outputOpts);\n    87→\n    88→      // 4. Parse and validate numeric options\n    89→      const maxIterations = parseInt(options.maxIterations, 10);\n    90→      const timeout = parseInt(options.timeout, 10);\n    91→      const iterationTimeout = parseInt(options.iterationTimeout, 10);\n    92→      const calls = parseInt(options.calls, 10);\n    93→      const maxStoryRetries = parseInt(options.maxStoryRetries, 10);\n    94→\n    95→      if (isNaN(maxIterations) || isNaN(timeout) || isNaN(iterationTimeout) || isNaN(calls) || isNaN(maxStoryRetries)) {\n    96→        fail('Invalid numeric option — --max-iterations, --timeout, --iteration-timeout, --calls, and --max-story-retries must be numbers', outputOpts);\n    97→        process.exitCode = 1;\n    98→        return;\n    99→      }\n   100→\n   101→      // 5. Generate prompt file (with flagged stories context if available)\n   102→      const promptFile = join(projectDir, 'ralph', '.harness-prompt.md');\n   103→      // Read flagged stories from sprint-state.json (reconcileState may have\n   104→      // already deleted the orphan .flagged_stories file, so read from state)\n   105→      let flaggedStories: string[] | undefined;\n   106→      const flaggedState = getSprintState();\n   107→      if (flaggedState.success && flaggedState.data.flagged?.length > 0) {\n   108→        flaggedStories = flaggedState.data.flagged;\n   109→      }\n   110→      const promptContent = generateRalphPrompt({\n   111→        projectDir,\n   112→        sprintStatusPath,\n   113→        flaggedStories,\n   114→      });\n   115→      try {\n   116→        mkdirSync(dirname(promptFile), { recursive: true });\n   117→        writeFileSync(promptFile, promptContent, 'utf-8');\n   118→      } catch (err) {\n   119→        const message = err instanceof Error ? err.message : String(err);\n   120→        fail(`Failed to write prompt file: ${message}`, outputOpts);\n   121→        process.exitCode = 1;\n   122→        return;\n   123→      }\n   124→\n   125→      // 6. Build spawn arguments\n   126→      const args = buildSpawnArgs({\n   127→        ralphPath,\n   128→        pluginDir,\n   129→        promptFile,\n   130→        maxIterations,\n   131→        timeout,\n   132→        iterationTimeout,\n   133→        calls,\n   134→        quiet: options.quiet,\n   135→        maxStoryRetries,\n   136→        reset: options.reset,\n   137→      });\n   138→\n   139→      // 7. Set environment — stream-json is always the output format\n   140→      const env = { ...process.env };\n   141→      if (isJson) {\n   142→        env.CLAUDE_OUTPUT_FORMAT = 'stream-json';\n   143→      }\n   144→\n   145→      // 8. Spawn Ralph — pipe stdout/stderr through stream parser → Ink renderer\n   146→      // Declare renderer handle outside try so cleanup is always reachable\n   147→      const quiet = options.quiet;\n   148→      const rendererHandle = startRenderer({ quiet });\n   149→      let sprintStateInterval: ReturnType<typeof setInterval> | null = null;\n   150→      const sessionStartTime = Date.now();\n   151→      let currentIterationCount = 0;\n   152→\n   153→      try {\n   154→        // Read initial sprint state for the renderer header\n   155→        const initialState = getSprintState();\n   156→        if (initialState.success) {\n   157→          const s = initialState.data;\n   158→          const sprintInfo: SprintInfo = {\n   159→            storyKey: s.run.currentStory ?? '',\n   160→            phase: s.run.currentPhase ?? '',\n   161→            done: s.sprint.done,\n   162→            total: s.sprint.total,\n   163→            elapsed: formatElapsed(Date.now() - sessionStartTime),\n   164→            iterationCount: currentIterationCount,\n   165→          };\n   166→          rendererHandle.updateSprintState(sprintInfo);\n   167→        }\n   168→\n   169→        // Feed initial per-story statuses to the renderer\n   170→        const initialStatuses = readSprintStatusFromState();\n   171→        const initialStories = mapSprintStatuses(initialStatuses);\n   172→        if (initialStories.length > 0) {\n   173→          rendererHandle.updateStories(initialStories);\n   174→        }\n   175→\n   176→        const child = spawn('bash', args, {\n   177→          stdio: quiet ? 'ignore' : ['inherit', 'pipe', 'pipe'],\n   178→          cwd: projectDir,\n   179→          env,\n   180→        });\n   181→\n   182→        if (!quiet && child.stdout && child.stderr) {\n   183→          // Wire up stream parser → Ink renderer via extracted createLineProcessor.\n   184→          const stdoutHandler = createLineProcessor({\n   185→            onEvent: (event) => rendererHandle.update(event),\n   186→          });\n   187→          const stderrHandler = createLineProcessor({\n   188→            onEvent: (event) => rendererHandle.update(event),\n   189→            onMessage: (msg) => rendererHandle.addMessage(msg),\n   190→            onIteration: (iteration) => { currentIterationCount = iteration; },\n   191→          }, { parseRalph: true });\n   192→          child.stdout.on('data', stdoutHandler);\n   193→          child.stderr.on('data', stderrHandler);\n   194→\n   195→          // Periodically refresh sprint state for the header display\n   196→          sprintStateInterval = setInterval(() => {\n   197→            try {\n   198→              const stateResult = getSprintState();\n   199→              if (stateResult.success) {\n   200→                const s = stateResult.data;\n   201→                const sprintInfo: SprintInfo = {\n   202→                  storyKey: s.run.currentStory ?? '',\n   203→                  phase: s.run.currentPhase ?? '',\n   204→                  done: s.sprint.done,\n   205→                  total: s.sprint.total,\n   206→                  elapsed: formatElapsed(Date.now() - sessionStartTime),\n   207→                  iterationCount: currentIterationCount,\n   208→                };\n   209→                rendererHandle.updateSprintState(sprintInfo);\n   210→              }\n   211→              // Refresh per-story statuses (AC #7)\n   212→              const currentStatuses = readSprintStatusFromState();\n   213→              const storyEntries = mapSprintStatuses(currentStatuses);\n   214→              rendererHandle.updateStories(storyEntries);\n   215→            } catch {\n   216→              // Ignore read errors during polling\n   217→            }\n   218→          }, 5_000);\n   219→        }\n   220→\n   221→        const exitCode = await new Promise<number>((resolve, reject) => {\n   222→          child.on('error', (err) => {\n   223→            if (sprintStateInterval) clearInterval(sprintStateInterval);\n   224→            rendererHandle.cleanup();\n   225→            reject(err);\n   226→          });\n   227→          child.on('close', (code) => {\n   228→            if (sprintStateInterval) clearInterval(sprintStateInterval);\n   229→            rendererHandle.cleanup();\n   230→            resolve(code ?? 1);\n   231→          });\n   232→        });\n   233→\n   234→        // 9. Handle JSON output on exit\n   235→        if (isJson) {\n   236→          const statusFile = join(projectDir, 'ralph', 'status.json');\n   237→          if (existsSync(statusFile)) {\n   238→            try {\n   239→              const statusData = JSON.parse(readFileSync(statusFile, 'utf-8'));\n   240→              const finalStatuses = readSprintStatusFromState();\n   241→              const finalCounts = countStories(finalStatuses);\n   242→              jsonOutput({\n   243→                status: statusData.status ?? (exitCode === 0 ? 'completed' : 'stopped'),\n   244→                iterations: statusData.loop_count ?? 0,\n   245→                storiesCompleted: finalCounts.done,\n   246→                storiesTotal: finalCounts.total,\n   247→                storiesRemaining: finalCounts.total - finalCounts.done,\n   248→                elapsedSeconds: statusData.elapsed_seconds ?? 0,\n   249→                flaggedStories: statusData.flagged_stories ?? [],\n   250→                exitReason: statusData.exit_reason ?? '',\n   251→              });\n   252→            } catch {\n   253→              jsonOutput({\n   254→                status: exitCode === 0 ? 'completed' : 'stopped',\n   255→                iterations: 0,\n   256→                storiesCompleted: 0,\n   257→                storiesTotal: counts.total,\n   258→                storiesRemaining: counts.total,\n   259→                elapsedSeconds: 0,\n   260→                flaggedStories: [],\n   261→                exitReason: 'status_file_unreadable',\n   262→              });\n   263→            }\n   264→          } else {\n   265→            // status.json not created (Ralph crashed early or never started)\n   266→            const finalStatuses = readSprintStatusFromState();\n   267→            const finalCounts = countStories(finalStatuses);\n   268→            jsonOutput({\n   269→              status: exitCode === 0 ? 'completed' : 'stopped',\n   270→              iterations: 0,\n   271→              storiesCompleted: finalCounts.done,\n   272→              storiesTotal: finalCounts.total,\n   273→              storiesRemaining: finalCounts.total - finalCounts.done,\n   274→              elapsedSeconds: 0,\n   275→              flaggedStories: [],\n   276→              exitReason: 'status_file_missing',\n   277→            });\n   278→          }\n   279→        }\n   280→\n   281→        process.exitCode = exitCode;\n   282→      } catch (err) {\n   283→        if (sprintStateInterval) clearInterval(sprintStateInterval);\n   284→        rendererHandle.cleanup();\n   285→        const message = err instanceof Error ? err.message : String(err);\n   286→        fail(`Failed to start Ralph: ${message}`, outputOpts);\n   287→        process.exitCode = 1;\n   288→      }\n   289→    });\n   290→}\n   291→"}]},"parent_tool_use_id":"toolu_01SHktkuCBrV1tHtE9gQXR6g","session_id":"3ce6f3e2-c583-4074-ab3d-bf1fc6d87b66","uuid":"e6b86e85-11df-4876-b3ca-c4c11f34901b","timestamp":"2026-03-24T15:52:35.952Z"}
