{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WkRqfSYCZ6JFmk6y67KbB1","type":"tool_result","content":"     1→/**\n     2→ * Stack provider types — the canonical location for all stack-related type definitions.\n     3→ *\n     4→ * All consumers import from `src/lib/stacks/index.ts`. The legacy `stack-detect.ts`\n     5→ * module was deleted in story 10-5.\n     6→ */\n     7→\n     8→/** Supported language stacks. */\n     9→export type StackName = 'nodejs' | 'python' | 'rust';\n    10→\n    11→/** Application archetype detected from project structure and dependencies. */\n    12→export type AppType = 'server' | 'cli' | 'web' | 'agent' | 'generic';\n    13→\n    14→/** Coverage tool identifiers. */\n    15→export type CoverageToolName = 'c8' | 'nyc' | 'istanbul' | 'coverage-py' | 'tarpaulin' | 'llvm-cov' | 'none';\n    16→\n    17→/** Coverage tool configuration detected in a project. */\n    18→export interface CoverageToolInfo {\n    19→  tool: CoverageToolName;\n    20→  configFile?: string;\n    21→}\n    22→\n    23→/** Result of an OTLP instrumentation installation. */\n    24→export interface OtlpResult {\n    25→  success: boolean;\n    26→  packagesInstalled: string[];\n    27→  error?: string;\n    28→}\n    29→\n    30→/** Parsed test execution counts. */\n    31→export interface TestCounts {\n    32→  passed: number;\n    33→  failed: number;\n    34→  skipped: number;\n    35→  total: number;\n    36→}\n    37→\n    38→/**\n    39→ * The StackProvider interface encapsulates all language-specific behavior.\n    40→ * Adding a new language requires only implementing this interface in a single file.\n    41→ */\n    42→export interface StackProvider {\n    43→  /** Canonical stack identifier. */\n    44→  readonly name: StackName;\n    45→\n    46→  /** Marker files whose presence indicates this stack (e.g. `['package.json']`). */\n    47→  readonly markers: string[];\n    48→\n    49→  /** Human-readable label (e.g. `'Node.js (package.json)'`). */\n    50→  readonly displayName: string;\n    51→\n    52→  /** Detect the application archetype for a project directory. */\n    53→  detectAppType(dir: string): AppType;\n    54→\n    55→  /** Return the preferred coverage tool for this stack. */\n    56→  getCoverageTool(): CoverageToolName;\n    57→\n    58→  /** Detect existing coverage configuration in a directory. */\n    59→  detectCoverageConfig(dir: string): CoverageToolInfo;\n    60→"}]},"parent_tool_use_id":"toolu_01ARb5KJHwvTVWjSi4hskh96","session_id":"7c5953f4-1d55-4aa9-825f-60bc73601e00","uuid":"de870499-1d91-4947-97ee-94df6b0a0fa6","timestamp":"2026-03-25T01:51:12.405Z"}
