{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016KvyUHNTQPsvfHJi5dVASy","type":"tool_result","content":"     1→import { execFileSync } from 'node:child_process';\n     2→import { ok, fail as failOutput, info } from './output.js';\n     3→\n     4→export interface InstallCommand {\n     5→  cmd: string;\n     6→  args: string[];\n     7→}\n     8→\n     9→export interface DependencySpec {\n    10→  name: string;\n    11→  displayName: string;\n    12→  installCommands: InstallCommand[];\n    13→  checkCommand: InstallCommand;\n    14→  critical: boolean;\n    15→}\n    16→\n    17→export interface DependencyResult {\n    18→  name: string;\n    19→  displayName: string;\n    20→  status: 'installed' | 'already-installed' | 'skipped' | 'failed';\n    21→  version: string | null;\n    22→  error?: string;\n    23→}\n    24→\n    25→export const DEPENDENCY_REGISTRY: readonly DependencySpec[] = [\n    26→  {\n    27→    name: 'showboat',\n    28→    displayName: 'Showboat',\n    29→    installCommands: [\n    30→      { cmd: 'pip', args: ['install', 'showboat'] },\n    31→      { cmd: 'pipx', args: ['install', 'showboat'] },\n    32→    ],\n    33→    checkCommand: { cmd: 'showboat', args: ['--version'] },\n    34→    critical: false,\n    35→  },\n    36→  {\n    37→    name: 'agent-browser',\n    38→    displayName: 'agent-browser',\n    39→    installCommands: [\n    40→      { cmd: 'npm', args: ['install', '-g', '@anthropic/agent-browser'] },\n    41→    ],\n    42→    checkCommand: { cmd: 'agent-browser', args: ['--version'] },\n    43→    critical: false,\n    44→  },\n    45→  {\n    46→    name: 'beads',\n    47→    displayName: 'beads',\n    48→    installCommands: [\n    49→      { cmd: 'pip', args: ['install', 'beads'] },\n    50→      { cmd: 'pipx', args: ['install', 'beads'] },\n    51→    ],\n    52→    checkCommand: { cmd: 'bd', args: ['--version'] },\n    53→    critical: false,\n    54→  },\n    55→  {\n    56→    name: 'semgrep',\n    57→    displayName: 'Semgrep',\n    58→    installCommands: [\n    59→      { cmd: 'pipx', args: ['install', 'semgrep'] },\n    60→      { cmd: 'pip', args: ['install', 'semgrep'] },\n    61→    ],\n    62→    checkCommand: { cmd: 'semgrep', args: ['--version'] },\n    63→    critical: false,\n    64→  },\n    65→  {\n    66→    name: 'bats',\n    67→    displayName: 'BATS',\n    68→    installCommands: [\n    69→      { cmd: 'brew', args: ['install', 'bats-core'] },\n    70→      { cmd: 'npm', args: ['install', '-g', 'bats'] },\n    71→    ],\n    72→    checkCommand: { cmd: 'bats', args: ['--version'] },\n    73→    critical: false,\n    74→  },\n    75→  {\n    76→    name: 'cargo-tarpaulin',\n    77→    displayName: 'cargo-tarpaulin',\n    78→    installCommands: [{ cmd: 'cargo', args: ['install', 'cargo-tarpaulin'] }],\n    79→    checkCommand: { cmd: 'cargo', args: ['tarpaulin', '--version'] },\n    80→    critical: false,\n    81→  },\n    82→];\n    83→\n    84→export function checkInstalled(spec: DependencySpec): { installed: boolean; version: string | null } {\n    85→  try {\n    86→    const output = execFileSync(spec.checkCommand.cmd, spec.checkCommand.args, { stdio: 'pipe', timeout: 15_000 }).toString().trim();\n    87→    const version = parseVersion(output);\n    88→    return { installed: true, version };\n    89→  } catch {\n    90→    return { installed: false, version: null };\n    91→  }\n    92→}\n    93→\n    94→export function parseVersion(output: string): string | null {\n    95→  const match = /(\\d+\\.\\d+[\\w.-]*)/.exec(output);\n    96→  return match ? match[1] : null;\n    97→}\n    98→\n    99→export function installDependency(spec: DependencySpec): DependencyResult {\n   100→  // Check if already installed\n   101→  const check = checkInstalled(spec);\n   102→  if (check.installed) {\n   103→    return {\n   104→      name: spec.name,\n   105→      displayName: spec.displayName,\n   106→      status: 'already-installed',\n   107→      version: check.version,\n   108→    };\n   109→  }\n   110→\n   111→  // Try each install command in the fallback chain\n   112→  for (const installCmd of spec.installCommands) {\n   113→    try {\n   114→      execFileSync(installCmd.cmd, installCmd.args, { stdio: 'pipe', timeout: 300_000 });\n   115→\n   116→      // Verify installation succeeded by checking version\n   117→      const postCheck = checkInstalled(spec);\n   118→      if (postCheck.installed) {\n   119→        return {\n   120→          name: spec.name,\n   121→          displayName: spec.displayName,\n   122→          status: 'installed',\n   123→          version: postCheck.version,\n   124→        };\n   125→      }\n   126→    } catch {\n   127→      // Try next fallback\n   128→      continue;\n   129→    }\n   130→  }\n   131→\n   132→  // All install commands failed\n   133→  const remedy = spec.installCommands.map(c => [c.cmd, ...c.args].join(' ')).join(' or ');\n   134→  return {\n   135→    name: spec.name,\n   136→    displayName: spec.displayName,\n   137→    status: 'failed',\n   138→    version: null,\n   139→    error: `Install failed. Try: ${remedy}`,\n   140→  };\n   141→}\n   142→\n   143→export function installAllDependencies(opts: { json?: boolean }): DependencyResult[] {\n   144→  const results: DependencyResult[] = [];\n   145→\n   146→  for (const spec of DEPENDENCY_REGISTRY) {\n   147→    const result = installDependency(spec);\n   148→    results.push(result);\n   149→\n   150→    if (!opts.json) {\n   151→      if (result.status === 'installed') {\n   152→        const versionStr = result.version ? ` (v${result.version})` : '';\n   153→        ok(`${spec.displayName}: installed${versionStr}`);\n   154→      } else if (result.status === 'already-installed') {\n   155→        const versionStr = result.version ? ` (v${result.version})` : '';\n   156→        ok(`${spec.displayName}: already installed${versionStr}`);\n   157→      } else if (result.status === 'failed') {\n   158→        failOutput(`${spec.displayName}: install failed. ${result.error ?? ''}`);\n   159→        if (!spec.critical) {\n   160→          info(`${spec.displayName} is optional — continuing without it`);\n   161→        }\n   162→      }\n   163→    }\n   164→\n   165→    if (result.status === 'failed' && spec.critical) {\n   166→      throw new CriticalDependencyError(spec.displayName, result.error ?? 'Install failed');\n   167→    }\n   168→  }\n   169→\n   170→  return results;\n   171→}\n   172→\n   173→export class CriticalDependencyError extends Error {\n   174→  constructor(\n   175→    public readonly dependencyName: string,\n   176→    public readonly reason: string,\n   177→  ) {\n   178→    super(`Critical dependency '${dependencyName}' failed to install: ${reason}`);\n   179→    this.name = 'CriticalDependencyError';\n   180→  }\n   181→}\n   182→"}]},"parent_tool_use_id":"toolu_01LPDiRBbNy94aBwYJ1i6trf","session_id":"b2eefe49-15c3-4418-957c-7920103cee96","uuid":"800ef54e-e3a3-4b25-944a-71af10ca2cb4","timestamp":"2026-03-23T06:29:15.188Z"}
