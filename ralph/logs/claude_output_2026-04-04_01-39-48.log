{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MQ2eZya7rHJxbsoPMEY1Ev","type":"tool_result","content":"1\timport { query } from '@anthropic-ai/claude-agent-sdk';\n2\timport type { SubagentDefinition } from './agent-resolver.js';\n3\t\n4\t// --- Interfaces ---\n5\t\n6\t/**\n7\t * Options for dispatching an agent session.\n8\t */\n9\texport interface DispatchOptions {\n10\t  /** Working directory for the agent session. */\n11\t  cwd?: string;\n12\t  /** Session ID for resuming an existing session (forward-compat for story 4-2). */\n13\t  sessionId?: string;\n14\t  /** Additional text appended to the system prompt (forward-compat for story 4-3 trace IDs). */\n15\t  appendSystemPrompt?: string;\n16\t}\n17\t\n18\t/**\n19\t * Result of a successful agent dispatch.\n20\t */\n21\texport interface DispatchResult {\n22\t  /** The session ID assigned by the Agent SDK. */\n23\t  sessionId: string;\n24\t  /** Whether the session completed successfully (no errors). */\n25\t  success: boolean;\n26\t  /** Wall-clock duration in milliseconds. */\n27\t  durationMs: number;\n28\t  /** The agent's final text response. */\n29\t  output: string;\n30\t}\n31\t\n32\t// --- Error Class ---\n33\t\n34\t/** Error codes for classifying dispatch failures. */\n35\texport type DispatchErrorCode = 'RATE_LIMIT' | 'NETWORK' | 'SDK_INIT' | 'UNKNOWN';\n36\t\n37\t/**\n38\t * Structured error thrown by dispatchAgent() with a classification code.\n39\t */\n40\texport class DispatchError extends Error {\n41\t  public readonly code: DispatchErrorCode;\n42\t  public readonly agentName: string;\n43\t  public readonly cause: unknown;\n44\t\n45\t  constructor(\n46\t    message: string,\n47\t    code: DispatchErrorCode,\n48\t    agentName: string,\n49\t    cause: unknown,\n50\t  ) {\n51\t    super(message);\n52\t    this.name = 'DispatchError';\n53\t    this.code = code;\n54\t    this.agentName = agentName;\n55\t    this.cause = cause;\n56\t  }\n57\t}\n58\t\n59\t// --- Error Classifica