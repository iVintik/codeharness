n524\t        }),\n525\t        expect.any(String),\n526\t      );\n527\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Resuming after circuit breaker — previous findings preserved'));\n528\t      expect(executeWorkflowMock).toHaveBeenCalled();\n529\t    });\n530\t\n531\t    it('--resume with circuit-breaker logs appropriate info message', async () => {\n532\t      mockPaths({ '.claude': true });\n533\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n534\t      readWorkflowStateMock.mockReturnValue({\n535\t        workflow_name: '',\n536\t        started: '',\n537\t        iteration: 2,\n538\t        phase: 'circuit-breaker',\n539\t        tasks_completed: [],\n540\t        evaluator_scores: [],\n541\t        circuit_breaker: { triggered: true, reason: 'stagnation', score_history: [1] },\n542\t        trace_ids: [],\n543\t      });\n544\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n545\t\n546\t      await runCommand(['--resume']);\n547\t\n548\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Resuming after circuit breaker'));\n549\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('previous findings preserved'));\n550\t    });\n551\t\n552\t    it('--resume with completed phase still works as before (regression)', async () => {\n553\t      mockPaths({ '.claude': true });\n554\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n555\t      readWorkflowStateMock.mockReturnValue({\n556\t        workflow_name: 'implement -> verify',\n557\t        started: new Date().toISOString(),\n558\t        iteration: 3,\n559\t        phase: 'completed',\n560\t        tasks_completed: [],\n561\t        evaluator_scores: [],\n562\t        circuit_breaker: { triggered: false, reason: null, score_history: [] },\n563\t        trace_ids: [],\n564\t      });\n565\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n566\t\n567\t      await runCommand(['--resume']);\n568\t\n569\t      expect(writeWorkflowStateMock).toHaveBeenCalledWith(\n570\t        expect.objectContaining({ phase: 'idle' }),\n571\t        expect.any(String),\n572\t      );\n573\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Resuming from completed state'));\n574\t    });\n575\t\n576\t    it('without --resume, circuit-breaker phase is NOT reset (AC #5)', async () => {\n577\t      mockPaths({ '.claude': true });\n578\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n579\t      readWorkflowStateMock.mockReturnValue({\n580\t        workflow_name: '',\n581\t        started: '',\n582\t        iteration: 5,\n583\t        phase: 'circuit-breaker',\n584\t        tasks_completed: [],\n585\t        evaluator_scores: [],\n586\t        circuit_breaker: { triggered: true, reason: 'stagnation', score_history: [3, 3] },\n587\t        trace_ids: [],\n588\t      });\n589\t      vi.spyOn(console, 'log').mockImplementation(() => {});\n590\t\n591\t      await runCommand();\n592\t\n593\t      expect(writeWorkflowStateMock).not.toHaveBeenCalled();\n594\t      expect(executeWorkflowMock).toHaveBeenCalled();\n595\t    });\n596\t  });\n597\t\n598\t  describe('--workflow option (Story 9.2)', () => {\n599\t    it('passes --workflow name and cwd to resolveWorkflow', async () => {\n600\t      mockPaths({ '.claude': true });\n601\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n602\t      vi.spyOn(console, 'log').mockImplementation(() => {});\n603\t\n604\t      await runCommand(['--workflow', 'my-workflow']);\n605\t\n606\t      expect(resolveWorkflowMock).toHaveBeenCalledWith(\n607\t        expect.objectContaining({ name: 'my-workflow', cwd: expect.any(String) }),\n608\t      );\n609\t    });\n610\t\n611\t    it('defaults to \"default\" when --workflow is not specified', async () => {\n612\t      mockPaths({ '.claude': true });\n613\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n614\t      vi.spyOn(console, 'log').mockImplementation(() => {});\n615\t\n616\t      await runCommand();\n617\t\n618\t      expect(resolveWorkflowMock).toHaveBeenCalledWith(\n619\t        expect.objectContaining({ name: 'default' }),\n620\t      );\n621\t    });\n622\t\n623\t    it('exits 1 with clear error when custom workflow not found (no fallback)', async () => {\n624\t      mockPaths({ '.claude': true });\n625\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n626\t      resolveWorkflowMock.mockImplementation(() => {\n627\t        throw new Error('Embedded workflow not found: my-workflow');\n628\t      });\n629\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n630\t\n631\t      await runCommand(['--workflow', 'my-workflow']);\n632\t\n633\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Failed to resolve workflow'));\n634\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('my-workflow'));\n635\t      expect(process.exitCode).toBe(1);\n636\t      // Should NOT attempt fallback for non-default workflows\n637\t      expect(parseWorkflowMock).not.toHaveBeenCalled();\n638\t    });\n639\t\n640\t    it('rejects workflow names with path traversal characters', async () => {\n641\t      mockPaths({ '.claude': true });\n642\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n643\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n644\t\n645\t      await runCommand(['--workflow', '../../../etc/passwd']);\n646\t\n647\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Invalid workflow name'));\n648\t      expect(process.exitCode).toBe(1);\n649\t      expect(resolveWorkflowMock).not.toHaveBeenCalled();\n650\t    });\n651\t\n652\t    it('rejects workflow names with slashes', async () => {\n653\t      mockPaths({ '.claude': true });\n654\t      readSprintStatusMock.mockRetu