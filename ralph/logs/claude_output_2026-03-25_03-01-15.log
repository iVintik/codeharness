at', status: 'already-installed', version: '0.6.1' },\n    39→  ]),\n    40→  checkInstalled: vi.fn(() => ({ installed: true, version: '1.0.0' })),\n    41→  DEPENDENCY_REGISTRY: [\n    42→    {\n    43→      name: 'showboat',\n    44→      displayName: 'Showboat',\n    45→      installCommands: [{ cmd: 'pip', args: ['install', 'showboat'] }],\n    46→      checkCommand: { cmd: 'showboat', args: ['--version'] },\n    47→      critical: false,\n    48→    },\n    49→  ],\n    50→  CriticalDependencyError: class extends Error {\n    51→    constructor(d: string, r: string) { super(`Critical dependency '${d}' failed: ${r}`); this.name = 'CriticalDependencyError'; }\n    52→  },\n    53→}));\n    54→\n    55→vi.mock('../../../lib/beads.js', () => ({\n    56→  isBeadsInitialized: vi.fn(() => false),\n    57→  initBeads: vi.fn(),\n    58→  detectBeadsHooks: vi.fn(() => ({ hasHooks: false, hookTypes: [] })),\n    59→  configureHookCoexistence: vi.fn(),\n    60→  BeadsError: class extends Error {\n    61→    constructor(c: string, m: string) { super(`Beads failed: ${m}`); this.name = 'BeadsError'; }\n    62→  },\n    63→}));\n    64→\n    65→vi.mock('../../../lib/bmad.js', () => ({\n    66→  isBmadInstalled: vi.fn(() => false),\n    67→  installBmad: vi.fn(() => ({ status: 'installed', version: '6.0.0', patches_applied: [] })),\n    68→  applyAllPatches: vi.fn(() => []),\n    69→  detectBmadVersion: vi.fn(() => '6.0.0'),\n    70→  detectBmalph: vi.fn(() => ({ detected: false, files: [] })),\n    71→  BmadError: class extends Error {\n    72→    constructor(c: string, m: string) { super(`BMAD failed: ${m}`); this.name = 'BmadError'; }\n    73→  },\n    74→}));\n    75→\n    76→vi.mock('../../../lib/observability/index.js', () => ({\n    77→  instrumentProject: vi.fn(() => ({\n    78→    status: 'configured',\n    79→    packages_installed: true,\n    80→    start_script_patched: true,\n    81→    env_vars_configured: true,\n    82→  })),\n    83→  configureOtlpEnvVars: vi.fn(),\n    84→}));\n    85→\n    86→vi.mock('../../../lib/templates.js', () => ({\n    87→  generateFile: vi.fn(),\n    88→}));\n    89→\n    90→vi.mock('../../../templates/readme.js', () => ({\n    91→  readmeTemplate: vi.fn(() => '# README'),\n    92→}));\n    93→\n    94→import { isDockerAvailable } from '../../../lib/docker/index.js';\n    95→import { installAllDependencies, CriticalDependencyError } from '../../../lib/deps.js';\n    96→import { isBeadsInitialized, BeadsError } from '../../../lib/beads.js';\n    97→import { readState, writeState, getDefaultState } from '../../../lib/state.js';\n    98→import { detectStacks, detectAppType } from '../../../lib/stacks/index.js';\n    99→import { instrumentProject } from '../../../lib/observability/index.js';\n   100→import { getCoverageTool } from '../docs-scaffold.js';\n   101→import { initProject } from '../init-project.js';\n   102→\n   103→const mockIsDockerAvailable = vi.mocked(isDockerAvailable);\n   104→const mockInstallAll = vi.mocked(installAllDependencies);\n   105→const mockIsBeadsInitialized = vi.mocked(isBeadsInitialized);\n   106→const mockDetectStacks = vi.mocked(detectStacks);\n   107→const mockInstrumentProject = vi.mocked(instrumentProject);\n   108→const mockGetCoverageTool = vi.mocked(getCoverageTool);\n   109→\n   110→let testDir: string;\n   111→let originalCwd: string;\n   112→\n   113→beforeEach(() => {\n   114→  testDir = mkdtempSync(join(tmpdir(), 'ch-init-project-test-'));\n   115→  originalCwd = process.cwd();\n   116→  process.chdir(testDir);\n   117→  vi.spyOn(console, 'log').mockImplementation(() => {});\n   118→  process.exitCode = undefined;\n   119→  // Reset mocks to default implementations\n   120→  mockIsDockerAvailable.mockReturnValue(true);\n   121→  mockInstallAll.mockReturnValue([\n   122→    { name: 'showboat', displayName: 'Showboat', status: 'already-installed', version: '0.6.1' },\n   123→  ]);\n   124→  mockIsBeadsInitialized.mockReturnValue(false);\n   125→});\n   126→\n