{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WGRktYcDHq1n1SxgVkqiCE","type":"tool_result","content":"     1→import { existsSync, readFileSync } from 'node:fs';\n     2→import { join } from 'node:path';\n     3→import { warn } from './output.js';\n     4→\n     5→export type AppType = 'server' | 'cli' | 'web' | 'agent' | 'generic';\n     6→\n     7→export function detectStack(dir: string = process.cwd()): string | null {\n     8→  if (existsSync(join(dir, 'package.json'))) return 'nodejs';\n     9→  if (existsSync(join(dir, 'requirements.txt'))) return 'python';\n    10→  if (existsSync(join(dir, 'pyproject.toml'))) return 'python';\n    11→  if (existsSync(join(dir, 'setup.py'))) return 'python';\n    12→  warn('No recognized stack detected');\n    13→  return null;\n    14→}\n    15→\n    16→const AGENT_DEPS_NODE = ['anthropic', '@anthropic-ai/sdk', 'openai', 'langchain', '@langchain/core', 'llamaindex'];\n    17→const AGENT_DEPS_PYTHON = ['anthropic', 'openai', 'langchain', 'llama-index', 'traceloop-sdk'];\n    18→const WEB_FRAMEWORK_DEPS = ['react', 'vue', 'svelte', 'angular', '@angular/core', 'next', 'nuxt', 'vite', 'webpack'];\n    19→const PYTHON_WEB_FRAMEWORKS = ['flask', 'django', 'fastapi', 'streamlit'];\n    20→\n    21→function readJsonSafe(path: string): Record<string, unknown> | null {\n    22→  try {\n    23→    if (!existsSync(path)) return null;\n    24→    return JSON.parse(readFileSync(path, 'utf-8')) as Record<string, unknown>;\n    25→  } catch {\n    26→    return null;\n    27→  }\n    28→}\n    29→\n    30→function readTextSafe(path: string): string | null {\n    31→  try {\n    32→    if (!existsSync(path)) return null;\n    33→    return readFileSync(path, 'utf-8');\n    34→  } catch {\n    35→    return null;\n    36→  }\n    37→}\n    38→\n    39→function getNodeDeps(pkg: Record<string, unknown>): Set<string> {\n    40→  const deps = new Set<string>();\n    41→  for (const field of ['dependencies', 'devDependencies']) {\n    42→    const section = pkg[field] as Record<string, string> | undefined;\n    43→    if (section && typeof section === 'object') {\n    44→      for (const key of Object.keys(section)) {\n    45→        deps.add(key);\n    46→      }\n    47→    }\n    48→  }\n    49→  return deps;\n    50→}\n    51→\n    52→function hasPythonDep(content: string, dep: string): boolean {\n    53→  // Match dep name as a standalone package, not as a substring of another package.\n    54→  // Handles requirements.txt lines like \"openai>=1.0\", pyproject.toml entries like '\"openai\"',\n    55→  // and extras like \"openai[all]\". Uses word boundary or common delimiters to avoid\n    56→  // matching \"not-openai\" or \"myopenai\".\n    57→  const escaped = dep.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n    58→  const pattern = new RegExp(`(?:^|[\\\\s\"',])${escaped}(?:[\\\\[>=<~!;\\\\s\"',]|$)`, 'm');\n    59→  return pattern.test(content);\n    60→}\n    61→\n    62→function getPythonDepsContent(dir: string): string {\n    63→  const files = ['requirements.txt', 'pyproject.toml', 'setup.py'];\n    64→  const parts: string[] = [];\n    65→  for (const file of files) {\n    66→    const content = readTextSafe(join(dir, file));\n    67→    if (content) parts.push(content);\n    68→  }\n    69→  return parts.join('\\n');\n    70→}\n    71→\n    72→export function detectAppType(dir: string, stack: string | null): AppType {\n    73→  if (stack === 'nodejs') {\n    74→    const pkg = readJsonSafe(join(dir, 'package.json'));\n    75→    if (!pkg) return 'generic';\n    76→\n    77→    const deps = getNodeDeps(pkg);\n    78→\n    79→    // Priority 1: Agent detection\n    80→    if (AGENT_DEPS_NODE.some(d => deps.has(d))) {\n    81→      return 'agent';\n    82→    }\n    83→\n    84→    // Priority 2: Web detection\n    85→    if (WEB_FRAMEWORK_DEPS.some(d => deps.has(d))) {\n    86→      return 'web';\n    87→    }\n    88→    if (\n    89→      existsSync(join(dir, 'index.html')) ||\n    90→      existsSync(join(dir, 'public', 'index.html')) ||\n    91→      existsSync(join(dir, 'src', 'index.html'))\n    92→    ) {\n    93→      return 'web';\n    94→    }\n    95→\n    96→    // Priority 3: CLI detection\n    97→    const bin = pkg['bin'];\n    98→    const scripts = pkg['scripts'] as Record<string, string> | undefined;\n    99→    const hasStart = scripts?.['start'] !== undefined;\n   100→    if (bin && !hasStart) {\n   101→      return 'cli';\n   102→    }\n   103→\n   104→    // Priority 4: Server detection\n   105→    if (hasStart) {\n   106→      return 'server';\n   107→    }\n   108→\n   109→    return 'generic';\n   110→  }\n   111→\n   112→  if (stack === 'python') {\n   113→    const content = getPythonDepsContent(dir);\n   114→\n   115→    // Priority 1: Agent detection\n   116→    if (AGENT_DEPS_PYTHON.some(d => hasPythonDep(content, d))) {\n   117→      return 'agent';\n   118→    }\n   119→\n   120→    // Priority 2: Web detection (framework + templates/static dirs)\n   121→    const hasWebFramework = PYTHON_WEB_FRAMEWORKS.some(d => hasPythonDep(content, d));\n   122→    if (hasWebFramework) {\n   123→      const hasTemplates = existsSync(join(dir, 'templates'));\n   124→      const hasStatic = existsSync(join(dir, 'static'));\n   125→      if (hasTemplates || hasStatic) {\n   126→        return 'web';\n   127→      }\n   128→      // Bare Flask/Django/FastAPI without templates => server\n   129→      return 'server';\n   130→    }\n   131→\n   132→    // Priority 4: Server detection (has main entry point)\n   133→    if (\n   134→      existsSync(join(dir, 'app.py')) ||\n   135→      existsSync(join(dir, 'main.py')) ||\n   136→      existsSync(join(dir, 'manage.py'))\n   137→    ) {\n   138→      return 'server';\n   139→    }\n   140→\n   141→    return 'generic';\n   142→  }\n   143→\n   144→  return 'generic';\n   145→}\n   146→"}]},"parent_tool_use_id":"toolu_01BBjRgoxyvtnnoauMdorFCo","session_id":"6b184f1a-3a3f-4307-8da0-d8cf52066851","uuid":"e94f0aaa-cc40-4fca-9f79-26c056b14dc6","timestamp":"2026-03-23T05:09:52.179Z"}
