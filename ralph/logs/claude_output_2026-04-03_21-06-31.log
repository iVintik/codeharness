{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Sfn2ibxkL1Vqg1vjv3STE6","type":"tool_result","content":"1\t/**\n2\t * Tests for null task (agent: null) engine integration.\n3\t *\n4\t * Story 16-2: Engine-Handled Null Tasks\n5\t */\n6\timport { describe, it, expect, vi, beforeEach } from 'vitest';\n7\t\n8\t// --- Hoisted Mocks ---\n9\t\n10\tconst {\n11\t  mockReadWorkflowState,\n12\t  mockWriteWorkflowState,\n13\t  mockWarn,\n14\t  mockReadFileSync,\n15\t  mockExistsSync,\n16\t  mockParse,\n17\t  mockGetDriver,\n18\t  mockResolveModel,\n19\t  mockDriverDispatch,\n20\t  mockBuildPromptWithContractContext,\n21\t  mockWriteOutputContract,\n22\t  mockGenerateTraceId,\n23\t  mockFormatTracePrompt,\n24\t  mockRecordTraceId,\n25\t  mockResolveSessionId,\n26\t  mockRecordSessionId,\n27\t  mockCreateIsolatedWorkspace,\n28\t  mockGetNullTask,\n29\t  mockListNullTasks,\n30\t} = vi.hoisted(() => ({\n31\t  mockReadWorkflowState: vi.fn(),\n32\t  mockWriteWorkflowState: vi.fn(),\n33\t  mockWarn: vi.fn(),\n34\t  mockReadFileSync: vi.fn(),\n35\t  mockExistsSync: vi.fn(),\n36\t  mockParse: vi.fn(),\n37\t  mockGetDriver: vi.fn(),\n38\t  mockResolveModel: vi.fn(),\n39\t  mockDriverDispatch: vi.fn(),\n40\t  mockBuildPromptWithContractContext: vi.fn(),\n41\t  mockWriteOutputContract: vi.fn(),\n42\t  mockGenerateTraceId: vi.fn(),\n43\t  mockFormatTracePrompt: vi.fn(),\n44\t  mockRecordTraceId: vi.fn(),\n45\t  mockResolveSessionId: vi.fn(),\n46\t  mockRecordSessionId: vi.fn(),\n47\t  mockCreateIsolatedWorkspace: vi.fn(),\n48\t  mockGetNullTask: vi.fn(),\n49\t  mockListNullTasks: vi.fn(),\n50\t}));\n51\t\n52\tvi.mock('../agent-dispatch.js', () => ({\n53\t  dispatchAgent: vi.fn(),\n54\t  DispatchError: class DispatchError extends Error {\n55\t    public readonly code: string;\n56\t    public readonly agentName: string;\n57\t    public readonly cause: unknown;\n58\t    constructor(message: string, code: string, agentName: string, cause: unknown) {\n59\t      super(message);\n60\t      this.name = 'DispatchError';\n61\t      this.code = code;\n62\t      this.agentName = agentName;\n63\t      this.cause = cause;\n64\t    }\n65\t  },\n66\t}));\n67\t\n68\tvi.mock('../agents/drivers/factory.js', () => ({\n69\t  getDriver: mockGetDriver,\n70\t  suggestCheaperDriver: vi.fn().mockReturnValue(null),\n71\t  listDrivers: vi.fn().mockReturnValue([]),\n72\t}));\n73\t\n74\tvi.mock('../agents/capability-check.js', () => ({\n75\t  checkCapabilityConflicts: vi.fn().mockReturnValue([]),\n76\t}));\n77\t\n78\tvi.mock('../agents/model-resolver.js', () => ({\n79\t  resolveModel: mockResolveModel,\n80\t}));\n81\t\n82\tvi.mock('../workflow-state.js', () => ({\n83\t  readWorkflowState: mockReadWorkflowState,\n84\t  writeWorkflowState: mockWriteWorkflowState,\n85\t  getDefaultWorkflowState: () => ({\n86\t    workflow_name: '',\n87\t    started: '',\n88\t    iteration: 0,\n89\t    phase: 'idle',\n90\t    tasks_completed: [],\n91\t    evaluator_scores: [],\n92\t    circuit_breaker: { triggered: false, reason: null, score_history: [] },\n93\t    trace_ids: [],\n94\t  }),\n95\t}));\n96\t\n97\tvi.mock('../source-isolation.js', () => ({\n98\t  createIsolatedWorkspace: mockCreateIsolatedWorkspace,\n99\t}));\n100\t\n101\tvi.mock('../trace-id.js', () => ({\n102\t  generateTraceId: mockGenerateTraceId,\n103\t  formatTracePrompt: mockFormatTracePrompt,\n104\t  recordTraceId: mockRecordTraceId,\n105\t}));\n106\t\n107\tvi.mock('../session-manager.js', () => ({\n108\t  resolveSessionId: mockResolveSessionId,\n109\t  recordSessionId: mockRecordSessionId,\n110\t}));\n111\t\n112\tvi.mock('../output.js', () => ({\n113\t  warn: mockWarn,\n114\t}));\n115\t\n116\tvi.mock('../agents/output-contract.js', () => ({\n117\t  buildPromptWithContractContext: mockBuildPromptWithContractContext,\n118\t  writeOutputContract: mockWriteOutputContract,\n119\t}));\n120\t\n121\tvi.mock('node:fs', () => ({\n122\t  readFileSync: mockReadFileSync,\n123\t  existsSync: mockExistsSync,\n124\t}));\n125\t\n126\tvi.mock('yaml', () => ({\n127\t  parse: mockParse,\n128\t}));\n129\t\n130\tvi.mock('../null-task-registry.js', () => ({\n131\t  getNullTask: mockGetNullTask,\n132\t  listNullTasks: mockListNullTasks,\n133\t}));\n134\t\n135\tvi.mock('../verdict-parser.js', () => ({\n136\t  parseVerdict: vi.fn(),\n137\t  VerdictParseError: class VerdictParseError extends Error {\n138\t    public readonly retryable: boolean;\n139\t    constructor(message: string, retryable: boolean) {\n140\t      super(message);\n141\t      this.retryable = retryable;\n142\t    }\n143\t  },\n144\t}));\n145\t\n146\tvi.mock('../circuit-breaker.js', () => ({\n147\t  evaluateProgress: vi.fn().mockReturnValue({ halt: false }),\n148\t}));\n149\t\n150\timport {\n151\t  executeWorkflow,\n152\t  executeLoopBlock,\n153\t  checkDriverHealth,\n154\t  isTaskCompleted,\n155\t  PER_RUN_SENTINEL,\n156\t} from '../workflow-engine.js';\n157\timport type {\n158\t  EngineConfig,\n159\t  WorkItem,\n160\t} from '../workflow-engine.js';\n161\timport type { WorkflowState } from '../workflow-state.js';\n162\timport type { ResolvedWorkflow, ResolvedTask, ExecutionConfig } from '../workflow-parser.js';\n163\timport type { SubagentDefinition } from '../agent-resolver.js';\n164\timport type { OutputContract } from '../agents/types.js';\n165\t\n166\t// --- Helpers ---\n167\t\n168\tfunction makeDefaultState(overrides?: Partial<WorkflowState>): WorkflowState {\n169\t  return {\n170\t    workflow_name: '',\n171\t    started: '2026-04-03T00:00:00.000Z',\n172\t    iteration: 0,\n173\t    phase: 'idle',\n174\t    tasks_completed: [],\n175\t    evaluator_scores: [],\n176\t    circuit_breaker: { triggered: false, reason: null, score_history: [] },\n177\t    trace_ids: [],\n178\t    ...overrides,\n179\t  };\n180\t}\n181\t\n182\tfunction makeDefinition(overrides?: Partial<SubagentDefinition>): SubagentDefinition {\n183\t  return {\n184\t    name: 'test-agent',\n185\t    model: 'claude-sonnet-4-20250514',\n186\t    instructions: 'You are a test agent.',\n187\t    disallowedTools: [],\n188\t    bare: true,\n189\t    ...overrides,\n190\t  };\n191\t}\n192\t\n193\tfunction makeTask(overrides?: Partial<ResolvedTask>): ResolvedTask {\n194\t  return {\n195\t    agent: 'dev',\n196\t    scope: 'per-story',\n197\t    session: 'fresh',\n198\t    source_access: true,\n199\t    ...overrides,\n200\t  };\n201\t}\n202\t\n203\tconst defaultExecution: ExecutionConfig = {\n204\t  max_parallel: 1,\n205\t  isolation: 'none',\n206\t  merge_strategy: 'merge-commit',\n207\t  epic_strategy: 'sequential',\n208\t  story_strategy: 'sequential',\n209\t};\n210\t\n211\tfunction makeWorkflow(partial: { tasks: Record<string, ResolvedTask>; flow: (string | { loop: string[] })[] }): ResolvedWorkflow {\n212\t  return {\n213\t    ...partial,\n214\t    execution: defaultExecution,\n215\t    storyFlow: partial.flow,\n216\t    epicFlow: [],\n217\t  };\n218\t}\n219\t\n220\tfunction makeConfig(overrides?: Partial<EngineConfig>): EngineConfig {\n221\t  return {\n222\t    workflow: makeWorkflow({\n223\t      tasks: {\n224\t        implement: makeTask(),\n225\t        telemetry: makeTask({ agent: null, scope: 'per-story' }),\n226\t      },\n227\t      flow: ['implement', 'telemetry'],\n228\t    }),\n229\t    agents: {\n230\t      dev: makeDefinition(),\n231\t    },\n232\t    sprintStatusPath: '/project/sprint-status.yaml',\n233\t    runId: 'run-001',\n234\t    projectDir: '/project',\n235\t    ...overrides,\n236\t  };\n237\t}\n238\t\n239\tfunction setupDefaultMocks() {\n240\t  mockReadWorkflowState.mockReturnValue(makeDefaultState());\n241\t  mockWriteWorkflowState.mockImplementation(() => {});\n242\t  mockBuildPromptWithContractContext.mockImplementation((basePrompt: string) => basePrompt);\n243\t  mockWriteOutputContract.mockImplementation(() => {});\n244\t  mockGenerateTraceId.mockReturnValue('ch-run-001-0-implement');\n245\t  mockFormatTracePrompt.mockReturnValue('[TRACE] trace_id=ch-run-001-0-implement');\n246\t  mockRecordTraceId.mockImplementation((_traceId: string, state: WorkflowState) => ({\n247\t    ...state,\n248\t    trace_ids: [...(state.trace_ids ?? []), _traceId],\n249\t  }));\n250\t  mockResolveSessionId.mockReturnValue(undefined);\n251\t  mockRecordSessionId.mockImplementation(\n252\t    (key: { taskName: string; storyKey: string }, sessionId: string, state: WorkflowState) => ({\n253\t      ...state,\n254\t      tasks_completed: [\n255\t        ...state.tasks_completed,\n256\t        {\n257\t          task_name: key.taskName,\n258\t          story_key: key.storyKey,\n259\t          completed_at: '2026-04-03T00:00:00.000Z',\n260\t          session_id: sessionId,\n261\t        },\n262\t      ],\n263\t    }),\n264\t  );\n265\t  mockDriverDispatch.mockImplementation(() => {\n266\t    return (async function* () {\n267\t      yield { type: 'text' as const, text: 'Done' };\n268\t      yield { type: 'result' as const, cost: 0.05, sessionId: 'sess-abc-123' };\n269\t    })();\n270\t  });\n271\t  mockGetDriver.mockReturnValue({\n272\t    name: 'claude-code',\n273\t    defaultModel: 'claude-sonnet-4-20250514',\n274\t    capabilities: { supportsPlugins: true, supportsStreaming: true, costReporting: true, costTier: 3 },\n275\t    healthCheck: vi.fn().mockResolvedValue({ available: true, authenticated: true, version: '1.0.0' }),\n276\t    dispatch: mockDriverDispatch,\n277\t    getLastCost: vi.fn().mockReturnValue(null),\n278\t  });\n279\t  mockResolveModel.mockReturnValue('claude-sonnet-4-20250514');\n280\t  mockExistsSync.mockImplementation((path: string) => {\n281\t    if (path === '/project/sprint-status.yaml') return true;\n282\t    return false;\n283\t  });\n284\t  mockReadFileSync.mockReturnValue('dummy yaml');\n285\t  mockParse.mockReturnValue({\n286\t    development_status: {\n287\t      '5-1-foo': 'ready-for-dev',\n288\t      '5-2-bar': 'backlog',\n289\t    },\n290\t  });\n291\t\n292\t  // Default null task mock: telemetry handler exists\n293\t  mockGetNullTask.mockImplementation((name: string) => {\n294\t    if (name === 'telemetry') {\n295\t      return async () => ({ success: true, output: 'telemetry collected' });\n296\t    }\n297\t    return undefined;\n298\t  });\n299\t  mockListNullTasks.mockReturnValue(['telemetry']);\n300\t}\n301\t\n302\t// --- Tests ---\n303\t\n304\tdescribe('Null Task Engine Integration (Story 16-2)', () => {\n305\t  beforeEach(() => {\n306\t    vi.clearAllMocks();\n307\t    setupDefaultMocks();\n308\t  });\n309\t\n310\t  describe('AC #1: engine skips driver dispatch for agent: null tasks', () => {\n311\t    it('does not call getDriver or driver.dispatch for null tasks', async () => {\n312\t      const config = makeConfig({\n313\t        workflow: makeWorkflow({\n314\t          tasks: {\n315\t            telemetry: makeTask({ agent: null, scope: 'per-run' }),\n316\t          },\n317\t          flow: ['telemetry'],\n318\t        }),\n319\t        agents: {},\n320\t      });\n321\t\n322\t      const result = await executeWorkflow(config);\n323\t\n324\t      expect(result.success).toBe(true);\n325\t      expect(result.tasksCompleted).toBe(1);\n326\t      // getDriver is called during health check, but NOT for our null task dispatch\n327\t      expect(mockDriverDispatch).not.toHaveBeenCalled();\n328\t    });\n329\t  });\n330\t\n331\t  describe('AC #2: registry returns handler or undefined', () => {\n332\t    it('engine calls getNullTask to look up handler', async () => {\n333\t      const config = makeConfig({\n334\t        workflow: makeWorkflow({\n335\t          tasks: {\n336\t            telemetry: makeTask({ agent: null, scope: 'per-run' }),\n337\t          },\n338\t          flow: ['telemetry'],\n339\t        }),\n340\t        agents: {},\n341\t      });\n342\t\n343\t      await executeWorkflow(config);\n344\t\n345\t      expect(mockGetNullTask).toHaveBeenCalledWith('telemetry');\n346\t    });\n347\t  });\n348\t\n349\t  describe('AC #3: handler receives correct TaskContext', () => {\n350\t    it('passes storyKey, taskName, cost, durationMs, outputContract, projectDir', async () => {\n351\t      const capturedCtxs: unknown[] = [];\n352\t      mockGetNullTask.mockImplementation((name: string) => {\n353\t        if (name === 'telemetry') {\n354\t          return async (ctx: unknown) => {\n355\t            capturedCtxs.push(ctx);\n356\t            return { success: true, output: 'ok' };\n357\t          };\n358\t        }\n359\t        return undefined;\n360\t      });\n361\t\n362\t      // Use single story for deterministic test\n363\t      mockParse.mockReturnValue({\n364\t        development_status: { 'story-1': 'ready-for-dev' },\n365\t      });\n366\t\n367\t      const config = makeConfig({\n368\t        workflow: makeWorkflow({\n369\t          tasks: {\n370\t            telemetry: makeTask({ agent: null, scope: 'per-story' }),\n371\t          },\n372\t          flow: ['telemetry'],\n373\t        }),\n374\t        agents: {},\n375\t      });\n376\t\n377\t      await executeWorkflow(config);\n378\t\n379\t      expect(capturedCtxs).toHaveLength(1);\n380\t      const ctx = capturedCtxs[0] as Record<string, unknown>;\n381\t      expect(ctx.storyKey).toBe('story-1');\n382\t      expect(ctx.taskName).toBe('telemetry');\n383\t      expect(typeof ctx.cost).toBe('number');\n384\t      expect(typeof ctx.durationMs).toBe('number');\n385\t      expect(ctx.projectDir).toBe('/project');\n386\t    });\n387\t  });\n388\t\n389\t  describe('AC #4: TaskCheckpoint written after null task completion', () => {\n390\t    it('writes checkpoint to workflow state', async () => {\n391\t      const config = makeConfig({\n392\t        workflow: makeWorkflow({\n393\t          tasks: {\n394\t            telemetry: makeTask({ agent: null, scope: 'per-run' }),\n395\t          },\n396\t          flow: ['telemetry'],\n397\t        }),\n398\t        agents: {},\n399\t      });\n400\t\n401\t      await executeWorkflow(config);\n402\t\n403\t      // writeWorkflowState is called multiple times; check that at least one\n404\t      // call includes a checkpoint for our null task\n405\t      const allCalls = mockWriteWorkflowState.mock.calls;\n406\t      const stateWithCheckpoint = allCalls.find(\n407\t        (call: unknown[]) => {\n408\t          const state = call[0] as WorkflowState;\n409\t          return state.tasks_completed.some(\n410\t            (cp) => cp.task_name === 'telemetry',\n411\t          );\n412\t        },\n413\t      );\n414\t      expect(stateWithCheckpoint).toBeDefined();\n415\t    });\n416\t  });\n417\t\n418\t  describe('AC #5: unknown null task throws NULL_TASK_NOT_FOUND', () => {\n419\t    it('records error with code NULL_TASK_NOT_FOUND for unknown handler', async () => {\n420\t      mockGetNullTask.mockReturnValue(undefined);\n421\t      mockListNullTasks.mockReturnValue(['telemetry']);\n422\t\n423\t      const config = makeConfig({\n424\t        workflow: makeWorkflow({\n425\t          tasks: {\n426\t            unknown_task: makeTask({ agent: null, scope: 'per-run' }),\n427\t          },\n428\t          flow: ['unknown_task'],\n429\t        }),\n430\t        agents: {},\n431\t      });\n432\t\n433\t      const result = await executeWorkflow(config);\n434\t\n435\t      expect(result.success).toBe(false);\n436\t      expect(result.errors.length).toBeGreaterThan(0);\n437\t      expect(result.errors[0].code).toBe('NULL_TASK_NOT_FOUND');\n438\t      expect(result.errors[0].message).toContain('unknown_task');\n439\t      expect(result.errors[0].message).toContain('telemetry');\n440\t    });\n441\t  });\n442\t\n443\t  describe('AC #7: mixed null and agent tasks interleave correctly', () => {\n444\t    it('executes null and agent tasks in flow order', async () => {\n445\t      const executionOrder: string[] = [];\n446\t\n447\t      mockGetNullTask.mockImplementation((name: string) => {\n448\t        if (name === 'telemetry') {\n449\t          return async () => {\n450\t            executionOrder.push('telemetry');\n451\t            return { success: true, output: 'telemetry done' };\n452\t          };\n453\t        }\n454\t        return undefined;\n455\t      });\n456\t\n457\t      mockDriverDispatch.mockImplementation(() => {\n458\t        return (async function* () {\n459\t          executionOrder.push('implement');\n460\t          yield { type: 'text' as const, text: 'Done' };\n461\t          yield { type: 'result' as const, cost: 0.05, sessionId: 'sess-abc' };\n462\t        })();\n463\t      });\n464\t\n465\t      const config = makeConfig({\n466\t        workflow: makeWorkflow({\n467\t          tasks: {\n468\t            implement: makeTask({ agent: 'dev', scope: 'per-story' }),\n469\t            telemetry: makeTask({ agent: null, scope: 'per-story' }),\n470\t          },\n471\t          flow: ['implement', 'telemetry'],\n472\t        }),\n473\t        agents: { dev: makeDefinition() },\n474\t      });\n475\t\n476\t      // Only one story for clearer order tracking\n477\t      mockParse.mockReturnValue({\n478\t        development_status: { 'story-1': 'ready-for-dev' },\n479\t      });\n480\t\n481\t      const result = await executeWorkflow(config);\n482\t\n483\t      expect(result.success).toBe(true);\n484\t      // implement runs first, then telemetry\n485\t      expect(executionOrder[0]).toBe('implement');\n486\t      expect(executionOrder[1]).toBe('telemetry');\n487\t    });\n488\t  });\n489\t\n490\t  describe('AC #8: null task OutputContract has driver=engine, cost_usd=0', () => {\n491\t    it('produces contract with engine driver and zero cost', async () => {\n492\t      // After the null task runs, the engine writes state. We can check the\n493\t      // result through the flow — a subsequent task should receive the contract.\n494\t      let receivedContract: unknown = null;\n495\t\n496\t      mockGetNullTask.mockImplementation((name: string) => {\n497\t        if (name === 'telemetry') {\n498\t          return async () => ({ success: true, output: 'data' });\n499\t        }\n500\t        if (name === 'after-telemetry') {\n501\t          return async (ctx: { outputContract: unknown }) => {\n502\t            receivedContract = ctx.outputContract;\n503\t            return { success: true };\n504\t          };\n505\t        }\n506\t        return undefined;\n507\t      });\n508\t\n509\t      const config = makeConfig({\n510\t        workflow: makeWorkflow({\n511\t          tasks: {\n512\t            telemetry: makeTask({ agent: null, scope: 'per-run' }),\n513\t            'after-telemetry': makeTask({ agent: null, scope: 'per-run' }),\n514\t          },\n515\t          flow: ['telemetry', 'after-telemetry'],\n516\t        }),\n517\t        agents: {},\n518\t      });\n519\t\n520\t      await executeWorkflow(config);\n521\t\n522\t      expect(receivedContract).not.toBeNull();\n523\t      const contract = receivedContract as OutputContract;\n524\t      expect(contract.driver).toBe('engine');\n525\t      expect(contract.model).toBe('null');\n526\t      expect(contract.cost_usd).toBe(0);\n527\t    });\n528\t  });\n529\t\n530\t  describe('crash recovery: skips completed null tasks', () => {\n531\t    it('skips null task with existing checkpoint', async () => {\n532\t      mockReadWorkflowState.mockReturnValue(makeDefaultState({\n533\t        phase: 'executing',\n534\t        tasks_completed: [\n535\t          { task_name: 'telemetry', story_key: '__run__', completed_at: '2026-04-03T00:00:00.000Z' },\n536\t        ],\n537\t      }));\n538\t\n539\t      const config = makeConfig({\n540\t        workflow: makeWorkflow({\n541\t          tasks: {\n542\t            telemetry: makeTask({ agent: null, scope: 'per-run' }),\n543\t          },\n544\t          flow: ['telemetry'],\n545\t        }),\n546\t        agents: {},\n547\t      });\n548\t\n549\t      const result = await executeWorkflow(config);\n550\t\n551\t      expect(result.success).toBe(true);\n552\t      expect(result.tasksCompleted).toBe(0); // skipped\n553\t      expect(mockGetNullTask).not.toHaveBeenCalled();\n554\t    });\n555\t  });\n556\t\n557\t  describe('per-story null task iterates all work items', () => {\n558\t    it('calls handler once per work item', async () => {\n559\t      const storyKeys: string[] = [];\n560\t      mockGetNullTask.mockImplementation((name: string) => {\n561\t        if (name === 'telemetry') {\n562\t          return async (ctx: { storyKey: string }) => {\n563\t            storyKeys.push(ctx.storyKey);\n564\t            return { success: true };\n565\t          };\n566\t        }\n567\t        return undefined;\n568\t      });\n569\t\n570\t      // Two stories\n571\t      mockParse.mockReturnValue({\n572\t        development_status: {\n573\t          'story-a': 'ready-for-dev',\n574\t          'story-b': 'backlog',\n575\t        },\n576\t      });\n577\t\n578\t      const config = makeConfig({\n579\t        workflow: makeWorkflow({\n580\t          tasks: {\n581\t            telemetry: makeTask({ agent: null, scope: 'per-story' }),\n582\t          },\n583\t          flow: ['telemetry'],\n584\t        }),\n585\t        agents: {},\n586\t      });\n587\t\n588\t      const result = await executeWorkflow(config);\n589\t\n590\t      expect(result.success).toBe(true);\n591\t      expect(storyKeys).toContain('story-a');\n592\t      expect(storyKeys).toContain('story-b');\n593\t      expect(storyKeys).toHaveLength(2);\n594\t    });\n595\t  });\n596\t\n597\t  describe('per-run null task runs once with sentinel key', () => {\n598\t    it('calls handler once with __run__ sentinel', async () => {\n599\t      const storyKeys: string[] = [];\n600\t      mockGetNullTask.mockImplementation((name: string) => {\n601\t        if (name === 'telemetry') {\n602\t          return async (ctx: { storyKey: string }) => {\n603\t            storyKeys.push(ctx.storyKey);\n604\t            return { success: true };\n605\t          };\n606\t        }\n607\t        return undefined;\n608\t      });\n609\t\n610\t      const config = makeConfig({\n611\t        workflow: makeWorkflow({\n612\t          tasks: {\n613\t            telemetry: makeTask({ agent: null, scope: 'per-run' }),\n614\t          },\n615\t          flow: ['telemetry'],\n616\t        }),\n617\t        agents: {},\n618\t      });\n619\t\n620\t      const result = await executeWorkflow(config);\n621\t\n622\t      expect(result.success).toBe(true);\n623\t      expect(storyKeys).toEqual(['__run__']);\n624\t    });\n625\t  });\n626\t\n627\t  describe('checkDriverHealth skips null agent tasks', () => {\n628\t    it('does not call getDriver for tasks with agent: null', async () => {\n629\t      const workflow = makeWorkflow({\n630\t        tasks: {\n631\t          implement: makeTask({ agent: 'dev' }),\n632\t          telemetry: makeTask({ agent: null }),\n633\t        },\n634\t        flow: ['implement', 'telemetry'],\n635\t      });\n636\t\n637\t      await checkDriverHealth(workflow);\n638\t\n639\t      // getDriver should be called for 'claude-code' (from implement) but NOT for telemetry\n640\t      expect(mockGetDriver).toHaveBeenCalledTimes(1);\n641\t    });\n642\t  });\n643\t\n644\t  describe('null task in loop block', () => {\n645\t    it('executes null tasks within loop iterations', async () => {\n646\t      const callCount = { telemetry: 0 };\n647\t      mockGetNullTask.mockImplementation((name: string) => {\n648\t        if (name === 'telemetry') {\n649\t          return async () => {\n650\t            callCount.telemetry++;\n651\t            return { success: true, output: 'loop telemetry' };\n652\t          };\n653\t        }\n654\t        return undefined;\n655\t      });\n656\t\n657\t      const loopBlock = { loop: ['telemetry'] };\n658\t      const state = makeDefaultState({ started: '2026-04-03T00:00:00.000Z' });\n659\t      const config = makeConfig({\n660\t        workflow: makeWorkflow({\n661\t          tasks: {\n662\t            telemetry: makeTask({ agent: null, scope: 'per-run' }),\n663\t          },\n664\t          flow: [loopBlock],\n665\t        }),\n666\t        agents: {},\n667\t        maxIterations: 1,\n668\t      });\n669\t\n670\t      const workItems: WorkItem[] = [{ key: 'story-1', source: 'sprint' }];\n671\t\n672\t      const loopResult = await executeLoopBlock(loopBlock, state, config, workItems);\n673\t\n674\t      expect(loopResult.tasksCompleted).toBeGreaterThanOrEqual(1);\n675\t      expect(callCount.telemetry).toBeGreaterThanOrEqual(1);\n676\t    });\n677\t  });\n678\t\n679\t  describe('performance: null task completes in <10ms (AC #6)', () => {\n680\t    it('null task dispatch and checkpoint takes less than 10ms', async () => {\n681\t      // Use a fast handler\n682\t      mockGetNullTask.mockImplementation((name: string) => {\n683\t        if (name === 'telemetry') {\n684\t          return async () => ({ success: true });\n685\t        }\n686\t        return undefined;\n687\t      });\n688\t\n689\t      const config = makeConfig({\n690\t        workflow: makeWorkflow({\n691\t          tasks: {\n692\t            telemetry: makeTask({ agent: null, scope: 'per-run' }),\n693\t          },\n694\t          flow: ['telemetry'],\n695\t        }),\n696\t        agents: {},\n697\t      });\n698\t\n699\t      const start = performance.now();\n700\t      await executeWorkflow(config);\n701\t      const elapsed = performance.now() - start;\n702\t\n703\t      // The total time includes setup overhead (state read/write mocks),\n704\t      // but the actual null task path should be well under 10ms.\n705\t      // We give a generous 50ms budget for the whole executeWorkflow call.\n706\t      expect(elapsed).toBeLessThan(50);\n707\t    });\n708\t  });\n709\t});\n710\t"}]},"parent_tool_use_id":"toolu_011ZTgKSKa4gwyUPFY6UYukh","session_id":"8a461711-53e2-475a-88dd-c7013f6080c5","uuid":"aa10cf03-40e7-4b38-80b0-340d8962de9f","timestamp":"2026-04-03T17:20:40.063Z"}
