{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016AHFyX1dhvmLGwFoAz8cAy","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→\n     3→vi.mock('node:child_process', () => ({\n     4→  execFileSync: vi.fn(),\n     5→}));\n     6→\n     7→vi.mock('node:fs', async () => {\n     8→  const actual = await vi.importActual<typeof import('node:fs')>('node:fs');\n     9→  return {\n    10→    ...actual,\n    11→    writeFileSync: vi.fn(),\n    12→  };\n    13→});\n    14→\n    15→vi.mock('../stack-path.js', () => ({\n    16→  getComposeFilePath: vi.fn(() => '/mock/.codeharness/stack/docker-compose.harness.yml'),\n    17→  getOtelConfigPath: vi.fn(() => '/mock/.codeharness/stack/otel-collector-config.yaml'),\n    18→  ensureStackDir: vi.fn(),\n    19→}));\n    20→\n    21→vi.mock('../../templates/docker-compose.js', () => ({\n    22→  dockerComposeTemplate: vi.fn(() => '# compose content'),\n    23→  dockerComposeCollectorOnlyTemplate: vi.fn(() => '# collector-only content'),\n    24→}));\n    25→\n    26→vi.mock('../../templates/otel-config.js', () => ({\n    27→  otelCollectorConfigTemplate: vi.fn(() => '# otel content'),\n    28→  otelCollectorRemoteTemplate: vi.fn(() => '# remote otel content'),\n    29→}));\n    30→\n    31→import {\n    32→  isDockerAvailable,\n    33→  isDockerComposeAvailable,\n    34→  isStackRunning,\n    35→  startStack,\n    36→  stopStack,\n    37→  getStackHealth,\n    38→  isSharedStackRunning,\n    39→  startSharedStack,\n    40→  stopSharedStack,\n    41→  startCollectorOnly,\n    42→  isCollectorRunning,\n    43→  stopCollectorOnly,\n    44→  getCollectorHealth,\n    45→  checkRemoteEndpoint,\n    46→} from '../docker.js';\n    47→import { execFileSync } from 'node:child_process';\n    48→import { writeFileSync } from 'node:fs';\n    49→import { ensureStackDir } from '../stack-path.js';\n    50→const mockExecFileSync = vi.mocked(execFileSync);\n    51→const mockWriteFileSync = vi.mocked(writeFileSync);\n    52→const mockEnsureStackDir = vi.mocked(ensureStackDir);\n    53→\n    54→beforeEach(() => {\n    55→  vi.clearAllMocks();\n    56→});\n    57→\n    58→describe('isDockerAvailable', () => {\n    59→  it('returns true when docker command succeeds', () => {\n    60→    mockExecFileSync.mockReturnValue(Buffer.from('Docker version 24.0.0'));\n    61→    expect(isDockerAvailable()).toBe(true);\n    62→    expect(mockExecFileSync).toHaveBeenCalledWith('docker', ['--version'], { stdio: 'pipe', timeout: 10_000 });\n    63→  });\n    64→\n    65→  it('returns false when docker command fails', () => {\n    66→    mockExecFileSync.mockImplementation(() => {\n    67→      throw new Error('command not found: docker');\n    68→    });\n    69→    expect(isDockerAvailable()).toBe(false);\n    70→  });\n    71→});\n    72→\n    73→describe('isDockerComposeAvailable', () => {\n    74→  it('returns true when docker compose version succeeds', () => {\n    75→    mockExecFileSync.mockReturnValue(Buffer.from('Docker Compose version v2.24.0'));\n    76→    expect(isDockerComposeAvailable()).toBe(true);\n    77→    expect(mockExecFileSync).toHaveBeenCalledWith('docker', ['compose', 'version'], { stdio: 'pipe', timeout: 10_000 });\n    78→  });\n    79→\n    80→  it('returns false when docker compose is not available', () => {\n    81→    mockExecFileSync.mockImplementation(() => {\n    82→      throw new Error('docker compose not found');\n    83→    });\n    84→    expect(isDockerComposeAvailable()).toBe(false);\n    85→  });\n    86→});\n    87→\n    88→describe('isStackRunning', () => {\n    89→  it('returns true when all services are running', () => {\n    90→    const jsonOutput = [\n    91→      '{\"Service\":\"victoria-logs\",\"State\":\"running\"}',\n    92→      '{\"Service\":\"victoria-metrics\",\"State\":\"running\"}',\n    93→    ].join('\\n');\n    94→    mockExecFileSync.mockReturnValue(Buffer.from(jsonOutput));\n    95→    exp