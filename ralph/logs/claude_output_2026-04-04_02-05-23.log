rror', async () => {\n441\t      mockReadFileSync.mockReturnValue('conflict');\n442\t      mockExecSync.mockImplementation(() => {\n443\t        throw new Error('git state corrupted');\n444\t      });\n445\t\n446\t      const driver = createMockDriver({\n447\t        dispatchFn: async function* () {\n448\t          throw new Error('Network error');\n449\t        },\n450\t      });\n451\t\n452\t      const ctx = createContext({ driver });\n453\t      const result = await resolveConflicts(ctx);\n454\t\n455\t      expect(result.resolved).toBe(false);\n456\t      expect(result.escalated).toBe(true);\n457\t      expect(result.attempts).toBe(1);\n458\t    });\n459\t  });\n460\t\n461\t  describe('resolveConflicts — test command failure edge cases', () => {\n462\t    it('handles test command that throws with partial stdout', async () => {\n463\t      mockReadFileSync.mockReturnValue('conflict');\n464\t      // Allow git reset to succeed\n465\t      mockExecSync.mockReturnValue('');\n466\t\n467\t      // First call: test command throws with partial output containing pass/fail\n468\t      // Second call: tests pass\n469\t      let callCount = 0;\n470\t      mockExecAsync.mockImplementation(async () => {\n471\t        callCount++;\n472\t        if (callCount === 1) {\n473\t          const err = new Error('Command failed') as Error & { stdout: string };\n474\t          err.stdout = '3 passed\\n2 failed\\nError: some test error';\n475\t          throw err;\n476\t        }\n477\t        return { stdout: '5 passed\\n0 failed' };\n478\t      });\n479\t\n480\t      const ctx = createContext();\n481\t      const result = await resolveConflicts(ctx);\n482\t\n483\t      expect(result.resolved).toBe(true);\n484\t      expect(result.attempts).toBe(2);\n485\t    });\n486\t\n487\t    it('handles test command that throws with no output', async () => {\n488\t      mockReadFileSync.mockReturnValue('conflict');\n489\t      // Allow git reset to succeed\n490\t      mockExecSync.mockReturnValue('');\n491\t\n492\t      mockExecAsync.mockImplementation(async () => {\n493\t        const err = new Error('Command failed') as Error & { stdout: string };\n494\t        err.stdout = '';\n495\t        throw err;\n496\t      });\n497\t\n498\t      const ctx = createContext();\n499\t      const result = await resolveConflicts(ctx);\n500\t\n501\t      // Should exhaust retries and escalate\n502\t      expect(result.resolved).toBe(false);\n503\t      expect(result.attempts).toBe(3);\n504\t      expect(result.escalated).toBe(true);\n505\t    });\n506\t  });\n507\t\n508\t  describe('resolveConflicts — git reset failure during retry', () => {\n509\t    it('escalates immediately if git reset fails after test failure', async () => {\n510\t      mockReadFileSync.mockReturnValue('conflict');\n511\t      mockExecAsync.mockResolvedValue({ stdout: '2 passed\\n1 failed' });\n512\t      mockExecSync.mockImplementation(() => {\n513\t        throw new Error('git state corrupted');\n514\t      });\n515\t\n516\t      const ctx = createContext();\n517\t      const result = await resolveConflicts(ctx);\n518\t\n519\t      expect(result.resolved).toBe(false);\n520\t      expect(result.escalated).toBe(true);\n521\t      expect(result.escalationMessage).toContain('/repo');\n522\t    });\n523\t  });\n524\t});\n525\t"}]},"parent_tool_use_id":"toolu_01KN13KxQzTPDh38EUNUPmae","session_id":"22206bba-5847-41b1-b510-883e1dd8c0da","uuid":"0831aa72-d3fe-4539-92d4-b220950b75bd","timestamp":"2026-04-03T22:22:33.821Z"}
