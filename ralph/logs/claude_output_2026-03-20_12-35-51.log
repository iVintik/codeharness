{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WRcVi9vYa1myCWADtXUUAn","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→\n     3→// Mock all I/O: filesystem, subprocess, HTTP\n     4→vi.mock('node:fs', () => ({\n     5→  existsSync: vi.fn(),\n     6→  readFileSync: vi.fn(),\n     7→  readdirSync: vi.fn(),\n     8→}));\n     9→\n    10→vi.mock('../../observability/index.js', () => ({\n    11→  analyze: vi.fn(),\n    12→  validateRuntime: vi.fn(),\n    13→}));\n    14→\n    15→vi.mock('../../../lib/coverage.js', () => ({\n    16→  checkOnlyCoverage: vi.fn(),\n    17→}));\n    18→\n    19→vi.mock('../../../lib/doc-health.js', () => ({\n    20→  scanDocHealth: vi.fn(),\n    21→}));\n    22→\n    23→vi.mock('../../verify/index.js', () => ({\n    24→  parseProof: vi.fn(),\n    25→}));\n    26→\n    27→import { existsSync, readFileSync, readdirSync } from 'node:fs';\n    28→import { analyze, validateRuntime } from '../../observability/index.js';\n    29→import { checkOnlyCoverage } from '../../../lib/coverage.js';\n    30→import { scanDocHealth } from '../../../lib/doc-health.js';\n    31→import { parseProof } from '../../verify/index.js';\n    32→import {\n    33→  checkObservability,\n    34→  checkTesting,\n    35→  checkDocumentation,\n    36→  checkVerification,\n    37→  checkInfrastructure,\n    38→} from '../dimensions.js';\n    39→\n    40→const mockExistsSync = vi.mocked(existsSync);\n    41→const mockReadFileSync = vi.mocked(readFileSync);\n    42→const mockReaddirSync = vi.mocked(readdirSync);\n    43→const mockAnalyze = vi.mocked(analyze);\n    44→const mockValidateRuntime = vi.mocked(validateRuntime);\n    45→const mockCheckOnlyCoverage = vi.mocked(checkOnlyCoverage);\n    46→const mockScanDocHealth = vi.mocked(scanDocHealth);\n    47→const mockParseProof = vi.mocked(parseProof);\n    48→\n    49→beforeEach(() => {\n    50→  vi.clearAllMocks();\n    51→});\n    52→\n    5