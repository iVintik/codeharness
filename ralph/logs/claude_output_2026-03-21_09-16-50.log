s.some(g => g.description.includes('No verification proofs'))).toBe(true);\n   517→    }\n   518→  });\n   519→\n   520→  it('returns warn when checkVerification outer catch fires', () => {\n   521→    mockExistsSync.mockImplementation(() => {\n   522→      throw new Error('Filesystem error');\n   523→    });\n   524→\n   525→    const result = checkVerification('/project');\n   526→    expect(result.success).toBe(true);\n   527→    if (result.success) {\n   528→      expect(result.data.status).toBe('warn');\n   529→      expect(result.data.gaps[0].description).toContain('Filesystem error');\n   530→    }\n   531→  });\n   532→\n   533→  it('returns warn when no proofs found', () => {\n   534→    mockExistsSync.mockImplementation((p: unknown) => {\n   535→      const path = String(p);\n   536→      if (path.includes('sprint-status.yaml')) return true;\n   537→      return false;\n   538→    });\n   539→\n   540→    const result = checkVerification('/project');\n   541→    expect(result.success).toBe(true);\n   542→    if (result.success) {\n   543→      expect(result.data.status).toBe('warn');\n   544→      expect(result.data.gaps.some(g => g.description.includes('No verification proofs'))).toBe(true);\n   545→    }\n   546→  });\n   547→});\n   548→\n   549→// ─── checkInfrastructure ────────────────────────────────────────────────────\n   550→\n   551→describe('checkInfrastructure', () => {\n   552→  it('returns fail when no Dockerfile', () => {\n   553→    mockExistsSync.mockReturnValue(false);\n   554→\n   555→    const result = checkInfrastructure('/project');\n   556→    expect(result.success).toBe(true);\n   557→    if (result.success) {\n   558→      expect(result.data.status).toBe('fail');\n   559→      expect(result.data.metric).toBe('no Dockerfile');\n   560→      expect(result.data.gaps[0].description).toBe('No Dockerfile found');\n   561→    }\n   562→  });\n   563→\n   564→  it('returns pass with properly pinned Dockerfile', () => {\n   565→    mockExi