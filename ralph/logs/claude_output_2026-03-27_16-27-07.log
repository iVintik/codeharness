{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0143aGEgpQR8KpGzLU3DePGD","type":"tool_result","content":"     1→/**\n     2→ * Tests for Story 16-5: harness-run verification dispatch rewrite.\n     3→ * Validates that commands/harness-run.md contains the four-tier routing\n     4→ * instead of the old binary unit-testable/black-box dispatch.\n     5→ */\n     6→\n     7→import { readFileSync } from 'node:fs';\n     8→import { resolve } from 'node:path';\n     9→import { describe, it, expect, beforeAll } from 'vitest';\n    10→\n    11→const HARNESS_RUN_PATH = resolve(__dirname, '../../../../commands/harness-run.md');\n    12→let content: string;\n    13→\n    14→beforeAll(() => {\n    15→  content = readFileSync(HARNESS_RUN_PATH, 'utf-8');\n    16→});\n    17→\n    18→// ─── AC1: Step 3d-0 derives tier from AC-level tags, not story-level tag ────\n    19→\n    20→describe('AC1: Step 3d-0 AC-level tier derivation', () => {\n    21→  it('contains instruction to ignore story-level verification-tier tag', () => {\n    22→    expect(content).toContain('Ignore the story-level `<!-- verification-tier: ... -->` tag');\n    23→  });\n    24→\n    25→  it('instructs to parse AC-level <!-- verification: {tier} --> tags', () => {\n    26→    expect(content).toContain('extract its `<!-- verification: {tier} -->` tag');\n    27→  });\n    28→\n    29→  it('references maxTier() for computing derived tier', () => {\n    30→    expect(content).toContain('maxTier(collectedTiers)');\n    31→  });\n    32→\n    33→  it('defaults to test-provable when no AC-level tags are found', () => {\n    34→    expect(content).toContain('If no AC-level tags are found at all, default to `test-provable`');\n    35→  });\n    36→});\n    37→\n    38→// ─── AC2: test-provable dispatch — build, test, code inspect ────────────────\n    39→\n    40→describe('AC2: test-provable verification dispatch', () => {\n    41→  it('has a test-provable verification section', () => {\n    42→    expect(content).toContain('**test-provable verification (derived tier = test-provable):**');\n    43→  });\n    44→\n    45→  it('mentions test-provable tier in the subagent prompt', () => {\n    46→    expect(content).toContain('test-provable tier');\n    47→  });\n    48→\n    49→  it('does NOT instruct to use Docker in the test-provable subagent prompt', () => {\n    50→    // Extract just the subagent prompt within the test-provable section\n    51→    const sectionStart = content.indexOf('**test-provable verification (derived tier = test-provable):**');\n    52→    const sectionEnd = content.indexOf('**runtime-provable verification (derived tier = runtime-provable):**');\n    53→    const section = content.slice(sectionStart, sectionEnd);\n    54→    // The subagent prompt itself should not reference Docker or codeharness stack start\n    55→    expect(section).not.toContain('codeharness stack start');\n    56→    expect(section).not.toContain('docker run');\n    57→    expect(section).not.toContain('docker exec');\n    58→    // The post-subagent note \"No Docker involved\" is fine — it's an instruction to skip Docker steps\n    59→    expect(section).toContain('No Docker involved at any point');\n    60→  });\n    61→});\n    62→\n    63→// ─── AC3: runtime-provable dispatch — build, run locally, interact ──────────\n    64→\n    65→describe('AC3: runtime-provable verification dispatch', () => {\n    66→  it('has a runtime-provable verification section', () => {\n    67→    expect(content).toContain('**runtime-provable verification (derived tier = runtime-provable):**');\n    68→  });\n    69→\n    70→  it('instructs to build and run the app locally', () => {\n    71→    const start = content.indexOf('**runtime-provable verification (derived tier = runtime-provable):**');\n    72→    const end = content.indexOf('**escalate verification (derived tier = escalate):**');\n    73→    const section = content.slice(start, end);\n    74→    expect(section).toCon