{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q791R1bQRZiTkeaiTazLig","type":"tool_result","content":"     1→/**\n     2→ * Audit dimension checkers — each wraps an existing module and maps\n     3→ * its output to DimensionResult. Each checker catches its own errors\n     4→ * and never throws (AC #6).\n     5→ *\n     6→ * Dimensions: observability, testing, documentation, verification, infrastructure.\n     7→ */\n     8→\n     9→import { existsSync, readFileSync, readdirSync } from 'node:fs';\n    10→import { join } from 'node:path';\n    11→import { ok, fail, isOk } from '../../types/result.js';\n    12→import type { Result } from '../../types/result.js';\n    13→import type { DimensionResult, AuditGap } from './types.js';\n    14→import { analyze, validateRuntime } from '../observability/index.js';\n    15→import type { AnalyzerResult, RuntimeValidationResult } from '../observability/index.js';\n    16→import { checkOnlyCoverage } from '../../lib/coverage.js';\n    17→import { scanDocHealth } from '../../lib/doc-health.js';\n    18→import { parseProof } from '../verify/index.js';\n    19→\n    20→// ─── Observability Dimension (Task 2.1) ─────────────────────────────────────\n    21→\n    22→export async function checkObservability(projectDir: string): Promise<Result<DimensionResult>> {\n    23→  try {\n    24→    const gaps: AuditGap[] = [];\n    25→\n    26→    // Static analysis via Semgrep\n    27→    let staticStatus: 'pass' | 'fail' | 'warn' = 'pass';\n    28→    let staticMetric = '';\n    29→    const staticResult = analyze(projectDir);\n    30→\n    31→    if (isOk(staticResult)) {\n    32→      const data: AnalyzerResult = staticResult.data;\n    33→      if (data.skipped) {\n    34→        staticStatus = 'warn';\n    35→        staticMetric = `static: skipped (${data.skipReason ?? 'unknown'})`;\n    36→        gaps.push({\n    37→          dimension: 'observability',\n    38→          description: `Static analysis skipped: ${data.skipReason ?? 'Semgrep not installed'}`,\n    39→          suggestedFix: 'Install Semgrep: pip install semgrep',\n    40→        });\n    41→      } else {\n    42→        const gapCount = data.gaps.length;\n    43→        staticMetric = `static: ${gapCount} gap${gapCount !== 1 ? 's' : ''}`;\n    44→        if (gapCount > 0) {\n    45→          staticStatus = 'warn';\n    46→          for (const gap of data.gaps) {\n    47→            gaps.push({\n    48→              dimension: 'observability',\n    49→              description: `${gap.file}:${gap.line} — ${gap.message}`,\n    50→              suggestedFix: gap.fix ?? 'Add observability instrumentation',\n    51→            });\n    52→          }\n    53→        }\n    54→      }\n    55→    } else {\n    56→      staticStatus = 'warn';\n    57→      staticMetric = 'static: skipped (analysis failed)';\n    58→      gaps.push({\n    59→        dimension: 'observability',\n    60→        description: `Static analysis failed: ${staticResult.error}`,\n    61→        suggestedFix: 'Check Semgrep installation and rules configuration',\n    62→      });\n    63→    }\n    64→\n    65→    // Runtime validation\n    66→    let runtimeStatus: 'pass' | 'fail' | 'warn' = 'pass';\n    67→    let runtimeMetric = '';\n    68→    try {\n    69→      const runtimeResult = await validateRuntime(projectDir);\n    70→\n    71→      if (isOk(runtimeResult)) {\n    72→        const data: RuntimeValidationResult = runtimeResult.data;\n    73→        if (data.skipped) {\n    74→          runtimeStatus = 'warn';\n    75→          runtimeMetric = `runtime: skipped (${data.skipReason ?? 'unknown'})`;\n    76→          gaps.push({\n    77→            dimension: 'observability',\n    78→            description: `Runtime validation skipped: ${data.skipReason ?? 'backend unreachable'}`,\n    79→            suggestedFix: 'Start the observability stack: codeharness stack up',\n    80→          });\n    81→        } else {\n    82→          runtimeMetric = `runtime: ${data.coveragePercent}%`;\n    83→          if (data.coveragePercent < 50) {\n    84→            runtimeStatus = 'warn';\n    85→            gaps.push({\n    86→              dimension: 'observability',\n    87→              description: `Runtime coverage low: ${data.coveragePercent}%`,\n    88→              suggestedFix: 'Add telemetry instrumentation to more modules',\n    89→            });\n    90→          }\n    91→        }\n    92→      } else {\n    93→        runtimeStatus = 'warn';\n    94→        runtimeMetric = 'runtime: skipped (validation failed)';\n    95→        gaps.push({\n    96→          dimension: 'observability',\n    97→          description: `Runtime validation failed: ${runtimeResult.error}`,\n    98→          suggestedFix: 'Ensure observability backend is running',\n    99→        });\n   100→      }\n   101→    } catch {\n   102→      runtimeStatus = 'warn';\n   103→      runtimeMetric = 'runtime: skipped (error)';\n   104→      gaps.push({\n   105→        dimension: 'observability',\n   106→        description: 'Runtime validation threw an unexpected error',\n   107→        suggestedFix: 'Check observability stack health',\n   108→      });\n   109→    }\n   110→\n   111→    // Combine statuses: worst of static and runtime\n   112→    const status = combineStatuses(staticStatus, runtimeStatus);\n   113→    const metric = `${staticMetric}, ${runtimeMetric}`;\n   114→\n   115→    return ok({ name: 'observability', status, metric, gaps });\n   116→  } catch (err: unknown) {\n   117→    const message = err instanceof Error ? err.message : String(err);\n   118→    return ok({\n   119→      name: 'observability',\n   120→      status: 'warn',\n   121→      metric: 'skipped (error)',\n   122→      gaps: [{\n   123→        dimension: 'observability',\n   124→        description: `Observability check failed: ${message}`,\n   125→        suggestedFix: 'Check Semgrep and observability stack configuration',\n   126→      }],\n   127→    });\n   128→  }\n   129→}\n   130→\n   131→// ─── Testing Dimension (Task 2.2) ───────────────────────────────────────────\n   132→\n   133→export function checkTesting(projectDir: string): Result<DimensionResult> {\n   134→  try {\n   135→    const result = checkOnlyCoverage(projectDir);\n   136→    const gaps: AuditGap[] = [];\n   137→\n   138→    if (!result.success) {\n   139→      return ok({\n   140→        name: 'testing',\n   141→        status: 'warn',\n   142→        metric: 'no coverage data',\n   143→        gaps: [{\n   144→          dimension: 'testing',\n   145→          description: 'No coverage tool detected or coverage data unavailable',\n   146→          suggestedFix: 'Run tests with coverage: npm run test:coverage',\n   147→        }],\n   148→      });\n   149→    }\n   150→\n   151→    const pct = result.coveragePercent;\n   152→    let status: 'pass' | 'fail' | 'warn' = 'pass';\n   153→\n   154→    if (pct < 50) {\n   155→      status = 'fail';\n   156→      gaps.push({\n   157→        dimension: 'testing',\n   158→        description: `Test coverage critically low: ${pct}%`,\n   159→        suggestedFix: 'Add unit tests to increase coverage above 50%',\n   160→      });\n   161→    } else if (pct < 80) {\n   162→      status = 'warn';\n   163→      gaps.push({\n   164→        dimension: 'testing',\n   165→        description: `Test coverage below target: ${pct}%`,\n   166→        suggestedFix: 'Add tests to reach 80% coverage target',\n   167→      });\n   168→    }\n   169→\n   170→    return ok({ name: 'testing', status, metric: `${pct}%`, gaps });\n   171→  } catch (err: unknown) {\n   172→    const message = err instanceof Error ? err.message : String(err);\n   173→    return ok({\n   174→      name: 'testing',\n   175→      status: 'warn',\n   176→      metric: 'error',\n   177→      gaps: [{\n   178→        dimension: 'testing',\n   179→        description: `Testing check failed: ${message}`,\n   180→        suggestedFix: 'Ensure test runner is configured',\n   181→      }],\n   182→    });\n   183→  }\n   184→}\n   185→\n   186→// ─── Documentation Dimension (Task 2.3) ─────────────────────────────────────\n   187→\n   188→export function checkDocumentation(projectDir: string): Result<DimensionResult> {\n   189→  try {\n   190→    const report = scanDocHealth(projectDir);\n   191→    const gaps: AuditGap[] = [];\n   192→\n   193→    const { fresh, stale, missing } = report.summary;\n   194→    let status: 'pass' | 'fail' | 'warn' = 'pass';\n   195→\n   196→    if (missing > 0) {\n   197→      status = 'fail';\n   198→      for (const doc of report.documents) {\n   199→        if (doc.grade === 'missing') {\n   200→          gaps.push({\n   201→            dimension: 'documentation',\n   202→            description: `Missing: ${doc.path} — ${doc.reason}`,\n   203→            suggestedFix: `Create ${doc.path}`,\n   204→          });\n   205→        }\n   206→      }\n   207→    }\n   208→\n   209→    if (stale > 0) {\n   210→      if (status !== 'fail') status = 'warn';\n   211→      for (const doc of report.documents) {\n   212→        if (doc.grade === 'stale') {\n   213→          gaps.push({\n   214→            dimension: 'documentation',\n   215→            description: `Stale: ${doc.path} — ${doc.reason}`,\n   216→            suggestedFix: `Update ${doc.path} to reflect current code`,\n   217→          });\n   218→        }\n   219→      }\n   220→    }\n   221→\n   222→    const metric = `${fresh} fresh, ${stale} stale, ${missing} missing`;\n   223→    return ok({ name: 'documentation', status, metric, gaps });\n   224→  } catch (err: unknown) {\n   225→    const message = err instanceof Error ? err.message : String(err);\n   226→    return ok({\n   227→      name: 'documentation',\n   228→      status: 'warn',\n   229→      metric: 'error',\n   230→      gaps: [{\n   231→        dimension: 'documentation',\n   232→        description: `Documentation check failed: ${message}`,\n   233→        suggestedFix: 'Run codeharness doc-health for details',\n   234→      }],\n   235→    });\n   236→  }\n   237→}\n   238→\n   239→// ─── Verification Dimension (Task 2.4) ──────────────────────────────────────\n   240→\n   241→export function checkVerification(projectDir: string): Result<DimensionResult> {\n   242→  try {\n   243→    const gaps: AuditGap[] = [];\n   244→\n   245→    // Try reading sprint-state.json for verification status\n   246→    const sprintStatePath = join(projectDir, '_bmad-output', 'implementation-artifacts', 'sprint-status.yaml');\n   247→    if (!existsSync(sprintStatePath)) {\n   248→      return ok({\n   249→        name: 'verification',\n   250→        status: 'warn',\n   251→        metric: 'no sprint data',\n   252→        gaps: [{\n   253→          dimension: 'verification',\n   254→          description: 'No sprint-status.yaml found',\n   255→          suggestedFix: 'Run sprint planning to create sprint status',\n   256→        }],\n   257→      });\n   258→    }\n   259→\n   260→    // Check for proof documents in verification/ or docs/exec-plans/\n   261→    const verificationDir = join(projectDir, 'verification');\n   262→    const proofDir = join(projectDir, 'docs', 'exec-plans', 'active');\n   263→    let proofCount = 0;\n   264→    let totalChecked = 0;\n   265→\n   266→    // Scan proof documents\n   267→    if (existsSync(verificationDir)) {\n   268→      const files = readdirSafe(verificationDir);\n   269→      for (const file of files) {\n   270→        if (file.endsWith('-proof.md')) {\n   271→          totalChecked++;\n   272→          const proofPath = join(verificationDir, file);\n   273→          const result = parseProof(proofPath);\n   274→          if (isOk(result) && result.data.passed) {\n   275→            proofCount++;\n   276→          } else {\n   277→            const storyKey = file.replace('-proof.md', '');\n   278→            gaps.push({\n   279→              dimension: 'verification',\n   280→              description: `Story ${storyKey} proof incomplete or failing`,\n   281→              suggestedFix: `Run codeharness verify ${storyKey}`,\n   282→            });\n   283→          }\n   284→        }\n   285→      }\n   286→    }\n   287→\n   288→    let status: 'pass' | 'fail' | 'warn' = 'pass';\n   289→    if (totalChecked === 0) {\n   290→      status = 'warn';\n   291→      gaps.push({\n   292→        dimension: 'verification',\n   293→        description: 'No verification proofs found',\n   294→        suggestedFix: 'Run codeharness verify for completed stories',\n   295→      });\n   296→    } else if (proofCount < totalChecked) {\n   297→      status = 'warn';\n   298→    }\n   299→\n   300→    const metric = totalChecked > 0\n   301→      ? `${proofCount}/${totalChecked} verified`\n   302→      : 'no proofs';\n   303→\n   304→    return ok({ name: 'verification', status, metric, gaps });\n   305→  } catch (err: unknown) {\n   306→    const message = err instanceof Error ? err.message : String(err);\n   307→    return ok({\n   308→      name: 'verification',\n   309→      status: 'warn',\n   310→      metric: 'error',\n   311→      gaps: [{\n   312→        dimension: 'verification',\n   313→        description: `Verification check failed: ${message}`,\n   314→        suggestedFix: 'Check verification configuration',\n   315→      }],\n   316→    });\n   317→  }\n   318→}\n   319→\n   320→// ─── Infrastructure Dimension (Task 2.5) ────────────────────────────────────\n   321→\n   322→export function checkInfrastructure(projectDir: string): Result<DimensionResult> {\n   323→  try {\n   324→    const gaps: AuditGap[] = [];\n   325→    const dockerfilePath = join(projectDir, 'Dockerfile');\n   326→\n   327→    if (!existsSync(dockerfilePath)) {\n   328→      return ok({\n   329→        name: 'infrastructure',\n   330→        status: 'fail',\n   331→        metric: 'no Dockerfile',\n   332→        gaps: [{\n   333→          dimension: 'infrastructure',\n   334→          description: 'No Dockerfile found',\n   335→          suggestedFix: 'Create a Dockerfile for containerized deployment',\n   336→        }],\n   337→      });\n   338→    }\n   339→\n   340→    // Basic structural validation — check for pinned base image\n   341→    let content: string;\n   342→    try {\n   343→      content = readFileSync(dockerfilePath, 'utf-8');\n   344→    } catch {\n   345→      return ok({\n   346→        name: 'infrastructure',\n   347→        status: 'warn',\n   348→        metric: 'Dockerfile unreadable',\n   349→        gaps: [{\n   350→          dimension: 'infrastructure',\n   351→          description: 'Dockerfile exists but could not be read',\n   352→          suggestedFix: 'Check Dockerfile permissions',\n   353→        }],\n   354→      });\n   355→    }\n   356→\n   357→    const fromLines = content\n   358→      .split('\\n')\n   359→      .filter(line => /^\\s*FROM\\s+/i.test(line));\n   360→\n   361→    if (fromLines.length === 0) {\n   362→      gaps.push({\n   363→        dimension: 'infrastructure',\n   364→        description: 'Dockerfile has no FROM instruction',\n   365→        suggestedFix: 'Add a FROM instruction with a pinned base image',\n   366→      });\n   367→      return ok({ name: 'infrastructure', status: 'fail', metric: 'invalid Dockerfile', gaps });\n   368→    }\n   369→\n   370→    let hasUnpinned = false;\n   371→    for (const line of fromLines) {\n   372→      // Check for :latest or no tag at all (just image name)\n   373→      const imageRef = line.replace(/^\\s*FROM\\s+/i, '').split(/\\s+/)[0];\n   374→      if (imageRef.endsWith(':latest')) {\n   375→        hasUnpinned = true;\n   376→        gaps.push({\n   377→          dimension: 'infrastructure',\n   378→          description: `Unpinned base image: ${imageRef}`,\n   379→          suggestedFix: `Pin ${imageRef} to a specific version tag`,\n   380→        });\n   381→      } else if (!imageRef.includes(':') && !imageRef.includes('@')) {\n   382→        hasUnpinned = true;\n   383→        gaps.push({\n   384→          dimension: 'infrastructure',\n   385→          description: `Unpinned base image (no tag): ${imageRef}`,\n   386→          suggestedFix: `Pin ${imageRef} to a specific version tag (e.g., ${imageRef}:22-slim)`,\n   387→        });\n   388→      }\n   389→    }\n   390→\n   391→    const status: 'pass' | 'fail' | 'warn' = hasUnpinned ? 'warn' : 'pass';\n   392→    const metric = hasUnpinned\n   393→      ? `Dockerfile exists (${gaps.length} issue${gaps.length !== 1 ? 's' : ''})`\n   394→      : 'Dockerfile valid';\n   395→\n   396→    return ok({ name: 'infrastructure', status, metric, gaps });\n   397→  } catch (err: unknown) {\n   398→    const message = err instanceof Error ? err.message : String(err);\n   399→    return ok({\n   400→      name: 'infrastructure',\n   401→      status: 'warn',\n   402→      metric: 'error',\n   403→      gaps: [{\n   404→        dimension: 'infrastructure',\n   405→        description: `Infrastructure check failed: ${message}`,\n   406→        suggestedFix: 'Check Dockerfile and project structure',\n   407→      }],\n   408→    });\n   409→  }\n   410→}\n   411→\n   412→// ─── Helpers ────────────────────────────────────────────────────────────────\n   413→\n   414→function combineStatuses(\n   415→  ...statuses: Array<'pass' | 'fail' | 'warn'>\n   416→): 'pass' | 'fail' | 'warn' {\n   417→  if (statuses.includes('fail')) return 'fail';\n   418→  if (statuses.includes('warn')) return 'warn';\n   419→  return 'pass';\n   420→}\n   421→\n   422→function readdirSafe(dir: string): string[] {\n   423→  try {\n   424→    return readdirSync(dir) as string[];\n   425→  } catch {\n   426→    return [];\n   427→  }\n   428→}\n   429→"}]},"parent_tool_use_id":"toolu_01AdMUjsSRd2zQjpuDrBr3HX","session_id":"e1f3df9b-d919-466e-880e-1001c8652ee8","uuid":"f8444dac-1cff-4c99-8976-1f5df53d65a2","timestamp":"2026-03-20T08:47:00.422Z"}
