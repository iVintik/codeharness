lement'],\n1098\t      },\n1099\t    });\n1100\t\n1101\t    const result = await executeWorkflow(config);\n1102\t\n1103\t    expect(mockWarn).toHaveBeenCalledWith(\n1104\t      expect.stringContaining('task \"nonexistent-task\" not found'),\n1105\t    );\n1106\t    // implement should still run\n1107\t    expect(mockDriverDispatch).toHaveBeenCalledTimes(1);\n1108\t    expect(result.success).toBe(true);\n1109\t  });\n1110\t\n1111\t  it('halts on NETWORK dispatch errors for per-run tasks', async () => {\n1112\t    const { DispatchError } = await import('../agent-dispatch.js');\n1113\t    mockDriverDispatch.mockImplementation(() => makeDriverStreamError(\n1114\t      new DispatchError('network fail', 'NETWORK', 'dev', new Error('inner')),\n1115\t    ));\n1116\t\n1117\t    mockParse.mockReturnValue({\n1118\t      development_status: { '3-1-foo': 'ready-for-dev' },\n1119\t    });\n1120\t\n1121\t    const config = makeConfig({\n1122\t      workflow: {\n1123\t        tasks: {\n1124\t          implement: makeTask(),\n1125\t          verify: makeTask({ scope: 'per-run' }),\n1126\t        },\n1127\t        flow: ['verify', 'implement'],\n1128\t      },\n1129\t    });\n1130\t\n1131\t    const result = await executeWorkflow(config);\n1132\t\n1133\t    expect(result.success).toBe(false);\n1134\t    // Should halt after verify fails — implement never runs\n1135\t    expect(mockDriverDispatch).toHaveBeenCalledTimes(1);\n1136\t  });\n1137\t});\n1138\t\n1139\t// --- Loop Block Tests (Story 5-2) ---\n1140\t\n1141\tdescribe('parseVerdict (re-exported from verdict-parser)', () => {\n1142\t  it('parses valid verdict JSON', () => {\n1143\t    const verdict = parseVerdict(JSON.stringify({\n1144\t      verdict: 'pass',\n1145\t      score: { passed: 3, failed: 0, unknown: 0, total: 3 },\n1146\t      findings: [],\n1147\t    }));\n1148\t\n1149\t    expect(verdict).toBeDefined();\n1150\t    expect(verdict.verdict).toBe('pass');\n1151\t    expect(verdict.score.passed).toBe(3);\n1152\t  });\n11