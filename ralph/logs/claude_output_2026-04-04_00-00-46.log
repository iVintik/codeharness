{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CK2pMUYUJkMDARifa4MpxG","type":"tool_result","content":"55\t  /** Maximum loop iterations before termination. Defaults to 5. */\n56\t  maxIterations?: number;\n57\t}\n58\t\n59\t/**\n60\t * Result returned by executeWorkflow().\n61\t */\n62\texport interface EngineResult {\n63\t  /** Whether the workflow completed without errors. */\n64\t  success: boolean;\n65\t  /** Number of task dispatches completed. */\n66\t  tasksCompleted: number;\n67\t  /** Number of work items (stories/issues) processed. */\n68\t  storiesProcessed: number;\n69\t  /** Errors encountered during execution. */\n70\t  errors: EngineError[];\n71\t  /** Wall-clock duration of the entire workflow in milliseconds. */\n72\t  durationMs: number;\n73\t}\n74\t\n75\t/**\n76\t * Structured error recorded during workflow execution.\n77\t */\n78\texport interface EngineError {\n79\t  taskName: string;\n80\t  storyKey: string;\n81\t  code: string;\n82\t  message: string;\n83\t}\n84\t\n85\t/**\n86\t * A work item (story or issue) ready for execution.\n87\t */\n88\texport interface WorkItem {\n89\t  key: string;\n90\t  title?: string;\n91\t  source: 'sprint' | 'issues';\n92\t}\n93\t\n94\t// --- Constants ---\n95\t\n96\t/** Sentinel story key for per-run tasks. */\n97\texport const PER_RUN_SENTINEL = '__run__';\n98\t\n99\t/** DispatchError codes that should halt execution immediately. */\n100\tconst HALT_ERROR_CODES = new Set(['RATE_LIMIT', 'NETWORK', 'SDK_INIT']);\n101\t\n102\t/** Default maximum loop iterations before termination. */\n103\tconst DEFAULT_MAX_ITERATIONS = 5;\n104\t"}]},"parent_tool_use_id":"toolu_012UHn5mnWaXKCc3AFFVB7ah","session_id":"5f276c07-4ea2-4b01-86c9-d8e4e30ebe94","uuid":"e6898ebd-462c-4ad4-a4d3-8976a80190c9","timestamp":"2026-04-03T20:02:54.817Z"}
