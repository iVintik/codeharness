ine code. */\n97\tfunction hasFailVerdict(section: string): boolean {\n98\t  return section.replace(/```[\\s\\S]*?```/g, '').replace(/`[^`]+`/g, '').includes('[FAIL]');\n99\t}\n100\t\n101\t/** Validates proof quality. `passed` is true when `pending === 0 && verified > 0`. */\n102\texport function validateProofQuality(proofPath: string): ProofQuality {\n103\t  const emptyResult: ProofQuality = {\n104\t    verified: 0, pending: 0, escalated: 0, total: 0, passed: false,\n105\t    grepSrcCount: 0, dockerExecCount: 0, observabilityCount: 0, otherCount: 0,\n106\t    blackBoxPass: false,\n107\t  };\n108\t\n109\t  if (!existsSync(proofPath)) {\n110\t    return emptyResult;\n111\t  }\n112\t\n113\t  const content = readFileSync(proofPath, 'utf-8');\n114\t\n115\t  // Compute black-box enforcement metrics once\n116\t  // Build tier regex dynamically from canonical TIER_HIERARCHY + legacy names\n117\t  const allTierNames = [...TIER_HIERARCHY, ...Object.keys(LEGACY_TIER_MAP)];\n118\t  const uniqueTierNames = [...new Set(allTierNames)];\n119\t  const tierPattern = new RegExp(`\\\\*\\\\*Tier:\\\\*\\\\*\\\\s*(${uniqueTierNames.join('|')})`, 'i');\n120\t  const bbTierMatch = tierPattern.exec(content);\n121\t  const rawTierValue = bbTierMatch ? bbTierMatch[1].toLowerCase() : null;\n122\t  // Normalize legacy tier names to canonical VerificationTier values\n123\t  const normalizedTier: VerificationTier | null = rawTierValue\n124\t    ? (LEGACY_TIER_MAP[rawTierValue] as VerificationTier | undefined) ?? (TIER_HIERARCHY.includes(rawTierValue as VerificationTier) ? rawTierValue as VerificationTier : null)\n125\t    : null;\n126\t  // Only environment-provable requires Docker evidence; all others skip\n127\t  const skipDockerEnforcement = normalizedTier !== null && normalizedTier !== 'environment-provable';\n128\t  // Always compute metrics for diagnostics; override blackBoxPass when skipping\n129\t  const bbRawEnforcement = checkBlackBoxEnforcement(content);\n130\t  const bbEnforcement = s