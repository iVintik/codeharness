uatorVerdict = {\n1247\t      verdict: 'pass',\n1248\t      score: { passed: 2, failed: 0, unknown: 0, total: 2 },\n1249\t      findings: [],\n1250\t    };\n1251\t    expect(getFailedItems(verdict, items)).toEqual([]);\n1252\t  });\n1253\t\n1254\t  it('returns all items when verdict is fail (conservative)', () => {\n1255\t    const verdict: EvaluatorVerdict = {\n1256\t      verdict: 'fail',\n1257\t      score: { passed: 1, failed: 1, unknown: 0, total: 2 },\n1258\t      findings: [],\n1259\t    };\n1260\t    expect(getFailedItems(verdict, items)).toEqual(items);\n1261\t  });\n1262\t});\n1263\t\n1264\tdescribe('loop block execution', () => {\n1265\t  beforeEach(() => {\n1266\t    vi.clearAllMocks();\n1267\t    setupDefaultMocks();\n1268\t  });\n1269\t\n1270\t  function makePassVerdict(): string {\n1271\t    return JSON.stringify({\n1272\t      verdict: 'pass',\n1273\t      score: { passed: 2, failed: 0, unknown: 0, total: 2 },\n1274\t      findings: [],\n1275\t    });\n1276\t  }\n1277\t\n1278\t  function makeFailVerdict(): string {\n1279\t    return JSON.stringify({\n1280\t      verdict: 'fail',\n1281\t      score: { passed: 1, failed: 1, unknown: 0, total: 2 },\n1282\t      findings: [\n1283\t        {\n1284\t          ac: 1,\n1285\t          description: 'Tests pass',\n1286\t          status: 'fail',\n1287\t          evidence: { commands_run: ['npm test'], output_observed: 'FAIL', reasoning: 'Test suite failed' },\n1288\t        },\n1289\t        {\n1290\t          ac: 2,\n1291\t          description: 'Build succeeds',\n1292\t          status: 'pass',\n1293\t          evidence: { commands_run: ['npm run build'], output_observed: 'OK', reasoning: 'Build fine' },\n1294\t        },\n1295\t      ],\n1296\t    });\n1297\t  }\n1298\t\n1299\t  it('terminates loop when verdict is pass (AC #2)', async () => {\n1300\t    mockDispatchAgent.mockImplementation(\n1301\t      async (_def: SubagentDefinition, prompt: string) => {\n1302\t        if (prompt.includes('Execute task'))