{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018SMsZJdzrnTE6BX79Xzfk8","type":"tool_result","content":"1\t/**\n2\t * Ink UI components — types and layout components (Header, Separator, StoryBreakdown).\n3\t *\n4\t * Renders a UX-spec-compliant live display with plain text header,\n5\t * ━━━ separators, and labeled story breakdown sections.\n6\t * Activity components (tools, thoughts, retry) are in ink-activity-components.tsx.\n7\t * The App root component is in ink-app.tsx to avoid circular imports.\n8\t */\n9\t\n10\timport React from 'react';\n11\timport { Text, Box } from 'ink';\n12\timport type { FlowStep } from './workflow-parser.js';\n13\t\n14\t// --- Types ---\n15\t\n16\texport interface SprintInfo {\n17\t  storyKey: string;\n18\t  phase: string;\n19\t  done: number;\n20\t  total: number;\n21\t  elapsed?: string;\n22\t  iterationCount?: number;\n23\t  totalCost?: number;\n24\t  acProgress?: string;\n25\t  currentCommand?: string;\n26\t}\n27\t\n28\texport interface CompletedToolEntry {\n29\t  name: string;\n30\t  args: string;\n31\t  driver?: string;\n32\t}\n33\t\n34\texport type StoryStatusValue = 'done' | 'in-progress' | 'pending' | 'failed' | 'blocked';\n35\t\n36\texport interface StoryStatusEntry {\n37\t  key: string;\n38\t  status: StoryStatusValue;\n39\t  retryCount?: number;\n40\t  maxRetries?: number;\n41\t  costByDriver?: Record<string, number>;\n42\t}\n43\t\n44\texport interface RetryInfo {\n45\t  attempt: number;\n46\t  delay: number;\n47\t}\n48\t\n49\texport interface StoryMessage {\n50\t  type: 'ok' | 'warn' | 'fail';\n51\t  key: string;\n52\t  message: string;\n53\t  details?: string[];\n54\t}\n55\t\n56\texport type TaskNodeState = 'pending' | 'active' | 'done' | 'failed';\n57\t\n58\texport interface TaskNodeMeta {\n59\t  driver?: string;\n60\t  costUsd?: number | null;\n61\t  elapsedMs?: number | null;\n62\t}\n63\t\n64\texport interface RendererState {\n65\t  sprintInfo: SprintInfo | null;\n66\t  stories: StoryStatusEntry[];\n67\t  messages: StoryMessage[];\n68\t  completedTools: CompletedToolEntry[];\n69\t  activeTool: { name: string } | null;\n70\t  activeToolArgs: string;\n71\t  lastThought: string | null;\n72\t  retryInfo: RetryInfo | null;\n73\t  workflowFlow: FlowStep[];\n74\t  currentTaskName: string | null;\n75\t  taskStates: Record<string, TaskNodeState>;\n76\t  taskMeta: Record<string, TaskNodeMeta>;\n77\t  activeDriverName: string | null;\n78\t  driverCosts: Record<string, number>;\n79\t}\n80\t"}]},"parent_tool_use_id":"toolu_01AgQJFigSq3KJGDuPKevuMV","session_id":"568bb8a3-7cec-4d55-8fe6-c91654e95e9c","uuid":"c69fc38a-c689-471d-aaad-7115c412b87c","timestamp":"2026-04-03T23:46:24.161Z"}
