async (opts, cmd) => {\n   296→    const globalOpts = cmd.optsWithGlobals();\n   297→    const isJson = opts.json === true || globalOpts.json === true;\n   298→    const isFull = opts.full === true || globalOpts.full === true;\n   299→    const forceScan = opts.forceScan === true || globalOpts.forceScan === true;\n   300→    const minModuleSize = parseInt(opts.minModuleSize ?? '3', 10);\n   301→\n   302→    const preconditions = runPreconditions();\n   303→    if (!preconditions.canProceed) {\n   304→      if (isJson) {\n   305→        jsonOutput({ status: 'fail', message: 'Harness not initialized \\u2014 run codeharness init first' });\n   306→      } else {\n   307→        fail('Harness not initialized \\u2014 run codeharness init first');\n   308→      }\n   309→      process.exitCode = 1;\n   310→      return;\n   311→    }\n   312→    for (const w of preconditions.warnings) {\n   313→      warn(w);\n   314→    }\n   315→\n   316→    // Check onboarding progress\n   317→    const progress = getOnboardingProgress({ listIssues });\n   318→    if (progress) {\n   319→      if (progress.remaining === 0 && !isFull && !forceScan) {\n   320→        ok('Onboarding complete \\u2014 all gaps resolved');\n   321→        return;\n   322→      }\n   323→      info(`Onboarding progress: ${progress.resolved}/${progress.total} gaps resolved (${progress.remaining} remaining)`);\n   324→    }\n   325→\n   326→    // Phase 1: Scan\n   327→    const scan = runScan(minModuleSize);\n   328→\n   329→    // Phase 2: Coverage\n   330→    const coverage = runCoverageAnalysis(scan);\n   331→\n   332→    // Phase 3: Audit\n   333→    const audit = runAudit();\n   334→\n   335→    // Save complete cache entry\n   336→    saveScanCache({\n   337→      timestamp: new Date().toISOString(),\n   338→      scan,\n   339→      coverage,\n   340→      audit,\n   341→    });\n   342→\n   343→    // Phase 4: Epic generation\n   344→    const epicPath = join(process.cwd(), 'ralph', 'onboarding-epic.md');\n   345→    const epic = generateOnboardingEpic(scan, coverage, audit);\n   346→\n   347→    // Merge extended gap detectors (story 8-3)\n   348→    mergeExtendedGaps(epic);\n   349→\n   350→    // Gap filtering: skip already-tracked gaps unless --full\n   351→    if (!isFull) {\n   352→      applyGapFiltering(epic);\n   353→    }\n   354→\n   355→    writeOnboardingEpic(epic, epicPath);\n   356→\n   357→    if (isJson) {\n   358→      jsonOutput({\n   359→        preconditions: { initialized: preconditions.initialized, bmad: preconditions.bmad, hooks: preconditions.hooks },\n   360→        scan,\n   361→        coverage,\n   362→        audit,\n   363→        epic,\n   364→      });\n   365→    } else {\n   366→      printScanOutput(scan);\n   367→      printCoverageOutput(coverage);\n   368→      printAuditOutput(audit);\n   369→      printEpicOutput(epic);\n   370→\n   371→      // Prompt for approval in combined mode\n   372→      const approved = await promptApproval();\n   373→      if (approved) {\n   374→        const results = importOnboardingEpic(epicPath, { listIssues, createIssue });\n   375→        const created = results.filter(r => r.status === 'created').length;\n   376→        ok(`Onboarding: ${created} stories imported into beads`);\n   377→\n   378→        // Append to sprint-status.yaml so harness-run can execute them\n   379→        const sprintResult = appendOnboardingEpicToSprint(\n   380→          epic.stories.map(s => ({ title: s.title })),\n   381→        );\n   382→        if (sprintResult.epicNumber >= 0) {\n   383→          ok(`Onboarding epic ${sprintResult.epicNumber} added to sprint-status.yaml (${sprintResult.storyKeys.length} stories)`);\n   384→        }\n   385→\n   386→        info('Ready to run: codeharness run');\n   387→      } else {\n   388→        info('Plan saved to ralph/onboarding-epic.md \\u2014 edit and re-run when ready');\n   389→      }\n   390→    }\n   391→  });\n   392→}\n   393→\n   394→// ─── Gap Filtering Helper ────────────────────────────────────────────────────\n   395→\n   396→function applyGapFiltering(epic: OnboardingEpic): void {\n   397→  const { untracked, trackedCount } = filterTrackedGaps(epic.stories, { listIssues });\n   398→  if (trackedCount > 0) {\n   399→    info(`${trackedCount} previously tracked gaps already in beads`);\n   400→  }\n   401→  epic.stories = untracked;\n   402→  rebuildEpicSummary(epic);\n   403→}\n   404→\n   405→function mergeExtendedGaps(epic: OnboardingEpic): void {\n   406→  const verificationGaps = findVerificationGaps();\n   407→  const perFileCoverageGaps = findPerFileCoverageGaps(80);\n   408→  const observabilityGaps = findObservabilityGaps();\n   409→\n   410→  epic.stories.push(...verificationGaps, ...perFileCoverageGaps, ...observabilityGaps);\n   411→  rebuildEpicSummary(epic);\n   412→}\n   413→\n   414→function rebuildEpicSummary(epic: OnboardingEpic): void {\n   415→  const coverageStories = epic.stories.filter(s => s.type === 'coverage').length;\n   416→  const docStories = epic.stories.filter(\n   417→    s => s.type === 'agents-md' || s.type === 'architecture' || s.type === 'doc-freshness',\n   418→  ).length;\n   419→  const verificationStories = epic.stories.filter(s => s.type === 'verification').length;\n   420→  const observabilityStories = epic.stories.filter(s => s.type === 'observability').length;\n   421→  epic.summary = {\n   422→    totalStories: epic.stories.length,\n   423→    coverageStories,\n   424→    docStories,\n   425→    verificationStories,\n   426→    observabilityStories,\n   427→  };\n   428→}\n   429→\n   430→// ─── Phase Implementations ───────────────────────────────────────────────────\n   431→\n   432→function runScan(minModuleSize: number): ScanResult {\n   433→  const result = scanCodebase(process.cwd(), { minModuleSize });\n   434→  lastScanResult = result;\n   435→  return result;\n   436→}\n   437→\n   438→function runCoverageAnalysis(scan: ScanResult): CoverageGapReport {\n   43