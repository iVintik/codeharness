{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G7VGpZKASRFwmXvhYMyiEc","type":"tool_result","content":"     1→/**\n     2→ * Project initialization orchestrator.\n     3→ * Composes sub-steps: stack detection, deps, Docker, BMAD, beads, state, docs, OTLP.\n     4→ */\n     5→\n     6→import { existsSync } from 'node:fs';\n     7→import { basename, join } from 'node:path';\n     8→import { ok as okOutput, fail as failOutput, info, jsonOutput } from '../../lib/output.js';\n     9→import { detectStack, detectStacks, detectAppType } from '../../lib/stack-detect.js';\n    10→import { readState, writeState, getDefaultState, getStatePath } from '../../lib/state.js';\n    11→import type { HarnessState } from '../../lib/state.js';\n    12→import { instrumentProject } from '../../lib/otlp.js';\n    13→import type { Result } from '../../types/result.js';\n    14→import { ok, fail, isOk } from '../../types/result.js';\n    15→import type { InitOptions, InitResult } from './types.js';\n    16→import { checkDocker, setupDocker } from './docker-setup.js';\n    17→import { installDeps, verifyDeps } from './deps-install.js';\n    18→import { setupBmad, verifyBmadOnRerun } from './bmad-setup.js';\n    19→import { initializeBeads } from './beads-init.js';\n    20→import { scaffoldDocs, getCoverageTool, getStackLabel } from './docs-scaffold.js';\n    21→import { generateDockerfileTemplate } from './dockerfile-template.js';\n    22→\n    23→declare const __PKG_VERSION__: string;\n    24→const HARNESS_VERSION = typeof __PKG_VERSION__ !== 'undefined' ? __PKG_VERSION__ : '0.0.0-dev';\n    25→\n    26→/** Helper: build a fail-status InitResult for early returns */\n    27→function failResult(opts: InitOptions, error: string): InitResult {\n    28→  return {\n    29→    status: 'fail', stack: null, stacks: [], error,\n    30→    enforcement: { frontend: opts.frontend, database: opts.database, api: opts.api },\n    31→    documentation: { agents_md: 'skipped', docs_scaffold: 'skipped', readme: 'skipped' },\n    32→  };\n    33→}\n    34→\n    35→/** Output error and set exit code for validation/critical failures */\n    36→function emitError(error: string, isJson: boolean): void {\n    37→  if (isJson) { jsonOutput({ status: 'fail', error }); } else { failOutput(error); }\n    38→  process.exitCode = 1;\n    39→}\n    40→\n    41→/** Main project initialization orchestrator. Never throws — returns fail() on unexpected errors. */\n    42→export async function initProject(opts: InitOptions): Promise<Result<InitResult>> {\n    43→  try {\n    44→    return await initProjectInner(opts);\n    45→  } catch (err) {\n    46→    const message = err instanceof Error ? err.message : String(err);\n    47→    return fail(`Unexpected init error: ${message}`);\n    48→  }\n    49→}\n    50→\n    51→async function initProjectInner(opts: InitOptions): Promise<Result<InitResult>> {\n    52→  const { projectDir, json: isJson = false } = opts;\n    53→  const result: InitResult = {\n    54→    status: 'ok', stack: null, stacks: [],\n    55→    enforcement: { frontend: opts.frontend, database: opts.database, api: opts.api },\n    56→    documentation: { agents_md: 'skipped', docs_scaffold: 'skipped', readme: 'skipped' },\n    57→  };\n    58→\n    59→  // --- Idempotent re-run check ---\n    60→  const rerunResult = handleRerun(opts, result);\n    61→  if (rerunResult !== null) return rerunResult;\n    62→\n    63→  // --- Remote endpoint URL validation ---\n    64→  const urlError = validateRemoteUrls(opts);\n    65→  if (urlError !== null) { emitError(urlError, isJson); return ok(failResult(opts, urlError)); }\n    66→\n    67→  // --- Stack detection ---\n    68→  const stack = detectStack(projectDir);\n    69→  result.stack = stack;\n    70→  const allStacks = detectStacks(projectDir);\n    71→  result.stacks = [...new Set(allStacks.map(s => s.stack))];\n    72→  const appType = detectAppType(projectDir, stack);\n    73→  result.app_type = appType;\n    74→  if (!isJson) {\n    75→    if (result.stacks.length > 0) {\n    76→      info(`Stack detected: ${getStackLabel(result.stacks)}`);\n    77→    } else if (stack) {\n    78→      info(`Stack detected: ${getStackLabel(stack)}`);\n    79→    }\n    80→    info(`App type: ${appType}`);\n    81→  }\n    82→\n    83→  // --- Dockerfile template generation ---\n    84→  const dfResult = generateDockerfileTemplate(projectDir, stack);\n    85→  if (isOk(dfResult)) {\n    86→    result.dockerfile = { generated: true, stack: dfResult.data.stack };\n    87→    if (!isJson) info(`Generated Dockerfile for ${dfResult.data.stack} project.`);\n    88→  } else {\n    89→    if (!isJson) info('Dockerfile already exists -- skipping template generation.');\n    90→  }\n    91→\n    92→  // --- Docker check ---\n    93→  const dockerCheck = checkDocker({ observability: opts.observability, otelEndpoint: opts.otelEndpoint, logsUrl: opts.logsUrl, opensearchUrl: opts.opensearchUrl, isJson });\n    94→  if (!isOk(dockerCheck)) return fail(dockerCheck.error);\n    95→  const { available: dockerAvailable, criticalFailure, dockerResult: criticalDockerResult } = dockerCheck.data;\n    96→  if (criticalFailure) {\n    97→    result.status = 'fail'; result.error = 'Docker not installed'; result.docker = criticalDockerResult;\n    98→    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); }\n    99→    else { failOutput('Docker not installed'); info('\\u2192 Install Docker: https://docs.docker.com/engine/install/'); info('\\u2192 Or skip observability: codeharness init --no-observability'); }\n   100→    process.exitCode = 1;\n   101→    return ok(result);\n   102→  }\n   103→\n   104→  // --- Dependency install ---\n   105→  const depResult = installDeps({ isJson });\n   106→  if (!isOk(depResult)) {\n   107→    result.status = 'fail'; result.error = depResult.error;\n   108→    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); } else { info('Critical dependency failed — aborting init'); }\n   109→    process.exitCode = 1;\n   110→    return ok(result);\n   111→  }\n   112→  result.dependencies = depResult.data;\n   113→\n   114→  // --- Beads initialization ---\n   115→  result.beads = initializeBeads(projectDir, isJson);\n   116→\n   117→  // --- BMAD installation ---\n   118→  const bmadResult = setupBmad({ projectDir, isJson });\n   119→  if (isOk(bmadResult)) result.bmad = bmadResult.data;\n   120→\n   121→  // --- State file creation ---\n   122→  let state: HarnessState = getDefaultState(stack);\n   123→  state.harness_version = HARNESS_VERSION;\n   124→  state.initialized = true;\n   125→  state.app_type = appType;\n   126→  state.enforcement = { frontend: opts.frontend, database: opts.database, api: opts.api };\n   127→  // Per-stack coverage detection: compute tool for each stack, primary stack's tool for backward compat\n   128→  for (const detection of allStacks) {\n   129→    getCoverageTool(detection.stack);\n   130→  }\n   131→  state.coverage.tool = getCoverageTool(stack);\n   132→  // Persist all detected stacks (not just the primary root stack)\n   133→  state.stacks = result.stacks as import('../../lib/stack-detect.js').StackName[];\n   134→  writeState(state, projectDir);\n   135→  if (!isJson) okOutput('State file: .claude/codeharness.local.md created');\n   136→\n   137→  // --- Documentation scaffold ---\n   138→  const docsResult = await scaffoldDocs({ projectDir, stack, isJson });\n   139→  if (isOk(docsResult)) result.documentation = docsResult.data;\n   140→\n   141→  // --- OTLP instrumentation ---\n   142→  if (!opts.observability) {\n   143→    result.otlp = { status: 'skipped', packages_installed: false, start_script_patched: false, env_vars_configured: false };\n   144→    if (!isJson) info('OTLP: skipped (--no-observability)');\n   145→  } else {\n   146→    // Per-stack OTLP instrumentation: instrument each detected stack in its directory\n   147→    for (const detection of allStacks) {\n   148→      const stackDir = detection.dir === '.' ? projectDir : join(projectDir, detection.dir);\n   149→      const stackOtlp = instrumentProject(stackDir, detection.stack, { json: isJson, appType });\n   150→      // Primary stack's result goes to result.otlp for backward compat\n   151→      if (detection.stack === stack) {\n   152→        result.otlp = stackOtlp;\n   153→      }\n   154→    }\n   155→    // Fallback: if primary stack wasn't in allStacks (shouldn't happen), use single-stack call\n   156→    if (!result.otlp) {\n   157→      result.otlp = instrumentProject(projectDir, stack, { json: isJson, appType });\n   158→    }\n   159→  }\n   160→\n   161→  // Re-read state to pick up otlp changes written by instrumentProject\n   162→  try { const u = readState(projectDir); if (u.otlp) state.otlp = u.otlp; } catch { /* ignore */ }\n   163→  if (!state.otlp) {\n   164→    state.otlp = { enabled: true, endpoint: 'http://localhost:4318', service_name: basename(projectDir), mode: 'local-shared' };\n   165→  }\n   166→\n   167→  // --- Docker stack setup ---\n   168→  const dockerSetup = setupDocker({\n   169→    observability: opts.observability, otelEndpoint: opts.otelEndpoint,\n   170→    opensearchUrl: opts.opensearchUrl,\n   171→    logsUrl: opts.logsUrl, metricsUrl: opts.metricsUrl, tracesUrl: opts.tracesUrl,\n   172→    isJson, dockerAvailable, appType, state, projectDir,\n   173→  });\n   174→  if (isOk(dockerSetup)) result.docker = dockerSetup.data.docker;\n   175→\n   176→  // --- Enforcement summary ---\n   177→  if (!isJson) {\n   178→    const e = state.enforcement;\n   179→    const fmt = (v: boolean): string => v ? 'ON' : 'OFF';\n   180→    okOutput(`Enforcement: frontend:${fmt(e.frontend)} database:${fmt(e.database)} api:${fmt(e.api)} observability:ON`);\n   181→    info('Harness initialized. Run: codeharness bridge --epics <path>');\n   182→  }\n   183→  if (isJson) jsonOutput(result as unknown as Record<string, unknown>);\n   184→\n   185→  return ok(result);\n   186→}\n   187→\n   188→function handleRerun(opts: InitOptions, result: InitResult): Result<InitResult> | null {\n   189→  const { projectDir, json: isJson = false } = opts;\n   190→  if (!existsSync(getStatePath(projectDir))) return null;\n   191→\n   192→  try {\n   193→    const existingState = readState(projectDir);\n   194→    const legacyObsDisabled = (existingState.enforcement as Record<string, unknown>).observability === false;\n   195→    if (!existingState.initialized || legacyObsDisabled) {\n   196→      if (legacyObsDisabled && !isJson) info('Observability upgraded from disabled to enabled');\n   197→      return null;\n   198→    }\n   199→    result.stack = existingState.stack;\n   200→    result.stacks = existingState.stacks ?? [];\n   201→    result.enforcement = existingState.enforcement;\n   202→    result.documentation = { agents_md: 'exists', docs_scaffold: 'exists', readme: 'exists' };\n   203→    result.dependencies = verifyDeps(isJson);\n   204→    result.docker = existingState.docker\n   205→      ? { compose_file: existingState.docker.compose_file, stack_running: existingState.docker.stack_running, services: [], ports: existingState.docker.ports }\n   206→      : null;\n   207→    const bmadResult = verifyBmadOnRerun(projectDir, isJson);\n   208→    if (bmadResult) result.bmad = bmadResult;\n   209→    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); }\n   210→    else { info('Harness already initialized — verifying configuration'); okOutput('Configuration verified'); }\n   211→    return ok(result);\n   212→  } catch {\n   213→    return null;\n   214→  }\n   215→}\n   216→\n   217→/** Returns error message string if validation fails, null if OK */\n   218→function validateRemoteUrls(opts: InitOptions): string | null {\n   219→  const remoteUrls = [opts.otelEndpoint, opts.opensearchUrl, opts.logsUrl, opts.metricsUrl, opts.tracesUrl].filter(Boolean) as string[];\n   220→  for (const url of remoteUrls) {\n   221→    if (!/^https?:\\/\\//i.test(url)) return `Invalid URL: '${url}' \\u2014 must start with http:// or https://`;\n   222→  }\n   223→  if (opts.otelEndpoint && (opts.logsUrl || opts.metricsUrl || opts.tracesUrl)) {\n   224→    return 'Cannot combine --otel-endpoint with --logs-url/--metrics-url/--traces-url';\n   225→  }\n   226→  const hasAny = opts.logsUrl || opts.metricsUrl || opts.tracesUrl;\n   227→  if (hasAny && !(opts.logsUrl && opts.metricsUrl && opts.tracesUrl)) {\n   228→    return 'When using remote backends, all three are required: --logs-url, --metrics-url, --traces-url';\n   229→  }\n   230→  return null;\n   231→}\n   232→"}]},"parent_tool_use_id":"toolu_01RW3DvRwuMditE8CiVokyWA","session_id":"46c7b24e-5b3f-4eb1-bc5a-20f6a0336cfe","uuid":"9c592584-9beb-463c-9181-c7b0160d7550","timestamp":"2026-03-23T14:56:14.893Z"}
