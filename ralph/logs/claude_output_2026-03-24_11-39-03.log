{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CTUHcgBTyyHSLr7PRcRZqy","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, afterEach } from 'vitest';\n     2→import { mkdtempSync, rmSync, writeFileSync, mkdirSync } from 'node:fs';\n     3→import { tmpdir } from 'node:os';\n     4→import { join } from 'node:path';\n     5→import {\n     6→  registerProvider,\n     7→  getStackProvider,\n     8→  detectStacks,\n     9→  detectStack,\n    10→  _resetRegistry,\n    11→} from '../../stacks/registry.js';\n    12→import type { StackProvider } from '../../stacks/types.js';\n    13→import { NodejsProvider } from '../../stacks/nodejs.js';\n    14→\n    15→let testDir: string;\n    16→\n    17→/** Create a minimal mock provider for testing. */\n    18→function mockProvider(overrides: Partial<StackProvider> & Pick<StackProvider, 'name' | 'markers' | 'displayName'>): StackProvider {\n    19→  return {\n    20→    detectAppType: () => 'generic',\n    21→    getCoverageTool: () => 'none',\n    22→    detectCoverageConfig: () => ({ tool: 'none' }),\n    23→    getOtlpPackages: () => [],\n    24→    installOtlp: () => ({ success: true, packagesInstalled: [] }),\n    25→    getDockerfileTemplate: () => '',\n    26→    getDockerBuildStage: () => '',\n    27→    getRuntimeCopyDirectives: () => '',\n    28→    getBuildCommands: () => [],\n    29→    getTestCommands: () => [],\n    30→    getSemgrepLanguages: () => [],\n    31→    parseTestOutput: () => ({ passed: 0, failed: 0, skipped: 0, total: 0 }),\n    32→    parseCoverageReport: () => 0,\n    33→    getProjectName: () => null,\n    34→    ...overrides,\n    35→  };\n    36→}\n    37→\n    38→beforeEach(() => {\n    39→  _resetRegistry();\n    40→  testDir = mkdtempSync(join(tmpdir(), 'ch-registry-test-'));\n    41→});\n    42→\n    43→afterEach(() => {\n    44→  rmSync(testDir, { recursive: true, force: true });\n    45→});\n    46→\n    47→describe('registerProvider / getStackProvider', () => {\n    48→  it('returns undefined for unregistered provider', () => {\n    49→    expect(getStackProvider('nodejs')).toBeUndefined();\n    50→  });\n    51→\n    52→  it('registers and retrieves a provider', () => {\n    53→    const provider = new NodejsProvider();\n    54→    registerProvider(provider);\n    55→    expect(getStackProvider('nodejs')).toBe(provider);\n    56→  });\n    57→\n    58→  it('overwrites existing provider on re-registration', () => {\n    59→    const first = new NodejsProvider();\n    60→    const second = new NodejsProvider();\n    61→    registerProvider(first);\n    62→    registerProvider(second);\n    63→    expect(getStackProvider('nodejs')).toBe(second);\n    64→  });\n    65→\n    66→  it('getStackProvider(\"nodejs\") returns NodejsProvider instance (AC3)', () => {\n    67→    registerProvider(new NodejsProvider());\n    68→    const provider = getStackProvider('nodejs');\n    69→    expect(provider).toBeInstanceOf(NodejsProvider);\n    70→    expect(provider!.name).toBe('nodejs');\n    71→    expect(provider!.markers).toEqual(['package.json']);\n    72→    expect(provider!.displayName).toBe('Node.js (package.json)');\n    73→  });\n    74→});\n    75→\n    76→describe('detectStacks — marker-based detection (AC2)', () => {\n    77→  it('detects nodejs when package.json exists', () => {\n    78→    registerProvider(new NodejsProvider());\n    79→    writeFileSync(join(testDir, 'package.json'), '{}');\n    80→    const result = detectStacks(testDir);\n    81→    expect(result).toEqual([{ stack: 'nodejs', dir: '.' }]);\n    82→  });\n    83→\n    84→  it('detects python when requirements.txt exists', () => {\n    85→    registerProvider(mockProvider({\n    86→      name: 'python',\n    87→      markers: ['requirements.txt', 'pyproject.toml', 'setup.py'],\n    88→      displayName: 'Python',\n    89→    }));\n    90→    writeFileSync(join(testDir, 'requirements.txt'), '');\n    91→    const result = detectStacks(testDir);\n    92→    expect(result).toEqual([{ stack: 'python', dir: '.' }]);\n    93→  });\n    94→\n    95→  it('detects multiple stacks at root in priority order', () => {\n    96→    registerProvider(new NodejsProvider());\n    97→    registerProvider(mockProvider({\n    98→      name: 'rust',\n    99→      markers: ['Cargo.toml'],\n   100→      displayName: 'Rust',\n   101→    }));\n   102→    writeFileSync(join(testDir, 'package.json'), '{}');\n   103→    writeFileSync(join(testDir, 'Cargo.toml'), '[package]\\nname=\"x\"');\n   104→    const result = detectStacks(testDir);\n   105→    expect(result).toEqual([\n   106→      { stack: 'nodejs', dir: '.' },\n   107→      { stack: 'rust', dir: '.' },\n   108→    ]);\n   109→  });\n   110→\n   111→  it('detects stacks in subdirectories', () => {\n   112→    registerProvider(new NodejsProvider());\n   113→    registerProvider(mockProvider({\n   114→      name: 'rust',\n   115→      markers: ['Cargo.toml'],\n   116→      displayName: 'Rust',\n   117→    }));\n   118→    mkdirSync(join(testDir, 'frontend'));\n   119→    mkdirSync(join(testDir, 'backend'));\n   120→    writeFileSync(join(testDir, 'frontend', 'package.json'), '{}');\n   121→    writeFileSync(join(testDir, 'backend', 'Cargo.toml'), '[package]\\nname=\"api\"');\n   122→    const result = detectStacks(testDir);\n   123→    expect(result).toEqual([\n   124→      { stack: 'rust', dir: 'backend' },\n   125→      { stack: 'nodejs', dir: 'frontend' },\n   126→    ]);\n   127→  });\n   128→\n   129→  it('returns empty array when no providers are registered', () => {\n   130→    writeFileSync(join(testDir, 'package.json'), '{}');\n   131→    const result = detectStacks(testDir);\n   132→    expect(result).toEqual([]);\n   133→  });\n   134→\n   135→  it('returns empty array for empty directory', () => {\n   136→    registerProvider(new NodejsProvider());\n   137→    const result = detectStacks(testDir);\n   138→    expect(result).toEqual([]);\n   139→  });\n   140→\n   141→  it('skips node_modules during subdirectory scan', () => {\n   142→    registerProvider(new NodejsProvider());\n   143→    mkdirSync(join(testDir, 'node_modules', 'pkg'), { recursive: true });\n   144→    writeFileSync(join(testDir, 'node_modules', 'pkg', 'package.json'), '{}');\n   145→    const result = detectStacks(testDir);\n   146→    expect(result).toEqual([]);\n   147→  });\n   148→\n   149→  it('skips .git directory during subdirectory scan', () => {\n   150→    registerProvider(new NodejsProvider());\n   151→    mkdirSync(join(testDir, '.git', 'hooks'), { recursive: true });\n   152→    writeFileSync(join(testDir, '.git', 'package.json'), '{}');\n   153→    const result = detectStacks(testDir);\n   154→    expect(result).toEqual([]);\n   155→  });\n   156→\n   157→  it('root stacks appear before subdirectory stacks', () => {\n   158→    registerProvider(new NodejsProvider());\n   159→    registerProvider(mockProvider({\n   160→      name: 'rust',\n   161→      markers: ['Cargo.toml'],\n   162→      displayName: 'Rust',\n   163→    }));\n   164→    writeFileSync(join(testDir, 'package.json'), '{}');\n   165→    mkdirSync(join(testDir, 'api'));\n   166→    writeFileSync(join(testDir, 'api', 'Cargo.toml'), '[package]\\nname=\"api\"');\n   167→    const result = detectStacks(testDir);\n   168→    expect(result).toEqual([\n   169→      { stack: 'nodejs', dir: '.' },\n   170→      { stack: 'rust', dir: 'api' },\n   171→    ]);\n   172→  });\n   173→\n   174→  it('subdirectory stacks sorted alphabetically', () => {\n   175→    registerProvider(new NodejsProvider());\n   176→    mkdirSync(join(testDir, 'zeta'));\n   177→    mkdirSync(join(testDir, 'alpha'));\n   178→    writeFileSync(join(testDir, 'zeta', 'package.json'), '{}');\n   179→    writeFileSync(join(testDir, 'alpha', 'package.json'), '{}');\n   180→    const result = detectStacks(testDir);\n   181→    expect(result).toEqual([\n   182→      { stack: 'nodejs', dir: 'alpha' },\n   183→      { stack: 'nodejs', dir: 'zeta' },\n   184→    ]);\n   185→  });\n   186→\n   187→  it('uses marker arrays from providers, not hardcoded checks', () => {\n   188→    // Register a provider with a custom marker to prove detection uses provider markers\n   189→    registerProvider(mockProvider({\n   190→      name: 'python',\n   191→      markers: ['custom-python-marker.txt'],\n   192→      displayName: 'Python (custom)',\n   193→    }));\n   194→    writeFileSync(join(testDir, 'custom-python-marker.txt'), '');\n   195→    const result = detectStacks(testDir);\n   196→    expect(result).toEqual([{ stack: 'python', dir: '.' }]);\n   197→  });\n   198→});\n   199→\n   200→describe('detectStack — compat wrapper', () => {\n   201→  it('returns first root stack name', () => {\n   202→    registerProvider(new NodejsProvider());\n   203→    writeFileSync(join(testDir, 'package.json'), '{}');\n   204→    expect(detectStack(testDir)).toBe('nodejs');\n   205→  });\n   206→\n   207→  it('returns null when no root stack detected', () => {\n   208→    registerProvider(new NodejsProvider());\n   209→    expect(detectStack(testDir)).toBeNull();\n   210→  });\n   211→\n   212→  it('returns null when stacks only in subdirectories', () => {\n   213→    registerProvider(new NodejsProvider());\n   214→    mkdirSync(join(testDir, 'sub'));\n   215→    writeFileSync(join(testDir, 'sub', 'package.json'), '{}');\n   216→    expect(detectStack(testDir)).toBeNull();\n   217→  });\n   218→});\n   219→"}]},"parent_tool_use_id":"toolu_01NBw9a8P5guFFtTFy7if2e9","session_id":"31f79ff4-68ea-4b44-861b-4091a0c239f5","uuid":"d5dbfc39-a7de-4e36-82c6-92e46e1f14ce","timestamp":"2026-03-24T07:46:24.799Z"}
