{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WyB5MZrDjxCUk79CmqjGbn","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach } from 'vitest';\n2\timport {\n3\t  registerNullTask,\n4\t  getNullTask,\n5\t  listNullTasks,\n6\t  clearNullTaskRegistry,\n7\t} from '../null-task-registry.js';\n8\timport type { TaskContext, NullTaskResult } from '../null-task-registry.js';\n9\t\n10\tdescribe('null-task-registry', () => {\n11\t  // Note: 'telemetry' is registered at module load time as a built-in.\n12\t\n13\t  describe('registerNullTask / getNullTask', () => {\n14\t    it('returns undefined for an unregistered handler', () => {\n15\t      expect(getNullTask('nonexistent-handler-xyz')).toBeUndefined();\n16\t    });\n17\t\n18\t    it('returns the registered handler', () => {\n19\t      const handler = async (_ctx: TaskContext): Promise<NullTaskResult> => ({\n20\t        success: true,\n21\t        output: 'test',\n22\t      });\n23\t      registerNullTask('test-handler-unique', handler);\n24\t      expect(getNullTask('test-handler-unique')).toBe(handler);\n25\t    });\n26\t\n27\t    it('overwrites a previously registered handler', () => {\n28\t      const handler1 = async () => ({ success: true });\n29\t      const handler2 = async () => ({ success: false });\n30\t      registerNullTask('overwrite-test', handler1);\n31\t      registerNullTask('overwrite-test', handler2);\n32\t      expect(getNullTask('overwrite-test')).toBe(handler2);\n33\t    });\n34\t  });\n35\t\n36\t  describe('listNullTasks', () => {\n37\t    it('includes built-in telemetry handler', () => {\n38\t      const names = listNullTasks();\n39\t      expect(names).toContain('telemetry');\n40\t    });\n41\t\n42\t    it('includes dynamically registered handlers', () => {\n43\t      registerNullTask('list-test-handler', async () => ({ success: true }));\n44\t      const names = listNullTasks();\n45\t      expect(names).toContain('list-test-handler');\n46\t    });\n47\t  });\n48\t\n49\t  describe('built-in telemetry handler', () => {\n50\t    it('exists and returns success', async () => {\n51\t      const handler = getNullTask('telemetry');\n52\t      expect(handler).toBeDefined();\n53\t\n54\t      const ctx: TaskContext = {\n55\t        storyKey: 'test-story',\n56\t        taskName: 'telemetry',\n57\t        cost: 0.5,\n58\t        durationMs: 1000,\n59\t        outputContract: null,\n60\t        projectDir: '/tmp/test',\n61\t      };\n62\t      const result = await handler!(ctx);\n63\t      expect(result.success).toBe(true);\n64\t      expect(result.output).toBeDefined();\n65\t    });\n66\t\n67\t    it('completes in under 10ms (AC #6)', async () => {\n68\t      const handler = getNullTask('telemetry')!;\n69\t      const ctx: TaskContext = {\n70\t        storyKey: 'perf-test',\n71\t        taskName: 'telemetry',\n72\t        cost: 0,\n73\t        durationMs: 0,\n74\t        outputContract: null,\n75\t        projectDir: '/tmp/test',\n76\t      };\n77\t      const start = performance.now();\n78\t      await handler(ctx);\n79\t      const elapsed = performance.now() - start;\n80\t      expect(elapsed).toBeLessThan(10);\n81\t    });\n82\t  });\n83\t\n84\t  describe('clearNullTaskRegistry', () => {\n85\t    it('removes all handlers including built-ins', () => {\n86\t      registerNullTask('clear-test-handler', async () => ({ success: true }));\n87\t      expect(getNullTask('clear-test-handler')).toBeDefined();\n88\t      expect(getNullTask('telemetry')).toBeDefined();\n89\t\n90\t      clearNullTaskRegistry();\n91\t\n92\t      expect(getNullTask('clear-test-handler')).toBeUndefined();\n93\t      expect(getNullTask('telemetry')).toBeUndefined();\n94\t      expect(listNullTasks()).toHaveLength(0);\n95\t\n96\t      // Re-register telemetry for subsequent tests\n97\t      registerNullTask('telemetry', async () => ({ success: true, output: 'telemetry: no-op placeholder' }));\n98\t    });\n99\t  });\n100\t\n101\t  describe('TaskContext interface', () => {\n102\t    it('handler receives all expected fields', async () => {\n103\t      let receivedCtx: TaskContext | null = null;\n104\t      registerNullTask('ctx-capture', async (ctx) => {\n105\t        receivedCtx = ctx;\n106\t        return { success: true };\n107\t      });\n108\t\n109\t      const mockContract = {\n110\t        version: 1,\n111\t        taskName: 'implement',\n112\t        storyId: 'story-1',\n113\t        driver: 'claude-code',\n114\t        model: 'claude-sonnet-4-20250514',\n115\t        timestamp: '2026-04-03T00:00:00.000Z',\n116\t        cost_usd: 0.05,\n117\t        duration_ms: 5000,\n118\t        changedFiles: [],\n119\t        testResults: null,\n120\t        output: 'done',\n121\t        acceptanceCriteria: [],\n122\t      };\n123\t\n124\t      const ctx: TaskContext = {\n125\t        storyKey: '16-2-test',\n126\t        taskName: 'ctx-capture',\n127\t        cost: 0.05,\n128\t        durationMs: 5000,\n129\t        outputContract: mockContract,\n130\t        projectDir: '/project',\n131\t      };\n132\t\n133\t      await getNullTask('ctx-capture')!(ctx);\n134\t\n135\t      expect(receivedCtx).not.toBeNull();\n136\t      expect(receivedCtx!.storyKey).toBe('16-2-test');\n137\t      expect(receivedCtx!.taskName).toBe('ctx-capture');\n138\t      expect(receivedCtx!.cost).toBe(0.05);\n139\t      expect(receivedCtx!.durationMs).toBe(5000);\n140\t      expect(receivedCtx!.outputContract).toBe(mockContract);\n141\t      expect(receivedCtx!.projectDir).toBe('/project');\n142\t    });\n143\t  });\n144\t});\n145\t"}]},"parent_tool_use_id":"toolu_01EThU22wRDbXmvukgem8PY8","session_id":"3330d992-072a-4898-af8b-5f3f7e12cbac","uuid":"365e35f8-86c4-440b-a50d-aa9daa4bc1d6","timestamp":"2026-04-03T17:45:40.232Z"}
