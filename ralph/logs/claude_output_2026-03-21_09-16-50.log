{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014e2kiMuok9UZd84GCJJwNz","type":"tool_result","content":"     1→/**\n     2→ * Audit module types — dimension status, results, and gaps.\n     3→ *\n     4→ * FR13 (full compliance report), FR14 (per-dimension status + metric),\n     5→ * FR21 (structured output).\n     6→ */\n     7→\n     8→/** Status of a single audit dimension */\n     9→export type DimensionStatus = 'pass' | 'fail' | 'warn';\n    10→\n    11→/** A specific compliance gap found during audit */\n    12→export interface AuditGap {\n    13→  /** Which dimension this gap belongs to */\n    14→  readonly dimension: string;\n    15→  /** Description of the gap */\n    16→  readonly description: string;\n    17→  /** Suggested fix for the gap */\n    18→  readonly suggestedFix: string;\n    19→}\n    20→\n    21→/** Result of checking a single audit dimension */\n    22→export interface DimensionResult {\n    23→  /** Name of the dimension (e.g., 'observability', 'testing') */\n    24→  readonly name: string;\n    25→  /** Overall status of this dimension */\n    26→  readonly status: DimensionStatus;\n    27→  /** Human-readable metric (e.g., '85%', 'A', '3/5 verified') */\n    28→  readonly metric: string;\n    29→  /** List of gaps found in this dimension */\n    30→  readonly gaps: AuditGap[];\n    31→}\n    32→\n    33→/** Aggregated result of running all audit dimensions */\n    34→export interface AuditResult {\n    35→  /** Per-dimension results keyed by dimension name */\n    36→  readonly dimensions: Record<string, DimensionResult>;\n    37→  /** Overall status: fail if any fail, warn if any warn, pass if all pass */\n    38→  readonly overallStatus: DimensionStatus;\n    39→  /** Total number of gaps across all dimensions */\n    40→  readonly gapCount: number;\n    41→  /** Time taken to run the full audit in milliseconds */\n    42→  readonly durationMs: number;\n    43→}\n    44→"}]},"parent_tool_use_id":"toolu_015U2Dv9GBzjkQ93L4EzWA3k","session_id":"ef2f2ce5-c013-4ad4-b6dd-a80c40f8ca85","uuid":"60eed149-6628-434a-8772-5d8da968fae8","timestamp":"2026-03-21T05:17:44.847Z"}
