{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012vKSFKc7XG9Z3TsVdpoKHP","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→\n     3→// Mock all I/O: filesystem, subprocess, HTTP\n     4→vi.mock('node:fs', () => ({\n     5→  existsSync: vi.fn(),\n     6→  readFileSync: vi.fn(),\n     7→  readdirSync: vi.fn(),\n     8→}));\n     9→\n    10→vi.mock('../../observability/index.js', () => ({\n    11→  analyze: vi.fn(),\n    12→  validateRuntime: vi.fn(),\n    13→}));\n    14→\n    15→vi.mock('../../../lib/coverage.js', () => ({\n    16→  checkOnlyCoverage: vi.fn(),\n    17→}));\n    18→\n    19→vi.mock('../../../lib/doc-health.js', () => ({\n    20→  scanDocHealth: vi.fn(),\n    21→}));\n    22→\n    23→vi.mock('../../verify/index.js', () => ({\n    24→  parseProof: vi.fn(),\n    25→}));\n    26→\n    27→import { existsSync, readFileSync, readdirSync } from 'node:fs';\n    28→import { analyze, validateRuntime } from '../../observability/index.js';\n    29→import { checkOnlyCoverage } from '../../../lib/coverage.js';\n    30→import { scanDocHealth } from '../../../lib/doc-health.js';\n    31→import { parseProof } from '../../verify/index.js';\n    32→import {\n    33→  checkObservability,\n    34→  checkTesting,\n    35→  checkDocumentation,\n    36→  checkVerification,\n    37→  checkInfrastructure,\n    38→} from '../dimensions.js';\n    39→\n    40→const mockExistsSync = vi.mocked(existsSync);\n    41→const mockReadFileSync = vi.mocked(readFileSync);\n    42→const mockReaddirSync = vi.mocked(readdirSync);\n    43→const mockAnalyze = vi.mocked(analyze);\n    44→const mockValidateRuntime = vi.mocked(validateRuntime);\n    45→const mockCheckOnlyCoverage = vi.mocked(checkOnlyCoverage);\n    46→const mockScanDocHealth = vi.mocked(scanDocHealth);\n    47→const mockParseProof = vi.mocked(parseProof);\n    48→\n    49→beforeEach(() => {\n    50→  vi.clearAllMocks();\n    51→});\n    52→\n    53→// ─── checkObservability ─────────────────────────────────────────────────────\n    54→\n    55→describe('checkObservability', () => {\n    56→  it('returns pass when static and runtime both pass', async () => {\n    57→    mockAnalyze.mockReturnValue({\n    58→      success: true,\n    59→      data: {\n    60→        tool: 'semgrep',\n    61→        gaps: [],\n    62→        summary: { totalFiles: 10, filesWithGaps: 0, totalGaps: 0 },\n    63→      },\n    64→    });\n    65→    mockValidateRuntime.mockResolvedValue({\n    66→      success: true,\n    67→      data: {\n    68→        entries: [],\n    69→        totalModules: 5,\n    70→        modulesWithTelemetry: 5,\n    71→        coveragePercent: 100,\n    72→        skipped: false,\n    73→      },\n    74→    });\n    75→\n    76→    const result = await checkObservability('/project');\n    77→    expect(result.success).toBe(true);\n    78→    if (result.success) {\n    79→      expect(result.data.name).toBe('observability');\n    80→      expect(result.data.status).toBe('pass');\n    81→      expect(result.data.gaps).toHaveLength(0);\n    82→    }\n    83→  });\n    84→\n    85→  it('returns warn when Semgrep not installed (skipped)', async () => {\n    86→    mockAnalyze.mockReturnValue({\n    87→      success: true,\n    88→      data: {\n    89→        tool: 'semgrep',\n    90→        gaps: [],\n    91→        summary: { totalFiles: 0, filesWithGaps: 0, totalGaps: 0 },\n    92→        skipped: true,\n    93→        skipReason: 'Semgrep not installed',\n    94→      },\n    95→    });\n    96→    mockValidateRuntime.mockResolvedValue({\n    97→      success: true,\n    98→      data: {\n    99→        entries: [],\n   100→        totalModules: 5,\n   101→        modulesWithTelemetry: 5,\n   102→        coveragePercent: 100,\n   103→        skipped: false,\n   104→      },\n   105→    });\n   106→\n   107→    const result = await checkObservability('/project');\n   108→    expect(result.success).toBe(true);\n   109→    if (result.success) {\n   110→      expect(result.data.status).toBe('warn');\n   111→      expect(result.data.gaps.length).toBeGreaterThan(0);\n   112→      expect(result.data.gaps[0].description).toContain('Semgrep not installed');\n   113→    }\n   114→  });\n   115→\n   116→  it('returns warn when backend unreachable (runtime skipped)', async () => {\n   117→    mockAnalyze.mockReturnValue({\n   118→      success: true,\n   119→      data: {\n   120→        tool: 'semgrep',\n   121→        gaps: [],\n   122→        summary: { totalFiles: 10, filesWithGaps: 0, totalGaps: 0 },\n   123→      },\n   124→    });\n   125→    mockValidateRuntime.mockResolvedValue({\n   126→      success: true,\n   127→      data: {\n   128→        entries: [],\n   129→        totalModules: 5,\n   130→        modulesWithTelemetry: 0,\n   131→        coveragePercent: 0,\n   132→        skipped: true,\n   133→        skipReason: 'Backend unreachable',\n   134→      },\n   135→    });\n   136→\n   137→    const result = await checkObservability('/project');\n   138→    expect(result.success).toBe(true);\n   139→    if (result.success) {\n   140→      expect(result.data.status).toBe('warn');\n   141→      expect(result.data.gaps.some(g => g.description.includes('Backend unreachable'))).toBe(true);\n   142→    }\n   143→  });\n   144→\n   145→  it('returns warn when analyze fails', async () => {\n   146→    mockAnalyze.mockReturnValue({\n   147→      success: false,\n   148→      error: 'Semgrep binary not found',\n   149→    });\n   150→    mockValidateRuntime.mockResolvedValue({\n   151→      success: true,\n   152→      data: {\n   153→        entries: [],\n   154→        totalModules: 5,\n   155→        modulesWithTelemetry: 5,\n   156→        coveragePercent: 100,\n   157→        skipped: false,\n   158→      },\n   159→    });\n   160→\n   161→    const result = await checkObservability('/project');\n   162→    expect(result.success).toBe(true);\n   163→    if (result.