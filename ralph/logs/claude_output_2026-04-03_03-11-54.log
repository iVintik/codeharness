{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017wiaXPMTNVQRn5sScz3Tds","type":"tool_result","content":"1\timport { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n2\timport { join } from 'node:path';\n3\timport { parse, stringify } from 'yaml';\n4\timport { warn } from './output.js';\n5\t\n6\t// --- Interfaces ---\n7\t\n8\texport interface TaskCheckpoint {\n9\t  task_name: string;\n10\t  story_key: string;\n11\t  completed_at: string;\n12\t  session_id?: string;\n13\t  /** When present, indicates this checkpoint records a failed dispatch (not a success). */\n14\t  error?: boolean;\n15\t}\n16\t\n17\texport interface EvaluatorScore {\n18\t  iteration: number;\n19\t  passed: number;\n20\t  failed: number;\n21\t  unknown: number;\n22\t  total: number;\n23\t  timestamp: string;\n24\t}\n25\t\n26\texport interface CircuitBreakerState {\n27\t  triggered: boolean;\n28\t  reason: string | null;\n29\t  score_history: number[];\n30\t}\n31\t\n32\texport interface WorkflowState {\n33\t  workflow_name: string;\n34\t  started: string;\n35\t  iteration: number;\n36\t  phase: string;\n37\t  tasks_completed: TaskCheckpoint[];\n38\t  evaluator_scores: EvaluatorScore[];\n39\t  circuit_breaker: CircuitBreakerState;\n40\t  trace_ids?: string[];\n41\t}\n42\t\n43\t// --- Constants ---\n44\t\n45\tconst STATE_DIR = '.codeharness';\n46\tconst STATE_FILE = 'workflow-state.yaml';\n47\t\n48\t// --- Functions ---\n49\t\n50\texport function getDefaultWorkflowState(): WorkflowState {\n51\t  return {\n52\t    workflow_name: '',\n53\t    started: '',\n54\t    iteration: 0,\n55\t    phase: 'idle',\n56\t    tasks_completed: [],\n57\t    evaluator_scores: [],\n58\t    circuit_breaker: {\n59\t      triggered: false,\n60\t      reason: null,\n61\t      score_history: [],\n62\t    },\n63\t    trace_ids: [],\n64\t  };\n65\t}\n66\t\n67\texport function writeWorkflowState(state: WorkflowState, dir?: string): void {\n68\t  const baseDir = dir ?? process.cwd();\n69\t  const stateDir = join(baseDir, STATE_DIR);\n70\t  mkdirSync(stateDir, { recursive: true });\n71\t  const yamlContent = stringify(state, { nullStr: 'null' });\n72\t  writeFileSync(join(stateDir, STATE_FILE), yamlContent, 'utf-8');\n73\t}\n74\t\n75\texport function readWorkflowState(dir?: string): WorkflowState {\n76\t  const baseDir = dir ?? process.cwd();\n77\t  const filePath = join(baseDir, STATE_DIR, STATE_FILE);\n78\t\n79\t  if (!existsSync(filePath)) {\n80\t    return getDefaultWorkflowState();\n81\t  }\n82\t\n83\t  let raw: string;\n84\t  try {\n85\t    raw = readFileSync(filePath, 'utf-8');\n86\t  } catch { // IGNORE: unreadable file (permissions, EISDIR, etc.) — recover with defaults\n87\t    warn('workflow-state.yaml could not be read — returning default state');\n88\t    return getDefaultWorkflowState();\n89\t  }\n90\t\n91\t  let parsed: unknown;\n92\t  try {\n93\t    parsed = parse(raw);\n94\t  } catch { // IGNORE: corrupted YAML — recover with defaults\n95\t    warn('workflow-state.yaml contains invalid YAML — returning default state');\n96\t    return getDefaultWorkflowState();\n97\t  }\n98\t\n99\t  if (!isValidWorkflowState(parsed)) {\n100\t    warn('workflow-state.yaml has invalid shape — returning default state');\n101\t    return getDefaultWorkflowState();\n102\t  }\n103\t\n104\t  return parsed;\n105\t}\n106\t\n107\t// --- Validation ---\n108\t\n109\tfunction isValidWorkflowState(value: unknown): value is WorkflowState {\n110\t  if (!value || typeof value !== 'object') return false;\n111\t  const s = value as Record<string, unknown>;\n112\t\n113\t  if (typeof s.workflow_name !== 'string') return false;\n114\t  if (typeof s.started !== 'string') return false;\n115\t  if (typeof s.iteration !== 'number') return false;\n116\t  if (typeof s.phase !== 'string') return false;\n117\t  if (!Array.isArray(s.tasks_completed)) return false;\n118\t  if (!Array.isArray(s.evaluator_scores)) return false;\n119\t  if (!s.circuit_breaker || typeof s.circuit_breaker !== 'object') return false;\n120\t\n121\t  // Validate trace_ids (optional array of strings)\n122\t  if (s.trace_ids !== undefined) {\n123\t    if (!Array.isArray(s.trace_ids)) return false;\n124\t    for (const id of s.trace_ids) {\n125\t      if (typeof id !== 'string') return false;\n126\t    }\n127\t  }\n128\t\n129\t  // Validate tasks_completed element shapes\n130\t  for (const t of s.tasks_completed) {\n131\t    if (!t || typeof t !== 'object') return false;\n132\t    const tc = t as Record<string, unknown>;\n133\t    if (typeof tc.task_name !== 'string') return false;\n134\t    if (typeof tc.story_key !== 'string') return false;\n135\t    if (typeof tc.completed_at !== 'string') return false;\n136\t    if (tc.session_id !== undefined && typeof tc.session_id !== 'string') return false;\n137\t    if (tc.error !== undefined && typeof tc.error !== 'boolean') return false;\n138\t  }\n139\t\n140\t  // Validate evaluator_scores element shapes\n141\t  for (const e of s.evaluator_scores) {\n142\t    if (!e || typeof e !== 'object') return false;\n143\t    const es = e as Record<string, unknown>;\n144\t    if (typeof es.iteration !== 'number') return false;\n145\t    if (typeof es.passed !== 'number') return false;\n146\t    if (typeof es.failed !== 'number') return false;\n147\t    if (typeof es.unknown !== 'number') return false;\n148\t    if (typeof es.total !== 'number') return false;\n149\t    if (typeof es.timestamp !== 'string') return false;\n150\t  }\n151\t\n152\t  const cb = s.circuit_breaker as Record<string, unknown>;\n153\t  if (typeof cb.triggered !== 'boolean') return false;\n154\t  if (cb.reason !== null && typeof cb.reason !== 'string') return false;\n155\t  if (!Array.isArray(cb.score_history)) return false;\n156\t\n157\t  // Validate score_history elements are numbers\n158\t  for (const score of cb.score_history) {\n159\t    if (typeof score !== 'number') return false;\n160\t  }\n161\t\n162\t  return true;\n163\t}\n164\t"}]},"parent_tool_use_id":"toolu_01ELiUhcroCmkW9Cb6Be3ouH","session_id":"452c48b4-eed2-4c96-83e9-8c71df0bbdac","uuid":"0a4de284-0211-4624-8977-6eacdfbb57a4","timestamp":"2026-04-02T23:18:05.003Z"}
