{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FME2hWEu6eEVuoku9BGugG","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { render } from 'ink-testing-library';\n3\timport React from 'react';\n4\timport { ActiveTool, CompletedTool, DriverCostSummary } from '../ink-activity-components.js';\n5\timport type { CompletedToolEntry } from '../ink-components.js';\n6\t\n7\t// --- ActiveTool tests ---\n8\t\n9\tdescribe('ActiveTool component', () => {\n10\t  it('renders driver name when provided', () => {\n11\t    const { lastFrame } = render(<ActiveTool name=\"Bash\" driverName=\"claude-code\" />);\n12\t    const frame = lastFrame()!;\n13\t    expect(frame).toContain('Bash');\n14\t    expect(frame).toContain('(claude-code)');\n15\t  });\n16\t\n17\t  it('renders without driver name (backward compat)', () => {\n18\t    const { lastFrame } = render(<ActiveTool name=\"Bash\" />);\n19\t    const frame = lastFrame()!;\n20\t    expect(frame).toContain('Bash');\n21\t    expect(frame).not.toContain('(');\n22\t  });\n23\t\n24\t  it('renders without driver name when null', () => {\n25\t    const { lastFrame } = render(<ActiveTool name=\"Read\" driverName={null} />);\n26\t    const frame = lastFrame()!;\n27\t    expect(frame).toContain('Read');\n28\t    expect(frame).not.toContain('(');\n29\t  });\n30\t});\n31\t\n32\t// --- CompletedTool tests ---\n33\t\n34\tdescribe('CompletedTool component', () => {\n35\t  it('renders driver name from entry', () => {\n36\t    const entry: CompletedToolEntry = { name: 'Edit', args: 'src/foo.ts', driver: 'codex' };\n37\t    const { lastFrame } = render(<CompletedTool entry={entry} />);\n38\t    const frame = lastFrame()!;\n39\t    expect(frame).toContain('Edit');\n40\t    expect(frame).toContain('src/foo.ts');\n41\t    expect(frame).toContain('(codex)');\n42\t  });\n43\t\n44\t  it('renders without driver name (backward compat)', () => {\n45\t    const entry: CompletedToolEntry = { name: 'Edit', args: 'src/foo.ts' };\n46\t    const { lastFrame } = render(<CompletedTool entry={entry} />);\n47\t    const frame = lastFrame()!;\n48\t    expect(frame).toContain('Edit');\n49\t    expect(frame).toContain('src/foo.ts');\n50\t    expect(frame).not.toContain('(');\n51\t  });\n52\t});\n53\t\n54\t// --- DriverCostSummary tests ---\n55\t\n56\tdescribe('DriverCostSummary component', () => {\n57\t  it('renders nothing when driverCosts is empty', () => {\n58\t    const { lastFrame } = render(<DriverCostSummary driverCosts={{}} />);\n59\t    expect(lastFrame()).toBe('');\n60\t  });\n61\t\n62\t  it('renders nothing when driverCosts is null-ish', () => {\n63\t    // Defensive: even though type says Record, runtime might get undefined\n64\t    const { lastFrame } = render(<DriverCostSummary driverCosts={undefined as unknown as Record<string, number>} />);\n65\t    expect(lastFrame()).toBe('');\n66\t  });\n67\t\n68\t  it('renders single driver cost', () => {\n69\t    const { lastFrame } = render(<DriverCostSummary driverCosts={{ 'claude-code': 1.5 }} />);\n70\t    const frame = lastFrame()!;\n71\t    expect(frame).toContain('Cost: claude-code $1.50');\n72\t  });\n73\t\n74\t  it('renders multi-driver costs sorted alphabetically', () => {\n75\t    const { lastFrame } = render(\n76\t      <DriverCostSummary driverCosts={{ codex: 0.45, 'claude-code': 1.23 }} />\n77\t    );\n78\t    const frame = lastFrame()!;\n79\t    expect(frame).toContain('Cost: claude-code $1.23, codex $0.45');\n80\t  });\n81\t\n82\t  it('formats cost as $X.XX with two decimal places', () => {\n83\t    const { lastFrame } = render(<DriverCostSummary driverCosts={{ opencode: 3 }} />);\n84\t    const frame = lastFrame()!;\n85\t    expect(frame).toContain('$3.00');\n86\t  });\n87\t});\n88\t"}]},"parent_tool_use_id":"toolu_0117vDhwD8YtdmVSBCbGt4wb","session_id":"a29ee53b-c2b0-4802-9455-7215112648b1","uuid":"e61eaf59-b95e-45ad-b583-db4a7b28c355","timestamp":"2026-04-03T12:09:33.898Z"}
