{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015GRcaxi5v21dbaXydse7J9","type":"tool_result","content":"1\timport { Command } from 'commander';\n2\timport { ok, fail, info, jsonOutput } from '../lib/output.js';\n3\timport {\n4\t  detectCoverageTool,\n5\t  runCoverage,\n6\t  checkOnlyCoverage,\n7\t  evaluateCoverage,\n8\t  updateCoverageState,\n9\t  printCoverageOutput,\n10\t  checkPerFileCoverage,\n11\t} from '../lib/coverage/index.js';\n12\t\n13\texport function registerCoverageCommand(program: Command): void {\n14\t  program\n15\t    .command('coverage')\n16\t    .description('Run tests with coverage and evaluate against targets')\n17\t    .option('--json', 'Machine-readable JSON output')\n18\t    .option('--check-only', 'Evaluate without running tests — reads last coverage report')\n19\t    .option('--story <id>', 'Associate coverage delta with a specific story')\n20\t    .option('--min-file <percent>', 'Minimum per-file statement coverage', '80')\n21\t    .action((opts, cmd) => {\n22\t      const globalOpts = cmd.optsWithGlobals();\n23\t      const isJson = opts.json === true || globalOpts.json === true;\n24\t      const checkOnly: boolean = opts.checkOnly === true;\n25\t      const storyId: string | undefined = opts.story;\n26\t      const minFile = parseInt(opts.minFile, 10) || 0;\n27\t      const root = process.cwd();\n28\t\n29\t      // 1. Detect coverage tool\n30\t      const toolInfo = detectCoverageTool(root);\n31\t\n32\t      if (toolInfo.tool === 'unknown') {\n33\t        if (isJson) {\n34\t          jsonOutput({\n35\t            status: 'fail',\n36\t            message: 'No coverage tool detected',\n37\t            tool: 'unknown',\n38\t          });\n39\t        } else {\n40\t          fail('No coverage tool detected. Ensure your project has a test runner configured.');\n41\t        }\n42\t        process.exitCode = 1;\n43\t        return;\n44\t      }\n45\t\n46\t      if (!isJson) {\n47\t        info(`Detected coverage tool: ${toolInfo.tool} (${toolInfo.runCommand})`);\n48\t      }\n49\t\n50\t      // 2. Run coverage or check-only\n51\t      const result = checkOnly ? checkOnlyCoverage(root) : runCoverage(root);\n52\t\n53\t      if (!result.success) {\n54\t        if (isJson) {\n55\t          jsonOutput({\n56\t            status: 'fail',\n57\t            message: result.rawOutput,\n58\t            testsPassed: false,\n59\t            passCount: 0,\n60\t            failCount: 0,\n61\t            coveragePercent: 0,\n62\t            target: 100,\n63\t            met: false,\n64\t            delta: null,\n65\t            baseline: null,\n66\t            tool: toolInfo.tool,\n67\t          });\n68\t        } else {\n69\t          fail(result.rawOutput);\n70\t        }\n71\t        process.exitCode = 1;\n72\t        return;\n73\t      }\n74\t\n75\t      // 3. Evaluate coverage\n76\t      const evaluation = evaluateCoverage(result, root);\n77\t\n78\t      // 4. Update state\n79\t      try {\n80\t        updateCoverageState(result, evaluation, root);\n81\t      } catch (err: unknown) {\n82\t        const message = err instanceof Error ? err.message : String(err);\n83\t        if (!isJson) {\n84\t          info(`Note: Could not update state file: ${message}`);\n85\t        }\n86\t      }\n87\t\n88\t      // 5. Per-file coverage floor check\n89\t      let perFileResult = null;\n90\t      if (minFile > 0) {\n91\t        perFileResult = checkPerFileCoverage(minFile, root);\n92\t      }\n93\t\n94\t      // 6. Output results\n95\t      const perFileOk = !perFileResult || perFileResult.violations.length === 0;\n96\t      if (isJson) {\n97\t        const status = result.testsPassed && evaluation.met && perFileOk ? 'ok' : 'fail';\n98\t        jsonOutput({\n99\t          status,\n100\t          testsPassed: result.testsPassed,\n101\t          passCount: result.passCount,\n102\t          failCount: result.failCount,\n103\t          coveragePercent: evaluation.actual,\n104\t          target: evaluation.target,\n105\t          met: evaluation.met,\n106\t          delta: evaluation.delta,\n107\t          baseline: evaluation.baseline,\n108\t          tool: toolInfo.tool,\n109\t          ...(storyId ? { story: storyId } : {}),\n110\t          ...(perFileResult ? {\n111\t            perFile: {\n112\t              floor: perFileResult.floor,\n113\t              totalFiles: perFileResult.totalFiles,\n114\t              violationCount: perFileResult.violations.length,\n115\t              violations: perFileResult.violations,\n116\t            },\n117\t          } : {}),\n118\t        });\n119\t      } else {\n120\t        printCoverageOutput(result, evaluation);\n121\t        if (storyId) {\n122\t          info(`Story: ${storyId}`);\n123\t        }\n124\t        if (perFileResult && perFileResult.violations.length > 0) {\n125\t          fail(`${perFileResult.violations.length} file(s) below ${minFile}% statement coverage:`);\n126\t          for (const v of perFileResult.violations) {\n127\t            fail(`  ${v.file}: ${v.statements}% statements, ${v.branches}% branches`);\n128\t          }\n129\t        } else if (perFileResult) {\n130\t          ok(`All ${perFileResult.totalFiles} files above ${minFile}% statement coverage`);\n131\t        }\n132\t      }\n133\t\n134\t      // 7. Set exit code\n135\t      if (!result.testsPassed || !evaluation.met || !perFileOk) {\n136\t        process.exitCode = 1;\n137\t      }\n138\t    });\n139\t}\n140\t"}]},"parent_tool_use_id":"toolu_01EbWLuRzBfXxKEeXQE4hLnQ","session_id":"9c9fe147-c536-4d36-9f64-8249f0c68839","uuid":"4d357b55-805d-4472-a781-bf5f9829771c","timestamp":"2026-04-03T16:52:13.738Z"}
