{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NHU6kNggC8fY2wd4Pfv9jj","type":"tool_result","content":"     1→/**\n     2→ * Status endpoints — URL builders for observability dashboards.\n     3→ * Pure functions; no filesystem or network access.\n     4→ */\n     5→\n     6→import type { HarnessState } from '../../lib/state.js';\n     7→\n     8→export interface EndpointUrls {\n     9→  logs: string;\n    10→  metrics: string;\n    11→  traces: string;\n    12→  otel_http: string;\n    13→}\n    14→\n    15→export interface ScopedEndpointUrls {\n    16→  logs: string;\n    17→  metrics: string;\n    18→  traces: string;\n    19→}\n    20→\n    21→export const DEFAULT_ENDPOINTS: EndpointUrls = {\n    22→  logs: 'http://localhost:9428',\n    23→  metrics: 'http://localhost:8428',\n    24→  traces: 'http://localhost:16686',\n    25→  otel_http: 'http://localhost:4318',\n    26→};\n    27→\n    28→/**\n    29→ * Build service-scoped endpoint URLs for observability dashboards.\n    30→ * Produces URLs filtered by service_name for logs, metrics, and traces.\n    31→ */\n    32→export function buildScopedEndpoints(endpoints: EndpointUrls, serviceName: string): ScopedEndpointUrls {\n    33→  const encoded = encodeURIComponent(serviceName);\n    34→  return {\n    35→    logs: `${endpoints.logs}/select/logsql/query?query=${encodeURIComponent(`service_name:${serviceName}`)}`,\n    36→    metrics: `${endpoints.metrics}/api/v1/query?query=${encodeURIComponent(`{service_name=\"${serviceName}\"}`)}`,\n    37→    traces: `${endpoints.traces}/api/traces?service=${encoded}&limit=20`,\n    38→  };\n    39→}\n    40→\n    41→/**\n    42→ * Resolve the correct endpoint URLs based on OTLP mode.\n    43→ * - remote-direct: all endpoints point to the remote OTLP endpoint\n    44→ * - remote-routed: uses configured remote backend URLs, falls back to defaults\n    45→ * - local-shared (default): uses DEFAULT_ENDPOINTS\n    46→ */\n    47→export function resolveEndpoints(state: HarnessState): EndpointUrls {\n    48→  const mode = state.otlp?.mode ?? 'local-shared';\n    49→  if (mode === 'remote-direct') {\n    50→    const endpoint = state.otlp?.endpoint ?? 'http://localhost:4318';\n    51→    return {\n    52→      logs: endpoint,\n    53→      metrics: endpoint,\n    54→      traces: endpoint,\n    55→      otel_http: endpoint,\n    56→    };\n    57→  }\n    58→  if (mode === 'remote-routed') {\n    59→    const re = state.docker?.remote_endpoints;\n    60→    return {\n    61→      logs: re?.logs_url ?? DEFAULT_ENDPOINTS.logs,\n    62→      metrics: re?.metrics_url ?? DEFAULT_ENDPOINTS.metrics,\n    63→      traces: re?.traces_url ?? DEFAULT_ENDPOINTS.traces,\n    64→      otel_http: DEFAULT_ENDPOINTS.otel_http,\n    65→    };\n    66→  }\n    67→  return DEFAULT_ENDPOINTS;\n    68→}\n    69→"}]},"parent_tool_use_id":"toolu_013rWcam9ZLGWy8y97T6yhWS","session_id":"790cd04c-5c91-45bb-998d-78a56b65af9a","uuid":"da41eaa2-4f76-4a69-a64d-f60b2c494df1","timestamp":"2026-03-24T23:19:46.824Z"}
