ifyImage,\n    47→  detectProjectType,\n    48→  prepareVerifyWorkspace,\n    49→  checkVerifyEnv,\n    50→  cleanupVerifyEnv,\n    51→  cleanupStaleContainers,\n    52→} from '../env.js';\n    53→\n    54→const mockExecFileSync = vi.mocked(execFileSync);\n    55→const mockIsDockerAvailable = vi.mocked(isDockerAvailable);\n    56→const mockDetectStack = vi.mocked(detectStack);\n    57→const mockDetectStacks = vi.mocked(detectStacks);\n    58→const mockReadStateWithBody = vi.mocked(readStateWithBody);\n    59→const mockWriteState = vi.mocked(writeState);\n    60→\n    61→let testDir: string;\n    62→\n    63→beforeEach(() => {\n    64→  vi.clearAllMocks();\n    65→  testDir = mkdtempSync(join(tmpdir(), 'ch-verify-env-test-'));\n    66→  // Create templates/Dockerfile.verify so buildVerifyImage can find it\n    67→  mkdirSync(join(testDir, 'templates'), { recursive: true });\n    68→  writeFileSync(join(testDir, 'templates', 'Dockerfile.verify'), 'FROM node:20-slim\\nARG TARBALL=package.tgz\\nCOPY ${TARBALL} /tmp/\\n');\n    69→  writeFileSync(join(testDir, 'templates', 'Dockerfile.verify.generic'), 'FROM node:20-slim\\nRUN apt-get update\\n');\n    70→  // Reset default mock behaviors after clearAllMocks\n    71→  mockIsDockerAvailable.mockReturnValue(true);\n    72→  mockDetectStack.mockReturnValue('nodejs');\n    73→  mockDetectStacks.mockReturnValue([{ stack: 'nodejs', dir: '.' }]);\n    74→});\n    75→\n    76→afterEach(() => {\n    77→  rmSync(testDir, { recursive: true, force: true });\n    78→});\n    79→\n    80→// ─── isValidStoryKey ────────────────────────────────────────────────────────"}]},"parent_tool_use_id":"toolu_01AeWcLgyHoXRPKGkiwoR1Eu","session_id":"38809bab-d371-4c03-b647-b7b7381ee002","uuid":"50038204-30d8-45ad-b9ff-49c9bcb7cb64","timestamp":"2026-03-24T23:37:07.138Z"}
