onConfig;\n52\t  /** Story-level flow steps (normalized from `flow` or `story_flow`). */\n53\t  storyFlow: FlowStep[];\n54\t  /** Epic-level flow steps (empty if not defined). */\n55\t  epicFlow: FlowStep[];\n56\t}\n57\t\n58\t// --- Error Class ---\n59\t\n60\texport class WorkflowParseError extends Error {\n61\t  public readonly errors: Array<{ path: string; message: string }>;\n62\t\n63\t  constructor(message: string, errors?: Array<{ path: string; message: string }>) {\n64\t    super(message);\n65\t    this.name = 'WorkflowParseError';\n66\t    this.errors = errors ?? [];\n67\t  }\n68\t}\n69\t\n70\t// --- Referential Integrity Validation ---\n71\t\n72\t/**\n73\t * Validate that driver and agent references in tasks point to real registered\n74\t * drivers and resolvable agents. Collects errors into the provided array\n75\t * (does not throw — caller decides when to throw).\n76\t *\n77\t * Driver validation is skipped when the driver registry is empty (parse can\n78\t * be called independently of engine startup).\n79\t *"}]},"parent_tool_use_id":"toolu_01QNNr4yQoQQfPTTg7FsQuMG","session_id":"e648a229-0e5b-4ea4-9861-593afdfcccd5","uuid":"315da480-99fe-4964-85ae-3c333d1d85fd","timestamp":"2026-04-03T19:01:58.756Z"}
