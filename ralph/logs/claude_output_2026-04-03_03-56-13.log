{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016bVzeJUqiGQVywY5xkZejf","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { parse } from 'yaml';\n3\timport { warn } from './output.js';\n4\timport { dispatchAgent, DispatchError } from './agent-dispatch.js';\n5\timport type { DispatchOptions, DispatchResult } from './agent-dispatch.js';\n6\timport type { SubagentDefinition } from './agent-resolver.js';\n7\timport type { ResolvedWorkflow, ResolvedTask, FlowStep, LoopBlock } from './workflow-parser.js';\n8\timport {\n9\t  readWorkflowState,\n10\t  writeWorkflowState,\n11\t} from './workflow-state.js';\n12\timport type { WorkflowState, TaskCheckpoint } from './workflow-state.js';\n13\timport { createIsolatedWorkspace } from './source-isolation.js';\n14\timport { generateTraceId, formatTracePrompt, recordTraceId } from './trace-id.js';\n15\timport { resolveSessionId, recordSessionId } from './session-manager.js';\n16\timport type { SessionLookupKey } from './session-manager.js';\n17\timport { parseVerdict, VerdictParseError } from './verdict-parser.js';\n18\timport type { EvaluatorVerdict } from './verdict-parser.js';\n19\t\n20\t// Re-export EvaluatorVerdict for downstream consumers that import from workflow-engine\n21\texport type { EvaluatorVerdict } from './verdict-parser.js';\n22\texport { parseVerdict } from './verdict-parser.js';\n23\t\n24\t// --- Interfaces ---\n25\t\n26\t/**\n27\t * Configuration for the workflow engine.\n28\t */\n29\texport interface EngineConfig {\n30\t  /** The resolved workflow with tasks and flow steps. */\n31\t  workflow: ResolvedWorkflow;\n32\t  /** Pre-compiled agent definitions keyed by agent name. */\n33\t  agents: Record<string, SubagentDefinition>;\n34\t  /** Path to sprint-status.yaml for work item discovery. */\n35\t  sprintStatusPath: string;\n36\t  /** Optional path to issues.yaml for additional work items. */\n37\t  issuesPath?: string;\n38\t  /** Unique identifier for this engine run. */\n39\t  runId: string;\n40\t  /** Project root directory. Defaults to process.cwd(). */\n41\t  projectDir?: string;\n42\t  /** Maximum loop iterations before termination. Defaults to 5. */\n43\t  maxIterations?: number;\n44\t}\n45\t\n46\t/**\n47\t * Result returned by executeWorkflow().\n48\t */\n49\texport interface EngineResult {\n50\t  /** Whether the workflow completed without errors. */\n51\t  success: boolean;\n52\t  /** Number of task dispatches completed. */\n53\t  tasksCompleted: number;\n54\t  /** Number of work items (stories/issues) processed. */\n55\t  storiesProcessed: number;\n56\t  /** Errors encountered during execution. */\n57\t  errors: EngineError[];\n58\t  /** Wall-clock duration of the entire workflow in milliseconds. */\n59\t  durationMs: number;\n60\t}\n61\t\n62\t/**\n63\t * Structured error recorded during workflow execution.\n64\t */\n65\texport interface EngineError {\n66\t  taskName: string;\n67\t  storyKey: string;\n68\t  code: string;\n69\t  message: string;\n70\t}\n71\t\n72\t/**\n73\t * A work item (story or issue) ready for execution.\n74\t */\n75\texport interface WorkItem {\n76\t  key: string;\n77\t  title?: string;\n78\t  source: 'sprint' | 'issues';\n79\t}\n80\t\n81\t// --- Constants ---\n82\t\n83\t/** Sentinel story key for per-run tasks. */\n84\texport const PER_RUN_SENTINEL = '__run__';\n85\t\n86\t/** DispatchError codes that should halt execution immediately. */\n87\tconst HALT_ERROR_CODES = new Set(['RATE_LIMIT', 'NETWORK', 'SDK_INIT']);\n88\t\n89\t/** Default maximum loop iterations before termination. */\n90\tconst DEFAULT_MAX_ITERATIONS = 5;\n91\t\n92\t// --- Crash Recovery: Task Completion Check ---\n93\t\n94\t/**\n95\t * Check whether a (taskName, storyKey) combination is already recorded\n96\t * in the workflow state's tasks_completed array.\n97\t *\n98\t * Both fields must match for the task to be considered completed.\n99\t * Used by the resume logic to skip already-completed dispatches.\n100\t */\n101\texport function isTaskCompleted(\n102\t  state: WorkflowState,\n103\t  taskName: string,\n104\t  storyKey: string,\n105\t): boolean {\n106\t  return state.tasks_completed.some(\n107\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey && !cp.error,\n108\t  );\n109\t}\n110\t\n111\t/**\n112\t * Check whether a (taskName, storyKey) combination has been completed\n113\t * enough times to cover the current iteration in a loop block.\n114\t *\n115\t * Loop tasks execute the same (taskName, storyKey) pair each iteration,\n116\t * recording a new checkpoint each time. To determine if a task is done\n117\t * for the current iteration, we count how many matching checkpoints exist\n118\t * and compare to the current iteration number.\n119\t */\n120\texport function isLoopTaskCompleted(\n121\t  state: WorkflowState,\n122\t  taskName: string,\n123\t  storyKey: string,\n124\t  iteration: number,\n125\t): boolean {\n126\t  const count = state.tasks_completed.filter(\n127\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey && !cp.error,\n128\t  ).length;\n129\t  return count >= iteration;\n130\t}\n131\t\n132\t// --- Work Item Loading ---\n133\t\n134\t/**\n135\t * Load work items from sprint-status.yaml and optionally issues.yaml.\n136\t *\n137\t * Stories are extracted from the `development_status` section of sprint-status.yaml.\n138\t * Issues are extracted from the `issues` array of issues.yaml.\n139\t *\n140\t * Only items with status `backlog` or `ready-for-dev` are included.\n141\t * Epic keys (`epic-*`) and retrospective keys (`*-retrospective`) are excluded.\n142\t *\n143\t * If issues.yaml does not exist, returns only stories (no error).\n144\t */\n145\texport function loadWorkItems(sprintStatusPath: string, issuesPath?: string): WorkItem[] {\n146\t  const items: WorkItem[] = [];\n147\t\n148\t  // --- Load stories from sprint-status.yaml ---\n149\t  if (existsSync(sprintStatusPath)) {\n150\t    let raw: string;\n151\t    try {\n152\t      raw = readFileSync(sprintStatusPath, 'utf-8');\n153\t    } catch { // IGNORE: unreadable file — warn and return empty\n154\t      warn(`workflow-engine: could not read sprint-status.yaml at ${sprintStatusPath}`);\n155\t      return items;\n156\t    }\n157\t\n158\t    let parsed: unknown;\n159\t    try {\n160\t      parsed = parse(raw);\n161\t    } catch { // IGNORE: malformed YAML — warn and return empty\n162\t      warn(`workflow-engine: invalid YAML in sprint-status.yaml at ${sprintStatusPath}`);\n163\t      return items;\n164\t    }\n165\t\n166\t    if (parsed && typeof parsed === 'object') {\n167\t      const data = parsed as Record<string, unknown>;\n168\t      const devStatus = data.development_status as Record<string, unknown> | undefined;\n169\t\n170\t      if (devStatus && typeof devStatus === 'object') {\n171\t        for (const [key, status] of Object.entries(devStatus)) {\n172\t          // Skip epic keys and retrospective keys\n173\t          if (key.startsWith('epic-')) continue;\n174\t          if (key.endsWith('-retrospective')) continue;\n175\t\n176\t          // Only include backlog or ready-for-dev\n177\t          if (status === 'backlog' || status === 'ready-for-dev') {\n178\t            items.push({ key, source: 'sprint' });\n179\t          }\n180\t        }\n181\t      }\n182\t    }\n183\t  }\n184\t\n185\t  // --- Load issues from issues.yaml ---\n186\t  if (issuesPath && existsSync(issuesPath)) {\n187\t    let raw: string;\n188\t    try {\n189\t      raw = readFileSync(issuesPath, 'utf-8');\n190\t    } catch { // IGNORE: unreadable issues file — warn and return what we have\n191\t      warn(`workflow-engine: could not read issues.yaml at ${issuesPath}`);\n192\t      return items;\n193\t    }\n194\t\n195\t    let parsed: unknown;\n196\t    try {\n197\t      parsed = parse(raw);\n198\t    } catch { // IGNORE: malformed issues YAML — warn and return what we have\n199\t      warn(`workflow-engine: invalid YAML in issues.yaml at ${issuesPath}`);\n200\t      return items;\n201\t    }\n202\t\n203\t    if (parsed && typeof parsed === 'object') {\n204\t      const data = parsed as Record<string, unknown>;\n205\t      const issuesList = data.issues as Array<Record<string, unknown>> | undefined;\n206\t\n207\t      if (Array.isArray(issuesList)) {\n208\t        for (const issue of issuesList) {\n209\t          if (issue && typeof issue === 'object') {\n210\t            const status = issue.status as string | undefined;\n211\t            if (status === 'backlog' || status === 'ready-for-dev') {\n212\t              items.push({\n213\t                key: issue.id as string,\n214\t                title: issue.title as string | undefined,\n215\t                source: 'issues',\n216\t              });\n217\t            }\n218\t          }\n219\t        }\n220\t      }\n221\t    }\n222\t  }\n223\t\n224\t  return items;\n225\t}\n226\t\n227\t// --- Single Task Dispatch ---\n228\t\n229\t/**\n230\t * Dispatch a single task for a specific work item (or per-run sentinel).\n231\t *\n232\t * Handles: trace ID generation, session resolution, source isolation,\n233\t * agent dispatch, state checkpointing, and cleanup.\n234\t *\n235\t * Returns the updated workflow state after recording the dispatch.\n236\t */\n237\texport async function dispatchTask(\n238\t  task: ResolvedTask,\n239\t  taskName: string,\n240\t  storyKey: string,\n241\t  definition: SubagentDefinition,\n242\t  state: WorkflowState,\n243\t  config: EngineConfig,\n244\t  customPrompt?: string,\n245\t): Promise<WorkflowState> {\n246\t  const { updatedState } = await dispatchTaskWithResult(\n247\t    task, taskName, storyKey, definition, state, config, customPrompt,\n248\t  );\n249\t  return updatedState;\n250\t}\n251\t\n252\t// --- Flow Step Type Guard ---\n253\t\n254\tfunction isLoopBlock(step: FlowStep): step is LoopBlock {\n255\t  return typeof step === 'object' && step !== null && 'loop' in step;\n256\t}\n257\t\n258\t// --- Core Dispatch (shared by dispatchTask and loop block execution) ---\n259\t\n260\t/**\n261\t * Dispatch a task and return both the updated state and the raw dispatch output.\n262\t * This is the single implementation of task dispatch logic. Both `dispatchTask()`\n263\t * and loop block execution delegate here.\n264\t */\n265\tasync function dispatchTaskWithResult(\n266\t  task: ResolvedTask,\n267\t  taskName: string,\n268\t  storyKey: string,\n269\t  definition: SubagentDefinition,\n270\t  state: WorkflowState,\n271\t  config: EngineConfig,\n272\t  customPrompt?: string,\n273\t): Promise<{ updatedState: WorkflowState; output: string }> {\n274\t  const projectDir = config.projectDir ?? process.cwd();\n275\t\n276\t  // 1. Generate trace ID\n277\t  const traceId = generateTraceId(config.runId, state.iteration, taskName);\n278\t\n279\t  // 2. Format trace prompt\n280\t  const tracePrompt = formatTracePrompt(traceId);\n281\t\n282\t  // 3. Resolve session ID\n283\t  const sessionKey: SessionLookupKey = { taskName, storyKey };\n284\t  const sessionId = resolveSessionId(task.session, sessionKey, state);\n285\t\n286\t  // 4. Build dispatch options based on source_access\n287\t  let dispatchOptions: DispatchOptions;\n288\t  let workspace: Awaited<ReturnType<typeof createIsolatedWorkspace>> | null = null;\n289\t\n290\t  if (task.source_access === false) {\n291\t    workspace = await createIsolatedWorkspace({ runId: config.runId, storyFiles: [] });\n292\t    dispatchOptions = {\n293\t      ...workspace.toDispatchOptions(),\n294\t      sessionId,\n295\t      appendSystemPrompt: tracePrompt,\n296\t    };\n297\t  } else {\n298\t    dispatchOptions = {\n299\t      cwd: projectDir,\n300\t      sessionId,\n301\t      appendSystemPrompt: tracePrompt,\n302\t    };\n303\t  }\n304\t\n305\t  // 5. Construct prompt\n306\t  const prompt = customPrompt\n307\t    ?? (storyKey === PER_RUN_SENTINEL\n308\t      ? `Execute task \"${taskName}\" for the current run.`\n309\t      : `Implement story ${storyKey}`);\n310\t\n311\t  // 6. Dispatch agent\n312\t  let result: DispatchResult;\n313\t  try {\n314\t    result = await dispatchAgent(definition, prompt, dispatchOptions);\n315\t  } finally {\n316\t    // Cleanup workspace regardless of dispatch success/failure\n317\t    if (workspace) {\n318\t      await workspace.cleanup();\n319\t    }\n320\t  }\n321\t\n322\t  // 7. Record session ID (if dispatch returned one)\n323\t  let updatedState = state;\n324\t  if (result.sessionId) {\n325\t    updatedState = recordSessionId(sessionKey, result.sessionId, updatedState);\n326\t  } else {\n327\t    // Append checkpoint manually when no session ID is returned\n328\t    const checkpoint: TaskCheckpoint = {\n329\t      task_name: taskName,\n330\t      story_key: storyKey,\n331\t      completed_at: new Date().toISOString(),\n332\t    };\n333\t    updatedState = {\n334\t      ...updatedState,\n335\t      tasks_completed: [...updatedState.tasks_completed, checkpoint],\n336\t    };\n337\t  }\n338\t\n339\t  // 8. Record trace ID\n340\t  updatedState = recordTraceId(traceId, updatedState);\n341\t\n342\t  // 9. Write state to disk\n343\t  writeWorkflowState(updatedState, projectDir);\n344\t\n345\t  return { updatedState, output: result.output };\n346\t}\n347\t\n348\t// --- Retry Prompt Construction (Task 3) ---\n349\t\n350\t/**\n351\t * Build a retry prompt with evaluator findings injected.\n352\t * Includes only failed/unknown findings.\n353\t */\n354\texport function buildRetryPrompt(storyKey: string, findings: EvaluatorVerdict['findings']): string {\n355\t  const failedFindings = findings.filter(\n356\t    (f) => f.status === 'fail' || f.status === 'unknown',\n357\t  );\n358\t\n359\t  if (failedFindings.length === 0) {\n360\t    return `Implement story ${storyKey}`;\n361\t  }\n362\t\n363\t  const formattedFindings = failedFindings\n364\t    .map((f) => {\n365\t      const status = f.status.toUpperCase();\n366\t      let entry = `AC #${f.ac} (${status}): ${f.description}`;\n367\t      if (f.evidence?.reasoning) {\n368\t        entry += `\\n  Evidence: ${f.evidence.reasoning}`;\n369\t      }\n370\t      return entry;\n371\t    })\n372\t    .join('\\n\\n');\n373\t\n374\t  return `Retry story ${storyKey}. Previous evaluator findings:\\n\\n${formattedFindings}\\n\\nFocus on fixing the failed criteria above.`;\n375\t}\n376\t\n377\t// --- All-UNKNOWN Verdict Builder ---\n378\t\n379\t/**\n380\t * Build an all-UNKNOWN EvaluatorVerdict as fallback when the evaluator\n381\t * fails to produce valid JSON after retry.\n382\t */\n383\texport function buildAllUnknownVerdict(\n384\t  workItems: WorkItem[],\n385\t  reasoning: string,\n386\t): EvaluatorVerdict {\n387\t  const findings = workItems.map((_, index) => ({\n388\t    ac: index + 1,\n389\t    description: `AC #${index + 1}`,\n390\t    status: 'unknown' as const,\n391\t    evidence: {\n392\t      commands_run: [] as string[],\n393\t      output_observed: '',\n394\t      reasoning,\n395\t    },\n396\t  }));\n397\t\n398\t  return {\n399\t    verdict: 'fail',\n400\t    score: {\n401\t      passed: 0,\n402\t      failed: 0,\n403\t      unknown: findings.length,\n404\t      total: findings.length,\n405\t    },\n406\t    findings,\n407\t  };\n408\t}\n409\t\n410\t// --- Failed Story Filtering (Task 4) ---\n411\t\n412\t/**\n413\t * Determine which work items failed based on evaluator findings.\n414\t * If verdict is null (parse failure), returns all items (conservative fallback).\n415\t */\n416\texport function getFailedItems(\n417\t  verdict: EvaluatorVerdict | null,\n418\t  allItems: WorkItem[],\n419\t): WorkItem[] {\n420\t  if (!verdict) return allItems;\n421\t\n422\t  // If verdict passed, no items need retry\n423\t  if (verdict.verdict === 'pass') return [];\n424\t\n425\t  // All items are retried on failure — per-story filtering based on individual\n426\t  // story results is not possible with the current verdict shape (verdict is per-run).\n427\t  // The findings track ACs, not stories. Conservative: retry all on failure.\n428\t  return allItems;\n429\t}\n430\t\n431\t// --- Loop Block Execution (Task 5) ---\n432\t\n433\t/**\n434\t * Result of loop block execution.\n435\t */\n436\tinterface LoopBlockResult {\n437\t  state: WorkflowState;\n438\t  errors: EngineError[];\n439\t  tasksCompleted: number;\n440\t  halted: boolean;\n441\t}\n442\t\n443\t/**\n444\t * Execute a loop block: iterate tasks until pass, max iterations, or circuit breaker.\n445\t */\n446\texport async function executeLoopBlock(\n447\t  loopBlock: LoopBlock,\n448\t  state: WorkflowState,\n449\t  config: EngineConfig,\n450\t  workItems: WorkItem[],\n451\t): Promise<LoopBlockResult> {\n452\t  const projectDir = config.projectDir ?? process.cwd();\n453\t  const maxIterations = config.maxIterations ?? DEFAULT_MAX_ITERATIONS;\n454\t  const errors: EngineError[] = [];\n455\t  let tasksCompleted = 0;\n456\t  let currentState = state;\n457\t  let lastVerdict: EvaluatorVerdict | null = null;\n458\t\n459\t  // Handle empty loop block\n460\t  if (loopBlock.loop.length === 0) {\n461\t    return { state: currentState, errors, tasksCompleted, halted: false };\n462\t  }\n463\t\n464\t  while (true) {\n465\t    // 1. Determine whether to increment iteration or resume a partial one.\n466\t    //    On fresh start (iteration === 0), always increment.\n467\t    //    On resume (iteration > 0), check if the current iteration is fully done.\n468\t    const nextIteration = currentState.iteration + 1;\n469\t    const allCurrentIterationDone = currentState.iteration > 0 && loopBlock.loop.every((tn) => {\n470\t      const t = config.workflow.tasks[tn];\n471\t      if (!t) return true; // missing task = skip = \"done\"\n472\t      if (t.scope === 'per-story') {\n473\t        return workItems.every((item) =>\n474\t          isLoopTaskCompleted(currentState, tn, item.key, currentState.iteration));\n475\t      }\n476\t      return isLoopTaskCompleted(currentState, tn, PER_RUN_SENTINEL, currentState.iteration);\n477\t    });\n478\t\n479\t    if (currentState.iteration === 0 || allCurrentIterationDone) {\n480\t      // Fresh start or current iteration fully done — advance\n481\t      currentState = {\n482\t        ...currentState,\n483\t        iteration: nextIteration,\n484\t      };\n485\t      writeWorkflowState(currentState, projectDir);\n486\t    }\n487\t    // else: resuming a partially completed iteration — keep current iteration\n488\t\n489\t    let haltedInLoop = false;\n490\t\n491\t    // 2. Execute each task in the loop\n492\t    for (const taskName of loopBlock.loop) {\n493\t      const task = config.workflow.tasks[taskName];\n494\t      if (!task) {\n495\t        warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n496\t        continue;\n497\t      }\n498\t\n499\t      const definition = config.agents[task.agent];\n500\t      if (!definition) {\n501\t        warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n502\t        continue;\n503\t      }\n504\t\n505\t      if (task.scope === 'per-story') {\n506\t        // Determine which items to dispatch for\n507\t        const itemsToRetry = lastVerdict ? getFailedItems(lastVerdict, workItems) : workItems;\n508\t\n509\t        for (const item of itemsToRetry) {\n510\t          // Skip if already completed for this iteration (crash recovery — AC #4)\n511\t          if (isLoopTaskCompleted(currentState, taskName, item.key, currentState.iteration)) {\n512\t            warn(`workflow-engine: skipping completed task ${taskName} for ${item.key}`);\n513\t            continue;\n514\t          }\n515\t\n516\t          // Build prompt: inject findings if we have a previous verdict\n517\t          const prompt = lastVerdict\n518\t            ? buildRetryPrompt(item.key, lastVerdict.findings)\n519\t            : undefined;\n520\t\n521\t          try {\n522\t            currentState = await dispatchTask(\n523\t              task, taskName, item.key, definition, currentState, config, prompt,\n524\t            );\n525\t            tasksCompleted++;\n526\t          } catch (err: unknown) {\n527\t            const engineError = handleDispatchError(err, taskName, item.key);\n528\t            errors.push(engineError);\n529\t            currentState = recordErrorInState(currentState, taskName, item.key, engineError);\n530\t            writeWorkflowState(currentState, projectDir);\n531\t\n532\t            if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n533\t              haltedInLoop = true;\n534\t              break;\n535\t            }\n536\t            continue;\n537\t          }\n538\t        }\n539\t\n540\t        if (haltedInLoop) break;\n541\t      } else {\n542\t        // per-run task (e.g., verify)\n543\t        // Skip if already completed for this iteration (crash recovery — AC #4)\n544\t        if (isLoopTaskCompleted(currentState, taskName, PER_RUN_SENTINEL, currentState.iteration)) {\n545\t          warn(`workflow-engine: skipping completed task ${taskName} for ${PER_RUN_SENTINEL}`);\n546\t          continue;\n547\t        }\n548\t\n549\t        try {\n550\t          // We need the dispatch result output to parse verdict\n551\t          // dispatchTask doesn't return the DispatchResult directly, so we\n552\t          // intercept via a wrapper that captures the output\n553\t          const dispatchResult = await dispatchTaskWithResult(\n554\t            task, taskName, PER_RUN_SENTINEL, definition, currentState, config,\n555\t          );\n556\t          currentState = dispatchResult.updatedState;\n557\t          tasksCompleted++;\n558\t\n559\t          // Attempt to parse verdict from output with retry semantics (story 6-2)\n560\t          let verdict: EvaluatorVerdict | null = null;\n561\t          try {\n562\t            verdict = parseVerdict(dispatchResult.output);\n563\t          } catch (parseErr: unknown) {\n564\t            if (parseErr instanceof VerdictParseError && parseErr.retryable) {\n565\t              // Re-dispatch evaluator for one retry attempt\n566\t              warn(`workflow-engine: verdict parse failed, retrying evaluator for ${taskName}`);\n567\t              try {\n568\t                const retryResult = await dispatchTaskWithResult(\n569\t                  task, taskName, PER_RUN_SENTINEL, definition, currentState, config,\n570\t                );\n571\t                currentState = retryResult.updatedState;\n572\t                tasksCompleted++;\n573\t                verdict = parseVerdict(retryResult.output);\n574\t              } catch { // IGNORE: retry failed — fall back to all-UNKNOWN verdict\n575\t                // Second failure: generate all-UNKNOWN verdict\n576\t                verdict = buildAllUnknownVerdict(\n577\t                  workItems,\n578\t                  'Evaluator failed to produce valid JSON after retry',\n579\t                );\n580\t              }\n581\t            }\n582\t            // If not a VerdictParseError or not retryable, verdict stays null\n583\t          }\n584\t          lastVerdict = verdict;\n585\t\n586\t          // Record score in state\n587\t          if (verdict) {\n588\t            const score = {\n589\t              iteration: currentState.iteration,\n590\t              passed: verdict.score.passed,\n591\t              failed: verdict.score.failed,\n592\t              unknown: verdict.score.unknown,\n593\t              total: verdict.score.total,\n594\t              timestamp: new Date().toISOString(),\n595\t            };\n596\t            currentState = {\n597\t              ...currentState,\n598\t              evaluator_scores: [...currentState.evaluator_scores, score],\n599\t            };\n600\t          } else {\n601\t            // Parse failure: record all-UNKNOWN score\n602\t            const totalItems = workItems.length;\n603\t            const score = {\n604\t              iteration: currentState.iteration,\n605\t              passed: 0,\n606\t              failed: 0,\n607\t              unknown: totalItems,\n608\t              total: totalItems,\n609\t              timestamp: new Date().toISOString(),\n610\t            };\n611\t            currentState = {\n612\t              ...currentState,\n613\t              evaluator_scores: [...currentState.evaluator_scores, score],\n614\t            };\n615\t          }\n616\t          writeWorkflowState(currentState, projectDir);\n617\t        } catch (err: unknown) {\n618\t          const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n619\t          errors.push(engineError);\n620\t          currentState = recordErrorInState(currentState, taskName, PER_RUN_SENTINEL, engineError);\n621\t          writeWorkflowState(currentState, projectDir);\n622\t\n623\t          // Clear stale verdict so next iteration retries all items\n624\t          lastVerdict = null;\n625\t\n626\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n627\t            haltedInLoop = true;\n628\t            break;\n629\t          }\n630\t          continue;\n631\t        }\n632\t      }\n633\t    }\n634\t\n635\t    if (haltedInLoop) {\n636\t      return { state: currentState, errors, tasksCompleted, halted: true };\n637\t    }\n638\t\n639\t    // 3. Check termination conditions\n640\t    if (lastVerdict?.verdict === 'pass') {\n641\t      // Success: loop passes\n642\t      return { state: currentState, errors, tasksCompleted, halted: false };\n643\t    }\n644\t\n645\t    if (currentState.iteration >= maxIterations) {\n646\t      currentState = { ...currentState, phase: 'max-iterations' };\n647\t      writeWorkflowState(currentState, projectDir);\n648\t      return { state: currentState, errors, tasksCompleted, halted: false };\n649\t    }\n650\t\n651\t    if (currentState.circuit_breaker.triggered) {\n652\t      currentState = { ...currentState, phase: 'circuit-breaker' };\n653\t      writeWorkflowState(currentState, projectDir);\n654\t      return { state: currentState, errors, tasksCompleted, halted: false };\n655\t    }\n656\t  }\n657\t}\n658\t\n659\t\n660\t// --- Main Execution ---\n661\t\n662\t/**\n663\t * Execute a workflow sequentially: iterate through flow steps, dispatch tasks\n664\t * per-story or per-run, checkpoint state after each dispatch.\n665\t *\n666\t * Loop blocks execute iteratively until pass, max-iterations, or circuit-breaker.\n667\t *\n668\t * Returns an EngineResult summarizing the execution.\n669\t */\n670\texport async function executeWorkflow(config: EngineConfig): Promise<EngineResult> {\n671\t  const startMs = Date.now();\n672\t  const projectDir = config.projectDir ?? process.cwd();\n673\t  const errors: EngineError[] = [];\n674\t  let tasksCompleted = 0;\n675\t  const processedStories = new Set<string>();\n676\t\n677\t  // 1. Read or initialize workflow state\n678\t  let state = readWorkflowState(projectDir);\n679\t\n680\t  // Early exit: workflow already completed (AC #6)\n681\t  if (state.phase === 'completed') {\n682\t    return {\n683\t      success: true,\n684\t      tasksCompleted: 0,\n685\t      storiesProcessed: 0,\n686\t      errors: [],\n687\t      durationMs: 0,\n688\t    };\n689\t  }\n690\t\n691\t  state = {\n692\t    ...state,\n693\t    phase: 'executing',\n694\t    started: state.started || new Date().toISOString(),\n695\t    workflow_name: config.workflow.flow.filter((s) => typeof s === 'string').join(' -> '),\n696\t  };\n697\t  writeWorkflowState(state, projectDir);\n698\t\n699\t  // 2. Load work items\n700\t  const workItems = loadWorkItems(config.sprintStatusPath, config.issuesPath);\n701\t\n702\t  // 3. Iterate through flow steps\n703\t  let halted = false;\n704\t  for (const step of config.workflow.flow) {\n705\t    if (halted) break;\n706\t\n707\t    // Execute loop blocks\n708\t    if (isLoopBlock(step)) {\n709\t      const loopResult = await executeLoopBlock(step, state, config, workItems);\n710\t      state = loopResult.state;\n711\t      errors.push(...loopResult.errors);\n712\t      tasksCompleted += loopResult.tasksCompleted;\n713\t\n714\t      // Track processed stories from loop\n715\t      for (const item of workItems) {\n716\t        processedStories.add(item.key);\n717\t      }\n718\t\n719\t      if (loopResult.halted) {\n720\t        halted = true;\n721\t      }\n722\t\n723\t      // If loop ended with max-iterations or circuit-breaker, treat as failure\n724\t      if (state.phase === 'max-iterations' || state.phase === 'circuit-breaker') {\n725\t        halted = true;\n726\t      }\n727\t      continue;\n728\t    }\n729\t\n730\t    // step is a string task name\n731\t    const taskName = step;\n732\t    const task = config.workflow.tasks[taskName];\n733\t\n734\t    if (!task) {\n735\t      warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n736\t      continue;\n737\t    }\n738\t\n739\t    // Look up the agent definition\n740\t    const definition = config.agents[task.agent];\n741\t    if (!definition) {\n742\t      warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n743\t      continue;\n744\t    }\n745\t\n746\t    if (task.scope === 'per-run') {\n747\t      // Skip if already completed (crash recovery — AC #3)\n748\t      if (isTaskCompleted(state, taskName, PER_RUN_SENTINEL)) {\n749\t        warn(`workflow-engine: skipping completed task ${taskName} for ${PER_RUN_SENTINEL}`);\n750\t        continue;\n751\t      }\n752\t\n753\t      // Per-run: dispatch once with sentinel key\n754\t      try {\n755\t        state = await dispatchTask(task, taskName, PER_RUN_SENTINEL, definition, state, config);\n756\t        tasksCompleted++;\n757\t      } catch (err: unknown) {\n758\t        const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n759\t        errors.push(engineError);\n760\t\n761\t        // Record error checkpoint in state (AC #13)\n762\t        state = recordErrorInState(state, taskName, PER_RUN_SENTINEL, engineError);\n763\t        writeWorkflowState(state, projectDir);\n764\t\n765\t        // Halt on critical errors\n766\t        if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n767\t          halted = true;\n768\t        }\n769\t      }\n770\t    } else {\n771\t      // Per-story: dispatch once per work item\n772\t      for (const item of workItems) {\n773\t        processedStories.add(item.key);\n774\t\n775\t        // Skip if already completed (crash recovery — AC #1, #2, #7)\n776\t        if (isTaskCompleted(state, taskName, item.key)) {\n777\t          warn(`workflow-engine: skipping completed task ${taskName} for ${item.key}`);\n778\t          continue;\n779\t        }\n780\t\n781\t        try {\n782\t          state = await dispatchTask(task, taskName, item.key, definition, state, config);\n783\t          tasksCompleted++;\n784\t        } catch (err: unknown) {\n785\t          const engineError = handleDispatchError(err, taskName, item.key);\n786\t          errors.push(engineError);\n787\t\n788\t          // Record error checkpoint in state (AC #13)\n789\t          state = recordErrorInState(state, taskName, item.key, engineError);\n790\t          writeWorkflowState(state, projectDir);\n791\t\n792\t          // Halt on critical errors, continue on UNKNOWN\n793\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n794\t            halted = true;\n795\t            break;\n796\t          }\n797\t          // UNKNOWN errors: record and continue to next story\n798\t          continue;\n799\t        }\n800\t      }\n801\t    }\n802\t  }\n803\t\n804\t  // 4. Set final phase if no errors and phase not already set by loop termination\n805\t  if (errors.length === 0 && state.phase !== 'max-iterations' && state.phase !== 'circuit-breaker') {\n806\t    state = { ...state, phase: 'completed' };\n807\t    writeWorkflowState(state, projectDir);\n808\t  }\n809\t\n810\t  // 5. Return result\n811\t  const loopTerminated = state.phase === 'max-iterations' || state.phase === 'circuit-breaker';\n812\t  return {\n813\t    success: errors.length === 0 && !loopTerminated,\n814\t    tasksCompleted,\n815\t    storiesProcessed: processedStories.size,\n816\t    errors,\n817\t    durationMs: Date.now() - startMs,\n818\t  };\n819\t}\n820\t\n821\t// --- Error Handling ---\n822\t\n823\t/**\n824\t * Record a dispatch error in workflow state: set phase to \"error\" and append\n825\t * a TaskCheckpoint with the error details (AC #13).\n826\t */\n827\tfunction recordErrorInState(\n828\t  state: WorkflowState,\n829\t  taskName: string,\n830\t  storyKey: string,\n831\t  error: EngineError,\n832\t): WorkflowState {\n833\t  const errorCheckpoint: TaskCheckpoint = {\n834\t    task_name: taskName,\n835\t    story_key: storyKey,\n836\t    completed_at: new Date().toISOString(),\n837\t    error: true,\n838\t  };\n839\t  return {\n840\t    ...state,\n841\t    phase: 'error',\n842\t    tasks_completed: [...state.tasks_completed, errorCheckpoint],\n843\t  };\n844\t}\n845\t\n846\tfunction handleDispatchError(err: unknown, taskName: string, storyKey: string): EngineError {\n847\t  if (err instanceof DispatchError) {\n848\t    return {\n849\t      taskName,\n850\t      storyKey,\n851\t      code: err.code,\n852\t      message: err.message,\n853\t    };\n854\t  }\n855\t\n856\t  const message = err instanceof Error ? err.message : String(err);\n857\t  return {\n858\t    taskName,\n859\t    storyKey,\n860\t    code: 'UNKNOWN',\n861\t    message,\n862\t  };\n863\t}\n864\t"}]},"parent_tool_use_id":"toolu_01Lp1WM9dkDn419erDDCd9nG","session_id":"64d7a6a2-a6f8-43cb-b618-df314a0f5500","uuid":"f088e50b-0531-4b14-b61f-1749635169bd","timestamp":"2026-04-03T00:08:55.242Z"}
