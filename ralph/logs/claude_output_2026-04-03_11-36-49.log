12)', async () => {\n449\t    const task = makeTask({ session: 'continue' });\n450\t    const definition = makeDefinition();\n451\t    const state = makeDefaultState();\n452\t    const config = makeConfig();\n453\t\n454\t    mockResolveSessionId.mockReturnValue('prev-sess-id');\n455\t\n456\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n457\t\n458\t    expect(mockResolveSessionId).toHaveBeenCalledWith(\n459\t      'continue',\n460\t      { taskName: 'implement', storyKey: '5-1-foo' },\n461\t      state,\n462\t    );\n463\t    // Session ID is handled internally, not passed via DispatchOpts\n464\t    expect(mockDriverDispatch).toHaveBeenCalledWith(\n465\t      expect.objectContaining({\n466\t        prompt: expect.any(String),\n467\t      }),\n468\t    );\n469\t  });\n470\t\n471\t  it('dispatches with cwd when source_access is true (default) (AC #10)', async () => {\n472\t    const task = makeTask({ source_access: true });\n473\t    const definition = makeDefinition();\n474\t    const state = makeDefaultState();\n475\t    const config = makeConfig({ projectDir: '/my-project' });\n476\t\n477\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n478\t\n479\t    expect(mockCreateIsolatedWorkspace).not.toHaveBeenCalled();\n480\t    expect(mockDriverDispatch).toHaveBeenCalledWith(\n481\t      expect.objectContaining({ cwd: '/my-project' }),\n482\t    );\n483\t  });\n484\t\n485\t  it('creates isolated workspace when source_access is false (AC #9)', async () => {\n486\t    const mockWorkspace = {\n487\t      dir: '/tmp/codeharness-verify-run-001',\n488\t      storyFilesDir: '/tmp/codeharness-verify-run-001/story-files',\n489\t      verdictDir: '/tmp/codeharness-verify-run-001/verdict',\n490\t      toDispatchOptions: () => ({ cwd: '/tmp/codeharness-verify-run-001' }),\n491\t      cleanup: vi.fn().mockResolvedValue(undefined),\n492\t    };\n493\t    mockCreateIsolatedWorkspace.mockResolvedValue(mockWorkspace);\n4