{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GtzvCt6CwS3jb1z47N9C2R","type":"tool_result","content":"520\t      'sess-abc-123',\n521\t      expect.any(Object),\n522\t    );\n523\t  });\n524\t\n525\t  it('appends checkpoint manually when dispatch returns no sessionId', async () => {\n526\t    mockDispatchAgent.mockResolvedValue({\n527\t      sessionId: '',\n528\t      success: true,\n529\t      durationMs: 100,\n530\t      output: 'ok',\n531\t    });\n532\t\n533\t    const task = makeTask();\n534\t    const definition = makeDefinition();\n535\t    const state = makeDefaultState();\n536\t    const config = makeConfig();\n537\t\n538\t    const result = await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n539\t\n540\t    // recordSessionId should NOT be called (empty string is falsy)\n541\t    expect(mockRecordSessionId).not.toHaveBeenCalled();\n542\t    // State should have a manually-created checkpoint\n543\t    const writtenState = mockWriteWorkflowState.mock.calls[0][0] as WorkflowState;\n544\t    expect(writtenState.tasks_completed).toHaveLength(1);\n545\t    expect(writtenState.tasks_completed[0].task_name).toBe('implement');\n546\t    expect(writtenState.tasks_completed[0].story_key).toBe('5-1-foo');\n547\t  });\n548\t\n549\t  it('cleans up workspace on dispatch error when source_access is false', async () => {\n550\t    const mockWorkspace = {\n551\t      dir: '/tmp/test',\n552\t      storyFilesDir: '/tmp/test/story-files',\n553\t      verdictDir: '/tmp/test/verdict',\n554\t      toDispatchOptions: () => ({ cwd: '/tmp/test' }),\n555\t      cleanup: vi.fn().mockResolvedValue(undefined),\n556\t    };\n557\t    mockCreateIsolatedWorkspace.mockResolvedValue(mockWorkspace);\n558\t    mockDispatchAgent.mockRejectedValue(new Error('dispatch failed'));\n559\t\n560\t    const task = makeTask({ source_access: false });\n561\t    const definition = makeDefinition();\n562\t    const state = makeDefaultState();\n563\t    const config = makeConfig();\n564\t\n565\t    await expect(\n566\t      dispatchTask(task, 'verify', '__run__', definition, state, config),\n567\t    ).rejects.toThrow('dispatch failed');\n568\t\n569\t    // Cleanup should still be called\n570\t    expect(mockWorkspace.cleanup).toHaveBeenCalled();\n571\t  });\n572\t\n573\t  it('constructs per-run prompt for sentinel key', async () => {\n574\t    const task = makeTask({ scope: 'per-run' });\n575\t    const definition = makeDefinition();\n576\t    const state = makeDefaultState();\n577\t    const config = makeConfig();\n578\t\n579\t    await dispatchTask(task, 'verify', '__run__', definition, state, config);\n580\t\n581\t    expect(mockDriverDispatch).toHaveBeenCalledWith(\n582\t      expect.objectContaining({\n583\t        prompt: 'Execute task \"verify\" for the current run.',\n584\t      }),\n585\t    );\n586\t  });\n587\t});\n588\t\n589\tdescribe('executeWorkflow', () => {\n590\t  beforeEach(() => {\n591\t    vi.clearAllMocks();\n592\t    setupDefaultMocks();\n593\t  });\n594\t\n595\t  it('executes flow steps sequentially in order (AC #2)', async () => {\n596\t    const callOrder: string[] = [];\n597\t    mockDispatchAgent.mockImplementation(\n598\t      async (_def: SubagentDefinition, prompt: string) => {\n599\t        callOrder.push(prompt);\n600\t        return { sessionId: 'sess-1', success: true, durationMs: 100, output: 'ok' };\n601\t      },\n602\t    );\n603\t\n604\t    // Two stories, flow: [implement, verify]\n605\t    mockParse.mockReturnValue({\n606\t      development_status: {\n607\t        '3-1-foo': 'ready-for-dev',\n608\t        '3-2-bar': 'backlog',\n609\t      },"}]},"parent_tool_use_id":"toolu_01JHBd2h21hZJ3ormyytEjgf","session_id":"f83470b7-c271-483e-ae93-7fe9bce4b683","uuid":"d004d240-9644-4b79-b1b0-be6d8f8ec95f","timestamp":"2026-04-03T07:46:36.645Z"}
