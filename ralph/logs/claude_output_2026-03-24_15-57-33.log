result = detectCoverageTool(testDir);\n   224ŌåÆ    expect(result.runCommand).toBe('npm run test:coverage');\n   225ŌåÆ  });\n   226ŌåÆ\n   227ŌåÆ  it('reads state file hint but re-detects when project config disagrees', () => {\n   228ŌåÆ    // Create state with c8 hint\n   229ŌåÆ    const state = getDefaultState('nodejs');\n   230ŌåÆ    state.coverage.tool = 'c8';\n   231ŌåÆ    writeState(state, testDir);\n   232ŌåÆ\n   233ŌåÆ    // But project has no vitest/c8\n   234ŌåÆ    writeFileSync(join(testDir, 'package.json'), JSON.stringify({ name: 'bare' }));\n   235ŌåÆ\n   236ŌåÆ    const result = detectCoverageTool(testDir);\n   237ŌåÆ    expect(result.tool).toBe('unknown'); // Re-detected as unknown\n   238ŌåÆ  });\n   239ŌåÆ\n   240ŌåÆ  it('handles malformed package.json gracefully', () => {\n   241ŌåÆ    writeFileSync(join(testDir, 'package.json'), '{invalid json');\n   242ŌåÆ    const result = detectCoverageTool(testDir);\n   243ŌåÆ    expect(result.tool).toBe('unknown');\n   244ŌåÆ  });\n   245ŌåÆ});\n   246ŌåÆ\n   247ŌåÆ// ŌöĆŌöĆŌöĆ getTestCommand ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\n   248ŌåÆ\n   249ŌåÆdescribe('getTestCommand', () => {\n   250ŌåÆ  it('returns the run command from detectCoverageTool', () => {\n   251ŌåÆ    writeFileSync(\n   252ŌåÆ      join(testDir, 'package.json'),\n   253ŌåÆ      JSON.stringify({\n   254ŌåÆ        name: 'test',\n   255ŌåÆ        devDependencies: { '@vitest/coverage-v8': '^1.0.0' },\n   256ŌåÆ      }),\n   257ŌåÆ    );\n   258ŌåÆ\n   259ŌåÆ    const cmd = getTestCommand(testDir);\n   260ŌåÆ    expect(cmd).toContain('vitest');\n   261ŌåÆ  });\n   262ŌåÆ\n   263ŌåÆ  it('returns empty string when no tool detected', () => {\n   264ŌåÆ    const cmd = getTestCommand(testDir);\n   265ŌåÆ    expect(cmd).toBe('');\n   266ŌåÆ  });\n   267ŌåÆ});\n   268ŌåÆ\n   269ŌåÆ// ŌöĆŌöĆŌöĆ parseTestCounts ŌöĆŌö