{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011ebR6qiBgBfDCaYF3XZtXc","type":"tool_result","content":"     1→/**\n     2→ * Helper functions for the run command.\n     3→ *\n     4→ * Extracted from run.ts to comply with NFR9 (max 300 lines per file).\n     5→ * Contains: elapsed time formatting, sprint status -> story status mapping,\n     6→ * and line processing utilities.\n     7→ *\n     8→ * Ralph-specific functions (parseRalphMessage, parseIterationMessage, buildSpawnArgs)\n     9→ * have been migrated to src/lib/agents/ralph.ts (story 13-2).\n    10→ */\n    11→\n    12→import { StringDecoder } from 'node:string_decoder';\n    13→import { parseStreamLine } from './agents/stream-parser.js';\n    14→import type { StreamEvent } from './agents/stream-parser.js';\n    15→import { parseRalphMessage, parseIterationMessage } from './agents/ralph.js';\n    16→import type { StoryStatusEntry, StoryStatusValue, StoryMessage } from './ink-components.js';\n    17→\n    18→// --- Story Counting ---\n    19→\n    20→/** Story key pattern: digit-digit-name */\n    21→const STORY_KEY_PATTERN = /^\\d+-\\d+-/;\n    22→\n    23→/**\n    24→ * Counts stories by status from sprint-status.yaml.\n    25→ */\n    26→export function countStories(statuses: Record<string, string>): {\n    27→  total: number;\n    28→  ready: number;\n    29→  done: number;\n    30→  inProgress: number;\n    31→  // eslint-disable-next-line @typescript-eslint/naming-convention\n    32→  verified: number;\n    33→} {\n    34→  let total = 0;\n    35→  let ready = 0;\n    36→  let done = 0;\n    37→  let inProgress = 0;\n    38→  // eslint-disable-next-line @typescript-eslint/naming-convention\n    39→  let verified = 0;\n    40→\n    41→  for (const [key, status] of Object.entries(statuses)) {\n    42→    if (!STORY_KEY_PATTERN.test(key)) continue;\n    43→    total++;\n    44→    if (status === 'backlog' || status === 'ready-for-dev') ready++;\n    45→    else if (status === 'done') done++;\n    46→    else if (status === 'in-progress' || status === 'review') inProgress++;\n    47→    else if (status === 'verifying') verified++;\n    48→  }\n    49→\n    50→  return { total, ready, done, inProgress, verified };\n    51→}\n    52→\n    53→// --- Elapsed Time Formatting (AC #6) ---\n    54→\n    55→/**\n    56→ * Format elapsed milliseconds as \"Xm\" or \"XhYm\".\n    57→ * Matches the UX spec format (not the DashboardFormatter \"Xm Ys\" format).\n    58→ */\n    59→export function formatElapsed(ms: number): string {\n    60→  const totalMinutes = Math.max(0, Math.floor(ms / 60_000));\n    61→  const hours = Math.floor(totalMinutes / 60);\n    62→  const minutes = totalMinutes % 60;\n    63→  if (hours > 0) {\n    64→    return `${hours}h${minutes}m`;\n    65→  }\n    66→  return `${totalMinutes}m`;\n    67→}\n    68→\n    69→// --- Sprint Status -> Story Status Mapping (AC #7) ---\n    70→\n    71→/**\n    72→ * Maps a sprint-status.yaml status value to a StoryStatusValue for the Ink renderer.\n    73→ *\n    74→ * Mapping:\n    75→ *   done -> done\n    76→ *   in-progress, review, verifying -> in-progress\n    77→ *   backlog, ready-for-dev -> pending\n    78→ *   failed -> failed\n    79→ *   blocked, exhausted -> blocked\n    80→ */\n    81→export function mapSprintStatus(status: string): StoryStatusValue {\n    82→  switch (status) {\n    83→    case 'done':\n    84→      return 'done';\n    85→    case 'in-progress':\n    86→    case 'review':\n    87→    case 'verifying':\n    88→      return 'in-progress';\n    89→    case 'backlog':\n    90→    case 'ready-for-dev':\n    91→      return 'pending';\n    92→    case 'failed':\n    93→      return 'failed';\n    94→    case 'blocked':\n    95→    case 'exhausted':\n    96→      return 'blocked';\n    97→    default:\n    98→      return 'pending';\n    99→  }\n   100→}\n   101→\n   102→/**\n   103→ * Converts sprint-status.yaml entries to StoryStatusEntry[] for the Ink renderer.\n   104→ * Filters out epic keys, retrospective keys, and optional entries.\n   105→ */\n   106→export function mapSprintStatuses(statuses: Record<string, string>): StoryStatusEntry[] {\n   107→  const entries: StoryStatusEntry[] = [];\n   108→  for (const [key, status] of Object.entries(statuses)) {\n   109→    if (!STORY_KEY_PATTERN.test(key)) continue;\n   110→    if (status === 'optional') continue;\n   111→    entries.push({ key, status: mapSprintStatus(status) });\n   112→  }\n   113→  return entries;\n   114→}\n   115→\n   116→// --- Line Processor (extracted from run.ts for testability) ---\n   117→\n   118→export interface LineProcessorCallbacks {\n   119→  onEvent: (event: StreamEvent) => void;\n   120→  onMessage?: (msg: StoryMessage) => void;\n   121→  onIteration?: (iteration: number) => void;\n   122→}\n   123→\n   124→/**\n   125→ * Creates a Buffer-to-lines processor that splits on newlines, handles\n   126→ * partial-line buffering across chunk boundaries, and feeds complete\n   127→ * lines through the stream parser and optional ralph message parser.\n   128→ *\n   129→ * This is the exact logic used in run.ts's makeLineHandler, extracted\n   130→ * so integration tests can exercise the real production code path.\n   131→ */\n   132→export function createLineProcessor(\n   133→  callbacks: LineProcessorCallbacks,\n   134→  opts?: { parseRalph?: boolean },\n   135→): (data: Buffer) => void {\n   136→  let partial = '';\n   137→  const decoder = new StringDecoder('utf8');\n   138→  return (data: Buffer): void => {\n   139→    const text = partial + decoder.write(data);\n   140→    const parts = text.split('\\n');\n   141→    partial = parts.pop() ?? '';\n   142→    for (const line of parts) {\n   143→      if (line.trim().length === 0) continue;\n   144→      const event = parseStreamLine(line);\n   145→      if (event) {\n   146→        callbacks.onEvent(event);\n   147→      }\n   148→      if (opts?.parseRalph) {\n   149→        const msg = parseRalphMessage(line);\n   150→        if (msg && callbacks.onMessage) {\n   151→          callbacks.onMessage(msg);\n   152→        }\n   153→        const iteration = parseIterationMessage(line);\n   154→        if (iteration !== null && callbacks.onIteration) {\n   155→          callbacks.onIteration(iteration);\n   156→        }\n   157→      }\n   158→    }\n   159→  };\n   160→}\n   161→"}]},"parent_tool_use_id":"toolu_01KNQnUKBFtzFzrosUg6K7qd","session_id":"7d2c764f-deb1-4354-ad31-e0a846d19ae3","uuid":"87ae5d02-6a97-4260-b2e0-83c43a9e4b3e","timestamp":"2026-03-25T00:16:59.038Z"}
