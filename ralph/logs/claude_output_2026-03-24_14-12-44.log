{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LdPeUhAp956gxx4ujXynmQ","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, afterEach } from 'vitest';\n     2→import {\n     3→  readFileSync,\n     4→  writeFileSync,\n     5→  unlinkSync,\n     6→  existsSync,\n     7→  mkdirSync,\n     8→} from 'node:fs';\n     9→import { join } from 'node:path';\n    10→import { migrateFromOldFormat } from '../migration.js';\n    11→\n    12→const ROOT = process.cwd();\n    13→const STATE_FILE = join(ROOT, 'sprint-state.json');\n    14→const TMP_FILE = join(ROOT, '.sprint-state.json.tmp');\n    15→const RALPH_DIR = join(ROOT, 'ralph');\n    16→const BMAD_DIR = join(\n    17→  ROOT,\n    18→  '_bmad-output',\n    19→  'implementation-artifacts',\n    20→);\n    21→\n    22→// Paths to old files (use test-specific versions to not conflict with real files)\n    23→const RETRIES_FILE = join(RALPH_DIR, '.story_retries_test');\n    24→const FLAGGED_FILE = join(RALPH_DIR, '.flagged_stories_test');\n    25→const STATUS_FILE = join(RALPH_DIR, 'status_test.json');\n    26→const YAML_FILE = join(BMAD_DIR, 'sprint-status-test.yaml');\n    27→const ISSUES_FILE = join(BMAD_DIR, '.session-issues-test.md');\n    28→\n    29→// We need to test with actual old file paths, so we'll create/cleanup them\n    30→const REAL_RETRIES = join(RALPH_DIR, '.story_retries');\n    31→const REAL_FLAGGED = join(RALPH_DIR, '.flagged_stories');\n    32→const REAL_STATUS = join(RALPH_DIR, 'status.json');\n    33→const REAL_YAML = join(BMAD_DIR, 'sprint-status.yaml');\n    34→const REAL_ISSUES = join(BMAD_DIR, '.session-issues.md');\n    35→\n    36→// Store original contents for restoration\n    37→let originalRetries: string | null = null;\n    38→let originalFlagged: string | null = null;\n    39→let originalStatus: string | null = null;\n    40→let originalYaml: string | null = null;\n    41→let originalIssues: string | null = null;\n    42→\n    43→function readSafe(path: string): string | null {\n    44→  try { return readFileSync(path, 'utf-8'); } catch { return null; }\n    45→}\n    46→\n    47→function saveOriginals(): void {\n    48→  originalRetries = readSafe(REAL_RETRIES);\n    49→  originalFlagged = readSafe(REAL_FLAGGED);\n    50→  originalStatus = readSafe(REAL_STATUS);\n    51→  originalYaml = readSafe(REAL_YAML);\n    52→  originalIssues = readSafe(REAL_ISSUES);\n    53→}\n    54→\n    55→function restoreOriginals(): void {\n    56→  // Clean up sprint-state.json\n    57→  if (existsSync(STATE_FILE)) unlinkSync(STATE_FILE);\n    58→  if (existsSync(TMP_FILE)) unlinkSync(TMP_FILE);\n    59→\n    60→  // Restore originals\n    61→  if (originalRetries !== null) writeFileSync(REAL_RETRIES, originalRetries, 'utf-8');\n    62→  if (originalFlagged !== null) writeFileSync(REAL_FLAGGED, originalFlagged, 'utf-8');\n    63→  if (originalStatus !== null) writeFileSync(REAL_STATUS, originalStatus, 'utf-8');\n    64→  if (originalYaml !== null) writeFileSync(REAL_YAML, originalYaml, 'utf-8');\n    65→  if (originalIssues !== null) writeFileSync(REAL_ISSUES, originalIssues, 'utf-8');\n    66→}\n    67→\n    68→function removeOldFiles(): void {\n    69→  for (const f of [REAL_RETRIES, REAL_FLAGGED, REAL_STATUS, REAL_YAML, REAL_ISSUES]) {\n    70→    if (existsSync(f)) unlinkSync(f);\n    71→  }\n    72→}\n    73→\n    74→describe('migrateFromOldFormat', () => {\n    75→  beforeEach(() => {\n    76→    saveOriginals();\n    77→    if (existsSync(STATE_FILE)) unlinkSync(STATE_FILE);\n    78→    // Remove old files so we control exactly what's present\n    79→    removeOldFiles();\n    80→  });\n    81→\n    82→  afterEach(() => {\n    83→    restoreOriginals();\n    84→  });\n    85→\n    86→  it('returns fail when no old files exist', () => {\n    87→    const result = migrateFromOldFormat();\n    88→    expect(result.success).toBe(false);\n    89→    if (!result.success) {\n    90→      expect(result.error).toContain('No old format files');\n    91→    }\n    92→  });\n    93→\n    94→  it('migrates story retries into attempts', () => {\n    95→    writeFileSync(\n    96→      REAL_RETRIES,\n    97→      'story-a 3\\nstory-b 1\\n',\n    98→      'utf-8',\n    99→    );\n   100→\n   101→    const result = migrateFromOldFormat();\n   102→    expect(result.success).toBe(true);\n   103→    if (result.success) {\n   104→      expect(result.data.stories['story-a'].attempts).toBe(3);\n   105→      expect(result.data.stories['story-b'].attempts).toBe(1);\n   106→    }\n   107→  });\n   108→\n   109→  it('migrates sprint-status.yaml into story statuses', () => {\n   110→    writeFileSync(\n   111→      REAL_YAML,\n   112→      [\n   113→        '# Sprint Status',\n   114→        'development_status:',\n   115→        '  epic-1: done',\n   116→        '  1-1-result-type: done',\n   117→        '  1-2-module-skeleton: backlog',\n   118→        '  2-1-sprint-state: in-progress',\n   119→      ].join('\\n'),\n   120→      'utf-8',\n   121→    );\n   122→\n   123→    const result = migrateFromOldFormat();\n   124→    expect(result.success).toBe(true);\n   125→    if (result.success) {\n   126→      expect(result.data.stories['1-1-result-type'].status).toBe('done');\n   127→      expect(result.data.stories['1-2-module-skeleton'].status).toBe('backlog');\n   128→      expect(result.data.stories['2-1-sprint-state'].status).toBe('in-progress');\n   129→      // epic-level entries should be skipped\n   130→      expect(result.data.stories['epic-1']).toBeUndefined();\n   131→    }\n   132→  });\n   133→\n   134→  it('migrates ralph/status.json into run section', () => {\n   135→    writeFileSync(\n   136→      REAL_STATUS,\n   137→      JSON.stringify({\n   138→        loop_count: 5,\n   139→        stories_total: 25,\n   140→        stories_completed: 3,\n   141→        elapsed_seconds: 1200,\n   142→        status: 'running',\n   143→      }),\n   144→      'utf-8',\n   145→    );\n   146→\n   147→    const result = migrateFromOldFormat();\n   148→    expect(result.success).toBe(true);\n   149→    if (result.success) {\n   150→      expect(result.data.run.iteration).toBe(5);\n   151→      expect(result.data.run.active).toBe(true);\n   152→    }\n   153→  });\n   154→\n   155→  it('migrates flagged stories as blocked', () => {\n   156→    writeFileSync(REAL_FLAGGED, 'story-x\\nstory-y\\n', 'utf-8');\n   157→\n   158→    const result = migrateFromOldFormat();\n   159→    expect(result.success).toBe(true);\n   160→    if (result.success) {\n   161→      expect(result.data.stories['story-x'].status).toBe('blocked');\n   162→      expect(result.data.stories['story-y'].status).toBe('blocked');\n   163→    }\n   164→  });\n   165→\n   166→  it('migrates session issues into action items', () => {\n   167→    writeFileSync(\n   168→      REAL_ISSUES,\n   169→      [\n   170→        '# Session Issues',\n   171→        '',\n   172→        '### story-abc — dev-story (2026-03-18)',\n   173→        '',\n   174→        '- Something went wrong',\n   175→        '- Another concern',\n   176→        '',\n   177→        '### story-def — code-review (2026-03-18)',\n   178→        '',\n   179→        '- Review finding',\n   180→      ].join('\\n'),\n   181→      'utf-8',\n   182→    );\n   183→\n   184→    const result = migrateFromOldFormat();\n   185→    expect(result.success).toBe(true);\n   186→    if (result.success) {\n   187→      expect(result.data.actionItems.length).toBe(3);\n   188→      expect(result.data.actionItems[0].story).toBe('story-abc');\n   189→      expect(result.data.actionItems[0].description).toBe('Something went wrong');\n   190→      expect(result.data.actionItems[2].story).toBe('story-def');\n   191→    }\n   192→  });\n   193→\n   194→  it('handles missing old files gracefully (partial migration)', () => {\n   195→    // Only retries file exists\n   196→    writeFileSync(REAL_RETRIES, 'only-story 2\\n', 'utf-8');\n   197→\n   198→    const result = migrateFromOldFormat();\n   199→    expect(result.success).toBe(true);\n   200→    if (result.success) {\n   201→      expect(result.data.stories['only-story'].attempts).toBe(2);\n   202→      expect(result.data.run.active).toBe(false); // no status.json\n   203→    }\n   204→  });\n   205→\n   206→  it('writes sprint-state.json after migration', () => {\n   207→    writeFileSync(REAL_RETRIES, 'migrated-story 1\\n', 'utf-8');\n   208→\n   209→    const result = migrateFromOldFormat();\n   210→    expect(result.success).toBe(true);\n   211→    expect(existsSync(STATE_FILE)).toBe(true);\n   212→  });\n   213→\n   214→  it('handles invalid JSON in ralph/status.json gracefully', () => {\n   215→    // Write invalid JSON to status.json — parseRalphStatus should catch and return null\n   216→    writeFileSync(REAL_STATUS, '{not valid json!!!', 'utf-8');\n   217→\n   218→    const result = migrateFromOldFormat();\n   219→    expect(result.success).toBe(true);\n   220→    if (result.success) {\n   221→      // Should fall back to default run section\n   222→      expect(result.data.run.active).toBe(false);\n   223→      expect(result.data.run.iteration).toBe(0);\n   224→    }\n   225→  });\n   226→\n   227→  it('handles retries file with malformed lines', () => {\n   228→    writeFileSync(\n   229→      REAL_RETRIES,\n   230→      'story-a 3\\nmalformed-no-count\\n\\nstory-b notanumber\\nstory-c 5\\n',\n   231→      'utf-8',\n   232→    );\n   233→\n   234→    const result = migrateFromOldFormat();\n   235→    expect(result.success).toBe(true);\n   236→    if (result.success) {\n   237→      expect(result.data.stories['story-a'].attempts).toBe(3);\n   238→      expect(result.data.stories['story-c'].attempts).toBe(5);\n   239→      // malformed-no-count has only 1 part, should be skipped\n   240→      expect(result.data.stories['malformed-no-count']).toBeUndefined();\n   241→      // notanumber is NaN, should be skipped\n   242→      expect(result.data.stories['story-b']).toBeUndefined();\n   243→    }\n   244→  });\n   245→\n   246→  it('computes sprint counts correctly', () => {\n   247→    writeFileSync(\n   248→      REAL_YAML,\n   249→      [\n   250→        'development_status:',\n   251→        '  s1: done',\n   252→        '  s2: done',\n   253→        '  s3: failed',\n   254→        '  s4: blocked',\n   255→        '  s5: backlog',\n   256→      ].join('\\n'),\n   257→      'utf-8',\n   258→    );\n   259→\n   260→    const result = migrateFromOldFormat();\n   261→    expect(result.success).toBe(true);\n   262→    if (result.success) {\n   263→      expect(result.data.sprint.total).toBe(5);\n   264→      expect(result.data.sprint.done).toBe(2);\n   265→      expect(result.data.sprint.failed).toBe(1);\n   266→      expect(result.data.sprint.blocked).toBe(1);\n   267→    }\n   268→  });\n   269→});\n   270→"}]},"parent_tool_use_id":"toolu_01EPL4eJAP5W5qUxFXY5uuFc","session_id":"6707468c-554d-4568-9ea5-0d04d4a85f59","uuid":"36a6a14f-c9ed-410c-96a0-3e2244a4efe9","timestamp":"2026-03-24T10:20:58.364Z"}
