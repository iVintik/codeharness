{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QAqJ51nC787tofLKhhtmud","type":"tool_result","content":"/**\n * README.md template for project documentation.\n * Architecture Decision 6: All templates are TypeScript string literals.\n * Architecture Decision 10: Documentation is load-bearing — wrong docs = verification failure.\n *\n * Generated by `codeharness init` when README.md does not exist.\n * Never overwrites an existing README.md.\n */\n\nexport interface ReadmeTemplateConfig {\n  /** Project name (from package.json name or directory basename) */\n  projectName: string;\n  /** Detected stack: 'nodejs', 'python', or null */\n  stack: string | null;\n  /** Output of `codeharness --help` for CLI reference section */\n  cliHelpOutput: string;\n}\n\n/**\n * Generates README.md content from the template config.\n */\nexport function readmeTemplate(config: ReadmeTemplateConfig): string {\n  const { projectName, stack, cliHelpOutput } = config;\n\n  const installCommand = getInstallCommand(stack);\n  const firstRunCommand = 'codeharness init';\n  const exampleUsage = 'codeharness status';\n\n  const lines: string[] = [\n    `# ${projectName}`,\n    '',\n    '## Quick Start',\n    '',\n    '```bash',\n    `# Install`,\n    installCommand,\n    '',\n    '# Initialize the project',\n    firstRunCommand,\n    '',\n    '# Check project status',\n    exampleUsage,\n    '```',\n    '',\n    '## Installation',\n    '',\n    '```bash',\n    installCommand,\n    '```',\n    '',\n    '## Usage',\n    '',\n    `After installation, initialize ${projectName} in your project directory:`,\n    '',\n    '```bash',\n    'codeharness init',\n    '```',\n    '',\n    'This sets up the harness with stack detection, observability, and documentation scaffolding.',\n    '',\n    '## CLI Reference',\n    '',\n    '```',\n    cliHelpOutput.trimEnd(),\n    '```',\n    '',\n  ];\n\n  return lines.join('\\n');\n}\n\nfunction getInstallCommand(stack: string | null): string {\n  if (stack === 'python') {\n    return 'pip install codeharness';\n  }\n  return 'npm install -g codeharness';\n}","is_error":false}]},"parent_tool_use_id":"toolu_017stQocDjYtQWzyiuCXnw1e","session_id":"58ae4f51-bff6-4a66-807a-d4f10c8bdaa3","uuid":"7acc8ff2-db58-4051-a73c-244e4cb264a0","timestamp":"2026-03-23T15:59:48.739Z"}
