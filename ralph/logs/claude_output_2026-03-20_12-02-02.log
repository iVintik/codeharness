ude': true, '.flagged_stories': false });\n   392→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   393→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   394→\n   395→      const p = runCommand(['--json']);\n   396→      await vi.waitFor(() => expect(spawnMock).toHaveBeenCalled());\n   397→      getChildOnHandlers()['close'](0);\n   398→      await p;\n   399→\n   400→      expect(spawnMock).toHaveBeenCalledWith('bash', expect.any(Array), expect.objectContaining({\n   401→        env: expect.objectContaining({ CLAUDE_OUTPUT_FORMAT: 'stream-json' }),\n   402→      }));\n   403→    });\n   404→\n   405→    it('does not set CLAUDE_OUTPUT_FORMAT without --json', async () => {\n   406→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   407→      mockPaths({ 'ralph.sh': true, '.claude': true, '.flagged_stories': false });\n   408→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   409→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   410→\n   411→      const p = runCommand();\n   412→      await vi.waitFor(() => expect(spawnMock).toHaveBeenCalled());\n   413→      getChildOnHandlers()['close'](0);\n   414→      await p;\n   415→\n   416→      const envArg = spawnMock.mock.calls[0][2].env;\n   417→      expect(envArg.CLAUDE_OUTPUT_FORMAT).toBeUndefined();\n   418→    });\n   419→\n   420→    it('writes prompt file to ralph directory', async () => {\n   421→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   422→      mockPaths({ 'ralph.sh': true, '.claude': true, '.flagged_stories': false });\n   423→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   424→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   425→\n   426→      const p = runCommand();\n   427→      await vi.waitFor(() => expect(spawnMock).toHaveBeenCalled());\n   428→      getChildOnHandlers()['close'](0);\n   429→      await p;\n   430→\n   431→      const promptPath = join(tmp