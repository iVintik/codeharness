{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KeSx7hYi45mgZDxYo6mLmt","type":"tool_result","content":"218\t/**\n219\t * Write state to disk atomically: write to tmp, then rename.\n220\t * Also regenerates sprint-status.yaml as a derived view.\n221\t */\n222\texport function writeStateAtomic(state: SprintState): Result<void> {\n223\t  try {\n224\t    const data = JSON.stringify(state, null, 2) + '\\n';\n225\t    const tmp = tmpPath();\n226\t    const final = statePath();\n227\t    writeFileSync(tmp, data, 'utf-8');\n228\t    renameSync(tmp, final);\n229\t    // Regenerate YAML view after successful state write\n230\t    writeSprintStatusYaml(state);\n231\t    return ok(undefined);\n232\t  } catch (err: unknown) {\n233\t    const msg = err instanceof Error ? err.message : String(err);\n234\t    return fail(`Failed to write sprint state: ${msg}`);\n235\t  }\n236\t}\n237\t"}]},"parent_tool_use_id":"toolu_01YSacQvkrW7LZee36oBUg8s","session_id":"be33ba5d-0e81-49c4-ae53-e69ac56cd1fb","uuid":"9be41d31-d2b0-48fc-8ee7-ec22be832269","timestamp":"2026-04-03T10:11:57.354Z"}
