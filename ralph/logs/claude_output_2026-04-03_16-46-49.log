ev', done: 0, total: 1 }, _forceTTY: true });\n973\t    handle.update({ type: 'result', cost: 1.50, sessionId: 'sess1' }, 'claude-code');\n974\t    handle.update({ type: 'result', cost: 0.75, sessionId: 'sess2' }, 'claude-code');\n975\t    handle.update({ type: 'result', cost: 0.25, sessionId: 'sess3' }, 'codex');\n976\t  });\n977\t\n978\t  it('does not accumulate driverCosts when no driverName on result', () => {\n979\t    handle = startRenderer({ sprintState: { storyKey: 'test', phase: 'dev', done: 0, total: 1 }, _forceTTY: true });\n980\t    handle.update({ type: 'result', cost: 1.50, sessionId: 'sess1' });\n981\t  });\n982\t\n983\t  it('handles error-like sequence without crash (driver failure resilience)', () => {\n984\t    handle = startRenderer({ sprintState: { storyKey: 'test', phase: 'dev', done: 0, total: 1 }, _forceTTY: true });\n985\t    handle.update({ type: 'tool-start', name: 'Bash', id: 't1' }, 'codex');\n986\t    handle.update({ type: 'tool-input', partial: '{\"command\":\"exit 1\"}' });\n987\t    handle.update({ type: 'tool-complete' });\n988\t    handle.update({ type: 'text', text: 'The command failed' });\n989\t    handle.update({ type: 'tool-start', name: 'Read', id: 't2' }, 'claude-code');\n990\t    handle.update({ type: 'tool-complete' });\n991\t  });\n992\t});\n993\t\n994\t// --- Per-Story Cost Tracking Tests (Story 15-2) ---\n995\t\n996\tdescribe('StoryBreakdown per-story cost display', () => {\n997\t  it('renders done story with multi-driver costs sorted alphabetically', () => {\n998\t    const stories: StoryStatusEntry[] = [\n999\t      { key: '1-1-auth', status: 'done', costByDriver: { codex: 0.15, 'claude-code': 0.42 } },\n1000\t    ];\n1001\t    const { lastFrame } = render(<StoryBreakdown stories={stories} />);\n1002\t    const frame = lastFrame()!;\n1003\t    expect(frame).toContain('1-1 ✓ claude-code $0.42, codex $0.15');\n1004\t  });\n1005\t\n1006\t  it('renders done story with single-driver cost', () => {\n1007\t    const stories: 