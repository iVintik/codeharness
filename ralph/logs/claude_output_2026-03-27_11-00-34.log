lp: { enabled: true, endpoint: 'http://localhost:4318', service_name: 'test', mode: 'local-shared', backend: 'elk' },\n   164→      docker: {\n   165→        compose_file: '/mock/.codeharness/stack/docker-compose.elk.yml',\n   166→        stack_running: true,\n   167→        ports: { logs: 9200, metrics: 8428, traces: 16686, otel_grpc: 4317, otel_http: 4318 },\n   168→      },\n   169→    } as HarnessState);\n   170→\n   171→    mockGetStackHealth.mockReturnValue({ healthy: true, services: [], remedy: undefined });\n   172→\n   173→    await handleDockerCheck(false);\n   174→\n   175→    // Verify getStackHealth was called with the ELK compose file, not the Victoria one\n   176→    expect(mockGetStackHealth).toHaveBeenCalledWith(\n   177→      '/mock/.codeharness/stack/docker-compose.elk.yml',\n   178→      'codeharness-shared',\n   179→    );\n   180→  });\n   181→\n   182→  it('shows ELK-specific endpoints when backend is elk and healthy', async () => {\n   183→    mockReadState.mockReturnValue({\n   184→      harness_version: '0.0.0-dev',\n   185→      initialized: true,\n   186→      stack: 'nodejs',\n   187→      stacks: ['nodejs'],\n   188→      enforcement: { frontend: true, database: true, api: true },\n   189→      coverage: { target: 90, baseline: null, current: null, tool: 'c8' },\n   190→      session_flags: { logs_queried: false, tests_passed: false, coverage_met: false, verification_run: false },\n   191→      verification_log: [],\n   192→      otlp: { enabled: true, endpoint: 'http://localhost:4318', service_name: 'test', mode: 'local-shared', backend: 'elk' },\n   193→      docker: {\n   194→        compose_file: '/mock/.codeharness/stack/docker-compose.elk.yml',\n   195→        stack_running: true,\n   196→        ports: { logs: 9200, metrics: 8428, traces: 16686, otel_grpc: 4317, otel_http: 4318 },\n   197→      },\n   198→    } as HarnessState);\n   199→\n   200→    mockGetStackHealth.mockReturnValue({ healthy: true, services: [], remedy: undefin