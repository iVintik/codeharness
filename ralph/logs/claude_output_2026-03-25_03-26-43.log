{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Mqq4D1vYg4BfRNrbcWh6vn","type":"tool_result","content":"     1→/**\n     2→ * Verification environment management: Docker image lifecycle, clean workspace,\n     3→ * and environment checks for black-box verification.\n     4→ */\n     5→import { execFileSync } from 'node:child_process';\n     6→import { existsSync, mkdirSync, readdirSync, readFileSync, writeFileSync, cpSync, rmSync, statSync } from 'node:fs';\n     7→import { join, basename } from 'node:path';\n     8→import { createHash } from 'node:crypto';\n     9→import { info } from '../../lib/output.js';\n    10→import { detectStacks } from '../../lib/stacks/index.js';\n    11→import { readStateWithBody, writeState } from '../../lib/state.js';\n    12→import { isDockerAvailable } from '../../lib/docker/index.js';\n    13→import type { BuildOptions, BuildResult, CheckResult, ProjectType } from './types.js';\n    14→import { generateVerifyDockerfile } from './dockerfile-generator.js';\n    15→\n    16→const IMAGE_TAG = 'codeharness-verify';\n    17→const STORY_DIR = '_bmad-output/implementation-artifacts';\n    18→const TEMP_PREFIX = '/tmp/codeharness-verify-';\n    19→const STATE_KEY_DIST_HASH = 'verify_env_dist_hash';\n    20→\n    21→/** Validates that a story key is safe for file paths and container names. */\n    22→export function isValidStoryKey(storyKey: string): boolean {\n    23→  if (!storyKey || storyKey.includes('..') || storyKey.includes('/') || storyKey.includes('\\\\')) {\n    24→    return false;\n    25→  }\n    26→  return /^[a-zA-Z0-9_-]+$/.test(storyKey);\n    27→}\n    28→\n    29→/** Computes a SHA-256 hash of all files in dist/ for cache invalidation. */\n    30→export function computeDistHash(projectDir: string): string | null {\n    31→  const distDir = join(projectDir, 'dist');\n    32→  if (!existsSync(distDir)) return null;\n    33→  const hash = createHash('sha256');\n    34→  const files = collectFiles(distDir).sort();\n    35→  for (const file of files) {\n    36→    hash.update(file.slice(distDir.length));\n    37→    hash.update(readFileSync(file));\n    38→  }\n    39→  return hash.digest('hex');\n    40→}\n    41→\n    42→function collectFiles(dir: string): string[] {\n    43→  const results: string[] = [];\n    44→  for (const entry of readdirSync(dir, { withFileTypes: true })) {\n    45→    const fullPath = join(dir, entry.name);\n    46→    if (entry.isDirectory()) { results.push(...collectFiles(fullPath)); }\n    47→    else { results.push(fullPath); }\n    48→  }\n    49→  return results;\n    50→}\n    51→\n    52→function getStoredDistHash(projectDir: string): string | null {\n    53→  try {\n    54→    const { state } = readStateWithBody(projectDir);\n    55→    return ((state as unknown as Record<string, unknown>)[STATE_KEY_DIST_HASH] as string) ?? null;\n    56→  } catch { return null; }\n    57→}\n    58→\n    59→function storeDistHash(projectDir: string, hash: string): void {\n    60→  try {\n    61→    const { state, body } = readStateWithBody(projectDir);\n    62→    (state as unknown as Record<string, unknown>)[STATE_KEY_DIST_HASH] = hash;\n    63→    writeState(state, projectDir, body);\n    64→  } catch {\n    65→    info('Could not persist dist hash to state file — cache will not be available until state is initialized');\n    66→  }\n    67→}\n    68→\n    69→/** Detects the project type for verification strategy selection. */\n    70→/** Stack names that map directly to ProjectType values. */\n    71→const STACK_TO_PROJECT_TYPE: Record<string, ProjectType> = {\n    72→  nodejs: 'nodejs',\n    73→  python: 'python',\n    74→  rust: 'rust',\n    75→};\n    76→\n    77→export function detectProjectType(projectDir: string): ProjectType {\n    78→  // Use detectStacks() (plural) for multi-stack awareness; derive primary from root detection\n    79→  const allStacks = detectStacks(projectDir);\n    80→  const rootDetection = allStacks.find(s => s.dir === '.');\n    81→  const stack = rootDetection ? rootDetection.stack : null;\n    82→  // Prefer known stacks when the project has a buildable package — the npm tarball\n    83→  // or Python wheel includes all distributable files. Plugin-only detection is the\n    84→  // fallback for projects that are purely Claude Code plugins with no build artifact.\n    85→  if (stack && STACK_TO_PROJECT_TYPE[stack]) return STACK_TO_PROJECT_TYPE[stack];\n    86→  if (existsSync(join(projectDir, '.claude-plugin', 'plugin.json'))) return 'plugin';\n    87→  return 'generic';\n    88→}\n    89→\n    90→/** Builds the verification Docker image with cache invalidation. */\n    91→export function buildVerifyImage(options: BuildOptions = {}): BuildResult {\n    92→  const projectDir = options.projectDir ?? process.cwd();\n    93→  if (!isDockerAvailable()) {\n    94→    throw new Error('Docker is not available. Install Docker and ensure the daemon is running.');\n    95→  }\n    96→  const projectType = detectProjectType(projectDir);\n    97→  const currentHash = computeDistHash(projectDir);\n    98→  /** Project types that don't require dist/ for verification image build */\n    99→  const NO_DIST_REQUIRED = new Set<ProjectType>(['generic', 'plugin', 'rust']);\n   100→  if (NO_DIST_REQUIRED.has(projectType)) {\n   101→    // Generic, plugin, and Rust projects may not have dist/ — skip hash check\n   102→  } else if (!currentHash) {\n   103→    throw new Error('No dist/ directory found. Run your build command first (e.g., npm run build).');\n   104→  }\n   105→  if (currentHash) {\n   106→    const storedHash = getStoredDistHash(projectDir);\n   107→    if (storedHash === currentHash && dockerImageExists(IMAGE_TAG)) {\n   108→      return { imageTag: IMAGE_TAG, imageSize: getImageSize(IMAGE_TAG), buildTimeMs: 0, cached: true };\n   109→    }\n   110→  }\n   111→  const startTime = Date.now();\n   112→  /** Per-project-type Docker image builders (no stack string comparisons). */\n   113→  const imageBuilders: Record<ProjectType, () => void> = {\n   114→    nodejs: () => buildNodeImage(projectDir),\n   115→    python: () => buildPythonImage(projectDir),\n   116→    rust: () => buildSimpleImage(projectDir, 'rust', 300_000),\n   117→    plugin: () => buildPluginImage(projectDir),\n   118→    generic: () => buildSimpleImage(projectDir, 'generic'),\n   119→  };\n   120→  imageBuilders[projectType]();\n   121→  if (currentHash) { storeDistHash(projectDir, currentHash); }\n   122→  return { imageTag: IMAGE_TAG, imageSize: getImageSize(IMAGE_TAG), buildTimeMs: Date.now() - startTime, cached: false };\n   123→}\n   124→\n   125→function buildNodeImage(projectDir: string): void {\n   126→  const packOutput = execFileSync('npm', ['pack', '--pack-destination', '/tmp'], {\n   127→    cwd: projectDir, stdio: 'pipe', timeout: 60_000,\n   128→  }).toString().trim();\n   129→  const lastLine = packOutput.split('\\n').pop()?.trim();\n   130→  if (!lastLine) throw new Error('npm pack produced no output — cannot determine tarball filename.');\n   131→  const tarballName = basename(lastLine);\n   132→  const tarballPath = join('/tmp', tarballName);\n   133→  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   134→  mkdirSync(buildContext, { recursive: true });\n   135→  try {\n   136→    cpSync(tarballPath, join(buildContext, tarballName));\n   137→    const dockerfile = generateVerifyDockerfile(projectDir)\n   138→      + `\\n# Install project from tarball\\nARG TARBALL=package.tgz\\nCOPY \\${TARBALL} /tmp/\\${TARBALL}\\nRUN npm install -g /tmp/\\${TARBALL} && rm /tmp/\\${TARBALL}\\n`;\n   139→    writeFileSync(join(buildContext, 'Dockerfile'), dockerfile);\n   140→    execFileSync('docker', ['build', '-t', IMAGE_TAG, '--build-arg', `TARBALL=${tarballName}`, '.'], {\n   141→      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   142→    });\n   143→  } finally {\n   144→    rmSync(buildContext, { recursive: true, force: true });\n   145→    rmSync(tarballPath, { force: true });\n   146→  }\n   147→}\n   148→\n   149→function buildPythonImage(projectDir: string): void {\n   150→  const distDir = join(projectDir, 'dist');\n   151→  const distFiles = readdirSync(distDir).filter(f => f.endsWith('.tar.gz') || f.endsWith('.whl'));\n   152→  if (distFiles.length === 0) {\n   153→    throw new Error('No distribution files found in dist/. Run your build command first (e.g., python -m build).');\n   154→  }\n   155→  const distFile = distFiles.filter(f => f.endsWith('.tar.gz'))[0] ?? distFiles[0];\n   156→  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   157→  mkdirSync(buildContext, { recursive: true });\n   158→  try {\n   159→    cpSync(join(distDir, distFile), join(buildContext, distFile));\n   160→    const dockerfile = generateVerifyDockerfile(projectDir)\n   161→      + `\\n# Install project from distribution\\nCOPY ${distFile} /tmp/${distFile}\\nRUN pip install --break-system-packages /tmp/${distFile} && rm /tmp/${distFile}\\n`;\n   162→    writeFileSync(join(buildContext, 'Dockerfile'), dockerfile);\n   163→    execFileSync('docker', ['build', '-t', IMAGE_TAG, '--build-arg', `TARBALL=${distFile}`, '.'], {\n   164→      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   165→    });\n   166→  } finally {\n   167→    rmSync(buildContext, { recursive: true, force: true });\n   168→  }\n   169→}\n   170→\n   171→/** Creates a clean temp workspace for verification (no src/, tests/, .git/). */\n   172→export function prepareVerifyWorkspace(storyKey: string, projectDir?: string): string {\n   173→  const root = projectDir ?? process.cwd();\n   174→  if (!isValidStoryKey(storyKey)) {\n   175→    throw new Error(`Invalid story key: ${storyKey}. Keys must contain only alphanumeric characters, hyphens, and underscores.`);\n   176→  }\n   177→  const storyFile = join(root, STORY_DIR, `${storyKey}.md`);\n   178→  if (!existsSync(storyFile)) throw new Error(`Story file not found: ${storyFile}`);\n   179→  const workspace = `${TEMP_PREFIX}${storyKey}`;\n   180→  if (existsSync(workspace)) rmSync(workspace, { recursive: true, force: true });\n   181→  mkdirSync(workspace, { recursive: true });\n   182→  cpSync(storyFile, join(workspace, 'story.md'));\n   183→  const readmePath = join(root, 'README.md');\n   184→  if (existsSync(readmePath)) cpSync(readmePath, join(workspace, 'README.md'));\n   185→  const docsDir = join(root, 'docs');\n   186→  if (existsSync(docsDir) && statSync(docsDir).isDirectory()) {\n   187→    cpSync(docsDir, join(workspace, 'docs'), { recursive: true });\n   188→  }\n   189→  mkdirSync(join(workspace, 'verification'), { recursive: true });\n   190→  return workspace;\n   191→}\n   192→\n   193→/** Validates verification environment: image, CLI, observability. */\n   194→export function checkVerifyEnv(): CheckResult {\n   195→  let imageExists = false;\n   196→  let cliWorks = false;\n   197→  let otelReachable = false;\n   198→\n   199→  imageExists = dockerImageExists(IMAGE_TAG);\n   200→  if (!imageExists) return { imageExists, cliWorks, otelReachable };\n   201→  try {\n   202→    execFileSync('docker', ['run', '--rm', IMAGE_TAG, 'codeharness', '--help'], {\n   203→      stdio: 'pipe', timeout: 30_000,\n   204→    });\n   205→    cliWorks = true;\n   206→  } catch { cliWorks = false; }\n   207→  try {\n   208→    execFileSync('docker', [\n   209→      'run', '--rm', '--add-host=host.docker.internal:host-gateway', IMAGE_TAG,\n   210→      'curl', '-sf', '--max-time', '5', 'http://host.docker.internal:4318/v1/status',\n   211→    ], { stdio: 'pipe', timeout: 30_000 });\n   212→    otelReachable = true;\n   213→  } catch { otelReachable = false; }\n   214→  return { imageExists, cliWorks, otelReachable };\n   215→}\n   216→\n   217→/** Cleans up all stale containers matching `codeharness-verify-*` pattern. Idempotent. */\n   218→export function cleanupStaleContainers(): void {\n   219→  try {\n   220→    const output = execFileSync(\n   221→      'docker', ['ps', '-a', '--filter', 'name=codeharness-verify-', '--format', '{{.Names}}'],\n   222→      { stdio: 'pipe', timeout: 15_000 },\n   223→    ).toString('utf-8').trim();\n   224→    if (output.length === 0) return;\n   225→    const containers = output.split('\\n').filter(name => name.length > 0);\n   226→    for (const name of containers) {\n   227→      try {\n   228→        execFileSync('docker', ['rm', '-f', name], { stdio: 'pipe', timeout: 15_000 });\n   229→      } catch { /* container may already be removed */ }\n   230→    }\n   231→  } catch { /* docker not available or no containers — ignore */ }\n   232→}\n   233→\n   234→/** Removes temp workspace and stops/removes the container. Idempotent. */\n   235→export function cleanupVerifyEnv(storyKey: string): void {\n   236→  if (!isValidStoryKey(storyKey)) {\n   237→    throw new Error(`Invalid story key: ${storyKey}. Keys must contain only alphanumeric characters, hyphens, and underscores.`);\n   238→  }\n   239→  const workspace = `${TEMP_PREFIX}${storyKey}`;\n   240→  const containerName = `codeharness-verify-${storyKey}`;\n   241→  if (existsSync(workspace)) rmSync(workspace, { recursive: true, force: true });\n   242→  try { execFileSync('docker', ['stop', containerName], { stdio: 'pipe', timeout: 15_000 }); }\n   243→  catch { /* container may not exist */ }\n   244→  try { execFileSync('docker', ['rm', '-f', containerName], { stdio: 'pipe', timeout: 15_000 }); }\n   245→  catch { /* container may not exist */ }\n   246→}\n   247→\n   248→function buildPluginImage(projectDir: string): void {\n   249→  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   250→  mkdirSync(buildContext, { recursive: true });\n   251→  try {\n   252→    // Copy plugin source into build context\n   253→    const pluginDir = join(projectDir, '.claude-plugin');\n   254→    cpSync(pluginDir, join(buildContext, '.claude-plugin'), { recursive: true });\n   255→    // Copy any commands, hooks, knowledge, skills directories if they exist\n   256→    for (const dir of ['commands', 'hooks', 'knowledge', 'skills']) {\n   257→      const src = join(projectDir, dir);\n   258→      if (existsSync(src) && statSync(src).isDirectory()) {\n   259→        cpSync(src, join(buildContext, dir), { recursive: true });\n   260→      }\n   261→    }\n   262→    writeFileSync(join(buildContext, 'Dockerfile'), generateVerifyDockerfile(projectDir));\n   263→    execFileSync('docker', ['build', '-t', IMAGE_TAG, '.'], {\n   264→      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   265→    });\n   266→  } finally {\n   267→    rmSync(buildContext, { recursive: true, force: true });\n   268→  }\n   269→}\n   270→\n   271→function buildSimpleImage(projectDir: string, _variant: string, timeout = 120_000): void {\n   272→  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   273→  mkdirSync(buildContext, { recursive: true });\n   274→  try {\n   275→    writeFileSync(join(buildContext, 'Dockerfile'), generateVerifyDockerfile(projectDir));\n   276→    execFileSync('docker', ['build', '-t', IMAGE_TAG, '.'], {\n   277→      cwd: buildContext, stdio: 'pipe', timeout,\n   278→    });\n   279→  } finally {\n   280→    rmSync(buildContext, { recursive: true, force: true });\n   281→  }\n   282→}\n   283→\n   284→\n   285→function dockerImageExists(tag: string): boolean {\n   286→  try {\n   287→    execFileSync('docker', ['image', 'inspect', tag], { stdio: 'pipe', timeout: 10_000 });\n   288→    return true;\n   289→  } catch { return false; }\n   290→}\n   291→\n   292→function getImageSize(tag: string): string {\n   293→  try {\n   294→    const output = execFileSync('docker', ['image', 'inspect', tag, '--format', '{{.Size}}'], {\n   295→      stdio: 'pipe', timeout: 10_000,\n   296→    }).toString().trim();\n   297→    const bytes = parseInt(output, 10);\n   298→    if (isNaN(bytes)) return output;\n   299→    if (bytes >= 1_000_000_000) return `${(bytes / 1_000_000_000).toFixed(1)}GB`;\n   300→    if (bytes >= 1_000_000) return `${(bytes / 1_000_000).toFixed(1)}MB`;\n   301→    if (bytes >= 1_000) return `${(bytes / 1_000).toFixed(1)}KB`;\n   302→    return `${bytes}B`;\n   303→  } catch { return 'unknown'; }\n   304→}\n   305→"}]},"parent_tool_use_id":"toolu_01UEcnB3h2gZqmEJqfPaXmt4","session_id":"38809bab-d371-4c03-b647-b7b7381ee002","uuid":"00e61941-e1d9-48f2-b012-7d3cf919364c","timestamp":"2026-03-24T23:42:39.566Z"}
