th.error).toBe('CLI not found on PATH');\n218\t    });\n219\t\n220\t    it('error field is optional', () => {\n221\t      const health: DriverHealth = {\n222\t        available: true,\n223\t        authenticated: true,\n224\t        version: '1.0.0',\n225\t      };\n226\t      expect(health.error).toBeUndefined();\n227\t    });\n228\t  });\n229\t\n230\t  describe('DriverCapabilities', () => {\n231\t    it('accepts capability flags', () => {\n232\t      const caps: DriverCapabilities = {\n233\t        supportsPlugins: true,\n234\t        supportsStreaming: false,\n235\t        costReporting: true,\n236\t      };\n237\t      expect(caps.supportsPlugins).toBe(true);\n238\t      expect(caps.supportsStreaming).toBe(false);\n239\t      expect(caps.costReporting).toBe(true);\n240\t    });\n241\t\n242\t    it('all-false capabilities are valid', () => {\n243\t      const caps: DriverCapabilities = {\n244\t        supportsPlugins: false,\n245\t        supportsStreaming: false,\n246\t        costReporting: false,\n247\t      };\n248\t      expect(caps.supportsPlugins).toBe(false);\n249\t      expect(caps.supportsStreaming).toBe(false);\n250\t      expect(caps.costReporting).toBe(false);\n251\t    });\n252\t  });\n253\t\n254\t  describe('ErrorCategory', () => {\n255\t    it('covers exactly 5 values', () => {\n256\t      const categories: ErrorCategory[] = [\n257\t        'RATE_LIMIT',\n258\t        'NETWORK',\n259\t        'AUTH',\n260\t        'TIMEOUT',\n261\t        'UNKNOWN',\n262\t      ];\n263\t      expect(categories).toHaveLength(5);\n264\t      // Verify each is a valid ErrorCategory (compile-time check)\n265\t      categories.forEach((cat) => {\n266\t        expect(typeof cat).toBe('string');\n267\t      });\n268\t    });\n269\t\n270\t    it('each value is assignable to ErrorCategory', () => {\n271\t      const a: ErrorCategory = 'RATE_LIMIT';\n272\t      const b: ErrorCategory = 'NETWORK';\n273\t      const c: ErrorCategory = 'AUTH';\n274\t      const d: ErrorCategory = 'TIMEOUT';\n275\t      const e: ErrorCategory = 'UNKNOWN';\n276\t      expect([a, b, c, d, e]).toEqual([\n277\t        'RATE_LIMIT',\n278\t        'NETWORK',\n279\t        'AUTH',\n280\t        'TIMEOUT',\n281\t        'UNKNOWN',\n282\t      ]);\n283\t    });\n284\t\n285\t    it('exhaustiveness check — switch covers all categories', () => {\n286\t      // Compile-time exhaustiveness: if ErrorCategory gains a 6th value,\n287\t      // the `never` default will cause a TS error\n288\t      function classifyError(cat: ErrorCategory): string {\n289\t        switch (cat) {\n290\t          case 'RATE_LIMIT': return 'retry';\n291\t          case 'NETWORK': return 'retry';\n292\t          case 'AUTH': return 'fail';\n293\t          case 'TIMEOUT': return 'fail';\n294\t          case 'UNKNOWN': return 'fail';\n295\t          default: {\n296\t            const _exhaustive: never = cat;\n297\t            return _exhaustive;\n298\t          }\n299\t        }\n300\t      }\n301\t      expect(classifyError('RATE_LIMIT')).toBe('retry');\n302\t      expect(classifyError('NETWORK')).toBe('retry');\n303\t      expect(classifyError('AUTH')).toBe('fail');\n304\t      expect(classifyError('TIMEOUT')).toBe('fail');\n305\t      expect(classifyError('UNKNOWN')).toBe('fail');\n306\t    });\n307\t  });\n308\t\n309\t  describe('OutputContract, TestResults, ACStatus', () => {\n310\t    it('accepts a valid OutputContract', () => {\n311\t      const contract: OutputContract = {\n312\t        version: 1,\n313\t        taskName: 'implement-story',\n314\t        storyId: '10-1',\n315\t        driver: 'claude-code',\n316\t        model: 'claude-sonnet-4-20250514',\n317\t        timestamp: '2026-04-03T12:00:00Z',\n318\t        cost_usd: 0.42,\n319\t        duration_ms: 15000,\n320\t        changedFiles: ['src/lib/agents/types.ts'],\n321\t        testResults: { passed: 10, failed: 0, coverage: 95.5 },\n322\t        output: 'Implementation complete',\n323\t        acceptanceCriteria: [\n324\t       