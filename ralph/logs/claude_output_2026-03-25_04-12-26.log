{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ehqk2SdZeEKU3e8QmXuqkD","type":"tool_result","content":"     1→import { existsSync } from 'node:fs';\n     2→import { join } from 'node:path';\n     3→import type { BeadsIssue } from '../beads.js';\n     4→import {\n     5→  resolveStoryFilePath,\n     6→  readStoryFileStatus,\n     7→  updateStoryFileStatus,\n     8→  storyKeyFromPath,\n     9→  beadsStatusToStoryStatus,\n    10→  storyStatusToBeadsStatus,\n    11→} from './story-files.js';\n    12→import type { SyncResult, SyncDirection } from './story-files.js';\n    13→import { updateSprintStatus } from './sprint-yaml.js';\n    14→\n    15→export type { SyncResult, SyncDirection };\n    16→\n    17→export function syncBeadsToStoryFile(\n    18→  beadsId: string,\n    19→  beadsFns: {\n    20→    listIssues: () => BeadsIssue[];\n    21→  },\n    22→  dir?: string,\n    23→): SyncResult {\n    24→  const root = dir ?? process.cwd();\n    25→  const issues = beadsFns.listIssues();\n    26→  const issue = issues.find(i => i.id === beadsId);\n    27→\n    28→  if (!issue) {\n    29→    return {\n    30→      storyKey: '',\n    31→      beadsId,\n    32→      previousStatus: '',\n    33→      newStatus: '',\n    34→      synced: false,\n    35→      error: `Beads issue not found: ${beadsId}`,\n    36→    };\n    37→  }\n    38→  const storyFilePath = resolveStoryFilePath(issue);\n    39→  if (!storyFilePath) {\n    40→    return {\n    41→      storyKey: '',\n    42→      beadsId,\n    43→      previousStatus: issue.status,\n    44→      newStatus: '',\n    45→      synced: false,\n    46→      error: `No story file path in beads issue description: ${beadsId}`,\n    47→    };\n    48→  }\n    49→  const storyKey = storyKeyFromPath(storyFilePath);\n    50→  const fullPath = join(root, storyFilePath);\n    51→  const currentStoryStatus = readStoryFileStatus(fullPath);\n    52→\n    53→  if (currentStoryStatus === null) {\n    54→    return {\n    55→      storyKey,\n    56→      beadsId,\n    57→      previousStatus: issue.status,\n    58→      newStatus: '',\n    59→      synced: false,\n    60→      error: `Story file not found or has no Status line: ${storyFilePath}`,\n    61→    };\n    62→  }\n    63→  const targetStoryStatus = beadsStatusToStoryStatus(issue.status);\n    64→  if (!targetStoryStatus) {\n    65→    return {\n    66→      storyKey,\n    67→      beadsId,\n    68→      previousStatus: currentStoryStatus,\n    69→      newStatus: '',\n    70→      synced: false,\n    71→      error: `Unknown beads status: ${issue.status}`,\n    72→    };\n    73→  }\n    74→  if (currentStoryStatus === targetStoryStatus) {\n    75→    return {\n    76→      storyKey,\n    77→      beadsId,\n    78→      previousStatus: currentStoryStatus,\n    79→      newStatus: currentStoryStatus,\n    80→      synced: false,\n    81→    };\n    82→  }\n    83→  updateStoryFileStatus(fullPath, targetStoryStatus);\n    84→  updateSprintStatus(storyKey, targetStoryStatus, root);\n    85→\n    86→  return {\n    87→    storyKey,\n    88→    beadsId,\n    89→    previousStatus: currentStoryStatus,\n    90→    newStatus: targetStoryStatus,\n    91→    synced: true,\n    92→  };\n    93→}\n    94→\n    95→export function syncStoryFileToBeads(\n    96→  storyKey: string,\n    97→  beadsFns: {\n    98→    listIssues: () => BeadsIssue[];\n    99→    updateIssue: (id: string, opts: { status?: string }) => void;\n   100→    closeIssue: (id: string) => void;\n   101→  },\n   102→  dir?: string,\n   103→): SyncResult {\n   104→  const root = dir ?? process.cwd();\n   105→  const storyFilePath = `_bmad-output/implementation-artifacts/${storyKey}.md`;\n   106→  const fullPath = join(root, storyFilePath);\n   107→\n   108→  const currentStoryStatus = readStoryFileStatus(fullPath);\n   109→  if (currentStoryStatus === null) {\n   110→    return {\n   111→      storyKey,\n   112→      beadsId: '',\n   113→      previousStatus: '',\n   114→      newStatus: '',\n   115→      synced: false,\n   116→      error: `Story file not found or has no Status line: ${storyFilePath}`,\n   117→    };\n   118→  }\n   119→  const issues = beadsFns.listIssues();\n   120→  const issue = issues.find(i => {\n   121→    const path = resolveStoryFilePath(i);\n   122→    if (!path) return false;\n   123→    return storyKeyFromPath(path) === storyKey;\n   124→  });\n   125→\n   126→  if (!issue) {\n   127→    return {\n   128→      storyKey,\n   129→      beadsId: '',\n   130→      previousStatus: currentStoryStatus,\n   131→      newStatus: '',\n   132→      synced: false,\n   133→      error: `No beads issue found for story: ${storyKey}`,\n   134→    };\n   135→  }\n   136→  const targetBeadsStatus = storyStatusToBeadsStatus(currentStoryStatus);\n   137→  if (!targetBeadsStatus) {\n   138→    return {\n   139→      storyKey,\n   140→      beadsId: issue.id,\n   141→      previousStatus: currentStoryStatus,\n   142→      newStatus: '',\n   143→      synced: false,\n   144→      error: `Unknown story status: ${currentStoryStatus}`,\n   145→    };\n   146→  }\n   147→  if (issue.status === targetBeadsStatus) {\n   148→    return {\n   149→      storyKey,\n   150→      beadsId: issue.id,\n   151→      previousStatus: currentStoryStatus,\n   152→      newStatus: currentStoryStatus,\n   153→      synced: false,\n   154→    };\n   155→  }\n   156→  if (targetBeadsStatus === 'closed') {\n   157→    beadsFns.closeIssue(issue.id);\n   158→  } else {\n   159→    beadsFns.updateIssue(issue.id, { status: targetBeadsStatus });\n   160→  }\n   161→  updateSprintStatus(storyKey, currentStoryStatus, root);\n   162→\n   163→  return {\n   164→    storyKey,\n   165→    beadsId: issue.id,\n   166→    previousStatus: issue.status,\n   167→    newStatus: targetBeadsStatus,\n   168→    synced: true,\n   169→  };\n   170→}\n   171→\n   172→export function syncClose(\n   173→  beadsId: string,\n   174→  beadsFns: {\n   175→    closeIssue: (id: string) => void;\n   176→    listIssues: () => BeadsIssue[];\n   177→  },\n   178→  dir?: string,\n   179→): SyncResult {\n   180→  const root = dir ?? process.cwd();\n   181→\n   182→  const issues = beadsFns.listIssues();\n   183→  const issue = issues.find(i => i.id === beadsId);\n   184→\n   185→  beadsFns.closeIssue(beadsId);\n   186→\n   187→  if (!issue) {\n   188→    return {\n   189→      storyKey: '',\n   190→      beadsId,\n   191→      previousStatus: '',\n   192→      newStatus: 'closed',\n   193→      synced: false,\n   194→      error: `Beads issue not found: ${beadsId}`,\n   195→    };\n   196→  }\n   197→  const storyFilePath = resolveStoryFilePath(issue);\n   198→  if (!storyFilePath) {\n   199→    return {\n   200→      storyKey: '',\n   201→      beadsId,\n   202→      previousStatus: issue.status,\n   203→      newStatus: 'closed',\n   204→      synced: false,\n   205→      error: `No story file path in beads issue description: ${beadsId}`,\n   206→    };\n   207→  }\n   208→  const storyKey = storyKeyFromPath(storyFilePath);\n   209→  const fullPath = join(root, storyFilePath);\n   210→  const previousStatus = readStoryFileStatus(fullPath);\n   211→\n   212→  if (previousStatus === null) {\n   213→    if (!existsSync(fullPath)) {\n   214→      return {\n   215→        storyKey,\n   216→        beadsId,\n   217→        previousStatus: '',\n   218→        newStatus: 'closed',\n   219→        synced: false,\n   220→        error: `Story file not found: ${storyFilePath}`,\n   221→      };\n   222→    }\n   223→  }\n   224→  updateStoryFileStatus(fullPath, 'done');\n   225→  updateSprintStatus(storyKey, 'done', root);\n   226→\n   227→  return {\n   228→    storyKey,\n   229→    beadsId,\n   230→    previousStatus: previousStatus ?? '',\n   231→    newStatus: 'done',\n   232→    synced: true,\n   233→  };\n   234→}\n   235→\n   236→export function syncAll(\n   237→  direction: SyncDirection,\n   238→  beadsFns: {\n   239→    listIssues: () => BeadsIssue[];\n   240→    updateIssue: (id: string, opts: { status?: string }) => void;\n   241→    closeIssue: (id: string) => void;\n   242→  },\n   243→  dir?: string,\n   244→): SyncResult[] {\n   245→  const root = dir ?? process.cwd();\n   246→  const results: SyncResult[] = [];\n   247→\n   248→  let issues: BeadsIssue[];\n   249→  try {\n   250→    issues = beadsFns.listIssues();\n   251→  } catch (err) {\n   252→    const message = err instanceof Error ? err.message : String(err);\n   253→    return [{\n   254→      storyKey: '',\n   255→      beadsId: '',\n   256→      previousStatus: '',\n   257→      newStatus: '',\n   258→      synced: false,\n   259→      error: `Failed to list beads issues: ${message}`,\n   260→    }];\n   261→  }\n   262→  const cachedListIssues = () => issues;\n   263→\n   264→  for (const issue of issues) {\n   265→    const storyFilePath = resolveStoryFilePath(issue);\n   266→    if (!storyFilePath) {\n   267→      continue;\n   268→    }\n   269→\n   270→    const storyKey = storyKeyFromPath(storyFilePath);\n   271→\n   272→    try {\n   273→      if (direction === 'beads-to-files' || direction === 'bidirectional') {\n   274→        const result = syncBeadsToStoryFile(issue.id, { listIssues: cachedListIssues }, root);\n   275→        results.push(result);\n   276→      } else if (direction === 'files-to-beads') {\n   277→        const result = syncStoryFileToBeads(storyKey, {\n   278→          listIssues: cachedListIssues,\n   279→          updateIssue: beadsFns.updateIssue,\n   280→          closeIssue: beadsFns.closeIssue,\n   281→        }, root);\n   282→        results.push(result);\n   283→      }\n   284→    } catch (err) {\n   285→      const message = err instanceof Error ? err.message : String(err);\n   286→      results.push({\n   287→        storyKey,\n   288→        beadsId: issue.id,\n   289→        previousStatus: '',\n   290→        newStatus: '',\n   291→        synced: false,\n   292→        error: message,\n   293→      });\n   294→    }\n   295→  }\n   296→  return results;\n   297→}\n   298→"}]},"parent_tool_use_id":"toolu_01KNQnUKBFtzFzrosUg6K7qd","session_id":"7d2c764f-deb1-4354-ad31-e0a846d19ae3","uuid":"e086b10e-5eb9-4156-a810-56cbe71c1b50","timestamp":"2026-03-25T00:17:10.977Z"}
