{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013DyRA7TZ8tq3szs3twcS2V","type":"tool_result","content":"     1→/**\n     2→ * Shared utility functions for stack providers.\n     3→ * Extracted from stack-detect.ts to avoid duplication across providers.\n     4→ */\n     5→\n     6→import { existsSync, readFileSync } from 'node:fs';\n     7→import { join } from 'node:path';\n     8→\n     9→/** Safely read and parse a JSON file. Returns null on any error. */\n    10→export function readJsonSafe(path: string): Record<string, unknown> | null {\n    11→  try {\n    12→    if (!existsSync(path)) return null;\n    13→    return JSON.parse(readFileSync(path, 'utf-8')) as Record<string, unknown>;\n    14→  } catch {\n    15→    return null;\n    16→  }\n    17→}\n    18→\n    19→/** Safely read a text file. Returns null on any error. */\n    20→export function readTextSafe(path: string): string | null {\n    21→  try {\n    22→    if (!existsSync(path)) return null;\n    23→    return readFileSync(path, 'utf-8');\n    24→  } catch {\n    25→    return null;\n    26→  }\n    27→}\n    28→\n    29→/** Collect all dependency names from a package.json object (dependencies + devDependencies). */\n    30→export function getNodeDeps(pkg: Record<string, unknown>): Set<string> {\n    31→  const deps = new Set<string>();\n    32→  for (const field of ['dependencies', 'devDependencies']) {\n    33→    const section = pkg[field] as Record<string, string> | undefined;\n    34→    if (section && typeof section === 'object') {\n    35→      for (const key of Object.keys(section)) {\n    36→        deps.add(key);\n    37→      }\n    38→    }\n    39→  }\n    40→  return deps;\n    41→}\n    42→\n    43→/**\n    44→ * Read and concatenate content from Python dependency files\n    45→ * (requirements.txt, pyproject.toml, setup.py) in a directory.\n    46→ */\n    47→export function getPythonDepsContent(dir: string): string {\n    48→  const files = ['requirements.txt', 'pyproject.toml', 'setup.py'];\n    49→  const parts: string[] = [];\n    50→  for (const file of files) {\n    51→    const content = readTextSafe(join(dir, file));\n    52→    if (content) parts.push(content);\n    53→  }\n    54→  return parts.join('\\n');\n    55→}\n    56→\n    57→/**\n    58→ * Check if a Python dependency is present in combined deps content.\n    59→ * Uses word-boundary-aware matching to avoid substring false positives\n    60→ * (e.g., \"openai\" should not match \"not-openai\" or \"myopenai\").\n    61→ */\n    62→export function hasPythonDep(content: string, dep: string): boolean {\n    63→  const escaped = dep.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n    64→  const pattern = new RegExp(`(?:^|[\\\\s\"',])${escaped}(?:[\\\\[>=<~!;\\\\s\"',]|$)`, 'm');\n    65→  return pattern.test(content);\n    66→}\n    67→\n    68→/**\n    69→ * Extract the [dependencies] section from Cargo.toml content.\n    70→ * Stops at the next section header (e.g., [dev-dependencies], [build-dependencies]).\n    71→ * Returns empty string if no [dependencies] section found.\n    72→ */\n    73→export function getCargoDepsSection(content: string): string {\n    74→  const match = content.match(/^\\[dependencies\\]\\s*$/m);\n    75→  if (!match || match.index === undefined) return '';\n    76→  const start = match.index + match[0].length;\n    77→  // Find next section header\n    78→  const nextSection = content.slice(start).search(/^\\[/m);\n    79→  return nextSection === -1 ? content.slice(start) : content.slice(start, start + nextSection);\n    80→}\n    81→\n    82→/**\n    83→ * Check if a Cargo.toml [dependencies] section contains a specific crate.\n    84→ * Uses word-boundary matching to avoid substring false positives\n    85→ * (e.g., searching for \"anthropic\" should not match \"anthropic-sdk\").\n    86→ */\n    87→export function hasCargoDep(depsSection: string, dep: string): boolean {\n    88→  const escaped = dep.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n    89→  const pattern = new RegExp(`(?:^|\\\\s)${escaped}(?:\\\\s*=|\\\\s*\\\\{)`, 'm');\n    90→  return pattern.test(depsSection);\n    91→}\n    92→"}]},"parent_tool_use_id":"toolu_01M6iq2XVtx8hbFMRevefAGh","session_id":"01d3be87-3cff-45e1-920c-7390a9e4093c","uuid":"2c0d3b71-a2c8-4f8f-9158-340ef120b82e","timestamp":"2026-03-24T09:43:42.609Z"}
