cks appear first, subdirs sorted alphabetically', () => {\n   171→    writeFileSync(join(testDir, 'package.json'), '{}', 'utf-8');\n   172→    mkdirSync(join(testDir, 'api'), { recursive: true });\n   173→    writeFileSync(join(testDir, 'api', 'Cargo.toml'), '[package]\\nname = \"api\"\\n');\n   174→    const result = detectStacks(testDir);\n   175→    expect(result).toEqual([\n   176→      { stack: 'nodejs', dir: '.' },\n   177→      { stack: 'rust', dir: 'api' },\n   178→    ]);\n   179→  });\n   180→\n   181→  it('root stacks in priority order (nodejs > python > rust)', () => {\n   182→    writeFileSync(join(testDir, 'Cargo.toml'), '[package]\\nname = \"foo\"\\n');\n   183→    writeFileSync(join(testDir, 'requirements.txt'), '', 'utf-8');\n   184→    writeFileSync(join(testDir, 'package.json'), '{}', 'utf-8');\n   185→    const result = detectStacks(testDir);\n   186→    expect(result).toEqual([\n   187→      { stack: 'nodejs', dir: '.' },\n   188→      { stack: 'python', dir: '.' },\n   189→      { stack: 'rust', dir: '.' },\n   190→    ]);\n   191→  });\n   192→\n   193→  it('subdirectory stacks sorted alphabetically by dir name', () => {\n   194→    mkdirSync(join(testDir, 'zeta'), { recursive: true });\n   195→    mkdirSync(join(testDir, 'alpha'), { recursive: true });\n   196→    mkdirSync(join(testDir, 'middle'), { recursive: true });\n   197→    writeFileSync(join(testDir, 'zeta', 'package.json'), '{}', 'utf-8');\n   198→    writeFileSync(join(testDir, 'alpha', 'Cargo.toml'), '[package]\\nname = \"a\"\\n');\n   199→    writeFileSync(join(testDir, 'middle', 'requirements.txt'), '', 'utf-8');\n   200→    const result = detectStacks(testDir);\n   201→    expect(result).toEqual([\n   202→      { stack: 'rust', dir: 'alpha' },\n   203→      { stack: 'python', dir: 'middle' },\n   204→      { stack: 'nodejs', dir: 'zeta' },\n   205→    ]);\n   206→  });\n   207→\n   208→  it('does not add duplicate stacks per directory (python detected once even with multiple markers)', () => {\n   209→    writeFileSync(join(testDir, 'requirements.txt'), '', 'utf-8');\n   210→    writeFileSync(join(testDir, 'pyproject.toml'), '', 'utf-8');\n   211→    writeFileSync(join(testDir, 'setup.py'), '', 'utf-8');\n   212→    const result = detectStacks(testDir);\n   213→    expect(result).toEqual([{ stack: 'python', dir: '.' }]);\n   214→  });\n   215→\n   216→  it('detects multiple stacks in the same subdirectory', () => {\n   217→    mkdirSync(join(testDir, 'app'), { recursive: true });\n   218→    writeFileSync(join(testDir, 'app', 'package.json'), '{}', 'utf-8');\n   219→    writeFileSync(join(testDir, 'app', 'Cargo.toml'), '[package]\\nname = \"mixed\"\\n');\n   220→    const result = detectStacks(testDir);\n   221→    expect(result).toEqual([\n   222→      { stack: 'nodejs', dir: 'app' },\n   223→      { stack: 'rust', dir: 'app' },\n   224→    ]);\n   225→  });\n   226→\n   227→  it('only scans one level deep (does not recurse into nested subdirectories)', () => {\n   228→    mkdirSync(join(testDir, 'level1', 'level2'), { recursive: true });\n   229→    writeFileSync(join(testDir, 'level1', 'level2', 'package.json'), '{}', 'utf-8');\n   230→    const result = detectStacks(testDir);\n   231→    // level1 has no stack markers, level2 is not scanned\n   232→    expect(result).toEqual([]);\n   233→  });\n   234→});\n   235→\n   236→describe('detectAppType', () => {\n   237→  // --- CLI detection ---\n   238→  it('returns \"cli\" for Node.js project with bin and no start script', () => {\n   239→    writeFileSync(\n   240→      join(testDir, 'package.json'),\n   241→      JSON.stringify({ name: 'my-cli', bin: { 'my-cli': './dist/cli.js' }, scripts: { build: 'tsc' } }),\n   242→    );\n   243→    expect(detectAppType(testDir, 'nodejs')).toBe('cli');\n   244→  });\n   245→\n   246→  it('returns \"cli\" for Node.js project with bin string and no start script', () => {\n   247→    writeFileSync(\n   248→      join(testDir, 'package.json'),\n   249→ 