{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RQ6x8GboxGUns67uabpQbX","type":"tool_result","content":"1\t/**\n2\t * Ink App root component — composes layout and activity components.\n3\t *\n4\t * Separated from ink-components.tsx to avoid circular imports\n5\t * (ink-components exports types, ink-activity-components imports them,\n6\t * and this file imports from both).\n7\t */\n8\t\n9\timport React from 'react';\n10\timport { Box, Static } from 'ink';\n11\timport { Header, Separator, StoryBreakdown, type RendererState } from './ink-components.js';\n12\timport { CompletedTools, ActiveTool, LastThought, RetryNotice, StoryMessageLine, DriverCostSummary } from './ink-activity-components.js';\n13\timport { WorkflowGraph } from './ink-workflow.js';\n14\timport { LaneContainer } from './ink-lane-container.js';\n15\timport type { LaneData } from './ink-lane-container.js';\n16\timport { SummaryBar } from './ink-summary-bar.js';\n17\timport { MergeStatus } from './ink-merge-status.js';\n18\t\n19\texport function App({ state }: { state: RendererState }) {\n20\t  const lanes: LaneData[] | undefined = state.lanes;\n21\t  const laneCount = lanes?.length ?? 0;\n22\t  const terminalWidth = process.stdout.columns || 80;\n23\t\n24\t  return (\n25\t    <Box flexDirection=\"column\">\n26\t      <Static items={state.messages}>\n27\t        {(msg, i) => <StoryMessageLine key={i} msg={msg} />}\n28\t      </Static>\n29\t      <Header info={state.sprintInfo} laneCount={laneCount > 1 ? laneCount : undefined} />\n30\t      {laneCount > 1 ? (\n31\t        <LaneContainer lanes={lanes!} terminalWidth={terminalWidth} />\n32\t      ) : (\n33\t        <>\n34\t          <WorkflowGraph flow={state.workflowFlow} currentTask={state.currentTaskName} taskStates={state.taskStates} taskMeta={state.taskMeta} />\n35\t          <StoryBreakdown stories={state.stories} sprintInfo={state.sprintInfo} />\n36\t          <DriverCostSummary driverCosts={state.driverCosts} />\n37\t        </>\n38\t      )}\n39\t      {laneCount > 1 && state.summaryBar && (\n40\t        <>\n41\t          <Separator />\n42\t          <SummaryBar {...state.summaryBar} />\n43\t        </>\n44\t      )}\n45\t      {laneCount > 1 && state.mergeState && (\n46\t        <>\n47\t          <Separator />\n48\t          <MergeStatus mergeState={state.mergeState} />\n49\t        </>\n50\t      )}\n51\t      {state.stories.length > 0 && <Separator />}\n52\t      <Box flexDirection=\"column\" paddingLeft={1}>\n53\t        <CompletedTools tools={state.completedTools} />\n54\t        {state.activeTool && <ActiveTool name={state.activeTool.name} driverName={state.activeDriverName} />}\n55\t        {state.lastThought && <LastThought text={state.lastThought} />}\n56\t        {state.retryInfo && <RetryNotice info={state.retryInfo} />}\n57\t      </Box>\n58\t    </Box>\n59\t  );\n60\t}\n61\t"}]},"parent_tool_use_id":"toolu_01TzQwpEV7uekTzzh7pB5DWd","session_id":"7e3ded59-6184-4f8b-8f55-ba5e63dae51f","uuid":"72591629-a639-491b-8475-a651eb1228e7","timestamp":"2026-04-04T02:49:35.362Z"}
