{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ex1sGyyTBafyL1RvykWHhc","type":"tool_result","content":"1\t/**\n2\t * Worktree Manager.\n3\t *\n4\t * Handles git worktree lifecycle for parallel epic execution:\n5\t * create, cleanup, list, and orphan detection. Each epic gets\n6\t * its own git worktree on a dedicated branch under the\n7\t * `codeharness/` namespace.\n8\t *\n9\t * @see Story 17-1: Worktree Manager\n10\t * @see Story 18-2: Merge Agent for Conflict Resolution (onConflict callback)\n11\t */\n12\t\n13\timport { execSync } from 'node:child_process';\n14\timport { existsSync, readFileSync, statSync } from 'node:fs';\n15\timport { join } from 'node:path';\n16\t\n17\timport type { ConflictResolutionResult } from './merge-agent.js';\n18\timport { validateMerge } from './cross-worktree-validator.js';\n19\t\n20\t/**\n21\t * Partial conflict context that mergeWorktree can fill from its own state.\n22\t * The onConflict callback receives this and enriches it with driver/descriptions\n23\t * before calling the merge agent.\n24\t */\n25\texport interface MergeConflictInfo {\n26\t  readonly epicId: string;\n27\t  readonly branch: string;\n28\t  readonly conflicts: string[];\n29\t  readonly cwd: string;\n30\t  readonly testCommand: string;\n31\t}\n32\t\n33\t// --- Constants ---\n34\t\n35\t/** Branch prefix for all codeharness worktree branches. */\n36\texport const BRANCH_PREFIX = 'codeharness/epic-';\n37\t\n38\t/** Base path for worktree directories in /tmp. */\n39\texport const WORKTREE_BASE = '/tmp/codeharness-wt-epic-';\n40\t\n41\t// --- Interfaces ---\n42\t\n43\t/**\n44\t * Information about a codeharness worktree.\n45\t */\n46\texport interface WorktreeInfo {\n47\t  /** Epic identifier extracted from the branch name. */\n48\t  readonly epicId: string;\n49\t  /** Absolute path to the worktree directory. */\n50\t  readonly path: string;"}]},"parent_tool_use_id":"toolu_01DyuE8H75hShivUjUvnNUNi","session_id":"22206bba-5847-41b1-b510-883e1dd8c0da","uuid":"85203ec3-de9d-4cf6-8d02-d0655e8ef7fe","timestamp":"2026-04-03T22:32:22.885Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01P3qvseuc9wQpqmHhhFocNT","type":"tool_result","content":"1\t/**\n2\t * Merge Agent — conflict resolution via driver dispatch with retry loop.\n3\t *\n4\t * Receives a MergeConflictContext with conflicting files, epic descriptions,\n5\t * and an AgentDriver instance. Dispatches the driver to resolve conflicts,\n6\t * validates with the test suite, and retries up to 3 times before escalating.\n7\t *\n8\t * @see Story 18-2: Merge Agent for Conflict Resolution\n9\t */\n10\t\n11\timport { execSync } from 'node:child_process';\n12\timport { readFileSync } from 'node:fs';\n13\timport { join } from 'node:path';\n14\t\n15\timport type { AgentDriver } from './agents/types.js';\n16\timport { validateMerge, writeMergeTelemetry } from './cross-worktree-validator.js';\n17\t\n18\t// --- Interfaces ---\n19\t\n20\t/**\n21\t * Context provided to the merge agent for conflict resolution.\n22\t */\n23\texport interface MergeConflictContext {\n24\t  /** Epic identifier. */\n25\t  readonly epicId: string;\n26\t  /** Branch being merged. */\n27\t  readonly branch: string;\n28\t  /** List of conflicting file paths (relative to cwd). */\n29\t  readonly conflicts: string[];\n30\t  /** Description of what the main branch contains. */\n31\t  readonly mainDescription: string;\n32\t  /** Description of what the feature branch was building. */\n33\t  readonly branchDescription: string;\n34\t  /** Working directory (main repo root where merge is in progress). */\n35\t  readonly cwd: string;\n36\t  /** Command to run for test validation. */\n37\t  readonly testCommand: string;\n38\t  /** Driver instance to dispatch for conflict resolution. */\n39\t  readonly driver: AgentDriver;\n40\t}\n41\t\n42\t/**\n43\t * Result of a conflict resolution attempt.\n44\t */\n45\texport interface ConflictResolutionResult {\n46\t  /** Whether all conflicts were resolved and tests pass. */\n47\t  resolved: boolean;\n48\t  /** Number of resolution attempts made. */\n49\t  attempts: number;\n50\t  /** Whether the conflict was escalated for manual resolution. */"}]},"parent_tool_use_id":"toolu_01DyuE8H75hShivUjUvnNUNi","session_id":"22206bba-5847-41b1-b510-883e1dd8c0da","uuid":"f2690f02-e006-4a08-a2c3-f41b1c14192b","timestamp":"2026-04-03T22:32:22.886Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Pg6uWvLQWg67QE4oStAvkh","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach } from 'vitest';\n2\t\n3\t// Create controllable mocks — must use vi.hoisted so they're available in vi.mock factories\n4\tconst { mockExecAsync, mockAppendFileSync, mockMkdirSync } = vi.hoisted(() => ({\n5\t  mockExecAsync: vi.fn(),\n6\t  mockAppendFileSync: vi.fn(),\n7\t  mockMkdirSync: vi.fn(),\n8\t}));\n9\t\n10\t// Mock node:child_process\n11\tvi.mock('node:child_process', () => ({\n12\t  exec: vi.fn(),\n13\t}));\n14\t\n15\t// Mock node:util to return our controllable mockExecAsync\n16\tvi.mock('node:util', () => ({\n17\t  promisify: () => mockExecAsync,\n18\t}));\n19\t\n20\t// Mock node:fs\n21\tvi.mock('node:fs', () => ({\n22\t  appendFileSync: mockAppendFileSync,\n23\t  mkdirSync: mockMkdirSync,\n24\t}));\n25\t\n26\timport {\n27\t  validateMerge,\n28\t  parseTestOutput,\n29\t  writeMergeTelemetry,\n30\t  type ValidateMergeOptions,\n31\t  type ValidationResult,\n32\t} from '../cross-worktree-validator.js';\n33\t\n34\tdescribe('cross-worktree-validator', () => {\n35\t  beforeEach(() => {\n36\t    vi.clearAllMocks();\n37\t  });\n38\t\n39\t  // --- Interface Shape Tests (AC #7, #8) ---\n40\t\n41\t  describe('ValidateMergeOptions interface shape (AC #8)', () => {\n42\t    it('has all required fields', () => {\n43\t      const opts: ValidateMergeOptions = {\n44\t        testCommand: 'npm test',\n45\t        cwd: '/repo',\n46\t        epicId: '18',\n47\t        writeTelemetry: true,\n48\t      };\n49\t      expect(opts).toHaveProperty('testCommand');\n50\t      expect(opts).toHaveProperty('cwd');\n51\t      expect(opts).toHaveProperty('epicId');\n52\t      expect(opts).toHaveProperty('writeTelemetry');\n53\t    });\n54\t\n55\t    it('accepts optional storyKey', () => {\n56\t      const opts: ValidateMergeOptions = {\n57\t        testCommand: 'npm test',\n58\t        cwd: '/repo',\n59\t        epicId: '18',\n60\t        storyKey: 'merge-18-custom',\n61\t        writeTelemetry: false,\n62\t      };\n63\t      expect(opts.storyKey).toBe('merge-18-custom');\n64\t    });\n65\t  });\n66\t\n67\t  describe('ValidationResult interface shape (AC #7)', () => {\n68\t    it('has all required fields', () => {\n69\t      const result: ValidationResult = {\n70\t        valid: true,\n71\t        testResults: { passed: 10, failed: 0, coverage: 95.5 },\n72\t        output: '10 passed',\n73\t        durationMs: 1234,\n74\t      };\n75\t      expect(result).toHaveProperty('valid');\n76\t      expect(result).toHaveProperty('testResults');\n77\t      expect(result).toHaveProperty('output');\n78\t      expect(result).toHaveProperty('durationMs');\n79\t    });\n80\t\n81\t    it('testResults includes passed, failed, and optional coverage', () => {\n82\t      const withCov: ValidationResult = {\n83\t        valid: true,\n84\t        testResults: { passed: 5, failed: 0, coverage: 88.2 },\n85\t        output: '',\n86\t        durationMs: 100,\n87\t      };\n88\t      expect(withCov.testResults.passed).toBe(5);\n89\t      expect(withCov.testResults.failed).toBe(0);\n90\t      expect(withCov.testResults.coverage).toBe(88.2);\n91\t\n92\t      const withoutCov: ValidationResult = {\n93\t        valid: false,\n94\t        testResults: { passed: 3, failed: 2, coverage: null },\n95\t        output: '',\n96\t        durationMs: 200,\n97\t      };\n98\t      expect(withoutCov.testResults.coverage).toBeNull();\n99\t    });\n100\t  });\n101\t\n102\t  // --- parseTestOutput Tests ---\n103\t\n104\t  describe('parseTestOutput (AC #1)', () => {\n105\t    it('parses passed and failed counts', () => {\n106\t      const result = parseTestOutput('10 passed\\n2 failed');\n107\t      expect(result.passed).toBe(10);\n108\t      expect(result.failed).toBe(2);\n109\t    });\n110\t\n111\t    it('parses passed only', () => {\n112\t      const result = parseTestOutput('5 passed');\n113\t      expect(result.passed).toBe(5);\n114\t      expect(result.failed).toBe(0);\n115\t    });\n116\t\n117\t    it('parses coverage from \"All files\" pattern', () => {\n118\t      const result = parseTestOutput('10 passed\\n0 failed\\nAll files | 95.5');\n119\t      expect(result.coverage).toBe(95.5);\n120\t    });\n121\t\n122\t    it('returns 0/0 for unparseable output', () => {\n123\t      const result = parseTestOutput('Build completed successfully.');\n124\t      expect(result.passed).toBe(0);\n125\t      expect(result.failed).toBe(0);\n126\t      expect(result.coverage).toBeNull();\n127\t    });\n128\t\n129\t    it('handles empty string', () => {\n130\t      const result = parseTestOutput('');\n131\t      expect(result.passed).toBe(0);\n132\t      expect(result.failed).toBe(0);\n133\t    });\n134\t  });\n135\t\n136\t  // --- validateMerge Tests ---\n137\t\n138\t  describe('validateMerge — success path (AC #1)', () => {\n139\t    it('returns valid: true when tests pass', async () => {\n140\t      mockExecAsync.mockResolvedValue({ stdout: '10 passed\\n0 failed' });\n141\t\n142\t      const result = await validateMerge({\n143\t        testCommand: 'npm test',\n144\t        cwd: '/repo',\n145\t        epicId: '18',\n146\t        writeTelemetry: false,\n147\t      });\n148\t\n149\t      expect(result.valid).toBe(true);\n150\t      expect(result.testResults).toEqual({ passed: 10, failed: 0, coverage: null });\n151\t      expect(result.output).toBe('10 passed\\n0 failed');\n152\t      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n153\t    });\n154\t\n155\t    it('includes coverage in test results when available', async () => {\n156\t      mockExecAsync.mockResolvedValue({ stdout: '10 passed\\nAll files | 95.5' });\n157\t\n158\t      const result = await validateMerge({\n159\t        testCommand: 'npm test',\n160\t        cwd: '/repo',\n161\t        epicId: '18',\n162\t        writeTelemetry: false,\n163\t      });\n164\t\n165\t      expect(result.valid).toBe(true);\n166\t      expect(result.testResults.coverage).toBe(95.5);\n167\t    });\n168\t  });\n169\t\n170\t  describe('validateMerge — failure path (AC #2)', () => {\n171\t    it('returns valid: false when tests fail', async () => {\n172\t      mockExecAsync.mockResolvedValue({ stdout: '5 passed\\n3 failed' });\n173\t\n174\t      const result = await validateMerge({\n175\t        testCommand: 'npm test',\n176\t        cwd: '/repo',\n177\t        epicId: '18',\n178\t        writeTelemetry: false,\n179\t      });\n180\t\n181\t      expect(result.valid).toBe(false);\n182\t      expect(result.testResults).toEqual({ passed: 5, failed: 3, coverage: null });\n183\t      expect(result.output).toBe('5 passed\\n3 failed');\n184\t    });\n185\t\n186\t    it('returns valid: false when test command exits non-zero with parseable output', async () => {\n187\t      const err = new Error('Command failed') as Error & { stdout: string };\n188\t      err.stdout = '3 passed\\n2 failed\\nError: some test error';\n189\t      mockExecAsync.mockRejectedValue(err);\n190\t\n191\t      const result = await validateMerge({\n192\t        testCommand: 'npm test',\n193\t        cwd: '/repo',\n194\t        epicId: '18',\n195\t        writeTelemetry: false,\n196\t      });\n197\t\n198\t      expect(result.valid).toBe(false);\n199\t      expect(result.testResults).toEqual({ passed: 3, failed: 2, coverage: null });\n200\t      expect(result.output).toContain('3 passed');\n201\t    });\n202\t\n203\t    it('returns failed: 1 when test command exits with no parseable output', async () => {\n204\t      const err = new Error('Command failed') as Error & { stdout: string };\n205\t      err.stdout = '';\n206\t      mockExecAsync.mockRejectedValue(err);\n207\t\n208\t      const result = await validateMerge({\n209\t        testCommand: 'npm test',\n210\t        cwd: '/repo',\n211\t        epicId: '18',\n212\t        writeTelemetry: false,\n213\t      });\n214\t\n215\t      expect(result.valid).toBe(false);\n216\t      expect(result.testResults).toEqual({ passed: 0, failed: 1, coverage: null });\n217\t      expect(result.output).toBe('Test command failed with no output');\n218\t    });\n219\t\n220\t    it('handles error with no stdout property', async () => {\n221\t      mockExecAsync.mockRejectedValue(new Error('SIGTERM'));\n222\t\n223\t      const result = await validateMerge({\n224\t        testCommand: 'npm test',\n225\t        cwd: '/repo',\n226\t        epicId: '18',\n227\t        writeTelemetry: false,\n228\t      });\n229\t\n230\t      expect(result.valid).toBe(false);\n231\t      expect(result.testResults).toEqual({ passed: 0, failed: 1, coverage: null });\n232\t    });\n233\t\n234\t    it('treats 0 passed 0 failed as failure (edge case)', async () => {\n235\t      mockExecAsync.mockResolvedValue({ stdout: 'Build completed successfully.' });\n236\t\n237\t      const result = await validateMerge({\n238\t        testCommand: 'npm test',\n239\t        cwd: '/repo',\n240\t        epicId: '18',\n241\t        writeTelemetry: false,\n242\t      });\n243\t\n244\t      // 0 passed && 0 failed => valid = false (passed must be > 0)\n245\t      expect(result.valid).toBe(false);\n246\t    });\n247\t  });\n248\t\n249\t  describe('validateMerge — timeout (AC #5)', () => {\n250\t    it('respects 5-minute timeout', async () => {\n251\t      mockExecAsync.mockResolvedValue({ stdout: '5 passed' });\n252\t\n253\t      await validateMerge({\n254\t        testCommand: 'npm test',\n255\t        cwd: '/repo',\n256\t        epicId: '18',\n257\t        writeTelemetry: false,\n258\t      });\n259\t\n260\t      expect(mockExecAsync).toHaveBeenCalledWith('npm test', {\n261\t        cwd: '/repo',\n262\t        timeout: 300_000,\n263\t        maxBuffer: 10 * 1024 * 1024,\n264\t      });\n265\t    });\n266\t\n267\t    it('handles timeout error as failure', async () => {\n268\t      const err = new Error('Process timed out') as Error & { stdout: string };\n269\t      err.stdout = '';\n270\t      mockExecAsync.mockRejectedValue(err);\n271\t\n272\t      const result = await validateMerge({\n273\t        testCommand: 'npm test',\n274\t        cwd: '/repo',\n275\t        epicId: '18',\n276\t        writeTelemetry: false,\n277\t      });\n278\t\n279\t      expect(result.valid).toBe(false);\n280\t      expect(result.testResults).toEqual({ passed: 0, failed: 1, coverage: null });\n281\t    });\n282\t  });\n283\t\n284\t  // --- Telemetry Tests (AC #4, #9) ---\n285\t\n286\t  describe('validateMerge — telemetry integration (AC #4, #9)', () => {\n287\t    it('writes telemetry when writeTelemetry is true', async () => {\n288\t      mockExecAsync.mockResolvedValue({ stdout: '10 passed\\n0 failed' });\n289\t\n290\t      await validateMerge({\n291\t        testCommand: 'npm test',\n292\t        cwd: '/repo',\n293\t        epicId: '18',\n294\t        writeTelemetry: true,\n295\t      });\n296\t\n297\t      expect(mockMkdirSync).toHaveBeenCalledWith('/repo/.codeharness', { recursive: true });\n298\t      expect(mockAppendFileSync).toHaveBeenCalledOnce();\n299\t      const written = mockAppendFileSync.mock.calls[0][1] as string;\n300\t      const entry = JSON.parse(written.trim());\n301\t      expect(entry.version).toBe(1);\n302\t      expect(entry.storyKey).toBe('merge-18');\n303\t      expect(entry.epicId).toBe('18');\n304\t      expect(entry.testResults.passed).toBe(10);\n305\t      expect(entry.testResults.failed).toBe(0);\n306\t      expect(entry.errors).toEqual([]);\n307\t    });\n308\t\n309\t    it('skips telemetry when writeTelemetry is false', async () => {\n310\t      mockExecAsync.mockResolvedValue({ stdout: '10 passed' });\n311\t\n312\t      await validateMerge({\n313\t        testCommand: 'npm test',\n314\t        cwd: '/repo',\n315\t        epicId: '18',\n316\t        writeTelemetry: false,\n317\t      });\n318\t\n319\t      expect(mockAppendFileSync).not.toHaveBeenCalled();\n320\t    });\n321\t\n322\t    it('writes telemetry on failure with error message', async () => {\n323\t      mockExecAsync.mockResolvedValue({ stdout: '5 passed\\n2 failed' });\n324\t\n325\t      await validateMerge({\n326\t        testCommand: 'npm test',\n327\t        cwd: '/repo',\n328\t        epicId: '18',\n329\t        writeTelemetry: true,\n330\t      });\n331\t\n332\t      expect(mockAppendFileSync).toHaveBeenCalledOnce();\n333\t      const written = mockAppendFileSync.mock.calls[0][1] as string;\n334\t      const entry = JSON.parse(written.trim());\n335\t      expect(entry.errors).toEqual(['Test suite failed after merge']);\n336\t      expect(entry.testResults.failed).toBe(2);\n337\t    });\n338\t\n339\t    it('telemetry entry has storyKey: merge-{epicId} format (AC #9)', async () => {\n340\t      mockExecAsync.mockResolvedValue({ stdout: '5 passed' });\n341\t\n342\t      await validateMerge({\n343\t        testCommand: 'npm test',\n344\t        cwd: '/repo',\n345\t        epicId: '42',\n346\t        writeTelemetry: true,\n347\t      });\n348\t\n349\t      const written = mockAppendFileSync.mock.calls[0][1] as string;\n350\t      const entry = JSON.parse(written.trim());\n351\t      expect(entry.storyKey).toBe('merge-42');\n352\t    });\n353\t\n354\t    it('uses custom storyKey when provided (AC #9)', async () => {\n355\t      mockExecAsync.mockResolvedValue({ stdout: '5 passed' });\n356\t\n357\t      await validateMerge({\n358\t        testCommand: 'npm test',\n359\t        cwd: '/repo',\n360\t        epicId: '42',\n361\t        storyKey: 'custom-key',\n362\t        writeTelemetry: true,\n363\t      });\n364\t\n365\t      const written = mockAppendFileSync.mock.calls[0][1] as string;\n366\t      const entry = JSON.parse(written.trim());\n367\t      expect(entry.storyKey).toBe('custom-key');\n368\t    });\n369\t\n370\t    it('telemetry entry includes duration_ms and timestamp', async () => {\n371\t      mockExecAsync.mockResolvedValue({ stdout: '5 passed' });\n372\t\n373\t      await validateMerge({\n374\t        testCommand: 'npm test',\n375\t        cwd: '/repo',\n376\t        epicId: '18',\n377\t        writeTelemetry: true,\n378\t      });\n379\t\n380\t      const written = mockAppendFileSync.mock.calls[0][1] as string;\n381\t      const entry = JSON.parse(written.trim());\n382\t      expect(typeof entry.duration_ms).toBe('number');\n383\t      expect(entry.duration_ms).toBeGreaterThanOrEqual(0);\n384\t      expect(typeof entry.timestamp).toBe('string');\n385\t      expect(entry.cost_usd).toBeNull();\n386\t      expect(entry.attempts).toBeNull();\n387\t      expect(entry.acResults).toBeNull();\n388\t      expect(entry.filesChanged).toEqual([]);\n389\t    });\n390\t\n391\t    it('telemetry write failure does not break validation', async () => {\n392\t      mockExecAsync.mockResolvedValue({ stdout: '10 passed\\n0 failed' });\n393\t      mockAppendFileSync.mockImplementation(() => {\n394\t        throw new Error('ENOSPC: no space left on device');\n395\t      });\n396\t\n397\t      const result = await validateMerge({\n398\t        testCommand: 'npm test',\n399\t        cwd: '/repo',\n400\t        epicId: '18',\n401\t        writeTelemetry: true,\n402\t      });\n403\t\n404\t      // Validation should still succeed despite telemetry failure\n405\t      expect(result.valid).toBe(true);\n406\t      expect(result.testResults).toEqual({ passed: 10, failed: 0, coverage: null });\n407\t    });\n408\t\n409\t    it('writes telemetry on test command error when writeTelemetry is true', async () => {\n410\t      const err = new Error('Command failed') as Error & { stdout: string };\n411\t      err.stdout = '2 passed\\n3 failed';\n412\t      mockExecAsync.mockRejectedValue(err);\n413\t\n414\t      await validateMerge({\n415\t        testCommand: 'npm test',\n416\t        cwd: '/repo',\n417\t        epicId: '18',\n418\t        writeTelemetry: true,\n419\t      });\n420\t\n421\t      expect(mockAppendFileSync).toHaveBeenCalledOnce();\n422\t      const written = mockAppendFileSync.mock.calls[0][1] as string;\n423\t      const entry = JSON.parse(written.trim());\n424\t      expect(entry.testResults.passed).toBe(2);\n425\t      expect(entry.testResults.failed).toBe(3);\n426\t    });\n427\t\n428\t    it('writes telemetry on no-output error when writeTelemetry is true', async () => {\n429\t      const err = new Error('Command failed') as Error & { stdout: string };\n430\t      err.stdout = '';\n431\t      mockExecAsync.mockRejectedValue(err);\n432\t\n433\t      await validateMerge({\n434\t        testCommand: 'npm test',\n435\t        cwd: '/repo',\n436\t        epicId: '18',\n437\t        writeTelemetry: true,\n438\t      });\n439\t\n440\t      expect(mockAppendFileSync).toHaveBeenCalledOnce();\n441\t      const written = mockAppendFileSync.mock.calls[0][1] as string;\n442\t      const entry = JSON.parse(written.trim());\n443\t      expect(entry.testResults).toEqual({ passed: 0, failed: 1, coverage: null });\n444\t      expect(entry.errors).toEqual(['Test suite failed after merge']);\n445\t    });\n446\t  });\n447\t\n448\t  // --- writeMergeTelemetry Tests ---\n449\t\n450\t  describe('writeMergeTelemetry (exported helper)', () => {\n451\t    it('writes NDJSON entry to .codeharness/telemetry.jsonl', () => {\n452\t      const opts: ValidateMergeOptions = {\n453\t        testCommand: 'npm test',\n454\t        cwd: '/repo',\n455\t        epicId: '18',\n456\t        writeTelemetry: true,\n457\t      };\n458\t      const result: ValidationResult = {\n459\t        valid: true,\n460\t        testResults: { passed: 10, failed: 0, coverage: null },\n461\t        output: '10 passed',\n462\t        durationMs: 500,\n463\t      };\n464\t\n465\t      writeMergeTelemetry(opts, result);\n466\t\n467\t      expect(mockMkdirSync).toHaveBeenCalledWith('/repo/.codeharness', { recursive: true });\n468\t      expect(mockAppendFileSync).toHaveBeenCalledWith(\n469\t        '/repo/.codeharness/telemetry.jsonl',\n470\t        expect.stringContaining('\"storyKey\":\"merge-18\"'),\n471\t      );\n472\t    });\n473\t\n474\t    it('silently catches write failures', () => {\n475\t      mockAppendFileSync.mockImplementation(() => {\n476\t        throw new Error('Permission denied');\n477\t      });\n478\t\n479\t      const opts: ValidateMergeOptions = {\n480\t        testCommand: 'npm test',\n481\t        cwd: '/repo',\n482\t        epicId: '18',\n483\t        writeTelemetry: true,\n484\t      };\n485\t      const result: ValidationResult = {\n486\t        valid: true,\n487\t        testResults: { passed: 5, failed: 0, coverage: null },\n488\t        output: '',\n489\t        durationMs: 100,\n490\t      };\n491\t\n492\t      // Should not throw\n493\t      expect(() => writeMergeTelemetry(opts, result)).not.toThrow();\n494\t    });\n495\t  });\n496\t\n497\t  // --- Uses configured test command (AC #5) ---\n498\t\n499\t  describe('validateMerge — test command configuration (AC #5)', () => {\n500\t    it('uses the configured test command', async () => {\n501\t      mockExecAsync.mockResolvedValue({ stdout: '5 passed' });\n502\t\n503\t      await validateMerge({\n504\t        testCommand: './node_modules/.bin/vitest run',\n505\t        cwd: '/my-project',\n506\t        epicId: '18',\n507\t        writeTelemetry: false,\n508\t      });\n509\t\n510\t      expect(mockExecAsync).toHaveBeenCalledWith('./node_modules/.bin/vitest run', {\n511\t        cwd: '/my-project',\n512\t        timeout: 300_000,\n513\t        maxBuffer: 10 * 1024 * 1024,\n514\t      });\n515\t    });\n516\t  });\n517\t\n518\t  // --- Regression: existing module tests still pass (AC #10) ---\n519\t\n520\t  describe('exports (AC #6)', () => {\n521\t    it('exports validateMerge function', () => {\n522\t      expect(typeof validateMerge).toBe('function');\n523\t    });\n524\t\n525\t    it('exports parseTestOutput function', () => {\n526\t      expect(typeof parseTestOutput).toBe('function');\n527\t    });\n528\t\n529\t    it('exports writeMergeTelemetry function', () => {\n530\t      expect(typeof writeMergeTelemetry).toBe('functi