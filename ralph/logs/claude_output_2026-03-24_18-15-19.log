{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01S3uDJQVtyxtMKJ5mmFtqKW","type":"tool_result","content":"     1→/**\n     2→ * Mock factory functions for commonly mocked modules.\n     3→ *\n     4→ * Each factory returns a plain object with vi.fn() stubs.\n     5→ * They do NOT call vi.mock() — that must happen at module level\n     6→ * in each test file (Vitest hoisting requirement).\n     7→ *\n     8→ * Usage pattern:\n     9→ *   import { createFsMock } from '../../lib/__tests__/helpers.js';\n    10→ *   const fsMock = createFsMock();\n    11→ *   vi.mock('node:fs', () => fsMock);\n    12→ */\n    13→\n    14→import { vi } from 'vitest';\n    15→\n    16→/**\n    17→ * Create mock stubs for `node:fs` module.\n    18→ * Includes the most commonly used fs functions in tests.\n    19→ */\n    20→export function createFsMock() {\n    21→  return {\n    22→    readFileSync: vi.fn(),\n    23→    writeFileSync: vi.fn(),\n    24→    existsSync: vi.fn(() => true),\n    25→    mkdirSync: vi.fn(),\n    26→    mkdtempSync: vi.fn(),\n    27→    rmSync: vi.fn(),\n    28→    readdirSync: vi.fn(() => []),\n    29→    statSync: vi.fn(),\n    30→    unlinkSync: vi.fn(),\n    31→    copyFileSync: vi.fn(),\n    32→    renameSync: vi.fn(),\n    33→  };\n    34→}\n    35→\n    36→/**\n    37→ * Create mock stubs for `node:child_process` module.\n    38→ */\n    39→export function createChildProcessMock() {\n    40→  return {\n    41→    execFileSync: vi.fn(),\n    42→    execSync: vi.fn(),\n    43→    spawn: vi.fn(),\n    44→    exec: vi.fn(),\n    45→  };\n    46→}\n    47→\n    48→/**\n    49→ * Create mock stubs for Docker-related functions.\n    50→ * Matches the exports from `src/lib/docker/index.ts`.\n    51→ */\n    52→export function createDockerMock() {\n    53→  return {\n    54→    isDockerAvailable: vi.fn(() => true),\n    55→    isDockerComposeAvailable: vi.fn(() => true),\n    56→    isStackRunning: vi.fn(() => false),\n    57→    startStack: vi.fn(() => ({ started: true, services: [], error: undefined })),\n    58→    stopStack: vi.fn(),\n    59→    getStackHealth: vi.fn(() => ({\n    60→      healthy: true,\n    61→      services: [],\n    62→      remedy: undefined,\n    63→    })),\n    64→    isSharedStackRunning: vi.fn(() => false),\n    65→    startSharedStack: vi.fn(() => ({ started: true, error: undefined })),\n    66→    stopSharedStack: vi.fn(),\n    67→    startCollectorOnly: vi.fn(() => ({ started: true, error: undefined })),\n    68→    isCollectorRunning: vi.fn(() => false),\n    69→    stopCollectorOnly: vi.fn(),\n    70→    getCollectorHealth: vi.fn(() => ({\n    71→      healthy: true,\n    72→      services: [],\n    73→      remedy: undefined,\n    74→    })),\n    75→    checkRemoteEndpoint: vi.fn(async () => ({ reachable: true, error: undefined })),\n    76→    cleanupOrphanedContainers: vi.fn(),\n    77→    cleanupVerifyEnv: vi.fn(),\n    78→  };\n    79→}\n    80→\n    81→/**\n    82→ * Create mock stubs for state-related functions.\n    83→ * Matches common patterns from `src/lib/state.ts` and `src/modules/sprint/state.ts`.\n    84→ */\n    85→export function createStateMock() {\n    86→  return {\n    87→    readState: vi.fn(() => ({})),\n    88→    writeState: vi.fn(),\n    89→    readStateWithBody: vi.fn(() => ({ state: {}, body: '' })),\n    90→    getStatePath: vi.fn(() => '.claude/codeharness.local.md'),\n    91→    readLocalConfig: vi.fn(() => ({})),\n    92→    getProjectRoot: vi.fn(() => '/mock/project'),\n    93→    getSprintState: vi.fn(() => ({ success: true, data: undefined })),\n    94→    updateStoryStatus: vi.fn(() => ({ success: true, data: undefined })),\n    95→  };\n    96→}\n    97→"}]},"parent_tool_use_id":"toolu_01E4d2UoNxdYuxQTG5Dezgge","session_id":"8c35c2f7-0e10-4994-a438-2b5cecce3396","uuid":"9bfeeca5-406d-4858-aac5-731cd9c7975c","timestamp":"2026-03-24T14:16:22.165Z"}
