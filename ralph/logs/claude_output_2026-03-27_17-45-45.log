alidation failed');\n   461→  });\n   462→});\n   463→\n   464→// ─── Task 4: getValidationProgress ───────────────────────────────────────────\n   465→\n   466→describe('getValidationProgress', () => {\n   467→  it('returns correct counts for mixed statuses', () => {\n   468→    const state = emptyState();\n   469→    (state as { stories: Record<string, StoryState> }).stories = {\n   470→      'val-1': defaultStory({ status: 'done' }),\n   471→      'val-2': defaultStory({ status: 'done' }),\n   472→      'val-3': defaultStory({ status: 'failed', attempts: 3 }),\n   473→      'val-4': defaultStory({ status: 'blocked' }),\n   474→      'val-5': defaultStory({ status: 'backlog' }),\n   475→      'val-6': defaultStory({ status: 'backlog' }),\n   476→      'val-7': defaultStory({ status: 'backlog' }),\n   477→    };\n   478→    mockGetSprintState.mockReturnValue({ success: true, data: state });\n   479→\n   480→    const result = getValidationProgress();\n   481→    expect(result.success).toBe(true);\n   482→    if (!result.success) return;\n   483→\n   484→    // Only counts ACs that exist in VALIDATION_ACS registry\n   485→    // val-1 through val-7 map to AC IDs 1-7 which exist in the 79-AC registry\n   486→    expect(result.data.passed).toBe(2);\n   487→    expect(result.data.failed).toBe(1);\n   488→    expect(result.data.blocked).toBe(1);\n   489→    expect(result.data.remaining).toBe(3);\n   490→    expect(result.data.total).toBe(7);\n   491→  });\n   492→\n   493→  it('returns per-AC status with attempts and lastError', () => {\n   494→    const state = emptyState();\n   495→    (state as { stories: Record<string, StoryState> }).stories = {\n   496→      'val-1': defaultStory({ status: 'done', attempts: 1, lastError: null }),\n   497→      'val-2': defaultStory({ status: 'failed', attempts: 5, lastError: 'exit code 1' }),\n   498→    };\n   499→    mockGetSprintState.mockReturnValue({ success: true, data: state });\n   500→\n   501→    const result = getValidationProgress();\n   502→    expect(result.success).toBe(true);\n   503→    if (!result.success) return;\n   504→\n   505→    const ac1 = result.data.perAC.find(a => a.acId === 1);\n   506→    expect(ac1).toBeDefined();\n   507→    expect(ac1!.status).toBe('done');\n   508→    expect(ac1!.attempts).toBe(1);\n   509→    expect(ac1!.lastError).toBeNull();\n   510→\n   511→    const ac2 = result.data.perAC.find(a => a.acId === 2);\n   512→    expect(ac2).toBeDefined();\n   513→    expect(ac2!.status).toBe('failed');\n   514→    expect(ac2!.attempts).toBe(5);\n   515→    expect(ac2!.lastError).toBe('exit code 1');\n   516→  });\n   517→\n   518→  it('returns fail when state read fails', () => {\n   519→    mockGetSprintState.mockReturnValue({ success: false, error: 'no file' });\n   520→\n   521→    const result = getValidationProgress();\n   522→    expect(result.success).toBe(false);\n   523→  });\n   524→});\n   525→\n   526→// ─── Task 5: runValidationCycle ──────────────────────────────────────────────\n   527→\n   528→describe('runValidationCycle', () => {\n   529→  it('routes failures to dev module via fix story', () => {\n   530→    // Find a CLI-verifiable AC from the real registry\n   531→    const targetAC = VALIDATION_ACS.find(ac => ac.verificationMethod === 'cli')!;\n   532→    const state = emptyState();\n   533→    // Set all ACs as done except our target\n   534→    for (let i = 1; i <= 79; i++) {\n   535→      (state as { stories: Record<string, StoryState> }).stories[`val-${i}`] = defaultStory({ status: 'done' });\n   536→    }\n   537→    (state as { stories: Record<string, StoryState> }).stories[`val-${targetAC.id}`] = defaultStory({ status: 'backlog' });\n   538→\n   539→    // Both getSprintState calls return the same state\n   540→    mockGetSprintState.mockReturnValue({ success: true, data: state });\n   541→\n   542→    // The AC command fails\n   543→    mockExecSync.mockImplementation(() => {\n   544→      const err = new Error('fail');\n   545→      (err as unknown as Record<string, unknown>).stderr = 'error output';\n   546→      throw err;\n   547→    });\n   548→\n   549→    const result = runValidationCycle();\n   550→    expect(result.success).toBe(true);\n   551→    if (!result.success) return;\n   552→\n   553→    expect(result.data.action).toBe('failed-routed-to-dev');\n   554→    expect(result.data.fixStoryKey).toMatch(/^val-fix-/);\n   555→    expect(mockDevelopStory).toHaveBeenCalled();\n   556→  });\n   557→\n   558→  it('returns no-actionable-ac when all are done or blocked', () => {\n   559→    const state = emptyState();\n   560→    (state as { stories: Record<string, StoryState> }).stories = {\n   561→      'val-1': defaultStory({ status: 'done' }),\n   562→      'val-2': defaultStory({ status: 'blocked' }),\n   563→    };\n   564→    // Add remaining ACs as done\n   565→    for (let i = 3; i <= 79; i++) {\n   566→      (state as { stories: Record<string, StoryState> }).stories[`val-${i}`] = defaultStory({ status: 'done' });\n   567→    }\n   568→    mockGetSprintState.mockReturnValue({ success: true, data: state });\n   569→\n   570→    const result = runValidationCycle();\n   571→    expect(result.success).toBe(true);\n   572→    if (!result.success) return;\n   573→    expect(result.data.action).toBe('no-actionable-ac');\n   574→  });\n   575→\n   576→  it('prefers failed ACs over backlog ACs (re-validation)', () => {\n   577→    // Find two CLI-verifiable ACs\n   578→    const cliACs = VALIDATION_ACS.filter(ac => ac.verificationMethod === 'cli');\n   579→    const backlogAC = cliACs[0];\n   580→    const failedAC = cliACs[1];\n   581→\n   582→    const state = emptyState();\n   583→    // Fill all with done\n   584→    for (let i = 1; i <= 79; i++) {\n   585→      (state as { stories: Record<string, StoryState> }).stories[`val-${i}`] = defaultStory({ status: 'done' });\n   586→    }\n   587→    // Set backlog and failed\n   588→    (state as { stories: Record<string, StoryState> }).stories[`val-${backlogAC.id}`] = defaultStory({ status: 'backlog' });\n   589→    (state as { stories: Record<string, StoryState> }).stories[`val-${failedAC.id}`] = defaultStory({ status: 'failed', attempts: 2 });\n   590→\n   591→    mockGetSprintState.mockReturnValue({ success: true, data: state });\n   592→    mockExecSync.mockReturnValue('fixed now');\n   593→\n   594→    const result = runValidationCycle();\n   595→    expect(result.success).toBe(true);\n   596→    if (!result.success) return;\n   597→    // Should pick failed AC, not backlog AC\n   598→    expect(result.data.acId).toBe(failedAC.id);\n   599→    expect(result.data.action).toBe('passed');\n   600→  });\n   601→\n   602→  it('handles blocked (integration) ACs correctly', () => {\n   603→    // AC 2 is integration-required in the actual registry\n   604→    const state = emptyState();\n   605→    // Set all ACs as done except an integration-required one\n   606→    for (let i = 1; i <= 79; i++) {\n   607→      (state as { stories: Record<string, StoryState> }).stories[`val-${i}`] = defaultStory({ status: 'done' });\n   608→    }\n   609→    // Find an integration AC from the real registry\n   610→    const intAC = VALIDATION_ACS.find(ac => ac.verificationMethod === 'integration');\n   611→    if (!intAC) return; // safety\n   612→    (state as { stories: Record<string, StoryState> }).stories[`val-${intAC.id}`] = defaultStory({ status: 'backlog' });\n   613→\n   614→    mockGetSprintState.mockReturnValue({ success: true, data: state });\n   615→\n   616→    const result = runValidationCycle();\n   617→    expect(result.success).toBe(true);\n   618→    if (!result.success) return;\n   619→    expect(result.data.acId).toBe(intAC.id);\n   620→    expect(result.data.action).toBe('blocked');\n   621→  });\n   622→\n   623→  it('skips retry-exhausted ACs', () => {\n   624→    const state = emptyState();\n   625→    (state as { stories: Record<string, StoryState> }).stories = {\n   626→      'val-1': defaultStory({ status: 'failed', attempts: 10 }),\n   627→      'val-2': defaultStory({ status: 'backlog' }),\n   628→    };\n   629→    for (let i = 3; i <= 79; i++) {\n   630→      (state as { stories: Record<string, StoryState> }).stories[`val-${i}`] = defaultStory({ status: 'done' });\n   631→    }\n   632→    mockGetSprintState.mockReturnValue({ success: true, data: state });\n   633→    mockExecSync.mockReturnValue('ok');\n   634→\n   635→    const result = runValidationCycle();\n   636→    expect(result.success).toBe(true);\n   637→    if (!result.success) return;\n   638→    // Should skip val-1 (exhausted) and pick val-2\n   639→    expect(result.data.acId).toBe(2);\n   640→  });\n   641→\n   642→  it('returns fail when state read fails', () => {\n   643→    mockGetSprintState.mockReturnValue({ success: false, error: 'disk error' });\n   644→\n   645→    const result = runValidationCycle();\n   646→    expect(result.success).toBe(false);\n   647→  });\n   648→\n   649→  it('returns fail when processValidationResult fails', () => {\n   650→    const cliACs = VALIDATION_ACS.filter(ac => ac.verificationMethod === 'cli');\n   651→    const targetAC = cliACs[0];\n   652→\n   653→    const state = emptyState();\n   654→    for (let i = 1; i <= 79; i++) {\n   655→      (state as { stories: Record<string, StoryState> }).stories[`val-${i}`] = defaultStory({ status: 'done' });\n   656→    }\n   657→    (state as { stories: Record<string, StoryState> }).stories[`val-${targetAC.id}`] = defaultStory({ status: 'backlog' });\n   658→\n   659→    // First call to getSprintState (in runValidationCycle) succeeds\n   660→    // Second call (in processValidationResult) fails\n   661→    mockGetSprintState\n   662→      .mockReturnValueOnce({ success: true, data: state })\n   663→      .mockReturnValueOnce({ success: false, error: 'state write locked' });\n   664→    mockExecSync.mockReturnValue('ok');\n   665→\n   666→    const result = runValidationCycle();\n   667→    expect(result.success).toBe(false);\n   668→    if (result.success) return;\n   669→    expect(result.error).toContain('state write locked');\n   670→  });\n   671→\n   672→  it('returns fail when createFixStory fails', () => {\n   673→    const cliACs = VALIDATION_ACS.filter(ac => ac.verificationMethod === 'cli');\n   674→    const targetAC = cliACs[0];\n   675→\n   676→    const state = emptyState();\n   677→    for (let i = 1; i <= 79; i++) {\n   678→      (state as { stories: Record<string, StoryState> }).stories[`val-${i}`] = defaultStory({ status: 'done' });\n   679→    }\n   680→    (state as { stories: Record<string, StoryState> }).stories[`val-${targetAC.id}`] = defaultStory({ status: 'backlog' });\n   681→\n   682→    mockGetSprintState.mockReturnValue({ success: true, data: state });\n   683→    // AC command fails\n   684→    mockExecSync.mockImplementation(() => {\n   685→      const err = new Error('fail');\n   686→      (err as unknown as Record<string, unknown>).stderr = 'error output';\n   687→      throw err;\n   688→    });\n   689→    // mkdirSync throws to make createFixStory fail\n   690→    mockMkdirSync.mockImplementation(() => { throw new Error('EACCES: permission denied'); });\n   691→\n   692→    const result = runValidationCycle();\n   693→    expect(result.success).toBe(false);\n   694→    if (result.success) return;\n   695→    expect(result.error).toContain('permission denied');\n   696→  });\n   697→\n   698→  it('reports devError when developStory fails', () => {\n   699→    const cliACs = VALIDATION_ACS.filter(ac => ac.verificationMethod === 'cli');\n   700→    const targetAC = cliACs[0];\n   701→\n   702→    const state = emptyState();\n   703→    for (let i = 1; i <= 79; i++) {\n   704→      (state as { stories: Record<string, StoryState> }).stories[`val-${i}`] = defaultStory({ status: 'done' });\n   705→    }\n   706→    (state as { stories: Record<string, StoryState> }).stories[`val-${targetAC.id}`] = defaultStory({ status: 'backlog' });\n   707→\n   708→    mockGetSprintState.mockReturnValue({ success: true, data: state });\n   709→    // AC command fails\n   710→    mockExecSync.mockImplementation(() => {\n   711→      const err = new Error('fail');\n   712→      (err as unknown as Record<string, unknown>).stderr = 'error output';\n   713→      throw err;\n   714→    });\n   715→    // developStory fails\n   716→    mockDevelopStory.mockReturnValue({ success: false, error: 'dev agent unavailable' });\n   717→\n   718→    const result = runValidationCycle();\n   719→    expect(result.success).toBe(true);\n   720→    if (!result.success) return;\n   721→    expect(result.data.action).toBe('failed-routed-to-dev');\n   722→    expect(result.data.devError).toBe('dev agent unavailable');\n   723→  });\n   724→});\n   725→"}]},"parent_tool_use_id":"toolu_013E2UoeCvJBffp8yubjwF9Y","session_id":"b3a82007-2654-437f-8d26-bde42ea858b0","uuid":"da2fe1db-e32f-4b4b-9b25-0ba2e6faf3d4","timestamp":"2026-03-27T13:52:27.903Z"}
