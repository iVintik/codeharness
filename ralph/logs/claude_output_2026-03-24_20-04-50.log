ose"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":672,"cache_read_input_tokens":81062,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":672},"output_tokens":39,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"110312c9-09eb-45d4-bc39-1124b22b5753","uuid":"593e7fca-8cba-4f32-b2fc-fbf19156f26f"}
