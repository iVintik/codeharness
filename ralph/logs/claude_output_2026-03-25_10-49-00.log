{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QXaX95pcc9cVUfQv1pSrhC","type":"tool_result","content":"     1→/**\n     2→ * Observability analyzer module — runs static analysis and produces\n     3→ * a standardized gap report.\n     4→ *\n     5→ * Currently implements Semgrep integration but the AnalyzerResult\n     6→ * interface is tool-agnostic: any tool producing the same shape\n     7→ * can be used as a drop-in replacement.\n     8→ */\n     9→\n    10→import { execFileSync } from 'node:child_process';\n    11→import { join } from 'node:path';\n    12→import { ok, fail } from '../../types/result.js';\n    13→import type { Result } from '../../types/result.js';\n    14→import type {\n    15→  AnalyzerConfig,\n    16→  AnalyzerResult,\n    17→  AnalyzerSummary,\n    18→  ObservabilityGap,\n    19→  GapSeverity,\n    20→  SemgrepRawOutput,\n    21→} from './types.js';\n    22→\n    23→const DEFAULT_RULES_DIR = 'patches/observability/';\n    24→const ADDITIONAL_RULES_DIRS = ['patches/error-handling/'];\n    25→const DEFAULT_TIMEOUT = 60_000;\n    26→const FUNCTION_NO_LOG_RULE = 'function-no-debug-log';\n    27→const CATCH_WITHOUT_LOGGING_RULE = 'catch-without-logging';\n    28→const ERROR_PATH_NO_LOG_RULE = 'error-path-no-log';\n    29→\n    30→/**\n    31→ * Check if a gap's type (rule ID) matches a known rule name.\n    32→ * Semgrep produces path-prefixed check_ids like\n    33→ * \"tmp.test-ac5c.patches.observability.function-no-debug-log\",\n    34→ * so we use endsWith() rather than strict equality.\n    35→ */\n    36→function matchesRule(gapType: string, ruleName: string): boolean {\n    37→  return gapType === ruleName || gapType.endsWith(`.${ruleName}`);\n    38→}\n    39→\n    40→/**\n    41→ * Run observability analysis on a project directory.\n    42→ *\n    43→ * @param projectDir - Absolute path to the project root\n    44→ * @param config - Optional configuration overriding defaults\n    45→ * @returns Result containing the analysis report, or a skip result if the tool is not installed\n    46→ */\n    47→export function analyze(\n    48→  projectDir: string,\n    49→  config?: AnalyzerConfig,\n    50→): Result<AnalyzerResult> {\n    51→  if (!projectDir || typeof projectDir !== 'string') {\n    52→    return fail('projectDir is required and must be a non-empty string');\n    53→  }\n    54→\n    55→  const tool = config?.tool ?? 'semgrep';\n    56→\n    57→  if (tool !== 'semgrep') {\n    58→    return fail(`Unsupported analyzer tool: ${tool}`);\n    59→  }\n    60→\n    61→  if (!checkSemgrepInstalled()) {\n    62→    return ok({\n    63→      tool: 'semgrep',\n    64→      gaps: [],\n    65→      summary: {\n    66→        totalFunctions: 0,\n    67→        functionsWithLogs: 0,\n    68→        errorHandlersWithoutLogs: 0,\n    69→        coveragePercent: 0,\n    70→        levelDistribution: {},\n    71→      },\n    72→      skipped: true,\n    73→      skipReason: 'static analysis skipped -- install semgrep',\n    74→    });\n    75→  }\n    76→\n    77→  const rulesDir = config?.rulesDir ?? DEFAULT_RULES_DIR;\n    78→  const timeout = config?.timeout ?? DEFAULT_TIMEOUT;\n    79→  const fullRulesDir = join(projectDir, rulesDir);\n    80→\n    81→  // Collect additional rule directories (e.g., patches/error-handling/)\n    82→  const additionalDirs = (config?.additionalRulesDirs ?? ADDITIONAL_RULES_DIRS)\n    83→    .map(d => join(projectDir, d));\n    84→\n    85→  const rawResult = runSemgrep(projectDir, fullRulesDir, timeout, additionalDirs);\n    86→  if (!rawResult.success) {\n    87→    return fail(rawResult.error);\n    88→  }\n    89→\n    90→  const gaps = parseSemgrepOutput(rawResult.data);\n    91→  const summaryOpts = config?.totalFunctions != null\n    92→    ? { totalFunctions: config.totalFunctions }\n    93→    : undefined;\n    94→  const summary = computeSummary(gaps, summaryOpts);\n    95→\n    96→  return ok({\n    97→    tool: 'semgrep',\n    98→    gaps,\n    99→    summary,\n   100→  });\n   101→}\n   102→\n   103→/**\n   104→ * Check whether Semgrep is installed and available on PATH.\n   105→ */\n   106→export function checkSemgrepInstalled(): boolean {\n   107→  try {\n   108→    execFileSync('semgrep', ['--version'], {\n   109→      encoding: 'utf-8',\n   110→      timeout: 5_000,\n   111→      stdio: 'pipe',\n   112→    });\n   113→    return true;\n   114→  } catch {\n   115→    // IGNORE: grep check may fail if tool not available\n   116→    return false;\n   117→  }\n   118→}\n   119→\n   120→/**\n   121→ * Spawn Semgrep and capture its JSON output.\n   122→ */\n   123→export function runSemgrep(\n   124→  projectDir: string,\n   125→  rulesDir: string,\n   126→  timeout: number = DEFAULT_TIMEOUT,\n   127→  additionalRulesDirs: string[] = [],\n   128→): Result<SemgrepRawOutput> {\n   129→  try {\n   130→    // Build --config args: primary rules dir + any additional dirs that exist\n   131→    const configArgs = ['--config', rulesDir];\n   132→    for (const dir of additionalRulesDirs) {\n   133→      configArgs.push('--config', dir);\n   134→    }\n   135→\n   136→    const stdout = execFileSync(\n   137→      'semgrep',\n   138→      ['scan', ...configArgs, '--json', projectDir],\n   139→      { encoding: 'utf-8', timeout, stdio: ['pipe', 'pipe', 'pipe'] },\n   140→    );\n   141→    const parsed: unknown = JSON.parse(stdout);\n   142→    if (\n   143→      typeof parsed !== 'object' ||\n   144→      parsed === null ||\n   145→      !Array.isArray((parsed as Record<string, unknown>).results)\n   146→    ) {\n   147→      return fail('Semgrep scan returned invalid JSON: missing results array');\n   148→    }\n   149→    return ok(parsed as SemgrepRawOutput);\n   150→  } catch (error) {\n   151→    return fail(`Semgrep scan failed: ${String(error)}`);\n   152→  }\n   153→}\n   154→\n   155→/**\n   156→ * Parse Semgrep JSON results into tool-agnostic ObservabilityGap[].\n   157→ */\n   158→export function parseSemgrepOutput(raw: SemgrepRawOutput): ObservabilityGap[] {\n   159→  if (!raw.results || !Array.isArray(raw.results)) {\n   160→    return [];\n   161→  }\n   162→  return raw.results.map((r) => ({\n   163→    file: r.path,\n   164→    line: r.start.line,\n   165→    type: r.check_id,\n   166→    description: r.extra.message,\n   167→    severity: normalizeSeverity(r.extra.severity),\n   168→  }));\n   169→}\n   170→\n   171→/**\n   172→ * Compute summary statistics from gaps.\n   173→ *\n   174→ * Coverage formula: functionsWithLogs / totalFunctions * 100.\n   175→ *\n   176→ * Uses Option 3 from architecture notes: the `function-no-debug-log` rule\n   177→ * matches functions WITHOUT logging. Combined with an optional\n   178→ * `totalFunctions` override, this gives exact coverage.\n   179→ *\n   180→ * When totalFunctions is not provided, it equals the count of\n   181→ * function-no-debug-log matches (all detected functions lack logs).\n   182→ *\n   183→ * If totalFunctions is 0, coverage = 100 (no functions = no gaps).\n   184→ *\n   185→ * @param gaps - Parsed observability gaps\n   186→ * @param opts - Optional overrides for function counts (e.g., from external scan)\n   187→ */\n   188→export function computeSummary(\n   189→  gaps: ObservabilityGap[],\n   190→  opts?: { totalFunctions?: number },\n   191→): AnalyzerSummary {\n   192→  const functionsWithoutLogs = gaps.filter(\n   193→    (g) => matchesRule(g.type, FUNCTION_NO_LOG_RULE),\n   194→  ).length;\n   195→\n   196→  const errorHandlersWithoutLogs = gaps.filter(\n   197→    (g) =>\n   198→      matchesRule(g.type, CATCH_WITHOUT_LOGGING_RULE) ||\n   199→      matchesRule(g.type, ERROR_PATH_NO_LOG_RULE),\n   200→  ).length;\n   201→\n   202→  // If totalFunctions is provided externally (e.g., from a complementary\n   203→  // function-counting rule or AST scan), use it. Otherwise, we only know\n   204→  // about the functions that LACK logs.\n   205→  const totalFunctions = opts?.totalFunctions ?? functionsWithoutLogs;\n   206→  const functionsWithLogs = totalFunctions - functionsWithoutLogs;\n   207→  const coveragePercent =\n   208→    totalFunctions === 0\n   209→      ? 100\n   210→      : Math.round((functionsWithLogs / totalFunctions) * 100 * 100) / 100;\n   211→\n   212→  // Build level distribution from gap severities\n   213→  const levelDistribution: Record<string, number> = {};\n   214→  for (const gap of gaps) {\n   215→    levelDistribution[gap.severity] =\n   216→      (levelDistribution[gap.severity] ?? 0) + 1;\n   217→  }\n   218→\n   219→  return {\n   220→    totalFunctions,\n   221→    functionsWithLogs,\n   222→    errorHandlersWithoutLogs,\n   223→    coveragePercent,\n   224→    levelDistribution,\n   225→  };\n   226→}\n   227→\n   228→/** Normalize Semgrep severity string to our GapSeverity union */\n   229→function normalizeSeverity(severity: string): GapSeverity {\n   230→  const lower = severity.toLowerCase();\n   231→  if (lower === 'error') return 'error';\n   232→  if (lower === 'warning') return 'warning';\n   233→  return 'info';\n   234→}\n   235→"}]},"parent_tool_use_id":"toolu_01RaXV75NMTprbvd4KMPDvjb","session_id":"3fcb2b1c-e710-401b-91ab-b64a3e9a3996","uuid":"ba9f51cb-d248-4d73-9184-3445e04e0a97","timestamp":"2026-03-25T06:58:31.862Z"}
