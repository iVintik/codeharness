{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01D247RKwaBDJqXoVPJ7DEiH","type":"tool_result","content":"     1→/**\n     2→ * Sprint state — read/write unified sprint-state.json with atomic writes.\n     3→ */\n     4→\n     5→import { readFileSync, writeFileSync, renameSync, existsSync } from 'node:fs';\n     6→import { join } from 'node:path';\n     7→import { ok, fail } from '../../types/result.js';\n     8→import type { Result } from '../../types/result.js';\n     9→import type { SprintState, StoryStatus, StoryState } from '../../types/state.js';\n    10→import type { StoryDetail, RunProgressUpdate } from './types.js';\n    11→import { migrateFromOldFormat } from './migration.js';\n    12→\n    13→/** Resolve project root (directory containing package.json) */\n    14→function projectRoot(): string {\n    15→  return process.cwd();\n    16→}\n    17→\n    18→/** Path to the sprint state file */\n    19→export function statePath(): string {\n    20→  return join(projectRoot(), 'sprint-state.json');\n    21→}\n    22→\n    23→/** Path to the temporary file used for atomic writes */\n    24→function tmpPath(): string {\n    25→  return join(projectRoot(), '.sprint-state.json.tmp');\n    26→}\n    27→\n    28→/** Return an empty default SprintState */\n    29→export function defaultState(): SprintState {\n    30→  return {\n    31→    version: 1,\n    32→    sprint: {\n    33→      total: 0,\n    34→      done: 0,\n    35→      failed: 0,\n    36→      blocked: 0,\n    37→      inProgress: null,\n    38→    },\n    39→    stories: {},\n    40→    run: {\n    41→      active: false,\n    42→      startedAt: null,\n    43→      iteration: 0,\n    44→      cost: 0,\n    45→      completed: [],\n    46→      failed: [],\n    47→      currentStory: null,\n    48→      currentPhase: null,\n    49→      lastAction: null,\n    50→      acProgress: null,\n    51→    },\n    52→    actionItems: [],\n    53→  };\n    54→}\n    55→\n    56→/** Return a default StoryState */\n    57→function defaultStoryState(): StoryState {\n    58→  return {\n    59→    status: 'backlog',\n    60→    attempts: 0,\n    61→    lastAttempt: null,\n    62→    lastError: null,\n    63→    proofPath: null,\n    64→    acResults: null,\n    65→  };\n    66→}\n    67→\n    68→/**\n    69→ * Write state to disk atomically: write to tmp, then rename.\n    70→ */\n    71→export function writeStateAtomic(state: SprintState): Result<void> {\n    72→  try {\n    73→    const data = JSON.stringify(state, null, 2) + '\\n';\n    74→    const tmp = tmpPath();\n    75→    const final = statePath();\n    76→    writeFileSync(tmp, data, 'utf-8');\n    77→    renameSync(tmp, final);\n    78→    return ok(undefined);\n    79→  } catch (err: unknown) {\n    80→    const msg = err instanceof Error ? err.message : String(err);\n    81→    return fail(`Failed to write sprint state: ${msg}`);\n    82→  }\n    83→}\n    84→\n    85→/**\n    86→ * Read and parse sprint-state.json.\n    87→ * If the file does not exist, attempt migration from old files.\n    88→ * If no old files exist either, return defaultState().\n    89→ */\n    90→export function getSprintState(): Result<SprintState> {\n    91→  const fp = statePath();\n    92→\n    93→  if (existsSync(fp)) {\n    94→    try {\n    95→      const raw = readFileSync(fp, 'utf-8');\n    96→      const parsed = JSON.parse(raw) as Record<string, unknown>;\n    97→      // Merge with defaults to handle old state files missing new fields\n    98→      const defaults = defaultState();\n    99→      const run = parsed.run as Record<string, unknown> | undefined;\n   100→      const sprint = parsed.sprint as Record<string, unknown> | undefined;\n   101→      const state: SprintState = {\n   102→        ...(parsed as unknown as SprintState),\n   103→        sprint: {\n   104→          ...defaults.sprint,\n   105→          ...(sprint as SprintState['sprint']),\n   106→        },\n   107→        run: {\n   108→          ...defaults.run,\n   109→          ...(run as SprintState['run']),\n   110→        },\n   111→      };\n   112→      return ok(state);\n   113→    } catch (err: unknown) {\n   114→      const msg = err instanceof Error ? err.message : String(err);\n   115→      return fail(`Failed to read sprint state: ${msg}`);\n   116→    }\n   117→  }\n   118→\n   119→  // No sprint-state.json — try migration\n   120→  const migrationResult = migrateFromOldFormat();\n   121→  if (migrationResult.success) {\n   122→    return migrationResult;\n   123→  }\n   124→\n   125→  // Migration found nothing or failed — return default\n   126→  return ok(defaultState());\n   127→}\n   128→\n   129→/** Recompute sprint summary counts from story data */\n   130→export function computeSprintCounts(\n   131→  stories: Record<string, StoryState>,\n   132→): SprintState['sprint'] {\n   133→  let total = 0;\n   134→  let done = 0;\n   135→  let failed = 0;\n   136→  let blocked = 0;\n   137→  let inProgress: string | null = null;\n   138→\n   139→  for (const [key, story] of Object.entries(stories)) {\n   140→    total++;\n   141→    if (story.status === 'done') done++;\n   142→    else if (story.status === 'failed') failed++;\n   143→    else if (story.status === 'blocked') blocked++;\n   144→    else if (story.status === 'in-progress') inProgress = key;\n   145→  }\n   146→\n   147→  return { total, done, failed, blocked, inProgress };\n   148→}\n   149→\n   150→/**\n   151→ * Update a single story's status in sprint-state.json.\n   152→ * Reads current state, merges update, writes atomically.\n   153→ */\n   154→export function updateStoryStatus(\n   155→  key: string,\n   156→  status: StoryStatus,\n   157→  detail?: StoryDetail,\n   158→): Result<void> {\n   159→  const stateResult = getSprintState();\n   160→  if (!stateResult.success) {\n   161→    return fail(stateResult.error);\n   162→  }\n   163→\n   164→  const current = stateResult.data;\n   165→  const existingStory = current.stories[key] ?? defaultStoryState();\n   166→\n   167→  const isNewAttempt = status === 'in-progress';\n   168→\n   169→  const updatedStory: StoryState = {\n   170→    ...existingStory,\n   171→    status,\n   172→    attempts: isNewAttempt\n   173→      ? existingStory.attempts + 1\n   174→      : existingStory.attempts,\n   175→    lastAttempt: isNewAttempt\n   176→      ? new Date().toISOString()\n   177→      : existingStory.lastAttempt,\n   178→    lastError: detail?.error ?? existingStory.lastError,\n   179→    proofPath: detail?.proofPath ?? existingStory.proofPath,\n   180→    acResults: existingStory.acResults,\n   181→  };\n   182→\n   183→  const updatedStories = { ...current.stories, [key]: updatedStory };\n   184→  const updatedSprint = computeSprintCounts(updatedStories);\n   185→\n   186→  const updatedState: SprintState = {\n   187→    ...current,\n   188→    sprint: updatedSprint,\n   189→    stories: updatedStories,\n   190→  };\n   191→\n   192→  return writeStateAtomic(updatedState);\n   193→}\n   194→\n   195→/**\n   196→ * Update live run progress fields in sprint-state.json.\n   197→ * Only provided fields are updated; omitted fields retain their current values.\n   198→ */\n   199→export function updateRunProgress(update: RunProgressUpdate): Result<void> {\n   200→  const stateResult = getSprintState();\n   201→  if (!stateResult.success) {\n   202→    return fail(stateResult.error);\n   203→  }\n   204→\n   205→  const current = stateResult.data;\n   206→  const updatedRun = {\n   207→    ...current.run,\n   208→    ...(update.currentStory !== undefined && { currentStory: update.currentStory }),\n   209→    ...(update.currentPhase !== undefined && { currentPhase: update.currentPhase }),\n   210→    ...(update.lastAction !== undefined && { lastAction: update.lastAction }),\n   211→    ...(update.acProgress !== undefined && { acProgress: update.acProgress }),\n   212→  };\n   213→\n   214→  const updatedState: SprintState = {\n   215→    ...current,\n   216→    run: updatedRun,\n   217→  };\n   218→\n   219→  return writeStateAtomic(updatedState);\n   220→}\n   221→\n   222→/**\n   223→ * Clear all live run progress fields to null.\n   224→ * Called when a story completes or fails.\n   225→ */\n   226→export function clearRunProgress(): Result<void> {\n   227→  const stateResult = getSprintState();\n   228→  if (!stateResult.success) {\n   229→    return fail(stateResult.error);\n   230→  }\n   231→\n   232→  const current = stateResult.data;\n   233→  const updatedState: SprintState = {\n   234→    ...current,\n   235→    run: {\n   236→      ...current.run,\n   237→      currentStory: null,\n   238→      currentPhase: null,\n   239→      lastAction: null,\n   240→      acProgress: null,\n   241→    },\n   242→  };\n   243→\n   244→  return writeStateAtomic(updatedState);\n   245→}\n   246→"}]},"parent_tool_use_id":"toolu_01VDEDGGGLstVGgA3jxfk8Nj","session_id":"6707468c-554d-4568-9ea5-0d04d4a85f59","uuid":"70e8d6ba-ed1e-419e-977f-68a03861e8e8","timestamp":"2026-03-24T10:17:19.000Z"}
