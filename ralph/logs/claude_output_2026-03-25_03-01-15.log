{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JwWnLVWSX4ecqUmHEru6nS","type":"tool_result","content":"     1→/**\n     2→ * Observability backend interface from architecture decision 4.\n     3→ * Backend-agnostic types usable by both Victoria and OpenSearch implementations.\n     4→ */\n     5→\n     6→import type { Result } from './result.js';\n     7→\n     8→/** Supported observability backend types */\n     9→export type ObservabilityBackendType = 'victoria' | 'opensearch';\n    10→\n    11→/** Time range for queries */\n    12→export interface TimeRange {\n    13→  readonly start: string;\n    14→  readonly end: string;\n    15→}\n    16→\n    17→/** Parameters for querying logs */\n    18→export interface LogQuery {\n    19→  readonly query: string;\n    20→  readonly timeRange: TimeRange;\n    21→  readonly limit?: number;\n    22→  readonly offset?: number;\n    23→  readonly filters?: Record<string, string>;\n    24→}\n    25→\n    26→/** Parameters for querying metrics */\n    27→export interface MetricQuery {\n    28→  readonly query: string;\n    29→  readonly timeRange: TimeRange;\n    30→  readonly step?: string;\n    31→  readonly filters?: Record<string, string>;\n    32→}\n    33→\n    34→/** Parameters for querying traces */\n    35→export interface TraceQuery {\n    36→  readonly traceId?: string;\n    37→  readonly serviceName?: string;\n    38→  readonly operationName?: string;\n    39→  readonly timeRange: TimeRange;\n    40→  readonly limit?: number;\n    41→  readonly filters?: Record<string, string>;\n    42→}\n    43→\n    44→/** A single log entry returned from a query */\n    45→export interface LogEntry {\n    46→  readonly timestamp: string;\n    47→  readonly message: string;\n    48→  readonly level: string;\n    49→  readonly labels: Record<string, string>;\n    50→}\n    51→\n    52→/** Result of a log query */\n    53→export interface LogResult {\n    54→  readonly entries: LogEntry[];\n    55→  readonly total: number;\n    56→}\n    57→\n    58→/** A single data point in a metric time series */\n    59→export interface MetricDataPoint {\n    60→  readonly timestamp: string;\n    61→  readonly value: number;\n    62→}\n    63→\n    64→/** A single metric time series */\n    65→export interface MetricSeries {\n    66→  readonly labels: Record<string, string>;\n    67→  readonly dataPoints: MetricDataPoint[];\n    68→}\n    69→\n    70→/** Result of a metric query */\n    71→export interface MetricResult {\n    72→  readonly series: MetricSeries[];\n    73→}\n    74→\n    75→/** A single span in a trace */\n    76→export interface TraceSpan {\n    77→  readonly traceId: string;\n    78→  readonly spanId: string;\n    79→  readonly parentSpanId: string | null;\n    80→  readonly operationName: string;\n    81→  readonly serviceName: string;\n    82→  readonly startTime: string;\n    83→  readonly duration: number;\n    84→  readonly tags: Record<string, string>;\n    85→}\n    86→\n    87→/** Result of a trace query */\n    88→export interface TraceResult {\n    89→  readonly spans: TraceSpan[];\n    90→}\n    91→\n    92→/** Health status of an observability backend */\n    93→export interface HealthStatus {\n    94→  readonly healthy: boolean;\n    95→  readonly message: string;\n    96→  readonly latencyMs: number;\n    97→}\n    98→\n    99→/** Backend-agnostic observability interface */\n   100→export interface ObservabilityBackend {\n   101→  readonly type: ObservabilityBackendType;\n   102→  queryLogs(params: LogQuery): Promise<Result<LogResult>>;\n   103→  queryMetrics(params: MetricQuery): Promise<Result<MetricResult>>;\n   104→  queryTraces(params: TraceQuery): Promise<Result<TraceResult>>;\n   105→  healthCheck(): Promise<Result<HealthStatus>>;\n   106→}\n   107→"}]},"parent_tool_use_id":"toolu_01GEPRaZucE7UgpGJiPm4ARu","session_id":"790cd04c-5c91-45bb-998d-78a56b65af9a","uuid":"397f9f52-a0b4-4cfb-8867-6e9bf0a35678","timestamp":"2026-03-24T23:06:35.484Z"}
