{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DNhPjg8Cu8tzLQsoSGTcSf","type":"tool_result","content":"   440→export interface PerFileCoverageResult {\n   441→  floor: number;\n   442→  violations: FileCoverageEntry[];\n   443→  totalFiles: number;\n   444→}\n   445→\n   446→/**\n   447→ * Checks per-file coverage against a minimum floor.\n   448→ * Reads coverage-summary.json and returns any files below the threshold.\n   449→ */\n   450→export function checkPerFileCoverage(floor: number, dir?: string): PerFileCoverageResult {\n   451→  const baseDir = dir ?? process.cwd();\n   452→  const reportPath = findCoverageSummary(baseDir);\n   453→\n   454→  if (!reportPath) {\n   455→    return { floor, violations: [], totalFiles: 0 };\n   456→  }\n   457→\n   458→  let report: Record<string, { statements?: { pct?: number }; branches?: { pct?: number }; functions?: { pct?: number }; lines?: { pct?: number } }>;\n   459→  try {\n   460→    report = JSON.parse(readFileSync(reportPath, 'utf-8')) as typeof report;\n   461→  } catch {\n   462→    warn('Failed to parse coverage-summary.json');\n   463→    return { floor, violations: [], totalFiles: 0 };\n   464→  }\n   465→\n   466→  const violations: FileCoverageEntry[] = [];\n   467→  let totalFiles = 0;\n   468→\n   469→  for (const [key, data] of Object.entries(report)) {\n   470→    if (key === 'total') continue;\n   471→    totalFiles++;\n   472→\n   473→    const stmts = data.statements?.pct ?? 0;\n   474→    const branches = data.branches?.pct ?? 0;\n   475→    const funcs = data.functions?.pct ?? 0;\n   476→    const lines = data.lines?.pct ?? 0;\n   477→\n   478→    if (stmts < floor) {\n   479→      // Extract relative path from absolute\n   480→      const relative = key.startsWith(baseDir)\n   481→        ? key.slice(baseDir.length + 1)\n   482→        : key;\n   483→\n   484→      violations.push({\n   485→        file: relative,\n   486→        statements: stmts,\n   487→        branches,\n   488→        functions: funcs,\n   489→        lines,\n   490→      });\n   491→    }\n   492→  }\n   493→\n   494→  // Sort worst first\n   495→  violations.sort((a, b) => a.statements - b.statements);\n   496→\n   497→  return { floor, violations, totalFiles };\n   498→}\n   499→"}]},"parent_tool_use_id":"toolu_01XRogrWXmkjb8B4r8U8sFo4","session_id":"64c1e9b9-a641-40be-ae67-07aee0c47965","uuid":"1770d4dc-6afd-4a9f-a685-fca991f8d761","timestamp":"2026-03-20T08:16:49.385Z"}
