{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017unnEz4LW1FsQosi4x7adR","type":"tool_result","content":"1\t/**\n2\t * AgentDriver abstraction types.\n3\t *\n4\t * Defines the contract that all agent drivers (Claude Code, Codex, OpenCode)\n5\t * must implement. See architecture-multi-framework.md Decision 1.\n6\t */\n7\t\n8\timport type { Readable } from 'node:stream';\n9\timport type { StreamEvent } from './stream-parser.js';\n10\t\n11\t// --- New Types (Epic 10) ---\n12\t\n13\t/**\n14\t * Health status returned by a driver's healthCheck().\n15\t */\n16\texport interface DriverHealth {\n17\t  readonly available: boolean;\n18\t  readonly authenticated: boolean;\n19\t  readonly version: string | null;\n20\t  readonly error?: string;\n21\t}\n22\t\n23\t/**\n24\t * Capability flags for a driver. Extensible — new boolean fields\n25\t * can be added without breaking existing drivers.\n26\t */\n27\texport interface DriverCapabilities {\n28\t  readonly supportsPlugins: boolean;\n29\t  readonly supportsStreaming: boolean;\n30\t  readonly costReporting: boolean;\n31\t  readonly costTier: number;\n32\t}\n33\t\n34\t/**\n35\t * A capability conflict or routing hint warning.\n36\t * Pure data — no side effects. Used by checkCapabilityConflicts().\n37\t */\n38\texport interface CapabilityWarning {\n39\t  readonly taskName: string;\n40\t  readonly driverName: string;\n41\t  readonly capability: string;\n42\t  readonly message: string;\n43\t}\n44\t\n45\t/**\n46\t * Error classification categories for driver errors.\n47\t * Drivers must NOT invent new categories.\n48\t *\n49\t * Classification priority:\n50\t * 1. HTTP 429 or \"rate limit\" in message -> RATE_LIMIT\n51\t * 2. ECONNREFUSED, ETIMEDOUT, ENOTFOUND -> NETWORK\n52\t * 3. HTTP 401/403 or \"unauthorized\"/\"forbidden\" -> AUTH\n53\t * 4. Process killed by timeout -> TIMEOUT\n54\t * 5. Everything else -> UNKNOWN\n55\t */\n56\texport type ErrorCategory = 'RATE_LIMIT' | 'NETWORK' | 'AUTH' | 'TIMEOUT' | 'UNKNOWN';\n57\t\n58\t/**\n59\t * Test results summary for an output contract.\n60\t */\n61\texport interface TestResults {\n62\t  readonly passed: number;\n63\t  readonly failed: number;\n64\t  readonly coverage: number | null;\n65\t}\n66\t\n67\t/**\n68\t * Acceptance criteria status entry.\n69\t */\n70\texport interface ACStatus {\n71\t  readonly id: string;\n72\t  readonly description: string;\n73\t  readonly status: string;\n74\t}\n75\t\n76\t/**\n77\t * Structured output contract produced by a dispatch.\n78\t */\n79\texport interface OutputContract {\n80\t  readonly version: number;\n81\t  readonly taskName: string;\n82\t  readonly storyId: string;\n83\t  readonly driver: string;\n84\t  readonly model: string;\n85\t  readonly timestamp: string;\n86\t  readonly cost_usd: number | null;\n87\t  readonly duration_ms: number;\n88\t  readonly changedFiles: readonly string[];\n89\t  readonly testResults: TestResults | null;\n90\t  readonly output: string;\n91\t  readonly acceptanceCriteria: readonly ACStatus[];\n92\t}\n93\t\n94\t/**\n95\t * Options for dispatching a task to a driver.\n96\t */\n97\texport interface DispatchOpts {\n98\t  readonly prompt: string;\n99\t  readonly model: string;\n100\t  readonly cwd: string;\n101\t  readonly sourceAccess: boolean;\n102\t  readonly plugins?: readonly string[];\n103\t  readonly timeout?: number;\n104\t  readonly sessionId?: string;\n105\t  readonly appendSystemPrompt?: string;\n106\t  readonly outputContract?: OutputContract;\n107\t}\n108\t\n109\t/**\n110\t * The core agent driver interface (v2 — Epic 10).\n111\t * Each driver knows how to check health, dispatch tasks, and report cost.\n112\t * `dispatch()` returns `AsyncIterable<StreamEvent>` enabling both in-process\n113\t * (Agent SDK yields) and CLI-wrapped (stdout parsed to events) drivers.\n114\t */\n115\texport interface AgentDriver {\n116\t  readonly name: string;\n117\t  readonly defaultModel: string;\n118\t  readonly capabilities: DriverCapabilities;\n119\t  healthCheck(): Promise<DriverHealth>;\n120\t  dispatch(opts: DispatchOpts): AsyncIterable<StreamEvent>;\n121\t  getLastCost(): number | null;\n122\t}\n123\t\n124\t// --- Deprecated Types (backward compatibility until story 10-3) ---\n125\t\n126\t/**\n127\t * Options for spawning an agent process.\n128\t * @deprecated Use `DispatchOpts` instead. Will be removed after story 10-3.\n129\t */\n130\texport interface SpawnOpts {\n131\t  storyKey: string;\n132\t  prompt: string;\n133\t  workDir: string;\n134\t  timeout: number;\n135\t  env?: Record<string, string>;\n136\t}\n137\t\n138\t/**\n139\t * Abstraction over a running agent process.\n140\t * Wraps Node.js ChildProcess but allows non-process-based drivers\n141\t * (direct API calls, WebSocket connections) to implement the same interface.\n142\t * @deprecated Use `AsyncIterable<StreamEvent>` from `dispatch()` instead. Will be removed after story 10-3.\n143\t */\n144\texport interface AgentProcess {\n145\t  stdout: Readable;\n146\t  stderr: Readable;\n147\t  on(event: 'close', handler: (code: number) => void): void;\n148\t  on(event: 'error', handler: (err: Error) => void): void;\n149\t  kill(signal?: string): void;\n150\t}\n151\t\n152\t/**\n153\t * Discriminated union of events emitted by an agent driver.\n154\t * The `parseOutput()` method converts raw agent output lines into these typed events.\n155\t * @deprecated Use `StreamEvent` from `stream-parser.ts` instead. Will be removed after story 10-3.\n156\t */\n157\texport type AgentEvent =\n158\t  | { type: 'tool-start'; name: string }\n159\t  | { type: 'tool-input'; partial: string }\n160\t  | { type: 'tool-complete'; name?: string; args?: string }\n161\t  | { type: 'text'; text: string }\n162\t  | { type: 'story-complete'; key: string; details: string }\n163\t  | { type: 'story-failed'; key: string; reason: string }\n164\t  | { type: 'iteration'; count: number }\n165\t  | { type: 'retry'; attempt: number; delay: number }\n166\t  | { type: 'result'; cost: number; sessionId: string };\n167\t"}]},"parent_tool_use_id":"toolu_01E368mBox6AGS9E4aPFSS48","session_id":"8a461711-53e2-475a-88dd-c7013f6080c5","uuid":"e0e10d94-eeb7-4cac-be46-3487e0411bfe","timestamp":"2026-04-03T17:12:54.694Z"}
