{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RLNz63PvFcDt67QjRvX3Wv","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { render } from 'ink-testing-library';\n3\timport React from 'react';\n4\timport { SummaryBar } from '../ink-summary-bar.js';\n5\timport type { SummaryBarProps, MergingEpicInfo, CompletedLaneInfo } from '../ink-summary-bar.js';\n6\t\n7\tfunction makeProps(overrides?: Partial<SummaryBarProps>): SummaryBarProps {\n8\t  return {\n9\t    doneStories: [],\n10\t    mergingEpic: null,\n11\t    pendingEpics: [],\n12\t    ...overrides,\n13\t  };\n14\t}\n15\t\n16\tdescribe('SummaryBar component', () => {\n17\t  it('exports SummaryBar as a function component', () => {\n18\t    expect(SummaryBar).toBeDefined();\n19\t    expect(typeof SummaryBar).toBe('function');\n20\t  });\n21\t\n22\t  it('renders done stories with checkmark symbols', () => {\n23\t    const { lastFrame } = render(\n24\t      <SummaryBar {...makeProps({ doneStories: ['10-1', '10-2', '10-3'] })} />\n25\t    );\n26\t    const frame = lastFrame()!;\n27\t    expect(frame).toContain('Done:');\n28\t    expect(frame).toContain('10-1 \\u2713');\n29\t    expect(frame).toContain('10-2 \\u2713');\n30\t    expect(frame).toContain('10-3 \\u2713');\n31\t  });\n32\t\n33\t  it('renders \"Merging: \\u2014\" when no merge active', () => {\n34\t    const { lastFrame } = render(\n35\t      <SummaryBar {...makeProps({ mergingEpic: null })} />\n36\t    );\n37\t    const frame = lastFrame()!;\n38\t    expect(frame).toContain('Merging:');\n39\t    expect(frame).toContain('\\u2014');\n40\t  });\n41\t\n42\t  it('renders merging epic with spinner when in-progress', () => {\n43\t    const mergingEpic: MergingEpicInfo = {\n44\t      epicId: 'epic-14',\n45\t      status: 'in-progress',\n46\t    };\n47\t    const { lastFrame } = render(\n48\t      <SummaryBar {...makeProps({ mergingEpic })} />\n49\t    );\n50\t    const frame = lastFrame()!;\n51\t    expect(frame).toContain('Merging:');\n52\t    expect(frame).toContain('epic-14');\n53\t    expect(frame).toContain('\\u2192 main');\n54\t    expect(frame).toContain('\\u25CC'); // spinner indicator\n55\t  });\n56\t\n57\t  it('renders resolving merge with conflict count', () => {\n58\t    const mergingEpic: MergingEpicInfo = {\n59\t      epicId: 'epic-11',\n60\t      status: 'resolving',\n61\t      conflictCount: 1,\n62\t    };\n63\t    const { lastFrame } = render(\n64\t      <SummaryBar {...makeProps({ mergingEpic })} />\n65\t    );\n66\t    const frame = lastFrame()!;\n67\t    expect(frame).toContain('epic-11');\n68\t    expect(frame).toContain('\\u2192 main');\n69\t    expect(frame).toContain('resolving 1 conflict');\n70\t    expect(frame).toContain('\\u25CC');\n71\t  });\n72\t\n73\t  it('renders resolving merge with plural conflicts', () => {\n74\t    const mergingEpic: MergingEpicInfo = {\n75\t      epicId: 'epic-11',\n76\t      status: 'resolving',\n77\t      conflictCount: 3,\n78\t    };\n79\t    const { lastFrame } = render(\n80\t      <SummaryBar {...makeProps({ mergingEpic })} />\n81\t    );\n82\t    const frame = lastFrame()!;\n83\t    expect(frame).toContain('resolving 3 conflicts');\n84\t  });\n85\t\n86\t  it('renders pending epics list', () => {\n87\t    const { lastFrame } = render(\n88\t      <SummaryBar {...makeProps({ pendingEpics: ['epic-12', 'epic-13'] })} />\n89\t    );\n90\t    const frame = lastFrame()!;\n91\t    expect(frame).toContain('Pending:');\n92\t    expect(frame).toContain('epic-12, epic-13');\n93\t  });\n94\t\n95\t  it('renders lane completion line', () => {\n96\t    const completedLanes: CompletedLaneInfo[] = [{\n97\t      laneIndex: 2,\n98\t      epicId: '14',\n99\t      storyCount: 3,\n100\t      cost: 4.80,\n101\t      elapsed: '22m',\n102\t    }];\n103\t    const { lastFrame } = render(\n104\t      <SummaryBar {...makeProps({ completedLanes })} />\n105\t    );\n106\t    const frame = lastFrame()!;\n107\t    expect(frame).toContain('[OK] Lane 2: Epic 14 complete (3 stories, $4.80, 22m)');\n108\t  });\n109\t\n110\t  it('handles empty done stories with em-dash fallback', () => {\n111\t    const { lastFrame } = render(\n112\t      <SummaryBar {...makeProps({ doneStories: [] })} />\n113\t    );\n114\t    const frame = lastFrame()!;\n115\t    expect(frame).toContain('Done: \\u2014');\n116\t  });\n117\t\n118\t  it('handles empty pending epics with em-dash fallback', () => {\n119\t    const { lastFrame } = render(\n120\t      <SummaryBar {...makeProps({ pendingEpics: [] })} />\n121\t    );\n122\t    const frame = lastFrame()!;\n123\t    expect(frame).toContain('Pending: \\u2014');\n124\t  });\n125\t\n126\t  it('exports correct types', () => {\n127\t    // Type-level check: ensure interfaces are importable and usable\n128\t    const props: SummaryBarProps = {\n129\t      doneStories: ['10-1'],\n130\t      mergingEpic: { epicId: 'epic-14', status: 'in-progress' },\n131\t      pendingEpics: ['epic-12'],\n132\t      completedLanes: [{ laneIndex: 1, epicId: '10', storyCount: 3, cost: 4.80, elapsed: '22m' }],\n133\t    };\n134\t    expect(props.doneStories).toHaveLength(1);\n135\t    expect(props.mergingEpic).not.toBeNull();\n136\t    expect(props.pendingEpics).toHaveLength(1);\n137\t    expect(props.completedLanes).toHaveLength(1);\n138\t  });\n139\t\n140\t  it('renders complete merge status with green checkmark', () => {\n141\t    const mergingEpic: MergingEpicInfo = {\n142\t      epicId: 'epic-14',\n143\t      status: 'complete',\n144\t    };\n145\t    const { lastFrame } = render(\n146\t      <SummaryBar {...makeProps({ mergingEpic })} />\n147\t    );\n148\t    const frame = lastFrame()!;\n149\t    expect(frame).toContain('epic-14');\n150\t    expect(frame).toContain('\\u2192 main');\n151\t    expect(frame).toContain('\\u2713');\n152\t  });\n153\t\n154\t  it('renders full summary with all sections populated', () => {\n155\t    const { lastFrame } = render(\n156\t      <SummaryBar {...makeProps({\n157\t        doneStories: ['10-1', '10-2', '14-1'],\n158\t        mergingEpic: { epicId: 'epic-14', status: 'in-progress' },\n159\t        pendingEpics: ['epic-11', 'epic-12'],\n160\t      })} />\n161\t    );\n162\t    const frame = lastFrame()!;\n163\t    // All three sections visible with pipe separators\n164\t    expect(frame).toContain('Done:');\n165\t    expect(frame).toContain('\\u2502');\n166\t    expect(frame).toContain('Merging:');\n167\t    expect(frame).toContain('Pending:');\n168\t  });\n169\t\n170\t  it('renders multiple lane completion lines', () => {\n171\t    const completedLanes: CompletedLaneInfo[] = [\n172\t      { laneIndex: 1, epicId: '10', storyCount: 3, cost: 4.80, elapsed: '22m' },\n173\t      { laneIndex: 2, epicId: '14', storyCount: 2, cost: 3.10, elapsed: '15m' },\n174\t    ];\n175\t    const { lastFrame } = render(\n176\t      <SummaryBar {...makeProps({ completedLanes })} />\n177\t    );\n178\t    const frame = lastFrame()!;\n179\t    expect(frame).toContain('[OK] Lane 1: Epic 10 complete');\n180\t    expect(frame).toContain('[OK] Lane 2: Epic 14 complete');\n181\t  });\n182\t\n183\t  it('renders $0.00 for zero cost in lane completion', () => {\n184\t    const completedLanes: CompletedLaneInfo[] = [{\n185\t      laneIndex: 1,\n186\t      epicId: '10',\n187\t      storyCount: 1,\n188\t      cost: 0,\n189\t      elapsed: '1m',\n190\t    }];\n191\t    const { lastFrame } = render(\n192\t      <SummaryBar {...makeProps({ completedLanes })} />\n193\t    );\n194\t    const frame = lastFrame()!;\n195\t    expect(frame).toContain('$0.00');\n196\t  });\n197\t});\n198\t"}]},"parent_tool_use_id":"toolu_01TzQwpEV7uekTzzh7pB5DWd","session_id":"7e3ded59-6184-4f8b-8f55-ba5e63dae51f","uuid":"2895405e-164e-4e71-9eff-876ab5dd7260","timestamp":"2026-04-04T02:49:39.920Z"}
