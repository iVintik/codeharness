{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PTKJGCQBVgLEFEdPiJZHMX","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import {\n     3→  formatElapsed,\n     4→  mapSprintStatus,\n     5→  mapSprintStatuses,\n     6→  countStories,\n     7→} from '../run-helpers.js';\n     8→import {\n     9→  parseRalphMessage,\n    10→  parseIterationMessage,\n    11→  buildSpawnArgs,\n    12→} from '../agents/ralph.js';\n    13→\n    14→describe('formatElapsed', () => {\n    15→  it('formats 0ms as \"0m\"', () => {\n    16→    expect(formatElapsed(0)).toBe('0m');\n    17→  });\n    18→\n    19→  it('formats sub-minute as \"0m\"', () => {\n    20→    expect(formatElapsed(30_000)).toBe('0m');\n    21→  });\n    22→\n    23→  it('formats 1 minute', () => {\n    24→    expect(formatElapsed(60_000)).toBe('1m');\n    25→  });\n    26→\n    27→  it('formats 47 minutes', () => {\n    28→    expect(formatElapsed(47 * 60_000)).toBe('47m');\n    29→  });\n    30→\n    31→  it('formats 60 minutes as \"1h0m\"', () => {\n    32→    expect(formatElapsed(60 * 60_000)).toBe('1h0m');\n    33→  });\n    34→\n    35→  it('formats 2h14m', () => {\n    36→    expect(formatElapsed((2 * 60 + 14) * 60_000)).toBe('2h14m');\n    37→  });\n    38→\n    39→  it('handles negative values as \"0m\"', () => {\n    40→    expect(formatElapsed(-5000)).toBe('0m');\n    41→  });\n    42→\n    43→  it('truncates fractional minutes (rounds down)', () => {\n    44→    // 1m 59s → still 1m\n    45→    expect(formatElapsed(119_000)).toBe('1m');\n    46→  });\n    47→});\n    48→\n    49→describe('mapSprintStatus', () => {\n    50→  it('maps done to done', () => {"}]},"parent_tool_use_id":"toolu_014LQotcmHZgHHY5F784aj9H","session_id":"110312c9-09eb-45d4-bc39-1124b22b5753","uuid":"1860845f-a968-433c-9e84-005c4c421c32","timestamp":"2026-03-24T16:15:32.760Z"}
