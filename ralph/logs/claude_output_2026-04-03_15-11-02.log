{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UdJSxek5bxfEuvRigsnTeP","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { render } from 'ink-testing-library';\n3\timport React from 'react';\n4\timport { WorkflowGraph } from '../ink-workflow.js';\n5\timport type { TaskNodeState } from '../ink-components.js';\n6\timport type { FlowStep } from '../workflow-parser.js';\n7\t\n8\tdescribe('WorkflowGraph component', () => {\n9\t  it('renders sequential flow as task1 → task2 → task3', () => {\n10\t    const flow: FlowStep[] = ['create-story', 'implement', 'verify'];\n11\t    const taskStates: Record<string, TaskNodeState> = {\n12\t      'create-story': 'done',\n13\t      'implement': 'active',\n14\t      'verify': 'pending',\n15\t    };\n16\t    const { lastFrame } = render(\n17\t      <WorkflowGraph flow={flow} currentTask=\"implement\" taskStates={taskStates} />\n18\t    );\n19\t    const frame = lastFrame()!;\n20\t    expect(frame).toContain('create-story');\n21\t    expect(frame).toContain('→');\n22\t    expect(frame).toContain('implement');\n23\t    expect(frame).toContain('verify');\n24\t  });\n25\t\n26\t  it('renders loop block as loop(N)[ task1 → task2 ]', () => {\n27\t    const flow: FlowStep[] = ['create-story', { loop: ['implement', 'verify'] }];\n28\t    const taskStates: Record<string, TaskNodeState> = {\n29\t      'create-story': 'done',\n30\t      'implement': 'active',\n31\t      'verify': 'pending',\n32\t    };\n33\t    const { lastFrame } = render(\n34\t      <WorkflowGraph flow={flow} currentTask=\"implement\" taskStates={taskStates} />\n35\t    );\n36\t    const frame = lastFrame()!;\n37\t    expect(frame).toContain('loop(');\n38\t    expect(frame).toContain('[ ');\n39\t    expect(frame).toContain('implement');\n40\t    expect(frame).toContain('verify');\n41\t    expect(frame).toContain(' ]');\n42\t  });\n43\t\n44\t  it('renders pending tasks with dim text', () => {\n45\t    const flow: FlowStep[] = ['task1'];\n46\t    const taskStates: Record<string, TaskNodeState> = { 'task1': 'pending' };\n47\t    const { lastFrame } = render(\n48\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} />\n49\t    );\n50\t    const frame = lastFrame()!;\n51\t    // Dim text in Ink renders the text without color markers\n52\t    expect(frame).toContain('task1');\n53\t    // Pending should NOT have status symbols\n54\t    expect(frame).not.toContain('✓');\n55\t    expect(frame).not.toContain('✗');\n56\t    expect(frame).not.toContain('◆');\n57\t  });\n58\t\n59\t  it('renders active task with ◆ marker', () => {\n60\t    const flow: FlowStep[] = ['task1'];\n61\t    const taskStates: Record<string, TaskNodeState> = { 'task1': 'active' };\n62\t    const { lastFrame } = render(\n63\t      <WorkflowGraph flow={flow} currentTask=\"task1\" taskStates={taskStates} />\n64\t    );\n65\t    const frame = lastFrame()!;\n66\t    expect(frame).toContain('◆');\n67\t    expect(frame).toContain('task1');\n68\t  });\n69\t\n70\t  it('renders completed task with ✓', () => {\n71\t    const flow: FlowStep[] = ['task1'];\n72\t    const taskStates: Record<string, TaskNodeState> = { 'task1': 'done' };\n73\t    const { lastFrame } = render(\n74\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} />\n75\t    );\n76\t    const frame = lastFrame()!;\n77\t    expect(frame).toContain('✓');\n78\t    expect(frame).toContain('task1');\n79\t  });\n80\t\n81\t  it('renders failed task with ✗', () => {\n82\t    const flow: FlowStep[] = ['task1'];\n83\t    const taskStates: Record<string, TaskNodeState> = { 'task1': 'failed' };\n84\t    const { lastFrame } = render(\n85\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} />\n86\t    );\n87\t    const frame = lastFrame()!;\n88\t    expect(frame).toContain('✗');\n89\t    expect(frame).toContain('task1');\n90\t  });\n91\t\n92\t  it('returns null for empty flow', () => {\n93\t    const { lastFrame } = render(\n94\t      <WorkflowGraph flow={[]} currentTask={null} taskStates={{ task1: 'pending' }} />\n95\t    );\n96\t    expect(lastFrame()).toBe('');\n97\t  });\n98\t\n99\t  it('returns null for empty taskStates', () => {\n100\t    const { lastFrame } = render(\n101\t      <WorkflowGraph flow={['task1']} currentTask={null} taskStates={{}} />\n102\t    );\n103\t    expect(lastFrame()).toBe('');\n104\t  });\n105\t\n106\t  it('renders mixed flow with sequential and loop steps', () => {\n107\t    const flow: FlowStep[] = ['create-story', { loop: ['implement', 'verify'] }, 'deploy'];\n108\t    const taskStates: Record<string, TaskNodeState> = {\n109\t      'create-story': 'done',\n110\t      'implement': 'done',\n111\t      'verify': 'active',\n112\t      'deploy': 'pending',\n113\t    };\n114\t    const { lastFrame } = render(\n115\t      <WorkflowGraph flow={flow} currentTask=\"verify\" taskStates={taskStates} />\n116\t    );\n117\t    const frame = lastFrame()!;\n118\t    expect(frame).toContain('create-story');\n119\t    expect(frame).toContain('✓');\n120\t    expect(frame).toContain('loop(');\n121\t    expect(frame).toContain('implement');\n122\t    expect(frame).toContain('verify');\n123\t    expect(frame).toContain('deploy');\n124\t    // Separator lines\n125\t    expect(frame).toContain('━');\n126\t  });\n127\t});\n128\t"}]},"parent_tool_use_id":"toolu_01Xt1BTzuX3J9Jg4gSz1FeWE","session_id":"1d40f54a-b143-44f0-8247-609f8fc4c105","uuid":"6772e2bd-b623-474b-badc-242e4cad2316","timestamp":"2026-04-03T11:21:45.198Z"}
