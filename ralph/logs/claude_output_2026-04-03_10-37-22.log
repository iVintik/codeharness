{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AZHEp73HhYgFHfy3CBhF4z","type":"tool_result","content":"1\t/**\n2\t * Public API for the agents subsystem.\n3\t *\n4\t * Re-exports types (story 13-1), stream parser functions/types,\n5\t * and the getDriver() factory (story 13-3).\n6\t *\n7\t * Ralph driver and prompt removed in Story 1.2 — will be replaced\n8\t * by workflow engine in Epic 5.\n9\t */\n10\t\n11\t// New types (Epic 10)\n12\texport type {\n13\t  AgentDriver,\n14\t  DriverHealth,\n15\t  DriverCapabilities,\n16\t  DispatchOpts,\n17\t  ErrorCategory,\n18\t  OutputContract,\n19\t  TestResults,\n20\t  ACStatus,\n21\t} from './types.js';\n22\t\n23\t// Deprecated types — kept for backward compatibility until story 10-3\n24\t/** @deprecated Use `DispatchOpts` instead. */\n25\texport type { SpawnOpts } from './types.js';\n26\t/** @deprecated Use `AsyncIterable<StreamEvent>` from `dispatch()` instead. */\n27\texport type { AgentProcess } from './types.js';\n28\t/** @deprecated Use `StreamEvent` from `stream-parser.ts` instead. */\n29\texport type { AgentEvent } from './types.js';\n30\t\n31\t// Stream parser\n32\texport { parseStreamLine } from './stream-parser.js';\n33\texport type {\n34\t  StreamEvent,\n35\t  ToolStartEvent,\n36\t  ToolInputEvent,\n37\t  ToolCompleteEvent,\n38\t  TextEvent,\n39\t  RetryEvent,\n40\t  ResultEvent,\n41\t} from './stream-parser.js';\n42\t\n43\t// --- Driver Factory ---\n44\t\n45\texport { getDriver, registerDriver, listDrivers, resetDrivers } from './drivers/factory.js';\n46\t"}]},"parent_tool_use_id":"toolu_017Urm7EPd5KhakJiz43kv21","session_id":"61d40628-eabe-45b5-b544-2f5989944a22","uuid":"754c61e2-eddf-4daf-ab77-1682df100ff9","timestamp":"2026-04-03T06:45:11.430Z"}
