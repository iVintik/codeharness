or state corruption (2026-03-27T19:15Z)"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":293,"cache_read_input_tokens":82454,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":293},"output_tokens":65,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"2a44c687-0795-47af-a7f4-46576056f827","uuid":"999efddc-18e1-4dfe-b1e9-f6a4cb16ba5b"}
