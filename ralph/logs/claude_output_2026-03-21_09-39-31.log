{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DSfwNMWzQQJ36n3DjJachk","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→\n     3→vi.mock('node:fs', () => ({\n     4→  existsSync: vi.fn(),\n     5→  readFileSync: vi.fn(),\n     6→}));\n     7→\n     8→import { existsSync, readFileSync } from 'node:fs';\n     9→import { validateDockerfile, loadRules } from '../dockerfile-validator.js';\n    10→\n    11→const mockExistsSync = vi.mocked(existsSync);\n    12→const mockReadFileSync = vi.mocked(readFileSync);\n    13→\n    14→beforeEach(() => {\n    15→  vi.clearAllMocks();\n    16→});\n    17→\n    18→// Helper: build a Dockerfile string that passes all rules\n    19→function goodDockerfile(): string {\n    20→  return [\n    21→    'FROM node:22-slim',\n    22→    'RUN apt-get update && apt-get install -y curl jq && rm -rf /var/lib/apt/lists/*',\n    23→    'RUN npm install -g codeharness',\n    24→    'COPY dist/ /app/dist/',\n    25→    'USER node',\n    26→    'CMD [\"codeharness\"]',\n    27→  ].join('\\n');\n    28→}\n    29→\n    30→// ─── Pinned FROM ────────────────────────────────────────────────────────────\n    31→\n    32→describe('pinned FROM', () => {\n    33→  it('passes for node:22-slim', () => {\n    34→    mockExistsSync.mockReturnValue(true);\n    35→    mockReadFileSync.mockReturnValue(goodDockerfile());\n    36→\n    37→    const r = validateDockerfile('/project');\n    38→    expect(r.success).toBe(true);\n    39→    if (r.success) {\n    40→      const fromGaps = r.data.gaps.filter(g => g.rule === 'pinned-from');\n    41→      expect(fromGaps).toHaveLength(0);\n    42→    }\n    43→  });\n    44→\n    45→  it('fails for node:latest', () => {\n    46→    mockExistsSync.mockReturnValue(true);\n    47→    mockReadFileSync.mockReturnValue(\n    48→      goodDockerfile().replace('FROM node:22-slim', 'FROM node:latest'),\n    49→    );\n    50→\n    51→    const r = validateDockerfile('/project');\n    52→    expect(r.success).toBe(true);\n    53→    if (r.success) {\n    54→      const fromGaps = r.data.gaps.filter(g => g.rule === 'pinned-from');\n    55→      expect(fromGaps.length).toBeGreaterThan(0);\n    56→      expect(fromGaps[0].description).toContain('unpinned base image');\n    57→    }\n    58→  });\n    59→\n    60→  it('passes for digest-pinned image', () => {\n    61→    mockExistsSync.mockReturnValue(true);\n    62→    mockReadFileSync.mockReturnValue(\n    63→      goodDockerfile().replace('FROM node:22-slim', 'FROM node@sha256:abc123def456'),\n    64→    );\n    65→\n    66→    const r = validateDockerfile('/project');\n    67→    expect(r.success).toBe(true);\n    68→    if (r.success) {\n    69→      const fromGaps = r.data.gaps.filter(g => g.rule === 'pinned-from');\n    70→      expect(fromGaps).toHaveLength(0);\n    71→    }\n    72→  });\n    73→\n    74→  it('fails for node (no tag)', () => {\n    75→    mockExistsSync.mockReturnValue(true);\n    76→    mockReadFileSync.mockReturnValue(\n    77→      goodDockerfile().replace('FROM node:22-slim', 'FROM node'),\n    78→    );\n    79→\n    80→    const r = validateDockerfile('/project');\n    81→    expect(r.success).toBe(true);\n    82→    if (r.success) {\n    83→      const fromGaps = r.data.gaps.filter(g => g.rule === 'pinned-from');\n    84→      expect(fromGaps.length).toBeGreaterThan(0);\n    85→      expect(fromGaps[0].description).toContain('unpinned base image');\n    86→    }\n    87→  });\n    88→});\n    89→\n    90→// ─── Project binary on PATH ─────────────────────────────────────────────────\n    91→\n    92→describe('project binary on PATH', () => {\n    93→  it('passes with npm install -g', () => {\n    94→    mockExistsSync.mockReturnValue(true);\n    95→    mockReadFileSync.mockReturnValue(goodDockerfile());\n    96→\n    97→    const r = validateDockerfile('/project');\n    98→    expect(r.success).toBe(true);\n    99→    if (r.success