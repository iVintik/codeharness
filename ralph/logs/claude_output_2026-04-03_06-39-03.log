{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SGzmyUmpuEiCSgKn1uCysN","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { join, resolve, dirname } from 'node:path';\n3\timport { fileURLToPath } from 'node:url';\n4\timport os from 'node:os';\n5\timport { parse } from 'yaml';\n6\timport { validateWorkflowSchema } from './schema-validate.js';\n7\t\n8\tconst __filename = fileURLToPath(import.meta.url);\n9\tconst __dirname = dirname(__filename);\n10\t\n11\tconst TEMPLATES_DIR = resolve(__dirname, '../../templates/workflows');\n12\t\n13\t// --- Interfaces ---\n14\t\n15\texport interface ResolvedTask {\n16\t  agent: string;\n17\t  scope: 'per-story' | 'per-run';\n18\t  session: 'fresh' | 'continue';\n19\t  source_access: boolean;\n20\t  prompt_template?: string;\n21\t  input_contract?: Record<string, unknown>;\n22\t  output_contract?: Record<string, unknown>;\n23\t  max_budget_usd?: number;\n24\t}\n25\t\n26\texport interface LoopBlock {\n27\t  loop: string[];\n28\t}\n29\t\n30\texport type FlowStep = string | LoopBlock;\n31\t\n32\texport interface ResolvedWorkflow {\n33\t  tasks: Record<string, ResolvedTask>;\n34\t  flow: FlowStep[];\n35\t}\n36\t\n37\t// --- Error Class ---\n38\t\n39\texport class WorkflowParseError extends Error {\n40\t  public readonly errors: Array<{ path: string; message: string }>;\n41\t\n42\t  constructor(message: string, errors?: Array<{ path: string; message: string }>) {\n43\t    super(message);\n44\t    this.name = 'WorkflowParseError';\n45\t    this.errors = errors ?? [];\n46\t  }\n47\t}\n48\t\n49\t// --- Parser ---\n50\t\n51\t/**\n52\t * Parse a workflow YAML file from disk, validate it against the JSON schema,\n53\t * check referential integrity, apply defaults, and return a typed ResolvedWorkflow.\n54\t */\n55\texport function parseWorkflow(filePath: string): ResolvedWorkflow {\n56\t  // 1. Read file\n57\t  let raw: string;\n58\t  try {\n59\t    raw = readFileSync(filePath, 'utf-8');\n60\t  } catch (err: unknown) {\n61\t    const code = err instanceof Error && 'code' in err ? (err as NodeJS.ErrnoException).code : undefined;\n62\t    const detail = code === 'ENOENT'\n63\t      ? 'File not found'\n64\t      : code === 'EACCES'\n65\t        ? 'Permission denied'\n66\t        : code === 'EISDIR'\n67\t          ? 'Path is a directory'\n68\t          : 'File not found or unreadable';\n69\t    throw new WorkflowParseError(`${detail}: ${filePath}`, [\n70\t      { path: filePath, message: detail },\n71\t    ]);\n72\t  }\n73\t\n74\t  // 2. Parse YAML\n75\t  let parsed: unknown;\n76\t  try {\n77\t    parsed = parse(raw);\n78\t  } catch (err: unknown) {\n79\t    const yamlMsg = err instanceof Error ? err.message : String(err);\n80\t    throw new WorkflowParseError(`Invalid YAML syntax: ${yamlMsg}`, [\n81\t      { path: filePath, message: yamlMsg },\n82\t    ]);\n83\t  }\n84\t\n85\t  // 3. Validate against JSON schema\n86\t  const result = validateWorkflowSchema(parsed);\n87\t  if (!result.valid) {\n88\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n89\t    throw new WorkflowParseError(\n90\t      `Schema validation failed: ${details}`,\n91\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n92\t    );\n93\t  }\n94\t\n95\t  // At this point, parsed has passed schema validation — safe to cast\n96\t  const data = parsed as { tasks: Record<string, Record<string, unknown>>; flow: unknown[] };\n97\t\n98\t  // 4. Referential integrity check\n99\t  const taskNames = new Set(Object.keys(data.tasks));\n100\t  const danglingRefs: Array<{ path: string; message: string }> = [];\n101\t\n102\t  for (let i = 0; i < data.flow.length; i++) {\n103\t    const step = data.flow[i];\n104\t    if (typeof step === 'string') {\n105\t      if (!taskNames.has(step)) {\n106\t        danglingRefs.push({\n107\t          path: `/flow/${i}`,\n108\t          message: `Task \"${step}\" referenced in flow but not defined in tasks`,\n109\t        });\n110\t      }\n111\t    } else if (typeof step === 'object' && step !== null && 'loop' in step) {\n112\t      const loopBlock = step as { loop: string[] };\n113\t      for (let j = 0; j < loopBlock.loop.length; j++) {\n114\t        const ref = loopBlock.loop[j];\n115\t        if (!taskNames.has(ref)) {\n116\t          danglingRefs.push({\n117\t            path: `/flow/${i}/loop/${j}`,\n118\t            message: `Task \"${ref}\" referenced in loop but not defined in tasks`,\n119\t          });\n120\t        }\n121\t      }\n122\t    }\n123\t  }\n124\t\n125\t  if (danglingRefs.length > 0) {\n126\t    const details = danglingRefs.map((e) => e.message).join('; ');\n127\t    throw new WorkflowParseError(`Dangling task references: ${details}`, danglingRefs);\n128\t  }\n129\t\n130\t  // 5. Apply defaults and build resolved tasks\n131\t  const resolvedTasks: Record<string, ResolvedTask> = {};\n132\t  for (const [name, task] of Object.entries(data.tasks)) {\n133\t    const resolved: ResolvedTask = {\n134\t      agent: task.agent as string,\n135\t      scope: (task.scope as ResolvedTask['scope']) ?? 'per-story',\n136\t      session: (task.session as ResolvedTask['session']) ?? 'fresh',\n137\t      source_access: (task.source_access as boolean) ?? true,\n138\t    };\n139\t    if (task.prompt_template !== undefined) {\n140\t      resolved.prompt_template = task.prompt_template as string;\n141\t    }\n142\t    if (task.input_contract !== undefined) {\n143\t      resolved.input_contract = task.input_contract as Record<string, unknown>;\n144\t    }\n145\t    if (task.output_contract !== undefined) {\n146\t      resolved.output_contract = task.output_contract as Record<string, unknown>;\n147\t    }\n148\t    if (task.max_budget_usd !== undefined) {\n149\t      resolved.max_budget_usd = task.max_budget_usd as number;\n150\t    }\n151\t    resolvedTasks[name] = resolved;\n152\t  }\n153\t\n154\t  // 6. Build resolved flow\n155\t  const resolvedFlow: FlowStep[] = data.flow.map((step) => {\n156\t    if (typeof step === 'string') {\n157\t      return step;\n158\t    }\n159\t    return step as LoopBlock;\n160\t  });\n161\t\n162\t  return { tasks: resolvedTasks, flow: resolvedFlow };\n163\t}\n164\t\n165\t// --- Patch Interfaces ---\n166\t\n167\t/**\n168\t * Patch file structure for workflow customization.\n169\t * `extends` identifies the base, `overrides` are deep-merged, `replace` sections wholly overwrite.\n170\t */\n171\texport interface WorkflowPatch {\n172\t  extends?: string;\n173\t  overrides?: Record<string, unknown>;\n174\t  replace?: Record<string, unknown>;\n175\t}\n176\t\n177\t// --- Deep Merge ---\n178\t\n179\t/**\n180\t * Deep merge strategy: objects merge recursively, arrays replace, scalars replace.\n181\t * Same semantics as agent-resolver deepMerge.\n182\t */\n183\tfunction deepMerge(base: Record<string, unknown>, patch: Record<string, unknown>): Record<string, unknown> {\n184\t  const result: Record<string, unknown> = { ...base };\n185\t\n186\t  for (const key of Object.keys(patch)) {\n187\t    const baseVal = base[key];\n188\t    const patchVal = patch[key];\n189\t\n190\t    if (\n191\t      patchVal !== null &&\n192\t      typeof patchVal === 'object' &&\n193\t      !Array.isArray(patchVal) &&\n194\t      baseVal !== null &&\n195\t      typeof baseVal === 'object' &&\n196\t      !Array.isArray(baseVal)\n197\t    ) {\n198\t      result[key] = deepMerge(\n199\t        baseVal as Record<string, unknown>,\n200\t        patchVal as Record<string, unknown>,\n201\t      );\n202\t    } else {\n203\t      result[key] = patchVal;\n204\t    }\n205\t  }\n206\t\n207\t  return result;\n208\t}\n209\t\n210\t// --- Patch Loading ---\n211\t\n212\t/**\n213\t * Load a workflow patch file. Returns null if the file does not exist (silent skip).\n214\t * Throws WorkflowParseError on malformed YAML.\n215\t */\n216\texport function loadWorkflowPatch(filePath: string): WorkflowPatch | null {\n217\t  if (!existsSync(filePath)) {\n218\t    return null;\n219\t  }\n220\t\n221\t  let raw: string;\n222\t  try {\n223\t    raw = readFileSync(filePath, 'utf-8');\n224\t  } catch { // IGNORE: file unreadable — treat as missing patch\n225\t    return null;\n226\t  }\n227\t\n228\t  let parsed: unknown;\n229\t  try {\n230\t    parsed = parse(raw);\n231\t  } catch (err: unknown) {\n232\t    const msg = err instanceof Error ? err.message : String(err);\n233\t    throw new WorkflowParseError(`Invalid YAML in patch file ${filePath}: ${msg}`, [\n234\t      { path: filePath, message: msg },\n235\t    ]);\n236\t  }\n237\t\n238\t  if (parsed === null || typeof parsed !== 'object') {\n239\t    throw new WorkflowParseError(`Patch file is not a valid object: ${filePath}`, [\n240\t      { path: filePath, message: 'Patch must be a YAML object' },\n241\t    ]);\n242\t  }\n243\t\n244\t  return parsed as WorkflowPatch;\n245\t}\n246\t\n247\t// --- Patch Merging ---\n248\t\n249\t/**\n250\t * Merge a workflow patch onto a base config.\n251\t * Deep-merges `overrides`, then applies `replace` sections as full overwrites.\n252\t */\n253\texport function mergeWorkflowPatch(\n254\t  base: Record<string, unknown>,\n255\t  patch: WorkflowPatch,\n256\t): Record<string, unknown> {\n257\t  let result = { ...base };\n258\t\n259\t  // Deep-merge overrides\n260\t  if (patch.overrides) {\n261\t    result = deepMerge(result, patch.overrides);\n262\t  }\n263\t\n264\t  // Full replacement for replace sections\n265\t  if (patch.replace) {\n266\t    for (const key of Object.keys(patch.replace)) {\n267\t      result[key] = patch.replace[key];\n268\t    }\n269\t  }\n270\t\n271\t  return result;\n272\t}\n273\t\n274\t// --- Main Resolution ---\n275\t\n276\t/**\n277\t * Resolve a workflow through the embedded -> user -> project patch chain.\n278\t *\n279\t * 1. Load embedded workflow from templates/workflows/{name}.yaml\n280\t * 2. Apply user-level patch from ~/.codeharness/workflows/{name}.patch.yaml (if exists)\n281\t * 3. Apply project-level patch from .codeharness/workflows/{name}.patch.yaml (if exists)\n282\t * 4. Validate merged result against JSON schema + referential integrity\n283\t * 5. Apply defaults and return ResolvedWorkflow\n284\t *\n285\t * If a full custom workflow (no patch, no extends) exists at project level, it is loaded directly.\n286\t */\n287\texport function resolveWorkflow(options?: { cwd?: string; name?: string }): ResolvedWorkflow {\n288\t  const cwd = options?.cwd ?? process.cwd();\n289\t  const name = options?.name ?? 'default';\n290\t\n291\t  const userPatchPath = join(os.homedir(), '.codeharness', 'workflows', `${name}.patch.yaml`);\n292\t  const projectPatchPath = join(cwd, '.codeharness', 'workflows', `${name}.patch.yaml`);\n293\t\n294\t  // Check for full custom workflow at project level (not a patch — no extends)\n295\t  const projectCustomPath = join(cwd, '.codeharness', 'workflows', `${name}.yaml`);\n296\t  if (existsSync(projectCustomPath)) {\n297\t    const customPatch = loadWorkflowPatch(projectCustomPath);\n298\t    if (customPatch && !customPatch.extends) {\n299\t      // This is a full custom workflow, not a patch — parse directly\n300\t      return parseWorkflow(projectCustomPath);\n301\t    }\n302\t  }\n303\t\n304\t  // Load embedded base\n305\t  const embeddedPath = join(TEMPLATES_DIR, `${name}.yaml`);\n306\t  let raw: string;\n307\t  try {\n308\t    raw = readFileSync(embeddedPath, 'utf-8');\n309\t  } catch { // IGNORE: rethrow as WorkflowParseError with context\n310\t    throw new WorkflowParseError(`Embedded workflow not found: ${name}`, [\n311\t      { path: embeddedPath, message: `File not found: ${embeddedPath}` },\n312\t    ]);\n313\t  }\n314\t\n315\t  let baseData: unknown;\n316\t  try {\n317\t    baseData = parse(raw);\n318\t  } catch (err: unknown) {\n319\t    const msg = err instanceof Error ? err.message : String(err);\n320\t    throw new WorkflowParseError(`Invalid YAML in embedded workflow ${name}: ${msg}`, [\n321\t      { path: embeddedPath, message: msg },\n322\t    ]);\n323\t  }\n324\t\n325\t  let merged = baseData as Record<string, unknown>;\n326\t\n327\t  // Apply user-level patch\n328\t  const userPatch = loadWorkflowPatch(userPatchPath);\n329\t  if (userPatch) {\n330\t    merged = mergeWorkflowPatch(merged, userPatch);\n331\t  }\n332\t\n333\t  // Apply project-level patch\n334\t  const projectPatch = loadWorkflowPatch(projectPatchPath);\n335\t  if (projectPatch) {\n336\t    merged = mergeWorkflowPatch(merged, projectPatch);\n337\t  }\n338\t\n339\t  // Validate merged result against JSON schema\n340\t  const schemaResult = validateWorkflowSchema(merged);\n341\t  if (!schemaResult.valid) {\n342\t    const details = schemaResult.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n343\t    throw new WorkflowParseError(\n344\t      `Schema validation failed after merging patches: ${details}`,\n345\t      schemaResult.errors.map((e) => ({ path: e.path, message: e.message })),\n346\t    );\n347\t  }\n348\t\n349\t  // Cast after schema validation\n350\t  const data = merged as { tasks: Record<string, Record<string, unknown>>; flow: unknown[] };\n351\t\n352\t  // Referential integrity check\n353\t  const taskNames = new Set(Object.keys(data.tasks));\n354\t  const danglingRefs: Array<{ path: string; message: string }> = [];\n355\t\n356\t  for (let i = 0; i < data.flow.length; i++) {\n357\t    const step = data.flow[i];\n358\t    if (typeof step === 'string') {\n359\t      if (!taskNames.has(step)) {\n360\t        danglingRefs.push({\n361\t          path: `/flow/${i}`,\n362\t          message: `Task \"${step}\" referenced in flow but not defined in tasks`,\n363\t        });\n364\t      }\n365\t    } else if (typeof step === 'object' && step !== null && 'loop' in step) {\n366\t      const loopBlock = step as { loop: string[] };\n367\t      for (let j = 0; j < loopBlock.loop.length; j++) {\n368\t        const ref = loopBlock.loop[j];\n369\t        if (!taskNames.has(ref)) {\n370\t          danglingRefs.push({\n371\t            path: `/flow/${i}/loop/${j}`,\n372\t            message: `Task \"${ref}\" referenced in loop but not defined in tasks`,\n373\t          });\n374\t        }\n375\t      }\n376\t    }\n377\t  }\n378\t\n379\t  if (danglingRefs.length > 0) {\n380\t    const details = danglingRefs.map((e) => e.message).join('; ');\n381\t    throw new WorkflowParseError(`Dangling task references: ${details}`, danglingRefs);\n382\t  }\n383\t\n384\t  // Apply defaults and build resolved tasks\n385\t  const resolvedTasks: Record<string, ResolvedTask> = {};\n386\t  for (const [taskName, task] of Object.entries(data.tasks)) {\n387\t    const resolved: ResolvedTask = {\n388\t      agent: task.agent as string,\n389\t      scope: (task.scope as ResolvedTask['scope']) ?? 'per-story',\n390\t      session: (task.session as ResolvedTask['session']) ?? 'fresh',\n391\t      source_access: (task.source_access as boolean) ?? true,\n392\t    };\n393\t    if (task.prompt_template !== undefined) {\n394\t      resolved.prompt_template = task.prompt_template as string;\n395\t    }\n396\t    if (task.input_contract !== undefined) {\n397\t      resolved.input_contract = task.input_contract as Record<string, unknown>;\n398\t    }\n399\t    if (task.output_contract !== undefined) {\n400\t      resolved.output_contract = task.output_contract as Record<string, unknown>;\n401\t    }\n402\t    if (task.max_budget_usd !== undefined) {\n403\t      resolved.max_budget_usd = task.max_budget_usd as number;\n404\t    }\n405\t    resolvedTasks[taskName] = resolved;\n406\t  }\n407\t\n408\t  // Build resolved flow\n409\t  const resolvedFlow: FlowStep[] = data.flow.map((step) => {\n410\t    if (typeof step === 'string') {\n411\t      return step;\n412\t    }\n413\t    return step as LoopBlock;\n414\t  });\n415\t\n416\t  return { tasks: resolvedTasks, flow: resolvedFlow };\n417\t}\n418\t"}]},"parent_tool_use_id":"toolu_01VzsYX8Z6EUQXQkK3QsLHTB","session_id":"b82e0b02-3413-404d-8b3c-c5e48f86089c","uu