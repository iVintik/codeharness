ess();\n   364→\n   365→    expect(result.success).toBe(false);\n   366→    if (!result.success) {\n   367→      expect(result.error).toContain('Failed to read sprint state');\n   368→    }\n   369→  });\n   370→});\n   371→\n   372→describe('atomic write guarantee for concurrent readers', () => {\n   373→  it('state is complete JSON immediately after write', () => {\n   374→    writeStateAtomic(defaultState());\n   375→\n   376→    updateRunProgress({\n   377→      currentStory: '1-2-user-auth',\n   378→      currentPhase: 'verify',\n   379→      lastAction: 'Running AC checks',\n   380→      acProgress: '3/7',\n   381→    });\n   382→\n   383→    // Simulate external reader\n   384→    const raw = readFileSync(stateFile(), 'utf-8');\n   385→    const parsed = JSON.parse(raw) as SprintState;\n   386→\n   387→    expect(parsed.version).toBe(2);\n   388→    expect(parsed.run.currentStory).toBe('1-2-user-auth');\n   389→    expect(parsed.run.currentPhase).toBe('verify');\n   390→    expect(parsed.run.lastAction).toBe('Running AC checks');\n   391→    expect(parsed.run.acProgress).toBe('3/7');\n   392→  });\n   393→\n   394→  it('rapid sequential updates produce valid JSON each time', () => {\n   395→    writeStateAtomic(defaultState());\n   396→\n   397→    for (let i = 1; i <= 10; i++) {\n   398→      updateRunProgress({ acProgress: `${i}/10` });\n   399→\n   400→      const raw = readFileSync(stateFile(), 'utf-8');\n   401→      expect(() => JSON.parse(raw)).not.toThrow();\n   402→\n   403→      const parsed = JSON.parse(raw) as SprintState;\n   404→      expect(parsed.run.acProgress).toBe(`${i}/10`);\n   405→    }\n   406→  });\n   407→});\n   408→\n   409→describe('backward compatibility', () => {\n   410→  it('getSprintState fills missing progress fields with null defaults on old state files', () => {\n   411→    // Simulate an old state file without the new progress fields\n   412→    const oldState = {\n   413→      version: 1,\n   414→      sprint: { total: 1,