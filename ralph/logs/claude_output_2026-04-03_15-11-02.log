13\t    expect(frame).toContain('💭');\n414\t    expect(frame).toContain('analyzing...');\n415\t  });\n416\t\n417\t  it('renders empty state without errors', () => {\n418\t    const state = makeState();\n419\t    const { lastFrame } = render(<App state={state} />);\n420\t    expect(lastFrame()).toBeDefined();\n421\t  });\n422\t\n423\t  it('renders retry info when present', () => {\n424\t    const state = makeState({\n425\t      retryInfo: { attempt: 3, delay: 10000 },\n426\t    });\n427\t    const { lastFrame } = render(<App state={state} />);\n428\t    const frame = lastFrame()!;\n429\t    expect(frame).toContain('⏳');\n430\t    expect(frame).toContain('3');\n431\t  });\n432\t\n433\t  it('renders bottom separator after story breakdown', () => {\n434\t    const state = makeState({\n435\t      sprintInfo: { storyKey: '3-2', phase: 'dev', done: 1, total: 5 },\n436\t      stories: [\n437\t        { key: '3-1-done', status: 'done' },\n438\t        { key: '3-2-current', status: 'in-progress' },\n439\t      ],\n440\t    });\n441\t    const { lastFrame } = render(<App state={state} />);\n442\t    const frame = lastFrame()!;\n443\t    // Should have separators\n444\t    const separatorCount = (frame.match(/━━━/g) || []).length;\n445\t    expect(separatorCount).toBeGreaterThanOrEqual(2); // header separator + bottom separator\n446\t  });\n447\t});\n448\t\n449\t// --- Controller API Tests ---\n450\t\n451\tdescribe('startRenderer', () => {\n452\t  let handle: RendererHandle | null = null;\n453\t\n454\t  afterEach(() => {\n455\t    if (handle) {\n456\t      handle.cleanup();\n457\t      handle = null;\n458\t    }\n459\t  });\n460\t\n461\t  describe('quiet mode (AC #8)', () => {\n462\t    it('returns no-op handle when quiet is true', () => {\n463\t      handle = startRenderer({ quiet: true });\n464\t      handle.update({ type: 'tool-start', name: 'Bash', id: 'x' });\n465\t      handle.update({ type: 'tool-complete' });\n466\t      handle.update({ type: 'text', text: 'hello' });\n