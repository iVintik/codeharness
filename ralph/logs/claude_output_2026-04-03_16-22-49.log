{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UJRiPBGmXNJbcENZQqTBZY","type":"tool_result","content":"1\timport { readFileSync, existsSync, readdirSync } from 'node:fs';\n2\timport { resolve, join, dirname } from 'node:path';\n3\timport { fileURLToPath } from 'node:url';\n4\timport os from 'node:os';\n5\timport { parse } from 'yaml';\n6\t\n7\tconst __filename = fileURLToPath(import.meta.url);\n8\tconst __dirname = dirname(__filename);\n9\timport { validateAgentSchema } from './schema-validate.js';\n10\t\n11\t// --- Interfaces ---\n12\t\n13\t/**\n14\t * Agent config shape matching agent.schema.json, plus optional prompt_patches\n15\t * accumulated from patch files.\n16\t */\n17\texport interface ResolvedAgent {\n18\t  name: string;\n19\t  role: {\n20\t    title: string;\n21\t    purpose: string;\n22\t  };\n23\t  persona: {\n24\t    identity: string;\n25\t    communication_style: string;\n26\t    principles: string[];\n27\t  };\n28\t  personality?: {\n29\t    traits: Record<string, number>;\n30\t  };\n31\t  disallowedTools?: string[];\n32\t  prompt_patches?: {\n33\t    append?: string;\n34\t  };\n35\t  prompt_template?: string;\n36\t}\n37\t\n38\t/**\n39\t * Compiled subagent definition ready for Agent SDK dispatch.\n40\t */\n41\texport interface SubagentDefinition {\n42\t  name: string;\n43\t  model: string;\n44\t  instructions: string;\n45\t  disallowedTools: string[];\n46\t  bare: true;\n47\t}\n48\t\n49\t/**\n50\t * Patch file structure: extends identifies base, overrides deep-merged,\n51\t * prompt_patches preserved separately.\n52\t */\n53\texport interface AgentPatch {\n54\t  extends?: string;\n55\t  overrides?: Record<string, unknown>;\n56\t  prompt_patches?: {\n57\t    append?: string;\n58\t  };\n59\t}\n60\t\n61\t// --- Error Class ---\n62\t\n63\texport class AgentResolveError extends Error {\n64\t  public readonly filePath: string;\n65\t  public readonly errors: Array<{ path: string; message: string }>;\n66\t\n67\t  constructor(\n68\t    message: string,\n69\t    filePath: string,\n70\t    errors?: Array<{ path: string; message: string }>,\n71\t  ) {\n72\t    super(message);\n73\t    this.name = 'AgentResolveError';\n74\t    this.filePath = filePath;\n75\t    this.errors = errors ?? [];\n76\t  }\n77\t}\n78\t\n79\t// --- Constants ---\n80\t\n81\tconst TEMPLATES_DIR = resolve(__dirname, '../../templates/agents');\n82\tconst DEFAULT_MODEL = 'claude-sonnet-4-20250514';\n83\t\n84\t// --- Input Validation ---\n85\t\n86\tconst SAFE_NAME_RE = /^[a-zA-Z0-9_-]+$/;\n87\t\n88\t/**\n89\t * Validate agent name to prevent path traversal and unexpected characters.\n90\t */\n91\tfunction validateName(name: string): void {\n92\t  if (!name || !SAFE_NAME_RE.test(name)) {\n93\t    throw new AgentResolveError(\n94\t      `Invalid agent name: \"${name}\" — must match ${SAFE_NAME_RE}`,\n95\t      '',\n96\t      [{ path: '', message: `Invalid agent name: ${name}` }],\n97\t    );\n98\t  }\n99\t}\n100\t\n101\t// --- Deep Merge ---\n102\t\n103\t/**\n104\t * Deep merge strategy: objects merge recursively, arrays replace, scalars replace.\n105\t */\n106\tfunction deepMerge(base: Record<string, unknown>, patch: Record<string, unknown>): Record<string, unknown> {\n107\t  const result: Record<string, unknown> = { ...base };\n108\t\n109\t  for (const key of Object.keys(patch)) {\n110\t    const baseVal = base[key];\n111\t    const patchVal = patch[key];\n112\t\n113\t    if (\n114\t      patchVal !== null &&\n115\t      typeof patchVal === 'object' &&\n116\t      !Array.isArray(patchVal) &&\n117\t      baseVal !== null &&\n118\t      typeof baseVal === 'object' &&\n119\t      !Array.isArray(baseVal)\n120\t    ) {\n121\t      result[key] = deepMerge(\n122\t        baseVal as Record<string, unknown>,\n123\t        patchVal as Record<string, unknown>,\n124\t      );\n125\t    } else {\n126\t      result[key] = patchVal;\n127\t    }\n128\t  }\n129\t\n130\t  return result;\n131\t}\n132\t\n133\t// --- Embedded Agent Loading ---\n134\t\n135\t/**\n136\t * Load an embedded agent template from templates/agents/{name}.yaml.\n137\t * Throws AgentResolveError if not found or invalid.\n138\t */\n139\texport function loadEmbeddedAgent(name: string): ResolvedAgent {\n140\t  validateName(name);\n141\t  const filePath = join(TEMPLATES_DIR, `${name}.yaml`);\n142\t\n143\t  let raw: string;\n144\t  try {\n145\t    raw = readFileSync(filePath, 'utf-8');\n146\t  } catch { // IGNORE: rethrow as AgentResolveError with context\n147\t    throw new AgentResolveError(\n148\t      `Embedded agent not found: ${name}`,\n149\t      filePath,\n150\t      [{ path: filePath, message: `File not found: ${filePath}` }],\n151\t    );\n152\t  }\n153\t\n154\t  let parsed: unknown;\n155\t  try {\n156\t    parsed = parse(raw);\n157\t  } catch (err: unknown) {\n158\t    const msg = err instanceof Error ? err.message : String(err);\n159\t    throw new AgentResolveError(\n160\t      `Invalid YAML in embedded agent ${name}: ${msg}`,\n161\t      filePath,\n162\t      [{ path: filePath, message: msg }],\n163\t    );\n164\t  }\n165\t\n166\t  const result = validateAgentSchema(parsed);\n167\t  if (!result.valid) {\n168\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n169\t    throw new AgentResolveError(\n170\t      `Schema validation failed for embedded agent ${name}: ${details}`,\n171\t      filePath,\n172\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n173\t    );\n174\t  }\n175\t\n176\t  return parsed as ResolvedAgent;\n177\t}\n178\t\n179\t// --- Embedded Agent Listing ---\n180\t\n181\t/**\n182\t * List all embedded agent template names (filenames without .yaml extension).\n183\t * Returns a sorted array of available agent names.\n184\t */\n185\texport function listEmbeddedAgents(): string[] {\n186\t  try {\n187\t    const files = readdirSync(TEMPLATES_DIR);\n188\t    return files\n189\t      .filter((f) => f.endsWith('.yaml'))\n190\t      .map((f) => f.replace(/\\.yaml$/, ''))\n191\t      .sort();\n192\t  } catch { // IGNORE: directory unreadable — return empty list\n193\t    return [];\n194\t  }\n195\t}\n196\t\n197\t// --- Patch Loading ---\n198\t\n199\t/**\n200\t * Load a patch file. Returns null if the file does not exist (silent skip).\n201\t * Throws AgentResolveError on malformed YAML.\n202\t */\n203\texport function loadPatch(filePath: string): AgentPatch | null {\n204\t  if (!existsSync(filePath)) {\n205\t    return null;\n206\t  }\n207\t\n208\t  let raw: string;\n209\t  try {\n210\t    raw = readFileSync(filePath, 'utf-8');\n211\t  } catch { // IGNORE: file unreadable — treat as missing patch\n212\t    return null;\n213\t  }\n214\t\n215\t  let parsed: unknown;\n216\t  try {\n217\t    parsed = parse(raw);\n218\t  } catch (err: unknown) {\n219\t    const msg = err instanceof Error ? err.message : String(err);\n220\t    throw new AgentResolveError(\n221\t      `Invalid YAML in patch file: ${msg}`,\n222\t      filePath,\n223\t      [{ path: filePath, message: msg }],\n224\t    );\n225\t  }\n226\t\n227\t  if (parsed === null || typeof parsed !== 'object') {\n228\t    throw new AgentResolveError(\n229\t      `Patch file is not a valid object`,\n230\t      filePath,\n231\t      [{ path: filePath, message: 'Patch must be a YAML object' }],\n232\t    );\n233\t  }\n234\t\n235\t  return parsed as AgentPatch;\n236\t}\n237\t\n238\t// --- Patch Merging ---\n239\t\n240\t/**\n241\t * Merge a patch onto a base config. Deep-merges overrides, preserves prompt_patches separately.\n242\t */\n243\texport function mergePatch(\n244\t  base: Record<string, unknown>,\n245\t  patch: AgentPatch,\n246\t): Record<string, unknown> {\n247\t  let result = { ...base };\n248\t\n249\t  if (patch.overrides) {\n250\t    result = deepMerge(result, patch.overrides);\n251\t  }\n252\t\n253\t  if (patch.prompt_patches) {\n254\t    const existing = result.prompt_patches as { append?: string } | undefined;\n255\t    const existingAppend = existing?.append ?? '';\n256\t    const newAppend = patch.prompt_patches.append ?? '';\n257\t\n258\t    if (newAppend) {\n259\t      result.prompt_patches = {\n260\t        append: existingAppend ? `${existingAppend}\\n${newAppend}` : newAppend,\n261\t      };\n262\t    }\n263\t  }\n264\t\n265\t  return result;\n266\t}\n267\t\n268\t// --- Main Resolution ---\n269\t\n270\t/**\n271\t * Resolve an agent through the embedded -> user -> project patch chain.\n272\t * For custom agents (no embedded match, found at project/user level without extends), loads directly.\n273\t */\n274\texport function resolveAgent(name: string, options?: { cwd?: string }): ResolvedAgent {\n275\t  validateName(name);\n276\t  const cwd = options?.cwd ?? process.cwd();\n277\t  const userPatchPath = join(os.homedir(), '.codeharness', 'agents', `${name}.patch.yaml`);\n278\t  const projectPatchPath = join(cwd, '.codeharness', 'agents', `${name}.patch.yaml`);\n279\t\n280\t  // Check for custom agent (project-level full config, no extends)\n281\t  const projectCustomPath = join(cwd, '.codeharness', 'agents', `${name}.yaml`);\n282\t  const userCustomPath = join(os.homedir(), '.codeharness', 'agents', `${name}.yaml`);\n283\t\n284\t  // Try custom agent at project level first, then user level\n285\t  for (const customPath of [projectCustomPath, userCustomPath]) {\n286\t    if (existsSync(customPath)) {\n287\t      const patch = loadPatch(customPath);\n288\t      if (patch && !patch.extends) {\n289\t        // This is a full custom agent, not a patch — load and validate directly\n290\t        const parsed = patch as unknown as Record<string, unknown>;\n291\t        // Strip prompt_patches before schema validation (not in schema, same as patch path)\n292\t        const { prompt_patches: customPP, ...customForValidation } = parsed as Record<string, unknown> & { prompt_patches?: unknown };\n293\t        const result = validateAgentSchema(customForValidation);\n294\t        if (!result.valid) {\n295\t          const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n296\t          throw new AgentResolveError(\n297\t            `Schema validation failed for custom agent ${name}: ${details}`,\n298\t            customPath,\n299\t            result.errors.map((e) => ({ path: e.path, message: e.message })),\n300\t          );\n301\t        }\n302\t        return (customPP ? { ...customForValidation, prompt_patches: customPP } : customForValidation) as unknown as ResolvedAgent;\n303\t      }\n304\t    }\n305\t  }\n306\t\n307\t  // Load embedded base\n308\t  const base = loadEmbeddedAgent(name);\n309\t  let merged: Record<string, unknown> = base as unknown as Record<string, unknown>;\n310\t\n311\t  // Apply user patch\n312\t  const userPatch = loadPatch(userPatchPath);\n313\t  if (userPatch) {\n314\t    merged = mergePatch(merged, userPatch);\n315\t  }\n316\t\n317\t  // Apply project patch\n318\t  const projectPatch = loadPatch(projectPatchPath);\n319\t  if (projectPatch) {\n320\t    merged = mergePatch(merged, projectPatch);\n321\t  }\n322\t\n323\t  // Validate merged result (strip prompt_patches for schema validation since it's not in schema)\n324\t  const { prompt_patches, ...forValidation } = merged as Record<string, unknown> & { prompt_patches?: unknown };\n325\t  const result = validateAgentSchema(forValidation);\n326\t  if (!result.valid) {\n327\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n328\t    const errorPath = projectPatch ? projectPatchPath : userPatch ? userPatchPath : 'merged';\n329\t    throw new AgentResolveError(\n330\t      `Schema validation failed after merging patches for ${name}: ${details}`,\n331\t      errorPath,\n332\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n333\t    );\n334\t  }\n335\t\n336\t  // Re-attach prompt_patches if present, return without mutating forValidation\n337\t  return (prompt_patches\n338\t    ? { ...forValidation, prompt_patches }\n339\t    : forValidation) as unknown as ResolvedAgent;\n340\t}\n341\t\n342\t// --- Subagent Compilation ---\n343\t\n344\t/**\n345\t * Compile a ResolvedAgent into a SubagentDefinition for Agent SDK dispatch.\n346\t */\n347\texport function compileSubagentDefinition(agent: ResolvedAgent): SubagentDefinition {\n348\t  const parts: string[] = [];\n349\t\n350\t  parts.push(`You are ${agent.persona.identity}`);\n351\t  parts.push(`Communication style: ${agent.persona.communication_style}`);\n352\t\n353\t  if (agent.persona.principles.length > 0) {\n354\t    const bullets = agent.persona.principles.map((p) => `- ${p}`).join('\\n');\n355\t    parts.push(`Principles:\\n${bullets}`);\n356\t  }\n357\t\n358\t  if (agent.prompt_patches?.append) {\n359\t    parts.push(agent.prompt_patches.append);\n360\t  }\n361\t\n362\t  if (agent.prompt_template) {\n363\t    parts.push(agent.prompt_template);\n364\t  }\n365\t\n366\t  return {\n367\t    name: agent.name,\n368\t    model: DEFAULT_MODEL,\n369\t    instructions: parts.join('\\n\\n'),\n370\t    disallowedTools: agent.disallowedTools ?? [],\n371\t    bare: true,\n372\t  };\n373\t}\n374\t"}]},"parent_tool_use_id":"toolu_01PJ1ZaMtGAYgkx9N7rYqNxX","session_id":"49777568-67d3-419d-b985-1c272283fc99","uuid":"ebf3ac54-e38c-407b-b2d7-77fcc4fad689","timestamp":"2026-04-03T12:29:27.745Z"}
