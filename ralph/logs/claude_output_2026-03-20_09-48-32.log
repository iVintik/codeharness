 sprint: { total: 0, done: 0 },\n    55→    observability: obs,\n    56→  });\n    57→}\n    58→\n    59→// ============================================================\n    60→// Module barrel exports\n    61→// ============================================================\n    62→\n    63→describe('module barrel exports', () => {\n    64→  it('re-exports saveCoverageResult from index.ts', () => {\n    65→    expect(barrelSave).toBe(saveCoverageResult);\n    66→  });\n    67→\n    68→  it('re-exports readCoverageState from index.ts', () => {\n    69→    expect(barrelRead).toBe(readCoverageState);\n    70→  });\n    71→\n    72→  it('re-exports getCoverageTrend from index.ts', () => {\n    73→    expect(barrelTrend).toBe(getCoverageTrend);\n    74→  });\n    75→\n    76→  it('re-exports checkCoverageTarget from index.ts', () => {\n    77→    expect(barrelCheck).toBe(checkCoverageTarget);\n    78→  });\n    79→});\n    80→\n    81→// ============================================================\n    82→// saveCoverageResult\n    83→// ============================================================\n    84→\n    85→describe('saveCoverageResult', () => {\n    86→  it('writes to sprint-state.json with correct structure', () => {\n    87→    mockExistsSync.mockReturnValue(false);\n    88→\n    89→    const result = saveCoverageResult('/project', makeAnalyzerResult(75));\n    90→    expect(result.success).toBe(true);\n    91→\n    92→    // Verify atomic write: writeFileSync to tmp, then renameSync\n    93→    expect(mockWriteFileSync).toHaveBeenCalledOnce();\n    94→    expect(mockRenameSync).toHaveBeenCalledOnce();\n    95→\n    96→    const writtenData = JSON.parse(\n    97→      mockWriteFileSync.mock.calls[0][1] as string,\n    98→    );\n    99→    expect(writtenData.observability.static.coveragePercent).toBe(75);\n   100→    expect(writtenData.observability.static.lastScanTimestamp).toBe(\n   101→      '2026-03-19T14:30:00.000Z',\n   102→    );\n   103→    expect(writtenData.observability.static.history).toHaveLength(1);\n   104→    expect(writtenData.observability.static.history[0]).toEqual({\n   105→      coveragePercent: 75,\n   106→      timestamp: '2026-03-19T14:30:00.000Z',\n   107→    });\n   108→    expect(writtenData.observability.targets.staticTarget).toBe(80);\n   109→  });\n   110→\n   111→  it('appends to history array (not replaces)', () => {\n   112→    const existingState = makeStateWithObservability({\n   113→      static: {\n   114→        coveragePercent: 70,\n   115→        lastScanTimestamp: '2026-03-18T10:00:00.000Z',\n   116→        history: [\n   117→          { coveragePercent: 70, timestamp: '2026-03-18T10:00:00.000Z' },\n   118→        ],\n   119→      },\n   120→      targets: { staticTarget: 80 },\n   121→    });\n   122→\n   123→    mockExistsSync.mockReturnValue(true);\n   124→    mockReadFileSync.mockReturnValue(existingState);\n   125→\n   126→    const result = saveCoverageResult('/project', makeAnalyzerResult(75));\n   127→    expect(result.success).toBe(true);\n   128→\n   129→    const writtenData = JSON.parse(\n   130→      mockWriteFileSync.mock.calls[0][1] as string,\n   131→    );\n   132→    expect(writtenData.observability.static.history).toHaveLength(2);\n   133→    expect(writtenData.observability.static.history[0]).toEqual({\n   134→      coveragePercent: 70,\n   135→      timestamp: '2026-03-18T10:00:00.000Z',\n   136→    });\n   137→    expect(writtenData.observability.static.history[1]).toEqual({\n   138→      coveragePercent: 75,\n   139→      timestamp: '2026-03-19T14:30:00.000Z',\n   140→    });\n   141→  });\n   142→\n   143→  it('preserves existing sprint-state.json fields', () => {\n   144→    const existingState = JSON.stringify({\n   145→      version: 1,\n   146→      sprint: { total: 5, done: 2 },\n   147→      stories: { 'story-1': { status: 'done' } },\n   148→      actionItems: ['fix bug'],\n   149→    });\n   150→\n   151→    mockExistsSync.mockReturnValue(true);\n   1