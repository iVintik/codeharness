{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WeHPer1aan6zpdvGoiu4QL","type":"tool_result","content":"1040\t\n1041\t      expect(result.success).toBe(false);\n1042\t      expect(result.reason).toBe('tests-failed');\n1043\t      expect(result.testResults).toEqual({ passed: 0, failed: 1 });\n1044\t    });\n1045\t\n1046\t    it('handles git reset --hard failure gracefully after test failure', async () => {\n1047\t      mockExecSync.mockImplementation((cmd: string) => {\n1048\t        if (cmd.includes('branch --list')) return Buffer.from('  codeharness/epic-17-slug\\n');\n1049\t        if (cmd.includes('status --porcelain')) return Buffer.from('');\n1050\t        if (cmd.includes('merge --no-ff')) return Buffer.from('');\n1051\t        if (cmd.includes('reset --hard')) {\n1052\t          const err = new Error('corrupted');\n1053\t          (err as unknown as { stderr: Buffer }).stderr = Buffer.from('error');\n1054\t          throw err;\n1055\t        }\n1056\t        return Buffer.from('');\n1057\t      });\n1058\t      mockExecAsync.mockResolvedValue({ stdout: '0 passed\\n3 failed' });\n1059\t\n1060\t      const result = await manager.mergeWorktree('17');\n1061\t\n1062\t      // Should still return tests-failed even if reset fails\n1063\t      expect(result.success).toBe(false);\n1064\t      expect(result.reason).toBe('tests-failed');\n1065\t    });\n1066\t  });\n1067\t\n1068\t  describe('AsyncMutex', () => {\n1069\t    it('acquire returns a release function', async () => {\n1070\t      const mutex = new AsyncMutex();\n1071\t      const release = await mutex.acquire();\n1072\t      expect(typeof release).toBe('function');\n1073\t      release();\n1074\t    });\n1075\t\n1076\t    it('serializes access — second acquire waits for first release', async () => {\n1077\t      const mutex = new AsyncMutex();\n1078\t      const order: string[] = [];\n1079\t\n1080\t      const release1 = await mutex.acquire();\n1081\t      order.push('acquired-1');\n1082\t\n1083\t      // Second acquire should not resolve until release1 is called\n1084\t      let release2: (() => void) | null = null;\n1085\t      const acquire2Promise = mutex.acquire().then((r) => {\n1086\t        release2 = r;\n1087\t        order.push('acquired-2');\n1088\t      });\n1089\t\n1090\t      // Give the event loop a tick — acquire2 should still be pending\n1091\t      await new Promise((r) => setTimeout(r, 10));\n1092\t      expect(order).toEqual(['acquired-1']);\n1093\t\n1094\t      // Release first lock\n1095\t      release1();\n1096\t      await acquire2Promise;\n1097\t\n1098\t      expect(order).toEqual(['acquired-1', 'acquired-2']);\n1099\t      release2!();\n1100\t    });\n1101\t  });\n1102\t});\n1103\t"}]},"parent_tool_use_id":"toolu_011KW5B7oWpj1MKDHqa2H54S","session_id":"74f4684f-cc80-4828-8405-943cba326449","uuid":"2c996efb-acaa-4cf8-9954-1c99defb260c","timestamp":"2026-04-03T21:45:48.701Z"}
