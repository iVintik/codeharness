{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BhXPEMdxBmy3xrC3eQx1LH","type":"tool_result","content":"     1→/**\n     2→ * Stale container cleanup for infra containers.\n     3→ *\n     4→ * Removes exited/dead containers matching codeharness-shared-*,\n     5→ * codeharness-collector-*, and codeharness-verify-* patterns.\n     6→ *\n     7→ * Public functions return Result<T> and never throw.\n     8→ */\n     9→\n    10→import { execFileSync } from 'node:child_process';\n    11→import { isDockerAvailable } from '../../lib/docker/index.js';\n    12→import { ok, fail } from '../../types/result.js';\n    13→import type { Result } from '../../types/result.js';\n    14→import type { CleanupResult } from './types.js';\n    15→\n    16→/** Container name patterns to match for cleanup */\n    17→const STALE_PATTERNS = ['codeharness-shared-', 'codeharness-collector-', 'codeharness-verify-'];\n    18→\n    19→/**\n    20→ * Remove stale codeharness infra containers (exited or dead).\n    21→ *\n    22→ * If Docker is not available, returns ok with 0 removed (AC#7).\n    23→ */\n    24→export function cleanupContainers(): Result<CleanupResult> {\n    25→  try {\n    26→    if (!isDockerAvailable()) {\n    27→      return ok({ containersRemoved: 0, names: [] });\n    28→    }\n    29→\n    30→    // List all containers (including stopped) matching our patterns\n    31→    const staleNames: string[] = [];\n    32→\n    33→    for (const pattern of STALE_PATTERNS) {\n    34→      try {\n    35→        const output = execFileSync(\n    36→          'docker',\n    37→          [\n    38→            'ps',\n    39→            '-a',\n    40→            '--filter', `name=${pattern}`,\n    41→            '--filter', 'status=exited',\n    42→            '--filter', 'status=dead',\n    43→            '--format', '{{.Names}}',\n    44→          ],\n    45→          { stdio: 'pipe', timeout: 10_000 },\n    46→        );\n    47→        const names = output\n    48→          .toString()\n    49→          .trim()\n    50→          .split('\\n')\n    51→          .filter(n => n.trim());\n    52→        staleNames.push(...names);\n    53→      } catch {\n    54→        // docker ps failed for this pattern — skip\n    55→      }\n    56→    }\n    57→\n    58→    if (staleNames.length === 0) {\n    59→      return ok({ containersRemoved: 0, names: [] });\n    60→    }\n    61→\n    62→    // Remove all stale containers\n    63→    const removed: string[] = [];\n    64→    for (const name of staleNames) {\n    65→      try {\n    66→        execFileSync('docker', ['rm', '-f', name], {\n    67→          stdio: 'pipe',\n    68→          timeout: 10_000,\n    69→        });\n    70→        removed.push(name);\n    71→      } catch {\n    72→        // Individual removal failed — continue with others\n    73→      }\n    74→    }\n    75→\n    76→    return ok({ containersRemoved: removed.length, names: removed });\n    77→    /* c8 ignore start -- defensive: inner catches handle all known paths */\n    78→  } catch (err) {\n    79→    const message = err instanceof Error ? err.message : String(err);\n    80→    return fail(`Container cleanup failed: ${message}`);\n    81→  }\n    82→  /* c8 ignore stop */\n    83→}\n    84→"}]},"parent_tool_use_id":"toolu_01NrzDLhF9NNDZQrr8WemqQC","session_id":"174e0897-5fbc-4ae0-bbc6-8b881d5c7525","uuid":"64cade57-2433-4397-a18b-fd850436321d","timestamp":"2026-03-24T22:52:26.220Z"}
