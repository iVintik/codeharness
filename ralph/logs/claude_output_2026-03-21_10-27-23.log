{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xr7T4wjv4X8uB7wpA6Vbnf","type":"tool_result","content":"     1→/**\n     2→ * Runtime coverage computation — tracks observability coverage from verification proofs.\n     3→ *\n     4→ * Implements Story 2.1: computes runtime coverage from parsed observability gaps\n     5→ * and persists results to sprint-state.json under `observability.runtime`.\n     6→ * Separate from `coverage.ts` (static coverage) per architecture Decision 2.\n     7→ */\n     8→\n     9→import { readFileSync, writeFileSync, renameSync, existsSync } from 'node:fs';\n    10→import { join } from 'node:path';\n    11→import { ok, fail } from '../../types/result.js';\n    12→import type { Result } from '../../types/result.js';\n    13→import type { RuntimeCoverageResult, RuntimeCoverageEntry } from './types.js';\n    14→import type { ObservabilityGapResult } from '../verify/index.js';\n    15→\n    16→const STATE_FILE = 'sprint-state.json';\n    17→const TMP_FILE = '.sprint-state.json.tmp';\n    18→\n    19→/**\n    20→ * Compute runtime coverage from parsed observability gap results.\n    21→ *\n    22→ * Coverage = acsWithLogs / totalACs * 100.\n    23→ * Returns 0% coverage when totalACs is 0 (avoids division by zero).\n    24→ */\n    25→export function computeRuntimeCoverage(\n    26→  gapResults: ObservabilityGapResult,\n    27→): RuntimeCoverageResult {\n    28→  const entries: RuntimeCoverageEntry[] = gapResults.entries.map(entry => ({\n    29→    acId: entry.acId,\n    30→    logEventsDetected: !entry.hasGap,\n    31→    logEventCount: entry.hasGap ? 0 : 1, // Binary: gap means 0, no gap means at least 1\n    32→    gapNote: entry.gapNote,\n    33→  }));\n    34→\n    35→  const totalACs = gapResults.totalACs;\n    36→  const acsWithLogs = gapResults.coveredCount;\n    37→  const coveragePercent = totalACs === 0 ? 0 : (acsWithLogs / totalACs) * 100;\n    38→\n    39→  return { entries, totalACs, acsWithLogs, coveragePercent };\n    40→}\n    41→\n    42→/**\n    43→ * Persist runtime coverage results to sprint-state.json under `observability.runtime`.\n    44→ *\n    45→ * Uses atomic write (write to temp, then rename) to prevent corruption.\n    46→ * Preserves all existing state fields including static coverage data.\n    47→ */\n    48→export function saveRuntimeCoverage(\n    49→  projectDir: string,\n    50→  result: RuntimeCoverageResult,\n    51→): Result<void> {\n    52→  if (!projectDir || typeof projectDir !== 'string') {\n    53→    return fail('projectDir is required and must be a non-empty string');\n    54→  }\n    55→\n    56→  // Read existing state\n    57→  const fp = join(projectDir, STATE_FILE);\n    58→  let state: Record<string, unknown> = {};\n    59→\n    60→  if (existsSync(fp)) {\n    61→    try {\n    62→      const raw = readFileSync(fp, 'utf-8');\n    63→      state = JSON.parse(raw) as Record<string, unknown>;\n    64→    } catch (err: unknown) {\n    65→      const msg = err instanceof Error ? err.message : String(err);\n    66→      return fail(`Failed to read ${STATE_FILE}: ${msg}`);\n    67→    }\n    68→  }\n    69→\n    70→  // Preserve existing observability section\n    71→  const existingObs = (state.observability as Record<string, unknown>) ?? {};\n    72→\n    73→  const runtimeState = {\n    74→    coveragePercent: result.coveragePercent,\n    75→    lastValidationTimestamp: new Date().toISOString(),\n    76→    modulesWithTelemetry: result.acsWithLogs,\n    77→    totalModules: result.totalACs,\n    78→    telemetryDetected: result.acsWithLogs > 0,\n    79→  };\n    80→\n    81→  // Preserve existing targets and add runtimeTarget default if missing\n    82→  const existingTargets = (existingObs.targets as Record<string, unknown>) ?? {};\n    83→  const targets = {\n    84→    ...existingTargets,\n    85→    runtimeTarget:\n    86→      typeof existingTargets.runtimeTarget === 'number'\n    87→        ? existingTargets.runtimeTarget\n    88→        : 60,\n    89→  };\n    90→\n    91→  const updatedState = {\n    92→    ...state,\n    93→    observability: {\n    94→      ...existingObs,\n    95→      runtime: runtimeState,\n    96→      targets,\n    97→    },\n    98→  };\n    99→\n   100→  // Atomic write\n   101→  try {\n   102→    const data = JSON.stringify(updatedState, null, 2) + '\\n';\n   103→    const tmp = join(projectDir, TMP_FILE);\n   104→    const finalPath = join(projectDir, STATE_FILE);\n   105→    writeFileSync(tmp, data, 'utf-8');\n   106→    renameSync(tmp, finalPath);\n   107→    return ok(undefined);\n   108→  } catch (err: unknown) {\n   109→    const msg = err instanceof Error ? err.message : String(err);\n   110→    return fail(`Failed to write ${STATE_FILE}: ${msg}`);\n   111→  }\n   112→}\n   113→"}]},"parent_tool_use_id":"toolu_01XPwSJXFDAHM6Py9mHqpeeW","session_id":"63766b2b-ee05-46af-a819-a3f0370845d2","uuid":"b71e899c-7cd2-4fbc-a032-c73682961ac3","timestamp":"2026-03-21T06:32:56.637Z"}
