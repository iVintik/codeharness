{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BT2DeBRkwDK5vNBw8y91oQ","type":"tool_result","content":"     1→/**\n     2→ * Coverage state persistence — tracks observability coverage in sprint-state.json.\n     3→ *\n     4→ * Implements Story 1.3: read/write/trend/target comparison for static analysis coverage.\n     5→ * Only the `static` section is managed here; `runtime` is deferred to Epic 2.\n     6→ */\n     7→\n     8→import { readFileSync, writeFileSync, renameSync, existsSync } from 'node:fs';\n     9→import { join } from 'node:path';\n    10→import { ok, fail } from '../../types/result.js';\n    11→import type { Result } from '../../types/result.js';\n    12→import type {\n    13→  AnalyzerResult,\n    14→  ObservabilityCoverageState,\n    15→  CoverageTrend,\n    16→  CoverageTargetResult,\n    17→  RuntimeCoverageState,\n    18→} from './types.js';\n    19→\n    20→const STATE_FILE = 'sprint-state.json';\n    21→const TMP_FILE = '.sprint-state.json.tmp';\n    22→const DEFAULT_STATIC_TARGET = 80;\n    23→const MAX_HISTORY_ENTRIES = 100;\n    24→\n    25→/**\n    26→ * Default observability coverage state when none exists.\n    27→ */\n    28→function defaultCoverageState(): ObservabilityCoverageState {\n    29→  return {\n    30→    static: {\n    31→      coveragePercent: 0,\n    32→      lastScanTimestamp: '',\n    33→      history: [],\n    34→    },\n    35→    targets: {\n    36→      staticTarget: DEFAULT_STATIC_TARGET,\n    37→    },\n    38→  };\n    39→}\n    40→\n    41→/**\n    42→ * Read the full sprint-state.json as a generic record.\n    43→ */\n    44→function readStateFile(projectDir: string): Result<Record<string, unknown>> {\n    45→  const fp = join(projectDir, STATE_FILE);\n    46→  if (!existsSync(fp)) {\n    47→    return ok({});\n    48→  }\n    49→  try {\n    50→    const raw = readFileSync(fp, 'utf-8');\n    51→    const parsed = JSON.parse(raw) as Record<string, unknown>;\n    52→    return ok(parsed);\n    53→  } catch (err: unknown) {\n    54→    const msg = err instanceof Error ? err.message : String(err);\n    55→    return fail(`Failed to read ${STATE_FILE}: ${msg}`);\n    56→  }\n    57→}\n    58→\n    59→/**\n    60→ * Write sprint-state.json atomically (write to temp, then rename).\n    61→ */\n    62→function writeStateAtomic(\n    63→  projectDir: string,\n    64→  state: Record<string, unknown>,\n    65→): Result<void> {\n    66→  try {\n    67→    const data = JSON.stringify(state, null, 2) + '\\n';\n    68→    const tmp = join(projectDir, TMP_FILE);\n    69→    const final = join(projectDir, STATE_FILE);\n    70→    writeFileSync(tmp, data, 'utf-8');\n    71→    renameSync(tmp, final);\n    72→    return ok(undefined);\n    73→  } catch (err: unknown) {\n    74→    const msg = err instanceof Error ? err.message : String(err);\n    75→    return fail(`Failed to write ${STATE_FILE}: ${msg}`);\n    76→  }\n    77→}\n    78→\n    79→/**\n    80→ * Save coverage result from an analysis run into sprint-state.json.\n    81→ *\n    82→ * Updates `observability.static.coveragePercent`, `observability.static.lastScanTimestamp`,\n    83→ * and appends to `observability.static.history`. Preserves all other state fields.\n    84→ */\n    85→export function saveCoverageResult(\n    86→  projectDir: string,\n    87→  result: AnalyzerResult,\n    88→): Result<void> {\n    89→  if (!projectDir || typeof projectDir !== 'string') {\n    90→    return fail('projectDir is required and must be a non-empty string');\n    91→  }\n    92→\n    93→  const stateResult = readStateFile(projectDir);\n    94→  if (!stateResult.success) {\n    95→    return fail(stateResult.error);\n    96→  }\n    97→\n    98→  const state = stateResult.data;\n    99→  const existing = extractCoverageState(state);\n   100→  const timestamp = new Date().toISOString();\n   101→\n   102→  const fullHistory = [\n   103→    ...existing.static.history,\n   104→    { coveragePercent: result.summary.coveragePercent, timestamp },\n   105→  ];\n   106→  // Keep only the most recent entries to prevent unbounded growth\n   107→  const trimmedHistory =\n   108→    fullHistory.length > MAX_HISTORY_ENTRIES\n   109→      ? fullHistory.slice(fullHistory.length - MAX_HISTORY_ENTRIES)\n   110→      : fullHistory;\n   111→\n   112→  const updatedStatic = {\n   113→    coveragePercent: result.summary.coveragePercent,\n   114→    lastScanTimestamp: timestamp,\n   115→    history: trimmedHistory,\n   116→  };\n   117→\n   118→  const updatedObservability: ObservabilityCoverageState = {\n   119→    static: updatedStatic,\n   120→    targets: existing.targets,\n   121→    ...(existing.runtime ? { runtime: existing.runtime } : {}),\n   122→  };\n   123→\n   124→  const updatedState = {\n   125→    ...state,\n   126→    observability: updatedObservability,\n   127→  };\n   128→\n   129→  return writeStateAtomic(projectDir, updatedState);\n   130→}\n   131→\n   132→/**\n   133→ * Read the observability coverage state from sprint-state.json.\n   134→ *\n   135→ * Returns the typed `ObservabilityCoverageState` from the `observability` key.\n   136→ * If no observability section exists, returns default state.\n   137→ */\n   138→export function readCoverageState(\n   139→  projectDir: string,\n   140→): Result<ObservabilityCoverageState> {\n   141→  if (!projectDir || typeof projectDir !== 'string') {\n   142→    return fail('projectDir is required and must be a non-empty string');\n   143→  }\n   144→\n   145→  const stateResult = readStateFile(projectDir);\n   146→  if (!stateResult.success) {\n   147→    return fail(stateResult.error);\n   148→  }\n   149→\n   150→  return ok(extractCoverageState(stateResult.data));\n   151→}\n   152→\n   153→/**\n   154→ * Get coverage trend by comparing latest vs previous history entries.\n   155→ */\n   156→export function getCoverageTrend(projectDir: string): Result<CoverageTrend> {\n   157→  if (!projectDir || typeof projectDir !== 'string') {\n   158→    return fail('projectDir is required and must be a non-empty string');\n   159→  }\n   160→\n   161→  const stateResult = readCoverageState(projectDir);\n   162→  if (!stateResult.success) {\n   163→    return fail(stateResult.error);\n   164→  }\n   165→\n   166→  const { history } = stateResult.data.static;\n   167→\n   168→  if (history.length === 0) {\n   169→    return ok({\n   170→      current: 0,\n   171→      previous: null,\n   172→      delta: null,\n   173→      currentTimestamp: '',\n   174→      previousTimestamp: null,\n   175→    });\n   176→  }\n   177→\n   178→  const latest = history[history.length - 1];\n   179→\n   180→  if (history.length === 1) {\n   181→    return ok({\n   182→      current: latest.coveragePercent,\n   183→      previous: null,\n   184→      delta: null,\n   185→      currentTimestamp: latest.timestamp,\n   186→      previousTimestamp: null,\n   187→    });\n   188→  }\n   189→\n   190→  const prev = history[history.length - 2];\n   191→  return ok({\n   192→    current: latest.coveragePercent,\n   193→    previous: prev.coveragePercent,\n   194→    delta: latest.coveragePercent - prev.coveragePercent,\n   195→    currentTimestamp: latest.timestamp,\n   196→    previousTimestamp: prev.timestamp,\n   197→  });\n   198→}\n   199→\n   200→/**\n   201→ * Check current coverage against a target threshold.\n   202→ *\n   203→ * @param projectDir - Project root directory\n   204→ * @param target - Target percentage (default 80%)\n   205→ * @returns Structured result indicating whether coverage meets the target\n   206→ */\n   207→export function checkCoverageTarget(\n   208→  projectDir: string,\n   209→  target?: number,\n   210→): Result<CoverageTargetResult> {\n   211→  if (!projectDir || typeof projectDir !== 'string') {\n   212→    return fail('projectDir is required and must be a non-empty string');\n   213→  }\n   214→\n   215→  const stateResult = readCoverageState(projectDir);\n   216→  if (!stateResult.success) {\n   217→    return fail(stateResult.error);\n   218→  }\n   219→\n   220→  const effectiveTarget = target ?? stateResult.data.targets.staticTarget;\n   221→  const current = stateResult.data.static.coveragePercent;\n   222→  const met = current >= effectiveTarget;\n   223→  const gap = met ? 0 : effectiveTarget - current;\n   224→\n   225→  return ok({ met, current, target: effectiveTarget, gap });\n   226→}\n   227→\n   228→/**\n   229→ * Extract typed ObservabilityCoverageState from raw sprint-state.json data.\n   230→ * Returns defaults when the observability section doesn't exist.\n   231→ */\n   232→function extractCoverageState(\n   233→  state: Record<string, unknown>,\n   234→): ObservabilityCoverageState {\n   235→  const obs = state.observability as Record<string, unknown> | undefined;\n   236→  if (!obs) {\n   237→    return defaultCoverageState();\n   238→  }\n   239→\n   240→  const staticSection = obs.static as Record<string, unknown> | undefined;\n   241→  const targets = obs.targets as Record<string, unknown> | undefined;\n   242→  const runtimeSection = obs.runtime as Record<string, unknown> | undefined;\n   243→\n   244→  const runtime: RuntimeCoverageState | undefined =\n   245→    runtimeSection && typeof runtimeSection.coveragePercent === 'number'\n   246→      ? {\n   247→          coveragePercent: runtimeSection.coveragePercent,\n   248→          lastValidationTimestamp:\n   249→            typeof runtimeSection.lastValidationTimestamp === 'string'\n   250→              ? runtimeSection.lastValidationTimestamp : '',\n   251→          modulesWithTelemetry:\n   252→            typeof runtimeSection.modulesWithTelemetry === 'number'\n   253→              ? runtimeSection.modulesWithTelemetry : 0,\n   254→          totalModules:\n   255→            typeof runtimeSection.totalModules === 'number'\n   256→              ? runtimeSection.totalModules : 0,\n   257→          telemetryDetected:\n   258→            typeof runtimeSection.telemetryDetected === 'boolean'\n   259→              ? runtimeSection.telemetryDetected : false,\n   260→        }\n   261→      : undefined;\n   262→\n   263→  const result: ObservabilityCoverageState = {\n   264→    static: {\n   265→      coveragePercent:\n   266→        typeof staticSection?.coveragePercent === 'number'\n   267→          ? staticSection.coveragePercent\n   268→          : 0,\n   269→      lastScanTimestamp:\n   270→        typeof staticSection?.lastScanTimestamp === 'string'\n   271→          ? staticSection.lastScanTimestamp\n   272→          : '',\n   273→      history: Array.isArray(staticSection?.history)\n   274→        ? (staticSection.history as unknown[]).filter(\n   275→            (entry): entry is { coveragePercent: number; timestamp: string } =>\n   276→              typeof entry === 'object' &&\n   277→              entry !== null &&\n   278→              typeof (entry as Record<string, unknown>).coveragePercent ===\n   279→                'number' &&\n   280→              typeof (entry as Record<string, unknown>).timestamp === 'string',\n   281→          )\n   282→        : [],\n   283→    },\n   284→    targets: {\n   285→      staticTarget:\n   286→        typeof targets?.staticTarget === 'number'\n   287→          ? targets.staticTarget\n   288→          : DEFAULT_STATIC_TARGET,\n   289→      ...(typeof targets?.runtimeTarget === 'number'\n   290→        ? { runtimeTarget: targets.runtimeTarget }\n   291→        : {}),\n   292→    },\n   293→    ...(runtime ? { runtime } : {}),\n   294→  };\n   295→\n   296→  return result;\n   297→}\n   298→"}]},"parent_tool_use_id":"toolu_01HaJKsv5YrKWXVV5tMae9v1","session_id":"2fa32674-558d-4231-8eb7-1997dc535a41","uuid":"aaf852d8-dcfb-4856-b363-6632bdbf91f6","timestamp":"2026-03-20T06:15:34.762Z"}
