{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Haw7pVuVXVtaSheWqboC1g","type":"tool_result","content":"748\t  // --- Story 9.2: Custom Workflow Creation ---\n749\t\n750\t  describe('custom workflow by name (Story 9.2)', () => {\n751\t    it('loads a custom workflow from .codeharness/workflows/{name}.yaml by name', () => {\n752\t      const customDir = join(testDir, '.codeharness', 'workflows');\n753\t      mkdirSync(customDir, { recursive: true });\n754\t\n755\t      writeFileSync(join(customDir, 'my-workflow.yaml'), `\n756\ttasks:\n757\t  deploy:\n758\t    agent: deployer\n759\tflow:\n760\t  - deploy\n761\t`, 'utf-8');\n762\t\n763\t      const result = resolveWorkflow({ cwd: testDir, name: 'my-workflow' });\n764\t      expect(result.tasks.deploy).toBeDefined();\n765\t      expect(result.tasks.deploy.agent).toBe('deployer');\n766\t      expect(result.flow).toEqual(['deploy']);\n767\t    });\n768\t\n769\t    it('custom workflow fails schema validation — throws WorkflowParseError', () => {\n770\t      const customDir = join(testDir, '.codeharness', 'workflows');\n771\t      mkdirSync(customDir, { recursive: true });\n772\t\n773\t      // Missing tasks key entirely\n774\t      writeFileSync(join(customDir, 'bad-schema.yaml'), `\n775\tflow:\n776\t  - deploy\n777\t`, 'utf-8');\n778\t\n779\t      expect(() => resolveWorkflow({ cwd: testDir, name: 'bad-schema' })).toThrow(WorkflowParseError);\n780\t      try {\n781\t        resolveWorkflow({ cwd: testDir, name: 'bad-schema' });\n782\t      } catch (err) {\n783\t        const pe = err as WorkflowParseError;\n784\t        expect(pe.message).toContain('Schema validation failed');\n785\t        expect(pe.errors.length).toBeGreaterThan(0);\n786\t      }\n787\t    });\n788\t\n789\t    it('custom workflow passes schema but has dangling flow refs — throws WorkflowParseError', () => {\n790\t      const customDir = join(testDir, '.codeharness', 'workflows');\n791\t      mkdirSync(customDir, { recursive: true });\n792\t\n793\t      writeFileSync(join(customDir, 'dangling.yaml'), `\n794\ttasks:\n795\t  deploy:\n796\t    agent: deployer\n797\tflow:\n798\t  - deploy\n799\t  - nonexistent\n800\t`, 'utf-8');\n801\t\n802\t      expect(() => resolveWorkflow({ cwd: testDir, name: 'dangling' })).toThrow(WorkflowParseError);\n803\t      try {\n804\t        resolveWorkflow({ cwd: testDir, name: 'dangling' });\n805\t      } catch (err) {\n806\t        const pe = err as WorkflowParseError;\n807\t        expect(pe.message).toContain('Dangling task references');\n808\t        expect(pe.errors.some((e) => e.message.includes('nonexistent'))).toBe(true);\n809\t      }\n810\t    });\n811\t\n812\t    it('resolveWorkflow({ name: \"nonexistent\" }) with no matching file throws clear error', () => {\n813\t      expect(() => resolveWorkflow({ cwd: testDir, name: 'nonexistent' })).toThrow(WorkflowParseError);\n814\t      try {\n815\t        resolveWorkflow({ cwd: testDir, name: 'nonexistent' });\n816\t      } catch (err) {\n817\t        const pe = err as WorkflowParseError;\n818\t        expect(pe.message).toContain('Embedded workflow not found: nonexistent');\n819\t      }\n820\t    });\n821\t\n822\t    it('resolveWorkflow() with no name defaults to \"default\" — backward-compatible', () => {\n823\t      const result = resolveWorkflow({ cwd: testDir });\n824\t      // Should load embedded default without error\n825\t      expect(result.tasks).toBeDefined();\n826\t      expect(result.tasks.implement).toBeDefined();\n827\t      expect(result.flow.length).toBeGreaterThan(0);\n828\t    });\n829\t\n830\t    it('custom workflow with extends key is NOT treated as full custom (falls to patch resolution)', () => {\n831\t      const customDir = join(testDir, '.codeharness', 'workflows');\n832\t      mkdirSync(customDir, { recursive: true });\n833\t\n834\t      // This has extends, so it should be treated as a patch-like file, not a full custom workflow\n835\t      // Since the name is 'ci' and there is no embedded 'ci' template, this should throw\n836\t      writeFileSync(join(customDir, 'ci.yaml'), `\n837\textends: embedded://default\n838\toverrides:\n839\t  tasks:\n840\t    implement:\n841\t      session: continue\n842\t`, 'utf-8');\n843\t\n844\t      // With extends, it's not treated as a full custom workflow.\n845\t      // It tries to load embedded 'ci' template which doesn't exist => error\n846\t      expect(() => resolveWorkflow({ cwd: testDir, name: 'ci' })).toThrow(WorkflowParseError);\n847\t      try {\n848\t        resolveWorkflow({ cwd: testDir, name: 'ci' });\n849\t      } catch (err) {\n850\t        const pe = err as WorkflowParseError;\n851\t        expect(pe.message).toContain('Embedded workflow not found: ci');\n852\t      }\n853\t    });\n854\t\n855\t    it('custom workflow alongside patch file: patch is ignored for full custom workflows', () => {\n856\t      const customDir = join(testDir, '.codeharness', 'workflows');\n857\t      mkdirSync(customDir, { recursive: true });\n858\t\n859\t      // Full custom workflow (no extends)\n860\t      writeFileSync(join(customDir, 'ci.yaml'), `\n861\ttasks:\n862\t  build:\n863\t    agent: builder\n864\tflow:\n865\t  - build\n866\t`, 'utf-8');\n867\t\n868\t      // Patch file that would change agent — should be ignored\n869\t      writeFileSync(join(customDir, 'ci.patch.yaml'), `\n870\textends: embedded://default\n871\toverrides:\n872\t  tasks:\n873\t    build:\n874\t      agent: patched-builder\n875\t`, 'utf-8');\n876\t\n877\t      const result = resolveWorkflow({ cwd: testDir, name: 'ci' });\n878\t      expect(result.tasks.build.agent).toBe('builder'); // Not patched\n879\t    });\n880\t\n881\t    it('custom workflow with custom agent names resolves agent field correctly', () => {\n882\t      const customDir = join(testDir, '.codeharness', 'workflows');\n883\t      mkdirSync(customDir, { recursive: true });\n884\t\n885\t      writeFileSync(join(customDir, 'multi-agent.yaml'), `\n886\ttasks:\n887\t  build:\n888\t    agent: my-custom-builder\n889\t  test:\n890\t    agent: my-custom-tester\n891\t  deploy:\n892\t    agent: my-custom-deployer\n893\tflow:\n894\t  - build\n895\t  - test\n896\t  - deploy\n897\t`, 'utf-8');\n898\t\n899\t      const result = resolveWorkflow({ cwd: testDir, name: 'multi-agent' });\n900\t      expect(result.tasks.build.agent).toBe('my-custom-builder');\n901\t      expect(result.tasks.test.agent).toBe('my-custom-tester');\n902\t      expect(result.tasks.deploy.agent).toBe('my-custom-deployer');\n903\t    });\n904\t  });\n905\t});\n906\t"}]},"parent_tool_use_id":"toolu_01RP7o3BVkPNLNUsnWp84iwa","session_id":"c2800ecc-75a3-43b2-b3d8-396855aa3c3c","uuid":"ca2947ab-497c-4c6a-bcf3-713c35e68195","timestamp":"2026-04-03T03:15:55.835Z"}
