{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017k5Q2reG64buB3D5QW1EG6","type":"tool_result","content":"     1→/**\n     2→ * Sprint state — read/write unified sprint-state.json with atomic writes.\n     3→ * Also generates sprint-status.yaml as a derived human-readable view.\n     4→ */\n     5→\n     6→import { readFileSync, writeFileSync, renameSync, existsSync, unlinkSync } from 'node:fs';\n     7→import { join, dirname } from 'node:path';\n     8→import { ok, fail } from '../../types/result.js';\n     9→import type { Result } from '../../types/result.js';\n    10→import type { SprintState, SprintStateAny, StoryStatus, StoryState, EpicState } from '../../types/state.js';\n    11→import type { StoryDetail, RunProgressUpdate } from './types.js';\n    12→import { migrateFromOldFormat, migrateV1ToV2, parseStoryRetriesRecord, parseFlaggedStoriesList } from './migration.js';\n    13→import { readSprintStatus } from '../../lib/sync/index.js';\n    14→\n    15→/** Result of state reconciliation */\n    16→export interface ReconciliationResult {\n    17→  readonly corrections: string[];\n    18→  readonly stateChanged: boolean;\n    19→}\n    20→\n    21→/** Resolve project root (directory containing package.json) */\n    22→function projectRoot(): string {\n    23→  return process.cwd();\n    24→}\n    25→\n    26→/** Path to the sprint state file */\n    27→export function statePath(): string {\n    28→  return join(projectRoot(), 'sprint-state.json');\n    29→}\n    30→\n    31→/** Path to the temporary file used for atomic writes */\n    32→function tmpPath(): string {\n    33→  return join(projectRoot(), '.sprint-state.json.tmp');\n    34→}\n    35→\n    36→/** Path to the sprint-status.yaml file (derived view) */\n    37→export function sprintStatusYamlPath(): string {\n    38→  return join(projectRoot(), '_bmad-output', 'implementation-artifacts', 'sprint-status.yaml');\n    39→}\n    40→\n    41→/** Return an empty default SprintState (v2) */\n    42→export function defaultState(): SprintState {\n    43→  return {\n    44→    version: 2,\n    45→    sprint: {\n    46→      total: 0,\n    47→      done: 0,\n    48→      failed: 0,\n    49→      blocked: 0,\n    50→      inProgress: null,\n    51→    },\n    52→    stories: {},\n    53→    retries: {},\n    54→    flagged: [],\n    55→    epics: {},\n    56→    session: {\n    57→      active: false,\n    58→      startedAt: null,\n    59→      iteration: 0,\n    60→      elapsedSeconds: 0,\n    61→    },\n    62→    observability: {\n    63→      statementCoverage: null,\n    64→      branchCoverage: null,\n    65→      functionCoverage: null,\n    66→      lineCoverage: null,\n    67→    },\n    68→    run: {\n    69→      active: false,\n    70→      startedAt: null,\n    71→      iteration: 0,\n    72→      cost: 0,\n    73→      completed: [],\n    74→      failed: [],\n    75→      currentStory: null,\n    76→      currentPhase: null,\n    77→      lastAction: null,\n    78→      acProgress: null,\n    79→    },\n    80→    actionItems: [],\n    81→  };\n    82→}\n    83→\n    84→/** Return a default StoryState */\n    85→function defaultStoryState(): StoryState {\n    86→  return {\n    87→    status: 'backlog',\n    88→    attempts: 0,\n    89→    lastAttempt: null,\n    90→    lastError: null,\n    91→    proofPath: null,\n    92→    acResults: null,\n    93→  };\n    94→}\n    95→\n    96→/**\n    97→ * Derive a flat story-key → status map from sprint state.\n    98→ * This replaces the old `readSprintStatus()` which parsed YAML.\n    99→ * Only includes story keys (digit-digit-name pattern), not epic keys.\n   100→ */\n   101→export function getStoryStatusesFromState(state: SprintState): Record<string, string> {\n   102→  const result: Record<string, string> = {};\n   103→  for (const [key, story] of Object.entries(state.stories)) {\n   104→    result[key] = story.status;\n   105→  }\n   106→  return result;\n   107→}\n   108→\n   109→/**\n   110→ * Map internal StoryStatus values to sprint-status.yaml status strings.\n   111→ * Most map 1:1, but 'ready' maps to 'ready-for-dev' for YAML compatibility.\n   112→ */\n   113→function yamlStatus(status: StoryStatus): string {\n   114→  if (status === 'ready') return 'ready-for-dev';\n   115→  return status;\n   116→}\n   117→\n   118→/**\n   119→ * Generate sprint-status.yaml content from sprint state.\n   120→ * Groups stories by epic prefix and produces the same YAML structure\n   121→ * that existed as the hand-maintained file.\n   122→ */\n   123→export function generateSprintStatusYaml(state: SprintState): string {\n   124→  const lines: string[] = [\n   125→    '# codeharness Sprint Status (auto-generated from sprint-state.json)',\n   126→    `# generated: ${new Date().toISOString().slice(0, 10)}`,\n   127→    '# This file is a derived view — do NOT edit manually.',\n   128→    '# Source of truth: sprint-state.json',\n   129→    '',\n   130→    'development_status:',\n   131→  ];\n   132→\n   133→  // Group stories by epic prefix (first number segment, or 'TD' for TD- stories)\n   134→  const epicGroups = new Map<string, string[]>();\n   135→  const sortedKeys = Object.keys(state.stories).sort((a, b) => {\n   136→    // Sort by epic number, then story number (TD stories sort last)\n   137→    const [aEpic, aStory] = parseStoryKey(a);\n   138→    const [bEpic, bStory] = parseStoryKey(b);\n   139→    if (aEpic !== bEpic) return aEpic - bEpic;\n   140→    return aStory - bStory;\n   141→  });\n   142→\n   143→  for (const key of sortedKeys) {\n   144→    const epicKey = getEpicGroupKey(key);\n   145→    if (!epicGroups.has(epicKey)) {\n   146→      epicGroups.set(epicKey, []);\n   147→    }\n   148→    epicGroups.get(epicKey)!.push(key);\n   149→  }\n   150→\n   151→  // Emit each epic group\n   152→  for (const [epicKey, storyKeys] of epicGroups) {\n   153→    lines.push('');\n   154→    lines.push(`  # Epic ${epicKey}`);\n   155→\n   156→    // Compute epic status from stories\n   157→    // epic-TD is always in-progress regardless of story statuses\n   158→    let epicStatus: string;\n   159→    if (epicKey === 'TD') {\n   160→      epicStatus = 'in-progress';\n   161→    } else {\n   162→      const allDone = storyKeys.every(k => state.stories[k].status === 'done');\n   163→      epicStatus = allDone ? 'done' : 'backlog';\n   164→    }\n   165→    lines.push(`  epic-${epicKey}: ${epicStatus}`);\n   166→\n   167→    for (const key of storyKeys) {\n   168→      const story = state.stories[key];\n   169→      lines.push(`  ${key}: ${yamlStatus(story.status)}`);\n   170→    }\n   171→  }\n   172→\n   173→  lines.push('');\n   174→  return lines.join('\\n');\n   175→}\n   176→\n   177→/**\n   178→ * Parse a story key into [epicNumber, storyNumber].\n   179→ * e.g. \"11-2-sprint-status-yaml-derived-view\" → [11, 2]\n   180→ * TD-prefix stories (e.g. \"TD-1-slug\") return [Infinity, storyNumber].\n   181→ */\n   182→function parseStoryKey(key: string): [number, number] {\n   183→  // Handle TD-prefix stories\n   184→  const tdMatch = key.match(/^TD-(\\d+)/);\n   185→  if (tdMatch) return [Infinity, parseInt(tdMatch[1], 10)];\n   186→  const match = key.match(/^(\\d+)-(\\d+)/);\n   187→  if (!match) return [Infinity, Infinity];\n   188→  return [parseInt(match[1], 10), parseInt(match[2], 10)];\n   189→}\n   190→\n   191→/**\n   192→ * Get the epic group key for a story key.\n   193→ * Returns 'TD' for TD-prefix stories, or the numeric epic prefix as string.\n   194→ */\n   195→function getEpicGroupKey(key: string): string {\n   196→  if (key.startsWith('TD-')) return 'TD';\n   197→  const match = key.match(/^(\\d+)-/);\n   198→  return match ? match[1] : String(Infinity);\n   199→}\n   200→\n   201→/**\n   202→ * Write the derived sprint-status.yaml from current state.\n   203→ * Best-effort: failures are silently ignored since this is a convenience view.\n   204→ */\n   205→function writeSprintStatusYaml(state: SprintState): void {\n   206→  try {\n   207→    const yamlPath = sprintStatusYamlPath();\n   208→    // Only write if the directory exists (project has been set up)\n   209→    const dir = dirname(yamlPath);\n   210→    if (!existsSync(dir)) return;\n   211→    const content = generateSprintStatusYaml(state);\n   212→    writeFileSync(yamlPath, content, 'utf-8');\n   213→  } catch {\n   214→    // IGNORE: YAML view write is best-effort, not critical\n   215→  }\n   216→}\n   217→\n   218→/**\n   219→ * Write state to disk atomically: write to tmp, then rename.\n   220→ * Also regenerates sprint-status.yaml as a derived view.\n   221→ */\n   222→export function writeStateAtomic(state: SprintState): Result<void> {\n   223→  try {\n   224→    const data = JSON.stringify(state, null, 2) + '\\n';\n   225→    const tmp = tmpPath();\n   226→    const final = statePath();\n   227→    writeFileSync(tmp, data, 'utf-8');\n   228→    renameSync(tmp, final);\n   229→    // Regenerate YAML view after successful state write\n   230→    writeSprintStatusYaml(state);\n   231→    return ok(undefined);\n   232→  } catch (err: unknown) {\n   233→    const msg = err instanceof Error ? err.message : String(err);\n   234→    return fail(`Failed to write sprint state: ${msg}`);\n   235→  }\n   236→}\n   237→\n   238→/**\n   239→ * Read and parse sprint-state.json.\n   240→ * If the file does not exist, attempt migration from old files.\n   241→ * If no old files exist either, return defaultState().\n   242→ * Automatically migrates v1 state to v2.\n   243→ */\n   244→export function getSprintState(): Result<SprintState> {\n   245→  const fp = statePath();\n   246→\n   247→  if (existsSync(fp)) {\n   248→    try {\n   249→      const raw = readFileSync(fp, 'utf-8');\n   250→      const parsed = JSON.parse(raw) as Record<string, unknown>;\n   251→      const version = parsed.version as number | undefined;\n   252→\n   253→      // Already v2 — merge with defaults and return\n   254→      if (version === 2) {\n   255→        const defaults = defaultState();\n   256→        const run = parsed.run as Record<string, unknown> | undefined;\n   257→        const sprint = parsed.sprint as Record<string, unknown> | undefined;\n   258→        const session = parsed.session as Record<string, unknown> | undefined;\n   259→        const observability = parsed.observability as Record<string, unknown> | undefined;\n   260→        const state: SprintState = {\n   261→          ...(parsed as unknown as SprintState),\n   262→          sprint: {\n   263→            ...defaults.sprint,\n   264→            ...(sprint as unknown as SprintState['sprint']),\n   265→          },\n   266→          run: {\n   267→            ...defaults.run,\n   268→            ...(run as unknown as SprintState['run']),\n   269→          },\n   270→          session: {\n   271→            ...defaults.session,\n   272→            ...(session as unknown as SprintState['session']),\n   273→          },\n   274→          observability: {\n   275→            ...defaults.observability,\n   276→            ...(observability as unknown as SprintState['observability']),\n   277→          },\n   278→          stories: (parsed.stories as Record<string, import('../../types/state.js').StoryState>) ?? {},\n   279→          retries: (parsed.retries as Record<string, number>) ?? {},\n   280→          flagged: (parsed.flagged as string[]) ?? [],\n   281→          epics: (parsed.epics as Record<string, import('../../types/state.js').EpicState>) ?? {},\n   282→          actionItems: (parsed.actionItems as string[]) ?? [],\n   283→        };\n   284→        return ok(state);\n   285→      }\n   286→\n   287→      // v1 or missing version — migrate to v2\n   288→      const v1State = parsed as unknown as import('../../types/state.js').SprintStateV1;\n   289→      const migrated = migrateV1ToV2(v1State);\n   290→      const writeResult = writeStateAtomic(migrated);\n   291→      if (!writeResult.success) {\n   292→        return fail(writeResult.error);\n   293→      }\n   294→      return ok(migrated);\n   295→    } catch (err: unknown) {\n   296→      const msg = err instanceof Error ? err.message : String(err);\n   297→      return fail(`Failed to read sprint state: ${msg}`);\n   298→    }\n   299→  }\n   300→\n   301→  // No sprint-state.json — try migration from old scattered files\n   302→  const migrationResult = migrateFromOldFormat();\n   303→  if (migrationResult.success) {\n   304→    return migrationResult;\n   305→  }\n   306→\n   307→  // Migration found nothing or failed — return default\n   308→  return ok(defaultState());\n   309→}\n   310→\n   311→/** Recompute sprint summary counts from story data */\n   312→export function computeSprintCounts(\n   313→  stories: Record<string, StoryState>,\n   314→): SprintState['sprint'] {\n   315→  let total = 0;\n   316→  let done = 0;\n   317→  let failed = 0;\n   318→  let blocked = 0;\n   319→  let inProgress: string | null = null;\n   320→\n   321→  for (const [key, story] of Object.entries(stories)) {\n   322→    total++;\n   323→    if (story.status === 'done') done++;\n   324→    else if (story.status === 'failed') failed++;\n   325→    else if (story.status === 'blocked') blocked++;\n   326→    else if (story.status === 'in-progress') inProgress = key;\n   327→  }\n   328→\n   329→  return { total, done, failed, blocked, inProgress };\n   330→}\n   331→\n   332→/**\n   333→ * Update a single story's status in sprint-state.json.\n   334→ * Reads current state, merges update, writes atomically.\n   335→ */\n   336→export function updateStoryStatus(\n   337→  key: string,\n   338→  status: StoryStatus,\n   339→  detail?: StoryDetail,\n   340→): Result<void> {\n   341→  const stateResult = getSprintState();\n   342→  if (!stateResult.success) {\n   343→    return fail(stateResult.error);\n   344→  }\n   345→\n   346→  const current = stateResult.data;\n   347→  const existingStory = current.stories[key] ?? defaultStoryState();\n   348→\n   349→  const isNewAttempt = status === 'in-progress';\n   350→\n   351→  const updatedStory: StoryState = {\n   352→    ...existingStory,\n   353→    status,\n   354→    attempts: isNewAttempt\n   355→      ? existingStory.attempts + 1\n   356→      : existingStory.attempts,\n   357→    lastAttempt: isNewAttempt\n   358→      ? new Date().toISOString()\n   359→      : existingStory.lastAttempt,\n   360→    lastError: detail?.error ?? existingStory.lastError,\n   361→    proofPath: detail?.proofPath ?? existingStory.proofPath,\n   362→    acResults: existingStory.acResults,\n   363→  };\n   364→\n   365→  const updatedStories = { ...current.stories, [key]: updatedStory };\n   366→  const updatedSprint = computeSprintCounts(updatedStories);\n   367→\n   368→  const updatedState: SprintState = {\n   369→    ...current,\n   370→    sprint: updatedSprint,\n   371→    stories: updatedStories,\n   372→  };\n   373→\n   374→  return writeStateAtomic(updatedState);\n   375→}\n   376→\n   377→/**\n   378→ * Update live run progress fields in sprint-state.json.\n   379→ * Only provided fields are updated; omitted fields retain their current values.\n   380→ */\n   381→export function updateRunProgress(update: RunProgressUpdate): Result<void> {\n   382→  const stateResult = getSprintState();\n   383→  if (!stateResult.success) {\n   384→    return fail(stateResult.error);\n   385→  }\n   386→\n   387→  const current = stateResult.data;\n   388→  const updatedRun = {\n   389→    ...current.run,\n   390→    ...(update.currentStory !== undefined && { currentStory: update.currentStory }),\n   391→    ...(update.currentPhase !== undefined && { currentPhase: update.currentPhase }),\n   392→    ...(update.lastAction !== undefined && { lastAction: update.lastAction }),\n   393→    ...(update.acProgress !== undefined && { acProgress: update.acProgress }),\n   394→  };\n   395→\n   396→  const updatedState: SprintState = {\n   397→    ...current,\n   398→    run: updatedRun,\n   399→  };\n   400→\n   401→  return writeStateAtomic(updatedState);\n   402→}\n   403→\n   404→/**\n   405→ * Clear all live run progress fields to null.\n   406→ * Called when a story completes or fails.\n   407→ */\n   408→export function clearRunProgress(): Result<void> {\n   409→  const stateResult = getSprintState();\n   410→  if (!stateResult.success) {\n   411→    return fail(stateResult.error);\n   412→  }\n   413→\n   414→  const current = stateResult.data;\n   415→  const updatedState: SprintState = {\n   416→    ...current,\n   417→    run: {\n   418→      ...current.run,\n   419→      currentStory: null,\n   420→      currentPhase: null,\n   421→      lastAction: null,\n   422→      acProgress: null,\n   423→    },\n   424→  };\n   425→\n   426→  return writeStateAtomic(updatedState);\n   427→}\n   428→\n   429→/**\n   430→ * Reconcile sprint state on session start.\n   431→ * Merges orphaned files, validates epic consistency, regenerates YAML.\n   432→ * Best-effort: returns corrections made; callers should log them.\n   433→ */\n   434→export function reconcileState(): Result<ReconciliationResult> {\n   435→  try {\n   436→    // 1. Read current state (handles v1→v2 migration internally)\n   437→    const stateResult = getSprintState();\n   438→    if (!stateResult.success) {\n   439→      return fail(stateResult.error);\n   440→    }\n   441→\n   442→    // Work with a mutable copy\n   443→    const state: SprintState = JSON.parse(JSON.stringify(stateResult.data));\n   444→    const corrections: string[] = [];\n   445→    let changed = false;\n   446→\n   447→    // 2. Merge orphaned .story_retries file\n   448→    const retriesPath = join(projectRoot(), 'ralph', '.story_retries');\n   449→    if (existsSync(retriesPath)) {\n   450→      try {\n   451→        const content = readFileSync(retriesPath, 'utf-8');\n   452→        const fileRetries = parseStoryRetriesRecord(content);\n   453→        const mergedRetries = { ...state.retries };\n   454→        for (const [key, count] of Object.entries(fileRetries)) {\n   455→          if (count > (mergedRetries[key] ?? 0)) {\n   456→            mergedRetries[key] = count;\n   457→            changed = true;\n   458→          }\n   459→        }\n   460→        (state as { retries: Record<string, number> }).retries = mergedRetries;\n   461→        unlinkSync(retriesPath);\n   462→        corrections.push('merged .story_retries into sprint-state.json');\n   463→      } catch {\n   464→        // IGNORE: malformed .story_retries file, delete and move on\n   465→        try { unlinkSync(retriesPath); } catch { /* IGNORE: cleanup failure */ }\n   466→        corrections.push('removed malformed .story_retries file');\n   467→      }\n   468→    }\n   469→\n   470→    // 3. Merge orphaned .flagged_stories file\n   471→    const flaggedPath = join(projectRoot(), 'ralph', '.flagged_stories');\n   472→    if (existsSync(flaggedPath)) {\n   473→      try {\n   474→        const content = readFileSync(flaggedPath, 'utf-8');\n   475→        const fileKeys = parseFlaggedStoriesList(content);\n   476→        const existing = new Set(state.flagged);\n   477→        const merged = [...state.flagged];\n   478→        for (const key of fileKeys) {\n   479→          if (!existing.has(key)) {\n   480→            merged.push(key);\n   481→            existing.add(key);\n   482→            changed = true;\n   483→          }\n   484→        }\n   485→        (state as { flagged: string[] }).flagged = merged;\n   486→        unlinkSync(flaggedPath);\n   487→        corrections.push('merged .flagged_stories into sprint-state.json');\n   488→      } catch {\n   489→        // IGNORE: malformed .flagged_stories file, delete and move on\n   490→        try { unlinkSync(flaggedPath); } catch { /* IGNORE: cleanup failure */ }\n   491→        corrections.push('removed malformed .flagged_stories file');\n   492→      }\n   493→    }\n   494→\n   495→    // 4. Import stories from sprint-status.yaml if stories is empty (unmigrated project)\n   496→    if (Object.keys(state.stories).length === 0) {\n   497→      try {\n   498→        const yamlStatuses = readSprintStatus(projectRoot());\n   499→        const storyKeyPattern = /^\\d+-\\d+-/;\n   500→        for (const [key, status] of Object.entries(yamlStatuses)) {\n   501→          if (!storyKeyPattern.test(key)) continue;\n   502→          state.stories[key] = {\n   503→            status: status as import('../../types/state.js').StoryStatus,\n   504→            attempts: 0,\n   505→            lastAttempt: null,\n   506→            lastError: null,\n   507→            proofPath: null,\n   508→            acResults: null,\n   509→          };\n   510→          changed = true;\n   511→        }\n   512→        if (Object.keys(state.stories).length > 0) {\n   513→          corrections.push(`imported ${Object.keys(state.stories).length} stories from sprint-status.yaml`);\n   514→        }\n   515→      } catch {\n   516→        // IGNORE: sprint-status.yaml may not exist\n   517→      }\n   518→    }\n   519→\n   520→    // 5. Validate epic consistency (renumbered from 4) — ensure every story's epic prefix has an epic entry\n   521→    const epicStories = new Map<string, string[]>();\n   522→    for (const key of Object.keys(state.stories)) {\n   523→      const [epicNum] = parseStoryKey(key);\n   524→      if (epicNum === Infinity) continue; // Not a valid story key\n   525→      const epicKey = `epic-${epicNum}`;\n   526→      if (!epicStories.has(epicKey)) {\n   527→        epicStories.set(epicKey, []);\n   528→      }\n   529→      epicStories.get(epicKey)!.push(key);\n   530→    }\n   531→\n   532→    const updatedEpics: Record<string, import('../../types/state.js').EpicState> = { ...state.epics };\n   533→    for (const [epicKey, storyKeys] of epicStories) {\n   534→      if (!(epicKey in updatedEpics)) {\n   535→        // Compute epic status from its stories\n   536→        const total = storyKeys.length;\n   537→        const doneCount = storyKeys.filter(k => state.stories[k].status === 'done').length;\n   538→        const epicStatus = doneCount === total ? 'done' : 'in-progress';\n   539→        updatedEpics[epicKey] = {\n   540→          status: epicStatus,\n   541→          storiesTotal: total,\n   542→          storiesDone: doneCount,\n   543→        };\n   544→        changed = true;\n   545→        corrections.push(`created missing epic entry: ${epicKey}`);\n   546→      }\n   547→    }\n   548→    (state as { epics: Record<string, import('../../types/state.js').EpicState> }).epics = updatedEpics;\n   549→\n   550→    // 5. Write state atomically if mutations were made (also regenerates YAML),\n   551→    //    otherwise just regenerate YAML standalone (idempotent, cheap).\n   552→    if (changed) {\n   553→      const writeResult = writeStateAtomic(state);\n   554→      if (!writeResult.success) {\n   555→        return fail(writeResult.error);\n   556→      }\n   557→    } else {\n   558→      writeSprintStatusYaml(state);\n   559→    }\n   560→\n   561→    // 7. Note YAML regeneration in corrections if any corrections were made\n   562→    if (corrections.length > 0) {\n   563→      corrections.push('regenerated sprint-status.yaml');\n   564→    }\n   565→\n   566→    return ok({ corrections, stateChanged: changed });\n   567→  } catch (err: unknown) {\n   568→    const msg = err instanceof Error ? err.message : String(err);\n   569→    return fail(`State reconciliation failed: ${msg}`);\n   570→  }\n   571→}\n   572→"}]},"parent_tool_use_id":"toolu_01GTepbYbnTDehnMhc3XqM2y","session_id":"2610e689-589b-4ec2-8784-d06d07275472","uuid":"9e94a215-737e-4b35-84b6-ad8b7ed637d0","timestamp":"2026-03-27T14:54:45.725Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012Y1CpMCEyRDXQcCH37nsG7","type":"tool_result","content":"     1→import { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n     2→import { join, dirname } from 'node:path';\n     3→import { StringDecoder } from 'node:string_decoder';\n     4→import { Command } from 'commander';\n     5→import { fail, info, warn, jsonOutput } from '../lib/output.js';\n     6→import { isDockerAvailable } from '../lib/docker/index.js';\n     7→import { cleanupContainers } from '../modules/infra/index.js';\n     8→import { readSprintStatusFromState, reconcileState, updateStoryStatus, shouldDeferPhase, getPhaseEstimate, computeRemainingMinutes } from '../modules/sprint/index.js';\n     9→import { generateRalphPrompt } from '../lib/agents/ralph-prompt.js';\n    10→import { startRenderer, type SprintInfo } from '../lib/ink-renderer.js';\n    11→import { getSprintState } from '../modules/sprint/index.js';\n    12→import { formatElapsed, mapSprintStatuses, countStories } from '../lib/run-helpers.js';\n    13→import { getDriver } from '../lib/agents/index.js';\n    14→import type { AgentDriver, AgentEvent } from '../lib/agents/types.js';\n    15→import type { RendererHandle } from '../lib/ink-renderer.js';\n    16→\n    17→/** Resolves the plugin directory path (.claude/ in project root). */\n    18→export function resolvePluginDir(): string {\n    19→  return join(process.cwd(), '.claude');\n    20→}\n    21→\n    22→// Re-export helpers that tests import from run.ts\n    23→export { countStories } from '../lib/run-helpers.js';\n    24→\n    25→/** Dispatches an AgentEvent to the appropriate renderer method. */\n    26→function handleAgentEvent(\n    27→  event: AgentEvent,\n    28→  rendererHandle: RendererHandle,\n    29→  state: { currentIterationCount: number },\n    30→): void {\n    31→  switch (event.type) {\n    32→    case 'tool-start':\n    33→    case 'tool-input':\n    34→    case 'tool-complete':\n    35→    case 'text':\n    36→    case 'result':\n    37→    case 'retry':\n    38→      // These AgentEvent types match StreamEvent shapes — pass through to renderer\n    39→      rendererHandle.update(event as Parameters<RendererHandle['update']>[0]);\n    40→      break;\n    41→    case 'story-complete': {\n    42→      // Status ownership: orchestrator writes status, not the subagent (AC 1)\n    43→      const completeResult = updateStoryStatus(event.key, 'review');\n    44→      if (!completeResult.success) {\n    45→        info(`[WARN] Failed to update status for ${event.key}: ${completeResult.error}`);\n    46→      }\n    47→      rendererHandle.addMessage({ type: 'ok', key: event.key, message: event.details });\n    48→      break;\n    49→    }\n    50→    case 'story-failed': {\n    51→      // Status ownership: orchestrator writes status, not the subagent (AC 2)\n    52→      const failResult = updateStoryStatus(event.key, 'failed');\n    53→      if (!failResult.success) {\n    54→        info(`[WARN] Failed to update status for ${event.key}: ${failResult.error}`);\n    55→      }\n    56→      rendererHandle.addMessage({ type: 'fail', key: event.key, message: event.reason });\n    57→      break;\n    58→    }\n    59→    case 'iteration':\n    60→      state.currentIterationCount = event.count;\n    61→      break;\n    62→  }\n    63→}\n    64→\n    65→/** Line splitter: buffers partial lines, calls driver.parseOutput(), dispatches via handleAgentEvent(). */\n    66→function createDriverLineHandler(\n    67→  driver: AgentDriver,\n    68→  rendererHandle: RendererHandle,\n    69→  state: { currentIterationCount: number },\n    70→): (data: Buffer) => void {\n    71→  let partial = '';\n    72→  const decoder = new StringDecoder('utf8');\n    73→  return (data: Buffer): void => {\n    74→    const text = partial + decoder.write(data);\n    75→    const parts = text.split('\\n');\n    76→    partial = parts.pop() ?? '';\n    77→    for (const line of parts) {\n    78→      if (line.trim().length === 0) continue;\n    79→      const event = driver.parseOutput(line);\n    80→      if (event) {\n    81→        handleAgentEvent(event, rendererHandle, state);\n    82→      }\n    83→    }\n    84→  };\n    85→}\n    86→\n    87→export function registerRunCommand(program: Command): void {\n    88→  program\n    89→    .command('run')\n    90→    .description('Execute the autonomous coding loop')\n    91→    .option('--max-iterations <n>', 'Maximum loop iterations', '50')\n    92→    .option('--timeout <seconds>', 'Total loop timeout in seconds', '43200')\n    93→    .option('--iteration-timeout <minutes>', 'Per-iteration timeout in minutes', '30')\n    94→    .option('--quiet', 'Suppress terminal output (background mode)', false)\n    95→    .option('--calls <n>', 'Max API calls per hour', '100')\n    96→    .option('--max-story-retries <n>', 'Max retries per story before flagging', '10')\n    97→    .option('--reset', 'Clear retry counters, flagged stories, and circuit breaker before starting', false)\n    98→    .action(async (options, cmd) => {\n    99→      const globalOpts = cmd.optsWithGlobals();\n   100→      const isJson = !!globalOpts.json;\n   101→      const outputOpts = { json: isJson };\n   102→\n   103→      // 1. Resolve plugin directory\n   104→      const pluginDir = resolvePluginDir();\n   105→      if (!existsSync(pluginDir)) {\n   106→        fail('Plugin directory not found — run codeharness init first', outputOpts);\n   107→        process.exitCode = 1;\n   108→        return;\n   109→      }\n   110→\n   111→      // 1b. Reconcile state (best-effort — failures warn but don't abort)\n   112→      const reconciliation = reconcileState();\n   113→      if (reconciliation.success && reconciliation.data.corrections.length > 0) {\n   114→        for (const correction of reconciliation.data.corrections) {\n   115→          info(`[INFO] Reconciled: ${correction}`, outputOpts);\n   116→        }\n   117→      } else if (!reconciliation.success) {\n   118→        info(`[WARN] State reconciliation failed: ${reconciliation.error}`, outputOpts);\n   119→      }\n   120→\n   121→      // 1c. Docker pre-flight: fail fast if Docker unavailable\n   122→      if (!isDockerAvailable()) {\n   123→        fail('[FAIL] Docker not available — install Docker or start the daemon', outputOpts);\n   124→        process.exitCode = 1;\n   125→        return;\n   126→      }\n   127→      // 1d. Orphan container cleanup (best-effort — failures warn but don't abort)\n   128→      const cleanup = cleanupContainers();\n   129→      if (cleanup.success && cleanup.data.containersRemoved > 0) {\n   130→        info(`[INFO] Cleaned up ${cleanup.data.containersRemoved} orphaned container(s): ${cleanup.data.names.join(', ')}`, outputOpts);\n   131→      } else if (!cleanup.success) {\n   132→        info(`[WARN] Container cleanup failed: ${cleanup.error}`, outputOpts);\n   133→      }\n   134→      // 2. Read sprint status for story count (from sprint-state.json)\n   135→      const projectDir = process.cwd();\n   136→      const sprintStatusPath = join(projectDir, '_bmad-output', 'implementation-artifacts', 'sprint-status.yaml');\n   137→      const statuses = readSprintStatusFromState();\n   138→      const counts = countStories(statuses);\n   139→\n   140→      if (counts.total === 0) {\n   141→        fail('No stories found in sprint-state.json — nothing to execute', outputOpts);\n   142→        process.exitCode = 1;\n   143→        return;\n   144→      }\n   145→\n   146→      info(`Starting autonomous execution — ${counts.ready} ready, ${counts.inProgress} in progress, ${counts.verified} verified, ${counts.done}/${counts.total} done`, outputOpts);\n   147→      // 3. Parse and validate numeric options\n   148→      const maxIterations = parseInt(options.maxIterations, 10);\n   149→      const timeout = parseInt(options.timeout, 10);\n   150→      const iterationTimeout = parseInt(options.iterationTimeout, 10);\n   151→      const calls = parseInt(options.calls, 10);\n   152→      const maxStoryRetries = parseInt(options.maxStoryRetries, 10);\n   153→      if (isNaN(maxIterations) || isNaN(timeout) || isNaN(iterationTimeout) || isNaN(calls) || isNaN(maxStoryRetries)) {\n   154→        fail('Invalid numeric option — --max-iterations, --timeout, --iteration-timeout, --calls, and --max-story-retries must be numbers', outputOpts);\n   155→        process.exitCode = 1;\n   156→        return;\n   157→      }\n   158→\n   159→      // 4. Generate prompt file (with flagged stories context if available)\n   160→      const promptFile = join(projectDir, 'ralph', '.harness-prompt.md');\n   161→      let flaggedStories: string[] | undefined;\n   162→      const flaggedState = getSprintState();\n   163→      if (flaggedState.success && flaggedState.data.flagged?.length > 0) {\n   164→        flaggedStories = flaggedState.data.flagged;\n   165→      }\n   166→      const promptContent = generateRalphPrompt({\n   167→        projectDir,\n   168→        sprintStatusPath,\n   169→        flaggedStories,\n   170→      });\n   171→      try {\n   172→        mkdirSync(dirname(promptFile), { recursive: true });\n   173→        writeFileSync(promptFile, promptContent, 'utf-8');\n   174→      } catch (err) {\n   175→        const message = err instanceof Error ? err.message : String(err);\n   176→        fail(`Failed to write prompt file: ${message}`, outputOpts);\n   177→        process.exitCode = 1;\n   178→        return;\n   179→      }\n   180→\n   181→      // 5. Create driver with ralph-specific configuration\n   182→      const quiet = options.quiet;\n   183→      const driver = getDriver('ralph', {\n   184→        pluginDir,\n   185→        maxIterations,\n   186→        iterationTimeout,\n   187→        calls,\n   188→        quiet,\n   189→        maxStoryRetries,\n   190→        reset: options.reset,\n   191→      });\n   192→\n   193→      // 6. Set environment — stream-json is always the output format\n   194→      const env: Record<string, string> = {};\n   195→      if (isJson) {\n   196→        env.CLAUDE_OUTPUT_FORMAT = 'stream-json';\n   197→      }\n   198→\n   199→      // 7. Spawn agent — pipe stdout/stderr through driver.parseOutput() → Ink renderer\n   200→      const rendererHandle = startRenderer({ quiet });\n   201→      let sprintStateInterval: ReturnType<typeof setInterval> | null = null;\n   202→      const sessionStartTime = Date.now();\n   203→      const totalBudgetMinutes = timeout / 60;\n   204→      const eventState = { currentIterationCount: 0 };\n   205→\n   206→      try {\n   207→        // Read initial sprint state for the renderer header\n   208→        const initialState = getSprintState();\n   209→        if (initialState.success) {\n   210→          const s = initialState.data;\n   211→          const sprintInfo: SprintInfo = {\n   212→            storyKey: s.run.currentStory ?? '',\n   213→            phase: s.run.currentPhase ?? '',\n   214→            done: s.sprint.done,\n   215→            total: s.sprint.total,\n   216→            elapsed: formatElapsed(Date.now() - sessionStartTime),\n   217→            iterationCount: eventState.currentIterationCount,\n   218→          };\n   219→          rendererHandle.updateSprintState(sprintInfo);\n   220→        }\n   221→\n   222→        // Feed initial per-story statuses to the renderer\n   223→        const initialStatuses = readSprintStatusFromState();\n   224→        const initialStories = mapSprintStatuses(initialStatuses);\n   225→        if (initialStories.length > 0) {\n   226→          rendererHandle.updateStories(initialStories);\n   227→        }\n   228→\n   229→        const child = driver.spawn({\n   230→          storyKey: '',\n   231→          prompt: promptFile,\n   232→          workDir: projectDir,\n   233→          timeout,\n   234→          env,\n   235→        });\n   236→\n   237→        if (!quiet && child.stdout && child.stderr) {\n   238→          const lineHandler = createDriverLineHandler(driver, rendererHandle, eventState);\n   239→          child.stdout.on('data', lineHandler);\n   240→          child.stderr.on('data', lineHandler);\n   241→\n   242→          // Periodically refresh sprint state for the header display\n   243→          sprintStateInterval = setInterval(() => {\n   244→            try {\n   245→              const stateResult = getSprintState();\n   246→              if (stateResult.success) {\n   247→                const s = stateResult.data;\n   248→                const sprintInfo: SprintInfo = {\n   249→                  storyKey: s.run.currentStory ?? '',\n   250→                  phase: s.run.currentPhase ?? '',\n   251→                  done: s.sprint.done,\n   252→                  total: s.sprint.total,\n   253→                  elapsed: formatElapsed(Date.now() - sessionStartTime),\n   254→                  iterationCount: eventState.currentIterationCount,\n   255→                };\n   256→                rendererHandle.updateSprintState(sprintInfo);\n   257→\n   258→                // Time budget awareness: check if the current phase should be deferred (AC 5, AC 8)\n   259→                const currentPhase = s.run.currentPhase;\n   260→                if (currentPhase) {\n   261→                  const remaining = computeRemainingMinutes(sessionStartTime, totalBudgetMinutes);\n   262→                  const estimate = getPhaseEstimate(currentPhase);\n   263→                  if (shouldDeferPhase(currentPhase, remaining)) {\n   264→                    info(`[INFO] deferring ${currentPhase} to next session (${remaining}min remaining, ${estimate}min needed)`, outputOpts);\n   265→                    // Actually defer: kill the child process so the session ends gracefully\n   266→                    child.kill('SIGTERM');\n   267→                    if (sprintStateInterval) {\n   268→                      clearInterval(sprintStateInterval);\n   269→                      sprintStateInterval = null;\n   270→                    }\n   271→                    return; // Stop polling after deferral\n   272→                  }\n   273→                }\n   274→              }\n   275→              // Refresh per-story statuses\n   276→              const currentStatuses = readSprintStatusFromState();\n   277→              const storyEntries = mapSprintStatuses(currentStatuses);\n   278→              rendererHandle.updateStories(storyEntries);\n   279→            } catch {\n   280→              // IGNORE: state read errors during polling are non-fatal\n   281→            }\n   282→          }, 5_000);\n   283→        }\n   284→\n   285→        const exitCode = await new Promise<number>((resolve, reject) => {\n   286→          child.on('error', (err) => {\n   287→            if (sprintStateInterval) clearInterval(sprintStateInterval);\n   288→            rendererHandle.cleanup();\n   289→            reject(err);\n   290→          });\n   291→          child.on('close', (code) => {\n   292→            if (sprintStateInterval) clearInterval(sprintStateInterval);\n   293→            rendererHandle.cleanup();\n   294→            resolve(code ?? 1);\n   295→          });\n   296→        });\n   297→\n   298→        // 8. Handle JSON output on exit\n   299→        if (isJson) {\n   300→          const statusFile = join(projectDir, driver.getStatusFile());\n   301→          let statusData: Record<string, unknown> | null = null;\n   302→          let exitReason = 'status_file_missing';\n   303→          if (existsSync(statusFile)) {\n   304→            try {\n   305→              statusData = JSON.parse(readFileSync(statusFile, 'utf-8'));\n   306→              exitReason = '';\n   307→            } catch { exitReason = 'status_file_unreadable'; } // IGNORE: status file may be malformed\n   308→          }\n   309→          const fc = statusData ? countStories(readSprintStatusFromState()) : counts;\n   310→          jsonOutput({\n   311→            status: statusData?.status ?? (exitCode === 0 ? 'completed' : 'stopped'),\n   312→            iterations: (statusData?.loop_count as number) ?? 0,\n   313→            storiesCompleted: statusData ? fc.done : 0,\n   314→            storiesTotal: fc.total,\n   315→            storiesRemaining: statusData ? fc.total - fc.done : fc.total,\n   316→            elapsedSeconds: (statusData?.elapsed_seconds as number) ?? 0,\n   317→            flaggedStories: (statusData?.flagged_stories as string[]) ?? [],\n   318→            exitReason: (statusData?.exit_reason as string) ?? exitReason,\n   319→          });\n   320→        }\n   321→\n   322→        process.exitCode = exitCode;\n   323→      } catch (err) {\n   324→        if (sprintStateInterval) clearInterval(sprintStateInterval);\n   325→        rendererHandle.cleanup();\n   326→        const message = err instanceof Error ? err.message : String(err);\n   327→        fail(`Failed to start agent: ${message}`, outputOpts);\n   328→        process.exitCode = 1;\n   329→      }\n   330→    });\n   331→}\n   332→"}]},"parent_tool_use_id":"toolu_01GTepbYbnTDehnMhc3XqM2y","session_id":"2610e689-589b-4ec2-8784-d06d07275472","uuid":"13e7d943-46ef-4978-a87f-5d840187c8dd","timestamp":"2026-03-27T14:54:45.894Z"}
