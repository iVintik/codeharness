{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011Bfk1a1BqN3UunChVZCwRs","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { render } from 'ink-testing-library';\n3\timport React from 'react';\n4\timport { Lane, formatLaneCost, formatLaneElapsed } from '../ink-lane.js';\n5\timport type { LaneProps, StoryProgressEntry } from '../ink-lane.js';\n6\t\n7\tfunction makeLaneProps(overrides?: Partial<LaneProps>): LaneProps {\n8\t  return {\n9\t    epicId: '10',\n10\t    epicTitle: 'Driver Interface',\n11\t    currentStory: '10-3',\n12\t    phase: 'dev',\n13\t    acProgress: '4/9',\n14\t    storyProgressEntries: [\n15\t      { key: '10-1', status: 'done' },\n16\t      { key: '10-2', status: 'done' },\n17\t      { key: '10-3', status: 'in-progress' },\n18\t      { key: '10-4', status: 'pending' },\n19\t      { key: '10-5', status: 'pending' },\n20\t    ],\n21\t    driver: 'claude-code',\n22\t    cost: 4.20,\n23\t    elapsedTime: 1080000, // 18m\n24\t    ...overrides,\n25\t  };\n26\t}\n27\t\n28\tdescribe('Lane component', () => {\n29\t  it('renders epic title', () => {\n30\t    const { lastFrame } = render(<Lane {...makeLaneProps()} />);\n31\t    const frame = lastFrame()!;\n32\t    expect(frame).toContain('Epic 10');\n33\t    expect(frame).toContain('Driver Interface');\n34\t  });\n35\t\n36\t  it('renders current story and phase', () => {\n37\t    const { lastFrame } = render(<Lane {...makeLaneProps()} />);\n38\t    const frame = lastFrame()!;\n39\t    expect(frame).toContain('10-3');\n40\t    expect(frame).toContain('dev');\n41\t  });\n42\t\n43\t  it('renders AC progress', () => {\n44\t    const { lastFrame } = render(<Lane {...makeLaneProps()} />);\n45\t    const frame = lastFrame()!;\n46\t    expect(frame).toContain('AC 4/9');\n47\t  });\n48\t\n49\t  it('renders story progress bar with correct symbols', () => {\n50\t    const { lastFrame } = render(<Lane {...makeLaneProps()} />);\n51\t    const frame = lastFrame()!;\n52\t    // Done stories get ✓\n53\t    expect(frame).toContain('✓ 10-1');\n54\t    expect(frame).toContain('✓ 10-2');\n55\t    // In-progress gets ◆\n56\t    expect(frame).toContain('◆ 10-3');\n57\t    // Pending gets ○\n58\t    expect(frame).toContain('○ 10-4');\n59\t    expect(frame).toContain('○ 10-5');\n60\t  });\n61\t\n62\t  it('renders driver name, cost, and elapsed time', () => {\n63\t    const { lastFrame } = render(<Lane {...makeLaneProps()} />);\n64\t    const frame = lastFrame()!;\n65\t    expect(frame).toContain('claude-code');\n66\t    expect(frame).toContain('$4.20');\n67\t    expect(frame).toContain('18m');\n68\t  });\n69\t\n70\t  it('renders lane index when provided', () => {\n71\t    const { lastFrame } = render(<Lane {...makeLaneProps({ laneIndex: 1 })} />);\n72\t    const frame = lastFrame()!;\n73\t    expect(frame).toContain('Lane 1:');\n74\t  });\n75\t\n76\t  it('omits lane index when not provided', () => {\n77\t    const { lastFrame } = render(<Lane {...makeLaneProps()} />);\n78\t    const frame = lastFrame()!;\n79\t    expect(frame).not.toContain('Lane ');\n80\t  });\n81\t\n82\t  it('handles null currentStory and phase gracefully', () => {\n83\t    const { lastFrame } = render(\n84\t      <Lane {...makeLaneProps({ currentStory: null, phase: null, acProgress: null })} />\n85\t    );\n86\t    const frame = lastFrame()!;\n87\t    // Should still render epic title\n88\t    expect(frame).toContain('Epic 10');\n89\t    expect(frame).toContain('Driver Interface');\n90\t  });\n91\t\n92\t  it('handles null cost and elapsedTime', () => {\n93\t    const { lastFrame } = render(\n94\t      <Lane {...makeLaneProps({ cost: null, elapsedTime: null })} />\n95\t    );\n96\t    const frame = lastFrame()!;\n97\t    expect(frame).toContain('--');\n98\t  });\n99\t\n100\t  it('handles zero cost', () => {\n101\t    const { lastFrame } = render(\n102\t      <Lane {...makeLaneProps({ cost: 0 })} />\n103\t    );\n104\t    const frame = lastFrame()!;\n105\t    expect(frame).toContain('$0.00');\n106\t  });\n107\t\n108\t  it('handles empty story progress entries', () => {\n109\t    const { lastFrame } = render(\n110\t      <Lane {...makeLaneProps({ storyProgressEntries: [] })} />\n111\t    );\n112\t    const frame = lastFrame()!;\n113\t    // Should not crash, should still show title\n114\t    expect(frame).toContain('Epic 10');\n115\t  });\n116\t\n117\t  it('exports Lane component and type interfaces', () => {\n118\t    // Verify exports exist\n119\t    expect(Lane).toBeDefined();\n120\t    expect(typeof Lane).toBe('function');\n121\t  });\n122\t});\n123\t\n124\tdescribe('formatLaneCost', () => {\n125\t  it('formats positive cost as $X.XX', () => {\n126\t    expect(formatLaneCost(4.20)).toBe('$4.20');\n127\t    expect(formatLaneCost(0)).toBe('$0.00');\n128\t    expect(formatLaneCost(12.345)).toBe('$12.35');\n129\t  });\n130\t\n131\t  it('returns -- for null', () => {\n132\t    expect(formatLaneCost(null)).toBe('--');\n133\t  });\n134\t});\n135\t\n136\tdescribe('formatLaneElapsed', () => {\n137\t  it('formats seconds < 60 as Xs', () => {\n138\t    expect(formatLaneElapsed(5000)).toBe('5s');\n139\t    expect(formatLaneElapsed(45000)).toBe('45s');\n140\t  });\n141\t\n142\t  it('formats minutes < 60 as Xm', () => {\n143\t    expect(formatLaneElapsed(60000)).toBe('1m');\n144\t    expect(formatLaneElapsed(1080000)).toBe('18m');\n145\t  });\n146\t\n147\t  it('formats >= 60 minutes as Xh Xm', () => {\n148\t    expect(formatLaneElapsed(3600000)).toBe('1h 0m');\n149\t    expect(formatLaneElapsed(4320000)).toBe('1h 12m');\n150\t    expect(formatLaneElapsed(7200000)).toBe('2h 0m');\n151\t  });\n152\t\n153\t  it('returns -- for null', () => {\n154\t    expect(formatLaneElapsed(null)).toBe('--');\n155\t  });\n156\t\n157\t  it('returns 0s for 0ms', () => {\n158\t    expect(formatLaneElapsed(0)).toBe('0s');\n159\t  });\n160\t});\n161\t"}]},"parent_tool_use_id":"toolu_018yuUCTksy6z1zXKFgN7iGd","session_id":"0c112080-0896-4e32-96a0-f82adec16922","uuid":"90c40c0e-dd02-42ed-8a07-0a8cc33ae82f","timestamp":"2026-04-04T02:19:01.463Z"}
