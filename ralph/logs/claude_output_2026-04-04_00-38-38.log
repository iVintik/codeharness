ss {\n43\t    constructor(..._args: unknown[]) {\n44\t      // @ts-expect-error: module-scoped tracking variables\n45\t      _worktreeManagerConstructed = true;\n46\t      // @ts-expect-error: _wtFactory is module-scoped\n47\t      return _wtFactory();\n48\t    }\n49\t  }\n50\t\n51\t  return {\n52\t    existsSyncMock: vi.fn(realFn),\n53\t    readSprintStatusMock: vi.fn(() => ({}) as Record<string, string>),\n54\t    reconcileStateMock: vi.fn(() => ({ success: true, data: { corrections: [], stateChanged: false } })),\n55\t    isDockerAvailableMock: vi.fn(() => true),\n56\t    cleanupContainersMock: vi.fn(() => ({ success: true, data: { containersRemoved: 0, names: [] } })),\n57\t    resolveWorkflowMock: vi.fn(() => ({\n58\t      tasks: { implement: { agent: 'dev', scope: 'per-story', session: 'fresh', source_access: true } },\n59\t      flow: ['implement'],\n60\t      execution: { epic_strategy: 'sequential', max_parallel: 1, isolation: 'none', merge_strategy: 'merge-commit', story_strategy: 'sequential' },\n61\t      storyFlow: ['implement'],\n62\t      epicFlow: [],\n63\t    })),\n64\t    resolveAgentMock: vi.fn(() => ({\n65\t      name: 'dev',\n66\t      role: { title: 'Developer', purpose: 'Implement code' },\n67\t      persona: { identity: 'A developer', communication_style: 'direct', principles: [] },\n68\t    })),\n69\t    compileSubagentMock: vi.fn(() => ({\n70\t      name: 'dev',\n71\t      model: 'claude-sonnet-4-20250514',\n72\t      instructions: 'You are a developer',\n73\t      disallowedTools: [],\n74\t      bare: true,\n75\t    })),\n76\t    executeWorkflowMock: vi.fn(async () => ({\n77\t      success: true,\n78\t      tasksCompleted: 3,\n79\t      storiesProcessed: 1,\n80\t      errors: [],\n81\t      durationMs: 60000,\n82\t    })),\n83\t    readWorkflowStateMock: vi.fn(() => ({\n84\t      workflow_name: '',\n85\t      started: '',\n86\t      iteration: 0,\n87\t      phase: 'idle',\n88\t      tasks_completed: [],\n89\t      evaluator_scores: [],\n90