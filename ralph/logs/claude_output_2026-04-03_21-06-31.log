,\n      });\n\n      await executeWorkflow(config);\n\n      // Check that no SUCCESS checkpoint was written (only error checkpoint should exist)\n      const successCheckpointCalls = mockWriteWorkflowState.mock.calls.filter(\n        (call: unknown[]) => {\n          const state = call[0] as WorkflowState;\n          return state.tasks_completed.some(\n            (cp) => cp.task_name === 'telemetry' && cp.story_key === '__run__' && !cp.error,\n          );\n        },\n      );\n      expect(successCheckpointCalls.length).toBe(0);\n\n      // Verify an error checkpoint WAS written\n      const errorCheckpointCalls = mockWriteWorkflowState.mock.calls.filter(\n        (call: unknown[]) => {\n          const state = call[0] as WorkflowState;\n          return state.tasks_completed.some(\n            (cp) => cp.task_name === 'telemetry' && cp.story_key === '__run__' && cp.error === true,\n          );\n        },\n      );\n      expect(errorCheckpointCalls.length).toBeGreaterThan(0);\n    });"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":395,"cache_read_input_tokens":65716,"cache_creation":{"ephemeral_5m_input_tokens":395,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_011ZTgKSKa4gwyUPFY6UYukh","session_id":"8a461711-53e2-475a-88dd-c7013f6080c5","uuid":"729bade0-6c6f-4899-b3a9-ab6f81e94150"}
