{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DKyMXdjUTkeWaM1AjYGLCF","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { evaluateProgress } from '../circuit-breaker.js';\n3\timport type { CircuitBreakerDecision } from '../circuit-breaker.js';\n4\timport type { EvaluatorScore } from '../workflow-state.js';\n5\t\n6\t// --- Helpers ---\n7\t\n8\tfunction makeScore(\n9\t  iteration: number,\n10\t  passed: number,\n11\t  failed: number,\n12\t  unknown: number,\n13\t): EvaluatorScore {\n14\t  const total = passed + failed + unknown;\n15\t  return {\n16\t    iteration,\n17\t    passed,\n18\t    failed,\n19\t    unknown,\n20\t    total,\n21\t    timestamp: new Date().toISOString(),\n22\t  };\n23\t}\n24\t\n25\t// --- Tests ---\n26\t\n27\tdescribe('evaluateProgress', () => {\n28\t  // AC #4: fewer than 2 scores returns halt: false\n29\t  describe('insufficient history', () => {\n30\t    it('returns halt: false for empty scores array', () => {\n31\t      const result = evaluateProgress([]);\n32\t      expect(result).toEqual({ halt: false });\n33\t    });\n34\t\n35\t    it('returns halt: false for a single score', () => {\n36\t      const result = evaluateProgress([makeScore(1, 2, 1, 0)]);\n37\t      expect(result).toEqual({ halt: false });\n38\t    });\n39\t  });\n40\t\n41\t  // AC #2: stagnation detection\n42\t  describe('stagnation detection', () => {\n43\t    it('halts when passed count has not increased for 2 consecutive iterations', () => {\n44\t      const scores = [makeScore(1, 2, 1, 0), makeScore(2, 2, 1, 0)];\n45\t      const result = evaluateProgress(scores);\n46\t      expect(result.halt).toBe(true);\n47\t    });\n48\t\n49\t    it('halts when passed count decreased', () => {\n50\t      const scores = [makeScore(1, 3, 0, 0), makeScore(2, 2, 1, 0)];\n51\t      const result = evaluateProgress(scores);\n52\t      expect(result.halt).toBe(true);\n53\t    });\n54\t\n55\t    it('halts with reason \"score-stagnation\"', () => {\n56\t      const scores = [makeScore(1, 1, 2, 0), makeScore(2, 1, 2, 0)];\n57\t      const result = evaluateProgress(scores);\n58\t      expect(result.halt).toBe(true);\n59\t      if (result.halt) {\n60\t        expect(result.reason).toBe('score-stagnation');\n61\t      }\n62\t    });\n63\t  });\n64\t\n65\t  // AC #3: progress detection\n66\t  describe('progress detection', () => {\n67\t    it('returns halt: false when passed count increased on last iteration', () => {\n68\t      const scores = [makeScore(1, 1, 2, 0), makeScore(2, 2, 1, 0)];\n69\t      const result = evaluateProgress(scores);\n70\t      expect(result).toEqual({ halt: false });\n71\t    });\n72\t\n73\t    it('returns halt: false when passed goes 1, 1, 2 (improved on last iteration)', () => {\n74\t      const scores = [\n75\t        makeScore(1, 1, 2, 0),\n76\t        makeScore(2, 1, 2, 0),\n77\t        makeScore(3, 2, 1, 0),\n78\t      ];\n79\t      const result = evaluateProgress(scores);\n80\t      expect(result).toEqual({ halt: false });\n81\t    });\n82\t  });\n83\t\n84\t  // AC #5: halt includes remainingFailures and scoreHistory\n85\t  describe('halt decision details', () => {\n86\t    it('includes correct remainingFailures', () => {\n87\t      // total=3, passed=1 → 2 remaining failures → [1, 2]\n88\t      const scores = [makeScore(1, 1, 2, 0), makeScore(2, 1, 2, 0)];\n89\t      const result = evaluateProgress(scores);\n90\t      expect(result.halt).toBe(true);\n91\t      if (result.halt) {\n92\t        expect(result.remainingFailures).toEqual([1, 2]);\n93\t      }\n94\t    });\n95\t\n96\t    it('includes correct scoreHistory', () => {\n97\t      const scores = [\n98\t        makeScore(1, 0, 3, 0),\n99\t        makeScore(2, 1, 2, 0),\n100\t        makeScore(3, 1, 2, 0),\n101\t      ];\n102\t      const result = evaluateProgress(scores);\n103\t      expect(result.halt).toBe(true);\n104\t      if (result.halt) {\n105\t        expect(result.scoreHistory).toEqual([0, 1, 1]);\n106\t      }\n107\t    });\n108\t\n109\t    it('remainingFailures is empty when all pass but stagnation still detected', () => {\n110\t      // Edge case: all passed but count stayed the same\n111\t      const scores = [makeScore(1, 3, 0, 0), makeScore(2, 3, 0, 0)];\n112\t      const result = evaluateProgress(scores);\n113\t      expect(result.halt).toBe(true);\n114\t      if (result.halt) {\n115\t        expect(result.remainingFailures).toEqual([]);\n116\t      }\n117\t    });\n118\t  });\n119\t\n120\t  // AC #6: discriminated union type check\n121\t  describe('type discrimination', () => {\n122\t    it('halt: false has no extra fields', () => {\n123\t      const result: CircuitBreakerDecision = evaluateProgress([]);\n124\t      expect(result).toEqual({ halt: false });\n125\t      expect(Object.keys(result)).toEqual(['halt']);\n126\t    });\n127\t\n128\t    it('halt: true includes reason, remainingFailures, scoreHistory', () => {\n129\t      const scores = [makeScore(1, 1, 1, 0), makeScore(2, 1, 1, 0)];\n130\t      const result: CircuitBreakerDecision = evaluateProgress(scores);\n131\t      expect(result.halt).toBe(true);\n132\t      if (result.halt) {\n133\t        expect(typeof result.reason).toBe('string');\n134\t        expect(Array.isArray(result.remainingFailures)).toBe(true);\n135\t        expect(Array.isArray(result.scoreHistory)).toBe(true);\n136\t      }\n137\t    });\n138\t  });\n139\t\n140\t  // Edge cases\n141\t  describe('edge cases', () => {\n142\t    it('all-unknown scores (passed=0 across iterations) triggers halt', () => {\n143\t      const scores = [makeScore(1, 0, 0, 3), makeScore(2, 0, 0, 3)];\n144\t      const result = evaluateProgress(scores);\n145\t      expect(result.halt).toBe(true);\n146\t      if (result.halt) {\n147\t        expect(result.reason).toBe('score-stagnation');\n148\t        expect(result.scoreHistory).toEqual([0, 0]);\n149\t        expect(result.remainingFailures).toEqual([1, 2, 3]);\n150\t      }\n151\t    });\n152\t\n153\t    it('single-AC edge case: passed goes 0, 0 = stagnation', () => {\n154\t      const scores = [makeScore(1, 0, 1, 0), makeScore(2, 0, 1, 0)];\n155\t      const result = evaluateProgress(scores);\n156\t      expect(result.halt).toBe(true);\n157\t    });\n158\t\n159\t    it('passed goes 1, 2, 2 = stagnation (last two identical)', () => {\n160\t      const scores = [\n161\t        makeScore(1, 1, 2, 0),\n162\t        makeScore(2, 2, 1, 0),\n163\t        makeScore(3, 2, 1, 0),\n164\t      ];\n165\t      const result = evaluateProgress(scores);\n166\t      expect(result.halt).toBe(true);\n167\t      if (result.halt) {\n168\t        expect(result.scoreHistory).toEqual([1, 2, 2]);\n169\t      }\n170\t    });\n171\t  });\n172\t\n173\t  // AC #7: performance\n174\t  describe('performance', () => {\n175\t    it('evaluates 20 scores in under 5ms', () => {\n176\t      const scores: EvaluatorScore[] = [];\n177\t      for (let i = 1; i <= 20; i++) {\n178\t        scores.push(makeScore(i, Math.floor(i / 2), 3, 0));\n179\t      }\n180\t\n181\t      const start = performance.now();\n182\t      evaluateProgress(scores);\n183\t      const elapsed = performance.now() - start;\n184\t\n185\t      expect(elapsed).toBeLessThan(5);\n186\t    });\n187\t  });\n188\t});\n189\t"}]},"parent_tool_use_id":"toolu_01M7cHdPNxRinB1ADy98F7e3","session_id":"0dddd908-79fb-4621-81f1-f9e1a3ee8324","uuid":"9309e820-dfdd-40a4-9e0b-03cecbd3600e","timestamp":"2026-04-03T01:05:03.496Z"}
