elta');\n   277→    expect(writtenContent).toContain('## Partial Output');\n   278→  });\n   279→\n   280→  it('handles partial failures gracefully (git unavailable but stderr captured)', () => {\n   281→    // git fails\n   282→    mockedExecSync.mockImplementation(() => {\n   283→      throw new Error('git not found');\n   284→    });\n   285→\n   286→    // state files exist, output file exists\n   287→    mockedExistsSync.mockReturnValue(true);\n   288→    mockedReadFileSync\n   289→      .mockReturnValueOnce(JSON.stringify({ stories: {} }))\n   290→      .mockReturnValueOnce(JSON.stringify({ stories: {} }))\n   291→      .mockReturnValueOnce('captured output line');\n   292→\n   293→    const result = captureTimeoutReport({\n   294→      storyKey: '3-1-test',\n   295→      iteration: 1,\n   296→      durationMinutes: 15,\n   297→      outputFile: '/tmp/output.log',\n   298→      stateSnapshotPath: '/tmp/snapshot.json',\n   299→    });\n   300→\n   301→    expect(result.success).toBe(true);\n   302→    if (!result.success) return;\n   303→    expect(result.data.capture.gitDiff).toContain('(unavailable:');\n   304→    expect(result.data.capture.partialStderr).toBe('captured output line');\n   305→  });\n   306→\n   307→  it('creates report directory if it does not exist', () => {\n   308→    mockedExecSync.mockReturnValue('');\n   309→    mockedExistsSync.mockImplementation((path: string) => {\n   310→      if (typeof path === 'string' && path.includes('ralph/logs')) return false;\n   311→      return true;\n   312→    });\n   313→    mockedReadFileSync\n   314→      .mockReturnValueOnce(JSON.stringify({ stories: {} }))\n   315→      .mockReturnValueOnce(JSON.stringify({ stories: {} }))\n   316→      .mockReturnValueOnce('output');\n   317→\n   318→    const result = captureTimeoutReport({\n   319→      storyKey: '3-1-test',\n   320→      iteration: 1,\n   321→      durationMinutes: 10,\n   322→      outputFile: '/tmp/output.log',\n   323→      stateSnapshotPath: