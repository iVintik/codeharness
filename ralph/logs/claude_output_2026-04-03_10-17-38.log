{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BcwRu38zgcogDdYEv19uBB","type":"tool_result","content":"1\t/**\n2\t * AgentDriver abstraction types.\n3\t *\n4\t * Defines the contract that all agent drivers (Claude Code, Codex, OpenCode)\n5\t * must implement. See architecture-multi-framework.md Decision 1.\n6\t */\n7\t\n8\timport type { Readable } from 'node:stream';\n9\timport type { StreamEvent } from './stream-parser.js';\n10\t\n11\t// --- New Types (Epic 10) ---\n12\t\n13\t/**\n14\t * Health status returned by a driver's healthCheck().\n15\t */\n16\texport interface DriverHealth {\n17\t  readonly available: boolean;\n18\t  readonly authenticated: boolean;\n19\t  readonly version: string | null;\n20\t  readonly error?: string;\n21\t}\n22\t\n23\t/**\n24\t * Capability flags for a driver. Extensible — new boolean fields\n25\t * can be added without breaking existing drivers.\n26\t */\n27\texport interface DriverCapabilities {\n28\t  readonly supportsPlugins: boolean;\n29\t  readonly supportsStreaming: boolean;\n30\t  readonly costReporting: boolean;\n31\t}\n32\t\n33\t/**\n34\t * Error classification categories for driver errors.\n35\t * Drivers must NOT invent new categories.\n36\t *\n37\t * Classification priority:\n38\t * 1. HTTP 429 or \"rate limit\" in message -> RATE_LIMIT\n39\t * 2. ECONNREFUSED, ETIMEDOUT, ENOTFOUND -> NETWORK\n40\t * 3. HTTP 401/403 or \"unauthorized\"/\"forbidden\" -> AUTH\n41\t * 4. Process killed by timeout -> TIMEOUT\n42\t * 5. Everything else -> UNKNOWN\n43\t */\n44\texport type ErrorCategory = 'RATE_LIMIT' | 'NETWORK' | 'AUTH' | 'TIMEOUT' | 'UNKNOWN';\n45\t\n46\t/**\n47\t * Test results summary for an output contract.\n48\t */\n49\texport interface TestResults {\n50\t  readonly passed: number;\n51\t  readonly failed: number;\n52\t  readonly coverage: number | null;\n53\t}\n54\t\n55\t/**\n56\t * Acceptance criteria status entry.\n57\t */\n58\texport interface ACStatus {\n59\t  readonly id: string;\n60\t  readonly description: string;\n61\t  readonly status: string;\n62\t}\n63\t\n64\t/**\n65\t * Structured output contract produced by a dispatch.\n66\t */\n67\texport interface OutputContract {\n68\t  readonly version: number;\n69\t  readonly taskName: string;\n70\t  readonly storyId: string;\n71\t  readonly driver: string;\n72\t  readonly model: string;\n73\t  readonly timestamp: string;\n74\t  readonly cost_usd: number | null;\n75\t  readonly duration_ms: number;\n76\t  readonly changedFiles: readonly string[];\n77\t  readonly testResults: TestResults | null;\n78\t  readonly output: string;\n79\t  readonly acceptanceCriteria: readonly ACStatus[];\n80\t}\n81\t\n82\t/**\n83\t * Options for dispatching a task to a driver.\n84\t */\n85\texport interface DispatchOpts {\n86\t  readonly prompt: string;\n87\t  readonly model: string;\n88\t  readonly cwd: string;\n89\t  readonly sourceAccess: boolean;\n90\t  readonly plugins?: readonly string[];\n91\t  readonly timeout?: number;\n92\t  readonly outputContract?: OutputContract;\n93\t}\n94\t\n95\t/**\n96\t * The core agent driver interface (v2 — Epic 10).\n97\t * Each driver knows how to check health, dispatch tasks, and report cost.\n98\t * `dispatch()` returns `AsyncIterable<StreamEvent>` enabling both in-process\n99\t * (Agent SDK yields) and CLI-wrapped (stdout parsed to events) drivers.\n100\t */\n101\texport interface AgentDriver {\n102\t  readonly name: string;\n103\t  readonly defaultModel: string;\n104\t  readonly capabilities: DriverCapabilities;\n105\t  healthCheck(): Promise<DriverHealth>;\n106\t  dispatch(opts: DispatchOpts): AsyncIterable<StreamEvent>;\n107\t  getLastCost(): number | null;\n108\t}\n109\t\n110\t// --- Deprecated Types (backward compatibility until story 10-3) ---\n111\t\n112\t/**\n113\t * Options for spawning an agent process.\n114\t * @deprecated Use `DispatchOpts` instead. Will be removed after story 10-3.\n115\t */\n116\texport interface SpawnOpts {\n117\t  storyKey: string;\n118\t  prompt: string;\n119\t  workDir: string;\n120\t  timeout: number;\n121\t  env?: Record<string, string>;\n122\t}\n123\t\n124\t/**\n125\t * Abstraction over a running agent process.\n126\t * Wraps Node.js ChildProcess but allows non-process-based drivers\n127\t * (direct API calls, WebSocket connections) to implement the same interface.\n128\t * @deprecated Use `AsyncIterable<StreamEvent>` from `dispatch()` instead. Will be removed after story 10-3.\n129\t */\n130\texport interface AgentProcess {\n131\t  stdout: Readable;\n132\t  stderr: Readable;\n133\t  on(event: 'close', handler: (code: number) => void): void;\n134\t  on(event: 'error', handler: (err: Error) => void): void;\n135\t  kill(signal?: string): void;\n136\t}\n137\t\n138\t/**\n139\t * Discriminated union of events emitted by an agent driver.\n140\t * The `parseOutput()` method converts raw agent output lines into these typed events.\n141\t * @deprecated Use `StreamEvent` from `stream-parser.ts` instead. Will be removed after story 10-3.\n142\t */\n143\texport type AgentEvent =\n144\t  | { type: 'tool-start'; name: string }\n145\t  | { type: 'tool-input'; partial: string }\n146\t  | { type: 'tool-complete'; name?: string; args?: string }\n147\t  | { type: 'text'; text: string }\n148\t  | { type: 'story-complete'; key: string; details: string }\n149\t  | { type: 'story-failed'; key: string; reason: string }\n150\t  | { type: 'iteration'; count: number }\n151\t  | { type: 'retry'; attempt: number; delay: number }\n152\t  | { type: 'result'; cost: number; sessionId: string };\n153\t"}]},"parent_tool_use_id":"toolu_01UpgK31qGpCnbtuMDgCDmWw","session_id":"e499f49a-fe4c-4b28-bb21-4e83348f2671","uuid":"7b51740e-fabf-4737-a2bb-d48aa8c8de0b","timestamp":"2026-04-03T06:32:04.504Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014uKQBoEjSCQLFrJup8k7uS","type":"tool_result","content":"1\t/**\n2\t * Stream Event Parser — converts Claude stream-json NDJSON lines into typed events.\n3\t *\n4\t * Stateless per-line: accepts one NDJSON line, returns one typed event or null.\n5\t * Accumulation (e.g., building full tool input from deltas) is the caller's responsibility.\n6\t *\n7\t * Event format reference:\n8\t * - Wrapper type \"stream_event\" contains API events (content_block_start, etc.)\n9\t * - Wrapper type \"system\" contains Claude Code events (api_retry, etc.)\n10\t * - Wrapper type \"result\" is the final event with session_id, cost, result text\n11\t */\n12\t\n13\t// --- Event Types ---\n14\t\n15\texport interface ToolStartEvent {\n16\t  readonly type: 'tool-start';\n17\t  readonly name: string;\n18\t  readonly id: string;\n19\t}\n20\t\n21\texport interface ToolInputEvent {\n22\t  readonly type: 'tool-input';\n23\t  readonly partial: string;\n24\t}\n25\t\n26\texport interface ToolCompleteEvent {\n27\t  readonly type: 'tool-complete';\n28\t}\n29\t\n30\texport interface TextEvent {\n31\t  readonly type: 'text';\n32\t  readonly text: string;\n33\t}\n34\t\n35\texport interface RetryEvent {\n36\t  readonly type: 'retry';\n37\t  readonly attempt: number;\n38\t  readonly delay: number;\n39\t}\n40\t\n41\texport interface ResultEvent {\n42\t  readonly type: 'result';\n43\t  readonly cost: number;\n44\t  readonly sessionId: string;\n45\t  /** Normalized cost in USD for multi-driver comparison. */\n46\t  readonly cost_usd?: number | null;\n47\t}\n48\t\n49\t/** Discriminated union of all stream events the parser can emit. */\n50\texport type StreamEvent =\n51\t  | ToolStartEvent\n52\t  | ToolInputEvent\n53\t  | ToolCompleteEvent\n54\t  | TextEvent\n55\t  | RetryEvent\n56\t  | ResultEvent;\n57\t\n58\t// --- Parser ---\n59\t\n60\t/**\n61\t * Parse a single NDJSON line from Claude's stream-json output.\n62\t *\n63\t * Returns a typed StreamEvent for recognized events, or null for:\n64\t * - Invalid JSON\n65\t * - Empty/whitespace lines\n66\t * - Unrecognized or irrelevant event types (message_start, message_stop, etc.)\n67\t */\n68\texport function parseStreamLine(line: string): StreamEvent | null {\n69\t  const trimmed = line.trim();\n70\t  if (trimmed.length === 0) {\n71\t    return null;\n72\t  }\n73\t\n74\t  let parsed: Record<string, unknown>;\n75\t  try {\n76\t    parsed = JSON.parse(trimmed) as Record<string, unknown>;\n77\t  } catch {\n78\t    // IGNORE: malformed JSON in stream output, skip line\n79\t    return null;\n80\t  }\n81\t\n82\t  if (typeof parsed !== 'object' || parsed === null || Array.isArray(parsed)) {\n83\t    return null;\n84\t  }\n85\t\n86\t  const wrapperType = parsed.type;\n87\t\n88\t  if (wrapperType === 'stream_event') {\n89\t    return parseStreamEvent(parsed);\n90\t  }\n91\t\n92\t  if (wrapperType === 'system') {\n93\t    return parseSystemEvent(parsed);\n94\t  }\n95\t\n96\t  if (wrapperType === 'result') {\n97\t    return parseResultEvent(parsed);\n98\t  }\n99\t\n100\t  return null;\n101\t}\n102\t\n103\t// --- Internal Parsers ---\n104\t\n105\tfunction parseStreamEvent(parsed: Record<string, unknown>): StreamEvent | null {\n106\t  const event = parsed.event as Record<string, unknown> | undefined;\n107\t  if (!event || typeof event !== 'object') {\n108\t    return null;\n109\t  }\n110\t\n111\t  const eventType = event.type as string | undefined;\n112\t\n113\t  if (eventType === 'content_block_start') {\n114\t    return parseContentBlockStart(event);\n115\t  }\n116\t\n117\t  if (eventType === 'content_block_delta') {\n118\t    return parseContentBlockDelta(event);\n119\t  }\n120\t\n121\t  if (eventType === 'content_block_stop') {\n122\t    // NOTE: content_block_stop fires for both tool_use and text blocks.\n123\t    // The parser is stateless and cannot distinguish them. The consumer\n124\t    // (renderer) must track whether the preceding block was a tool_use.\n125\t    return { type: 'tool-complete' };\n126\t  }\n127\t\n128\t  // message_start, message_stop, message_delta — skip\n129\t  return null;\n130\t}\n131\t\n132\tfunction parseContentBlockStart(event: Record<string, unknown>): StreamEvent | null {\n133\t  const contentBlock = event.content_block as Record<string, unknown> | undefined;\n134\t  if (!contentBlock || typeof contentBlock !== 'object') {\n135\t    return null;\n136\t  }\n137\t\n138\t  if (contentBlock.type === 'tool_use') {\n139\t    const name = contentBlock.name;\n140\t    const id = contentBlock.id;\n141\t    if (typeof name === 'string' && typeof id === 'string') {\n142\t      return { type: 'tool-start', name, id };\n143\t    }\n144\t  }\n145\t\n146\t  // content_block_start with type \"text\" — skip (the actual text comes via deltas)\n147\t  return null;\n148\t}\n149\t\n150\tfunction parseContentBlockDelta(event: Record<string, unknown>): StreamEvent | null {\n151\t  const delta = event.delta as Record<string, unknown> | undefined;\n152\t  if (!delta || typeof delta !== 'object') {\n153\t    return null;\n154\t  }\n155\t\n156\t  if (delta.type === 'input_json_delta') {\n157\t    const partialJson = delta.partial_json;\n158\t    if (typeof partialJson === 'string') {\n159\t      return { type: 'tool-input', partial: partialJson };\n160\t    }\n161\t    return null;\n162\t  }\n163\t\n164\t  if (delta.type === 'text_delta') {\n165\t    const text = delta.text;\n166\t    if (typeof text === 'string') {\n167\t      return { type: 'text', text };\n168\t    }\n169\t    return null;\n170\t  }\n171\t\n172\t  return null;\n173\t}\n174\t\n175\tfunction parseSystemEvent(parsed: Record<string, unknown>): StreamEvent | null {\n176\t  const subtype = parsed.subtype as string | undefined;\n177\t  if (subtype === 'api_retry') {\n178\t    const attempt = parsed.attempt;\n179\t    const delay = parsed.retry_delay_ms;\n180\t    if (typeof attempt === 'number' && typeof delay === 'number') {\n181\t      return { type: 'retry', attempt, delay };\n182\t    }\n183\t    return null;\n184\t  }\n185\t\n186\t  return null;\n187\t}\n188\t\n189\tfunction parseResultEvent(parsed: Record<string, unknown>): StreamEvent | null {\n190\t  const costUsd = parsed.cost_usd;\n191\t  const sessionId = parsed.session_id;\n192\t  if (typeof costUsd === 'number' && typeof sessionId === 'string') {\n193\t    return { type: 'result', cost: costUsd, sessionId };\n194\t  }\n195\t  return null;\n196\t}\n197\t"}]},"parent_tool_use_id":"toolu_01UpgK31qGpCnbtuMDgCDmWw","session_id":"e499f49a-fe4c-4b28-bb21-4e83348f2671","uuid":"139543c6-f716-4cdf-a5c2-d6a9673012e5","timestamp":"2026-04-03T06:32:04.504Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SBSjc18M2cdWnCf3dZsNz7","type":"tool_result","content":"1\t/**\n2\t * Public API for the agents subsystem.\n3\t *\n4\t * Re-exports types (story 13-1), stream parser functions/types,\n5\t * and the getDriver() factory (story 13-3).\n6\t *\n7\t * Ralph driver and prompt removed in Story 1.2 — will be replaced\n8\t * by workflow engine in Epic 5.\n9\t */\n10\t\n11\timport type { AgentDriver } from './types.js';\n12\t\n13\t// New types (Epic 10)\n14\texport type {\n15\t  AgentDriver,\n16\t  DriverHealth,\n17\t  DriverCapabilities,\n18\t  DispatchOpts,\n19\t  ErrorCategory,\n20\t  OutputContract,\n21\t  TestResults,\n22\t  ACStatus,\n23\t} from './types.js';\n24\t\n25\t// Deprecated types — kept for backward compatibility until story 10-3\n26\t/** @deprecated Use `DispatchOpts` instead. */\n27\texport type { SpawnOpts } from './types.js';\n28\t/** @deprecated Use `AsyncIterable<StreamEvent>` from `dispatch()` instead. */\n29\texport type { AgentProcess } from './types.js';\n30\t/** @deprecated Use `StreamEvent` from `stream-parser.ts` instead. */\n31\texport type { AgentEvent } from './types.js';\n32\t\n33\t// Stream parser\n34\texport { parseStreamLine } from './stream-parser.js';\n35\texport type {\n36\t  StreamEvent,\n37\t  ToolStartEvent,\n38\t  ToolInputEvent,\n39\t  ToolCompleteEvent,\n40\t  TextEvent,\n41\t  RetryEvent,\n42\t  ResultEvent,\n43\t} from './stream-parser.js';\n44\t\n45\t// --- Driver Factory ---\n46\t\n47\t// TODO: v2 workflow-engine (Epic 5) — rebuild getDriver with workflow-based driver\n48\t/**\n49\t * Returns an AgentDriver instance by name.\n50\t * Throws for all driver names — Ralph removed, workflow engine pending (Epic 5).\n51\t */\n52\texport function getDriver(name?: string, _config?: unknown): AgentDriver {\n53\t  const driverName = name ?? 'default';\n54\t  throw new Error(`No agent drivers available (requested: ${driverName}). Workflow engine pending (Epic 5).`);\n55\t}\n56\t"}]},"parent_tool_use_id":"toolu_01UpgK31qGpCnbtuMDgCDmWw","session_id":"e499f49a-fe4c-4b28-bb21-4e83348f2671","uuid":"2deab25f-d01c-4835-8094-9682f2bd0d3a","timestamp":"2026-04-03T06:32:04.504Z"}
