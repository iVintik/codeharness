{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GUiUeEL2WJTNEZvPHuLZcz","type":"tool_result","content":"     1→/**\n     2→ * Documentation scaffolding for project initialization.\n     3→ * Generates AGENTS.md, docs/ directory structure, and README.md.\n     4→ */\n     5→\n     6→import { existsSync, readFileSync } from 'node:fs';\n     7→import { join, basename } from 'node:path';\n     8→import { ok as okOutput } from '../../lib/output.js';\n     9→import { generateFile } from '../../lib/templates.js';\n    10→import { readmeTemplate } from '../../templates/readme.js';\n    11→import type { Result } from '../../types/result.js';\n    12→import { ok, fail } from '../../types/result.js';\n    13→import type { InitDocumentationResult } from './types.js';\n    14→import type { StackDetection } from '../../lib/stack-detect.js';\n    15→\n    16→const DO_NOT_EDIT_HEADER = '<!-- DO NOT EDIT MANUALLY -->\\n';\n    17→\n    18→export function getProjectName(projectDir: string): string {\n    19→  try {\n    20→    const pkgPath = join(projectDir, 'package.json');\n    21→    if (existsSync(pkgPath)) {\n    22→      const pkg = JSON.parse(readFileSync(pkgPath, 'utf-8')) as Record<string, unknown>;\n    23→      if (pkg.name && typeof pkg.name === 'string') {\n    24→        return pkg.name;\n    25→      }\n    26→    }\n    27→  } catch {\n    28→    // Fall through to Cargo.toml check\n    29→  }\n    30→\n    31→  // Cargo.toml fallback for Rust projects\n    32→  try {\n    33→    const cargoPath = join(projectDir, 'Cargo.toml');\n    34→    if (existsSync(cargoPath)) {\n    35→      const content = readFileSync(cargoPath, 'utf-8');\n    36→      const packageMatch = content.match(/\\[package\\]([\\s\\S]*?)(?=\\n\\[|$)/s);\n    37→      if (packageMatch) {\n    38→        const nameMatch = packageMatch[1].match(/^\\s*name\\s*=\\s*[\"']([^\"']+)[\"']/m);\n    39→        if (nameMatch) {\n    40→          return nameMatch[1];\n    41→        }\n    42→      }\n    43→    }\n    44→  } catch {\n    45→    // Fall through to basename\n    46→  }\n    47→\n    48→  return basename(projectDir);\n    49→}\n    50→\n    51→export function getStackLabel(stack: string | string[] | null): string {\n    52→  if (Array.isArray(stack)) {\n    53→    if (stack.length === 0) return 'Unknown';\n    54→    return stack.map(s => getStackLabel(s)).join(' + ');\n    55→  }\n    56→  if (stack === 'nodejs') return 'Node.js (package.json)';\n    57→  if (stack === 'python') return 'Python';\n    58→  if (stack === 'rust') return 'Rust (Cargo.toml)';\n    59→  return 'Unknown';\n    60→}\n    61→\n    62→export function getCoverageTool(stack: string | null): 'c8' | 'coverage.py' | 'cargo-tarpaulin' | 'unknown' {\n    63→  if (stack === 'python') return 'coverage.py';\n    64→  if (stack === 'rust') return 'cargo-tarpaulin';\n    65→  return 'c8';\n    66→}\n    67→\n    68→export function generateAgentsMdContent(projectDir: string, stack: string | StackDetection[] | null): string {\n    69→  // Multi-stack path: StackDetection[] with more than one entry\n    70→  if (Array.isArray(stack) && stack.length > 1) {\n    71→    return generateMultiStackAgentsMd(projectDir, stack);\n    72→  }\n    73→  // Single-element array: unwrap to string for backward-compatible single-stack output\n    74→  if (Array.isArray(stack)) {\n    75→    stack = stack.length === 1 ? stack[0].stack : null;\n    76→  }\n    77→\n    78→  // Single-stack path: string | null (backward compat)\n    79→  const projectName = basename(projectDir);\n    80→  const stackLabel = stack === 'nodejs' ? 'Node.js' : stack === 'python' ? 'Python' : stack === 'rust' ? 'Rust' : 'Unknown';\n    81→\n    82→  const lines = [\n    83→    `# ${projectName}`,\n    84→    '',\n    85→    '## Stack',\n    86→    '',\n    87→    `- **Language/Runtime:** ${stackLabel}`,\n    88→    '',\n    89→    '## Build & Test Commands',\n    90→    '',\n    91→  ];\n    92→\n    93→  if (stack === 'nodejs') {\n    94→    lines.push(\n    95→      '```bash',\n    96→      'npm install    # Install dependencies',\n    97→      'npm run build  # Build the project',\n    98→      'npm test       # Run tests',\n    99→      '```',\n   100→    );\n   101→  } else if (stack === 'python') {\n   102→    lines.push(\n   103→      '```bash',\n   104→      'pip install -r requirements.txt  # Install dependencies',\n   105→      'python -m pytest                 # Run tests',\n   106→      '```',\n   107→    );\n   108→  } else if (stack === 'rust') {\n   109→    lines.push(\n   110→      '```bash',\n   111→      'cargo build    # Build the project',\n   112→      'cargo test     # Run tests',\n   113→      'cargo tarpaulin --out json  # Run coverage',\n   114→      '```',\n   115→    );\n   116→  } else {\n   117→    lines.push('```bash', '# No recognized stack — add build/test commands here', '```');\n   118→  }\n   119→\n   120→  lines.push(\n   121→    '',\n   122→    '## Project Structure',\n   123→    '',\n   124→    '```',\n   125→    `${projectName}/`,\n   126→    '├── src/           # Source code',\n   127→    '├── tests/         # Test files',\n   128→    '├── docs/          # Documentation',\n   129→    '└── .claude/       # Codeharness state',\n   130→    '```',\n   131→    '',\n   132→    '## Conventions',\n   133→    '',\n   134→    '- All changes must pass tests before commit',\n   135→    '- Maintain test coverage targets',\n   136→    '- Follow existing code style and patterns',\n   137→    '',\n   138→  );\n   139→\n   140→  return lines.join('\\n');\n   141→}\n   142→\n   143→/** Maps stack identifier to display name for AGENTS.md generation. */\n   144→function stackDisplayName(stack: string): string {\n   145→  if (stack === 'nodejs') return 'Node.js';\n   146→  if (stack === 'python') return 'Python';\n   147→  if (stack === 'rust') return 'Rust';\n   148→  return 'Unknown';\n   149→}\n   150→\n   151→function generateMultiStackAgentsMd(projectDir: string, stacks: StackDetection[]): string {\n   152→  const projectName = basename(projectDir);\n   153→  const stackNames = stacks.map(s => stackDisplayName(s.stack));\n   154→\n   155→  const lines = [\n   156→    `# ${projectName}`,\n   157→    '',\n   158→    '## Stack',\n   159→    '',\n   160→    `- **Language/Runtime:** ${stackNames.join(' + ')}`,\n   161→    '',\n   162→    '## Build & Test Commands',\n   163→    '',\n   164→  ];\n   165→\n   166→  for (const detection of stacks) {\n   167→    const label = stackDisplayName(detection.stack);\n   168→    const heading = detection.dir === '.' ? `### ${label}` : `### ${label} (${detection.dir}/)`;\n   169→    const prefix = detection.dir === '.' ? '' : `cd ${detection.dir} && `;\n   170→\n   171→    lines.push(heading, '', '```bash');\n   172→\n   173→    if (detection.stack === 'nodejs') {\n   174→      lines.push(\n   175→        `${prefix}npm install    # Install dependencies`,\n   176→        `${prefix}npm run build  # Build the project`,\n   177→        `${prefix}npm test       # Run tests`,\n   178→      );\n   179→    } else if (detection.stack === 'python') {\n   180→      lines.push(\n   181→        `${prefix}pip install -r requirements.txt  # Install dependencies`,\n   182→        `${prefix}python -m pytest                 # Run tests`,\n   183→      );\n   184→    } else if (detection.stack === 'rust') {\n   185→      lines.push(\n   186→        `${prefix}cargo build    # Build the project`,\n   187→        `${prefix}cargo test     # Run tests`,\n   188→        `${prefix}cargo tarpaulin --out json  # Run coverage`,\n   189→      );\n   190→    }\n   191→\n   192→    lines.push('```', '');\n   193→  }\n   194→\n   195→  lines.push(\n   196→    '## Project Structure',\n   197→    '',\n   198→    '```',\n   199→    `${projectName}/`,\n   200→    '├── src/           # Source code',\n   201→    '├── tests/         # Test files',\n   202→    '├── docs/          # Documentation',\n   203→    '└── .claude/       # Codeharness state',\n   204→    '```',\n   205→    '',\n   206→    '## Conventions',\n   207→    '',\n   208→    '- All changes must pass tests before commit',\n   209→    '- Maintain test coverage targets',\n   210→    '- Follow existing code style and patterns',\n   211→    '',\n   212→  );\n   213→\n   214→  return lines.join('\\n');\n   215→}\n   216→\n   217→export function generateDocsIndexContent(): string {\n   218→  return [\n   219→    '# Project Documentation',\n   220→    '',\n   221→    '## Planning Artifacts',\n   222→    '- [Product Requirements](../_bmad-output/planning-artifacts/prd.md)',\n   223→    '- [Architecture](../_bmad-output/planning-artifacts/architecture.md)',\n   224→    '- [Epics & Stories](../_bmad-output/planning-artifacts/epics.md)',\n   225→    '',\n   226→    '## Execution',\n   227→    '- [Active Exec Plans](exec-plans/active/)',\n   228→    '- [Completed Exec Plans](exec-plans/completed/)',\n   229→    '',\n   230→    '## Quality',\n   231→    '- [Quality Reports](quality/)',\n   232→    '- [Generated Reports](generated/)',\n   233→    '',\n   234→  ].join('\\n');\n   235→}\n   236→\n   237→interface ScaffoldDocsOptions {\n   238→  readonly projectDir: string;\n   239→  readonly stack: string | null;\n   240→  readonly stacks?: StackDetection[];\n   241→  readonly isJson: boolean;\n   242→}\n   243→\n   244→export async function scaffoldDocs(opts: ScaffoldDocsOptions): Promise<Result<InitDocumentationResult>> {\n   245→  try {\n   246→    let agentsMd: 'created' | 'exists' | 'skipped' = 'skipped';\n   247→    let docsScaffold: 'created' | 'exists' | 'skipped' = 'skipped';\n   248→    let readme: 'created' | 'exists' | 'skipped' = 'skipped';\n   249→\n   250→    // AGENTS.md\n   251→    const agentsMdPath = join(opts.projectDir, 'AGENTS.md');\n   252→    if (!existsSync(agentsMdPath)) {\n   253→      const stackArg = opts.stacks && opts.stacks.length > 1 ? opts.stacks : opts.stack;\n   254→      const content = generateAgentsMdContent(opts.projectDir, stackArg);\n   255→      generateFile(agentsMdPath, content);\n   256→      agentsMd = 'created';\n   257→    } else {\n   258→      agentsMd = 'exists';\n   259→    }\n   260→\n   261→    // docs/ scaffold\n   262→    const docsDir = join(opts.projectDir, 'docs');\n   263→    if (!existsSync(docsDir)) {\n   264→      generateFile(join(docsDir, 'index.md'), generateDocsIndexContent());\n   265→      generateFile(join(docsDir, 'exec-plans', 'active', '.gitkeep'), '');\n   266→      generateFile(join(docsDir, 'exec-plans', 'completed', '.gitkeep'), '');\n   267→      generateFile(join(docsDir, 'quality', '.gitkeep'), DO_NOT_EDIT_HEADER);\n   268→      generateFile(join(docsDir, 'generated', '.gitkeep'), DO_NOT_EDIT_HEADER);\n   269→      docsScaffold = 'created';\n   270→    } else {\n   271→      docsScaffold = 'exists';\n   272→    }\n   273→\n   274→    // README.md\n   275→    const readmePath = join(opts.projectDir, 'README.md');\n   276→    if (!existsSync(readmePath)) {\n   277→      let cliHelpOutput = '';\n   278→      try {\n   279→        const { execFileSync } = await import('node:child_process');\n   280→        cliHelpOutput = execFileSync(process.execPath, [process.argv[1], '--help'], {\n   281→          stdio: 'pipe',\n   282→          timeout: 10_000,\n   283→        }).toString();\n   284→      } catch {\n   285→        cliHelpOutput = 'Run: codeharness --help';\n   286→      }\n   287→\n   288→      const readmeStack = opts.stacks && opts.stacks.length > 1\n   289→        ? opts.stacks.map(s => s.stack)\n   290→        : opts.stack;\n   291→      const readmeContent = readmeTemplate({\n   292→        projectName: getProjectName(opts.projectDir),\n   293→        stack: readmeStack,\n   294→        cliHelpOutput,\n   295→      });\n   296→      generateFile(readmePath, readmeContent);\n   297→      readme = 'created';\n   298→    } else {\n   299→      readme = 'exists';\n   300→    }\n   301→\n   302→    const result: InitDocumentationResult = { agents_md: agentsMd, docs_scaffold: docsScaffold, readme };\n   303→\n   304→    if (!opts.isJson) {\n   305→      if (result.agents_md === 'created' || result.docs_scaffold === 'created') {\n   306→        okOutput('Documentation: AGENTS.md + docs/ scaffold created');\n   307→      }\n   308→      if (result.readme === 'created') {\n   309→        okOutput('Documentation: README.md created');\n   310→      }\n   311→    }\n   312→\n   313→    return ok(result);\n   314→  } catch (err) {\n   315→    const message = err instanceof Error ? err.message : String(err);\n   316→    return fail(`Documentation scaffold failed: ${message}`);\n   317→  }\n   318→}\n   319→"}]},"parent_tool_use_id":"toolu_01M6iq2XVtx8hbFMRevefAGh","session_id":"01d3be87-3cff-45e1-920c-7390a9e4093c","uuid":"331ed564-2b98-4f3d-bbd8-7be14e29e6c1","timestamp":"2026-03-24T09:43:01.140Z"}
