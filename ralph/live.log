{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015Lz2QvWTrRnfn1657wcunA","type":"tool_result","content":"     1→/**\n     2→ * Documentation scaffolding for project initialization.\n     3→ * Generates AGENTS.md, docs/ directory structure, and README.md.\n     4→ */\n     5→\n     6→import { existsSync, readFileSync } from 'node:fs';\n     7→import { join, basename } from 'node:path';\n     8→import { ok as okOutput } from '../../lib/output.js';\n     9→import { generateFile } from '../../lib/templates.js';\n    10→import { readmeTemplate } from '../../templates/readme.js';\n    11→import type { Result } from '../../types/result.js';\n    12→import { ok, fail } from '../../types/result.js';\n    13→import type { InitDocumentationResult } from './types.js';\n    14→\n    15→const DO_NOT_EDIT_HEADER = '<!-- DO NOT EDIT MANUALLY -->\\n';\n    16→\n    17→export function getProjectName(projectDir: string): string {\n    18→  try {\n    19→    const pkgPath = join(projectDir, 'package.json');\n    20→    if (existsSync(pkgPath)) {\n    21→      const pkg = JSON.parse(readFileSync(pkgPath, 'utf-8')) as Record<string, unknown>;\n    22→      if (pkg.name && typeof pkg.name === 'string') {\n    23→        return pkg.name;\n    24→      }\n    25→    }\n    26→  } catch {\n    27→    // Fall through to basename\n    28→  }\n    29→  return basename(projectDir);\n    30→}\n    31→\n    32→export function getStackLabel(stack: string | null): string {\n    33→  if (stack === 'nodejs') return 'Node.js (package.json)';\n    34→  if (stack === 'python') return 'Python';\n    35→  return 'Unknown';\n    36→}\n    37→\n    38→export function getCoverageTool(stack: string | null): 'c8' | 'coverage.py' | 'cargo-tarpaulin' | 'unknown' {\n    39→  if (stack === 'python') return 'coverage.py';\n    40→  if (stack === 'rust') return 'cargo-tarpaulin';\n    41→  return 'c8';\n    42→}\n    43→\n    44→export function generateAgentsMdContent(projectDir: string, stack: string | null): string {\n    45→  const projectName = basename(projectDir);\n    46→  const stackLabel = stack === 'nodejs' ? 'Node.js' : stack === 'python' ? 'Python' : 'Unknown';\n    47→\n    48→  const lines = [\n    49→    `# ${projectName}`,\n    50→    '',\n    51→    '## Stack',\n    52→    '',\n    53→    `- **Language/Runtime:** ${stackLabel}`,\n    54→    '',\n    55→    '## Build & Test Commands',\n    56→    '',\n    57→  ];\n    58→\n    59→  if (stack === 'nodejs') {\n    60→    lines.push(\n    61→      '```bash',\n    62→      'npm install    # Install dependencies',\n    63→      'npm run build  # Build the project',\n    64→      'npm test       # Run tests',\n    65→      '```',\n    66→    );\n    67→  } else if (stack === 'python') {\n    68→    lines.push(\n    69→      '```bash',\n    70→      'pip install -r requirements.txt  # Install dependencies',\n    71→      'python -m pytest                 # Run tests',\n    72→      '```',\n    73→    );\n    74→  } else {\n    75→    lines.push('```bash', '# No recognized stack — add build/test commands here', '```');\n    76→  }\n    77→\n    78→  lines.push(\n    79→    '',\n    80→    '## Project Structure',\n    81→    '',\n    82→    '```',\n    83→    `${projectName}/`,\n    84→    '├── src/           # Source code',\n    85→    '├── tests/         # Test files',\n    86→    '├── docs/          # Documentation',\n    87→    '└── .claude/       # Codeharness state',\n    88→    '```',\n    89→    '',\n    90→    '## Conventions',\n    91→    '',\n    92→    '- All changes must pass tests before commit',\n    93→    '- Maintain test coverage targets',\n    94→    '- Follow existing code style and patterns',\n    95→    '',\n    96→  );\n    97→\n    98→  return lines.join('\\n');\n    99→}\n   100→\n   101→export function generateDocsIndexContent(): string {\n   102→  return [\n   103→    '# Project Documentation',\n   104→    '',\n   105→    '## Planning Artifacts',\n   106→    '- [Product Requirements](../_bmad-output/planning-artifacts/prd.md)',\n   107→    '- [Architecture](../_bmad-output/planning-artifacts/architecture.md)',\n   108→    '- [Epics & Stories](../_bmad-output/planning-artifacts/epics.md)',\n   109→    '',\n   110→    '## Execution',\n   111→    '- [Active Exec Plans](exec-plans/active/)',\n   112→    '- [Completed Exec Plans](exec-plans/completed/)',\n   113→    '',\n   114→    '## Quality',\n   115→    '- [Quality Reports](quality/)',\n   116→    '- [Generated Reports](generated/)',\n   117→    '',\n   118→  ].join('\\n');\n   119→}\n   120→\n   121→interface ScaffoldDocsOptions {\n   122→  readonly projectDir: string;\n   123→  readonly stack: string | null;\n   124→  readonly isJson: boolean;\n   125→}\n   126→\n   127→export async function scaffoldDocs(opts: ScaffoldDocsOptions): Promise<Result<InitDocumentationResult>> {\n   128→  try {\n   129→    let agentsMd: 'created' | 'exists' | 'skipped' = 'skipped';\n   130→    let docsScaffold: 'created' | 'exists' | 'skipped' = 'skipped';\n   131→    let readme: 'created' | 'exists' | 'skipped' = 'skipped';\n   132→\n   133→    // AGENTS.md\n   134→    const agentsMdPath = join(opts.projectDir, 'AGENTS.md');\n   135→    if (!existsSync(agentsMdPath)) {\n   136→      const content = generateAgentsMdContent(opts.projectDir, opts.stack);\n   137→      generateFile(agentsMdPath, content);\n   138→      agentsMd = 'created';\n   139→    } else {\n   140→      agentsMd = 'exists';\n   141→    }\n   142→\n   143→    // docs/ scaffold\n   144→    const docsDir = join(opts.projectDir, 'docs');\n   145→    if (!existsSync(docsDir)) {\n   146→      generateFile(join(docsDir, 'index.md'), generateDocsIndexContent());\n   147→      generateFile(join(docsDir, 'exec-plans', 'active', '.gitkeep'), '');\n   148→      generateFile(join(docsDir, 'exec-plans', 'completed', '.gitkeep'), '');\n   149→      generateFile(join(docsDir, 'quality', '.gitkeep'), DO_NOT_EDIT_HEADER);\n   150→      generateFile(join(docsDir, 'generated', '.gitkeep'), DO_NOT_EDIT_HEADER);\n   151→      docsScaffold = 'created';\n   152→    } else {\n   153→      docsScaffold = 'exists';\n   154→    }\n   155→\n   156→    // README.md\n   157→    const readmePath = join(opts.projectDir, 'README.md');\n   158→    if (!existsSync(readmePath)) {\n   159→      let cliHelpOutput = '';\n   160→      try {\n   161→        const { execFileSync } = await import('node:child_process');\n   162→        cliHelpOutput = execFileSync(process.execPath, [process.argv[1], '--help'], {\n   163→          stdio: 'pipe',\n   164→          timeout: 10_000,\n   165→        }).toString();\n   166→      } catch {\n   167→        cliHelpOutput = 'Run: codeharness --help';\n   168→      }\n   169→\n   170→      const readmeContent = readmeTemplate({\n   171→        projectName: getProjectName(opts.projectDir),\n   172→        stack: opts.stack,\n   173→        cliHelpOutput,\n   174→      });\n   175→      generateFile(readmePath, readmeContent);\n   176→      readme = 'created';\n   177→    } else {\n   178→      readme = 'exists';\n   179→    }\n   180→\n   181→    const result: InitDocumentationResult = { agents_md: agentsMd, docs_scaffold: docsScaffold, readme };\n   182→\n   183→    if (!opts.isJson) {\n   184→      if (result.agents_md === 'created' || result.docs_scaffold === 'created') {\n   185→        okOutput('Documentation: AGENTS.md + docs/ scaffold created');\n   186→      }\n   187→      if (result.readme === 'created') {\n   188→        okOutput('Documentation: README.md created');\n   189→      }\n   190→    }\n   191→\n   192→    return ok(result);\n   193→  } catch (err) {\n   194→    const message = err instanceof Error ? err.message : String(err);\n   195→    return fail(`Documentation scaffold failed: ${message}`);\n   196→  }\n   197→}\n   198→"}]},"parent_tool_use_id":"toolu_01CGkWizVB7CtGCqwFm5rfNr","session_id":"6b184f1a-3a3f-4307-8da0-d8cf52066851","uuid":"bf698728-70be-46bd-9710-1b02a998acc5","timestamp":"2026-03-23T05:23:03.787Z"}
