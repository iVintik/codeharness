{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CLKiWPjQEpXSXBG3u7rXLZ","type":"tool_result","content":"     1→/**\n     2→ * Types for the verify module.\n     3→ * Merged from src/lib/verify.ts and src/lib/verify-parser.ts.\n     4→ */\n     5→\n     6→import type { AcResult } from '../../types/state.js';\n     7→\n     8→// ─── Parser Types ────────────────────────────────────────────────────────────\n     9→\n    10→/** @deprecated Use `VerificationTier` instead. Will be removed in a future release. */\n    11→export type Verifiability = 'cli-verifiable' | 'integration-required';\n    12→\n    13→/** The four verification tiers — what evidence is needed to prove ACs work. */\n    14→export type VerificationTier = 'test-provable' | 'runtime-provable' | 'environment-provable' | 'escalate';\n    15→\n    16→/** Tier ordering from lowest to highest. Index = priority. */\n    17→export const TIER_HIERARCHY: readonly VerificationTier[] = [\n    18→  'test-provable',\n    19→  'runtime-provable',\n    20→  'environment-provable',\n    21→  'escalate',\n    22→] as const;\n    23→\n    24→/** Returns the highest tier from an array of tiers. Empty array -> 'test-provable'. */\n    25→export function maxTier(tiers: VerificationTier[]): VerificationTier {\n    26→  if (tiers.length === 0) return 'test-provable';\n    27→  return tiers.reduce((max, t) =>\n    28→    TIER_HIERARCHY.indexOf(t) > TIER_HIERARCHY.indexOf(max) ? t : max\n    29→  );\n    30→}\n    31→\n    32→/** Maps old tag values to new VerificationTier values for backward compat. */\n    33→export const LEGACY_TIER_MAP: Record<string, VerificationTier> = {\n    34→  'cli-verifiable': 'test-provable',\n    35→  'integration-required': 'environment-provable',\n    36→  'unit-testable': 'test-provable',\n    37→  'black-box': 'environment-provable',\n    38→};\n    39→\n    40→/**\n    41→ * Verification strategy — how the verifier should approach proving an AC.\n    42→ *\n    43→ * @deprecated Use `VerificationTier` instead. Will be removed in a future release.\n    44→ *\n    45→ * - docker:    Run in a Docker container (default, safest)\n    46→ * - cli-direct: Run CLI commands in the current subprocess (fallback)\n    47→ * - escalate:   Truly impossible — requires physical hardware, external paid\n    48→ *               service, or human judgement. Last resort only.\n    49→ */\n    50→export type VerificationStrategy = 'docker' | 'cli-direct' | 'escalate';\n    51→\n    52→export interface ParsedAC {\n    53→  readonly id: string;\n    54→  readonly description: string;\n    55→  readonly type: 'ui' | 'api' | 'db' | 'general';\n    56→  /** @deprecated Use `tier` instead. */\n    57→  readonly verifiability: Verifiability;\n    58→  /** @deprecated Use `tier` instead. */\n    59→  readonly strategy: VerificationStrategy;\n    60→  /** The verification tier for this AC. */\n    61→  readonly tier: VerificationTier;\n    62→}\n    63→\n    64→// ─── Proof Quality Types ─────────────────────────────────────────────────────\n    65→\n    66→export interface ProofQuality {\n    67→  readonly verified: number;\n    68→  readonly pending: number;\n    69→  readonly escalated: number;\n    70→  readonly total: number;\n    71→  readonly passed: boolean;\n    72→  /** Count of `grep ... src/` commands in evidence (black-box metric) */\n    73→  readonly grepSrcCount: number;\n    74→  /** Count of `docker exec` commands in evidence (black-box metric) */\n    75→  readonly dockerExecCount: number;\n    76→  /** Count of observability query commands in evidence (black-box metric) */\n    77→  readonly observabilityCount: number;\n    78→  /** Count of other commands in evidence (black-box metric) */\n    79→  readonly otherCount: number;\n    80→  /** Whether the proof passes black-box enforcement checks */\n    81→  readonly blackBoxPass: boolean;\n    82→}\n    83→\n    84→export type EvidenceCommandType =\n    85→  | 'docker-exec'\n    86→  | 'docker-host'\n    87→  | 'observability'\n    88→  | 'grep-src'\n    89→  | 'other';\n    90→\n    91→export interface ClassifiedCommand {\n    92→  readonly command: string;\n    93→  readonly type: EvidenceCommandType;\n    94→}\n    95→\n    96→// ─── Orchestrator Types ──────────────────────────────────────────────────────\n    97→\n    98→export interface VerifyResult {\n    99→  readonly storyId: string;\n   100→  readonly success: boolean;\n   101→  readonly totalACs: number;\n   102→  readonly verifiedCount: number;\n   103→  readonly failedCount: number;\n   104→  readonly escalatedCount: number;\n   105→  readonly proofPath: string;\n   106→  readonly showboatVerifyStatus: 'pass' | 'fail' | 'skipped';\n   107→  /** Number of ACs with observability gaps (Story 2.1) */\n   108→  readonly observabilityGapCount: number;\n   109→  /** Runtime coverage percentage: ACs with logs / total ACs * 100 (Story 2.1) */\n   110→  readonly runtimeCoveragePercent: number;\n   111→  readonly perAC: ReadonlyArray<{\n   112→    readonly id: string;\n   113→    readonly description: string;\n   114→    readonly verified: boolean;\n   115→    readonly evidencePaths: readonly string[];\n   116→  }>;\n   117→}\n   118→\n   119→export interface PreconditionResult {\n   120→  readonly passed: boolean;\n   121→  readonly failures: readonly string[];\n   122→}\n   123→\n   124→export interface ShowboatVerifyResult {\n   125→  readonly passed: boolean;\n   126→  readonly output: string;\n   127→}\n   128→\n   129→// ─── Observability Gap Types ─────────────────────────────────────────────\n   130→\n   131→/** Per-AC observability gap presence */\n   132→export interface ObservabilityGapEntry {\n   133→  /** Acceptance criterion identifier */\n   134→  readonly acId: string;\n   135→  /** Whether an observability gap was detected */\n   136→  readonly hasGap: boolean;\n   137→  /** The gap note text, if present */\n   138→  readonly gapNote?: string;\n   139→}\n   140→\n   141→/** Result of parsing observability gaps from proof content */\n   142→export interface ObservabilityGapResult {\n   143→  /** Per-AC gap presence */\n   144→  readonly entries: readonly ObservabilityGapEntry[];\n   145→  /** Total number of ACs found in proof */\n   146→  readonly totalACs: number;\n   147→  /** Number of ACs with observability gaps */\n   148→  readonly gapCount: number;\n   149→  /** Number of ACs without gaps (produced log events) */\n   150→  readonly coveredCount: number;\n   151→}\n   152→\n   153→// ─── Env Types ───────────────────────────────────────────────────────────────\n   154→\n   155→/** Project type for verification strategy selection. */\n   156→export type ProjectType = 'nodejs' | 'python' | 'rust' | 'plugin' | 'generic';\n   157→\n   158→export interface BuildOptions {\n   159→  readonly projectDir?: string;\n   160→}\n   161→\n   162→export interface BuildResult {\n   163→  readonly imageTag: string;\n   164→  readonly imageSize: string;\n   165→  readonly buildTimeMs: number;\n   166→  readonly cached: boolean;\n   167→}\n   168→\n   169→export interface CheckResult {\n   170→  readonly imageExists: boolean;\n   171→  readonly cliWorks: boolean;\n   172→  readonly otelReachable: boolean;\n   173→}\n   174→\n   175→// ─── Browser Verifier Types ──────────────────────────────────────────────────\n   176→\n   177→export interface BrowserActionResult {\n   178→  readonly output: string;\n   179→  readonly screenshotPath?: string;\n   180→  readonly exitCode: number;\n   181→}\n   182→\n   183→export interface DiffResult {\n   184→  readonly hasDifferences: boolean;\n   185→  readonly beforePath: string;\n   186→  readonly afterPath: string;\n   187→}\n   188→\n   189→// ─── Black-Box Enforcement Result ────────────────────────────────────────────\n   190→\n   191→export interface BlackBoxEnforcementResult {\n   192→  readonly blackBoxPass: boolean;\n   193→  readonly grepSrcCount: number;\n   194→  readonly dockerExecCount: number;\n   195→ 