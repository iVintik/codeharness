{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AjQJdrbrhh9vWr9LxcJLqM","type":"tool_result","content":"1\t/**\n2\t * Stream Event Parser — converts Claude stream-json NDJSON lines into typed events.\n3\t *\n4\t * Stateless per-line: accepts one NDJSON line, returns one typed event or null.\n5\t * Accumulation (e.g., building full tool input from deltas) is the caller's responsibility.\n6\t *\n7\t * Event format reference:\n8\t * - Wrapper type \"stream_event\" contains API events (content_block_start, etc.)\n9\t * - Wrapper type \"system\" contains Claude Code events (api_retry, etc.)\n10\t * - Wrapper type \"result\" is the final event with session_id, cost, result text\n11\t */\n12\t\n13\t// --- Event Types ---\n14\t\n15\texport interface ToolStartEvent {\n16\t  readonly type: 'tool-start';\n17\t  readonly name: string;\n18\t  readonly id: string;\n19\t}\n20\t\n21\texport interface ToolInputEvent {\n22\t  readonly type: 'tool-input';\n23\t  readonly partial: string;\n24\t}\n25\t\n26\texport interface ToolCompleteEvent {\n27\t  readonly type: 'tool-complete';\n28\t}\n29\t\n30\texport interface TextEvent {\n31\t  readonly type: 'text';\n32\t  readonly text: string;\n33\t}\n34\t\n35\texport interface RetryEvent {\n36\t  readonly type: 'retry';\n37\t  readonly attempt: number;\n38\t  readonly delay: number;\n39\t}\n40\t\n41\texport interface ResultEvent {\n42\t  readonly type: 'result';\n43\t  readonly cost: number;\n44\t  readonly sessionId: string;\n45\t  /** Normalized cost in USD for multi-driver comparison. */\n46\t  readonly cost_usd?: number | null;\n47\t  /** Error message when the dispatch failed. Absent on success. */\n48\t  readonly error?: string;\n49\t  /** Classified error category. Present only when `error` is set. */\n50\t  readonly errorCategory?: import('../agents/types.js').ErrorCategory;\n51\t}\n52\t\n53\t/** Discriminated union of all stream events the parser can emit. */\n54\texport type StreamEvent =\n55\t  | ToolStartEvent\n56\t  | ToolInputEvent\n57\t  | ToolCompleteEvent\n58\t  | TextEvent\n59\t  | RetryEvent\n60\t  | ResultEvent;\n61\t\n62\t// --- Parser ---\n63\t\n64\t/**\n65\t * Parse a single NDJSON line from Claude's stream-json output.\n66\t *\n67\t * Returns a typed StreamEvent for recognized events, or null for:\n68\t * - Invalid JSON\n69\t * - Empty/whitespace lines\n70\t * - Unrecognized or irrelevant event types (message_start, message_stop, etc.)\n71\t */\n72\texport function parseStreamLine(line: string): StreamEvent | null {\n73\t  const trimmed = line.trim();\n74\t  if (trimmed.length === 0) {\n75\t    return null;\n76\t  }\n77\t\n78\t  let parsed: Record<string, unknown>;\n79\t  try {\n80\t    parsed = JSON.parse(trimmed) as Record<string, unknown>;\n81\t  } catch {\n82\t    // IGNORE: malformed JSON in stream output, skip line\n83\t    return null;\n84\t  }\n85\t\n86\t  if (typeof parsed !== 'object' || parsed === null || Array.isArray(parsed)) {\n87\t    return null;\n88\t  }\n89\t\n90\t  const wrapperType = parsed.type;\n91\t\n92\t  if (wrapperType === 'stream_event') {\n93\t    return parseStreamEvent(parsed);\n94\t  }\n95\t\n96\t  if (wrapperType === 'system') {\n97\t    return parseSystemEvent(parsed);\n98\t  }\n99\t\n100\t  if (wrapperType === 'result') {\n101\t    return parseResultEvent(parsed);\n102\t  }\n103\t\n104\t  return null;\n105\t}\n106\t\n107\t// --- Internal Parsers ---\n108\t\n109\tfunction parseStreamEvent(parsed: Record<string, unknown>): StreamEvent | null {\n110\t  const event = parsed.event as Record<string, unknown> | undefined;\n111\t  if (!event || typeof event !== 'object') {\n112\t    return null;\n113\t  }\n114\t\n115\t  const eventType = event.type as string | undefined;\n116\t\n117\t  if (eventType === 'content_block_start') {\n118\t    return parseContentBlockStart(event);\n119\t  }\n120\t\n121\t  if (eventType === 'content_block_delta') {\n122\t    return parseContentBlockDelta(event);\n123\t  }\n124\t\n125\t  if (eventType === 'content_block_stop') {\n126\t    // NOTE: content_block_stop fires for both tool_use and text blocks.\n127\t    // The parser is stateless and cannot distinguish them. The consumer\n128\t    // (renderer) must track whether the preceding block was a tool_use.\n129\t    return { type: 'tool-complete' };\n130\t  }\n131\t\n132\t  // message_start, message_stop, message_delta — skip\n133\t  return null;\n134\t}\n135\t\n136\tfunction parseContentBlockStart(event: Record<string, unknown>): StreamEvent | null {\n137\t  const contentBlock = event.content_block as Record<string, unknown> | undefined;\n138\t  if (!contentBlock || typeof contentBlock !== 'object') {\n139\t    return null;\n140\t  }\n141\t\n142\t  if (contentBlock.type === 'tool_use') {\n143\t    const name = contentBlock.name;\n144\t    const id = contentBlock.id;\n145\t    if (typeof name === 'string' && typeof id === 'string') {\n146\t      return { type: 'tool-start', name, id };\n147\t    }\n148\t  }\n149\t\n150\t  // content_block_start with type \"text\" — skip (the actual text comes via deltas)\n151\t  return null;\n152\t}\n153\t\n154\tfunction parseContentBlockDelta(event: Record<string, unknown>): StreamEvent | null {\n155\t  const delta = event.delta as Record<string, unknown> | undefined;\n156\t  if (!delta || typeof delta !== 'object') {\n157\t    return null;\n158\t  }\n159\t\n160\t  if (delta.type === 'input_json_delta') {\n161\t    const partialJson = delta.partial_json;\n162\t    if (typeof partialJson === 'string') {\n163\t      return { type: 'tool-input', partial: partialJson };\n164\t    }\n165\t    return null;\n166\t  }\n167\t\n168\t  if (delta.type === 'text_delta') {\n169\t    const text = delta.text;\n170\t    if (typeof text === 'string') {\n171\t      return { type: 'text', text };\n172\t    }\n173\t    return null;\n174\t  }\n175\t\n176\t  return null;\n177\t}\n178\t\n179\tfunction parseSystemEvent(parsed: Record<string, unknown>): StreamEvent | null {\n180\t  const subtype = parsed.subtype as string | undefined;\n181\t  if (subtype === 'api_retry') {\n182\t    const attempt = parsed.attempt;\n183\t    const delay = parsed.retry_delay_ms;\n184\t    if (typeof attempt === 'number' && typeof delay === 'number') {\n185\t      return { type: 'retry', attempt, delay };\n186\t    }\n187\t    return null;\n188\t  }\n189\t\n190\t  return null;\n191\t}\n192\t\n193\tfunction parseResultEvent(parsed: Record<string, unknown>): StreamEvent | null {\n194\t  const costUsd = parsed.cost_usd;\n195\t  const sessionId = parsed.session_id;\n196\t  if (typeof costUsd === 'number' && typeof sessionId === 'string') {\n197\t    return { type: 'result', cost: costUsd, sessionId };\n198\t  }\n199\t  return null;\n200\t}\n201\t"}]},"parent_tool_use_id":"toolu_01WAycfHnC8swrmkjbQ2XuWH","session_id":"576f74f4-0d7f-4316-a569-4c3ab5c122fd","uuid":"933dff31-ccdd-45b8-9052-684fbf89c5d1","timestamp":"2026-04-03T08:56:13.617Z"}
