{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TPv33eEs3NqfbGazNzwPfU","type":"tool_result","content":"     1→/**\n     2→ * AgentDriver abstraction types.\n     3→ *\n     4→ * Defines the contract that all agent drivers (Ralph, future API-based agents)\n     5→ * must implement. See architecture-v3.md Decision 3.\n     6→ */\n     7→\n     8→import type { Readable } from 'node:stream';\n     9→\n    10→/**\n    11→ * Options for spawning an agent process.\n    12→ */\n    13→export interface SpawnOpts {\n    14→  storyKey: string;\n    15→  prompt: string;\n    16→  workDir: string;\n    17→  timeout: number;\n    18→  env?: Record<string, string>;\n    19→}\n    20→\n    21→/**\n    22→ * Abstraction over a running agent process.\n    23→ * Wraps Node.js ChildProcess but allows non-process-based drivers\n    24→ * (direct API calls, WebSocket connections) to implement the same interface.\n    25→ */\n    26→export interface AgentProcess {\n    27→  stdout: Readable;\n    28→  stderr: Readable;\n    29→  on(event: 'close', handler: (code: number) => void): void;\n    30→  on(event: 'error', handler: (err: Error) => void): void;\n    31→  kill(signal?: string): void;\n    32→}\n    33→\n    34→/**\n    35→ * Discriminated union of events emitted by an agent driver.\n    36→ * The `parseOutput()` method converts raw agent output lines into these typed events.\n    37→ */\n    38→export type AgentEvent =\n    39→  | { type: 'tool-start'; name: string }\n    40→  | { type: 'tool-complete'; name?: string; args?: string }\n    41→  | { type: 'text'; text: string }\n    42→  | { type: 'story-complete'; key: string; details: string }\n    43→  | { type: 'story-failed'; key: string; reason: string }\n    44→  | { type: 'iteration'; count: number }\n    45→  | { type: 'retry'; attempt: number; delay: number }\n    46→  | { type: 'result'; cost: number; sessionId: string };\n    47→\n    48→/**\n    49→ * The core agent driver interface.\n    50→ * Each driver knows how to spawn an agent, parse its output, and locate its status file.\n    51→ */\n    52→export interface AgentDriver {\n    53→  readonly name: string;\n    54→  spawn(opts: SpawnOpts): AgentProcess;\n    55→  parseOutput(line: string): AgentEvent | null;\n    56→  getStatusFile(): string;\n    57→}\n    58→"}]},"parent_tool_use_id":"toolu_01AeYymucNLjmuqL83DiV485","session_id":"a5a043ae-cfd1-4d51-82dd-d0069edc63ef","uuid":"eda261ac-4c9e-465f-9c9f-c39378f70e87","timestamp":"2026-03-24T16:30:29.902Z"}
