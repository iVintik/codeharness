{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011PskLhCqbjFQ913w2vdf4W","type":"tool_result","content":"3590\t    // verify gets contract from implement\n3591\t    expect(contractCalls[2].contract).not.toBeNull();\n3592\t    expect(contractCalls[2].contract?.taskName).toBe('implement');\n3593\t  });\n3594\t});\n3595\t\n3596\t// --- Story 16-4: Verify Flag Propagation ---\n3597\t\n3598\tdescribe('propagateVerifyFlags (story 16-4)', () => {\n3599\t  beforeEach(() => {\n3600\t    vi.clearAllMocks();\n3601\t    setupDefaultMocks();\n3602\t  });\n3603\t\n3604\t  function makeContract(overrides?: Partial<OutputContract>): OutputContract {\n3605\t    return {\n3606\t      version: 1,\n3607\t      taskName: 'implement',\n3608\t      storyId: '5-1-foo',\n3609\t      driver: 'claude-code',\n3610\t      model: 'claude-sonnet-4-20250514',\n3611\t      timestamp: '2026-04-03T00:00:00.000Z',\n3612\t      cost_usd: 0.05,\n3613\t      duration_ms: 1000,\n3614\t      changedFiles: [],\n3615\t      testResults: null,\n3616\t      output: 'Done',\n3617\t      acceptanceCriteria: [],\n3618\t      ...overrides,\n3619\t    };\n3620\t  }\n3621\t\n3622\t  /**\n3623\t   * Helper: set up the driver to return a stream whose output contract\n3624\t   * will have a specific taskName (via the engine's internal contract builder).\n3625\t   * The propagation function reads from the contract built by the engine,\n3626\t   * which always has testResults: null — but we override readStateWithBody\n3627\t   * to verify that propagateVerifyFlags is called correctly.\n3628\t   *\n3629\t   * Since the engine builds contracts with testResults: null, we need to\n3630\t   * intercept the writeOutputContract call to inject testResults into the\n3631\t   * contract that gets returned from dispatchTaskWithResult.\n3632\t   */\n3633\t\n3634\t  it('AC#1: implement task with failed === 0 sets tests_passed = true', async () => {\n3635\t    // Override writeOutputContract to capture and inject testResults\n3636\t    let capturedContract: OutputContract | null = null;\n3637\t    mockWriteOutputContract.mockImplementation((contract: OutputContract) => {\n3638\t      capturedContract = contract;\n3639\t    });\n3640\t\n3641\t    // The engine builds contracts with testResults: null.\n3642\t    // propagateVerifyFlags reads the contract returned by dispatchTaskWithResult.\n3643\t    // Since testResults is always null in engine-built contracts, we need to\n3644\t    // test propagateVerifyFlags through dispatchTask by making the engine\n3645\t    // actually produce a contract with testResults.\n3646\t    //\n3647\t    // But the engine hardcodes testResults: null. The propagation logic\n3648\t    // operates on whatever contract the engine builds. So for now, the\n3649\t    // production path won't trigger until testResults parsing is added.\n3650\t    //\n3651\t    // Test strategy: call dispatchTask with task named 'implement',\n3652\t    // verify that writeState is NOT called (since testResults is null).\n3653\t    // Then test the actual propagation logic by directly testing state writes\n3654\t    // when the mock returns contracts with testResults.\n3655\t\n3656\t    await dispatchTask(\n3657\t      makeTask({ scope: 'per-story' }),\n3658\t      'implement',\n3659\t      '5-1-foo',\n3660\t      makeDefinition(),\n3661\t      makeDefaultState(),\n3662\t      makeConfig(),\n3663\t    );\n3664\t\n3665\t    // Engine-built contracts have testResults: null, so no propagation should occur\n3666\t    expect(mockWriteState).not.toHaveBeenCalled();\n3667\t  });\n3668\t\n3669\t  it('AC#3: implement task with testResults: null does not change any flags', async () => {\n3670\t    await dispatchTask(\n3671\t      makeTask({ scope: 'per-story' }),\n3672\t      'implement',\n3673\t      '5-1-foo',\n3674\t      makeDefinition(),\n3675\t      makeDefaultState(),\n3676\t      makeConfig(),\n3677\t    );\n3678\t\n3679\t    // testResults is null in engine-built contracts → no state writes\n3680\t    expect(mockWriteState).not.toHaveBeenCalled();\n3681\t  });\n3682\t\n3683\t  it('AC#7: non-implement task does not trigger flag propagation', async () => {\n3684\t    await dispatchTask(\n3685\t      makeTask({ scope: 'per-run', source_access: false }),\n3686\t      'verify',\n3687\t      PER_RUN_SENTINEL,\n3688\t      makeDefinition(),\n3689\t      makeDefaultState(),\n3690\t      makeConfig(),\n3691\t    );\n3692\t\n3693\t    expect(mockWriteState).not.toHaveBeenCalled();\n3694\t  });\n3695\t\n3696\t  // --- Direct propagation logic tests via executeWorkflow with mocked contracts ---\n3697\t  // These tests verify the propagation logic by intercepting the contract construction\n3698\t\n3699\t  it('AC#1,#2: sets both tests_passed and coverage_met when both conditions met', async () => {\n3700\t    // Intercept writeOutputContract to inject testResults into the contract\n3701\t    // We modify the contract object in-place so propagateVerifyFlags sees it\n3702\t    mockWriteOutputContract.mockImplementation((contract: OutputContract) => {\n3703\t      // Mutate the contract to add testResults (the engine builds mutable objects\n3704\t      // despite the readonly interface — the object literal is not frozen)\n3705\t      (contract as Record<string, unknown>).testResults = {\n3706\t        passed: 10,\n3707\t        failed: 0,\n3708\t        coverage: 95,\n3709\t      };\n3710\t    });\n3711\t\n3712\t    await dispatchTask(\n3713\t      makeTask({ scope: 'per-story' }),\n3714\t      'implement',\n3715\t      '5-1-foo',\n3716\t      makeDefinition(),\n3717\t      makeDefaultState(),\n3718\t      makeConfig(),\n3719\t    );\n3720\t\n3721\t    // propagateVerifyFlags should have been called with the mutated contract\n3722\t    expect(mockReadStateWithBody).toHaveBeenCalledWith('/project');\n3723\t    expect(mockWriteState).toHaveBeenCalledTimes(1);\n3724\t\n3725\t    const writtenState = mockWriteState.mock.calls[0][0];\n3726\t    expe