{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01P5gtpBTLpwzHCXm7XN7sCC","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import {\n     3→  formatElapsed,\n     4→  mapSprintStatus,\n     5→  mapSprintStatuses,\n     6→  parseRalphMessage,\n     7→  parseIterationMessage,\n     8→  countStories,\n     9→  buildSpawnArgs,\n    10→} from '../run-helpers.js';\n    11→\n    12→describe('formatElapsed', () => {\n    13→  it('formats 0ms as \"0m\"', () => {\n    14→    expect(formatElapsed(0)).toBe('0m');\n    15→  });\n    16→\n    17→  it('formats sub-minute as \"0m\"', () => {\n    18→    expect(formatElapsed(30_000)).toBe('0m');\n    19→  });\n    20→\n    21→  it('formats 1 minute', () => {\n    22→    expect(formatElapsed(60_000)).toBe('1m');\n    23→  });\n    24→\n    25→  it('formats 47 minutes', () => {\n    26→    expect(formatElapsed(47 * 60_000)).toBe('47m');\n    27→  });\n    28→\n    29→  it('formats 60 minutes as \"1h0m\"', () => {\n    30→    expect(formatElapsed(60 * 60_000)).toBe('1h0m');\n    31→  });\n    32→\n    33→  it('formats 2h14m', () => {\n    34→    expect(formatElapsed((2 * 60 + 14) * 60_000)).toBe('2h14m');\n    35→  });\n    36→\n    37→  it('handles negative values as \"0m\"', () => {\n    38→    expect(formatElapsed(-5000)).toBe('0m');\n    39→  });\n    40→\n    41→  it('truncates fractional minutes (rounds down)', () => {\n    42→    // 1m 59s → still 1m\n    43→    expect(formatElapsed(119_000)).toBe('1m');\n    44→  });\n    45→});\n    46→\n    47→describe('mapSprintStatus', () => {\n    48→  it('maps done to done', () => {\n    49→    expect(mapSprintStatus('done')).toBe('done');\n    50→  });\n    51→\n    52→  it('maps in-progress to in-progress', () => {\n    53→    expect(mapSprintStatus('in-progress')).toBe('in-progress');\n    54→  });\n    55→\n    56→  it('maps review to in-progress', () => {\n    57→    expect(mapSprintStatus('review')).toBe('in-progress');\n    58→  });\n    59→\n    60→  it('maps verifying to in-progress', () => {\n    61→    expect(mapSprintStatus('verifying')).toBe('in-progress');\n    62→  });\n    63→\n    64→  it('maps backlog to pending', () => {\n    65→    expect(mapSprintStatus('backlog')).toBe('pending');\n    66→  });\n    67→\n    68→  it('maps ready-for-dev to pending', () => {\n    69→    expect(mapSprintStatus('ready-for-dev')).toBe('pending');\n    70→  });\n    71→\n    72→  it('maps failed to failed', () => {\n    73→    expect(mapSprintStatus('failed')).toBe('failed');\n    74→  });\n    75→\n    76→  it('maps blocked to blocked', () => {\n    77→    expect(mapSprintStatus('blocked')).toBe('blocked');\n    78→  });\n    79→\n    80→  it('maps exhausted to blocked', () => {\n    81→    expect(mapSprintStatus('exhausted')).toBe('blocked');\n    82→  });\n    83→\n    84→  it('maps unknown statuses to pending', () => {\n    85→    expect(mapSprintStatus('some-unknown')).toBe('pending');\n    86→  });\n    87→});\n    88→\n    89→describe('mapSprintStatuses', () => {\n    90→  it('converts sprint-status entries to StoryStatusEntry[]', () => {\n    91→    const entries = mapSprintStatuses({\n    92→      'epic-1': 'done',\n    93→      '1-1-story-a': 'done',\n    94→      '1-2-story-b': 'in-progress',\n    95→      '1-3-story-c': 'backlog',\n    96→      'epic-1-retrospective': 'optional',\n    97→    });\n    98→    expect(entries).toEqual([\n    99→      { key: '1-1-story-a', status: 'done' },\n   100→      { key: '1-2-story-b', status: 'in-progress' },\n   101→      { key: '1-3-story-c', status: 'pending' },\n   102→    ]);\n   103→  });\n   104→\n   105→  it('filters out epic keys and optional entries', () => {\n   106→    const entries = mapSprintStatuses({\n   107→      'epic-5': 'in-progress',\n   108→      '5-1-foo': 'review',\n   109→      'epic-5-retrospective': 'optional',\n   110→    });\n   111→    expect(entries).toEqual([\n   112→      { key: '5-1-foo', status: 'in