result.data.gaps[0].description).toContain('state file missing');\n   376→    }\n   377→  });\n   378→});\n   379→\n   380→// ─── checkDocumentation ─────────────────────────────────────────────────────\n   381→\n   382→describe('checkDocumentation', () => {\n   383→  it('returns pass when all docs fresh', () => {\n   384→    mockScanDocHealth.mockReturnValue({\n   385→      documents: [\n   386→        { path: 'AGENTS.md', grade: 'fresh', lastModified: new Date(), codeLastModified: new Date(), reason: 'Up to date' },\n   387→      ],\n   388→      summary: { fresh: 1, stale: 0, missing: 0, total: 1 },\n   389→      passed: true,\n   390→      scanDurationMs: 50,\n   391→    });\n   392→\n   393→    const result = checkDocumentation('/project');\n   394→    expect(result.success).toBe(true);\n   395→    if (result.success) {\n   396→      expect(result.data.status).toBe('pass');\n   397→      expect(result.data.metric).toBe('1 fresh, 0 stale, 0 missing');\n   398→    }\n   399→  });\n   400→\n   401→  it('returns fail when docs missing', () => {\n   402→    mockScanDocHealth.mockReturnValue({\n   403→      documents: [\n   404→        { path: 'AGENTS.md', grade: 'missing', lastModified: null, codeLastModified: null, reason: 'Root AGENTS.md not found' },\n   405→      ],\n   406→      summary: { fresh: 0, stale: 0, missing: 1, total: 1 },\n   407→      passed: false,\n   408→      scanDurationMs: 50,\n   409→    });\n   410→\n   411→    const result = checkDocumentation('/project');\n   412→    expect(result.success).toBe(true);\n   413→    if (result.success) {\n   414→      expect(result.data.status).toBe('fail');\n   415→      expect(result.data.gaps.length).toBeGreaterThan(0);\n   416→    }\n   417→  });\n   418→\n   419→  it('returns warn when docs stale', () => {\n   420→    mockScanDocHealth.mockReturnValue({\n   421→      documents: [\n   422→        { path: 'AGENTS.md', grade: 'stale', lastModified: new Date(), codeLastModified: new Date(), reason: 'Stale' }