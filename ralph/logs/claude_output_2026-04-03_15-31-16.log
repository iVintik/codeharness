{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01F5SeYEvRA5zHd7sqy5uNZr","type":"tool_result","content":"1\t/**\n2\t * WorkflowGraph ã Ink component that renders a schematic workflow graph.\n3\t *\n4\t * Displays tasks as nodes connected by arrows, with status indicators\n5\t * (pending, active, done, failed). Loop blocks are rendered with an\n6\t * iteration counter and visual grouping.\n7\t *\n8\t * This is a pure presentational component ã no side effects, no state hooks.\n9\t */\n10\t\n11\timport React from 'react';\n12\timport { Text, Box } from 'ink';\n13\timport type { FlowStep, LoopBlock } from './workflow-parser.js';\n14\timport type { TaskNodeState } from './ink-components.js';\n15\t\n16\t/** Terminal width, capped to avoid excessive line lengths. */\n17\tconst termWidth = () => Math.min(process.stdout.columns || 60, 80);\n18\t\n19\texport interface WorkflowGraphProps {\n20\t  flow: FlowStep[];\n21\t  currentTask: string | null;\n22\t  taskStates: Record<string, TaskNodeState>;\n23\t}\n24\t\n25\tfunction isLoopBlock(step: FlowStep): step is LoopBlock {\n26\t  return typeof step === 'object' && step !== null && 'loop' in step;\n27\t}\n28\t\n29\t/** Render a single task name with its status indicator. */\n30\tfunction TaskNode({ name, status }: { name: string; status: TaskNodeState | undefined }) {\n31\t  const s = status ?? 'pending';\n32\t  switch (s) {\n33\t    case 'done':\n34\t      return <Text color=\"green\">{name} ã</Text>;\n35\t    case 'active':\n36\t      return <Text color=\"cyan\">ã {name}</Text>;\n37\t    case 'failed':\n38\t      return <Text color=\"red\">{name} ã</Text>;\n39\t    case 'pending':\n40\t    default:\n41\t      return <Text dimColor>{name}</Text>;\n42\t  }\n43\t}\n44\t\n45\t/** Count completed iterations for a loop block based on task states. */\n46\tfunction loopIteration(tasks: string[], taskStates: Record<string, TaskNodeState>): number {\n47\t  // Heuristic: 0 before any task starts, 1 once any task is active/done/failed.\n48\t  // Proper multi-iteration counting requires engine-provided iteration data,\n49\t  // which will be wired when the engine integration story lands.\n50\t  const anyStarted = tasks.some(t => {\n51\t    const s = taskStates[t];\n52\t    return s !== undefined && s !== 'pending';\n53\t  });\n54\t  return anyStarted ? 1 : 0;\n55\t}\n56\t\n57\texport function WorkflowGraph({ flow, currentTask, taskStates }: WorkflowGraphProps) {\n58\t  if (flow.length === 0 || Object.keys(taskStates).length === 0) {\n59\t    return null;\n60\t  }\n61\t\n62\t  const elements: React.ReactNode[] = [];\n63\t\n64\t  for (let i = 0; i < flow.length; i++) {\n65\t    const step = flow[i];\n66\t\n67\t    if (i > 0) {\n68\t      elements.push(<Text key={`arrow-${i}`}>{' ã '}</Text>);\n69\t    }\n70\t\n71\t    if (isLoopBlock(step)) {\n72\t      const iteration = loopIteration(step.loop, taskStates);\n73\t      const loopNodes: React.ReactNode[] = [];\n74\t      for (let j = 0; j < step.loop.length; j++) {\n75\t        if (j > 0) {\n76\t          loopNodes.push(<Text key={`loop-arrow-${i}-${j}`}>{' ã '}</Text>);\n77\t        }\n78\t        loopNodes.push(\n79\t          <TaskNode key={`loop-task-${i}-${j}`} name={step.loop[j]} status={taskStates[step.loop[j]]} />\n80\t        );\n81\t      }\n82\t      elements.push(\n83\t        <Text key={`loop-${i}`}>\n84\t          <Text>loop({iteration})[ </Text>\n85\t          {loopNodes}\n86\t          <Text> ]</Text>\n87\t        </Text>\n88\t      );\n89\t    } else {\n90\t      elements.push(\n91\t        <TaskNode key={`task-${i}`} name={step} status={taskStates[step]} />\n92\t      );\n93\t    }\n94\t  }\n95\t\n96\t  return (\n97\t    <Box flexDirection=\"column\">\n98\t      <Text>{'ã'.repeat(termWidth())}</Text>\n99\t      <Text>  {elements}</Text>\n100\t      <Text>{'ã'.repeat(termWidth())}</Text>\n101\t    </Box>\n102\t  );\n103\t}\n104\t"}]},"parent_tool_use_id":"toolu_019DMmBw36UEa9mKyd4eDFiB","session_id":"87203133-5cdd-4288-8e5c-bcff0e178735","uuid":"deb8e2e4-4fc3-4e10-b79c-b586abc14633","timestamp":"2026-04-03T11:38:15.095Z"}
