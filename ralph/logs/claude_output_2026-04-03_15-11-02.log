{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011EurAgEYLMJtk6F5XLsMqM","type":"tool_result","content":"80\t  let cleaned = false;\n81\t\n82\t  // Mount Ink with performance options\n83\t  const inkInstance = inkRender(<App state={state} />, {\n84\t    exitOnCtrlC: false,\n85\t    patchConsole: !options?._forceTTY,\n86\t    maxFps: 15,\n87\t  });\n88\t\n89\t  function rerender() {\n90\t    if (!cleaned) {\n91\t      // Create a new state object reference to trigger React re-render\n92\t      state = { ...state };\n93\t      inkInstance.rerender(<App state={state} />);\n94\t    }\n95\t  }\n96\t\n97\t  function cleanup() {\n98\t    if (cleaned) return;\n99\t    cleaned = true;\n100\t    try {\n101\t      inkInstance.unmount();\n102\t    } catch {\n103\t      // Ignore — may already be unmounted\n104\t    }\n105\t    try {\n106\t      inkInstance.cleanup();\n107\t    } catch {\n108\t      // Ignore\n109\t    }\n110\t    // Remove our signal handlers\n111\t    process.removeListener('SIGINT', onSigint);\n112\t    process.removeListener('SIGTERM', onSigterm);\n113\t  }\n114\t\n115\t  function onSigint() {\n116\t    cleanup();\n117\t    // Re-raise signal so the default handler runs (allows caller to handle exit)\n118\t    process.kill(process.pid, 'SIGINT');\n119\t  }\n120\t\n121\t  function onSigterm() {\n122\t    cleanup();\n123\t    process.kill(process.pid, 'SIGTERM');\n124\t  }\n125\t\n126\t  // Register signal handlers\n127\t  process.on('SIGINT', onSigint);\n128\t  process.on('SIGTERM', onSigterm);\n129\t\n130\t  function update(event: StreamEvent): void {\n131\t    if (cleaned) return;\n132\t\n133\t    switch (event.type) {\n134\t      case 'tool-start':\n135\t        // If a long-running tool was still active, promote it to completed now\n136\t        if (state.activeTool) {\n137\t          const entry: CompletedToolEntry = {\n138\t            name: state.activeTool.name,\n139\t            args: state.activeToolArgs,\n140\t          };\n141\t          const updated = [...state.completedTools, entry];\n142\t          state.completedTools = updated.length > MAX_COMPLETED_TOOLS\n143\t            ? updated.slice(updated.length - MAX_COMPLETED_TOOLS)\n144\t            : updated;\n145\t        }\n146\t        state.activeTool = { name: event.name };\n147\t        state.activeToolArgs = '';\n148\t        state.lastThought = null;\n149\t        state.retryInfo = null;\n150\t        break;\n151\t\n152\t      case 'tool-input':\n153\t        state.activeToolArgs += event.partial;\n154\t        return; // Skip rerender — args only shown on completion\n155\t\n156\t      case 'tool-complete':\n157\t        // CRITICAL: Only promote if there's an active tool.\n158\t        // The parser emits tool-complete for ALL content_block_stop events\n159\t        // (both tool and text blocks). Ignore if no activeTool is set.\n160\t        if (state.activeTool) {\n161\t          // Long-running tools (Agent, Skill) get content_block_stop when their\n162\t          // INPUT is complete, not when they finish executing. Keep them active\n163\t          // so the spinner shows during the entire execution. They'll be promoted\n164\t          // when the next tool-start fires (below in tool-start case).\n165\t          const LONG_RUNNING_TOOLS = ['Agent', 'Skill'];\n166\t          if (LONG_RUNNING_TOOLS.includes(state.activeTool.name)) {\n167\t            break; // Keep as active — don't promote to completed yet\n168\t          }\n169\t          const entry: CompletedToolEntry = {\n170\t            name: state.activeTool.name,\n171\t            args: state.activeToolArgs,\n172\t          };\n173\t          const updated = [...state.completedTools, entry];\n174\t          // Bound the list to prevent unbounded memory growth in long sessions\n175\t          state.completedTools = updated.length > MAX_COMPLETED_TOOLS\n176\t            ? updated.slice(updated.length - MAX_COMPLETED_TOOLS)\n177\t            : updated;\n178\t          state.activeTool = null;\n179\t          state.activeToolArgs = '';\n180\t        }\n181\t        break;\n182\t\n183\t      case 'text':\n184\t        state.lastThought = event.text;\n185\t        state.retryInfo = null;\n186\t        break;\n187\t\n188\t      case 'retry':\n189\t        state.retryInfo = { attempt: event.attempt, delay: event.delay };\n190\t        break;\n191\t\n192\t      case 'result':\n193\t        // Accumulate cost from result events (AC #7)\n194\t        if (event.cost > 0 && state.sprintInfo) {\n195\t          state.sprintInfo = {\n196\t            ...state.sprintInfo,\n197\t            totalCost: (state.sprintInfo.totalCost ?? 0) + event.cost,\n198\t          };\n199\t        }\n200\t        break;\n201\t    }\n202\t\n203\t    rerender();\n204\t  }\n205\t\n206\t  function updateSprintState(sprintState: SprintInfo | undefined): void {\n207\t    if (cleaned) return;\n208\t    if (sprintState && state.sprintInfo) {\n209\t      // Preserve accumulated fields (totalCost, acProgress, currentCommand)\n210\t      // that are set by event handlers but not by the polling caller.\n211\t      state.sprintInfo = {\n212\t        ...sprintState,\n213\t        totalCost: sprintState.totalCost ?? state.sprintInfo.totalCost,\n214\t        acProgress: sprintState.acProgress ?? state.sprintInfo.acProgress,\n215\t        currentCommand: sprintState.currentCommand ?? state.sprintInfo.currentCommand,\n216\t      };\n217\t    } else {\n218\t      state.sprintInfo = sprintState ?? null;\n219\t    }\n220\t    rerender();\n221\t  }\n222\t\n223\t  function updateStories(stories: StoryStatusEntry[]): void {\n224\t    if (cleaned) return;\n225\t    state.stories = [...stories];\n226\t    rerender();\n227\t  }\n228\t\n229\t  function addMessage(msg: StoryMessage): void {\n230\t    if (cleaned) return;\n231\t    state.messages = [...state.messages, msg];\n232\t    rerender();\n233\t  }\n234\t\n235\t  return { update, updateSprintState, updateStories, addMessage, cleanup };\n236\t}\n237\t\n238\t// Re-export types that consumers may need\n239\texport type { SprintInfo, CompletedToolEntry, RetryInfo, RendererState, StoryStatusEntry, StoryStatusValue, StoryMessage } from './ink-components.js';\n240\t"}]},"parent_tool_use_id":"toolu_01R36a3At1jqzjisMujLFJtW","session_id":"1d40f54a-b143-44f0-8247-609f8fc4c105","uuid":"53bc8af2-3f38-4fe2-87ca-16aaa2e19a83","timestamp":"2026-04-03T11:12:55.893Z"}
