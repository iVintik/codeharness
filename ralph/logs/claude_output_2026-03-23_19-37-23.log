kflows/4-implementation/sprint-planning/workflow.yaml\n/Users/ivintik/dev/personal/codeharness/_bmad/bmm/workflows/4-implementation/sprint-status/workflow.yaml\n/Users/ivintik/dev/personal/codeharness/_bmad/bmm/workflows/bmad-quick-flow/quick-dev/workflow.md\n/Users/ivintik/dev/personal/codeharness/_bmad/bmm/workflows/bmad-quick-flow/quick-spec/workflow.md\n/Users/ivintik/dev/personal/codeharness/_bmad/bmm/workflows/document-project/workflow.yaml\n/Users/ivintik/dev/personal/codeharness/_bmad/bmm/workflows/generate-project-context/workflow.md\n/Users/ivintik/dev/personal/codeharness/_bmad/bmm/workflows/qa/automate/workflow.yaml\n/Users/ivintik/dev/personal/codeharness/_bmad/core/tasks/workflow.xml\n/Users/ivintik/dev/personal/codeharness/_bmad/core/workflows/advanced-elicitation/workflow.xml\n/Users/ivintik/dev/personal/codeharness/_bmad/core/workflows/brainstorming/workflow.md\n/Users/ivintik/dev/personal/codeharness/_bmad/core/workflows/party-mode/workflow.md"}]},"parent_tool_use_id":"toolu_017stQocDjYtQWzyiuCXnw1e","session_id":"58ae4f51-bff6-4a66-807a-d4f10c8bdaa3","uuid":"9f4f3afd-4618-455a-8e80-5996666d6a72","timestamp":"2026-03-23T15:51:21.557Z"}
