{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013xbPg8toV5BziLUXeioAnx","type":"tool_result","content":"     1→/**\n     2→ * Dockerfile template generator — creates stack-appropriate Dockerfiles for user projects.\n     3→ * Returns Result<DockerfileTemplateResult> following the project's Result<T> pattern.\n     4→ *\n     5→ * FR22 (Dockerfile template based on project type).\n     6→ * Supports single-stack and multi-stage (multi-stack) Dockerfile generation.\n     7→ *\n     8→ * Templates are read from static files in templates/dockerfiles/ via renderTemplateFile().\n     9→ */\n    10→\n    11→import { existsSync, writeFileSync } from 'node:fs';\n    12→import { join } from 'node:path';\n    13→import { ok, fail } from '../../types/result.js';\n    14→import type { Result } from '../../types/result.js';\n    15→import type { StackDetection } from '../../lib/stacks/index.js';\n    16→import { getStackProvider } from '../../lib/stacks/index.js';\n    17→import type { StackName } from '../../lib/stacks/index.js';\n    18→import { renderTemplateFile } from '../../lib/templates.js';\n    19→\n    20→/** Result returned by generateDockerfileTemplate */\n    21→export interface DockerfileTemplateResult {\n    22→  readonly path: string;\n    23→  readonly stack: string;\n    24→  readonly stacks: string[];\n    25→}\n    26→\n    27→// ─── Template content generators ────────────────────────────────────────────\n    28→\n    29→function nodejsTemplate(): string {\n    30→  return renderTemplateFile('templates/dockerfiles/Dockerfile.nodejs');\n    31→}\n    32→\n    33→function pythonTemplate(): string {\n    34→  return renderTemplateFile('templates/dockerfiles/Dockerfile.python');\n    35→}\n    36→\n    37→function rustTemplate(): string {\n    38→  return renderTemplateFile('templates/dockerfiles/Dockerfile.rust');\n    39→}\n    40→\n    41→function genericTemplate(): string {\n    42→  return renderTemplateFile('templates/dockerfiles/Dockerfile.generic');\n    43→}\n    44→\n    45→// ─── Multi-stage build-stage content extractors ─────────────────────────────\n    46→\n    47→/** COPY directives for each stack in the runtime stage */\n    48→function runtimeCopyDirectives(stacks: string[]): string {\n    49→  const lines: string[] = [];\n    50→  for (const stack of stacks) {\n    51→    const provider = getStackProvider(stack as StackName);\n    52→    if (provider) {\n    53→      lines.push(provider.getRuntimeCopyDirectives());\n    54→    }\n    55→  }\n    56→  return lines.join('\\n');\n    57→}\n    58→\n    59→/** Compose a multi-stage Dockerfile from multiple stack detections */\n    60→function multiStageTemplate(detections: StackDetection[]): string {\n    61→  // Filter to only stacks with a registered provider (all registered providers support multi-stage)\n    62→  const supported = detections.filter(d => getStackProvider(d.stack) !== undefined);\n    63→  if (supported.length === 0) {\n    64→    // All stacks unknown — fall back to generic-like runtime-only Dockerfile\n    65→    return genericTemplate();\n    66→  }\n    67→  const stacks = supported.map(d => d.stack);\n    68→\n    69→  const buildStages: string[] = [];\n    70→  for (const stack of stacks) {\n    71→    const provider = getStackProvider(stack as StackName);\n    72→    if (provider) {\n    73→      buildStages.push(provider.getDockerBuildStage());\n    74→    }\n    75→  }\n    76→\n    77→  const copyLines = runtimeCopyDirectives(stacks);\n    78→\n    79→  return renderTemplateFile('templates/dockerfiles/Dockerfile.multi-stage.tmpl', {\n    80→    BUILD_STAGES: buildStages.join('\\n'),\n    81→    COPY_DIRECTIVES: copyLines,\n    82→  });\n    83→}\n    84→\n    85→// ─── Main generator ─────────────────────────────────────────────────────────\n    86→\n    87→/**\n    88→ * Generate a Dockerfile template based on detected stack type.\n    89→ * Accepts either a string stack name (backward compat) or StackDetection[] for multi-stack.\n    90→ * Returns fail() if a Dockerfile already exists — caller handles messaging.\n    91→ */\n    92→export function generateDockerfileTemplate(\n    93→  projectDir: string,\n    94→  stackOrDetections: string | null | StackDetection[],\n    95→): Result<DockerfileTemplateResult> {\n    96→  if (!projectDir) {\n    97→    return fail('projectDir is required');\n    98→  }\n    99→\n   100→  const dockerfilePath = join(projectDir, 'Dockerfile');\n   101→\n   102→  if (existsSync(dockerfilePath)) {\n   103→    return fail('Dockerfile already exists');\n   104→  }\n   105→\n   106→  // Multi-stack path: StackDetection[] with >1 entry\n   107→  if (Array.isArray(stackOrDetections) && stackOrDetections.length > 1) {\n   108→    const content = multiStageTemplate(stackOrDetections);\n   109→    const stacks = stackOrDetections.map(d => d.stack);\n   110→    try {\n   111→      writeFileSync(dockerfilePath, content, 'utf-8');\n   112→    } catch (err) {\n   113→      const message = err instanceof Error ? err.message : String(err);\n   114→      return fail(`Failed to write Dockerfile: ${message}`);\n   115→    }\n   116→    return ok({ path: dockerfilePath, stack: stacks[0], stacks });\n   117→  }\n   118→\n   119→  // Resolve single stack from StackDetection[] or string\n   120→  const stack: string | null = Array.isArray(stackOrDetections)\n   121→    ? (stackOrDetections.length === 1 ? stackOrDetections[0].stack : null)\n   122→    : stackOrDetections;\n   123→\n   124→  let content: string;\n   125→  let resolvedStack: string;\n   126→\n   127→  const provider = stack ? getStackProvider(stack as StackName) : undefined;\n   128→  if (provider) {\n   129→    content = provider.getDockerfileTemplate();\n   130→    resolvedStack = provider.name;\n   131→  } else {\n   132→    content = genericTemplate();\n   133→    resolvedStack = 'generic';\n   134→  }\n   135→\n   136→  try {\n   137→    writeFileSync(dockerfilePath, content, 'utf-8');\n   138→  } catch (err) {\n   139→    const message = err instanceof Error ? err.message : String(err);\n   140→    return fail(`Failed to write Dockerfile: ${message}`);\n   141→  }\n   142→\n   143→  return ok({ path: dockerfilePath, stack: resolvedStack, stacks: [resolvedStack] });\n   144→}\n   145→"}]},"parent_tool_use_id":"toolu_01L5LiJHunZnUnw7ysWAKpUU","session_id":"7c5953f4-1d55-4aa9-825f-60bc73601e00","uuid":"89187f1a-3e9a-46a5-a728-00d80cb8f3e4","timestamp":"2026-03-25T02:03:41.309Z"}
