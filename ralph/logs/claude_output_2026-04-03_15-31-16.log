{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UYBTWPALsz4dtpAk6YcyuH","type":"tool_result","content":"1\t/**\n2\t * Ink Terminal Renderer ã live terminal UI for Claude activity display.\n3\t *\n4\t * Exports a controller API: startRenderer(), which returns a RendererHandle\n5\t * with update(), updateSprintState(), and cleanup() methods.\n6\t *\n7\t * The renderer accumulates state from StreamEvent objects and renders\n8\t * tool calls, thoughts, and sprint progress using Ink (React for terminals).\n9\t */\n10\t\n11\timport React from 'react';\n12\timport { render as inkRender } from 'ink';\n13\timport type { StreamEvent } from './agents/stream-parser.js';\n14\timport {\n15\t  App,\n16\t  type SprintInfo,\n17\t  type CompletedToolEntry,\n18\t  type RetryInfo,\n19\t  type RendererState,\n20\t  type StoryStatusEntry,\n21\t  type StoryMessage,\n22\t  type TaskNodeState,\n23\t} from './ink-components.js';\n24\timport type { FlowStep } from './workflow-parser.js';\n25\t\n26\t// --- Public Types ---\n27\t\n28\texport interface RendererOptions {\n29\t  quiet?: boolean;\n30\t  sprintState?: SprintInfo;\n31\t  /** @internal Force TTY mode for testing. Not part of the public API. */\n32\t  _forceTTY?: boolean;\n33\t}\n34\t\n35\texport interface RendererHandle {\n36\t  update(event: StreamEvent): void;\n37\t  updateSprintState(state: SprintInfo | undefined): void;\n38\t  updateStories(stories: StoryStatusEntry[]): void;\n39\t  addMessage(msg: StoryMessage): void;\n40\t  updateWorkflowState(flow: FlowStep[], currentTask: string | null, taskStates: Record<string, TaskNodeState>): void;\n41\t  cleanup(): void;\n42\t}\n43\t\n44\t// --- No-op handle for quiet mode ---\n45\t\n46\tconst noopHandle: RendererHandle = {\n47\t  update() {},\n48\t  updateSprintState() {},\n49\t  updateStories() {},\n50\t  addMessage() {},\n51\t  updateWorkflowState() {},\n52\t  cleanup() {},\n53\t};\n54\t\n55\t/** Maximum number of completed tools to retain in the display list. */\n56\tconst MAX_COMPLETED_TOOLS = 50;\n57\t\n58\t// --- Controller ---\n59\t\n60\t/**\n61\t * Start the Ink terminal renderer.\n62\t *\n63\t * If `quiet` is true or stdout is not a TTY, returns a no-op handle\n64\t * (no Ink instance created).\n65\t * Otherwise, mounts the component tree and returns a handle for feeding events.\n66\t */\n67\texport function startRenderer(options?: RendererOptions): RendererHandle {\n68\t  if (options?.quiet || (!process.stdout.isTTY && !options?._forceTTY)) {\n69\t    return noopHandle;\n70\t  }\n71\t\n72\t  // Mutable state that drives re-renders\n73\t  let state: RendererState = {\n74\t    sprintInfo: options?.sprintState ?? null,\n75\t    stories: [],\n76\t    messages: [],\n77\t    completedTools: [],\n78\t    activeTool: null,\n79\t    activeToolArgs: '',\n80\t    lastThought: null,\n81\t    retryInfo: null,\n82\t    workflowFlow: [],\n83\t    currentTaskName: null,\n84\t    taskStates: {},\n85\t  };\n86\t\n87\t  let cleaned = false;\n88\t\n89\t  // Mount Ink with performance options\n90\t  const inkInstance = inkRender(<App state={state} />, {\n91\t    exitOnCtrlC: false,\n92\t    patchConsole: !options?._forceTTY,\n93\t    maxFps: 15,\n94\t  });\n95\t\n96\t  function rerender() {\n97\t    if (!cleaned) {\n98\t      // Create a new state object reference to trigger React re-render\n99\t      state = { ...state };\n100\t      inkInstance.rerender(<App state={state} />);\n101\t    }\n102\t  }\n103\t\n104\t  function cleanup() {\n105\t    if (cleaned) return;\n106\t    cleaned = true;\n107\t    try {\n108\t      inkInstance.unmount();\n109\t    } catch {\n110\t      // Ignore ã may already be unmounted\n111\t    }\n112\t    try {\n113\t      inkInstance.cleanup();\n114\t    } catch {\n115\t      // Ignore\n116\t    }\n117\t    // Remove our signal handlers\n118\t    process.removeListener('SIGINT', onSigint);\n119\t    process.removeListener('SIGTERM', onSigterm);\n120\t  }\n121\t\n122\t  function onSigint() {\n123\t    cleanup();\n124\t    // Re-raise signal so the default handler runs (allows caller to handle exit)\n125\t    process.kill(process.pid, 'SIGINT');\n126\t  }\n127\t\n128\t  function onSigterm() {\n129\t    cleanup();\n130\t    process.kill(process.pid, 'SIGTERM');\n131\t  }\n132\t\n133\t  // Register signal handlers\n134\t  process.on('SIGINT', onSigint);\n135\t  process.on('SIGTERM', onSigterm);\n136\t\n137\t  function update(event: StreamEvent): void {\n138\t    if (cleaned) return;\n139\t\n140\t    switch (event.type) {\n141\t      case 'tool-start':\n142\t        // If a long-running tool was still active, promote it to completed now\n143\t        if (state.activeTool) {\n144\t          const entry: CompletedToolEntry = {\n145\t            name: state.activeTool.name,\n146\t            args: state.activeToolArgs,\n147\t          };\n148\t          const updated = [...state.completedTools, entry];\n149\t          state.completedTools = updated.length > MAX_COMPLETED_TOOLS\n150\t            ? updated.slice(updated.length - MAX_COMPLETED_TOOLS)\n151\t            : updated;\n152\t        }\n153\t        state.activeTool = { name: event.name };\n154\t        state.activeToolArgs = '';\n155\t        state.lastThought = null;\n156\t        state.retryInfo = null;\n157\t        break;\n158\t\n159\t      case 'tool-input':\n160\t        state.activeToolArgs += event.partial;\n161\t        return; // Skip rerender ã args only shown on completion\n162\t\n163\t      case 'tool-complete':\n164\t        // CRITICAL: Only promote if there's an active tool.\n165\t        // The parser emits tool-complete for ALL content_block_stop events\n166\t        // (both tool and text blocks). Ignore if no activeTool is set.\n167\t        if (state.activeTool) {\n168\t          // Long-running tools (Agent, Skill) get content_block_stop when their\n169\t          // INPUT is complete, not when they finish executing. Keep them active\n170\t          // so the spinner shows during the entire execution. They'll be promoted\n171\t          // when the next tool-start fires (below in tool-start case).\n172\t          const LONG_RUNNING_TOOLS = ['Agent', 'Skill'];\n173\t          if (LONG_RUNNING_TOOLS.includes(state.activeTool.name)) {\n174\t            break; // Keep as active ã don't promote to completed yet\n175\t          }\n176\t          const entry: CompletedToolEntry = {\n177\t            name: state.activeTool.name,\n178\t            args: state.activeToolArgs,\n179\t          };\n180\t          const updated = [...state.completedTools, entry];\n181\t          // Bound the list to prevent unbounded memory growth in long sessions\n182\t          state.completedTools = updated.length > MAX_COMPLETED_TOOLS\n183\t            ? updated.slice(updated.length - MAX_COMPLETED_TOOLS)\n184\t            : updated;\n185\t          state.activeTool = null;\n186\t          state.activeToolArgs = '';\n187\t        }\n188\t        break;\n189\t\n190\t      case 'text':\n191\t        state.lastThought = event.text;\n192\t        state.retryInfo = null;\n193\t        break;\n194\t\n195\t      case 'retry':\n196\t        state.retryInfo = { attempt: event.attempt, delay: event.delay };\n197\t        break;\n198\t\n199\t      case 'result':\n200\t        // Accumulate cost from result events (AC #7)\n201\t        if (event.cost > 0 && state.sprintInfo) {\n202\t          state.sprintInfo = {\n203\t            ...state.sprintInfo,\n204\t            totalCost: (state.sprintInfo.totalCost ?? 0) + event.cost,\n205\t          };\n206\t        }\n207\t        break;\n208\t    }\n209\t\n210\t    rerender();\n211\t  }\n212\t\n213\t  function updateSprintState(sprintState: SprintInfo | undefined): void {\n214\t    if (cleaned) return;\n215\t    if (sprintState && state.sprintInfo) {\n216\t      // Preserve accumulated fields (totalCost, acProgress, currentCommand)\n217\t      // that are set by event handlers but not by the polling caller.\n218\t      state.sprintInfo = {\n219\t        ...sprintState,\n220\t        totalCost: sprintState.totalCost ?? state.sprintInfo.totalCost,\n221\t        acProgress: sprintState.acProgress ?? state.sprintInfo.acProgress,\n222\t        currentCommand: sprintState.currentCommand ?? state.sprintInfo.currentCommand,\n223\t      };\n224\t    } else {\n225\t      state.sprintInfo = sprintState ?? null;\n226\t    }\n227\t    rerender();\n228\t  }\n229\t\n230\t  function updateStories(stories: StoryStatusEntry[]): void {\n231\t    if (cleaned) return;\n232\t    state.stories = [...stories];\n233\t    rerender();\n234\t  }\n235\t\n236\t  function addMessage(msg: StoryMessage): void {\n237\t    if (cleaned) return;\n238\t    state.messages = [...state.messages, msg];\n239\t    rerender();\n240\t  }\n241\t\n242\t  function updateWorkflowState(flow: FlowStep[], currentTask: string | null, taskStates: Record<string, TaskNodeState>): void {\n243\t    if (cleaned) return;\n244\t    state.workflowFlow = flow;\n245\t    state.currentTaskName = currentTask;\n246\t    state.taskStates = { ...taskStates };\n247\t    rerender();\n248\t  }\n249\t\n250\t  return { update, updateSprintState, updateStories, addMessage, updateWorkflowState, cleanup };\n251\t}\n252\t\n253\t// Re-export types that consumers may need\n254\texport type { SprintInfo, CompletedToolEntry, RetryInfo, RendererState, StoryStatusEntry, StoryStatusValue, StoryMessage, TaskNodeState } from './ink-components.js';\n255\t"}]},"parent_tool_use_id":"toolu_019DMmBw36UEa9mKyd4eDFiB","session_id":"87203133-5cdd-4288-8e5c-bcff0e178735","uuid":"b6b08e40-f876-44b6-8962-3dc75197de02","timestamp":"2026-04-03T11:38:16.001Z"}
{"type":"system","subtype":"task_progress","task_id":"a666b46e70a53ec23","tool_use_id":"toolu_019DMmBw36UEa9mKyd4eDFiB","description":"Reading src/lib/__tests__/ink-workflow.test.tsx","usage":{"total_tokens":29280,"tool_uses":10,"duration_ms":23440},"last_tool_name":"Read","uuid":"57b1974f-f4dc-4f4e-91b7-e454e0518c4e","session_id":"87203133-5cdd-4288-8e5c-bcff0e178735"}
