ctStack, detectStacks } from '../../../lib/stacks/index.js';\n    47→import { readStateWithBody, writeState } from '../../../lib/state.js';\n    48→import {\n    49→  isValidStoryKey,\n    50→  computeDistHash,\n    51→  buildVerifyImage,\n    52→  detectProjectType,\n    53→  prepareVerifyWorkspace,\n    54→  checkVerifyEnv,\n    55→  cleanupVerifyEnv,\n    56→  cleanupStaleContainers,\n    57→} from '../env.js';\n    58→\n    59→const mockExecFileSync = vi.mocked(execFileSync);\n    60→const mockIsDockerAvailable = vi.mocked(isDockerAvailable);\n    61→const mockDetectStack = vi.mocked(detectStack);\n    62→const mockDetectStacks = vi.mocked(detectStacks);\n    63→const mockReadStateWithBody = vi.mocked(readStateWithBody);\n    64→const mockWriteState = vi.mocked(writeState);\n    65→\n    66→let testDir: string;\n    67→\n    68→beforeEach(() => {\n    69→  vi.clearAllMocks();\n    70→  testDir = mkdtempSync(join(tmpdir(), 'ch-verify-env-test-'));\n    71→  // Reset default mock behaviors after clearAllMocks\n    72→  mockIsDockerAvailable.mockReturnValue(true);\n    73→  mockDetectStack.mockReturnValue('nodejs');\n    74→  mockDetectStacks.mockReturnValue([{ stack: 'nodejs', dir: '.' }]);\n    75→});\n    76→\n    77→afterEach(() => {\n    78→  rmSync(testDir, { recursive: true, force: true });\n    79→});\n    80→\n    81→// ─── isValidStoryKey ────────────────────────────────────────────────────────\n    82→\n    83→describe('isValidStoryKey', () => {\n    84→  it('accepts valid story keys', () => {\n    85→    expect(isValidStoryKey('13-1-verification-dockerfile-generator')).toBe(true);\n    86→    expect(isValidStoryKey('story_key_123')).toBe(true);\n    87→    expect(isValidStoryKey('abc')).toBe(true);\n    88→  });\n    89→\n    90→  it('rejects empty string', () => {\n    91→    expect(isValidStoryKey('')).toBe(false);\n    92→  });\n    93→\n    94→  it('rejects path traversal', () => {\n    95→    expect(isValidStoryKey('../etc/passwd')).toBe(false);\n 