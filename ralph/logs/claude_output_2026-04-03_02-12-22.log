40\t\n1541\t    const config = makeConfig({\n1542\t      workflow: {\n1543\t        tasks: {\n1544\t          retry: makeTask({ scope: 'per-story' }),\n1545\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n1546\t        },\n1547\t        flow: [{ loop: ['retry', 'verify'] }],\n1548\t      },\n1549\t    });\n1550\t\n1551\t    await executeWorkflow(config);\n1552\t\n1553\t    // Find all writes with different iteration values\n1554\t    const iterations = mockWriteWorkflowState.mock.calls\n1555\t      .map((c: unknown[]) => (c[0] as WorkflowState).iteration)\n1556\t      .filter((v: number, i: number, arr: number[]) => i === 0 || v !== arr[i - 1]);\n1557\t\n1558\t    // Should have iterations 0 (initial), 1, 2, 3\n1559\t    expect(iterations).toContain(1);\n1560\t    expect(iterations).toContain(2);\n1561\t    expect(iterations).toContain(3);\n1562\t  });\n1563\t\n1564\t  it('halt error (RATE_LIMIT) terminates loop immediately (AC #8)', async () => {\n1565\t    const { DispatchError } = await import('../agent-dispatch.js');\n1566\t    mockDispatchAgent.mockRejectedValue(\n1567\t      new DispatchError('rate limited', 'RATE_LIMIT', 'dev', new Error('inner')),\n1568\t    );\n1569\t\n1570\t    mockParse.mockReturnValue({\n1571\t      development_status: { '3-1-foo': 'ready-for-dev' },\n1572\t    });\n1573\t\n1574\t    const config = makeConfig({\n1575\t      workflow: {\n1576\t        tasks: {\n1577\t          retry: makeTask({ scope: 'per-story' }),\n1578\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n1579\t        },\n1580\t        flow: [{ loop: ['retry', 'verify'] }],\n1581\t      },\n1582\t    });\n1583\t\n1584\t    const result = await executeWorkflow(config);\n1585\t\n1586\t    expect(result.success).toBe(false);\n1587\t    expect(result.errors).toHaveLength(1);\n1588\t    expect(result.errors[0].code).toBe('RATE_LIMIT');\n1589\t    // Only one dispatch attempted before halt\n1590\t    expect(mockDispatchAgent).t