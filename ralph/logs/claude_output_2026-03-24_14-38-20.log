{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PJiCqVJKGsEZekKmgDNFg9","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→\n     3→// Mock node:fs\n     4→vi.mock('node:fs', () => ({\n     5→  existsSync: vi.fn(),\n     6→  writeFileSync: vi.fn(),\n     7→  mkdirSync: vi.fn(),\n     8→}));\n     9→\n    10→// Mock sprint state module\n    11→vi.mock('../../sprint/index.js', () => ({\n    12→  getSprintState: vi.fn(),\n    13→  writeStateAtomic: vi.fn(),\n    14→  computeSprintCounts: vi.fn(),\n    15→}));\n    16→\n    17→import { existsSync, writeFileSync, mkdirSync } from 'node:fs';\n    18→import {\n    19→  getSprintState,\n    20→  writeStateAtomic,\n    21→  computeSprintCounts,\n    22→} from '../../sprint/index.js';\n    23→import {\n    24→  generateFixStories,\n    25→  addFixStoriesToState,\n    26→  buildStoryKey,\n    27→  buildStoryMarkdown,\n    28→} from '../fix-generator.js';\n    29→import type { AuditResult, AuditGap } from '../types.js';\n    30→\n    31→const mockExistsSync = vi.mocked(existsSync);\n    32→const mockWriteFileSync = vi.mocked(writeFileSync);\n    33→const mockMkdirSync = vi.mocked(mkdirSync);\n    34→const mockGetSprintState = vi.mocked(getSprintState);\n    35→const mockWriteStateAtomic = vi.mocked(writeStateAtomic);\n    36→const mockComputeSprintCounts = vi.mocked(computeSprintCounts);\n    37→\n    38→function makeGap(dimension: string, description: string, suggestedFix: string): AuditGap {\n    39→  return { dimension, description, suggestedFix };\n    40→}\n    41→\n    42→function makeAuditResult(gaps: Record<string, AuditGap[]>): AuditResult {\n    43→  const dimensions: AuditResult['dimensions'] = {};\n    44→  let gapCount = 0;\n    45→\n    46→  for (const [name, dimGaps] of Object.entries(gaps)) {\n    47→    gapCount += dimGaps.length;\n    48→    dimensions[name] = {\n    49→      name,\n    50→      status: dimGaps.length > 0 ? 'fail' : 'pass',\n    51→      metric: `${dimGaps.length} gaps`,\n    52→      gaps: dimGaps,\n    53→    };\n    54→  }\n    55→\n    56→  return {\n    57→    dimensions,\n    58→    overallStatus: gapCount > 0 ? 'fail' : 'pass',\n    59→    gapCount,\n    60→    durationMs: 42,\n    61→  };\n    62→}\n    63→\n    64→beforeEach(() => {\n    65→  vi.clearAllMocks();\n    66→  mockExistsSync.mockReturnValue(false);\n    67→});\n    68→\n    69→// ─── buildStoryKey ──────────────────────────────────────────────────────────\n    70→\n    71→describe('buildStoryKey', () => {\n    72→  it('generates deterministic key from dimension and index', () => {\n    73→    const gap = makeGap('observability', 'Missing logs', 'Add logs');\n    74→    expect(buildStoryKey(gap, 1)).toBe('audit-fix-observability-1');\n    75→  });\n    76→\n    77→  it('sanitizes dimension name for filesystem safety', () => {\n    78→    const gap = makeGap('Code Quality', 'Issue', 'Fix');\n    79→    expect(buildStoryKey(gap, 2)).toBe('audit-fix-code-quality-2');\n    80→  });\n    81→\n    82→  it('produces same key for same input', () => {\n    83→    const gap = makeGap('testing', 'Low coverage', 'Add tests');\n    84→    const k1 = buildStoryKey(gap, 1);\n    85→    const k2 = buildStoryKey(gap, 1);\n    86→    expect(k1).toBe(k2);\n    87→  });\n    88→});\n    89→\n    90→// ─── buildStoryMarkdown ─────────────────────────────────────────────────────\n    91→\n    92→describe('buildStoryMarkdown', () => {\n    93→  it('follows BMAD format with Status: backlog header', () => {\n    94→    const gap = makeGap('testing', 'Low coverage in src/lib/docker.ts', 'Add unit tests');\n    95→    const md = buildStoryMarkdown(gap, 'audit-fix-testing-1');\n    96→    expect(md).toContain('# Fix: testing — Low coverage in src/lib/docker.ts');\n    97→    expect(md).toContain('Status: backlog');\n    98→  });\n    99→\n   100→  it('includes user story section', () => {\n   101→    const gap = makeGap('testing', 'Missing tests', 'Write tests');\n   102→    const md = buildStoryMarkdown(gap, 'key');\n   103→    expect(md).toContain('## Story');\n   104→    expect(md).toContain('As an operator, I need Missing tests fixed so that audit compliance improves.');\n   105→  });\n   106→\n   107→  it('includes Given/When/Then acceptance criteria', () => {\n   108→    const gap = makeGap('observability', 'No logging', 'Add structured logs');\n   109→    const md = buildStoryMarkdown(gap, 'key');\n   110→    expect(md).toContain('## Acceptance Criteria');\n   111→    expect(md).toContain('**Given**');\n   112→    expect(md).toContain('**When**');\n   113→    expect(md).toContain('**Then**');\n   114→  });\n   115→\n   116→  it('references specific file path from gap description (AC #3)', () => {\n   117→    const gap = makeGap(\n   118→      'observability',\n   119→      'src/lib/docker.ts:42 — Missing error logging',\n   120→      'Add error logging at line 42',\n   121→    );\n   122→    const md = buildStoryMarkdown(gap, 'key');\n   123→    expect(md).toContain('src/lib/docker.ts:42 — Missing error logging');\n   124→  });\n   125→\n   126→  it('includes Dev Notes with audit gap details', () => {\n   127→    const gap = makeGap('testing', 'Low coverage', 'Add tests');\n   128→    const md = buildStoryMarkdown(gap, 'key');\n   129→    expect(md).toContain('## Dev Notes');\n   130→    expect(md).toContain('auto-generated fix story created by `codeharness audit --fix`');\n   131→    expect(md).toContain('**Audit Gap:** testing: Low coverage');\n   132→    expect(md).toContain('**Suggested Fix:** Add tests');\n   133→  });\n   134→});\n   135→\n   136→// ─── generateFixStories ────────────────────────────────────────────────────\n   137→\n   138→describe('generateFixStories', () => {\n   139→  it('returns empty result with 0 gaps (AC #4)', () => {\n   140→    const auditResult = makeAuditResult({ testing: [] });\n   141→    const result = generateFixStories(auditResult);\n   142→    expect(result.success).toBe(true);\n   143→    if (result.success) {\n   144→      expect(result.data.stories).toHaveLength(0);\n   145→      expect(result.data.created).toBe(0);\n   146→      expect(result.data.skipped).toBe(0);\n   147→    }\n   148→  });\n   149→\n   150→  it('creates 3 story files for 3 gaps', () => {\n   151→    const auditResult = makeAuditResult({\n   152→      observability: [\n   153→        makeGap('observability', 'Gap A', 'Fix A'),\n   154→        makeGap('observability', 'Gap B', 'Fix B'),\n   155→      ],\n   156→      testing: [\n   157→        makeGap('testing', 'Gap C', 'Fix C'),\n   158→      ],\n   159→    });\n   160→\n   161→    const result = generateFixStories(auditResult);\n   162→    expect(result.success).toBe(true);\n   163→    if (result.success) {\n   164→      expect(result.data.stories).toHaveLength(3);\n   165→      expect(result.data.created).toBe(3);\n   166→      expect(result.data.skipped).toBe(0);\n   167→      expect(mockWriteFileSync).toHaveBeenCalledTimes(3);\n   168→    }\n   169→  });\n   170→\n   171→  it('writes story files with BMAD markdown content', () => {\n   172→    const auditResult = makeAuditResult({\n   173→      testing: [makeGap('testing', 'Low coverage', 'Add tests')],\n   174→    });\n   175→\n   176→    generateFixStories(auditResult);\n   177→\n   178→    expect(mockWriteFileSync).toHaveBeenCalledTimes(1);\n   179→    const writtenContent = mockWriteFileSync.mock.calls[0][1] as string;\n   180→    expect(writtenContent).toContain('# Fix: testing — Low coverage');\n   181→    expect(writtenContent).toContain('Status: backlog');\n   182→  });\n   183→\n   184→  it('creates parent directory before writing', () => {\n   185→    const auditResult = makeAuditResult({\n   186→      testing: [makeGap('testing', 'Gap', 'Fix')],\n   187→    });\n   188→\n   189→    generateFixStories(auditResult);\n   190→\n   191→    expect(mockMkdirSync).toHaveBeenCalledWith(\n   192→      expect.stringContaining('implementation-artifacts'),\n   193→      { recursive: true },\n   194→    );\n   195→  });\n   196→\n   197→  it('skips existing story files and returns skipped: true (AC #6)', () => {\n   198→    mockExistsSync.mockReturnValue(true);\n   199→\n   200→    const auditResult = makeAuditResult({\n   201→      testing: [makeGap('testing', 'Gap', 'Fix')],\n   202→    });\n   203→\n   204→    const result = generateFixStories(auditResult);\n   205→    expect(result.success).toBe(true);\n   206→    if (result.success) {\n   207→      expect(result.data.stories).toHaveLength(1);\n   208→      expect(result.data.stories[0].skipped).toBe(true);\n   209→      expect(result.data.stories[0].skipReason).toBe('Story file already exists');\n   210→      expect(result.data.created).toBe(0);\n   211→      expect(result.data.skipped).toBe(1);\n   212→      expect(mockWriteFileSync).not.toHaveBeenCalled();\n   213→    }\n   214→  });\n   215→\n   216→  it('story key is deterministic for same gap', () => {\n   217→    const auditResult = makeAuditResult({\n   218→      testing: [makeGap('testing', 'Gap A', 'Fix A')],\n   219→    });\n   220→\n   221→    const r1 = generateFixStories(auditResult);\n   222→    const r2 = generateFixStories(auditResult);\n   223→\n   224→    expect(r1.success && r2.success).toBe(true);\n   225→    if (r1.success && r2.success) {\n   226→      expect(r1.data.stories[0].key).toBe(r2.data.stories[0].key);\n   227→    }\n   228→  });\n   229→\n   230→  it('returns fail result when writeFileSync throws', () => {\n   231→    mockWriteFileSync.mockImplementationOnce(() => {\n   232→      throw new Error('EACCES: permission denied');\n   233→    });\n   234→\n   235→    const auditResult = makeAuditResult({\n   236→      testing: [makeGap('testing', 'Gap', 'Fix')],\n   237→    });\n   238→\n   239→    const result = generateFixStories(auditResult);\n   240→    expect(result.success).toBe(false);\n   241→    if (!result.success) {\n   242→      expect(result.error).toContain('Failed to generate fix stories');\n   243→      expect(result.error).toContain('EACCES: permission denied');\n   244→    }\n   245→  });\n   246→\n   247→  it('returns fail result when non-Error is thrown', () => {\n   248→    mockWriteFileSync.mockImplementationOnce(() => {\n   249→      throw 'string error';\n   250→    });\n   251→\n   252→    const auditResult = makeAuditResult({\n   253→      testing: [makeGap('testing', 'Gap', 'Fix')],\n   254→    });\n   255→\n   256→    const result = generateFixStories(auditResult);\n   257→    expect(result.success).toBe(false);\n   258→    if (!result.success) {\n   259→      expect(result.error).toContain('string error');\n   260→    }\n   261→  });\n   262→\n   263→  it('handles mixed created and skipped stories', () => {\n   264→    // First gap file exists, second does not\n   265→    mockExistsSync\n   266→      .mockReturnValueOnce(true)\n   267→      .mockReturnValueOnce(false);\n   268→\n   269→    const auditResult = makeAuditResult({\n   270→      testing: [\n   271→        makeGap('testing', 'Gap A', 'Fix A'),\n   272→        makeGap('testing', 'Gap B', 'Fix B'),\n   273→      ],\n   274→    });\n   275→\n   276→    const result = generateFixStories(auditResult);\n   277→    expect(result.success).toBe(true);\n   278→    if (result.success) {\n   279→      expect(result.data.created).toBe(1);\n   280→      expect(result.data.skipped).toBe(1);\n   281→      expect(mockWriteFileSync).toHaveBeenCalledTimes(1);\n   282→    }\n   283→  });\n   284→});\n   285→\n   286→// ─── addFixStoriesToState ───────────────────────────────────────────────────\n   287→\n   288→describe('addFixStoriesToState', () => {\n   289→  const defaultState = {\n   290→    version: 2 as const,\n   291→    sprint: { total: 0, done: 0, failed: 0, blocked: 0, inProgress: null },\n   292→    stories: {},\n   293→    retries: {},\n   294→    flagged: [] as string[],\n   295→    epics: {},\n   296→    session: { active: false, startedAt: null, iteration: 0, elapsedSeconds: 0 },\n   297→    observability: { statementCoverage: null, branchCoverage: null, functionCoverage: null, lineCoverage: null },\n   298→    run: {\n   299→      active: false,\n   300→      startedAt: null,\n   301→      iteration: 0,\n   302→      cost: 0,\n   303→      completed: [],\n   304→      failed: [],\n   305→      currentStory: null,\n   306→      currentPhase: null,\n   307→      lastAction: null,\n   308→      acProgress: null,\n   309→    },\n   310→    actionItems: [],\n   311→  };\n   312→\n   313→  beforeEach(() => {\n   314→    mockGetSprintState.mockReturnValue({ success: true, data: { ...defaultState } });\n   315→    mockWriteStateAtomic.mockReturnValue({ success: true, data: undefined });\n   316→    mockComputeSprintCounts.mockReturnValue({\n   317→      total: 2, done: 0, failed: 0, blocked: 0, inProgress: null,\n   318→    });\n   319→  });\n   320→\n   321→  it('adds stories to sprint-state.json as backlog entries (AC #2)', () => {\n   322→    const stories = [\n   323→      {\n   324→        key: 'audit-fix-testing-1',\n   325→        filePath: '/path/to/audit-fix-testing-1.md',\n   326→        gap: makeGap('testing', 'Gap', 'Fix'),\n   327→        skipped: false,\n   328→      },\n   329→    ];\n   330→\n   331→    const result = addFixStoriesToState(stories);\n   332→    expect(result.success).toBe(true);\n   333→    expect(mockWriteStateAtomic).toHaveBeenCalledTimes(1);\n   334→\n   335→    const writtenState = mockWriteStateAtomic.mock.calls[0][0];\n   336→    expect(writtenState.stories['audit-fix-testing-1']).toEqual({\n   337→      status: 'backlog',\n   338→      attempts: 0,\n   339→      lastAttempt: null,\n   340→      lastError: null,\n   341→      proofPath: null,\n   342→      acResults: null,\n   343→    });\n   344→  });\n   345→\n   346→  it('creates default state when sprint-state.json is missing (AC #9)', () => {\n   347→    mockGetSprintState.mockReturnValue({ success: true, data: { ...defaultState } });\n   348→\n   349→    const stories = [\n   350→      {\n   351→        key: 'audit-fix-testing-1',\n   352→        filePath: '/path/file.md',\n   353→        gap: makeGap('testing', 'Gap', 'Fix'),\n   354→        skipped: false,\n   355→      },\n   356→    ];\n   357→\n   358→    const result = addFixStoriesToState(stories);\n   359→    expect(result.success).toBe(true);\n   360→    expect(mockGetSprintState).toHaveBeenCalled();\n   361→  });\n   362→\n   363→  it('uses atomic write via writeStateAtomic (AC #8)', () => {\n   364→    const stories = [\n   365→      {\n   366→        key: 'audit-fix-testing-1',\n   367→        filePath: '/path/file.md',\n   368→        gap: makeGap('testing', 'Gap', 'Fix'),\n   369→        skipped: false,\n   370→      },\n   371→    ];\n   372→\n   373→    addFixStoriesToState(stories);\n   374→    expect(mockWriteStateAtomic).toHaveBeenCalledTimes(1);\n   375→  });\n   376→\n   377→  it('recomputes sprint counts after adding stories', () => {\n   378→    const stories = [\n   379→      {\n   380→        key: 'audit-fix-testing-1',\n   381→        filePath: '/path/file.md',\n   382→        gap: makeGap('testing', 'Gap', 'Fix'),\n   383→        skipped: false,\n   384→      },\n   385→    ];\n   386→\n   387→    addFixStoriesToState(stories);\n   388→    expect(mockComputeSprintCounts).toHaveBeenCalledTimes(1);\n   389→    // Verify the recomputed counts are used in the written state\n   390→    const writtenState = mockWriteStateAtomic.mock.calls[0][0];\n   391→    expect(writtenState.sprint.total).toBe(2);\n   392→  });\n   393→\n   394→  it('skips writing when all stories are skipped', () => {\n   395→    const stories = [\n   396→      {\n   397→        key: 'audit-fix-testing-1',\n   398→        filePath: '/path/file.md',\n   399→        gap: makeGap('testing', 'Gap', 'Fix'),\n   400→        skipped: true,\n   401→        skipReason: 'Already exists',\n   402→      },\n   403→    ];\n   404→\n   405→    const result = addFixStoriesToState(stories);\n   406→    expect(result.success).toBe(true);\n   407→    expect(mockGetSprintState).not.toHaveBeenCalled();\n   408→    expect(mockWriteStateAtomic).not.toHaveBeenCalled();\n   409→  });\n   410→\n   411→  it('handles getSprintState failure', () => {\n   412→    mockGetSprintState.mockReturnValue({\n   413→      success: false,\n   414→      error: 'File corrupted',\n   415→    });\n   416→\n   417→    const stories = [\n   418→      {\n   419→        key: 'audit-fix-testing-1',\n   420→        filePath: '/path/file.md',\n   421→        gap: makeGap('testing', 'Gap', 'Fix'),\n   422→        skipped: false,\n   423→      },\n   424→    ];\n   425→\n   426→    const result = addFixStoriesToState(stories);\n   427→    expect(result.success).toBe(false);\n   428→    if (!result.success) {\n   429→      expect(result.error).toBe('File corrupted');\n   430→    }\n   431→  });\n   432→\n   433→  it('preserves existing stories when adding new ones', () => {\n   434→    const existingStories = {\n   435→      'existing-story': {\n   436→        status: 'done' as const,\n   437→        attempts: 2,\n   438→        lastAttempt: '2026-01-01',\n   439→        lastError: null,\n   440→        proofPath: null,\n   441→        acResults: null,\n   442→      },\n   443→    };\n   444→\n   445→    mockGetSprintState.mockReturnValue({\n   446→      success: true,\n   447→      data: { ...defaultState, stories: existingStories },\n   448→    });\n   449→\n   450→    const stories = [\n   451→      {\n   452→        key: 'audit-fix-testing-1',\n   453→        filePath: '/path/file.md',\n   454→        gap: makeGap('testing', 'Gap', 'Fix'),\n   455→        skipped: false,\n   456→      },\n   457→    ];\n   458→\n   459→    addFixStoriesToState(stories);\n   460→    const writtenState = mockWriteStateAtomic.mock.calls[0][0];\n   461→    expect(writtenState.stories['existing-story']).toEqual(existingStories['existing-story']);\n   462→    expect(writtenState.stories['audit-fix-testing-1']).toBeDefined();\n   463→  });\n   464→});\n   465→"}]},"parent_tool_use_id":"toolu_01CfvkxunN8dwVBkgTqCVyZN","session_id":"0e449f80-823c-4489-a784-b43b6c7039d6","uuid":"d390bdd1-5f90-43e9-b3e1-e2535d6b20b8","timestamp":"2026-03-24T10:39:55.575Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011dRjT3xUA8ZPrKK9PswV57","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n     2→import type { SprintState, StoryState } from '../../../types/state.js';\n     3→\n     4→// ─── Mocks ───────────────────────────────────────────────────────────────────\n     5→\n     6→// Mock sprint module (public API)\n     7→const mockGetSprintState = vi.fn();\n     8→const mockWriteStateAtomic = vi.fn();\n     9→const mockComputeSprintCounts = vi.fn();\n    10→\n    11→vi.mock('../../sprint/index.js', () => ({\n    12→  getSprintState: (...args: unknown[]) => mockGetSprintState(...args),\n    13→  writeStateAtomic: (...args: unknown[]) => mockWriteStateAtomic(...args),\n    14→  computeSprintCounts: (...args: unknown[]) => mockComputeSprintCounts(...args),\n    15→}));\n    16→\n    17→// Mock dev module\n    18→const mockDevelopStory = vi.fn();\n    19→vi.mock('../../dev/index.js', () => ({\n    20→  developStory: (...args: unknown[]) => mockDevelopStory(...args),\n    21→}));\n    22→\n    23→// Mock child_process\n    24→const mockExecSync = vi.fn();\n    25→vi.mock('node:child_process', () => ({\n    26→  execSync: (...args: unknown[]) => mockExecSync(...args),\n    27→}));\n    28→\n    29→// Mock fs\n    30→const mockWriteFileSync = vi.fn();\n    31→const mockMkdirSync = vi.fn();\n    32→vi.mock('node:fs', () => ({\n    33→  writeFileSync: (...args: unknown[]) => mockWriteFileSync(...args),\n    34→  mkdirSync: (...args: unknown[]) => mockMkdirSync(...args),\n    35→}));\n    36→\n    37→// Import after mocks\n    38→import {\n    39→  createValidationSprint,\n    40→  executeValidationAC,\n    41→  createFixStory,\n    42→  processValidationResult,\n    43→} from '../validation-runner.js';\n    44→import {\n    45→  getValidationProgress,\n    46→  runValidationCycle,\n    47→} from '../validation-orchestrator.js';\n    48→import { VALIDATION_ACS } from '../validation-acs.js';\n    49→import type { ValidationAC } from '../validation-ac-types.js';\n    50→import type { ValidationACResult } from '../validation-runner-types.js';\n    51→\n    52→// ─── Helpers ─────────────────────────────────────────────────────────────────\n    53→\n    54→function emptyState(): SprintState {\n    55→  return {\n    56→    version: 2,\n    57→    sprint: { total: 0, done: 0, failed: 0, blocked: 0, inProgress: null },\n    58→    stories: {},\n    59→    retries: {},\n    60→    flagged: [],\n    61→    epics: {},\n    62→    session: { active: false, startedAt: null, iteration: 0, elapsedSeconds: 0 },\n    63→    observability: { statementCoverage: null, branchCoverage: null, functionCoverage: null, lineCoverage: null },\n    64→    run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n    65→    actionItems: [],\n    66→  };\n    67→}\n    68→\n    69→function defaultStory(overrides?: Partial<StoryState>): StoryState {\n    70→  return {\n    71→    status: 'backlog',\n    72→    attempts: 0,\n    73→    lastAttempt: null,\n    74→    lastError: null,\n    75→    proofPath: null,\n    76→    acResults: null,\n    77→    ...overrides,\n    78→  };\n    79→}\n    80→\n    81→function cliAC(id: number): ValidationAC {\n    82→  return {\n    83→    id,\n    84→    frRef: `FR${id}`,\n    85→    description: `Test AC ${id}`,\n    86→    verificationMethod: 'cli',\n    87→    command: `echo \"AC ${id} ok\"`,\n    88→    category: 'FR',\n    89→  };\n    90→}\n    91→\n    92→function integrationAC(id: number): ValidationAC {\n    93→  return {\n    94→    id,\n    95→    frRef: `FR${id}`,\n    96→    description: `Test AC ${id}`,\n    97→    verificationMethod: 'integration',\n    98→    category: 'FR',\n    99→  };\n   100→}\n   101→\n   102→beforeEach(() => {\n   103→  vi.resetAllMocks();\n   104→  mockComputeSprintCounts.mockReturnValue({\n   105→    total: 0, done: 0, failed: 0, blocked: 0, inProgress: null,\n   106→  });\n   107→  mockWriteStateAtomic.mockReturnValue({ success: true, data: undefined });\n   108→  mockDevelopStory.mockReturnValue({ success: true, data: { storyKey: 'test', status: 'done' } });\n   109→  mockMkdirSync.mockReturnValue(undefined);\n   110→  mockWriteFileSync.mockReturnValue(undefined);\n   111→});\n   112→\n   113→// ─── Task 1: createValidationSprint ──────────────────────────────────────────\n   114→\n   115→describe('createValidationSprint', () => {\n   116→  it('creates 79 story entries with correct initial state', () => {\n   117→    const state = emptyState();\n   118→    mockGetSprintState.mockReturnValue({ success: true, data: state });\n   119→\n   120→    const result = createValidationSprint();\n   121→\n   122→    expect(result.success).toBe(true);\n   123→    if (!result.success) return;\n   124→    expect(result.data.acsAdded).toBe(79);\n   125→    expect(result.data.existingPreserved).toBe(0);\n   126→\n   127→    // Verify writeStateAtomic was called with 79 val- entries\n   128→    const writtenState = mockWriteStateAtomic.mock.calls[0][0] as SprintState;\n   129→    const valKeys = Object.keys(writtenState.stories).filter(k => k.startsWith('val-'));\n   130→    expect(valKeys).toHaveLength(79);\n   131→\n   132→    // Each entry has correct initial state\n   133→    for (const key of valKeys) {\n   134→      const story = writtenState.stories[key];\n   135→      expect(story.status).toBe('backlog');\n   136→      expect(story.attempts).toBe(0);\n   137→      expect(story.lastAttempt).toBeNull();\n   138→      expect(story.lastError).toBeNull();\n   139→    }\n   140→  });\n   141→\n   142→  it('preserves existing non-validation stories in sprint-state.json', () => {\n   143→    const state = emptyState();\n   144→    state.stories['1-1-user-auth'] = defaultStory({ status: 'in-progress' });\n   145→    state.stories['2-1-data-model'] = defaultStory({ status: 'done' });\n   146→    // Treat stories as mutable for test setup\n   147→    (state as { stories: Record<string, StoryState> }).stories = {\n   148→      '1-1-user-auth': defaultStory({ status: 'in-progress' }),\n   149→      '2-1-data-model': defaultStory({ status: 'done' }),\n   150→    };\n   151→    mockGetSprintState.mockReturnValue({ success: true, data: state });\n   152→\n   153→    const result = createValidationSprint();\n   154→\n   155→    expect(result.success).toBe(true);\n   156→    if (!result.success) return;\n   157→    expect(result.data.existingPreserved).toBe(2);\n   158→    expect(result.data.acsAdded).toBe(79);\n   159→\n   160→    const writtenState = mockWriteStateAtomic.mock.calls[0][0] as SprintState;\n   161→    expect(writtenState.stories['1-1-user-auth']).toBeDefined();\n   162→    expect(writtenState.stories['1-1-user-auth'].status).toBe('in-progress');\n   163→    expect(writtenState.stories['2-1-data-model']).toBeDefined();\n   164→    expect(writtenState.stories['2-1-data-model'].status).toBe('done');\n   165→  });\n   166→\n   167→  it('does not overwrite existing validation entries', () => {\n   168→    const state = emptyState();\n   169→    (state as { stories: Record<string, StoryState> }).stories = {\n   170→      'val-1': defaultStory({ status: 'done', attempts: 3 }),\n   171→    };\n   172→    mockGetSprintState.mockReturnValue({ success: true, data: state });\n   173→\n   174→    const result = createValidationSprint();\n   175→\n   176→    expect(result.success).toBe(true);\n   177→    if (!result.success) return;\n   178→    expect(result.data.acsAdded).toBe(78); // 79 - 1 existing\n   179→\n   180→    const writtenState = mockWriteStateAtomic.mock.calls[0][0] as SprintState;\n   181→    expect(writtenState.stories['val-1'].status).toBe('done');\n   182→    expect(writtenState.stories['val-1'].attempts).toBe(3);\n   183→  });\n   184→\n   185→  it('returns fail when getSprintState fails', () => {\n   186→    mockGetSprintState.mockReturnValue({ success: false, error: 'disk error' });\n   187→\n   188→    const result = createValidationSprint();\n   189→    expect(result.success).toBe(false);\n   190→    if (result.success) return;\n   191→    expect(result.error).toBe('disk error');\n   192→  });\n   193→\n   194→  it('returns fail when writeStateAtomic fails', () => {\n   195→    mockGetSprintState.mockReturnValue({ success: true, data: emptyState() });\n   196→    mockWriteStateAtomic.mockReturnValue({ success: false, error: 'write failed' });\n   197→\n   198→    const result = createValidationSprint();\n   199→    expect(result.success).toBe(false);\n   200→    if (result.success) return;\n   201→    expect(result.error).toBe('write failed');\n   202→  });\n   203→});\n   204→\n   205→// ─── Task 2: executeValidationAC ─────────────────────────────────────────────\n   206→\n   207→describe('executeValidationAC', () => {\n   208→  it('CLI AC with passing command returns pass', () => {\n   209→    const ac = cliAC(1);\n   210→    mockExecSync.mockReturnValue('all good');\n   211→\n   212→    const result = executeValidationAC(ac);\n   213→\n   214→    expect(result.success).toBe(true);\n   215→    if (!result.success) return;\n   216→    expect(result.data.acId).toBe(1);\n   217→    expect(result.data.verdict).toBe('pass');\n   218→    expect(result.data.output).toBe('all good');\n   219→    expect(result.data.durationMs).toBeGreaterThanOrEqual(0);\n   220→  });\n   221→\n   222→  it('CLI AC with failing command returns fail with captured output', () => {\n   223→    const ac = cliAC(2);\n   224→    const execError = new Error('Command failed');\n   225→    (execError as Record<string, unknown>).stdout = 'partial output';\n   226→    (execError as Record<string, unknown>).stderr = 'error details';\n   227→    mockExecSync.mockImplementation(() => { throw execError; });\n   228→\n   229→    const result = executeValidationAC(ac);\n   230→\n   231→    expect(result.success).toBe(true);\n   232→    if (!result.success) return;\n   233→    expect(result.data.acId).toBe(2);\n   234→    expect(result.data.verdict).toBe('fail');\n   235→    expect(result.data.output).toContain('partial output');\n   236→    expect(result.data.output).toContain('error details');\n   237→  });\n   238→\n   239→  it('integration AC returns blocked with reason', () => {\n   240→    const ac = integrationAC(5);\n   241→\n   242→    const result = executeValidationAC(ac);\n   243→\n   244→    expect(result.success).toBe(true);\n   245→    if (!result.success) return;\n   246→    expect(result.data.acId).toBe(5);\n   247→    expect(result.data.verdict).toBe('blocked');\n   248→    expect(result.data.reason).toBe('integration-required');\n   249→    expect(result.data.durationMs).toBe(0);\n   250→    expect(result.data.output).toBe('');\n   251→  });\n   252→\n   253→  it('CLI AC without command returns blocked', () => {\n   254→    const ac: ValidationAC = {\n   255→      id: 99,\n   256→      frRef: 'FR99',\n   257→      description: 'No command AC',\n   258→      verificationMethod: 'cli',\n   259→      category: 'FR',\n   260→    };\n   261→\n   262→    const result = executeValidationAC(ac);\n   263→\n   264→    expect(result.success).toBe(true);\n   265→    if (!result.success) return;\n   266→    expect(result.data.verdict).toBe('blocked');\n   267→    expect(result.data.reason).toBe('no-command');\n   268→  });\n   269→\n   270→  it('passes timeout option to execSync', () => {\n   271→    const ac = cliAC(1);\n   272→    mockExecSync.mockReturnValue('ok');\n   273→\n   274→    executeValidationAC(ac);\n   275→\n   276→    expect(mockExecSync).toHaveBeenCalledWith(\n   277→      ac.command,\n   278→      expect.objectContaining({ timeout: 30_000 }),\n   279→    );\n   280→  });\n   281→});\n   282→\n   283→// ─── Task 3: createFixStory ──────────────────────────────────────────────────\n   284→\n   285→describe('createFixStory', () => {\n   286→  it('generates valid markdown with AC details', () => {\n   287→    const ac = cliAC(42);\n   288→    const error = 'Expected file not found';\n   289→\n   290→    const result = createFixStory(ac, error);\n   291→\n   292→    expect(result.success).toBe(true);\n   293→    if (!result.success) return;\n   294→    expect(result.data).toBe('val-fix-42');\n   295→\n   296→    // Verify file was written\n   297→    expect(mockMkdirSync).toHaveBeenCalled();\n   298→    expect(mockWriteFileSync).toHaveBeenCalledTimes(1);\n   299→\n   300→    const writtenContent = mockWriteFileSync.mock.calls[0][1] as string;\n   301→    expect(writtenContent).toContain('# Fix: Validation AC 42');\n   302→    expect(writtenContent).toContain('FR42');\n   303→    expect(writtenContent).toContain('Expected file not found');\n   304→    expect(writtenContent).toContain(ac.description);\n   305→    expect(writtenContent).toContain('Status: ready-for-dev');\n   306→  });\n   307→\n   308→  it('includes command in story when AC has one', () => {\n   309→    const ac = cliAC(10);\n   310→    const result = createFixStory(ac, 'fail');\n   311→\n   312→    expect(result.success).toBe(true);\n   313→    const writtenContent = mockWriteFileSync.mock.calls[0][1] as string;\n   314→    expect(writtenContent).toContain('`echo \"AC 10 ok\"`');\n   315→  });\n   316→\n   317→  it('omits command line when AC has no command', () => {\n   318→    const ac = integrationAC(20);\n   319→    const result = createFixStory(ac, 'missing service');\n   320→\n   321→    expect(result.success).toBe(true);\n   322→    const writtenContent = mockWriteFileSync.mock.calls[0][1] as string;\n   323→    expect(writtenContent).not.toContain('**Command:**');\n   324→    expect(writtenContent).toContain('missing service');\n   325→  });\n   326→\n   327→  it('returns fail on write error', () => {\n   328→    const ac = cliAC(1);\n   329→    mockMkdirSync.mockImplementation(() => { throw new Error('Permissi