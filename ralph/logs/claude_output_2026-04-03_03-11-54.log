false })),\n43\t}));\n44\t\n45\tvi.mock('../../verify/index.js', () => ({\n46\t  getValidationProgress: vi.fn(() => ({ success: false })),\n47\t}));\n48\t\n49\tvi.mock('../../../lib/workflow-state.js', () => ({\n50\t  readWorkflowState: (...args: unknown[]) => readWorkflowStateMock(...args),\n51\t}));\n52\t\n53\timport { handleFullStatus, formatElapsed } from '../formatters.js';\n54\timport type { WorkflowState } from '../../../lib/workflow-state.js';\n55\t\n56\tfunction makeDefaultState(): WorkflowState {\n57\t  return {\n58\t    workflow_name: '',\n59\t    started: '',\n60\t    iteration: 0,\n61\t    phase: 'idle',\n62\t    tasks_completed: [],\n63\t    evaluator_scores: [],\n64\t    circuit_breaker: { triggered: false, reason: null, score_history: [] },\n65\t    trace_ids: [],\n66\t  };\n67\t}\n68\t\n69\tfunction makeActiveState(overrides?: Partial<WorkflowState>): WorkflowState {\n70\t  return {\n71\t    workflow_name: 'implement -> verify',\n72\t    started: new Date(Date.now() - 3600000).toISOString(), // 1 hour ago\n73\t    iteration: 2,\n74\t    phase: 'executing',\n75\t    tasks_completed: [\n76\t      { task_name: 'implement', story_key: '5-1-story', completed_at: new Date().toISOString() },\n77\t      { task_name: 'verify', story_key: '__run__', completed_at: new Date().toISOString() },\n78\t    ],\n79\t    evaluator_scores: [\n80\t      { iteration: 1, passed: 3, failed: 1, unknown: 0, total: 4, timestamp: new Date().toISOString() },\n81\t    ],\n82\t    circuit_breaker: { triggered: false, reason: null, score_history: [] },\n83\t    trace_ids: [],\n84\t    ...overrides,\n85\t  };\n86\t}\n87\t\n88\tlet consoleSpy: ReturnType<typeof vi.spyOn>;\n89\t\n90\tbeforeEach(() => {\n91\t  vi.clearAllMocks();\n92\t  consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n93\t  process.exitCode = undefined;\n94\t});\n95\t\n96\tafterEach(() => {\n97\t  consoleSpy.mockRestore();\n98\t  process.exitCode = undefined;\n99\t});\n100\t\n101\tfunction getLogOutput(): string {\n102\t  return consoleSpy.mock.calls.map((c: unknown[]) => String(c[0])).join('\\n');\n103\t}\n104\t\n105\t// --- formatElapsed tests ---\n106\t\n107\tdescribe('formatElapsed', () => {\n108\t  it('formats seconds only', () => {\n109\t    expect(formatElapsed(5000)).toBe('5s');\n110\t  });\n111\t\n112\t  it('formats minutes and seconds', () => {\n113\t    expect(formatElapsed(195000)).toBe('3m15s');\n114\t  });\n115\t\n116\t  it('formats hours and minutes', () => {\n117\t    expect(formatElapsed(8040000)).toBe('2h14m');\n118\t  });\n119\t\n120\t  it('formats zero', () => {\n121\t    expect(formatElapsed(0)).toBe('0s');\n122\t  });\n123\t});\n124\t\n125\t// --- printWorkflowState tests (via handleFullStatus) ---\n126\t\n127\tdescribe('handleFullStatus — workflow engine section', () => {\n128\t  it('displays \"No active workflow run\" when no state exists', () => {\n129\t    readWorkflowStateMock.mockReturnValue(makeDefaultState());\n130\t    handleFullStatus(false);\n131\t\n132\t    const output = getLogOutput();\n133\t    expect(output).toContain('No active workflow run');\n134\t  });\n135\t\n136\t  it('displays workflow state fields when executing', () => {\n137\t    readWorkflowStateMock.mockReturnValue(makeActiveState());\n138\t    handleFullStatus(false);\n139\t\n140\t    const output = getLogOutput();\n141\t    expect(output).toContain('Workflow Engine');\n142\t    expect(output).toContain('Phase: executing');\n143\t    expect(output).toContain('Iteration: 2');\n144\t    expect(output).toContain('Tasks completed: 2');\n145\t    expect(output).toContain('Elapsed:');\n146\t    expect(output).toContain('Evaluator: 3/4 passed');\n147\t    expect(output).toContain('Circuit breaker: no');\n148\t  });\n149\t\n150\t  it('displays circuit breaker triggered state with reason', () => {\n151\t    readWorkflowStateMock.mockReturnValue(makeActiveState({\n152\t      phase: 'circuit-breaker',\n153\t      circuit_breaker: { triggered: true, reason: 'Score plateau detected', score_history: [50, 50, 50] },\n154\t    }));\n155\t    handleFullStatus(false);\n156\t\n157\t    const output = getLogOutput();\n158\t    expect(output).toContain('Circuit breaker: TRIGGERED');\n159\t    expect(output).toContain('Score plateau detected');\n160\t  });\n161\t\n162\t  it('does not show elapsed time when phase is not executing', () => {\n163\t    readWorkflowStateMock.mockReturnValue(makeActiveState({ phase: 'completed' }));\n164\t    handleFullStatus(false);\n165\t\n166\t    const output = getLogOutput();\n167\t    expect(output).toContain('Phase: completed');\n168\t    expect(output).not.toContain('Elapsed:');\n169\t  });\n170\t});\n171\t\n172\t// --- handleFullStatusJson — workflow state in JSON ---\n173\t\n174\tdescribe('handleFullStatusJson — workflow state', () => {\n175\t  it('includes workflow field in JSON when state is active', () => {\n176\t    readWorkflowStateMock.mockReturnValue(makeActiveState());\n177\t    handleFullStatus(true);\n178\t\n179\t    const jsonCall = consoleSpy.mock.calls[0]?.[0];\n180\t    expect(jsonCall).toBeDefined();\n181\t    const parsed = JSON.parse(String(jsonCall));\n182\t    expect(parsed.workflow).toBeDefined();\n183\t    expect(parsed.workflow.phase).toBe('executing');\n184\t    expect(parsed.workflow.iteration).toBe(2);\n185\t    expect(parsed.workflow.tasks_completed).toBe(2);\n186\t    expect(parsed.workflow.workflow_name).toBe('implement -> verify');\n187\t    expect(parsed.workflow.evaluator_scores).toHaveLength(1);\n188\t    expect(parsed.workflow.circuit_breaker.triggered).toBe(false);\n189\t    expect(parsed.workflow.elapsed_ms).toBeGreaterThan(0);\n190\t    expect(parsed.workflow.elapsed).toBeDefined();\n191\t  });\n192\t\n193\t  it('omits workflow field in JSON when no active run', () => {\n194\t    readWorkflowStateMock.mockReturnValue(makeDefaultState());\n195\t    handleFullStatus(true);\n196\t\n197\t    const jsonCall = consoleSpy.mock.calls[0]?.[0];\n198\t    const parsed = JSON.parse(String(jsonCall));\n199\t    expect(parsed.workflow).toBeUndefined();\n200\t  });\n201\t});\n202\t"}]},"parent_tool_use_id":"toolu_01Xy8yD9yroHvB5H97Nype24","session_id":"452c48b4-eed2-4c96-83e9-8c71df0bbdac","uuid":"a04db0f9-384e-48a0-b1fd-562a11a7e80a","timestamp":"2026-04-02T23:30:13.568Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01F1NDvHu81UTF8vW5hzMgsa","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';\n2\timport { mkdtempSync, rmSync } from 'node:fs';\n3\timport { existsSync as origExistsSync, readFileSync as origReadFileSync } from 'node:fs';\n4\timport { tmpdir } from 'node:os';\n5\timport { join } from 'node:path';\n6\timport { Command } from 'commander';\n7\timport { resolvePluginDir, countStories } from '../run.js';\n8\t\n9\t// --- Hoisted mocks ---\n10\tconst {\n11\t  getDriverMock, existsSyncMock, readSprintStatusMock,\n12\t  realExistsSync, startRendererMock, rendererCleanupMock,\n13\t  getSprintStateMock, reconcileStateMock,\n14\t  isDockerAvailableMock, cleanupContainersMock,\n15\t  parseWorkflowMock, resolveAgentMock, compileSubagentMock,\n16\t  executeWorkflowMock,\n17\t  readWorkflowStateMock, writeWorkflowStateMock,\n18\t} = vi.hoisted(() => {\n19\t  // eslint-disable-next-line @typescript-eslint/no-require-imports\n20\t  const fs = require('node:fs');\n21\t  const realFn = fs.existsSync.bind(fs);\n22\t\n23\t  const rendererCleanupMock = vi.fn();\n24\t\n25\t  return {\n26\t    getDriverMock: vi.fn(() => { throw new Error('No agent drivers available'); }),\n27\t    existsSyncMock: vi.fn(realFn),\n28\t    readSprintStatusMock: vi.fn(() => ({}) as Record<string, string>),\n29\t    realExistsSync: realFn as (path: string) => boolean,\n30\t    startRendererMock: vi.fn(() => ({\n31\t      update: vi.fn(),\n32\t      updateSprintState: vi.fn(),\n33\t      updateStories: vi.fn(),\n34\t      addMessage: vi.fn(),\n35\t      cleanup: rendererCleanupMock,\n36\t    })),\n37\t    rendererCleanupMock,\n38\t    getSprintStateMock: vi.fn((): { success: boolean; data?: Record<string, unknown>; error?: string } => ({ success: false, error: 'no state' })),\n39\t    reconcileStateMock: vi.fn(() => ({ success: true, data: { corrections: [], stateChanged: false } })),\n40\t    isDockerAvailableMock: vi.fn(() => true),\n41\t    cleanupContainersMock: vi.fn((): { success: boolean; data?: { containersRemoved: number; names: string[] }; error?: string } => ({ success: true, data: { containersRemoved: 0, names: [] } })),\n42\t    parseWorkflowMock: vi.fn(() => ({\n43\t      tasks: {\n44\t        implement: { agent: 'dev', scope: 'per-story', session: 'fresh', source_access: true },\n45\t      },\n46\t      flow: ['implement'],\n47\t    })),\n48\t    resolveAgentMock: vi.fn(() => ({\n49\t      name: 'dev',\n50\t      role: { title: 'Developer', purpose: 'Implement code' },\n51\t      persona: { identity: 'A developer', communication_style: 'direct', principles: [] },\n52\t    })),\n53\t    compileSubagentMock: vi.fn(() => ({\n54\t      name: 'dev',\n55\t      model: 'claude-sonnet-4-20250514',\n56\t      instructions: 'You are a developer',\n57\t      disallowedTools: [],\n58\t      bare: true,\n59\t    })),\n60\t    executeWorkflowMock: vi.fn(async () => ({\n61\t      success: true,\n62\t      tasksCompleted: 3,\n63\t      storiesProcessed: 1,\n64\t      errors: [],\n65\t      durationMs: 60000,\n66\t    })),\n67\t    readWorkflowStateMock: vi.fn(() => ({\n68\t      workflow_name: '',\n69\t      started: '',\n70\t      iteration: 0,\n71\t      phase: 'idle',\n72\t      tasks_completed: [],\n73\t      evaluator_scores: [],\n74\t      circuit_breaker: { triggered: false, reason: null, score_history: [] },\n75\t      trace_ids: [],\n76\t    })),\n77\t    writeWorkflowStateMock: vi.fn(),\n78\t  };\n79\t});\n80\t\n81\tvi.mock('../../lib/agents/index.js', () => ({\n82\t  getDriver: (...args: unknown[]) => getDriverMock(...(args as Parameters<typeof getDriverMock>)),\n83\t}));\n84\t\n85\tvi.mock('node:fs', async (importOriginal) => {\n86\t  const actual = await importOriginal<typeof import('node:fs')>();\n87\t  return { ...actual, existsSync: existsSyncMock };\n88\t});\n89\t\n90\tvi.mock('../../lib/ink-renderer.js', () => ({\n91\t  startRenderer: (...args: unknown[]) => startRendererMock(...(args as Parameters<typeof startRendererMock>)),\n92\t}));\n93\t\n94\tvi.mock('../../modules/sprint/index.js', () => ({\n95\t  getSprintState: (...args: unknown[]) => getSprintStateMock(...(args as Parameters<typeof getSprintStateMock>)),\n96\t  readSprintStatusFromState: (...args: unknown[]) => readSprintStatusMock(...(args as Parameters<typeof readSprintStatusMock>)),\n97\t  reconcileState: (...args: unknown[]) => reconcileStateMock(...(args as Parameters<typeof reconcileStateMock>)),\n98\t  updateStoryStatus: vi.fn(() => ({ success: true, data: undefined })),\n99\t  shouldDeferPhase: vi.fn(() => false),\n100\t  getPhaseEstimate: vi.fn(() => 15),\n101\t  computeRemainingMinutes: vi.fn(() => 60),\n102\t}));\n103\t\n104\tvi.mock('../../lib/docker/index.js', () => ({\n105\t  isDockerAvailable: (...args: unknown[]) => isDockerAvailableMock(...(args as Parameters<typeof isDockerAvailableMock>)),\n106\t}));\n107\t\n108\tvi.mock('../../modules/infra/index.js', () => ({\n109\t  cleanupContainers: (...args: unknown[]) => cleanupContainersMock(...(args as Parameters<typeof cleanupContainersMock>)),\n110\t}));\n111\t\n112\tvi.mock('../../lib/workflow-parser.js', () => ({\n113\t  parseWorkflow: (...args: unknown[]) => parseWorkflowMock(...(args as Parameters<typeof parseWorkflowMock>)),\n114\t}));\n115\t\n116\tvi.mock('../../lib/agent-resolver.js', () => ({\n117\t  resolveAgent: (...args: unknown[]) => resolveAgentMock(...(args as Parameters<typeof resolveAgentMock>)),\n118\t  compileSubagentDefinition: (...args: unknown[]) => compileSubagentMock(...(args as Parameters<typeof compileSubagentMock>)),\n119\t}));\n120\t\n121\tvi.mock('../../lib/workflow-engine.js', () => ({\n122\t  executeWorkflow: (...args: unknown[]) => executeWorkflowMock(...(args as Parameters<typeof executeWorkflowMock>)),\n123\t}));\n124\t\n125\tvi.mock('../../lib/workflow-state.js', () => ({\n126\t  readWorkflowState: (...args: unknown[]) => readWorkflowStateMock(...(args as Parameters<typeof readWorkflowStateMock>)),\n127\t  writeWorkflowState: (...args: unknown[]) => writeWorkflowStateMock(...(args as Parameters<typeof writeWorkflowStateMock>)),\n128\t}));\n129\t\n130\t\n131\tdescribe('run command', () => {\n132\t  let tmpDir: string;\n133\t\n134\t  beforeEach(() => {\n135\t    tmpDir = mkdtempSync(join(tmpdir(), 'run-test-'));\n136\t    getDriverMock.mockClear();\n137\t    existsSyncMock.mockReset();\n138\t    existsSyncMock.mockImplementation((p: unknown) => realExistsSync(String(p)));\n139\t    readSprintStatusMock.mockReset();\n140\t    readSprintStatusMock.mockReturnValue({});\n141\t    startRendererMock.mockClear();\n142\t    rendererCleanupMock.mockClear();\n143\t    getSprintStateMock.mockClear();\n144\t    getSprintStateMock.mockReturnValue({ success: false, error: 'no state' });\n145\t    reconcileStateMock.mockClear();\n146\t    reconcileStateMock.mockReturnValue({ success: true, data: { corrections: [], stateChanged: false } });\n147\t    isDockerAvailableMock.mockClear();\n148\t    isDockerAvailableMock.mockReturnValue(true);\n149\t    cleanupContainersMock.mockClear();\n150\t    cleanupContainersMock.mockReturnValue({ success: true, data: { containersRemoved: 0, names: [] } });\n151\t    parseWorkflowMock.mockReset();\n152\t    parseWorkflowMock.mockReturnValue({\n153\t      tasks: {\n154\t        implement: { agent: 'dev', scope: 'per-story', session: 'fresh', source_access: true },\n155\t      },\n156\t      flow: ['implement'],\n157\t    });\n158\t    resolveAgentMock.mockReset();\n159\t    resolveAgentMock.mockReturnValue({\n160\t      name: 'dev',\n161\t      role: { title: 'Developer', purpose: 'Implement code' },\n162\t      persona: { identity: 'A developer', communication_style: 'direct', principles: [] },\n163\t    });\n164\t    compileSubagentMock.mockReset();\n165\t    compileSubagentMock.mockReturnValue({\n166\t      name: 'dev',\n167\t      model: 'claude-sonnet-4-20250514',\n168\t      instructions: 'You are a developer',\n169\t      disallowedTools: [],\n170\t      bare: true,\n171\t    });\n172\t    executeWorkflowMock.mockReset();\n173\t    executeWorkflowMock.mockResolvedValue({\n174\t      success: true,\n175\t      tasksCompleted: 3,\n176\t      storiesProcessed: 1,\n177\t      errors: [],\n178\t      durationMs: 60000,\n179\t    });\n180\t    readWorkflowStateMock.mockReset();\n181\t    readWorkflowStateMock.mockReturnValue({\n182\t      workflow_name: '',\n183\t      started: '',\n184\t      iteration: 0,\n185\t      phase: 'idle',\n186\t      tasks_completed: [],\n187\t      evaluator_scores: [],\n188\t      circuit_breaker: { triggered: false, reason: null, score_history: [] },\n189\t      trace_ids: [],\n190\t    });\n191\t    writeWorkflowStateMock.mockReset();\n192\t    process.exitCode = undefined;\n193\t  });\n194\t\n195\t  afterEach(() => {\n196\t    rmSync(tmpDir, { recursive: true, force: true });\n197\t    vi.restoreAllMocks();\n198\t    process.exitCode = undefined;\n199\t  });\n200\t\n201\t  function mockPaths(overrides: Record<string, boolean>) {\n202\t    existsSyncMock.mockImplementation((p: unknown) => {\n203\t      const path = String(p);\n204\t      for (const [pattern, value] of Object.entries(overrides)) {\n205\t        if (path.includes(pattern)) return value;\n206\t      }\n207\t      return realExistsSync(path);\n208\t    });\n209\t  }\n210\t\n211\t  async function runCommand(args: string[] = []) {\n212\t    const { registerRunCommand } = await import('../run.js');\n213\t    const program = new Command();\n214\t    program.exitOverride();\n215\t    program.option('--json', 'JSON output');\n216\t    registerRunCommand(program);\n217\t    await program.parseAsync(['node', 'codeharness', 'run', ...args]);\n218\t  }\n219\t\n220\t  describe('resolvePluginDir', () => {\n221\t    it('returns cwd/.claude', () => {\n222\t      expect(resolvePluginDir()).toBe(join(process.cwd(), '.claude'));\n223\t    });\n224\t  });\n225\t\n226\t  describe('countStories (re-export)', () => {\n227\t    it('re-exports countStories from run-helpers.ts', () => {\n228\t      const counts = countStories({ '1-1-story': 'done', '1-2-story': 'backlog' });\n229\t      expect(counts.total).toBe(2);\n230\t      expect(counts.done).toBe(1);\n231\t    });\n232\t  });\n233\t\n234\t  describe('action handler', () => {\n235\t    it('fails when plugin directory not found', async () => {\n236\t      mockPaths({ '.claude': false });\n237\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n238\t\n239\t      await runCommand();\n240\t\n241\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Plugin directory not found'));\n242\t      expect(process.exitCode).toBe(1);\n243\t    });\n244\t\n245\t    it('fails when Docker is unavailable', async () => {\n246\t      mockPaths({ '.claude': true });\n247\t      isDockerAvailableMock.mockReturnValue(false);\n248\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n249\t\n250\t      await runCommand();\n251\t\n252\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Docker not available'));\n253\t      expect(process.exitCode).toBe(1);\n254\t    });\n255\t\n256\t    it('fails when no stories found in sprint state', async () => {\n257\t      mockPaths({ '.claude': true });\n258\t      readSprintStatusMock.mockReturnValue({});\n259\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n260\t\n261\t      await runCommand();\n262\t\n263\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('No stories found'));\n264\t      expect(process.exitCode).toBe(1);\n265\t    });\n266\t\n267\t    it('fails when no stories are ready for execution (AC #9)', async () => {\n268\t      mockPaths({ '.claude': true });\n269\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'done', '1-2-story': 'done' });\n270\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n271\t\n272\t      await runCommand();\n273\t\n274\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('No stories ready for execution'));\n275\t      expect(process.exitCode).toBe(1);\n276\t    });\n277\t\n278\t    it('calls executeWorkflow on success path (AC #1, #2)', async () => {\n279\t      mockPaths({ '.claude': true });\n280\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n281\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n282\t\n283\t      await runCommand();\n284\t\n285\t      expect(parseWorkflowMock).toHaveBeenCalled();\n286\t      expect(resolveAgentMock).toHaveBeenCalled();\n287\t      expect(executeWorkflowMock).toHaveBeenCalled();\n288\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Workflow completed'));\n289\t      expect(process.exitCode).toBeUndefined();\n290\t    });\n291\t\n292\t    it('constructs EngineConfig correctly from CLI options (AC #4)', async () => {\n293\t      mockPaths({ '.claude': true });\n294\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n295\t      vi.spyOn(console, 'log').mockImplementation(() => {});\n296\t\n297\t      await runCommand(['--max-iterations', '10']);\n298\t\n299\t      expect(executeWorkflowMock).toHaveBeenCalled();\n300\t      const config = executeWorkflowMock.mock.calls[0][0];\n301\t      expect(config.maxIterations).toBe(10);\n302\t      expect(config.runId).toMatch(/^run-\\d+$/);\n303\t      expect(config.workflow).toBeDefined();\n304\t      expect(config.agents).toBeDefined();\n305\t      expect(config.sprintStatusPath).toContain('sprint-status.yaml');\n306\t    });\n307\t\n308\t    it('exits 1 on workflow failure (AC #2)', async () => {\n309\t      mockPaths({ '.claude': true });\n310\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n311\t      executeWorkflowMock.mockResolvedValue({\n312\t        success: false,\n313\t        tasksCompleted: 1,\n314\t        storiesProcessed: 1,\n315\t        errors: [{ taskName: 'implement', storyKey: '1-1-story', code: 'UNKNOWN', message: 'dispatch failed' }],\n316\t        durationMs: 5000,\n317\t      });\n318\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n319\t\n320\t      await runCommand();\n321\t\n322\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Workflow failed'));\n323\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('dispatch failed'));\n324\t      expect(process.exitCode).toBe(1);\n325\t    });\n326\t\n327\t    it('exits 1 when executeWorkflow throws', async () => {\n328\t      mockPaths({ '.claude': true });\n329\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n330\t      executeWorkflowMock.mockRejectedValue(new Error('engine crashed'));\n331\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n332\t\n333\t      await runCommand();\n334\t\n335\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Workflow engine error'));\n336\t      expect(process.exitCode).toBe(1);\n337\t    });\n338\t\n339\t    it('exits 1 when workflow parsing fails', async () => {\n340\t      mockPaths({ '.claude': true });\n341\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n342\t      parseWorkflowMock.mockImplementation(() => { throw new Error('bad YAML'); });\n343\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n344\t\n345\t      await runCommand();\n346\t\n347\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Failed to parse workflow'));\n348\t      expect(process.exitCode).toBe(1);\n349\t    });\n350\t\n351\t    it('exits 1 when agent resolution fails', async () => {\n352\t      mockPaths({ '.claude': true });\n353\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n354\t      resolveAgentMock.mockImplementation(() => { throw new Error('agent not found'); });\n355\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n356\t\n357\t      await runCommand();\n358\t\n359\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Failed to resolve agents'));\n360\t      expect(process.exitCode).toBe(1);\n361\t    });\n362\t\n363\t    it('logs reconciliation corrections when present', async () => {\n364\t      mockPaths({ '.claude': true });\n365\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n366\t      reconcileStateMock.mockReturnValue({\n367\t        success: true,\n368\t        data: { corrections: ['Fixed story-a status'], stateChanged: true },\n369\t      });\n370\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n371\t\n372\t      await runCommand();\n373\t\n374\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Reconciled: Fixed story-a status'));\n375\t    });\n376\t\n377\t    it('warns when state reconciliation fails', async () => {\n378\t      mockPaths({ '.claude': true });\n379\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n380\t      reconcileStateMock.mockReturnValue({ success: false, error: 'state file corrupt' });\n381\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n382\t\n383\t      await runCommand();\n384\t\n385\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('State reconciliation failed'));\n386\t    });\n387\t\n388\t    it('logs container cleanup when containers removed', async () => {\n389\t      mockPaths({ '.claude': true });\n390\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n391\t      cleanupContainersMock.mockReturnValue({\n392\t        success: true,\n393\t        data: { containersRemoved: 2, names: ['harness-a', 'harness-b'] },\n394\t      });\n395\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n396\t\n397\t      await runCommand();\n398\t\n399\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Cleaned up 2 orphaned container(s)'));\n400\t    });\n401\t\n402\t    it('warns when container cleanup fails', async () => {\n403\t      mockPaths({ '.claude': true });\n404\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n405\t      cleanupContainersMock.mockReturnValue({ success: false, error: 'docker socket error' });\n406\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n407\t\n408\t      await runCommand();\n409\t\n410\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Container cleanup failed'));\n411\t    });\n412\t\n413\t    it('fails with invalid numeric option', async () => {\n414\t      mockPaths({ '.claude': true });\n415\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n416\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n417\t\n418\t      await runCommand(['--max-iterations', 'abc']);\n419\t\n420\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Invalid numeric option'));\n421\t      expect(process.exitCode).toBe(1);\n422\t    });\n423\t\n424\t    it('--resume resets completed phase to idle before executing (AC #3)', async () => {\n425\t      mockPaths({ '.claude': true });\n426\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n427\t      readWorkflowStateMock.mockReturnValue({\n428\t        workflow_name: 'implement -> verify',\n429\t        started: new Date().toISOString(),\n430\t        iteration: 3,\n431\t        phase: 'completed',\n432\t        tasks_completed: [],\n433\t        evaluator_scores: [],\n434\t        circuit_breaker: { triggered: false, reason: null, score_history: [] },\n435\t        trace_ids: [],\n436\t      });\n437\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n438\t\n439\t   