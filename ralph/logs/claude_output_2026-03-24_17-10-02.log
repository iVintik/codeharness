{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JxxVNDf5Sidngw78mFpzFi","type":"tool_result","content":"     1→/**\n     2→ * Public API for the sync subsystem.\n     3→ */\n     4→\n     5→// Types\n     6→export type { SyncResult, SyncDirection } from './story-files.js';\n     7→export type { OnboardingStoryEntry } from './sprint-yaml.js';\n     8→\n     9→// Story file operations\n    10→export {\n    11→  resolveStoryFilePath,\n    12→  readStoryFileStatus,\n    13→  updateStoryFileStatus,\n    14→  beadsStatusToStoryStatus,\n    15→  storyStatusToBeadsStatus,\n    16→} from './story-files.js';\n    17→\n    18→// Sprint YAML operations\n    19→export {\n    20→  readSprintStatus,\n    21→  updateSprintStatus,\n    22→  appendOnboardingEpicToSprint,\n    23→} from './sprint-yaml.js';\n    24→\n    25→// Beads sync operations\n    26→export {\n    27→  syncBeadsToStoryFile,\n    28→  syncStoryFileToBeads,\n    29→  syncClose,\n    30→  syncAll,\n    31→} from './beads.js';\n    32→"}]},"parent_tool_use_id":"toolu_01WxJciqSN2EMLLyK1wQ7yug","session_id":"6831c0a8-772d-4704-bc72-4469c7d7a986","uuid":"71ffde86-f799-42b1-91af-f4108da8f3d0","timestamp":"2026-03-24T13:13:59.798Z"}
