{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012bkAEebmXsomNT5hVcTo4v","type":"tool_result","content":"1\timport { existsSync } from 'node:fs';\n2\timport { join } from 'node:path';\n3\timport { Command } from 'commander';\n4\timport { fail, info, ok } from '../lib/output.js';\n5\timport { isDockerAvailable } from '../lib/docker/index.js';\n6\timport { cleanupContainers } from '../modules/infra/index.js';\n7\timport { readSprintStatusFromState, reconcileState } from '../modules/sprint/index.js';\n8\timport { countStories, formatElapsed } from '../lib/run-helpers.js';\n9\timport { parseWorkflow, resolveWorkflow } from '../lib/workflow-parser.js';\n10\timport { resolveAgent, compileSubagentDefinition } from '../lib/agent-resolver.js';\n11\timport { executeWorkflow } from '../lib/workflow-engine.js';\n12\timport { readWorkflowState, writeWorkflowState } from '../lib/workflow-state.js';\n13\timport type { EngineConfig } from '../lib/workflow-engine.js';\n14\timport type { SubagentDefinition } from '../lib/agent-resolver.js';\n15\t\n16\t/** Resolves the plugin directory path (.claude/ in project root). */\n17\texport function resolvePluginDir(): string {\n18\t  return join(process.cwd(), '.claude');\n19\t}\n20\t\n21\t// Re-export helpers that tests import from run.ts\n22\texport { countStories } from '../lib/run-helpers.js';\n23\t\n24\texport function registerRunCommand(program: Command): void {\n25\t  program\n26\t    .command('run')\n27\t    .description('Execute the autonomous coding loop')\n28\t    .option('--max-iterations <n>', 'Maximum loop iterations', '50')\n29\t    .option('--timeout <seconds>', 'Total loop timeout in seconds', '43200')\n30\t    .option('--iteration-timeout <minutes>', 'Per-iteration timeout in minutes', '30')\n31\t    .option('--quiet', 'Suppress terminal output (background mode)', false)\n32\t    .option('--calls <n>', 'Max API calls per hour', '100')\n33\t    .option('--max-story-retries <n>', 'Max retries per story before flagging', '10')\n34\t    .option('--reset', 'Clear retry counters, flagged stories, and circuit breaker before starting', false)\n35\t    .option('--resume', 'Resume from last checkpoint (engine resumes by default)', false)\n36\t    .option('--workflow <name>', 'Workflow name to load (default: \"default\")')\n37\t    .action(async (options, cmd) => {\n38\t      const globalOpts = cmd.optsWithGlobals();\n39\t      const isJson = !!globalOpts.json;\n40\t      const outputOpts = { json: isJson };\n41\t\n42\t      // 1. Resolve plugin directory\n43\t      const pluginDir = resolvePluginDir();\n44\t      if (!existsSync(pluginDir)) {\n45\t        fail('Plugin directory not found — run codeharness init first', outputOpts);\n46\t        process.exitCode = 1;\n47\t        return;\n48\t      }\n49\t\n50\t      // 1b. Reconcile state (best-effort — failures warn but don't abort)\n51\t      const reconciliation = reconcileState();\n52\t      if (reconciliation.success && reconciliation.data.corrections.length > 0) {\n53\t        for (const correction of reconciliation.data.corrections) {\n54\t          info(`[INFO] Reconciled: ${correction}`, outputOpts);\n55\t        }\n56\t      } else if (!reconciliation.success) {\n57\t        info(`[WARN] State reconciliation failed: ${reconciliation.error}`, outputOpts);\n58\t      }\n59\t\n60\t      // 1c. Docker pre-flight: fail fast if Docker unavailable\n61\t      if (!isDockerAvailable()) {\n62\t        fail('[FAIL] Docker not available — install Docker or start the daemon', outputOpts);\n63\t        process.exitCode = 1;\n64\t        return;\n65\t      }\n66\t      // 1d. Orphan container cleanup (best-effort — failures warn but don't abort)\n67\t      const cleanup = cleanupContainers();\n68\t      if (cleanup.success && cleanup.data.containersRemoved > 0) {\n69\t        info(`[INFO] Cleaned up ${cleanup.data.containersRemoved} orphaned container(s): ${cleanup.data.names.join(', ')}`, outputOpts);\n70\t      } else if (!cleanup.success) {\n71\t        info(`[WARN] Container cleanup failed: ${cleanup.error}`, outputOpts);\n72\t      }\n73\t      // 2. Read sprint status for story count (from sprint-state.json)\n74\t      const statuses = readSprintStatusFromState();\n75\t      const counts = countStories(statuses);\n76\t\n77\t      if (counts.total === 0) {\n78\t        fail('No stories found in sprint-state.json — nothing to execute', outputOpts);\n79\t        process.exitCode = 1;\n80\t        return;\n81\t      }\n82\t\n83\t      if (counts.ready === 0) {\n84\t        fail('No stories ready for execution', outputOpts);\n85\t        process.exitCode = 1;\n86\t        return;\n87\t      }\n88\t\n89\t      info(`Starting autonomous execution — ${counts.ready} ready, ${counts.inProgress} in progress, ${counts.verified} verified, ${counts.done}/${counts.total} done`, outputOpts);\n90\t      // 3. Parse and validate numeric options\n91\t      const maxIterations = parseInt(options.maxIterations, 10);\n92\t      const timeout = parseInt(options.timeout, 10);\n93\t      const iterationTimeout = parseInt(options.iterationTimeout, 10);\n94\t      const calls = parseInt(options.calls, 10);\n95\t      const maxStoryRetries = parseInt(options.maxStoryRetries, 10);\n96\t      if (isNaN(maxIterations) || isNaN(timeout) || isNaN(iterationTimeout) || isNaN(calls) || isNaN(maxStoryRetries)) {\n97\t        fail('Invalid numeric option — --max-iterations, --timeout, --iteration-timeout, --calls, and --max-story-retries must be numbers', outputOpts);\n98\t        process.exitCode = 1;\n99\t        return;\n100\t      }\n101\t\n102\t      // 4. Resolve workflow (embedded -> user patch -> project patch)\n103\t      const projectDir = process.cwd();\n104\t      const workflowName = options.workflow ?? 'default';\n105\t\n106\t      // Validate workflow name: only alphanumeric, hyphens, underscores allowed\n107\t      if (!/^[a-zA-Z0-9_-]+$/.test(workflowName)) {\n108\t        fail(`Invalid workflow name \"${workflowName}\" — only alphanumeric characters, hyphens, and underscores are allowed`, outputOpts);\n109\t        process.exitCode = 1;\n110\t        return;\n111\t      }\n112\t\n113\t      let parsedWorkflow;\n114\t      try {\n115\t        parsedWorkflow = resolveWorkflow({ cwd: projectDir, name: workflowName });\n116\t      } catch (err: unknown) {\n117\t        // Fallback: try direct file parsing for backward compatibility (only for default)\n118\t        if (workflowName !== 'default') {\n119\t          const msg = err instanceof Error ? err.message : String(err);\n120\t          fail(`Failed to resolve workflow: ${msg}`, outputOpts);\n121\t          process.exitCode = 1;\n122\t          return;\n123\t        }\n124\t        const projectWorkflowPath = join(projectDir, '.codeharness', 'workflows', 'default.yaml');\n125\t        const templateWorkflowPath = join(projectDir, 'templates', 'workflows', 'default.yaml');\n126\t        const workflowPath = existsSync(projectWorkflowPath) ? projectWorkflowPath : templateWorkflowPath;\n127\t        try {\n128\t          parsedWorkflow = parseWorkflow(workflowPath);\n129\t        } catch (fallbackErr: unknown) {\n130\t          const msg = fallbackErr instanceof Error ? fallbackErr.message : String(fallbackErr);\n131\t          fail(`Failed to resolve workflow: ${msg}`, outputOpts);\n132\t          process.exitCode = 1;\n133\t          return;\n134\t        }\n135\t      }\n136\t\n137\t      // 5. Resolve agents referenced in workflow\n138\t      const agents: Record<string, SubagentDefinition> = {};\n139\t      try {\n140\t        for (const [, task] of Object.entries(parsedWorkflow.tasks)) {\n141\t          if (task.agent != null && !agents[task.agent]) {\n142\t            const resolved = resolveAgent(task.agent, { cwd: projectDir });\n143\t            agents[task.agent] = compileSubagentDefinition(resolved);\n144\t          }\n145\t        }\n146\t      } catch (err: unknown) {\n147\t        const msg = err instanceof Error ? err.message : String(err);\n148\t        fail(`Failed to resolve agents: ${msg}`, outputOpts);\n149\t        process.exitCode = 1;\n150\t        return;\n151\t      }\n152\t\n153\t      // 6. Handle --resume: reset completed or circuit-breaker state so the engine re-enters execution\n154\t      if (options.resume) {\n155\t        const currentState = readWorkflowState(projectDir);\n156\t        if (currentState.phase === 'completed') {\n157\t          writeWorkflowState({ ...currentState, phase: 'idle' }, projectDir);\n158\t          info('Resuming from completed state — phase reset to idle', outputOpts);\n159\t        } else if (currentState.phase === 'circuit-breaker') {\n160\t          writeWorkflowState({\n161\t            ...currentState,\n162\t            phase: 'idle',\n163\t            circuit_breaker: {\n164\t              ...currentState.circuit_breaker,\n165\t              triggered: false,\n166\t              reason: null,\n167\t              // score_history is PRESERVED\n168\t            },\n169\t          }, projectDir);\n170\t          info('Resuming after circuit breaker — previous findings preserved', outputOpts);\n171\t        }\n172\t      }\n173\t\n174\t      // 7. Build EngineConfig and execute\n175\t      const config: EngineConfig = {\n176\t        workflow: parsedWorkflow,\n177\t        agents,\n178\t        sprintStatusPath: join(projectDir, '_bmad-output', 'implementation-artifacts', 'sprint-status.yaml'),\n179\t        issuesPath: join(projectDir, '.codeharness', 'issues.yaml'),\n180\t        runId: `run-${Date.now()}`,\n181\t        projectDir,\n182\t        maxIterations,\n183\t      };\n184\t\n185\t      try {\n186\t        const result = await executeWorkflow(config);\n187\t\n188\t        if (result.success) {\n189\t          ok(`Workflow completed — ${result.storiesProcessed} stories processed, ${result.tasksCompleted} tasks completed in ${formatElapsed(result.durationMs)}`, outputOpts);\n190\t        } else {\n191\t          fail(`Workflow failed — ${result.storiesProcessed} stories processed, ${result.tasksCompleted} tasks completed, ${result.errors.length} error(s) in ${formatElapsed(result.durationMs)}`, outputOpts);\n192\t          for (const err of result.errors) {\n193\t            info(`  ${err.taskName}/${err.storyKey}: [${err.code}] ${err.message}`, outputOpts);\n194\t          }\n195\t          process.exitCode = 1;\n196\t        }\n197\t      } catch (err: unknown) {\n198\t        const msg = err instanceof Error ? err.message : String(err);\n199\t        fail(`Workflow engine error: ${msg}`, outputOpts);\n200\t        process.exitCode = 1;\n201\t      }\n202\t    });\n203\t}\n204\t"}]},"parent_tool_use_id":"toolu_01YVAicDPB2Xe9r2bfCAtkWv","session_id":"1e0d780f-040f-4c10-b8e5-df49ae6fae2c","uuid":"6091d20b-bcfc-470c-90b6-9d3f23150723","timestamp":"2026-04-03T20:45:10.513Z"}
