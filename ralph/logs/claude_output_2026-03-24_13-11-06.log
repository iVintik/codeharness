{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SUX1DD2P4N6TDhJnEutsFD","type":"tool_result","content":"     1→/**\n     2→ * Public API for the stacks subsystem.\n     3→ */\n     4→\n     5→// Types\n     6→export type {\n     7→  StackName,\n     8→  AppType,\n     9→  CoverageToolName,\n    10→  CoverageToolInfo,\n    11→  OtlpResult,\n    12→  TestCounts,\n    13→  StackProvider,\n    14→} from './types.js';\n    15→\n    16→// Registry\n    17→export {\n    18→  registerProvider,\n    19→  getStackProvider,\n    20→  detectStack,\n    21→  detectStacks,\n    22→  type StackDetection,\n    23→  _resetRegistry,\n    24→} from './registry.js';\n    25→\n    26→// Auto-register built-in providers\n    27→import { registerProvider } from './registry.js';\n    28→import { NodejsProvider } from './nodejs.js';\n    29→import { PythonProvider } from './python.js';\n    30→import { RustProvider } from './rust.js';\n    31→\n    32→registerProvider(new NodejsProvider());\n    33→registerProvider(new PythonProvider());\n    34→registerProvider(new RustProvider());\n    35→"}]},"parent_tool_use_id":"toolu_017PSxBvnRkcQULAwL8e4KVd","session_id":"1d547185-a995-481d-9659-9279ed70f717","uuid":"bf97efe3-cfb1-493e-9542-78a5430a6a4b","timestamp":"2026-03-24T09:25:48.150Z"}
