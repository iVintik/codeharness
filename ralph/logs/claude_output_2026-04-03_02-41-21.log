{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EFm9fUHEmEjA4G7hPa5qgW","type":"tool_result","content":"1\timport { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n2\timport { join } from 'node:path';\n3\timport { parse, stringify } from 'yaml';\n4\timport { warn } from './output.js';\n5\t\n6\t// --- Interfaces ---\n7\t\n8\texport interface TaskCheckpoint {\n9\t  task_name: string;\n10\t  story_key: string;\n11\t  completed_at: string;\n12\t  session_id?: string;\n13\t}\n14\t\n15\texport interface EvaluatorScore {\n16\t  iteration: number;\n17\t  passed: number;\n18\t  failed: number;\n19\t  unknown: number;\n20\t  total: number;\n21\t  timestamp: string;\n22\t}\n23\t\n24\texport interface CircuitBreakerState {\n25\t  triggered: boolean;\n26\t  reason: string | null;\n27\t  score_history: number[];\n28\t}\n29\t\n30\texport interface WorkflowState {\n31\t  workflow_name: string;\n32\t  started: string;\n33\t  iteration: number;\n34\t  phase: string;\n35\t  tasks_completed: TaskCheckpoint[];\n36\t  evaluator_scores: EvaluatorScore[];\n37\t  circuit_breaker: CircuitBreakerState;\n38\t  trace_ids?: string[];\n39\t}\n40\t\n41\t// --- Constants ---\n42\t\n43\tconst STATE_DIR = '.codeharness';\n44\tconst STATE_FILE = 'workflow-state.yaml';\n45\t\n46\t// --- Functions ---\n47\t\n48\texport function getDefaultWorkflowState(): WorkflowState {\n49\t  return {\n50\t    workflow_name: '',\n51\t    started: '',\n52\t    iteration: 0,\n53\t    phase: 'idle',\n54\t    tasks_completed: [],\n55\t    evaluator_scores: [],\n56\t    circuit_breaker: {\n57\t      triggered: false,\n58\t      reason: null,\n59\t      score_history: [],\n60\t    },\n61\t    trace_ids: [],\n62\t  };\n63\t}\n64\t\n65\texport function writeWorkflowState(state: WorkflowState, dir?: string): void {\n66\t  const baseDir = dir ?? process.cwd();\n67\t  const stateDir = join(baseDir, STATE_DIR);\n68\t  mkdirSync(stateDir, { recursive: true });\n69\t  const yamlContent = stringify(state, { nullStr: 'null' });\n70\t  writeFileSync(join(stateDir, STATE_FILE), yamlContent, 'utf-8');\n71\t}\n72\t\n73\texport function readWorkflowState(dir?: string): WorkflowState {\n74\t  const baseDir = dir ?? process.cwd();\n75\t  const filePath = join(baseDir, STATE_DIR, STATE_FILE);\n76\t\n77\t  if (!existsSync(filePath)) {\n78\t    return getDefaultWorkflowState();\n79\t  }\n80\t\n81\t  let raw: string;\n82\t  try {\n83\t    raw = readFileSync(filePath, 'utf-8');\n84\t  } catch { // IGNORE: unreadable file (permissions, EISDIR, etc.) — recover with defaults\n85\t    warn('workflow-state.yaml could not be read — returning default state');\n86\t    return getDefaultWorkflowState();\n87\t  }\n88\t\n89\t  let parsed: unknown;\n90\t  try {\n91\t    parsed = parse(raw);\n92\t  } catch { // IGNORE: corrupted YAML — recover with defaults\n93\t    warn('workflow-state.yaml contains invalid YAML — returning default state');\n94\t    return getDefaultWorkflowState();\n95\t  }\n96\t\n97\t  if (!isValidWorkflowState(parsed)) {\n98\t    warn('workflow-state.yaml has invalid shape — returning default state');\n99\t    return getDefaultWorkflowState();\n100\t  }\n101\t\n102\t  return parsed;\n103\t}\n104\t\n105\t// --- Validation ---\n106\t\n107\tfunction isValidWorkflowState(value: unknown): value is WorkflowState {\n108\t  if (!value || typeof value !== 'object') return false;\n109\t  const s = value as Record<string, unknown>;\n110\t\n111\t  if (typeof s.workflow_name !== 'string') return false;\n112\t  if (typeof s.started !== 'string') return false;\n113\t  if (typeof s.iteration !== 'number') return false;\n114\t  if (typeof s.phase !== 'string') return false;\n115\t  if (!Array.isArray(s.tasks_completed)) return false;\n116\t  if (!Array.isArray(s.evaluator_scores)) return false;\n117\t  if (!s.circuit_breaker || typeof s.circuit_breaker !== 'object') return false;\n118\t\n119\t  // Validate trace_ids (optional array of strings)\n120\t  if (s.trace_ids !== undefined) {\n121\t    if (!Array.isArray(s.trace_ids)) return false;\n122\t    for (const id of s.trace_ids) {\n123\t      if (typeof id !== 'string') return false;\n124\t    }\n125\t  }\n126\t\n127\t  // Validate tasks_completed element shapes\n128\t  for (const t of s.tasks_completed) {\n129\t    if (!t || typeof t !== 'object') return false;\n130\t    const tc = t as Record<string, unknown>;\n131\t    if (typeof tc.task_name !== 'string') return false;\n132\t    if (typeof tc.story_key !== 'string') return false;\n133\t    if (typeof tc.completed_at !== 'string') return false;\n134\t    if (tc.session_id !== undefined && typeof tc.session_id !== 'string') return false;\n135\t  }\n136\t\n137\t  // Validate evaluator_scores element shapes\n138\t  for (const e of s.evaluator_scores) {\n139\t    if (!e || typeof e !== 'object') return false;\n140\t    const es = e as Record<string, unknown>;\n141\t    if (typeof es.iteration !== 'number') return false;\n142\t    if (typeof es.passed !== 'number') return false;\n143\t    if (typeof es.failed !== 'number') return false;\n144\t    if (typeof es.unknown !== 'number') return false;\n145\t    if (typeof es.total !== 'number') return false;\n146\t    if (typeof es.timestamp !== 'string') return false;\n147\t  }\n148\t\n149\t  const cb = s.circuit_breaker as Record<string, unknown>;\n150\t  if (typeof cb.triggered !== 'boolean') return false;\n151\t  if (cb.reason !== null && typeof cb.reason !== 'string') return false;\n152\t  if (!Array.isArray(cb.score_history)) return false;\n153\t\n154\t  // Validate score_history elements are numbers\n155\t  for (const score of cb.score_history) {\n156\t    if (typeof score !== 'number') return false;\n157\t  }\n158\t\n159\t  return true;\n160\t}\n161\t"}]},"parent_tool_use_id":"toolu_01GD3dd86R9DYmBSHRKfrVV3","session_id":"8b4a1da7-9e18-4302-ad13-ce7f0aff0314","uuid":"36a7be2b-d828-47eb-a534-3bf38189c025","timestamp":"2026-04-02T22:54:43.712Z"}
