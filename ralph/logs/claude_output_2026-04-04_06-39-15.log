{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01E9ErFs7JW9KV46MnsByrFg","type":"tool_result","content":"1\t/**\n2\t * Ink UI components — activity display (tools, thoughts, retry, messages).\n3\t *\n4\t * Split from ink-components.tsx to comply with NFR9 (max 300 lines per file).\n5\t * Types are defined in ink-components.tsx and imported here.\n6\t */\n7\t\n8\timport React from 'react';\n9\timport { Text, Box } from 'ink';\n10\timport { Spinner } from '@inkjs/ui';\n11\timport type { CompletedToolEntry, RetryInfo, StoryMessage } from './ink-components.js';\n12\t\n13\t// --- Message Styles ---\n14\t\n15\tconst MESSAGE_STYLE: Record<StoryMessage['type'], { prefix: string; color: string }> = {\n16\t  ok: { prefix: '[OK]', color: 'green' },\n17\t  warn: { prefix: '[WARN]', color: 'yellow' },\n18\t  fail: { prefix: '[FAIL]', color: 'red' },\n19\t};\n20\t\n21\t// --- Components ---\n22\t\n23\texport function StoryMessageLine({ msg }: { msg: StoryMessage }) {\n24\t  const style = MESSAGE_STYLE[msg.type];\n25\t  return (\n26\t    <Box flexDirection=\"column\">\n27\t      <Text>\n28\t        <Text color={style.color} bold>{style.prefix}</Text>\n29\t        <Text>{` Story ${msg.key}: ${msg.message}`}</Text>\n30\t      </Text>"}]},"parent_tool_use_id":"toolu_01TzQwpEV7uekTzzh7pB5DWd","session_id":"7e3ded59-6184-4f8b-8f55-ba5e63dae51f","uuid":"a608cdaa-bfd6-4674-8703-67ae5947cdbb","timestamp":"2026-04-04T02:49:51.857Z"}
