{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BUYTKh1WTCGBqXaVZt9EdB","type":"tool_result","content":"1\timport { query } from '@anthropic-ai/claude-agent-sdk';\n2\timport type { SubagentDefinition } from './agent-resolver.js';\n3\t\n4\t// --- Interfaces ---\n5\t\n6\t/**\n7\t * Options for dispatching an agent session.\n8\t */\n9\texport interface DispatchOptions {\n10\t  /** Working directory for the agent session. */\n11\t  cwd?: string;\n12\t  /** Session ID for resuming an existing session (forward-compat for story 4-2). */\n13\t  sessionId?: string;\n14\t  /** Additional text appended to the system prompt (forward-compat for story 4-3 trace IDs). */\n15\t  appendSystemPrompt?: string;\n16\t}\n17\t\n18\t/**\n19\t * Result of a successful agent dispatch.\n20\t */\n21\texport interface DispatchResult {\n22\t  /** The session ID assigned by the Agent SDK. */\n23\t  sessionId: string;\n24\t  /** Whether the session completed successfully (no errors). */\n25\t  success: boolean;\n26\t  /** Wall-clock duration in milliseconds. */\n27\t  durationMs: number;\n28\t  /** The agent's final text response. */\n29\t  output: string;\n30\t}\n31\t\n32\t// --- Error Class ---\n33\t\n34\t/** Error codes for classifying dispatch failures. */\n35\texport type DispatchErrorCode = 'RATE_LIMIT' | 'NETWORK' | 'SDK_INIT' | 'UNKNOWN';\n36\t\n37\t/**\n38\t * Structured error thrown by dispatchAgent() with a classification code.\n39\t */\n40\texport class DispatchError extends Error {\n41\t  public readonly code: DispatchErrorCode;\n42\t  public readonly agentName: string;\n43\t  public readonly cause: unknown;\n44\t\n45\t  constructor(\n46\t    message: string,\n47\t    code: DispatchErrorCode,\n48\t    agentName: string,\n49\t    cause: unknown,\n50\t  ) {\n51\t    super(message);\n52\t    this.name = 'DispatchError';\n53\t    this.code = code;\n54\t    this.agentName = agentName;\n55\t    this.cause = cause;\n56\t  }\n57\t}\n58\t\n59\t// --- Error Classification ---\n60\t\n61\tconst NETWORK_CODES = new Set([\n62\t  'ECONNREFUSED',\n63\t  'ETIMEDOUT',\n64\t  'ENOTFOUND',\n65\t  'ENETUNREACH',\n66\t  'ECONNRESET',\n67\t  'EPIPE',\n68\t]);\n69\t\n70\t/**\n71\t * Classify an error from the Agent SDK into a DispatchErrorCode.\n72\t */\n73\tfunction classifyError(err: unknown): DispatchErrorCode {\n74\t  const message = err instanceof Error ? err.message : String(err);\n75\t  const code = (err as { code?: string })?.code;\n76\t  const status = (err as { status?: number })?.status;\n77\t\n78\t  // Rate limit: HTTP 429 or message containing \"rate limit\"\n79\t  if (status === 429 || /rate.?limit/i.test(message)) {\n80\t    return 'RATE_LIMIT';\n81\t  }\n82\t\n83\t  // Network errors: known error codes or fetch-related failures\n84\t  if (code && NETWORK_CODES.has(code)) {\n85\t    return 'NETWORK';\n86\t  }\n87\t  if (/fetch|network|dns/i.test(message) && /fail|error|timeout/i.test(message)) {\n88\t    return 'NETWORK';\n89\t  }\n90\t\n91\t  // SDK init: binary not found, SDK constructor errors\n92\t  if (/not found|cannot find|no such file|ENOENT/i.test(message) && /claude|binary|executable/i.test(message)) {\n93\t    return 'SDK_INIT';\n94\t  }\n95\t  if (/sdk.*init|constructor.*fail|cannot.*initialize/i.test(message)) {\n96\t    return 'SDK_INIT';\n97\t  }\n98\t\n99\t  return 'UNKNOWN';\n100\t}\n101\t\n102\t// --- Main Dispatch Function ---\n103\t\n104\t/**\n105\t * Dispatch an agent session via the Agent SDK query() API.\n106\t *\n107\t * Starts a session with the given subagent definition and prompt,\n108\t * consumes the async generator, and returns a DispatchResult when done.\n109\t *\n110\t * Uses only the SDK — no process invocation. No retry logic. No output parsing.\n111\t */\n112\texport async function dispatchAgent(\n113\t  definition: SubagentDefinition,\n114\t  prompt: string,\n115\t  options?: DispatchOptions,\n116\t): Promise<DispatchResult> {\n117\t  const startMs = Date.now();\n118\t\n119\t  // Build system prompt — use the definition instructions,\n120\t  // optionally appending the trace ID / extra context.\n121\t  let systemPrompt: string = definition.instructions;\n122\t\n123\t  if (options?.appendSystemPrompt) {\n124\t    systemPrompt = `${definition.instructions}\\n\\n${options.appendSystemPrompt}`;\n125\t  }\n126\t\n127\t  try {\n128\t    const queryGenerator = query({\n129\t      prompt,\n130\t      options: {\n131\t        model: definition.model,\n132\t        systemPrompt,\n133\t        disallowedTools: definition.disallowedTools,\n134\t        ...(options?.cwd ? { cwd: options.cwd } : {}),\n135\t        ...(options?.sessionId ? { resume: options.sessionId } : {}),\n136\t        permissionMode: 'bypassPermissions',\n137\t        allowDangerouslySkipPermissions: true,\n138\t      },\n139\t    });\n140\t\n141\t    // Consume the async generator to completion, capturing the result message.\n142\t    let sessionId = '';\n143\t    let output = '';\n144\t    let success = false;\n145\t\n146\t    for await (const message of queryGenerator) {\n147\t      // Capture session_id from any message that has it.\n148\t      if ('session_id' in message && message.session_id) {\n149\t        sessionId = message.session_id;\n150\t      }\n151\t\n152\t      // Capture the result message (final message in the stream).\n153\t      if (message.type === 'result') {\n154\t        const resultMsg = message as {\n155\t          type: 'result';\n156\t          subtype: string;\n157\t          result?: string;\n158\t          errors?: string[];\n159\t          session_id: string;\n160\t        };\n161\t\n162\t        sessionId = resultMsg.session_id;\n163\t        success = resultMsg.subtype === 'success';\n164\t        output = resultMsg.result ?? '';\n165\t      }\n166\t    }\n167\t\n168\t    const durationMs = Date.now() - startMs;\n169\t\n170\t    return {\n171\t      sessionId,\n172\t      success,\n173\t      durationMs,\n174\t      output,\n175\t    };\n176\t  } catch (err: unknown) {\n177\t    const errorCode = classifyError(err);\n178\t    const message = err instanceof Error ? err.message : String(err);\n179\t    throw new DispatchError(\n180\t      `Agent dispatch failed for \"${definition.name}\": ${message}`,\n181\t      errorCode,\n182\t      definition.name,\n183\t      err,\n184\t    );\n185\t  }\n186\t}\n187\t"}]},"parent_tool_use_id":"toolu_01BUjCG6H8L3i8XGB6FePD7q","session_id":"45fbbef5-e9ca-4512-91b9-2760b179ad44","uuid":"e020ee77-e607-41c3-9fba-4ee25d372408","timestamp":"2026-04-02T19:57:54.675Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M6EmLgoy6yHWum5frbQLDR","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach } from 'vitest';\n2\timport fs from 'node:fs';\n3\timport path from 'node:path';\n4\t\n5\t// --- Mock the Agent SDK ---\n6\t\n7\tconst { mockQuery } = vi.hoisted(() => ({\n8\t  mockQuery: vi.fn(),\n9\t}));\n10\t\n11\tvi.mock('@anthropic-ai/claude-agent-sdk', () => ({\n12\t  query: mockQuery,\n13\t}));\n14\t\n15\timport {\n16\t  dispatchAgent,\n17\t  DispatchError,\n18\t} from '../agent-dispatch.js';\n19\timport type {\n20\t  DispatchOptions,\n21\t  DispatchResult,\n22\t  DispatchErrorCode,\n23\t} from '../agent-dispatch.js';\n24\timport type { SubagentDefinition } from '../agent-resolver.js';\n25\t\n26\t// --- Helpers ---\n27\t\n28\tfunction makeDefinition(overrides?: Partial<SubagentDefinition>): SubagentDefinition {\n29\t  return {\n30\t    name: 'test-agent',\n31\t    model: 'claude-sonnet-4-20250514',\n32\t    instructions: 'You are a test agent.',\n33\t    disallowedTools: [],\n34\t    bare: true,\n35\t    ...overrides,\n36\t  };\n37\t}\n38\t\n39\t/**\n40\t * Create an async generator that yields the given messages.\n41\t */\n42\tasync function* fakeStream(messages: Array<Record<string, unknown>>) {\n43\t  for (const msg of messages) {\n44\t    yield msg;\n45\t  }\n46\t}\n47\t\n48\tfunction makeSuccessResult(overrides?: Record<string, unknown>) {\n49\t  return {\n50\t    type: 'result',\n51\t    subtype: 'success',\n52\t    result: 'Agent completed the task.',\n53\t    session_id: 'sess-abc-123',\n54\t    duration_ms: 1234,\n55\t    duration_api_ms: 1000,\n56\t    is_error: false,\n57\t    num_turns: 3,\n58\t    total_cost_usd: 0.05,\n59\t    usage: { input_tokens: 100, output_tokens: 200 },\n60\t    modelUsage: {},\n61\t    permission_denials: [],\n62\t    uuid: 'uuid-123',\n63\t    ...overrides,\n64\t  };\n65\t}\n66\t\n67\tfunction makeErrorResult(overrides?: Record<string, unknown>) {\n68\t  return {\n69\t    type: 'result',\n70\t    subtype: 'error_during_execution',\n71\t    session_id: 'sess-err-456',\n72\t    duration_ms: 500,\n73\t    duration_api_ms: 400,\n74\t    is_error: true,\n75\t    num_turns: 1,\n76\t    stop_reason: null,\n77\t    total_cost_usd: 0.01,\n78\t    usage: { input_tokens: 50, output_tokens: 10 },\n79\t    modelUsage: {},\n80\t    permission_denials: [],\n81\t    errors: ['Something went wrong'],\n82\t    uuid: 'uuid-456',\n83\t    ...overrides,\n84\t  };\n85\t}\n86\t\n87\t// --- Tests ---\n88\t\n89\tdescribe('agent-dispatch', () => {\n90\t  beforeEach(() => {\n91\t    vi.clearAllMocks();\n92\t  });\n93\t\n94\t  describe('successful dispatch', () => {\n95\t    it('returns correct DispatchResult shape (AC #2)', async () => {\n96\t      mockQuery.mockReturnValue(fakeStream([makeSuccessResult()]));\n97\t\n98\t      const result = await dispatchAgent(makeDefinition(), 'Do the thing');\n99\t\n100\t      expect(result).toEqual(\n101\t        expect.objectContaining({\n102\t          sessionId: 'sess-abc-123',\n103\t          success: true,\n104\t          output: 'Agent completed the task.',\n105\t        }),\n106\t      );\n107\t      expect(typeof result.durationMs).toBe('number');\n108\t      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n109\t    });\n110\t\n111\t    it('durationMs is a positive number (AC #3)', async () => {\n112\t      mockQuery.mockReturnValue(fakeStream([makeSuccessResult()]));\n113\t\n114\t      const result = await dispatchAgent(makeDefinition(), 'Do the thing');\n115\t\n116\t      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n117\t      expect(Number.isFinite(result.durationMs)).toBe(true);\n118\t    });\n119\t\n120\t    it('returns success: false for error result subtype', async () => {\n121\t      mockQuery.mockReturnValue(fakeStream([makeErrorResult()]));\n122\t\n123\t      const result = await dispatchAgent(makeDefinition(), 'Do the thing');\n124\t\n125\t      expect(result.success).toBe(false);\n126\t      expect(result.sessionId).toBe('sess-err-456');\n127\t    });\n128\t\n129\t    it('captures session_id from intermediate messages', async () => {\n130\t      mockQuery.mockReturnValue(\n131\t        fakeStream([\n132\t          { type: 'system', session_id: 'sess-early', tools: [] },\n133\t          makeSuccessResult({ session_id: 'sess-final' }),\n134\t        ]),\n135\t      );\n136\t\n137\t      const result = await dispatchAgent(makeDefinition(), 'Do the thing');\n138\t\n139\t      expect(result.sessionId).toBe('sess-final');\n140\t    });\n141\t  });\n142\t\n143\t  describe('SDK call parameters', () => {\n144\t    it('passes prompt to query() (AC #1)', async () => {\n145\t      mockQuery.mockReturnValue(fakeStream([makeSuccessResult()]));\n146\t\n147\t      await dispatchAgent(makeDefinition(), 'Build a widget');\n148\t\n149\t      expect(mockQuery).toHaveBeenCalledTimes(1);\n150\t      const call = mockQuery.mock.calls[0][0];\n151\t      expect(call.prompt).toBe('Build a widget');\n152\t    });\n153\t\n154\t    it('passes model from definition to options (AC #1)', async () => {\n155\t      mockQuery.mockReturnValue(fakeStream([makeSuccessResult()]));\n156\t\n157\t      await dispatchAgent(\n158\t        makeDefinition({ model: 'claude-opus-4-20250514' }),\n159\t        'Do the thing',\n160\t      );\n161\t\n162\t      const call = mockQuery.mock.calls[0][0];\n163\t      expect(call.options.model).toBe('claude-opus-4-20250514');\n164\t    });\n165\t\n166\t    it('passes systemPrompt from definition instructions (AC #1)', async () => {\n167\t      mockQuery.mockReturnValue(fakeStream([makeSuccessResult()]));\n168\t\n169\t      await dispatchAgent(\n170\t        makeDefinition({ instructions: 'You are an expert coder.' }),\n171\t        'Do the thing',\n172\t      );\n173\t\n174\t      const call = mockQuery.mock.calls[0][0];\n175\t      expect(call.options.systemPrompt).toBe('You are an expert coder.');\n176\t    });\n177\t\n178\t    it('passes disallowedTools from definition (AC #1)', async () => {\n179\t      mockQuery.mockReturnValue(fakeStream([makeSuccessResult()]));\n180\t\n181\t      await dispatchAgent(\n182\t        makeDefinition({ disallowedTools: ['Edit', 'Write'] }),\n183\t        'Do the thing',\n184\t      );\n185\t\n186\t      const call = mockQuery.mock.calls[0][0];\n187\t      expect(call.options.disallowedTools).toEqual(['Edit', 'Write']);\n188\t    });\n189\t\n190\t    it('passes cwd from options (AC #9)', async () => {\n191\t      mockQuery.mockReturnValue(fakeStream([makeSuccessResult()]));\n192\t\n193\t      await dispatchAgent(makeDefinition(), 'Do the thing', {\n194\t        cwd: '/some/path',\n195\t      });\n196\t\n197\t      const call = mockQuery.mock.calls[0][0];\n198\t      expect(call.options.cwd).toBe('/some/path');\n199\t    });\n200\t\n201\t    it('does not pass cwd when not provided', async () => {\n202\t      mockQuery.mockReturnValue(fakeStream([makeSuccessResult()]));\n203\t\n204\t      await dispatchAgent(makeDefinition(), 'Do the thing');\n205\t\n206\t      const call = mockQuery.mock.calls[0][0];\n207\t      expect(call.options.cwd).toBeUndefined();\n208\t    });\n209\t\n210\t    it('passes appendSystemPrompt by appending to instructions', async () => {\n211\t      mockQuery.mockReturnValue(fakeStream([makeSuccessResult()]));\n212\t\n213\t      await dispatchAgent(\n214\t        makeDefinition({ instructions: 'Base instructions.' }),\n215\t        'Do the thing',\n216\t        { appendSystemPrompt: 'TRACE-ID: abc-123' },\n217\t      );\n218\t\n219\t      const call = mockQuery.mock.calls[0][0];\n220\t      expect(call.options.systemPrompt).toBe(\n221\t        'Base instructions.\\n\\nTRACE-ID: abc-123',\n222\t      );\n223\t    });\n224\t\n225\t    it('does not modify systemPrompt when appendSystemPrompt is not provided', async () => {\n226\t      mockQuery.mockReturnValue(fakeStream([makeSuccessResult()]));\n227\t\n228\t      await dispatchAgent(\n229\t        makeDefinition({ instructions: 'Base instructions.' }),\n230\t        'Do the thing',\n231\t      );\n232\t\n233\t      const call = mockQuery.mock.calls[0][0];\n234\t      expect(call.options.systemPrompt).toBe('Base instructions.');\n235\t    });\n236\t\n237\t    it('passes permissionMode bypassPermissions (bare mode, AC #1)', async () => {\n238\t      mockQuery.mockReturnValue(fakeStream([makeSuccessResult()]));\n239\t\n240\t      await dispatchAgent(makeDefinition(), 'Do the thing');\n241\t\n242\t      const call = mockQuery.mock.calls[0][0];\n243\t      expect(call.options.permissionMode).toBe('bypassPermissions');\n244\t      expect(call.options.allowDangerouslySkipPermissions).toBe(true);\n245\t    });\n246\t\n247\t    it('passes resume from sessionId option (forward-compat for story 4-2)', async () => {\n248\t      mockQuery.mockReturnValue(fakeStream([makeSuccessResult()]));\n249\t\n250\t      await dispatchAgent(makeDefinition(), 'Continue', {\n251\t        sessionId: 'sess-resume-789',\n252\t      });\n253\t\n254\t      const call = mockQuery.mock.calls[0][0];\n255\t      expect(call.options.resume).toBe('sess-resume-789');\n256\t    });\n257\t  });\n258\t\n259\t  describe('error classification', () => {\n260\t    it('classifies HTTP 429 as RATE_LIMIT (AC #5)', async () => {\n261\t      expect.assertions(4);\n262\t      const sdkError = Object.assign(new Error('Rate limit exceeded'), {\n263\t        status: 429,\n264\t      });\n265\t      mockQuery.mockImplementation(() => {\n266\t        throw sdkError;\n267\t      });\n268\t\n269\t      try {\n270\t        await dispatchAgent(makeDefinition({ name: 'rate-test' }), 'Go');\n271\t      } catch (err) {\n272\t        expect(err).toBeInstanceOf(DispatchError);\n273\t        const e = err as DispatchError;\n274\t        expect(e.code).toBe('RATE_LIMIT');\n275\t        expect(e.agentName).toBe('rate-test');\n276\t        expect(e.cause).toBe(sdkError);\n277\t      }\n278\t    });\n279\t\n280\t    it('classifies \"rate limit\" in message as RATE_LIMIT (AC #5)', async () => {\n281\t      expect.assertions(2);\n282\t      mockQuery.mockImplementation(() => {\n283\t        throw new Error('You have been rate limited, please slow down');\n284\t      });\n285\t\n286\t      try {\n287\t        await dispatchAgent(makeDefinition({ name: 'rl-msg' }), 'Go');\n288\t      } catch (err) {\n289\t        const e = err as DispatchError;\n290\t        expect(e.code).toBe('RATE_LIMIT');\n291\t        expect(e.agentName).toBe('rl-msg');\n292\t      }\n293\t    });\n294\t\n295\t    it('classifies ECONNREFUSED as NETWORK (AC #6)', async () => {\n296\t      expect.assertions(2);\n297\t      mockQuery.mockImplementation(() => {\n298\t        throw Object.assign(new Error('connect ECONNREFUSED'), {\n299\t          code: 'ECONNREFUSED',\n300\t        });\n301\t      });\n302\t\n303\t      try {\n304\t        await dispatchAgent(makeDefinition({ name: 'net-test' }), 'Go');\n305\t      } catch (err) {\n306\t        const e = err as DispatchError;\n307\t        expect(e.code).toBe('NETWORK');\n308\t        expect(e.agentName).toBe('net-test');\n309\t      }\n310\t    });\n311\t\n312\t    it('classifies ETIMEDOUT as NETWORK (AC #6)', async () => {\n313\t      expect.assertions(1);\n314\t      mockQuery.mockImplementation(() => {\n315\t        throw Object.assign(new Error('request timed out'), {\n316\t          code: 'ETIMEDOUT',\n317\t        });\n318\t      });\n319\t\n320\t      try {\n321\t        await dispatchAgent(makeDefinition({ name: 'timeout-test' }), 'Go');\n322\t      } catch (err) {\n323\t        const e = err as DispatchError;\n324\t        expect(e.code).toBe('NETWORK');\n325\t      }\n326\t    });\n327\t\n328\t    it('classifies ENOTFOUND as NETWORK (AC #6)', async () => {\n329\t      expect.assertions(1);\n330\t      mockQuery.mockImplementation(() => {\n331\t        throw Object.assign(new Error('getaddrinfo ENOTFOUND'), {\n332\t          code: 'ENOTFOUND',\n333\t        });\n334\t      });\n335\t\n336\t      try {\n337\t        await dispatchAgent(makeDefinition({ name: 'dns-test' }), 'Go');\n338\t      } catch (err) {\n339\t        const e = err as DispatchError;\n340\t        expect(e.code).toBe('NETWORK');\n341\t      }\n342\t    });\n343\t\n344\t    it('classifies fetch/network message errors as NETWORK (AC #6)', async () => {\n345\t      expect.assertions(1);\n346\t      mockQuery.mockImplementation(() => {\n347\t        throw new Error('fetch failed: network error');\n348\t      });\n349\t\n350\t      try {\n351\t        await dispatchAgent(makeDefinition({ name: 'fetch-test' }), 'Go');\n352\t      } catch (err) {\n353\t        const e = err as DispatchError;\n354\t        expect(e.code).toBe('NETWORK');\n355\t      }\n356\t    });\n357\t\n358\t    it('classifies \"claude binary not found\" as SDK_INIT (AC #7)', async () => {\n359\t      expect.assertions(2);\n360\t      mockQuery.mockImplementation(() => {\n361\t        throw new Error('claude binary not found in PATH');\n362\t      });\n363\t\n364\t      try {\n365\t        await dispatchAgent(makeDefinition({ name: 'init-test' }), 'Go');\n366\t      } catch (err) {\n367\t        const e = err as DispatchError;\n368\t        expect(e.code).toBe('SDK_INIT');\n369\t        expect(e.agentName).toBe('init-test');\n370\t      }\n371\t    });\n372\t\n373\t    it('classifies SDK constructor failure as SDK_INIT (AC #7)', async () => {\n374\t      expect.assertions(1);\n375\t      mockQuery.mockImplementation(() => {\n376\t        throw new Error('SDK initialization failed: cannot initialize runtime');\n377\t      });\n378\t\n379\t      try {\n380\t        await dispatchAgent(makeDefinition({ name: 'sdk-fail' }), 'Go');\n381\t      } catch (err) {\n382\t        const e = err as DispatchError;\n383\t        expect(e.code).toBe('SDK_INIT');\n384\t      }\n385\t    });\n386\t\n387\t    it('classifies unknown errors as UNKNOWN (AC #8)', async () => {\n388\t      expect.assertions(4);\n389\t      mockQuery.mockImplementation(() => {\n390\t        throw new Error('Something completely unexpected');\n391\t      });\n392\t\n393\t      try {\n394\t        await dispatchAgent(makeDefinition({ name: 'unknown-test' }), 'Go');\n395\t      } catch (err) {\n396\t        const e = err as DispatchError;\n397\t        expect(e.code).toBe('UNKNOWN');\n398\t        expect(e.agentName).toBe('unknown-test');\n399\t        expect(e.message).toContain('Something completely unexpected');\n400\t        expect(e.cause).toBeInstanceOf(Error);\n401\t      }\n402\t    });\n403\t\n404\t    it('classifies non-Error throws as UNKNOWN (AC #8)', async () => {\n405\t      expect.assertions(2);\n406\t      mockQuery.mockImplementation(() => {\n407\t        throw 'string error'; // eslint-disable-line no-throw-literal\n408\t      });\n409\t\n410\t      try {\n411\t        await dispatchAgent(makeDefinition({ name: 'str-err' }), 'Go');\n412\t      } catch (err) {\n413\t        const e = err as DispatchError;\n414\t        expect(e.code).toBe('UNKNOWN');\n415\t        expect(e.cause).toBe('string error');\n416\t      }\n417\t    });\n418\t\n419\t    it('DispatchError has correct name and structure', () => {\n420\t      const err = new DispatchError('test msg', 'NETWORK', 'my-agent', new Error('orig'));\n421\t      expect(err.name).toBe('DispatchError');\n422\t      expect(err.message).toBe('test msg');\n423\t      expect(err.code).toBe('NETWORK');\n424\t      expect(err.agentName).toBe('my-agent');\n425\t      expect(err.cause).toBeInstanceOf(Error);\n426\t      expect(err).toBeInstanceOf(Error);\n427\t      expect(err).toBeInstanceOf(DispatchError);\n428\t    });\n429\t  });\n430\t\n431\t  describe('no child_process usage (AC #4, NFR11)', () => {\n432\t    it('agent-dispatch.ts does not import child_process', () => {\n433\t      const sourcePath = path.resolve(__dirname, '../agent-dispatch.ts');\n434\t      const source = fs.readFileSync(sourcePath, 'utf-8');\n435\t      expect(source).not.toContain('child_process');\n436\t      expect(source).not.toContain('execFileSync');\n437\t      expect(source).not.toContain('spawn');\n438\t      expect(source).not.toContain('exec(');\n439\t    });\n440\t  });\n441\t\n442\t  describe('error during stream consumption', () => {\n443\t    it('classifies errors thrown during async iteration', async () => {\n444\t      expect.assertions(2);\n445\t      async function* throwingStream() {\n446\t        yield { type: 'system', session_id: 'sess-mid', tools: [] };\n447\t        throw Object.assign(new Error('connection reset'), {\n448\t          code: 'ECONNRESET',\n449\t        });\n450\t      }\n451\t\n452\t      mockQuery.mockReturnValue(throwingStream());\n453\t\n454\t      try {\n455\t        await dispatchAgent(makeDefinition({ name: 'mid-err' }), 'Go');\n456\t      } catch (err) {\n457\t        const e = err as DispatchError;\n458\t        expect(e.code).toBe('NETWORK');\n459\t        expect(e.agentName).toBe('mid-err');\n460\t      }\n461\t    });\n462\t  });\n463\t});\n464\t"}]},"parent_tool_use_id":"toolu_01BUjCG6H8L3i8XGB6FePD7q","session_id":"45fbbef5-e9ca-4512-91b9-2760b179ad44","uuid":"4498340d-879a-49cb-8b3f-5f92de6a93c6","timestamp":"2026-04-02T19:57:54.726Z"}
