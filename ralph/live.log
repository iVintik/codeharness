{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013jyMMgHtPNkvWaWWfVX54S","type":"tool_result","content":"1\timport type { EvaluatorScore } from './workflow-state.js';\n2\t\n3\t// --- Types ---\n4\t\n5\texport type CircuitBreakerDecision =\n6\t  | { halt: false }\n7\t  | {\n8\t      halt: true;\n9\t      reason: string;\n10\t      remainingFailures: number[];\n11\t      scoreHistory: number[];\n12\t    };\n13\t\n14\t// --- Functions ---\n15\t\n16\t/**\n17\t * Evaluate whether progress is being made based on evaluator score history.\n18\t *\n19\t * Stagnation rule: halt when the `passed` count has not increased for 2+\n20\t * consecutive iterations (i.e., the most recent `passed` is not greater than\n21\t * the one before it, for at least two data points).\n22\t *\n23\t * Pure computation — no I/O, no async, no state mutation.\n24\t */\n25\texport function evaluateProgress(scores: EvaluatorScore[]): CircuitBreakerDecision {\n26\t  // Insufficient history — cannot detect stagnation\n27\t  if (scores.length < 2) {\n28\t    return { halt: false };\n29\t  }\n30\t\n31\t  const scoreHistory = scores.map((s) => s.passed);\n32\t\n33\t  // Check if the most recent passed count improved over the previous one\n34\t  const latest = scoreHistory[scoreHistory.length - 1];\n35\t  const previous = scoreHistory[scoreHistory.length - 2];\n36\t\n37\t  if (latest > previous) {\n38\t    // Progress detected — no stagnation\n39\t    return { halt: false };\n40\t  }\n41\t\n42\t  // Stagnation: passed count did not increase in the most recent iteration.\n43\t  // Build remainingFailures as placeholder indices [1..failCount].\n44\t  const latestScore = scores[scores.length - 1];\n45\t  const failCount = latestScore.total - latestScore.passed;\n46\t  const remainingFailures = Array.from({ length: failCount }, (_, i) => i + 1);\n47\t\n48\t  return {\n49\t    halt: true,\n50\t    reason: 'score-stagnation',\n51\t    remainingFailures,\n52\t    scoreHistory,\n53\t  };\n54\t}\n55\t"}]},"parent_tool_use_id":"toolu_01QYotpFMACcHiddivScxr1W","session_id":"f80ae629-5ae7-4b25-aa2b-80283cb9a6d8","uuid":"3c02a67d-96cc-47bf-98ec-7140814bc6fe","timestamp":"2026-04-03T01:32:44.235Z"}
