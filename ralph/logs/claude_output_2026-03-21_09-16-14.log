file missing', () => {\n   338→    mockExistsSync.mockReturnValue(false);\n   339→\n   340→    const { rules, warnings } = loadRules('/project');\n   341→    expect(rules.requirePinnedFrom).toBe(true);\n   342→    expect(rules.verificationTools).toEqual(['curl', 'jq']);\n   343→    expect(warnings).toContain('dockerfile-rules.md not found -- using defaults.');\n   344→  });\n   345→\n   346→  it('loadRules returns no warning when rules file exists', () => {\n   347→    mockExistsSync.mockReturnValue(true);\n   348→\n   349→    const { warnings } = loadRules('/project');\n   350→    expect(warnings).toHaveLength(0);\n   351→  });\n   352→});\n   353→\n   354→// ─── Missing Dockerfile ────────────────────────────────────────────────────\n   355→\n   356→describe('missing Dockerfile', () => {\n   357→  it('returns fail result when no Dockerfile', () => {\n   358→    mockExistsSync.mockReturnValue(false);\n   359→\n   360→    const r = validateDockerfile('/project');\n   361→    expect(r.success).toBe(false);\n   362→    if (!r.success) {\n   363→      expect(r.error).toContain('No Dockerfile found');\n   364→    }\n   365→  });\n   366→});\n   367→\n   368→// ─── Unreadable Dockerfile ──────────────────────────────────────────────────\n   369→\n   370→describe('unreadable Dockerfile', () => {\n   371→  it('returns fail result when Dockerfile cannot be read', () => {\n   372→    mockExistsSync.mockReturnValue(true);\n   373→    mockReadFileSync.mockImplementation(() => {\n   374→      throw new Error('Permission denied');\n   375→    });\n   376→\n   377→    const r = validateDockerfile('/project');\n   378→    expect(r.success).toBe(false);\n   379→    if (!r.success) {\n   380→      expect(r.error).toContain('could not be read');\n   381→    }\n   382→  });\n   383→});\n   384→\n   385→// ─── No FROM instruction ───────────────────────────────────────────────────\n   386→\n   387→describe('no FROM instruction', () => {\n   388→  it('returns fail result', () => {\n   389→    mockExistsSync.mockReturnValue(true);\n   390→    mockReadFileSync.mockReturnValue('RUN echo hello\\n');\n   391→\n   392→    const r = validateDockerfile('/project');\n   393→    expect(r.success).toBe(false);\n   394→    if (!r.success) {\n   395→      expect(r.error).toContain('no FROM instruction');\n   396→    }\n   397→  });\n   398→});\n   399→\n   400→// ─── Line numbers ──────────────────────────────────────────────────────────\n   401→\n   402→describe('line numbers', () => {\n   403→  it('includes line number for pinned FROM gap', () => {\n   404→    mockExistsSync.mockReturnValue(true);\n   405→    const df = [\n   406→      '# comment',\n   407→      'FROM node:latest',\n   408→      'RUN npm install -g codeharness',\n   409→      'RUN apt-get update && apt-get install -y curl jq && rm -rf /var/lib/apt/lists/*',\n   410→      'USER node',\n   411→    ].join('\\n');\n   412→    mockReadFileSync.mockReturnValue(df);\n   413→\n   414→    const r = validateDockerfile('/project');\n   415→    expect(r.success).toBe(true);\n   416→    if (r.success) {\n   417→      const fromGap = r.data.gaps.find(g => g.rule === 'pinned-from');\n   418→      expect(fromGap?.line).toBe(2);\n   419→    }\n   420→  });\n   421→\n   422→  it('includes line number for source copy gap', () => {\n   423→    mockExistsSync.mockReturnValue(true);\n   424→    const df = [\n   425→      'FROM node:22-slim',\n   426→      'RUN npm install -g codeharness',\n   427→      'RUN apt-get update && apt-get install -y curl jq && rm -rf /var/lib/apt/lists/*',\n   428→      'COPY src/ /app/src/',\n   429→      'USER node',\n   430→    ].join('\\n');\n   431→    mockReadFileSync.mockReturnValue(df);\n   432→\n   433→    const r = validateDockerfile('/project');\n   434→    expect(r.success).toBe(true);\n   435→    if (r.success) {\n   436→      const copyGap = r.data.gaps.find(g => g.rule === 'no-source-copy');\n   437→      expect(copyGap?.line).toBe(4);\n   438→    }\n   439→  });\n   440