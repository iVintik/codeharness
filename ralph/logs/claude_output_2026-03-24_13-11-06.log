{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LguKu3Z1LopMgYDvNYo8Ln","type":"tool_result","content":"     1→/**\n     2→ * Shared utility functions for stack providers.\n     3→ * Extracted from stack-detect.ts to avoid duplication across providers.\n     4→ */\n     5→\n     6→import { existsSync, readFileSync } from 'node:fs';\n     7→import { join } from 'node:path';\n     8→\n     9→/** Safely read and parse a JSON file. Returns null on any error. */\n    10→export function readJsonSafe(path: string): Record<string, unknown> | null {\n    11→  try {\n    12→    if (!existsSync(path)) return null;\n    13→    return JSON.parse(readFileSync(path, 'utf-8')) as Record<string, unknown>;\n    14→  } catch {\n    15→    return null;\n    16→  }\n    17→}\n    18→\n    19→/** Safely read a text file. Returns null on any error. */\n    20→export function readTextSafe(path: string): string | null {\n    21→  try {\n    22→    if (!existsSync(path)) return null;\n    23→    return readFileSync(path, 'utf-8');\n    24→  } catch {\n    25→    return null;\n    26→  }\n    27→}\n    28→\n    29→/** Collect all dependency names from a package.json object (dependencies + devDependencies). */\n    30→export function getNodeDeps(pkg: Record<string, unknown>): Set<string> {\n    31→  const deps = new Set<string>();\n    32→  for (const field of ['dependencies', 'devDependencies']) {\n    33→    const section = pkg[field] as Record<string, string> | undefined;\n    34→    if (section && typeof section === 'object') {\n    35→      for (const key of Object.keys(section)) {\n    36→        deps.add(key);\n    37→      }\n    38→    }\n    39→  }\n    40→  return deps;\n    41→}\n    42→\n    43→/**\n    44→ * Read and concatenate content from Python dependency files\n    45→ * (requirements.txt, pyproject.toml, setup.py) in a directory.\n    46→ */\n    47→export function getPythonDepsContent(dir: string): string {\n    48→  const files = ['requirements.txt', 'pyproject.toml', 'setup.py'];\n    49→  const parts: string[] = [];\n    50→  for (const file of files) {\n    51→    const content = readTextSafe(join(dir, file));\n    52→    if (content) parts.push(content);\n    53→  }\n    54→  return parts.join('\\n');\n    55→}\n    56→\n    57→/**\n    58→ * Check if a Python dependency is present in combined deps content.\n    59→ * Uses word-boundary-aware matching to avoid substring false positives\n    60→ * (e.g., \"openai\" should not match \"not-openai\" or \"myopenai\").\n    61→ */\n    62→export function hasPythonDep(content: string, dep: string): boolean {\n    63→  const escaped = dep.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n    64→  const pattern = new RegExp(`(?:^|[\\\\s\"',])${escaped}(?:[\\\\[>=<~!;\\\\s\"',]|$)`, 'm');\n    65→  return pattern.test(content);\n    66→}\n    67→"}]},"parent_tool_use_id":"toolu_01NZTEF7sbp6vDvJwtuFPV4R","session_id":"1d547185-a995-481d-9659-9279ed70f717","uuid":"b7e0b2c6-c507-4b1a-aea4-428aae10c41a","timestamp":"2026-03-24T09:15:16.625Z"}
