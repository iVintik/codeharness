{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ViVy3WbRNDDs6duuRvn1D1","type":"tool_result","content":"1\t/**\n2\t * Epic Flow Executor.\n3\t *\n4\t * Orchestrates sequential execution of epic_flow tasks (retro, merge,\n5\t * validate) when an epic completes. Delegates to existing modules for\n6\t * each step and drives epic state transitions via transitionEpicState().\n7\t *\n8\t * @see Story 19-2: Epic Flow Execution\n9\t */\n10\t\n11\timport type { SprintState } from '../types/state.js';\n12\timport type { TelemetryEntry } from './telemetry-writer.js';\n13\timport type { WorktreeManager, MergeStrategy, OnConflictCallback } from './worktree-manager.js';\n14\t\n15\timport { transitionEpicState, type EpicLifecycleStatus } from './epic-completion.js';\n16\timport { readTelemetryForEpic } from './telemetry-writer.js';\n17\timport { validateMerge } from './cross-worktree-validator.js';\n18\t\n19\t// --- Types ---\n20\t\n21\t/**\n22\t * Configuration for executing an epic flow.\n23\t */\n24\texport interface EpicFlowConfig {\n25\t  /** The epic identifier (numeric string). */\n26\t  readonly epicId: string;\n27\t  /** Ordered list of epic_flow step names from the workflow. */\n28\t  readonly epicFlow: string[];\n29\t  /** Worktree manager instance for merge operations. */\n30\t  readonly worktreeManager: WorktreeManager;\n31\t  /** Strategy for merging the epic branch. */\n32\t  readonly mergeStrategy: MergeStrategy;\n33\t  /** Command to run for test validation. */\n34\t  readonly testCommand: string;\n35\t  /** Project root directory. */\n36\t  readonly projectDir: string;\n37\t  /** Current sprint state (immutable — each transition produces a new state). */\n38\t  readonly initialState: SprintState;\n39\t  /** Optional callback for conflict resolution during merge. */\n40\t  readonly onConflict?: OnConflictCallback;\n41\t  /** Optional callback to dispatch the analyst agent for retro. */\n42\t  readonly dispatchRetro?: (epicId: string, telemetry: TelemetryEntry[]) => Promise<void>;\n43\t  /** Optional callback invoked on each state transition. */\n44\t  readonly onStateChange?: (state: SprintState) => void;\n45\t}\n46\t\n47\t/**\n48\t * Result of a single epic_flow step.\n49\t */\n50\texport interface EpicFlowStepResult {\n51\t  /** Step name. */\n52\t  readonly step: string;\n53\t  /** Whether the step succeeded. */\n54\t  readonly success: boolean;\n55\t  /** Wall-clock duration in milliseconds. */\n56\t  readonly durationMs: number;\n57\t  /** Error message if the step failed. */\n58\t  readonly error?: string;\n59\t}\n60\t\n61\t/**\n62\t * Result of executing the full epic flow.\n63\t */\n64\texport interface EpicFlowResult {\n65\t  /** Whether all steps completed successfully. */\n66\t  readonly success: boolean;\n67\t  /** The epic identifier. */\n68\t  readonly epicId: string;\n69\t  /** Names of steps that completed successfully. */\n70\t  readonly stepsCompleted: string[];\n71\t  /** Detailed results for each attempted step. */\n72\t  readonly stepResults: EpicFlowStepResult[];\n73\t  /** Name of the step that failed, or null if all succeeded. */\n74\t  readonly failedStep: string | null;\n75\t  /** Error message from the failed step, or null. */\n76\t  readonly error: string | null;\n77\t  /** Total wall-clock duration in milliseconds. */\n78\t  readonly durationMs: number;\n79\t}\n80\t\n81\t// --- Error ---\n82\t\n83\t/**\n84\t * Error thrown by epic flow step execution.\n85\t */\n86\texport class EpicFlowError extends Error {\n87\t  constructor(message: string) {\n88\t    super(message);\n89\t    this.name = 'EpicFlowError';\n90\t  }\n91\t}\n92\t\n93\t// --- Step-to-State Mapping ---\n94\t\n95\t/**\n96\t * Maps built-in epic_flow step names to the epic state they transition to\n97\t * BEFORE the step executes.\n98\t */\n99\tconst STEP_STATE_MAP: Record<string, EpicLifecycleStatus> = {\n100\t  'merge': 'merging',\n101\t  'validate': 'validating',\n102\t};\n103\t\n104\t/**\n105\t * Transition sequence for an empty epicFlow.\n106\t * The state machine requires completing → merging → validating → done;\n107\t * we cannot skip directly from completing to done.\n108\t */\n109\tconst EMPTY_FLOW_TRANSITIONS: EpicLifecycleStatus[] = ['merging', 'validating', 'done'];\n110\t\n111\t// --- Step Execution ---\n112\t\n113\t/**\n114\t * Execute a single epic_flow step.\n115\t * Throws EpicFlowError on failure.\n116\t */\n117\tasync function executeStep(step: string, config: EpicFlowConfig): Promise<void> {\n118\t  switch (step) {\n119\t    case 'retro': {\n120\t      const telemetry = readTelemetryForEpic(config.epicId, config.projectDir);\n121\t      if (config.dispatchRetro) {\n122\t        await config.dispatchRetro(config.epicId, telemetry);\n123\t      }\n124\t      return;\n125\t    }\n126\t    case 'merge': {\n127\t      const result = await config.worktreeManager.mergeWorktree(\n128\t        config.epicId,\n129\t        config.mergeStrategy,\n130\t        config.testCommand,\n131\t        config.onConflict,\n132\t      );\n133\t      if (!result.success) {\n134\t        throw new EpicFlowError(`Merge failed: ${result.reason ?? 'unknown'}`);\n135\t      }\n136\t      return;\n137\t    }\n138\t    case 'validate': {\n139\t      const result = await validateMerge({\n140\t        testCommand: config.testCommand,\n141\t        cwd: config.projectDir,\n142\t        epicId: config.epicId,\n143\t        writeTelemetry: true,\n144\t      });\n145\t      if (!result.valid) {\n146\t        throw new EpicFlowError(`Validation failed: ${result.testResults.failed} test(s) failed`);\n147\t      }\n148\t      return;\n149\t    }\n150\t    default:\n151\t      throw new EpicFlowError(`Unknown epic_flow step: \"${step}\"`);\n152\t  }\n153\t}\n154\t\n155\t// --- Orchestrator ---\n156\t\n157\t/**\n158\t * Execute epic_flow tasks in strict sequence.\n159\t *\n160\t * Transitions epic state at each step boundary:\n161\t * - Before `merge`: completing → merging\n162\t * - Before `validate`: merging → validating\n163\t * - After all steps: → done\n164\t * - On failure: → failed\n165\t *\n166\t * @param config  Epic flow configuration including steps, managers, and callbacks.\n167\t * @returns Comprehensive result describing each step outcome.\n168\t */\n169\texport async function executeEpicFlow(config: EpicFlowConfig): Promise<EpicFlowResult> {\n170\t  const start = Date.now();\n171\t  let state = config.initialState;\n172\t  const stepResults: EpicFlowStepResult[] = [];\n173\t  const stepsCompleted: string[] = [];\n174\t\n175\t  // Empty flow — fast-path through the state machine to reach 'done'.\n176\t  // The state machine requires completing → merging → validating → done,\n177\t  // so we transition through each intermediate state.\n178\t  if (config.epicFlow.length === 0) {\n179\t    for (const intermediateStatus of EMPTY_FLOW_TRANSITIONS) {\n180\t      state = transitionEpicState(state, config.epicId, intermediateStatus);\n181\t      config.onStateChange?.(state);\n182\t    }\n183\t    return {\n184\t      success: true,\n185\t      epicId: config.epicId,\n186\t      stepsCompleted: [],\n187\t      stepResults: [],\n188\t      failedStep: null,\n189\t      error: null,\n190\t      durationMs: Date.now() - start,\n191\t    };\n192\t  }\n193\t\n194\t  for (const step of config.epicFlow) {\n195\t    const stepStart = Date.now();\n196\t\n197\t    // Transition epic state before built-in steps\n198\t    const preTransition = STEP_STATE_MAP[step];\n199\t    if (preTransition) {\n200\t      state = transitionEpicState(state, config.epicId, preTransition);\n201\t      config.onStateChange?.(state);\n202\t    }\n203\t\n204\t    try {\n205\t      await executeStep(step, config);\n206\t      const stepResult: EpicFlowStepResult = {\n207\t        step,\n208\t        success: true,\n209\t        durationMs: Date.now() - stepStart,\n210\t      };\n211\t      stepResults.push(stepResult);\n212\t      stepsCompleted.push(step);\n213\t    } catch (err: unknown) {\n214\t      const errorMessage = err instanceof Error ? err.message : String(err);\n215\t      const stepResult: EpicFlowStepResult = {\n216\t        step,\n217\t        success: false,\n218\t        durationMs: Date.now() - stepStart,\n219\t        error: errorMessage,\n220\t      };\n221\t      stepResults.push(stepResult);\n222\t\n223\t      // Transition to failed\n224\t      state = transitionEpicState(state, config.epicId, 'failed');\n225\t      config.onStateChange?.(state);\n226\t\n227\t      return {\n228\t        success: false,\n229\t        epicId: config.epicId,\n230\t        stepsCompleted,\n231\t        stepResults,\n232\t        failedStep: step,\n233\t        error: errorMessage,\n234\t        durationMs: Date.now() - start,\n235\t      };\n236\t    }\n237\t  }\n238\t\n239\t  // All steps succeeded — transition to done\n240\t  state = transitionEpicState(state, config.epicId, 'done');\n241\t  config.onStateChange?.(state);\n242\t\n243\t  return {\n244\t    success: true,\n245\t    epicId: config.epicId,\n246\t    stepsCompleted,\n247\t    stepResults,\n248\t    failedStep: null,\n249\t    error: null,\n250\t    durationMs: Date.now() - start,\n251\t  };\n252\t}\n253\t"}]},"parent_tool_use_id":"toolu_01MiUpnYRUgdVNHMSKLiPCKP","session_id":"d383a9e0-3bc4-4a94-aaff-6965a5cc223b","uuid":"805fd63b-908e-444d-b8d0-ef9d6e8343ac","timestamp":"2026-04-03T23:36:52.122Z"}
