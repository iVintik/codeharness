{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LiDNTi8cJfuNZQPbZj89WW","type":"tool_result","content":"     1→/**\n     2→ * Public API for the agents subsystem.\n     3→ *\n     4→ * Re-exports types (story 13-1), RalphDriver implementation (story 13-2),\n     5→ * stream parser functions/types, and ralph prompt functions/types.\n     6→ */\n     7→\n     8→// Types\n     9→export type {\n    10→  SpawnOpts,\n    11→  AgentProcess,\n    12→  AgentEvent,\n    13→  AgentDriver,\n    14→} from './types.js';\n    15→\n    16→// RalphDriver\n    17→export { RalphDriver } from './ralph.js';\n    18→export { buildSpawnArgs, resolveRalphPath, parseRalphMessage, parseIterationMessage } from './ralph.js';\n    19→\n    20→// Stream parser\n    21→export { parseStreamLine } from './stream-parser.js';\n    22→export type {\n    23→  StreamEvent,\n    24→  ToolStartEvent,\n    25→  ToolInputEvent,\n    26→  ToolCompleteEvent,\n    27→  TextEvent,\n    28→  RetryEvent,\n    29→  ResultEvent,\n    30→} from './stream-parser.js';\n    31→\n    32→// Ralph prompt\n    33→export { generateRalphPrompt } from './ralph-prompt.js';\n    34→export type { RalphPromptConfig } from './ralph-prompt.js';\n    35→"}]},"parent_tool_use_id":"toolu_01RmTRSciNZ4m4Rj6YrMRu8q","session_id":"110312c9-09eb-45d4-bc39-1124b22b5753","uuid":"06b5b5a1-b4a9-4695-85ae-63fbbffd0f75","timestamp":"2026-03-24T16:06:18.997Z"}
