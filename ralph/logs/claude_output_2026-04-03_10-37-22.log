{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01R24mWp1XypPnYfFy6QLhyt","type":"tool_result","content":"1\t/**\n2\t * Public API for the agents subsystem.\n3\t *\n4\t * Re-exports types (story 13-1), stream parser functions/types,\n5\t * and the getDriver() factory (story 13-3).\n6\t *\n7\t * Ralph driver and prompt removed in Story 1.2 — will be replaced\n8\t * by workflow engine in Epic 5.\n9\t */\n10\t\n11\timport type { AgentDriver } from './types.js';\n12\t\n13\t// New types (Epic 10)\n14\texport type {\n15\t  AgentDriver,\n16\t  DriverHealth,\n17\t  DriverCapabilities,\n18\t  DispatchOpts,\n19\t  ErrorCategory,\n20\t  OutputContract,\n21\t  TestResults,\n22\t  ACStatus,\n23\t} from './types.js';\n24\t\n25\t// Deprecated types — kept for backward compatibility until story 10-3\n26\t/** @deprecated Use `DispatchOpts` instead. */\n27\texport type { SpawnOpts } from './types.js';\n28\t/** @deprecated Use `AsyncIterable<StreamEvent>` from `dispatch()` instead. */\n29\texport type { AgentProcess } from './types.js';\n30\t/** @deprecated Use `StreamEvent` from `stream-parser.ts` instead. */\n31\texport type { AgentEvent } from './types.js';\n32\t\n33\t// Stream parser\n34\texport { parseStreamLine } from './stream-parser.js';\n35\texport type {\n36\t  StreamEvent,\n37\t  ToolStartEvent,\n38\t  ToolInputEvent,\n39\t  ToolCompleteEvent,\n40\t  TextEvent,\n41\t  RetryEvent,\n42\t  ResultEvent,\n43\t} from './stream-parser.js';\n44\t\n45\t// --- Driver Factory ---\n46\t\n47\t// TODO: v2 workflow-engine (Epic 5) — rebuild getDriver with workflow-based driver\n48\t/**\n49\t * Returns an AgentDriver instance by name.\n50\t * Throws for all driver names — Ralph removed, workflow engine pending (Epic 5).\n51\t */\n52\texport function getDriver(name?: string, _config?: unknown): AgentDriver {\n53\t  const driverName = name ?? 'default';\n54\t  throw new Error(`No agent drivers available (requested: ${driverName}). Workflow engine pending (Epic 5).`);\n55\t}\n56\t"}]},"parent_tool_use_id":"toolu_01TCd6uEz5D6YETUWqShfUU7","session_id":"61d40628-eabe-45b5-b544-2f5989944a22","uuid":"d8f3bfba-5624-44cf-b8c3-f18f3bb87217","timestamp":"2026-04-03T06:41:57.925Z"}
