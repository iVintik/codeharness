Dir);\n    51→    expect(typeof name).toBe('string');\n    52→    expect(name.length).toBeGreaterThan(0);\n    53→  });\n    54→\n    55→  it('falls back to basename when package.json has no name', () => {\n    56→    writeFileSync(join(testDir, 'package.json'), '{}');\n    57→    const name = getProjectName(testDir);\n    58→    expect(typeof name).toBe('string');\n    59→  });\n    60→});\n    61→\n    62→describe('getStackLabel', () => {\n    63→  it('returns Node.js label for nodejs stack', () => {\n    64→    expect(getStackLabel('nodejs')).toBe('Node.js (package.json)');\n    65→  });\n    66→\n    67→  it('returns Python label for python stack', () => {\n    68→    expect(getStackLabel('python')).toBe('Python');\n    69→  });\n    70→\n    71→  it('returns Unknown for null stack', () => {\n    72→    expect(getStackLabel(null)).toBe('Unknown');\n    73→  });\n    74→});\n    75→\n    76→describe('getCoverageTool', () => {\n    77→  it('returns c8 for nodejs', () => {\n    78→    expect(getCoverageTool('nodejs')).toBe('c8');\n    79→  });\n    80→\n    81→  it('returns coverage.py for python', () => {\n    82→    expect(getCoverageTool('python')).toBe('coverage.py');\n    83→  });\n    84→\n    85→  it('returns c8 for null', () => {\n    86→    expect(getCoverageTool(null)).toBe('c8');\n    87→  });\n    88→\n    89→  it('returns cargo-tarpaulin for rust', () => {\n    90→    expect(getCoverageTool('rust')).toBe('cargo-tarpaulin');\n    91→  });\n    92→});\n    93→\n    94→describe('generateAgentsMdContent', () => {\n    95→  it('includes project name', () => {\n    96→    const content = generateAgentsMdContent(testDir, 'nodejs');\n    97→    expect(content).toContain('# ');\n    98→  });\n    99→\n   100→  it('includes Node.js commands for nodejs stack', () => {\n   101→    const content = generateAgentsMdContent(testDir, 'nodejs');\n   102→    expect(content).toContain('npm install');\n   103→    expect(content).toContain('npm test');\n   104→  });\n   105→\n   106→  it('includes Python commands for python stack', () => {\n   107→    const content = generateAgentsMdContent(testDir, 'python');\n   108→    expect(content).toContain('pip install');\n   109→    expect(content).toContain('pytest');\n   110→  });\n   111→\n   112→  it('includes generic message for unknown stack', () => {\n   113→    const content = generateAgentsMdContent(testDir, null);\n   114→    expect(content).toContain('No recognized stack');\n   115→  });\n   116→});\n   117→\n   118→describe('generateDocsIndexContent', () => {\n   119→  it('includes documentation sections', () => {\n   120→    const content = generateDocsIndexContent();\n   121→    expect(content).toContain('Planning Artifacts');\n   122→    expect(content).toContain('Execution');\n   123→    expect(content).toContain('Quality');\n   124→  });\n   125→});\n   126→\n   127→describe('scaffoldDocs', () => {\n   128→  it('creates AGENTS.md when it does not exist', async () => {\n   129→    const result = await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: false });\n   130→    expect(result.success).toBe(true);\n   131→    if (result.success) {\n   132→      expect(result.data.agents_md).toBe('created');\n   133→    }\n   134→  });\n   135→\n   136→  it('reports exists when AGENTS.md already exists', async () => {\n   137→    writeFileSync(join(testDir, 'AGENTS.md'), '# existing');\n   138→    const result = await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: false });\n   139→    expect(result.success).toBe(true);\n   140→    if (result.success) {\n   141→      expect(result.data.agents_md).toBe('exists');\n   142→    }\n   143→  });\n   144→\n   145→  it('creates docs scaffold when docs/ does not exist', async () => {\n   146→    const result = await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: false });\n   147→    expect(result.success).toBe(true);\n   148→    if (result.success) {\n   149→      expect(result.data.docs_scaffold).toBe('created');\n   150→    }\n   151→  });\n   152→\n   153→  it('creates README.md when it does not exist', async () => {\n   154→    const result = await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: false });\n   155→    expect(result.success).toBe(true);\n   156→    if (result.success) {\n   157→      expect(result.data.readme).toBe('created');\n   158→    }\n   159→  });\n   160→\n   161→  it('reports exists when README.md already exists', async () => {\n   162→    writeFileSync(join(testDir, 'README.md'), '# existing');\n   163→    const result = await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: false });\n   164→    expect(result.success).toBe(true);\n   165→    if (result.success) {\n   166→      expect(result.data.readme).toBe('exists');\n   167→    }\n   168→  });\n   169→\n   170→  it('suppresses console output in json mode', async () => {\n   171→    const spy = vi.spyOn(console, 'log');\n   172→    await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: true });\n   173→    // In json mode, no [OK]/[INFO] messages should be printed\n   174→    const calls = spy.mock.calls.map(c => c[0] as string);\n   175→    const outputCalls = calls.filter(c => c && (c.startsWith('[OK]') || c.startsWith('[INFO]')));\n   176→    expect(outputCalls).toHaveLength(0);\n   177→  });\n   178→});\n   179→"}]},"parent_tool_use_id":"toolu_01CGkWizVB7CtGCqwFm5rfNr","session_id":"6b184f1a-3a3f-4307-8da0-d8cf52066851","uuid":"f8f0602a-63ec-4a86-80c5-ec35ed4987cd","timestamp":"2026-03-23T05:23:05.113Z"}
