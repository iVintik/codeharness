{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DwRJsMj9QdDDznLptyRKP6","type":"tool_result","content":"     1→/**\n     2→ * Shared utility functions for stack providers.\n     3→ * Extracted from stack-detect.ts to avoid duplication across providers.\n     4→ */\n     5→\n     6→import { existsSync, readFileSync } from 'node:fs';\n     7→import { join } from 'node:path';\n     8→\n     9→/** Safely read and parse a JSON file. Returns null on any error. */\n    10→export function readJsonSafe(path: string): Record<string, unknown> | null {\n    11→  try {\n    12→    if (!existsSync(path)) return null;\n    13→    return JSON.parse(readFileSync(path, 'utf-8')) as Record<string, unknown>;\n    14→  } catch {\n    15→    // IGNORE: JSON file may be malformed\n    16→    return null;\n    17→  }\n    18→}\n    19→\n    20→/** Safely read a text file. Returns null on any error. */\n    21→export function readTextSafe(path: string): string | null {\n    22→  try {\n    23→    if (!existsSync(path)) return null;\n    24→    return readFileSync(path, 'utf-8');\n    25→  } catch {\n    26→    // IGNORE: file may be unreadable\n    27→    return null;\n    28→  }\n    29→}\n    30→\n    31→/** Collect all dependency names from a package.json object (dependencies + devDependencies). */\n    32→export function getNodeDeps(pkg: Record<string, unknown>): Set<string> {\n    33→  const deps = new Set<string>();\n    34→  for (const field of ['dependencies', 'devDependencies']) {\n    35→    const section = pkg[field] as Record<string, string> | undefined;\n    36→    if (section && typeof section === 'object') {\n    37→      for (const key of Object.keys(section)) {\n    38→        deps.add(key);\n    39→      }\n    40→    }\n    41→  }\n    42→  return deps;\n    43→}\n    44→\n    45→/**\n    46→ * Read and concatenate content from Python dependency files\n    47→ * (requirements.txt, pyproject.toml, setup.py) in a directory.\n    48→ */\n    49→export function getPythonDepsContent(dir: string): string {\n    50→  const files = ['requirements.txt', 'pyproject.toml', 'setup.py'];\n    51→  const parts: string[] = [];\n    52→  for (const file of files) {\n    53→    const content = readTextSafe(join(dir, file));\n    54→    if (content) parts.push(content);\n    55→  }\n    56→  return parts.join('\\n');\n    57→}\n    58→\n    59→/**\n    60→ * Check if a Python dependency is present in combined deps content."}]},"parent_tool_use_id":"toolu_01A5VRSCWrKG5o81CvpB3aWg","session_id":"83e99bf1-19ed-4459-85db-f9346f9425ec","uuid":"8b7a7d92-37d3-4cb8-91d7-8d221054b7c2","timestamp":"2026-03-27T09:34:11.944Z"}
