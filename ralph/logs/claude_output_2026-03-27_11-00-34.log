pect(result.data.dependencies).toBeDefined();\n   223→      expect(result.data.dependencies!.length).toBeGreaterThan(0);\n   224→    }\n   225→  });\n   226→});\n   227→\n   228→describe('initProject — idempotent re-run', () => {\n   229→  it('detects already initialized and returns early', async () => {\n   230→    writeFileSync(join(testDir, 'package.json'), '{}');\n   231→    // First init\n   232→    await initProject({\n   233→      projectDir: testDir,\n   234→      frontend: true,\n   235→      database: true,\n   236→      api: true,\n   237→      observability: false,\n   238→    });\n   239→    // Second init (re-run)\n   240→    const result = await initProject({\n   241→      projectDir: testDir,\n   242→      frontend: true,\n   243→      database: true,\n   244→      api: true,\n   245→      observability: false,\n   246→    });\n   247→    expect(result.success).toBe(true);\n   248→    if (result.success) {\n   249→      expect(result.data.documentation.agents_md).toBe('exists');\n   250→    }\n   251→  });\n   252→});\n   253→\n   254→describe('initProject — critical failures', () => {\n   255→  it('returns ok with fail status when Docker missing and observability on', async () => {\n   256→    writeFileSync(join(testDir, 'package.json'), '{}');\n   257→    mockIsDockerAvailable.mockReturnValue(false);\n   258→    const result = await initProject({\n   259→      projectDir: testDir,\n   260→      frontend: true,\n   261→      database: true,\n   262→      api: true,\n   263→      observability: true,\n   264→    });\n   265→    expect(result.success).toBe(true);\n   266→    if (result.success) {\n   267→      expect(result.data.status).toBe('fail');\n   268→      expect(result.data.error).toBe('Docker not installed');\n   269→    }\n   270→    expect(process.exitCode).toBe(1);\n   271→  });\n   272→\n   273→  it('returns ok with fail status on critical dep failure', async () => {\n   274→    writeFileSync(join(testDir, 'package.json'), '{}');\n   275