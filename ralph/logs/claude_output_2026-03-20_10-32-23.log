{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XaTNSFNa25sYCCFjjxsGMo","type":"tool_result","content":"     1→/**\n     2→ * Observability analyzer module — public API.\n     3→ *\n     4→ * All consumers should import from this barrel file only.\n     5→ * Internal implementation details are not re-exported.\n     6→ */\n     7→\n     8→export type {\n     9→  AnalyzerResult,\n    10→  AnalyzerConfig,\n    11→  AnalyzerSummary,\n    12→  ObservabilityGap,\n    13→  GapSeverity,\n    14→  ObservabilityCoverageState,\n    15→  CoverageHistoryEntry,\n    16→  StaticCoverageState,\n    17→  CoverageTargets,\n    18→  CoverageTrend,\n    19→  CoverageTargetResult,\n    20→  ObservabilityCoverageGateResult,\n    21→  RuntimeCoverageEntry,\n    22→  RuntimeCoverageResult,\n    23→  RuntimeCoverageState,\n    24→  RuntimeValidationConfig,\n    25→  ModuleTelemetryEntry,\n    26→  RuntimeValidationResult,\n    27→  TelemetryEvent,\n    28→} from './types.js';\n    29→\n    30→export { analyze } from './analyzer.js';\n    31→\n    32→export {\n    33→  saveCoverageResult,\n    34→  readCoverageState,\n    35→  getCoverageTrend,\n    36→  checkCoverageTarget,\n    37→} from './coverage.js';\n    38→\n    39→export {\n    40→  computeRuntimeCoverage,\n    41→  saveRuntimeCoverage,\n    42→} from './runtime-coverage.js';\n    43→\n    44→export { checkObservabilityCoverageGate } from './coverage-gate.js';\n    45→\n    46→export {\n    47→  validateRuntime,\n    48→  checkBackendHealth,\n    49→  queryTelemetryEvents,\n    50→  mapEventsToModules,\n    51→} from './runtime-validator.js';\n    52→"}]},"parent_tool_use_id":"toolu_01X8HPzdvjqKbRcjmtsWDTRD","session_id":"c5eaf6a6-ac7c-4707-b82c-6220d711aa9c","uuid":"df9262dd-6291-4c66-936e-1eb5aa1c81f2","timestamp":"2026-03-20T06:44:47.731Z"}
