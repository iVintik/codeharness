{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YTPupTz6ZpB4TLC4k5bQAN","type":"tool_result","content":"1\t/**\n2\t * LaneContainer — Ink component that manages multi-lane layout.\n3\t *\n4\t * Renders lanes side-by-side, stacked, or single depending on terminal width.\n5\t * Lanes 3+ collapse to one-line summaries. Pure presentational component.\n6\t *\n7\t * @see Story 20.1: Lane Container & Lane Components\n8\t */\n9\t\n10\timport React from 'react';\n11\timport { Text, Box } from 'ink';\n12\timport { Lane, formatLaneCost, formatLaneElapsed } from './ink-lane.js';\n13\timport type { StoryProgressEntry } from './ink-lane.js';\n14\t\n15\t// --- Types ---\n16\t\n17\texport type LayoutMode = 'side-by-side' | 'stacked' | 'single';\n18\t\n19\texport interface LaneData {\n20\t  /** Epic identifier. */\n21\t  epicId: string;\n22\t  /** Human-readable epic title. */\n23\t  epicTitle: string;\n24\t  /** Current story key. */\n25\t  currentStory: string | null;\n26\t  /** Current phase. */\n27\t  phase: string | null;\n28\t  /** AC progress (e.g., \"4/9\"). */\n29\t  acProgress: string | null;\n30\t  /** Story progress entries. */\n31\t  storyProgressEntries: StoryProgressEntry[];\n32\t  /** Driver name. */\n33\t  driver: string | null;\n34\t  /** Cost in USD. */\n35\t  cost: number | null;\n36\t  /** Elapsed time in ms. */\n37\t  elapsedTime: number | null;\n38\t  /** Timestamp of last activity (ISO 8601 or epoch ms). */\n39\t  lastActivityTime?: number;\n40\t}\n41\t\n42\texport interface LaneContainerProps {\n43\t  /** All active lanes to render. */\n44\t  lanes: LaneData[];\n45\t  /** Current terminal width in columns. */\n46\t  terminalWidth: number;\n47\t}\n48\t\n49\texport interface CollapsedLaneData {\n50\t  /** Lane index (1-based for display). */\n51\t  laneIndex: number;\n52\t  /** Epic title. */\n53\t  epicTitle: string;\n54\t  /** Current story key. */\n55\t  currentStory: string | null;\n56\t  /** Current phase. */\n57\t  phase: string | null;\n58\t  /** Cost in USD. */\n59\t  cost: number | null;\n60\t  /** Elapsed time in ms. */\n61\t  elapsedTime: number | null;\n62\t}\n63\t\n64\t// --- Helpers ---\n65\t\n66\t/** Determine layout mode from terminal width. */\n67\texport function getLayoutMode(terminalWidth: number): LayoutMode {\n68\t  if (terminalWidth >= 120) return 'side-by-side';\n69\t  if (terminalWidth >= 80) return 'stacked';\n70\t  return 'single';\n71\t}\n72\t\n73\t/** Truncate a string to fit within maxLen, adding ellipsis if needed. */\n74\tfunction truncate(str: string, maxLen: number): string {\n75\t  if (maxLen < 4) return str.slice(0, maxLen);\n76\t  if (str.length <= maxLen) return str;\n77\t  return str.slice(0, maxLen - 1) + '\\u2026';\n78\t}\n79\t\n80\t// --- Sub-components ---\n81\t\n82\t/** Renders collapsed lane summaries as single lines. */\n83\texport function CollapsedLanes({ lanes }: { lanes: CollapsedLaneData[] }) {\n84\t  if (lanes.length === 0) return null;\n85\t\n86\t  return (\n87\t    <Box flexDirection=\"column\">\n88\t      {lanes.map((lane) => {\n89\t        const storyPart = lane.currentStory ?? '--';\n90\t        const phasePart = lane.phase ?? '--';\n91\t        const costPart = formatLaneCost(lane.cost);\n92\t        const timePart = formatLaneElapsed(lane.elapsedTime);\n93\t        const line = `Lane ${lane.laneIndex}: ${lane.epicTitle} \\u2502 ${storyPart} \\u25C6 ${phasePart} \\u2502 ${costPart} / ${timePart}`;\n94\t\n95\t        return (\n96\t          <Text key={`collapsed-${lane.laneIndex}`} dimColor>{line}</Text>\n97\t        );\n98\t      })}\n99\t    </Box>\n100\t  );\n101\t}\n102\t\n103\t/** Multi-lane layout manager. */\n104\texport function LaneContainer({ lanes, terminalWidth }: LaneContainerProps) {\n105\t  if (lanes.length === 0) return null;\n106\t\n107\t  const mode = getLayoutMode(terminalWidth);\n108\t\n109\t  // Determine which lanes are full vs collapsed\n110\t  // In single mode: only most recently active lane is full, rest collapsed\n111\t  // In side-by-side/stacked: first 2 full, rest collapsed\n112\t  let fullLanes: LaneData[];\n113\t  let collapsedLaneData: CollapsedLaneData[];\n114\t\n115\t  if (mode === 'single') {\n116\t    // Find most recently active lane\n117\t    let mostRecentIndex = 0;\n118\t    let mostRecentTime = -Infinity;\n119\t    for (let i = 0; i < lanes.length; i++) {\n120\t      const t = lanes[i].lastActivityTime ?? 0;\n121\t      if (t >= mostRecentTime) {\n122\t        mostRecentTime = t;\n123\t        mostRecentIndex = i;\n124\t      }\n125\t    }\n126\t    fullLanes = [lanes[mostRecentIndex]];\n127\t    collapsedLaneData = lanes\n128\t      .filter((_, i) => i !== mostRecentIndex)\n129\t      .map((lane, i) => {\n130\t        // Calculate original 1-based index\n131\t        const originalIndex = i >= mostRecentIndex ? i + 2 : i + 1;\n132\t        return {\n133\t          laneIndex: originalIndex,\n134\t          epicTitle: truncate(lane.epicTitle, 30),\n135\t          currentStory: lane.currentStory,\n136\t          phase: lane.phase,\n137\t          cost: lane.cost,\n138\t          elapsedTime: lane.elapsedTime,\n139\t        };\n140\t      });\n141\t  } else {\n142\t    // Side-by-side or stacked: first 2 full, rest collapsed\n143\t    fullLanes = lanes.slice(0, 2);\n144\t    collapsedLaneData = lanes.slice(2).map((lane, i) => ({\n145\t      laneIndex: i + 3,\n146\t      epicTitle: truncate(lane.epicTitle, 30),\n147\t      currentStory: lane.currentStory,\n148\t      phase: lane.phase,\n149\t      cost: lane.cost,\n150\t      elapsedTime: lane.elapsedTime,\n151\t    }));\n152\t  }\n153\t\n154\t  // Render full lanes\n155\t  const laneWidth = mode === 'side-by-side'\n156\t    ? Math.floor(terminalWidth / 2) - 1\n157\t    : terminalWidth;\n158\t\n159\t  const fullLaneElements: React.ReactNode[] = [];\n160\t  for (let i = 0; i < fullLanes.length; i++) {\n161\t    const lane = fullLanes[i];\n162\t    const laneIndex = mode === 'single' ? undefined : i + 1;\n163\t    // Add a thin separator between stacked/single full lanes (not in side-by-side)\n164\t    if (i > 0 && mode !== 'side-by-side') {\n165\t      fullLaneElements.push(<Text key={`sep-${i}`} dimColor>{'─'.repeat(Math.min(terminalWidth, 60))}</Text>);\n166\t    }\n167\t    fullLaneElements.push(\n168\t      <Box key={`lane-${lane.epicId}`} width={mode === 'side-by-side' ? laneWidth : undefined} flexDirection=\"column\">\n169\t        <Lane\n170\t          epicId={lane.epicId}\n171\t          epicTitle={lane.epicTitle}\n172\t          currentStory={lane.currentStory}\n173\t          phase={lane.phase}\n174\t          acProgress={lane.acProgress}\n175\t          storyProgressEntries={lane.storyProgressEntries}\n176\t          driver={lane.driver}\n177\t          cost={lane.cost}\n178\t          elapsedTime={lane.elapsedTime}\n179\t          laneIndex={laneIndex}\n180\t        />\n181\t      </Box>\n182\t    );\n183\t  }\n184\t\n185\t  return (\n186\t    <Box flexDirection=\"column\">\n187\t      {mode === 'side-by-side' ? (\n188\t        <Box flexDirection=\"row\">\n189\t          {fullLaneElements}\n190\t        </Box>\n191\t      ) : (\n192\t        <Box flexDirection=\"column\">\n193\t          {fullLaneElements}\n194\t        </Box>\n195\t      )}\n196\t      <CollapsedLanes lanes={collapsedLaneData} />\n197\t    </Box>\n198\t  );\n199\t}\n200\t"}]},"parent_tool_use_id":"toolu_01Lyf5tpvBU7eZNwMupgDFgG","session_id":"7e3ded59-6184-4f8b-8f55-ba5e63dae51f","uuid":"18a55a66-d943-4262-9b78-5f3e0aa6bf9a","timestamp":"2026-04-04T02:45:48.012Z"}
