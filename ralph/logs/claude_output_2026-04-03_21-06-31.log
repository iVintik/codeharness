{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01E6NCwsc9AaP2JUS5Na26Hv","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { join } from 'node:path';\n3\timport { parse } from 'yaml';\n4\timport { warn } from './output.js';\n5\timport { DispatchError } from './agent-dispatch.js';\n6\timport type { DispatchErrorCode } from './agent-dispatch.js';\n7\t// Note: dispatchAgent is no longer imported — dispatch goes through the driver factory\n8\timport { getDriver } from './agents/drivers/factory.js';\n9\timport { checkCapabilityConflicts } from './agents/capability-check.js';\n10\timport { resolveModel } from './agents/model-resolver.js';\n11\timport type { DispatchOpts, DriverHealth, OutputContract } from './agents/types.js';\n12\timport type { ResultEvent, ToolStartEvent } from './agents/stream-parser.js';\n13\timport type { SubagentDefinition } from './agent-resolver.js';\n14\timport type { ResolvedWorkflow, ResolvedTask, FlowStep, LoopBlock } from './workflow-parser.js';\n15\timport {\n16\t  readWorkflowState,\n17\t  writeWorkflowState,\n18\t} from './workflow-state.js';\n19\timport { buildPromptWithContractContext, writeOutputContract } from './agents/output-contract.js';\n20\timport type { WorkflowState, TaskCheckpoint } from './workflow-state.js';\n21\timport { createIsolatedWorkspace } from './source-isolation.js';\n22\timport { generateTraceId, formatTracePrompt, recordTraceId } from './trace-id.js';\n23\timport { resolveSessionId, recordSessionId } from './session-manager.js';\n24\timport type { SessionLookupKey } from './session-manager.js';\n25\timport { parseVerdict, VerdictParseError } from './verdict-parser.js';\n26\timport type { EvaluatorVerdict } from './verdict-parser.js';\n27\timport { evaluateProgress } from './circuit-breaker.js';\n28\t\n29\t// Re-export EvaluatorVerdict for downstream consumers that import from workflow-engine\n30\texport type { EvaluatorVerdict } from './verdict-parser.js';\n31\texport { parseVerdict } from './verdict-parser.js';\n32\t\n33\t// --- Interfaces ---\n34\t\n35\t/**\n36\t * Configuration for the workflow engine.\n37\t */\n38\texport interface EngineConfig {\n39\t  /** The resolved workflow with tasks and flow steps. */\n40\t  workflow: ResolvedWorkflow;\n41\t  /** Pre-compiled agent definitions keyed by agent name. */\n42\t  agents: Record<string, SubagentDefinition>;\n43\t  /** Path to sprint-status.yaml for work item discovery. */\n44\t  sprintStatusPath: string;\n45\t  /** Optional path to issues.yaml for additional work items. */\n46\t  issuesPath?: string;\n47\t  /** Unique identifier for this engine run. */\n48\t  runId: string;\n49\t  /** Project root directory. Defaults to process.cwd(). */\n50\t  projectDir?: string;\n51\t  /** Maximum loop iterations before termination. Defaults to 5. */\n52\t  maxIterations?: number;\n53\t}\n54\t\n55\t/**\n56\t * Result returned by executeWorkflow().\n57\t */\n58\texport interface EngineResult {\n59\t  /** Whether the workflow completed without errors. */\n60\t  success: boolean;\n61\t  /** Number of task dispatches completed. */\n62\t  tasksCompleted: number;\n63\t  /** Number of work items (stories/issues) processed. */\n64\t  storiesProcessed: number;\n65\t  /** Errors encountered during execution. */\n66\t  errors: EngineError[];\n67\t  /** Wall-clock duration of the entire workflow in milliseconds. */\n68\t  durationMs: number;\n69\t}\n70\t\n71\t/**\n72\t * Structured error recorded during workflow execution.\n73\t */\n74\texport interface EngineError {\n75\t  taskName: string;\n76\t  storyKey: string;\n77\t  code: string;\n78\t  message: string;\n79\t}\n80\t\n81\t/**\n82\t * A work item (story or issue) ready for execution.\n83\t */\n84\texport interface WorkItem {\n85\t  key: string;\n86\t  title?: string;\n87\t  source: 'sprint' | 'issues';\n88\t}\n89\t\n90\t// --- Constants ---\n91\t\n92\t/** Sentinel story key for per-run tasks. */\n93\texport const PER_RUN_SENTINEL = '__run__';\n94\t\n95\t/** DispatchError codes that should halt execution immediately. */\n96\tconst HALT_ERROR_CODES = new Set(['RATE_LIMIT', 'NETWORK', 'SDK_INIT']);\n97\t\n98\t/** Default maximum loop iterations before termination. */\n99\tconst DEFAULT_MAX_ITERATIONS = 5;\n100\t"}]},"parent_tool_use_id":"toolu_01E368mBox6AGS9E4aPFSS48","session_id":"8a461711-53e2-475a-88dd-c7013f6080c5","uuid":"a3677cd7-a8e4-49e3-bc57-d0e9bd995fe7","timestamp":"2026-04-03T17:12:59.094Z"}
