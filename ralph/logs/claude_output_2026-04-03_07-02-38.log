{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SYcPHyR7EYMiC9KkTC4dcy","type":"tool_result","content":"1\t{\n2\t  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n3\t  \"$id\": \"https://codeharness.dev/schemas/workflow.schema.json\",\n4\t  \"title\": \"Codeharness Workflow\",\n5\t  \"description\": \"Schema for codeharness workflow YAML files\",\n6\t  \"type\": \"object\",\n7\t  \"required\": [\"tasks\", \"flow\"],\n8\t  \"properties\": {\n9\t    \"tasks\": {\n10\t      \"type\": \"object\",\n11\t      \"description\": \"Named task definitions\",\n12\t      \"additionalProperties\": {\n13\t        \"$ref\": \"#/definitions/task\"\n14\t      }\n15\t    },\n16\t    \"flow\": {\n17\t      \"type\": \"array\",\n18\t      \"description\": \"Ordered execution steps — task references or loop blocks\",\n19\t      \"items\": {\n20\t        \"oneOf\": [\n21\t          {\n22\t            \"type\": \"string\",\n23\t            \"description\": \"Task reference by name\"\n24\t          },\n25\t          {\n26\t            \"type\": \"object\",\n27\t            \"required\": [\"loop\"],\n28\t            \"properties\": {\n29\t              \"loop\": {\n30\t                \"type\": \"array\",\n31\t                \"items\": {\n32\t                  \"type\": \"string\"\n33\t                },\n34\t                \"minItems\": 1,\n35\t                \"description\": \"Task names to repeat in a loop\"\n36\t              }\n37\t            },\n38\t            \"additionalProperties\": false,\n39\t            \"description\": \"Loop block containing task references\"\n40\t          }\n41\t        ]\n42\t      }\n43\t    }\n44\t  },\n45\t  \"additionalProperties\": false,\n46\t  \"definitions\": {\n47\t    \"task\": {\n48\t      \"type\": \"object\",\n49\t      \"required\": [\"agent\"],\n50\t      \"properties\": {\n51\t        \"agent\": {\n52\t          \"type\": \"string\",\n53\t          \"description\": \"Agent identifier for this task\"\n54\t        },\n55\t        \"scope\": {\n56\t          \"type\": \"string\",\n57\t          \"enum\": [\"per-story\", \"per-run\"],\n58\t          \"default\": \"per-story\",\n59\t          \"description\": \"Execution scope — per-story or per-run\"\n60\t        },\n61\t        \"session\": {\n62\t          \"type\": \"string\",\n63\t          \"enum\": [\"fresh\", \"continue\"],\n64\t          \"default\": \"fresh\",\n65\t          \"description\": \"Session strategy — fresh or continue\"\n66\t        },\n67\t        \"source_access\": {\n68\t          \"type\": \"boolean\",\n69\t          \"default\": true,\n70\t          \"description\": \"Whether the agent has source code access\"\n71\t        },\n72\t        \"prompt_template\": {\n73\t          \"type\": \"string\",\n74\t          \"description\": \"Prompt template with {{variable}} placeholders\"\n75\t        },\n76\t        \"input_contract\": {\n77\t          \"type\": \"object\",\n78\t          \"description\": \"Input contract schema for this task\"\n79\t        },\n80\t        \"output_contract\": {\n81\t          \"type\": \"object\",\n82\t          \"description\": \"Output contract schema for this task\"\n83\t        },\n84\t        \"max_budget_usd\": {\n85\t          \"type\": \"number\",\n86\t          \"description\": \"Maximum budget in USD for this task execution\"\n87\t        }\n88\t      },\n89\t      \"additionalProperties\": false\n90\t    }\n91\t  }\n92\t}\n93\t"}]},"parent_tool_use_id":"toolu_01ChyoLDPrvpbR13hYNAz6e8","session_id":"c2800ecc-75a3-43b2-b3d8-396855aa3c3c","uuid":"22674146-dcaf-4766-884c-e586199435d1","timestamp":"2026-04-03T03:04:25.892Z"}
