{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019zfuS58iUBKmweUqrrqJtD","type":"tool_result","content":"    48в†’/**\n    49в†’ * Parse a ralph output line and return a StoryMessage if it matches\n    50в†’ * a story completion, failure, or warning pattern.\n    51в†’ * Returns null for non-matching lines.\n    52в†’ */\n    53в†’export function parseRalphMessage(rawLine: string): StoryMessage | null {\n    54в†’  const clean = rawLine.replace(ANSI_ESCAPE, '').replace(TIMESTAMP_PREFIX, '').trim();\n    55в†’  if (clean.length === 0) return null;\n    56в†’\n    57в†’  // [SUCCESS] Story {key}: DONE ...\n    58в†’  const success = SUCCESS_STORY.exec(clean);\n    59в†’  if (success) {\n    60в†’    const key = success[1];\n    61в†’    const rest = success[2].trim().replace(/^вЂ”\\s*/, '');\n    62в†’    return {\n    63в†’      type: 'ok',\n    64в†’      key,\n    65в†’      message: rest ? `DONE вЂ” ${rest}` : 'DONE',\n    66в†’    };\n    67в†’  }\n    68в†’\n    69в†’  // [WARN] Story {key} exceeded retry limit\n    70в†’  const retryExceeded = WARN_STORY_RETRY.exec(clean);\n    71в†’  if (retryExceeded) {\n    72в†’    return {\n    73в†’      type: 'fail',\n    74в†’      key: retryExceeded[1],\n    75в†’      message: 'exceeded retry limit',\n    76в†’    };\n    77в†’  }"}]},"parent_tool_use_id":null,"session_id":"2a44c687-0795-47af-a7f4-46576056f827","uuid":"6d8fbfeb-8f2d-459d-8308-06e118dfcc63","timestamp":"2026-03-27T15:09:32.863Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ivintik/dev/personal/codeharness/src/lib/agents/ralph.ts","content":"/**\n * Parse a ralph output line and return a StoryMessage if it matches\n * a story completion, failure, or warning pattern.\n * Returns null for non-matching lines.\n */\nexport function parseRalphMessage(rawLine: string): StoryMessage | null {\n  const clean = rawLine.replace(ANSI_ESCAPE, '').replace(TIMESTAMP_PREFIX, '').trim();\n  if (clean.length === 0) return null;\n\n  // [SUCCESS] Story {key}: DONE ...\n  const success = SUCCESS_STORY.exec(clean);\n  if (success) {\n    const key = success[1];\n    const rest = success[2].trim().replace(/^вЂ”\\s*/, '');\n    return {\n      type: 'ok',\n      key,\n      message: rest ? `DONE вЂ” ${rest}` : 'DONE',\n    };\n  }\n\n  // [WARN] Story {key} exceeded retry limit\n  const retryExceeded = WARN_STORY_RETRY.exec(clean);\n  if (retryExceeded) {\n    return {\n      type: 'fail',\n      key: retryExceeded[1],\n      message: 'exceeded retry limit',\n    };\n  }","numLines":30,"startLine":48,"totalLines":280}}}
