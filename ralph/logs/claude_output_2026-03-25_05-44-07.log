{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HeZ7Fw4yLyuAnvioLx2AvS","type":"tool_result","content":"     1→/**\n     2→ * Python stack provider — encapsulates all Python-specific behavior.\n     3→ * Implements every StackProvider method for the python stack.\n     4→ *\n     5→ * Story 10-3: full implementation following NodejsProvider pattern from story 10-2.\n     6→ */\n     7→\n     8→import { execFileSync } from 'node:child_process';\n     9→import { existsSync, readFileSync } from 'node:fs';\n    10→import { join } from 'node:path';\n    11→\n    12→import { renderTemplateFile } from '../templates.js';\n    13→import type {\n    14→  AppType,\n    15→  CoverageToolInfo,\n    16→  CoverageToolName,\n    17→  OtlpResult,\n    18→  StackProvider,\n    19→  TestCounts,\n    20→} from './types.js';\n    21→import { readTextSafe, getPythonDepsContent, hasPythonDep } from './utils.js';\n    22→\n    23→/** Dependency names that signal an AI/agent project. */\n    24→const AGENT_DEPS = [\n    25→  'anthropic',\n    26→  'openai',\n    27→  'langchain',\n    28→  'llama-index',\n    29→  'traceloop-sdk',\n    30→];\n    31→\n    32→/** Dependency names that signal a web framework project. */\n    33→const WEB_FRAMEWORK_DEPS = ['flask', 'django', 'fastapi', 'streamlit'];\n    34→\n    35→/** OTLP packages required for Python instrumentation. */\n    36→const PYTHON_OTLP_PACKAGES = [\n    37→  'opentelemetry-distro',\n    38→  'opentelemetry-exporter-otlp',\n    39→];\n    40→\n    41→export class PythonProvider implements StackProvider {\n    42→  readonly name = 'python' as const;\n    43→  readonly markers = ['requirements.txt', 'pyproject.toml', 'setup.py'];\n    44→  readonly displayName = 'Python';\n    45→\n    46→  // ── Task 2: detectAppType ──────────────────────────────────────────────\n    47→\n    48→  detectAppType(dir: string): AppType {\n    49→    const content = getPythonDepsContent(dir);\n    50→\n    51→    // Priority 1: Agent detection\n    52→    if (AGENT_DEPS.some((d) => hasPythonDep(content, d))) {\n    53→      return 'agent';\n    54→    }\n    55→\n    56→    // Priority 2: Web detection (framework + templates/static dirs)\n    57→    const hasWebFramework = WEB_FRAMEWORK_DEPS.some((d) => hasPythonDep(content, d));\n    58→    if (hasWebFramework) {\n    59→      const hasTemplates = existsSync(join(dir, 'templates'));\n    60→      const hasStatic = existsSync(join(dir, 'static'));\n    61→      if (hasTemplates || hasStatic) {\n    62→        return 'web';\n    63→      }\n    64→      // Bare Flask/Django/FastAPI without templates => server\n    65→      return 'server';\n    66→    }\n    67→\n    68→    // Priority 3: Server detection (has main entry point)\n    69→    if (\n    70→      existsSync(join(dir, 'app.py')) ||\n    71→      existsSync(join(dir, 'main.py')) ||\n    72→      existsSync(join(dir, 'manage.py'))\n    73→    ) {\n    74→      return 'server';\n    75→    }\n    76→\n    77→    return 'generic';\n    78→  }\n    79→\n    80→  // ── Task 4: getCoverageTool ────────────────────────────────────────────\n    81→\n    82→  getCoverageTool(): CoverageToolName {\n    83→    return 'coverage-py';\n    84→  }\n    85→\n    86→  // ── Task 5: detectCoverageConfig ───────────────────────────────────────\n    87→\n    88→  detectCoverageConfig(dir: string): CoverageToolInfo {\n    89→    // Check requirements.txt\n    90→    const reqPath = join(dir, 'requirements.txt');\n    91→    const reqContent = readTextSafe(reqPath);\n    92→    if (reqContent) {\n    93→      if (hasPythonDep(reqContent, 'pytest-cov') || hasPythonDep(reqContent, 'coverage')) {\n    94→        return { tool: 'coverage-py', configFile: reqPath };\n    95→      }\n    96→    }\n    97→\n    98→    // Check pyproject.toml — use includes() here because coverage config sections\n    99→    // (e.g. [tool.coverage.run]) are not package deps and won't match hasPythonDep().\n   100→    const pyprojectPath = join(dir, 'pyproject.toml');\n   101→    const pyprojectContent = readTextSafe(pyprojectPath);\n   102→    if (pyprojectContent) {\n   103→      if (\n   104→        hasPythonDep(pyprojectContent, 'pytest-cov') ||\n   105→        hasPythonDep(pyprojectContent, 'coverage') ||\n   106→        pyprojectContent.includes('[tool.coverage')\n   107→      ) {\n   108→        return { tool: 'coverage-py', configFile: pyprojectPath };\n   109→      }\n   110→    }\n   111→\n   112→    return { tool: 'none' };\n   113→  }\n   114→\n   115→  // ── Task 6: getOtlpPackages ────────────────────────────────────────────\n   116→\n   117→  getOtlpPackages(): string[] {\n   118→    return [...PYTHON_OTLP_PACKAGES];\n   119→  }\n   120→\n   121→  // ── Task 7: installOtlp ───────────────────────────────────────────────\n   122→\n   123→  installOtlp(dir: string): OtlpResult {\n   124→    // Primary: pip install both packages in one command\n   125→    try {\n   126→      execFileSync('pip', ['install', ...PYTHON_OTLP_PACKAGES], {\n   127→        cwd: dir,\n   128→        stdio: 'pipe',\n   129→        timeout: 300_000,\n   130→      });\n   131→      return {\n   132→        success: true,\n   133→        packagesInstalled: [...PYTHON_OTLP_PACKAGES],\n   134→      };\n   135→    } catch {\n   136→      // IGNORE: pip install failed, fallback to pipx\n   137→    }\n   138→\n   139→    const installed: string[] = [];\n   140→    try {\n   141→      for (const pkg of PYTHON_OTLP_PACKAGES) {\n   142→        execFileSync('pipx', ['install', pkg], {\n   143→          cwd: dir,\n   144→          stdio: 'pipe',\n   145→          timeout: 300_000,\n   146→        });\n   147→        installed.push(pkg);\n   148→      }\n   149→      return {\n   150→        success: true,\n   151→        packagesInstalled: installed,\n   152→      };\n   153→    } catch (err) {\n   154→      const message = err instanceof Error ? err.message : 'Unknown error';\n   155→      return {\n   156→        success: false,\n   157→        packagesInstalled: installed,\n   158→        error: `Failed to install Python OTLP packages: ${message.length > 200 ? message.slice(0, 200) + '... (truncated)' : message}`,\n   159→      };\n   160→    }\n   161→  }\n   162→\n   163→  // ── Task 8: getDockerfileTemplate ─────────────────────────────────────\n   164→\n   165→  getDockerfileTemplate(): string {\n   166→    return renderTemplateFile('templates/dockerfiles/Dockerfile.python');\n   167→  }\n   168→\n   169→  // ── Task 9: getDockerBuildStage ───────────────────────────────────────\n   170→\n   171→  getDockerBuildStage(): string {\n   172→    return `# === Build stage: python ===\n   173→FROM python:3.12-slim AS build-python\n   174→WORKDIR /build\n   175→COPY . .\n   176→RUN pip install --target=/build/dist .\n   177→`;\n   178→  }\n   179→\n   180→  // ── Task 10: getRuntimeCopyDirectives ──────────────────────────────────\n   181→\n   182→  getRuntimeCopyDirectives(): string {\n   183→    return 'COPY --from=build-python /build/dist /opt/app/python/';\n   184→  }\n   185→\n   186→  // ── Task 11: getBuildCommands ──────────────────────────────────────────\n   187→\n   188→  getBuildCommands(): string[] {\n   189→    return ['pip install -r requirements.txt'];\n   190→  }\n   191→\n   192→  // ── Task 12: getTestCommands ──────────────────────────────────────────\n   193→\n   194→  getTestCommands(): string[] {\n   195→    return ['python -m pytest'];\n   196→  }\n   197→\n   198→  // ── Task 13: getSemgrepLanguages ──────────────────────────────────────\n   199→\n   200→  getSemgrepLanguages(): string[] {\n   201→    return ['python'];\n   202→  }\n   203→\n   204→  // ── Task 14: parseTestOutput ──────────────────────────────────────────\n   205→\n   206→  parseTestOutput(output: string): TestCounts {\n   207→    // Pytest format: \"12 passed, 3 failed\" or \"5 passed\" or \"12 passed, 3 failed, 1 skipped\"\n   208→    const passedMatch = /(\\d+)\\s+passed/i.exec(output);\n   209→    if (passedMatch) {\n   210→      const passed = parseInt(passedMatch[1], 10);\n   211→      const failedMatch = /(\\d+)\\s+failed/i.exec(output);\n   212→      const skippedMatch = /(\\d+)\\s+skipped/i.exec(output);\n   213→      const failed = failedMatch ? parseInt(failedMatch[1], 10) : 0;\n   214→      const skipped = skippedMatch ? parseInt(skippedMatch[1], 10) : 0;\n   215→      return { passed, failed, skipped, total: passed + failed + skipped };\n   216→    }\n   217→\n   218→    return { passed: 0, failed: 0, skipped: 0, total: 0 };\n   219→  }\n   220→\n   221→  // ── Task 15: parseCoverageReport ──────────────────────────────────────\n   222→\n   223→  parseCoverageReport(dir: string): number {\n   224→    const reportPath = join(dir, 'coverage.json');\n   225→    if (!existsSync(reportPath)) return 0;\n   226→\n   227→    try {\n   228→      const report = JSON.parse(readFileSync(reportPath, 'utf-8')) as {\n   229→        totals?: { percent_covered?: number };\n   230→      };\n   231→      return report.totals?.percent_covered ?? 0;\n   232→    } catch {\n   233→      // IGNORE: Python coverage report may be malformed\n   234→      return 0;\n   235→    }\n   236→  }\n   237→\n   238→  // ── Task 16: getProjectName ───────────────────────────────────────────\n   239→\n   240→  // ── getVerifyDockerfileSection ──────────────────────────────────────\n   241→\n   242→  getVerifyDockerfileSection(_projectDir: string): string {\n   243→    return [\n   244→      '# --- Python tooling ---',\n   245→      'RUN apt-get update && apt-get install -y --no-install-recommends \\\\',\n   246→      '    python3-pip python3-venv \\\\',\n   247→      '    && rm -rf /var/lib/apt/lists/*',\n   248→      'RUN pip install --break-system-packages coverage pytest',\n   249→    ].join('\\n');\n   250→  }\n   251→\n   252→  getProjectName(dir: string): string | null {\n   253→    // Try pyproject.toml first\n   254→    const pyprojectContent = readTextSafe(join(dir, 'pyproject.toml'));\n   255→    if (pyprojectContent) {\n   256→      // Extract the [project] section (up to the next section header or EOF)\n   257→      const projectIdx = pyprojectContent.search(/^\\[project\\]\\s*$/m);\n   258→      if (projectIdx !== -1) {\n   259→        const afterHeader = pyprojectContent.slice(\n   260→          projectIdx + pyprojectContent.slice(projectIdx).indexOf('\\n') + 1,\n   261→        );\n   262→        // Find where next section starts (line beginning with '[')\n   263→        const nextSectionIdx = afterHeader.search(/^\\[/m);\n   264→        const section = nextSectionIdx === -1 ? afterHeader : afterHeader.slice(0, nextSectionIdx);\n   265→        // Match name = \"...\" or name = '...' within the [project] section only\n   266→        const nameMatch = /^\\s*name\\s*=\\s*[\"']([^\"']+)[\"']/m.exec(section);\n   267→        if (nameMatch) return nameMatch[1];\n   268→      }\n   269→    }\n   270→\n   271→    // Try setup.py\n   272→    const setupContent = readTextSafe(join(dir, 'setup.py'));\n   273→    if (setupContent) {\n   274→      const match = /name\\s*=\\s*['\"]([^'\"]+)['\"]/m.exec(setupContent);\n   275→      if (match) return match[1];\n   276→    }\n   277→\n   278→    return null;\n   279→  }\n   280→}\n   281→"}]},"parent_tool_use_id":"toolu_01L5LiJHunZnUnw7ysWAKpUU","session_id":"7c5953f4-1d55-4aa9-825f-60bc73601e00","uuid":"ebdd97f6-04de-4515-b295-7fe26362c2a1","timestamp":"2026-03-25T02:03:49.794Z"}
