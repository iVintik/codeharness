tion\n   129→    expect(result).toContain('rustup');\n   130→    expect(result).toContain('cargo-tarpaulin');\n   131→  });\n   132→\n   133→  it('produces only base + common tools for generic/plugin project (no stacks)', () => {\n   134→    mockDetectStacks.mockReturnValue([]);\n   135→    const result = generateVerifyDockerfile(testDir);\n   136→    expect(result).toContain('FROM ubuntu:22.04');\n   137→    expect(result).toContain('curl jq git python3 pipx');\n   138→    // No stack-specific sections\n   139→    expect(result).not.toContain('nodesource');\n   140→    expect(result).not.toContain('rustup');\n   141→    expect(result).not.toContain('python3-pip');\n   142→  });\n   143→});\n   144→"}]},"parent_tool_use_id":"toolu_01A5VRSCWrKG5o81CvpB3aWg","session_id":"83e99bf1-19ed-4459-85db-f9346f9425ec","uuid":"0933aba5-36cc-4cc0-b64f-eb7c4b5206b6","timestamp":"2026-03-27T09:33:28.131Z"}
