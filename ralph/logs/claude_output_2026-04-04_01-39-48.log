{ // IGNORE: stale worktree removal is best-effort before re-create per AC #9\n484\t        try {\n485\t          this.execGit('git worktree prune');\n486\t        } catch { // IGNORE: prune is best-effort fallback for stale worktree cleanup\n487\t        }\n488\t      }\n489\t    }\n490\t\n491\t    // Check if branch already exists\n492\t    const existingBranch = this.findBranchForEpic(epicId);\n493\t    if (existingBranch) {\n494\t      try {\n495\t        this.execGit(`git branch -D ${existingBranch}`);\n496\t      } catch { // IGNORE: stale branch deletion is best-effort before re-create per AC #9\n497\t      }\n498\t    }\n499\t  }\n500\t\n501\t  /**\n502\t   * Clean up partial state after a failed createWorktree (AC #10).\n503\t   */\n504\t  private cleanupPartial(branchCreated: boolean, branchName: string, worktreePath: string): void {\n505\t    // Try to remove worktree if it was partially created\n506\t    try {\n507\t      this.execGit(`git worktree remove ${worktreePath} --force`);\n508\t    } catch { // IGNORE: partial worktree may not exist during failure cleanup per AC #10\n509\t    }\n510\t\n511\t    // Delete branch if it was created\n512\t    if (branchCreated) {\n513\t      try {\n514\t        this.execGit(`git branch -D ${branchName}`);\n515\t      } catch { // IGNORE: partial branch may not exist during failure cleanup per AC #10\n516\t      }\n517\t    }\n518\t  }\n519\t\n520\t  /**\n521\t   * Find a branch matching `codeharness/epic-{epicId}-*`.\n522\t   */\n523\t  private findBranchForEpic(epicId: string): string | undefined {\n524\t    try {\n525\t      const output = this.execGit(`git branch --list ${BRANCH_PREFIX}${epicId}-*`);\n526\t      const branches = output\n527\t        .split('\\n')\n528\t        .map((b) => b.trim().replace(/^\\*\\s*/, ''))\n529\t        .filter((b) => b.length > 0);\n530\t      return branches[0];\n531\t    } catch { // IGNORE: branch listing failure means no branch exists — safe to return undefined\n532\t      return undefined;\n533\t    }\n534\t  }\n535\t\n536\t  /**\n537\t   * Parse `git worktree list --porcelain` output into structured entries.\n538\t   */\n539\t  private parsePorcelainOutput(output: string): Array<{ path: string; branch: string }> {\n540\t    if (!output.trim()) return [];\n541\t\n542\t    const blocks = output.split('\\n\\n').filter((b) => b.trim());\n543\t    const entries: Array<{ path: string; branch: string }> = [];\n544\t\n545\t    for (const block of blocks) {\n546\t      const lines = block.split('\\n');\n547\t      let path = '';\n548\t      let branch = '';\n549\t\n550\t      for (const line of lines) {\n551\t        if (line.startsWith('worktree ')) {\n552\t          path = line.slice('worktree '.length);\n553\t        } else if (line.startsWith('branch ')) {\n554\t          branch = line.slice('branch '.length);\n555\t        }\n556\t      }\n557\t\n558\t      if (path && branch) {\n559\t        entries.push({ path, branch });\n560\t      }\n561\t    }\n562\t\n563\t    return entries;\n564\t  }\n565\t\n566\t  /**\n567\t   * Extract epicId from a branch name like `codeharness/epic-17-slug`.\n568\t   */\n569\t  private extractEpicId(branchName: string): string {\n570\t    const withoutPrefix = branchName.slice(BRANCH_PREFIX.length);\n571\t    const dashIndex = withoutPrefix.indexOf('-');\n572\t    if (dashIndex === -1) return withoutPrefix;\n573\t    return withoutPrefix.slice(0, dashIndex);\n574\t  }\n575\t\n576\t  /**\n577\t   * Detect conflicting files after a failed merge/rebase.\n578\t   * Uses `git diff --name-only --diff-filter=U` to find unmerged paths.\n579\t   */\n580\t  private detectConflicts(): string[] {\n581\t    try {\n582\t      const output = this.execGit('git diff --name-only --diff-filter=U');\n583\t      return output\n584\t        .split('\\n')\n585\t        .map((f) => f.trim())\n586\t        .filter((f) => f.length > 0);\n587\t    } catch { // IGNORE: diff failure means no conflict info available\n588\t      return [];\n589\t    }\n590\t  }\n591\t\n592\t  /**\n593\t   * Abort an in-progress merge or rebase to restore main branch state.\n594\t   */\n595\t  private abortMerge(strategy: MergeStrategy): void {\n596\t    try {\n597\t      if (strategy === 'rebase') {\n598\t        this.execGit('git rebase --abort');\n599\t      } else {\n600\t        this.execGit('git merge --abort');\n601\t      }\n602\t    } catch { // IGNORE: abort may fail if merge already resolved; main state is preserved\n603\t    }\n604\t  }\n605\t\n606\t  /**\n607\t   * Run the test suite and parse results from stdout.\n608\t   * Uses async exec with a 5-minute timeout.\n609\t   */\n610\t  private async runTestSuite(\n611\t    testCommand: string = 'npm test',\n612\t  ): Promise<{ passed: number; failed: number; coverage?: number }> {\n613\t    try {\n614\t      const { stdout } = await execAsync(testCommand, {\n615\t        cwd: this.cwd,\n616\t        timeout: 300_000, // 5 minutes\n617\t      });\n618\t\n619\t      return this.parseTestOutput(stdout);\n620\t    } catch (err: unknown) {\n621\t      // Test command failed (non-zero exit) — parse whatever output we got\n622\t      const stdout = (err as { stdout?: string })?.stdout ?? '';\n623\t      const result = this.parseTestOutput(stdout);\n624\t      // If we couldn't parse anything, report 1 failure\n625\t      if (result.passed === 0 && result.failed === 0) {\n626\t        return { passed: 0, failed: 1 };\n627\t      }\n628\t      return result;\n629\t    }\n630\t  }\n631\t\n632\t  /**\n633\t   * Parse test output to extract pass/fail counts and optional coverage.\n634\t   * Supports common vitest/jest output patterns.\n635\t   */\n636\t  private parseTestOutput(stdout: string): { passed: number; failed: number; coverage?: number } {\n637\t    let passed = 0;\n638\t    let failed = 0;\n639\t    let coverage: number | undefined;\n640\t\n641\t    // Match vitest/jest \"Tests: X passed, Y failed\" or \"X passed\" patterns\n642\t    const passMatch = stdout.match(/(\\d+)\\s+passed/);\n643\t    const failMatch = stdout.match(/(\\d+)\\s+failed/);\n644\t    if (passMatch) passed = parseInt(passMatch[1], 10);\n645\t    if (failMatch) failed = parseInt(failMatch[1], 10);\n646\t\n647\t    // Match coverage percentage patterns like \"All files | 85.5\"\n648\t    const covMatch = stdout.match(/All files[^|]*\\|\\s*([\\d.]+)/);\n649\t    if (covMatch) coverage = parseFloat(covMatch[1]);\n650\t\n651\t    return { passed, failed, ...(coverage !== undefined && { coverage }) };\n652\t  }\n653\t\n654\t  /**\n655\t   * Check if a worktree is orphaned (no active codeharness process).\n656\t   */\n657\t  private isOrphaned(wt: WorktreeInfo): boolean {\n658\t    const laneStatePath = join(wt.path, '.codeharness', 'lane-state.json');\n659\t\n660\t    if (!existsSync(laneStatePath)) {\n661\t      return true;\n662\t    }\n663\t\n664\t    try {\n665\t      const content = readFileSync(laneStatePath, 'utf-8');\n666\t      const state = JSON.parse(content) as { pid?: number };\n667\t\n668\t      if (!state.pid) {\n669\t        return true;\n670\t      }\n671\t\n672\t      // Check if the PID is still running\n673\t      try {\n674\t        process.kill(state.pid, 0);\n675\t        return false; // Process is alive — not orphaned\n676\t      } catch { // IGNORE: ESRCH means process is dead — worktree is orphaned per AC #8\n677\t        return true;\n678\t      }\n679\t    } catch { // IGNORE: unreadable/corrupt lane-state.json means orphaned per AC #8\n680\t      return true;\n681\t    }\n682\t  }\n683\t}\n684\t"}]},"parent_tool_use_id":"toolu_01GdPP4HBhJR2VUUVuGFjShf","session_id":"74f4684f-cc80-4828-8405-943cba326449","uuid":"3c24d8cd-19d6-4ee2-81be-5289dbbc9ffb","timestamp":"2026-04-03T21:51:52.606Z"}
