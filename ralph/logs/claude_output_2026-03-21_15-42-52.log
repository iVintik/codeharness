{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0162xnEJ7HLwUaXvBgDzo5Dm","type":"tool_result","content":"     1→import { execFileSync } from 'node:child_process';\n     2→import { ok, fail as failOutput, info } from './output.js';\n     3→\n     4→export interface InstallCommand {\n     5→  cmd: string;\n     6→  args: string[];\n     7→}\n     8→\n     9→export interface DependencySpec {\n    10→  name: string;\n    11→  displayName: string;\n    12→  installCommands: InstallCommand[];\n    13→  checkCommand: InstallCommand;\n    14→  critical: boolean;\n    15→}\n    16→\n    17→export interface DependencyResult {\n    18→  name: string;\n    19→  displayName: string;\n    20→  status: 'installed' | 'already-installed' | 'skipped' | 'failed';\n    21→  version: string | null;\n    22→  error?: string;\n    23→}\n    24→\n    25→export const DEPENDENCY_REGISTRY: readonly DependencySpec[] = [\n    26→  {\n    27→    name: 'showboat',\n    28→    displayName: 'Showboat',\n    29→    installCommands: [\n    30→      { cmd: 'pip', args: ['install', 'showboat'] },\n    31→      { cmd: 'pipx', args: ['install', 'showboat'] },\n    32→    ],\n    33→    checkCommand: { cmd: 'showboat', args: ['--version'] },\n    34→    critical: false,\n    35→  },\n    36→  {\n    37→    name: 'agent-browser',\n    38→    displayName: 'agent-browser',\n    39→    installCommands: [\n    40→      { cmd: 'npm', args: ['install', '-g', '@anthropic/agent-browser'] },\n    41→    ],\n    42→    checkCommand: { cmd: 'agent-browser', args: ['--version'] },\n    43→    critical: false,\n    44→  },\n    45→  {\n    46→    name: 'beads',\n    47→    displayName: 'beads',\n    48→    installCommands: [\n    49→      { cmd: 'pip', args: ['install', 'beads'] },\n    50→      { cmd: 'pipx', args: ['install', 'beads'] },\n    51→    ],\n    52→    checkCommand: { cmd: 'bd', args: ['--version'] },\n    53→    critical: false,\n    54→  },\n    55→  {\n    56→    name: 'semgrep',\n    57→    displayName: 'Semgrep',\n    58→    installCommands: [\n    59→      { cmd: 'pipx', args: ['install', 'semgrep'] },\n    60→      { cmd: 'pip', args: ['install', 'semgrep'] },\n    61→    ],\n    62→    checkCommand: { cmd: 'semgrep', args: ['--version'] },\n    63→    critical: false,\n    64→  },\n    65→];\n    66→\n    67→export function checkInstalled(spec: DependencySpec): { installed: boolean; version: string | null } {\n    68→  try {\n    69→    const output = execFileSync(spec.checkCommand.cmd, spec.checkCommand.args, { stdio: 'pipe', timeout: 15_000 }).toString().trim();\n    70→    const version = parseVersion(output);\n    71→    return { installed: true, version };\n    72→  } catch {\n    73→    return { installed: false, version: null };\n    74→  }\n    75→}\n    76→\n    77→export function parseVersion(output: string): string | null {\n    78→  const match = /(\\d+\\.\\d+[\\w.-]*)/.exec(output);\n    79→  return match ? match[1] : null;\n    80→}\n    81→\n    82→export function installDependency(spec: DependencySpec): DependencyResult {\n    83→  // Check if already installed\n    84→  const check = checkInstalled(spec);\n    85→  if (check.installed) {\n    86→    return {\n    87→      name: spec.name,\n    88→      displayName: spec.displayName,\n    89→      status: 'already-installed',\n    90→      version: check.version,\n    91→    };\n    92→  }\n    93→\n    94→  // Try each install command in the fallback chain\n    95→  for (const installCmd of spec.installCommands) {\n    96→    try {\n    97→      execFileSync(installCmd.cmd, installCmd.args, { stdio: 'pipe', timeout: 300_000 });\n    98→\n    99→      // Verify installation succeeded by checking version\n   100→      const postCheck = checkInstalled(spec);\n   101→      if (postCheck.installed) {\n   102→        return {\n   103→          name: spec.name,\n   104→          displayName: spec.displayName,\n   105→          status: 'installed',\n   106→          version: postCheck.version,\n   107→        };\n   108→      }\n   109→    } catch {\n   110→      // Try next fallback\n   111→      continue;\n   112→    }\n   113→  }\n   114→\n   115→  // All install commands failed\n   116→  const remedy = spec.installCommands.map(c => [c.cmd, ...c.args].join(' ')).join(' or ');\n   117→  return {\n   118→    name: spec.name,\n   119→    displayName: spec.displayName,\n   120→    status: 'failed',\n   121→    version: null,\n   122→    error: `Install failed. Try: ${remedy}`,\n   123→  };\n   124→}\n   125→\n   126→export function installAllDependencies(opts: { json?: boolean }): DependencyResult[] {\n   127→  const results: DependencyResult[] = [];\n   128→\n   129→  for (const spec of DEPENDENCY_REGISTRY) {\n   130→    const result = installDependency(spec);\n   131→    results.push(result);\n   132→\n   133→    if (!opts.json) {\n   134→      if (result.status === 'installed') {\n   135→        const versionStr = result.version ? ` (v${result.version})` : '';\n   136→        ok(`${spec.displayName}: installed${versionStr}`);\n   137→      } else if (result.status === 'already-installed') {\n   138→        const versionStr = result.version ? ` (v${result.version})` : '';\n   139→        ok(`${spec.displayName}: already installed${versionStr}`);\n   140→      } else if (result.status === 'failed') {\n   141→        failOutput(`${spec.displayName}: install failed. ${result.error ?? ''}`);\n   142→        if (!spec.critical) {\n   143→          info(`${spec.displayName} is optional — continuing without it`);\n   144→        }\n   145→      }\n   146→    }\n   147→\n   148→    if (result.status === 'failed' && spec.critical) {\n   149→      throw new CriticalDependencyError(spec.displayName, result.error ?? 'Install failed');\n   150→    }\n   151→  }\n   152→\n   153→  return results;\n   154→}\n   155→\n   156→export class CriticalDependencyError extends Error {\n   157→  constructor(\n   158→    public readonly dependencyName: string,\n   159→    public readonly reason: string,\n   160→  ) {\n   161→    super(`Critical dependency '${dependencyName}' failed to install: ${reason}`);\n   162→    this.name = 'CriticalDependencyError';\n   163→  }\n   164→}\n   165→"}]},"parent_tool_use_id":"toolu_01GwwRGHx2aGkVK7JeqGtRMs","session_id":"02b06ad8-9233-430d-bd8e-764032ea190c","uuid":"ca8e5bc4-470a-4986-b3b9-fa8db6ae1b21","timestamp":"2026-03-21T11:51:09.562Z"}
