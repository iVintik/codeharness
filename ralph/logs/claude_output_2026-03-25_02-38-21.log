{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MqQjyWkeBhu2Gdf6yWr6DG","type":"tool_result","content":"     1→import { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n     2→import { join, dirname } from 'node:path';\n     3→import { StringDecoder } from 'node:string_decoder';\n     4→import { Command } from 'commander';\n     5→import { fail, info, jsonOutput } from '../lib/output.js';\n     6→import { isDockerAvailable } from '../lib/docker/index.js';\n     7→import { cleanupContainers } from '../modules/infra/index.js';\n     8→import { readSprintStatusFromState, reconcileState } from '../modules/sprint/index.js';\n     9→import { generateRalphPrompt } from '../lib/agents/ralph-prompt.js';\n    10→import { startRenderer, type SprintInfo } from '../lib/ink-renderer.js';\n    11→import { getSprintState } from '../modules/sprint/index.js';\n    12→import { formatElapsed, mapSprintStatuses, countStories } from '../lib/run-helpers.js';\n    13→import { getDriver } from '../lib/agents/index.js';\n    14→import type { AgentDriver, AgentEvent } from '../lib/agents/types.js';\n    15→import type { RendererHandle } from '../lib/ink-renderer.js';\n    16→\n    17→/** Resolves the plugin directory path (.claude/ in project root). */\n    18→export function resolvePluginDir(): string {\n    19→  return join(process.cwd(), '.claude');\n    20→}\n    21→\n    22→// Re-export helpers that tests import from run.ts\n    23→export { countStories } from '../lib/run-helpers.js';\n    24→\n    25→/** Dispatches an AgentEvent to the appropriate renderer method. */\n    26→function handleAgentEvent(\n    27→  event: AgentEvent,\n    28→  rendererHandle: RendererHandle,\n    29→  state: { currentIterationCount: number },\n    30→): void {\n    31→  switch (event.type) {\n    32→    case 'tool-start':\n    33→    case 'tool-complete':\n    34→    case 'text':\n    35→    case 'result':\n    36→    case 'retry':\n    37→      // These AgentEvent types match StreamEvent shapes — pass through to renderer\n    38→      rendererHandle.update(event as Parameters<RendererHandle['update']>[0]);\n    39→      break;\n    40→    case 'story-complete':\n    41→      rendererHandle.addMessage({ type: 'ok', key: event.key, message: event.details });\n    42→      break;\n    43→    case 'story-failed':\n    44→      rendererHandle.addMessage({ type: 'fail', key: event.key, message: event.reason });\n    45→      break;\n    46→    case 'iteration':\n    47→      state.currentIterationCount = event.count;\n    48→      break;\n    49→  }\n    50→}\n    51→\n    52→/** Line splitter: buffers partial lines, calls driver.parseOutput(), dispatches via handleAgentEvent(). */\n    53→function createDriverLineHandler(\n    54→  driver: AgentDriver,\n    55→  rendererHandle: RendererHandle,\n    56→  state: { currentIterationCount: number },\n    57→): (data: Buffer) => void {\n    58→  let partial = '';\n    59→  const decoder = new StringDecoder('utf8');\n    60→  return (data: Buffer): void => {\n    61→    const text = partial + decoder.write(data);\n    62→    const parts = text.split('\\n');\n    63→    partial = parts.pop() ?? '';\n    64→    for (const line of parts) {\n    65→      if (line.trim().length === 0) continue;\n    66→      const event = driver.parseOutput(line);\n    67→      if (event) {\n    68→        handleAgentEvent(event, rendererHandle, state);\n    69→      }\n    70→    }\n    71→  };\n    72→}\n    73→\n    74→export function registerRunCommand(program: Command): void {\n    75→  program\n    76→    .command('run')\n    77→    .description('Execute the autonomous coding loop')\n    78→    .option('--max-iterations <n>', 'Maximum loop iterations', '50')\n    79→    .option('--timeout <seconds>', 'Total loop timeout in seconds', '43200')\n    80→    .option('--iteration-timeout <minutes>', 'Per-iteration timeout in minutes', '30')\n    81→    .option('--quiet', 'Suppress terminal output (background mode)', false)\n    82→    .option('--calls <n>', 'Max API calls per hour', '100')\n    83→    .option('--max-story-retries <n>', 'Max retries per story before flagging', '10')\n    84→    .option('--reset', 'Clear retry counters, flagged stories, and circuit breaker before starting', false)\n    85→    .action(async (options, cmd) => {\n    86→      const globalOpts = cmd.optsWithGlobals();\n    87→      const isJson = !!globalOpts.json;\n    88→      const outputOpts = { json: isJson };\n    89→\n    90→      // 1. Resolve plugin directory\n    91→      const pluginDir = resolvePluginDir();\n    92→      if (!existsSync(pluginDir)) {\n    93→        fail('Plugin directory not found — run codeharness init first', outputOpts);\n    94→        process.exitCode = 1;\n    95→        return;\n    96→      }\n    97→\n    98→      // 1b. Reconcile state (best-effort — failures warn but don't abort)\n    99→      const reconciliation = reconcileState();\n   100→      if (reconciliation.success && reconciliation.data.corrections.length > 0) {\n   101→        for (const correction of reconciliation.data.corrections) {\n   102→          info(`[INFO] Reconciled: ${correction}`, outputOpts);\n   103→        }\n   104→      } else if (!reconciliation.success) {\n   105→        info(`[WARN] State reconciliation failed: ${reconciliation.error}`, outputOpts);\n   106→      }\n   107→\n   108→      // 1c. Docker pre-flight: fail fast if Docker unavailable\n   109→      if (!isDockerAvailable()) {\n   110→        fail('[FAIL] Docker not available — install Docker or start the daemon', outputOpts);\n   111→        process.exitCode = 1;\n   112→        return;\n   113→      }\n   114→      // 1d. Orphan container cleanup (best-effort — failures warn but don't abort)\n   115→      const cleanup = cleanupContainers();\n   116→      if (cleanup.success && cleanup.data.containersRemoved > 0) {\n   117→        info(`[INFO] Cleaned up ${cleanup.data.containersRemoved} orphaned container(s): ${cleanup.data.names.join(', ')}`, outputOpts);\n   118→      } else if (!cleanup.success) {\n   119→        info(`[WARN] Container cleanup failed: ${cleanup.error}`, outputOpts);\n   120→      }\n   121→      // 2. Read sprint status for story count (from sprint-state.json)\n   122→      const projectDir = process.cwd();\n   123→      const sprintStatusPath = join(projectDir, '_bmad-output', 'implementation-artifacts', 'sprint-status.yaml');\n   124→      const statuses = readSprintStatusFromState();\n   125→      const counts = countStories(statuses);\n   126→\n   127→      if (counts.total === 0) {\n   128→        fail('No stories found in sprint-state.json — nothing to execute', outputOpts);\n   129→        process.exitCode = 1;\n   130→        return;\n   131→      }\n   132→\n   133→      info(`Starting autonomous execution — ${counts.ready} ready, ${counts.inProgress} in progress, ${counts.verified} verified, ${counts.done}/${counts.total} done`, outputOpts);\n   134→      // 3. Parse and validate numeric options\n   135→      const maxIterations = parseInt(options.maxIterations, 10);\n   136→      const timeout = parseInt(options.timeout, 10);\n   137→      const iterationTimeout = parseInt(options.iterationTimeout, 10);\n   138→      const calls = parseInt(options.calls, 10);\n   139→      const maxStoryRetries = parseInt(options.maxStoryRetries, 10);\n   140→      if (isNaN(maxIterations) || isNaN(timeout) || isNaN(iterationTimeout) || isNaN(calls) || isNaN(maxStoryRetries)) {\n   141→        fail('Invalid numeric option — --max-iterations, --timeout, --iteration-timeout, --calls, and --max-story-retries must be numbers', outputOpts);\n   142→        process.exitCode = 1;\n   143→        return;\n   144→      }\n   145→\n   146→      // 4. Generate prompt file (with flagged stories context if available)\n   147→      const promptFile = join(projectDir, 'ralph', '.harness-prompt.md');\n   148→      let flaggedStories: string[] | undefined;\n   149→      const flaggedState = getSprintState();\n   150→      if (flaggedState.success && flaggedState.data.flagged?.length > 0) {\n   151→        flaggedStories = flaggedState.data.flagged;\n   152→      }\n   153→      const promptContent = generateRalphPrompt({\n   154→        projectDir,\n   155→        sprintStatusPath,\n   156→        flaggedStories,\n   157→      });\n   158→      try {\n   159→        mkdirSync(dirname(promptFile), { recursive: true });\n   160→        writeFileSync(promptFile, promptContent, 'utf-8');\n   161→      } catch (err) {\n   162→        const message = err instanceof Error ? err.message : String(err);\n   163→        fail(`Failed to write prompt file: ${message}`, outputOpts);\n   164→        process.exitCode = 1;\n   165→        return;\n   166→      }\n   167→\n   168→      // 5. Create driver with ralph-specific configuration\n   169→      const quiet = options.quiet;\n   170→      const driver = getDriver('ralph', {\n   171→        pluginDir,\n   172→        maxIterations,\n   173→        iterationTimeout,\n   174→        calls,\n   175→        quiet,\n   176→        maxStoryRetries,\n   177→        reset: options.reset,\n   178→      });\n   179→\n   180→      // 6. Set environment — stream-json is always the output format\n   181→      const env: Record<string, string> = {};\n   182→      if (isJson) {\n   183→        env.CLAUDE_OUTPUT_FORMAT = 'stream-json';\n   184→      }\n   185→\n   186→      // 7. Spawn agent — pipe stdout/stderr through driver.parseOutput() → Ink renderer\n   187→      const rendererHandle = startRenderer({ quiet });\n   188→      let sprintStateInterval: ReturnType<typeof setInterval> | null = null;\n   189→      const sessionStartTime = Date.now();\n   190→      const eventState = { currentIterationCount: 0 };\n   191→\n   192→      try {\n   193→        // Read initial sprint state for the renderer header\n   194→        const initialState = getSprintState();\n   195→        if (initialState.success) {\n   196→          const s = initialState.data;\n   197→          const sprintInfo: SprintInfo = {\n   198→            storyKey: s.run.currentStory ?? '',\n   199→            phase: s.run.currentPhase ?? '',\n   200→            done: s.sprint.done,\n   201→            total: s.sprint.total,\n   202→            elapsed: formatElapsed(Date.now() - sessionStartTime),\n   203→            iterationCount: eventState.currentIterationCount,\n   204→          };\n   205→          rendererHandle.updateSprintState(sprintInfo);\n   206→        }\n   207→\n   208→        // Feed initial per-story statuses to the renderer\n   209→        const initialStatuses = readSprintStatusFromState();\n   210→        const initialStories = mapSprintStatuses(initialStatuses);\n   211→        if (initialStories.length > 0) {\n   212→          rendererHandle.updateStories(initialStories);\n   213→        }\n   214→\n   215→        const child = driver.spawn({\n   216→          storyKey: '',\n   217→          prompt: promptFile,\n   218→          workDir: projectDir,\n   219→          timeout,\n   220→          env,\n   221→        });\n   222→\n   223→        if (!quiet && child.stdout && child.stderr) {\n   224→          const lineHandler = createDriverLineHandler(driver, rendererHandle, eventState);\n   225→          child.stdout.on('data', lineHandler);\n   226→          child.stderr.on('data', lineHandler);\n   227→\n   228→          // Periodically refresh sprint state for the header display\n   229→          sprintStateInterval = setInterval(() => {\n   230→            try {\n   231→              const stateResult = getSprintState();\n   232→              if (stateResult.success) {\n   233→                const s = stateResult.data;\n   234→                const sprintInfo: SprintInfo = {\n   235→                  storyKey: s.run.currentStory ?? '',\n   236→                  phase: s.run.currentPhase ?? '',\n   237→                  done: s.sprint.done,\n   238→                  total: s.sprint.total,\n   239→                  elapsed: formatElapsed(Date.now() - sessionStartTime),\n   240→                  iterationCount: eventState.currentIterationCount,\n   241→                };\n   242→                rendererHandle.updateSprintState(sprintInfo);\n   243→              }\n   244→              // Refresh per-story statuses\n   245→              const currentStatuses = readSprintStatusFromState();\n   246→              const storyEntries = mapSprintStatuses(currentStatuses);\n   247→              rendererHandle.updateStories(storyEntries);\n   248→            } catch {\n   249→              // Ignore read errors during polling\n   250→            }\n   251→          }, 5_000);\n   252→        }\n   253→\n   254→        const exitCode = await new Promise<number>((resolve, reject) => {\n   255→          child.on('error', (err) => {\n   256→            if (sprintStateInterval) clearInterval(sprintStateInterval);\n   257→            rendererHandle.cleanup();\n   258→            reject(err);\n   259→          });\n   260→          child.on('close', (code) => {\n   261→            if (sprintStateInterval) clearInterval(sprintStateInterval);\n   262→            rendererHandle.cleanup();\n   263→            resolve(code ?? 1);\n   264→          });\n   265→        });\n   266→\n   267→        // 8. Handle JSON output on exit\n   268→        if (isJson) {\n   269→          const statusFile = join(projectDir, driver.getStatusFile());\n   270→          let statusData: Record<string, unknown> | null = null;\n   271→          let exitReason = 'status_file_missing';\n   272→          if (existsSync(statusFile)) {\n   273→            try {\n   274→              statusData = JSON.parse(readFileSync(statusFile, 'utf-8'));\n   275→              exitReason = '';\n   276→            } catch { exitReason = 'status_file_unreadable'; }\n   277→          }\n   278→          const fc = statusData ? countStories(readSprintStatusFromState()) : counts;\n   279→          jsonOutput({\n   280→            status: statusData?.status ?? (exitCode === 0 ? 'completed' : 'stopped'),\n   281→            iterations: (statusData?.loop_count as number) ?? 0,\n   282→            storiesCompleted: statusData ? fc.done : 0,\n   283→            storiesTotal: fc.total,\n   284→            storiesRemaining: statusData ? fc.total - fc.done : fc.total,\n   285→            elapsedSeconds: (statusData?.elapsed_seconds as number) ?? 0,\n   286→            flaggedStories: (statusData?.flagged_stories as string[]) ?? [],\n   287→            exitReason: (statusData?.exit_reason as string) ?? exitReason,\n   288→          });\n   289→        }\n   290→\n   291→        process.exitCode = exitCode;\n   292→      } catch (err) {\n   293→        if (sprintStateInterval) clearInterval(sprintStateInterval);\n   294→        rendererHandle.cleanup();\n   295→        const message = err instanceof Error ? err.message : String(err);\n   296→        fail(`Failed to start agent: ${message}`, outputOpts);\n   297→        process.exitCode = 1;\n   298→      }\n   299→    });\n   300→}\n   301→"}]},"parent_tool_use_id":"toolu_01NrzDLhF9NNDZQrr8WemqQC","session_id":"174e0897-5fbc-4ae0-bbc6-8b881d5c7525","uuid":"da60adca-93e9-4c53-bc2e-922a1792e839","timestamp":"2026-03-24T22:52:26.102Z"}
