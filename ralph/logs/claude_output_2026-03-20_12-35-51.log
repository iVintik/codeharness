{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BvfP77SU2GNMUvbCXsPHYJ","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→import { Command } from 'commander';\n     3→\n     4→// Mock dependencies\n     5→vi.mock('../../lib/output.js', () => ({\n     6→  ok: vi.fn(),\n     7→  fail: vi.fn(),\n     8→  warn: vi.fn(),\n     9→  info: vi.fn(),\n    10→  jsonOutput: vi.fn(),\n    11→}));\n    12→\n    13→vi.mock('../../lib/onboard-checks.js', () => ({\n    14→  runPreconditions: vi.fn(),\n    15→}));\n    16→\n    17→vi.mock('../../modules/audit/index.js', () => ({\n    18→  runAudit: vi.fn(),\n    19→}));\n    20→\n    21→vi.mock('../../modules/audit/report.js', () => ({\n    22→  formatAuditHuman: vi.fn(),\n    23→  formatAuditJson: vi.fn(),\n    24→}));\n    25→\n    26→import { fail as failOutput, jsonOutput } from '../../lib/output.js';\n    27→import { runPreconditions } from '../../lib/onboard-checks.js';\n    28→import { runAudit } from '../../modules/audit/index.js';\n    29→import { formatAuditHuman, formatAuditJson } from '../../modules/audit/report.js';\n    30→import { registerAuditCommand } from '../audit.js';\n    31→\n    32→const mockRunPreconditions = vi.mocked(runPreconditions);\n    33→const mockRunAudit = vi.mocked(runAudit);\n    34→const mockFormatAuditHuman = vi.mocked(formatAuditHuman);\n    35→const mockFormatAuditJson = vi.mocked(formatAuditJson);\n    36→const mockFailOutput = vi.mocked(failOutput);\n    37→const mockJsonOutput = vi.mocked(jsonOutput);\n    38→\n    39→beforeEach(() => {\n    40→  vi.clearAllMocks();\n    41→  process.exitCode = undefined;\n    42→});\n    43→\n    44→async function runAuditCmd(args: string[]): Promise<void> {\n    45→  const program = new Command();\n    46→  program.exitOverride();\n    47→  program.option('--json', 'JSON output');\n    48→  registerAuditCommand(program);\n    49→  try {\n    50→    await program.parseAsync(['node', 'test', 'audit', ...args]);\n    51→  } catch {\n    52→    // Commander throws on exitOverride — ignore\n    53→  }\n    54→}\n    55→\n    56→describe('registerAuditCommand', () => {\n    57→  it('registers the audit command', () => {\n    58→    const program = new Command();\n    59→    registerAuditCommand(program);\n    60→    const auditCmd = program.commands.find(c => c.name() === 'audit');\n    61→    expect(auditCmd).toBeDefined();\n    62→  });\n    63→\n    64→  it('exits with fail when not initialized', async () => {\n    65→    mockRunPreconditions.mockReturnValue({\n    66→      canProceed: false,\n    67→      warnings: [],\n    68→      initialized: false,\n    69→      bmad: false,\n    70→      hooks: false,\n    71→    });\n    72→\n    73→    await runAuditCmd([]);\n    74→\n    75→    expect(mockFailOutput).toHaveBeenCalledWith(\n    76→      'Harness not initialized -- run codeharness init first',\n    77→    );\n    78→    expect(process.exitCode).toBe(1);\n    79→  });\n    80→\n    81→  it('exits with JSON fail when not initialized with --json', async () => {\n    82→    mockRunPreconditions.mockReturnValue({\n    83→      canProceed: false,\n    84→      warnings: [],\n    85→      initialized: false,\n    86→      bmad: false,\n    87→      hooks: false,\n    88→    });\n    89→\n    90→    await runAuditCmd(['--json']);\n    91→\n    92→    expect(mockJsonOutput).toHaveBeenCalledWith({\n    93→      status: 'fail',\n    94→      message: 'Harness not initialized -- run codeharness init first',\n    95→    });\n    96→    expect(process.exitCode).toBe(1);\n    97→  });\n    98→\n    99→  it('produces valid JSON with --json flag', async () => {\n   100→    mockRunPreconditions.mockReturnValue({\n   101→      canProceed: true,\n   102→      warnings: [],\n   103→      initialized: true,\n   104→      bmad: true,\n   105→      hooks: true,\n   106→    });\n   107→    mockRunAudit.mockResolvedValue({\n   108→      success: true,\n   109→      data: {\n   110→        dimensions: {},\n   111→        overallStatus: 'pass',\n   112→        gapCount: 0,\n   113→        durationMs: 100,\n   114→      },\n   115→    });\n   116→    mockFormatAuditJson.mockReturnValue({ dimensions: {}, overallStatus: 'pass', gapCount: 0, durationMs: 100 });\n   117→\n   118→    await runAuditCmd(['--json']);\n   119→\n   120→    expect(mockJsonOutput).toHaveBeenCalledWith(\n   121→      expect.objectContaining({ overallStatus: 'pass' }),\n   122→    );\n   123→  });\n   124→\n   125→  it('formats human output when no --json flag', async () => {\n   126→    mockRunPreconditions.mockReturnValue({\n   127→      canProceed: true,\n   128→      warnings: [],\n   129→      initialized: true,\n   130→      bmad: true,\n   131→      hooks: true,\n   132→    });\n   133→    mockRunAudit.mockResolvedValue({\n   134→      success: true,\n   135→      data: {\n   136→        dimensions: {},\n   137→        overallStatus: 'pass',\n   138→        gapCount: 0,\n   139→        durationMs: 100,\n   140→      },\n   141→    });\n   142→    mockFormatAuditHuman.mockReturnValue(['[OK] all good']);\n   143→\n   144→    const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n   145→    await runAuditCmd([]);\n   146→    expect(mockFormatAuditHuman).toHaveBeenCalled();\n   147→    consoleSpy.mockRestore();\n   148→  });\n   149→\n   150→  it('sets exit code 1 when overall status is fail', async () => {\n   151→    mockRunPreconditions.mockReturnValue({\n   152→      canProceed: true,\n   153→      warnings: [],\n   154→      initialized: true,\n   155→      bmad: true,\n   156→      hooks: true,\n   157→    });\n   158→    mockRunAudit.mockResolvedValue({\n   159→      success: true,\n   160→      data: {\n   161→        dimensions: {},\n   162→        overallStatus: 'fail',\n   163→        gapCount: 2,\n   164→        durationMs: 100,\n   165→      },\n   166→    });\n   167→    mockFormatAuditHuman.mockReturnValue(['[FAIL] testing: 30%']);\n   168→\n   169→    const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n   170→    await runAuditCmd([]);\n   171→    expect(process.exitCode).toBe(1);\n   172→    consoleSpy.mockRestore();\n   173→  });\n   174→});\n   175→"}]},"parent_tool_use_id":"toolu_01UmDTVZ4iS72Xuw7ncmN4YZ","session_id":"e1f3df9b-d919-466e-880e-1001c8652ee8","uuid":"f0a681b5-f2b1-46a2-86fd-d8ffefaff0dd","timestamp":"2026-03-20T08:52:14.463Z"}
