{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EG7Za6ENe7uDAqZSBCEVDx","type":"tool_result","content":"     1→/**\n     2→ * Migration from old scattered state files to unified sprint-state.json.\n     3→ * Runs once when sprint-state.json does not exist and old files are found.\n     4→ */\n     5→\n     6→import { readFileSync, existsSync } from 'node:fs';\n     7→import { join } from 'node:path';\n     8→import { ok, fail } from '../../types/result.js';\n     9→import type { Result } from '../../types/result.js';\n    10→import type { SprintState, StoryState, StoryStatus, ActionItem } from '../../types/state.js';\n    11→import { defaultState, writeStateAtomic, computeSprintCounts } from './state.js';\n    12→\n    13→const OLD_FILES = {\n    14→  storyRetries: 'ralph/.story_retries',\n    15→  flaggedStories: 'ralph/.flagged_stories',\n    16→  ralphStatus: 'ralph/status.json',\n    17→  sprintStatusYaml: '_bmad-output/implementation-artifacts/sprint-status.yaml',\n    18→  sessionIssues: '_bmad-output/implementation-artifacts/.session-issues.md',\n    19→} as const;\n    20→\n    21→function resolve(relative: string): string {\n    22→  return join(process.cwd(), relative);\n    23→}\n    24→\n    25→function readIfExists(relative: string): string | null {\n    26→  const p = resolve(relative);\n    27→  if (!existsSync(p)) return null;\n    28→  try { return readFileSync(p, 'utf-8'); } catch { return null; }\n    29→}\n    30→\n    31→/** Return a fresh empty StoryState */\n    32→function emptyStory(): StoryState {\n    33→  return {\n    34→    status: 'backlog', attempts: 0, lastAttempt: null,\n    35→    lastError: null, proofPath: null, acResults: null,\n    36→  };\n    37→}\n    38→\n    39→/** Ensure a story entry exists, then apply a partial update */\n    40→function upsertStory(\n    41→  stories: Record<string, StoryState>,\n    42→  key: string,\n    43→  patch: Partial<StoryState>,\n    44→): void {\n    45→  stories[key] = { ...(stories[key] ?? emptyStory()), ...patch };\n    46→}\n    47→\n    48→/** Parse ralph/.story_retries: \"<key> <count>\" per line */\n    49→function parseStoryRetries(content: string, stories: Record<string, StoryState>): void {\n    50→  for (const line of content.split('\\n')) {\n    51→    const trimmed = line.trim();\n    52→    if (!trimmed) continue;\n    53→    const parts = trimmed.split(/\\s+/);\n    54→    if (parts.length < 2) continue;\n    55→    const count = parseInt(parts[1], 10);\n    56→    if (!isNaN(count)) upsertStory(stories, parts[0], { attempts: count });\n    57→  }\n    58→}\n    59→\n    60→/** Parse ralph/.flagged_stories: one key per line */\n    61→function parseFlaggedStories(content: string, stories: Record<string, StoryState>): void {\n    62→  for (const line of content.split('\\n')) {\n    63→    const key = line.trim();\n    64→    if (key) upsertStory(stories, key, { status: 'blocked' });\n    65→  }\n    66→}\n    67→\n    68→/** Map YAML status strings to StoryStatus */\n    69→function mapYamlStatus(value: string): StoryStatus | null {\n    70→  const mapping: Record<string, StoryStatus> = {\n    71→    done: 'done', backlog: 'backlog', verifying: 'verifying',\n    72→    'in-progress': 'in-progress', 'ready-for-dev': 'ready',\n    73→    blocked: 'blocked', failed: 'failed', review: 'review', ready: 'ready',\n    74→  };\n    75→  return mapping[value.trim().toLowerCase()] ?? null;\n    76→}\n    77→\n    78→/**\n    79→ * Parse sprint-status.yaml (flat key: value).\n    80→ * Story lines like \"  1-1-result-type: done\" become entries.\n    81→ * Epic lines like \"  epic-1: done\" are skipped.\n    82→ */\n    83→function parseSprintStatusYaml(content: string, stories: Record<string, StoryState>): void {\n    84→  for (const line of content.split('\\n')) {\n    85→    const trimmed = line.trim();\n    86→    if (!trimmed || trimmed.startsWith('#')) continue;\n    87→    const match = trimmed.match(/^([a-zA-Z0-9_-