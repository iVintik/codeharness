key: '3-3',\n   344→      message: 'verification found 2 failing ACs → returning to dev (attempt 2/10)',\n   345→      details: [\n   346→        'AC 3: bridge --dry-run output missing epic headers',\n   347→        'AC 7: bridge creates duplicate beads issues',\n   348→      ],\n   349→    };\n   350→    const { lastFrame } = render(<StoryMessageLine msg={msg} />);\n   351→    const frame = lastFrame()!;\n   352→    expect(frame).toContain('[WARN]');\n   353→    expect(frame).toContain('Story 3-3');\n   354→    expect(frame).toContain('2 failing ACs');\n   355→    expect(frame).toContain('└ AC 3');\n   356→    expect(frame).toContain('└ AC 7');\n   357→  });\n   358→\n   359→  it('renders [FAIL] message', () => {\n   360→    const msg: StoryMessage = { type: 'fail', key: '2-3', message: 'verification failed at AC 4 (attempt 3/10)' };\n   361→    const { lastFrame } = render(<StoryMessageLine msg={msg} />);\n   362→    const frame = lastFrame()!;\n   363→    expect(frame).toContain('[FAIL]');\n   364→    expect(frame).toContain('Story 2-3');\n   365→  });\n   366→\n   367→  it('renders [OK] with detail lines for proof, duration, and cost', () => {\n   368→    const msg: StoryMessage = {\n   369→      type: 'ok',\n   370→      key: '3-2',\n   371→      message: 'DONE — 12/12 ACs verified',\n   372→      details: [\n   373→        'Proof: verification/3-2-proof.md',\n   374→        'Duration: 18m | Cost: $4.20',\n   375→      ],\n   376→    };\n   377→    const { lastFrame } = render(<StoryMessageLine msg={msg} />);\n   378→    const frame = lastFrame()!;\n   379→    expect(frame).toContain('[OK]');\n   380→    expect(frame).toContain('Story 3-2: DONE');\n   381→    expect(frame).toContain('└ Proof: verification/3-2-proof.md');\n   382→    expect(frame).toContain('└ Duration: 18m | Cost: $4.20');\n   383→  });\n   384→});\n   385→\n   386→describe('App component', () => {\n   387→  it('renders all elements when state is full', () => {\n   388→    const state = makeState({\n   389→      sprintInfo: {\n   390→        storyKey: '1-2-3',\n   391→        phase: 'dev',\n   392→        done: 1,\n   393→        total: 5,\n   394→        iterationCount: 1,\n   395→        totalCost: 2.50,\n   396→      },\n   397→      completedTools: [{ name: 'Bash', args: 'echo hello' }],\n   398→      activeTool: { name: 'Read' },\n   399→      lastThought: 'analyzing...',\n   400→      retryInfo: null,\n   401→    });\n   402→    const { lastFrame } = render(<App state={state} />);\n   403→    const frame = lastFrame()!;\n   404→    expect(frame).toContain('codeharness run');\n   405→    expect(frame).toContain('Story: 1-2-3');\n   406→    expect(frame).toContain('✓');\n   407→    expect(frame).toContain('[Bash]');\n   408→    expect(frame).toContain('⚡');\n   409→    expect(frame).toContain('[Read]');\n   410→    expect(frame).toContain('💭');\n   411→    expect(frame).toContain('analyzing...');\n   412→  });\n   413→\n   414→  it('renders empty state without errors', () => {\n   415→    const state = makeState();\n   416→    const { lastFrame } = render(<App state={state} />);\n   417→    expect(lastFrame()).toBeDefined();\n   418→  });\n   419→\n   420→  it('renders retry info when present', () => {\n   421→    const state = makeState({\n   422→      retryInfo: { attempt: 3, delay: 10000 },\n   423→    });\n   424→    const { lastFrame } = render(<App state={state} />);\n   425→    const frame = lastFrame()!;\n   426→    expect(frame).toContain('⏳');\n   427→    expect(frame).toContain('3');\n   428→  });\n   429→\n   430→  it('renders bottom separator after story breakdown', () => {\n   431→    const state = makeState({\n   432→      sprintInfo: { storyKey: '3-2', phase: 'dev', done: 1, total: 5 },\n   433→      stories: [\n   434→        { key: '3-1-done', status: 'done' },\n   435→        { key: '3-2-current', status: 'in-progress' },\n   436→      ],\n   437→    });\n   438→    const { lastFrame } = render(<App state={state} />);\n   439→    const frame = lastFrame()!;\n   440→    // Should have separators\n   441→    const separatorCount = (frame.match(/━━━/g) || []).length;\n   442→    expect(separatorCount).toBeGreaterThanOrEqual(2); // header separator + bottom separator\n   443→  });\n   444→});\n   445→\n   446→// --- Controller API Tests ---\n   447→\n   448→describe('startRenderer', () => {\n   449→  let handle: RendererHandle | null = null;\n   450→\n   451→  afterEach(() => {\n   452→    if (handle) {\n   453→      handle.cleanup();\n   454→      handle = null;\n   455→    }\n   456→  });\n   457→\n   458→  describe('quiet mode (AC #8)', () => {\n   459→    it('returns no-op handle when quiet is true', () => {\n   460→      handle = startRenderer({ quiet: true });\n   461→      handle.update({ type: 'tool-start', name: 'Bash', id: 'x' });\n   462→      handle.update({ type: 'tool-complete' });\n   463→      handle.update({ type: 'text', text: 'hello' });\n   464→      handle.updateSprintState({ storyKey: 'a', phase: 'b', done: 1, total: 2 });\n   465→      handle.updateStories([{ key: '1-1', status: 'done' }]);\n   466→      handle.addMessage({ type: 'ok', key: '1-1', message: 'DONE' });\n   467→      handle.cleanup();\n   468→      handle.cleanup();\n   469→    });\n   470→  });\n   471→\n   472→  describe('event handling', () => {\n   473→    it('handles tool-start event', () => {\n   474→      handle = startRenderer({ _forceTTY: true });\n   475→      handle.update({ type: 'tool-start', name: 'Bash', id: 'tool1' });\n   476→    });\n   477→\n   478→    it('handles tool-complete after tool-start (moves to completed)', () => {\n   479→      handle = startRenderer({ _forceTTY: true });\n   480→      handle.update({ type: 'tool-start', name: 'Bash', id: 'tool1' });\n   481→      handle.update({ type: 'tool-input', partial: '{\"command\":' });\n   482→      handle.update({ type: 'tool-input', partial: '\"ls\"}' });\n   483→      handle.update({ type: 'tool-complete' });\n   484→    });\n   485→\n   486→    it('handles tool-complete when no activeTool (text block stop)', () => {\n   487→      handle = startRenderer({ _forceTTY: true });\n   488→      handle.update({ type: 'tool-complete' });\n   489→    });\n   490→\n   491→    it('handles text event', () => {\n   492→      handle = startRenderer({ _forceTTY: true });\n   493→      handle.update({ type: 'text', text: 'thinking...' });\n   494→    });\n   495→\n   496→    it('handles retry event', () => {\n   497→      handle = startRenderer({ _forceTTY: true });\n   498→      handle.update({ type: 'retry', attempt: 1, delay: 5000 });\n   499→    });\n   500→\n   501→    it('handles result event and accumulates cost', () => {\n   502→      handle = startRenderer({\n   503→        sprintState: { storyKey: 'a', phase: 'b', done: 1, total: 2 },\n   504→        _forceTTY: true,\n   505→      });\n   506→      handle.update({ type: 'result', cost: 0.05, sessionId: 'sess_123' });\n   507→      // Cost should be accumulated in sprintInfo\n   508→    });\n   509→\n   510→    it('preserves accumulated cost when updateSprintState is called without cost', () => {\n   511→      handle = startRenderer({\n   512→        sprintState: { storyKey: 'a', phase: 'b', done: 1, total: 2 },\n   513→        _forceTTY: true,\n   514→      });\n   515→      // Accumulate cost via result events\n   516→      handle.update({ type: 'result', cost: 0.05, sessionId: 'sess_1' });\n   517→      handle.update({ type: 'result', cost: 0.10, sessionId: 'sess_2' });\n   518→      // Sprint state refresh (simulating the 5s polling interval) should NOT wipe cost\n   519→      handle.updateSprintState({ storyKey: 'a', phase: 'b', done: 2, total: 5, elapsed: '5m', iterationCount: 2 });\n   520→      // Cost should still be preserved (0.15 total) — this test ensures the bug fix works\n   521→    });\n   522→\n   523→    it('clears retry on next tool-start', () => {\n   524→      handle = startRenderer({ _forceTTY: true });\n   525→      handle.update({ type: 'retry', attempt: 1, delay: 5000 });\n   526→      handle.update({ type: 'tool-start', name: 'Bash', id: 'tool1' });\n   527→    });\n   528→\n   529→    it('clears retry on next text event', () => {\n   530→      handle = startRenderer({ _forceTTY: true });\n   531→      handle.update({ type: 'retry', attempt: 1, delay: 5000 });\n   532→      handle.update({ type: 'text', text: 'thinking...' });\n   533→    });\n   534→\n   535→    it('clears lastThought on tool-start', () => {\n   536→      handle = startRenderer({ _forceTTY: true });\n   537→      handle.update({ type: 'text', text: 'old thought' });\n   538→      handle.update({ type: 'tool-start', name: 'Bash', id: 'tool1' });\n   539→    });\n   540→\n   541→    it('text event overwrites previous thought (not append)', () => {\n   542→      handle = startRenderer({ _forceTTY: true });\n   543→      handle.update({ type: 'text', text: 'first thought' });\n   544→      handle.update({ type: 'text', text: 'second thought' });\n   545→    });\n   546→\n   547→    it('accumulates tool input args', () => {\n   548→      handle = startRenderer({ _forceTTY: true });\n   549→      handle.update({ type: 'tool-start', name: 'Write', id: 'tool1' });\n   550→      handle.update({ type: 'tool-input', partial: '{\"path\":' });\n   551→      handle.update({ type: 'tool-input', partial: '\"/tmp/test.ts\",' });\n   552→      handle.update({ type: 'tool-input', partial: '\"content\":\"hello\"}' });\n   553→      handle.update({ type: 'tool-complete' });\n   554→    });\n   555→\n   556→    it('bounds completed tools list at MAX_COMPLETED_TOOLS (50)', () => {\n   557→      handle = startRenderer({ _forceTTY: true });\n   558→      for (let i = 0; i < 55; i++) {\n   559→        handle.update({ type: 'tool-start', name: `Tool${i}`, id: `t${i}` });\n   560→        handle.update({ type: 'tool-input', partial: `arg${i}` });\n   561→        handle.update({ type: 'tool-complete' });\n   562→      }\n   563→    });\n   564→\n   565→    it('handles multiple tool cycles', () => {\n   566→      handle = startRenderer({ _forceTTY: true });\n   567→      handle.update({ type: 'tool-start', name: 'Read', id: 'tool1' });\n   568→      handle.update({ type: 'tool-input', partial: '{\"path\":\"/a\"}' });\n   569→      handle.update({ type: 'tool-complete' });\n   570→      handle.update({ type: 'tool-start', name: 'Write', id: 'tool2' });\n   571→      handle.update({ type: 'tool-input', partial: '{\"path\":\"/b\"}' });\n   572→      handle.update({ type: 'tool-complete' });\n   573→    });\n   574→  });\n   575→\n   576→  describe('updateSprintState', () => {\n   577→    it('updates sprint state', () => {\n   578→      handle = startRenderer({ _forceTTY: true });\n   579→      handle.updateSprintState({\n   580→        storyKey: '0-5-3',\n   581→        phase: 'dev',\n   582→        done: 5,\n   583→        total: 12,\n   584→      });\n   585→    });\n   586→\n   587→    it('clears sprint state with undefined', () => {\n   588→      handle = startRenderer({\n   589→        sprintState: { storyKey: 'x', phase: 'dev', done: 1, total: 2 },\n   590→        _forceTTY: true,\n   591→      });\n   592→      handle.updateSprintState(undefined);\n   593→    });\n   594→  });\n   595→\n   596→  describe('updateStories (AC #4)', () => {\n   597→    it('updates story statuses', () => {\n   598→      handle = startRenderer({ _forceTTY: true });\n   599→      handle.updateStories([\n   600→        { key: '3-1', status: 'done' },\n   601→        { key: '3-2', status: 'in-progress' },\n   602→      ]);\n   603→    });\n   604→\n   605→    it('clears stories with empty array', () => {\n   606→      handle = startRenderer({ _forceTTY: true });\n   607→      handle.updateStories([{ key: '1-1', status: 'done' }]);\n   608→      handle.updateStories([]);\n   609→    });\n   610→  });\n   611→\n   612→  describe('addMessage (AC #5, #6)', () => {\n   613→    it('adds story completion message', () => {\n   614→      handle = startRenderer({ _forceTTY: true });\n   615→      handle.addMessage({ type: 'ok', key: '3-2', message: 'DONE — 12/12 ACs verified' });\n   616→    });\n   617→\n   618→    it('adds story failure message with details', () => {\n   619→      handle = startRenderer({ _forceTTY: true });\n   620→      handle.addMessage({\n   621→        type: 'warn',\n   622→        key: '3-3',\n   623→        message: 'verification found 2 failing ACs',\n   624→        details: ['AC 3: missing headers', 'AC 7: duplicate issues'],\n   625→      });\n   626→    });\n   627→\n   628→    it('accumulates multiple messages', () => {\n   629→      handle = startRenderer({ _forceTTY: true });\n   630→      handle.addMessage({ type: 'ok', key: '3-1', message: 'DONE' });\n   631→      handle.addMessage({ type: 'warn', key: '3-2', message: 'failing' });\n   632→      handle.addMessage({ type: 'fail', key: '2-3', message: 'failed' });\n   633→    });\n   634→  });\n   635→\n   636→  describe('quiet mode includes new methods', () => {\n   637→    it('no-op handle has updateStories and addMessage', () => {\n   638→      handle = startRenderer({ quiet: true });\n   639→      handle.updateStories([{ key: '1-1', status: 'done' }]);\n   640→      handle.addMessage({ type: 'ok', key: '1-1', message: 'DONE' });\n   641→    });\n   642→  });\n   643→\n   644→  describe('cleanup (AC #6)', () => {\n   645→    it('can be called multiple times without error', () => {\n   646→      handle = startRenderer({ _forceTTY: true });\n   647→      handle.cleanup();\n   648→      handle.cleanup();\n   649→      handle.cleanup();\n   650→      handle = null;\n   651→    });\n   652→\n   653→    it('ignores updates after cleanup', () => {\n   654→      handle = startRenderer({ _forceTTY: true });\n   655→      handle.cleanup();\n   656→      handle.update({ type: 'tool-start', name: 'Bash', id: 'x' });\n   657→      handle.update({ type: 'text', text: 'hello' });\n   658→      handle.updateSprintState({ storyKey: 'a', phase: 'b', done: 1, total: 2 });\n   659→      handle.updateStories([{ key: '1-1', status: 'done' }]);\n   660→      handle.addMessage({ type: 'ok', key: '1-1', message: 'DONE' });\n   661→      handle = null;\n   662→    });\n   663→  });\n   664→\n   665→  describe('signal handling (AC #9)', () => {\n   666→    it('cleans up and re-raises SIGINT', () => {\n   667→      handle = startRenderer({ _forceTTY: true });\n   668→      const killSpy = vi.spyOn(process, 'kill').mockImplementation(() => true);\n   669→      try {\n   670→        process.emit('SIGINT');\n   671→        expect(killSpy).toHaveBeenCalledWith(process.pid, 'SIGINT');\n   672→        handle.update({ type: 'text', text: 'should be ignored' });\n   673→      } finally {\n   674→        killSpy.mockRestore();\n   675→      }\n   676→      handle = null;\n   677→    });\n   678→\n   679→    it('cleans up and re-raises SIGTERM', () => {\n   680→      handle = startRenderer({ _forceTTY: true });\n   681→      const killSpy = vi.spyOn(process, 'kill').mockImplementation(() => true);\n   682→      try {\n   683→        process.emit('SIGTERM');\n   684→        expect(killSpy).toHaveBeenCalledWith(process.pid, 'SIGTERM');\n   685→      } finally {\n   686→        killSpy.mockRestore();\n   687→      }\n   688→      handle = null;\n   689→    });\n   690→  });\n   691→\n   692→  describe('non-TTY fallback (AC #6)', () => {\n   693→    it('returns no-op handle when stdout is not a TTY', () => {\n   694→      handle = startRenderer();\n   695→      handle.update({ type: 'tool-start', name: 'Bash', id: 'x' });\n   696→      handle.update({ type: 'tool-complete' });\n   697→      handle.cleanup();\n   698→      handle = null;\n   699→    });\n   700→  });\n   701→\n   702→  describe('initial sprint state', () => {\n   703→    it('accepts sprint state in options', () => {\n   704→      handle = startRenderer({\n   705→        sprintState: { storyKey: '1-1', phase: 'dev', done: 0, total: 5 },\n   706→        _forceTTY: true,\n   707→      });\n   708→    });\n   709→  });\n   710→});\n   711→\n   712→// --- Integration: full event sequence ---\n   713→\n   714→describe('full event sequence', () => {\n   715→  let handle: RendererHandle;\n   716→\n   717→  afterEach(() => {\n   718→    handle?.cleanup();\n   719→  });\n   720→\n   721→  it('processes a realistic stream of events', () => {\n   722→    handle = startRenderer({\n   723→      sprintState: { storyKey: '0-5-3', phase: 'dev', done: 3, total: 10 },\n   724→      _forceTTY: true,\n   725→    });\n   726→\n   727→    const events: StreamEvent[] = [\n   728→      { type: 'text', text: 'Let me analyze...' },\n   729→      { type: 'tool-complete' },\n   730→      { type: 'tool-start', name: 'Read', id: 'tool1' },\n   731→      { type: 'tool-input', partial: '{\"file_path\":\"/src/index.ts\"}' },\n   732→      { type: 'tool-complete' },\n   733→      { type: 'text', text: 'Now I understand the structure' },\n   734→      { type: 'tool-complete' },\n   735→      { type: 'tool-start', name: 'Write', id: 'tool2' },\n   736→      { type: 'tool-input', partial: '{\"file_path\":\"/src/new.ts\",' },\n   737→      { type: 'tool-input', partial: '\"content\":\"export const x = 1;\"}' },\n   738→      { type: 'tool-complete' },\n   739→      { type: 'retry', attempt: 1, delay: 5000 },\n   740→      { type: 'tool-start', name: 'Bash', id: 'tool3' },\n   741→      { type: 'tool-input', partial: '{\"command\":\"npm test\"}' },\n   742→      { type: 'tool-complete' },\n   743→      { type: 'result', cost: 0.15, sessionId: 'sess_abc' },\n   744→    ];\n   745→\n   746→    for (const event of events) {\n   747→      handle.update(event);\n   748→    }\n   749→  });\n   750→});\n   751→\n   752→// --- Visual Snapshot Test (AC #10) ---\n   753→\n   754→describe('Visual snapshot: spec-compliant output', () => {\n   755→  it('renders known state matching UX spec format', () => {\n   756→    const state = makeState({\n   757→      sprintInfo: