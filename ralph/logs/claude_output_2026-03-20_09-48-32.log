{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Tg69K7decctZJxLbiF6YW5","type":"tool_result","content":"     1→import { Command } from 'commander';\n     2→import { ok, fail, jsonOutput } from '../lib/output.js';\n     3→import { checkObservabilityCoverageGate } from '../modules/observability/index.js';\n     4→\n     5→export function registerObservabilityGateCommand(program: Command): void {\n     6→  program\n     7→    .command('observability-gate')\n     8→    .description('Check observability coverage against targets (commit gate)')\n     9→    .option('--json', 'Machine-readable JSON output')\n    10→    .option('--min-static <percent>', 'Override static coverage target')\n    11→    .option('--min-runtime <percent>', 'Override runtime coverage target')\n    12→    .action((opts, cmd) => {\n    13→      const globalOpts = cmd.optsWithGlobals();\n    14→      const isJson = opts.json === true || globalOpts.json === true;\n    15→      const root = process.cwd();\n    16→\n    17→      const overrides: { staticTarget?: number; runtimeTarget?: number } = {};\n    18→      if (opts.minStatic !== undefined) {\n    19→        overrides.staticTarget = parseInt(opts.minStatic, 10);\n    20→      }\n    21→      if (opts.minRuntime !== undefined) {\n    22→        overrides.runtimeTarget = parseInt(opts.minRuntime, 10);\n    23→      }\n    24→\n    25→      const result = checkObservabilityCoverageGate(root, overrides);\n    26→\n    27→      if (!result.success) {\n    28→        if (isJson) {\n    29→          jsonOutput({ status: 'error', message: result.error });\n    30→        } else {\n    31→          fail(`Observability gate error: ${result.error}`);\n    32→        }\n    33→        process.exitCode = 1;\n    34→        return;\n    35→      }\n    36→\n    37→      const gate = result.data;\n    38→\n    39→      if (isJson) {\n    40→        jsonOutput({\n    41→          status: gate.passed ? 'pass' : 'fail',\n    42→          passed: gate.passed,\n    43→          static: {\n    44→            current: gate.staticResult.current,\n    45→            target: gate.staticResult.target,\n    46→            met: gate.staticResult.met,\n    47→            gap: gate.staticResult.gap,\n    48→          },\n    49→          runtime: gate.runtimeResult\n    50→            ? {\n    51→                current: gate.runtimeResult.current,\n    52→                target: gate.runtimeResult.target,\n    53→                met: gate.runtimeResult.met,\n    54→                gap: gate.runtimeResult.gap,\n    55→              }\n    56→            : null,\n    57→          gaps: gate.gapSummary.map(g => ({\n    58→            file: g.file,\n    59→            line: g.line,\n    60→            type: g.type,\n    61→            description: g.description,\n    62→          })),\n    63→        });\n    64→      } else {\n    65→        const staticLine = `Static: ${gate.staticResult.current}% / ${gate.staticResult.target}% target`;\n    66→        if (gate.passed) {\n    67→          ok(`Observability gate passed. ${staticLine}`);\n    68→          if (gate.runtimeResult) {\n    69→            ok(`Runtime: ${gate.runtimeResult.current}% / ${gate.runtimeResult.target}% target`);\n    70→          }\n    71→        } else {\n    72→          fail(`Observability gate failed. ${staticLine}`);\n    73→          if (gate.runtimeResult && !gate.runtimeResult.met) {\n    74→            fail(`Runtime: ${gate.runtimeResult.current}% / ${gate.runtimeResult.target}% target`);\n    75→          }\n    76→          fail('Run `codeharness analyze` to see gaps and fix suggestions.');\n    77→        }\n    78→      }\n    79→\n    80→      if (!gate.passed) {\n    81→        process.exitCode = 1;\n    82→      }\n    83→    });\n    84→}\n    85→"}]},"parent_tool_use_id":"toolu_01L7x1Zkv5Yv1DsfgSndzqDQ","session_id":"f7a66acd-0cc1-40de-a592-d59e75273c0b","uuid":"4085449b-e658-4587-9b08-5c8d8c401924","timestamp":"2026-03-20T06:00:16.251Z"}
