{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DXNdTgUVvve3R3dpHH1Sgq","type":"tool_result","content":"80\t\n81\t/**\n82\t * Structured error recorded during workflow execution.\n83\t */\n84\texport interface EngineError {\n85\t  taskName: string;\n86\t  storyKey: string;\n87\t  code: string;\n88\t  message: string;\n89\t}\n90\t\n91\t/**\n92\t * A work item (story or issue) ready for execution.\n93\t */\n94\texport interface WorkItem {\n95\t  key: string;\n96\t  title?: string;\n97\t  source: 'sprint' | 'issues';\n98\t}\n99\t\n100\t// --- Constants ---\n101\t\n102\t/** Sentinel story key for per-run tasks. */\n103\texport const PER_RUN_SENTINEL = '__run__';\n104\t\n105\t/** DispatchError codes that should halt execution immediately. */\n106\tconst HALT_ERROR_CODES = new Set(['RATE_LIMIT', 'NETWORK', 'SDK_INIT']);\n107\t\n108\t/** Default maximum loop iterations before termination. */\n109\tconst DEFAULT_MAX_ITERATIONS = 5;\n110\t\n111\t// --- Crash Recovery: Task Completion Check ---\n112\t\n113\t/**\n114\t * Check whether a (taskName, storyKey) combination is already recorded\n115\t * in the workflow state's tasks_completed array.\n116\t *\n117\t * Both fields must match for the task to be considered completed.\n118\t * Used by the resume logic to skip already-completed dispatches.\n119\t */\n120\texport function isTaskCompleted(\n121\t  state: WorkflowState,\n122\t  taskName: string,\n123\t  storyKey: string,\n124\t): boolean {\n125\t  return state.tasks_completed.some(\n126\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey && !cp.error,\n127\t  );\n128\t}\n129\t\n130\t/**\n131\t * Check whether a (taskName, storyKey) combination has been completed\n132\t * enough times to cover the current iteration in a loop block.\n133\t *\n134\t * Loop tasks execute the same (taskName, storyKey) pair each iteration,\n135\t * recording a new checkpoint each time. To determine if a task is done\n136\t * for the current iteration, we count how many matching checkpoints exist\n137\t * and compare to the current iteration number.\n138\t */\n139\texport function isLoopTaskCompleted(\n140\t  state: WorkflowState,\n141\t  taskName: string,\n142\t  storyKey: string,\n143\t  iteration: number,\n144\t): boolean {\n145\t  const count = state.tasks_completed.filter(\n146\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey && !cp.error,\n147\t  ).length;\n148\t  return count >= iteration;\n149\t}\n150\t\n151\t// --- Work Item Loading ---\n152\t\n153\t/**\n154\t * Load work items from sprint-status.yaml and optionally issues.yaml.\n155\t *\n156\t * Stories are extracted from the `development_status` section of sprint-status.yaml.\n157\t * Issues are extracted from the `issues` array of issues.yaml.\n158\t *\n159\t * Only items with status `backlog` or `ready-for-dev` are included.\n160\t * Epic keys (`epic-*`) and retrospective keys (`*-retrospective`) are excluded.\n161\t *\n162\t * If issues.yaml does not exist, returns only stories (no error).\n163\t */\n164\texport function loadWorkItems(sprintStatusPath: string, issuesPath?: string): WorkItem[] {\n165\t  const items: WorkItem[] = [];\n166\t\n167\t  // --- Load stories from sprint-status.yaml ---\n168\t  if (existsSync(sprintStatusPath)) {\n169\t    let raw: string;\n170\t    try {\n171\t      raw = readFileSync(sprintStatusPath, 'utf-8');\n172\t    } catch { // IGNORE: unreadable file — warn and return empty\n173\t      warn(`workflow-engine: could not read sprint-status.yaml at ${sprintStatusPath}`);\n174\t      return items;\n175\t    }\n176\t\n177\t    let parsed: unknown;\n178\t    try {\n179\t      parsed = parse(raw);"}]},"parent_tool_use_id":"toolu_011M8ZBuds1zdWKjWaZPai8m","session_id":"452c48b4-eed2-4c96-83e9-8c71df0bbdac","uuid":"7b21b291-7140-4443-93fe-2e26280f5dda","timestamp":"2026-04-02T23:13:39.875Z"}
