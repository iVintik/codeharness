{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014QvXugSJVPZhDQFoyEnS5s","type":"tool_result","content":"100\t// --- Crash Recovery: Task Completion Check ---\n101\t\n102\t/**\n103\t * Check whether a (taskName, storyKey) combination is already recorded\n104\t * in the workflow state's tasks_completed array.\n105\t *\n106\t * Both fields must match for the task to be considered completed.\n107\t * Used by the resume logic to skip already-completed dispatches.\n108\t */\n109\texport function isTaskCompleted(\n110\t  state: WorkflowState,\n111\t  taskName: string,\n112\t  storyKey: string,\n113\t): boolean {\n114\t  return state.tasks_completed.some(\n115\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey && !cp.error,\n116\t  );\n117\t}\n118\t\n119\t/**\n120\t * Check whether a (taskName, storyKey) combination has been completed\n121\t * enough times to cover the current iteration in a loop block.\n122\t *\n123\t * Loop tasks execute the same (taskName, storyKey) pair each iteration,\n124\t * recording a new checkpoint each time. To determine if a task is done\n125\t * for the current iteration, we count how many matching checkpoints exist\n126\t * and compare to the current iteration number.\n127\t */\n128\texport function isLoopTaskCompleted(\n129\t  state: WorkflowState,\n130\t  taskName: string,\n131\t  storyKey: string,\n132\t  iteration: number,\n133\t): boolean {\n134\t  const count = state.tasks_completed.filter(\n135\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey && !cp.error,\n136\t  ).length;\n137\t  return count >= iteration;\n138\t}\n139\t\n140\t// --- Work Item Loading ---\n141\t\n142\t/**\n143\t * Load work items from sprint-status.yaml and optionally issues.yaml.\n144\t *\n145\t * Stories are extracted from the `development_status` section of sprint-status.yaml.\n146\t * Issues are extracted from the `issues` array of issues.yaml.\n147\t *\n148\t * Only items with status `backlog` or `ready-for-dev` are included.\n149\t * Epic keys (`epic-*`) and retrospective keys (`*-retrospective`) are excluded.\n150\t *\n151\t * If issues.yaml does not exist, returns only stories (no error).\n152\t */\n153\texport function loadWorkItems(sprintStatusPath: string, issuesPath?: string): WorkItem[] {\n154\t  const items: WorkItem[] = [];\n155\t\n156\t  // --- Load stories from sprint-status.yaml ---\n157\t  if (existsSync(sprintStatusPath)) {\n158\t    let raw: string;\n159\t    try {\n160\t      raw = readFileSync(sprintStatusPath, 'utf-8');\n161\t    } catch { // IGNORE: unreadable file — warn and return empty\n162\t      warn(`workflow-engine: could not read sprint-status.yaml at ${sprintStatusPath}`);\n163\t      return items;\n164\t    }\n165\t\n166\t    let parsed: unknown;\n167\t    try {\n168\t      parsed = parse(raw);\n169\t    } catch { // IGNORE: malformed YAML — warn and return empty\n170\t      warn(`workflow-engine: invalid YAML in sprint-status.yaml at ${sprintStatusPath}`);\n171\t      return items;\n172\t    }\n173\t\n174\t    if (parsed && typeof parsed === 'object') {\n175\t      const data = parsed as Record<string, unknown>;\n176\t      const devStatus = data.development_status as Record<string, unknown> | undefined;\n177\t\n178\t      if (devStatus && typeof devStatus === 'object') {\n179\t        for (const [key, status] of Object.entries(devStatus)) {\n180\t          // Skip epic keys and retrospective keys\n181\t          if (key.startsWith('epic-')) continue;\n182\t          if (key.endsWith('-retrospective')) continue;\n183\t\n184\t          // Only include backlog or ready-for-dev\n185\t          if (status === 'backlog' || status === 'ready-for-dev') {\n186\t            items.push({ key, source: 'sprint' });\n187\t          }\n188\t        }\n189\t      }\n190\t    }\n191\t  }\n192\t\n193\t  // --- Load issues from issues.yaml ---\n194\t  if (issuesPath && existsSync(issuesPath)) {\n195\t    let raw: string;\n196\t    try {\n197\t      raw = readFileSync(issuesPath, 'utf-8');\n198\t    } catch { // IGNORE: unreadable issues file — warn and return what we have\n199\t      warn(`workflow-engine: could not read issues.yaml at ${issuesPath}`);\n200\t      return items;\n201\t    }\n202\t\n203\t    let parsed: unknown;\n204\t    try {\n205\t      parsed = parse(raw);\n206\t    } catch { // IGNORE: malformed issues YAML — warn and return what we have\n207\t      warn(`workflow-engine: invalid YAML in issues.yaml at ${issuesPath}`);\n208\t      return items;\n209\t    }\n210\t\n211\t    if (parsed && typeof parsed === 'object') {\n212\t      const data = parsed as Record<string, unknown>;\n213\t      const issuesList = data.issues as Array<Record<string, unknown>> | undefined;\n214\t\n215\t      if (Array.isArray(issuesList)) {\n216\t        for (const issue of issuesList) {\n217\t          if (issue && typeof issue === 'object') {\n218\t            const status = issue.status as string | undefined;\n219\t            if (status === 'backlog' || status === 'ready-for-dev') {\n220\t              items.push({\n221\t                key: issue.id as string,\n222\t                title: issue.title as string | undefined,\n223\t                source: 'issues',\n224\t              });\n225\t            }\n226\t          }\n227\t        }\n228\t      }\n229\t    }\n230\t  }\n231\t\n232\t  return items;\n233\t}\n234\t\n235\t// --- Single Task Dispatch ---\n236\t\n237\t/**\n238\t * Dispatch a single task for a specific work item (or per-run sentinel).\n239\t *\n240\t * Handles: trace ID generation, session resolution, source isolation,\n241\t * agent dispatch, state checkpointing, and cleanup.\n242\t *\n243\t * Returns the updated workflow state after recording the dispatch.\n244\t */\n245\texport async function dispatchTask(\n246\t  task: ResolvedTask,\n247\t  taskName: string,\n248\t  storyKey: string,\n249\t  definition: SubagentDefinition,\n250\t  state: WorkflowState,\n251\t  config: EngineConfig,\n252\t  customPrompt?: string,\n253\t  previousOutputContract?: OutputContract,\n254\t): Promise<WorkflowState> {\n255\t  const { updatedState } = await dispatchTaskWithResult(\n256\t    task, taskName, storyKey, definition, state, config, customPrompt, previousOutputContract,\n257\t  );\n258\t  return updatedState;\n259\t}\n260\t\n261\t/** Tool names that indicate file write/edit operations across different drivers. */\n262\tconst FILE_WRITE_TOOL_NAMES = new Set([\n263\t  'Write', 'Edit', 'write_to_file', 'edit_file',\n264\t  'write', 'edit', 'WriteFile', 'EditFile',\n265\t]);\n266\t\n267\t// --- Flow Step Type Guard ---\n268\t\n269\tfunction isLoopBlock(step: FlowStep): step is LoopBlock {\n270\t  return typeof step === 'object' && step !== null && 'loop' in step;\n271\t}\n272\t\n273\t// --- Core Dispatch (shared by dispatchTask and loop block execution) ---\n274\t\n275\t/**\n276\t * Dispatch a task and return both the updated state and the raw dispatch output.\n277\t * This is the single implementation of task dispatch logic. Both `dispatchTask()`\n278\t * and loop block execution delegate here.\n279\t */\n280\tasync function dispatchTaskWithResult(\n281\t  task: ResolvedTask,\n282\t  taskName: string,\n283\t  storyKey: string,\n284\t  definition: SubagentDefinition,\n285\t  state: WorkflowState,\n286\t  config: EngineConfig,\n287\t  customPrompt?: string,\n288\t  previousOutputContract?: OutputContract,\n289\t): Promise<{ updatedState: WorkflowState; output: string; contract: OutputContract | null }> {\n290\t  const projectDir = config.projectDir ?? process.cwd();\n291\t\n292\t  // 1. Generate trace ID\n293\t  const traceId = generateTraceId(config.runId, state.iteration, taskName);\n294\t\n295\t  // 2. Format trace prompt — injected into driver via DispatchOpts.appendSystemPrompt\n296\t  const tracePrompt = formatTracePrompt(traceId);\n297\t\n298\t  // 3. Resolve session ID\n299\t  const sessionKey: SessionLookupKey = { taskName, storyKey };"}]},"parent_tool_use_id":"toolu_01UsAm2qXT84D1u4sW8gSAmJ","session_id":"a29ee53b-c2b0-4802-9455-7215112648b1","uuid":"87e4d5ae-5b99-4968-a8ab-bcf39f91d931","timestamp":"2026-04-03T11:58:33.182Z"}
