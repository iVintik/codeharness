meResult!.target).toBe(50);\n   240→    }\n   241→  });\n   242→});\n   243→\n   244→// ============================================================\n   245→// Gap summary\n   246→// ============================================================\n   247→\n   248→describe('checkObservabilityCoverageGate — gap summary', () => {\n   249→  it('returns empty gap list when no gaps are cached', () => {\n   250→    mockExistsSync.mockReturnValue(true);\n   251→    mockReadFileSync.mockReturnValue(\n   252→      makeState({\n   253→        static: { coveragePercent: 72, lastScanTimestamp: '', history: [] },\n   254→        targets: { staticTarget: 80 },\n   255→      }),\n   256→    );\n   257→\n   258→    const result = checkObservabilityCoverageGate('/project');\n   259→    expect(result.success).toBe(true);\n   260→    if (result.success) {\n   261→      expect(result.data.gapSummary).toEqual([]);\n   262→    }\n   263→  });\n   264→\n   265→  it('returns cached gaps from sprint-state.json', () => {\n   266→    mockExistsSync.mockReturnValue(true);\n   267→    mockReadFileSync.mockReturnValue(\n   268→      makeState({\n   269→        static: {\n   270→          coveragePercent: 72,\n   271→          lastScanTimestamp: '',\n   272→          history: [],\n   273→          gaps: [\n   274→            { file: 'src/foo.ts', line: 10, type: 'catch-without-logging', description: 'Missing log in catch', severity: 'error' },\n   275→            { file: 'src/bar.ts', line: 25, type: 'function-no-debug-log', description: 'No debug log', severity: 'warning' },\n   276→          ],\n   277→        },\n   278→        targets: { staticTarget: 80 },\n   279→      }),\n   280→    );\n   281→\n   282→    const result = checkObservabilityCoverageGate('/project');\n   283→    expect(result.success).toBe(true);\n   284→    if (result.success) {\n   285→      expect(result.data.gapSummary).toHaveLength(2);\n   286→      expect(result.data.gapSummary[0]).toEqual({\n   287→        file: 'src/foo.ts',\n   288→        line: 10,\n   289→        type: 'catch-without-logging',\n   290→        description: 'Missing log in catch',\n   291→        severity: 'error',\n   292→      });\n   293→      expect(result.data.gapSummary[1]).toEqual({\n   294→        file: 'src/bar.ts',\n   295→        line: 25,\n   296→        type: 'function-no-debug-log',\n   297→        description: 'No debug log',\n   298→        severity: 'warning',\n   299→      });\n   300→    }\n   301→  });\n   302→\n   303→  it('handles malformed gap entries gracefully', () => {\n   304→    mockExistsSync.mockReturnValue(true);\n   305→    mockReadFileSync.mockReturnValue(\n   306→      makeState({\n   307→        static: {\n   308→          coveragePercent: 72,\n   309→          lastScanTimestamp: '',\n   310→          history: [],\n   311→          gaps: [\n   312→            { file: 'src/foo.ts', line: 10, type: 'catch-without-logging', description: 'Valid gap', severity: 'error' },\n   313→            { file: 'src/bad.ts' }, // missing required fields\n   314→            null,\n   315→            'not an object',\n   316→          ],\n   317→        },\n   318→        targets: { staticTarget: 80 },\n   319→      }),\n   320→    );\n   321→\n   322→    const result = checkObservabilityCoverageGate('/project');\n   323→    expect(result.success).toBe(true);\n   324→    if (result.success) {\n   325→      expect(result.data.gapSummary).toHaveLength(1);\n   326→      expect(result.data.gapSummary[0].file).toBe('src/foo.ts');\n   327→    }\n   328→  });\n   329→});\n   330→\n   331→// ============================================================\n   332→// Error handling\n   333→// ============================================================\n   334→\n   335→describe('checkObservabilityCoverageGate — errors', () => {\n   336→  it('rejects empty projectDir', () => {\n   337→    const result = checkObservabilityCoverageGate('');\n   338→    expect(result.success).toBe(false);\n   339→    if (!result.success) {\n   340→      expect(result.error).toContain('projectDir is required');\n   341→    }\n   342→  });\n   343→\n   344→  it('propagates state read errors', () => {\n   345→    mockExistsSync.mockReturnValue(true);\n   346→    mockReadFileSync.mockImplementation(() => {\n   347→      throw new Error('EACCES');\n   348→    });\n   349→\n   350→    const result = checkObservabilityCoverageGate('/project');\n   351→    expect(result.success).toBe(false);\n   352→    if (!result.success) {\n   353→      expect(result.error).toContain('Failed to read sprint-state.json');\n   354→    }\n   355→  });\n   356→\n   357→  it('uses default targets when no state file exists', () => {\n   358→    mockExistsSync.mockReturnValue(false);\n   359→\n   360→    const result = checkObservabilityCoverageGate('/project');\n   361→    expect(result.success).toBe(true);\n   362→    if (result.success) {\n   363→      // 0% coverage vs 80% default target = fail\n   364→      expect(result.data.passed).toBe(false);\n   365→      expect(result.data.staticResult.target).toBe(80);\n   366→      expect(result.data.staticResult.current).toBe(0);\n   367→    }\n   368→  });\n   369→\n   370→  it('uses default runtime target (60) when not specified in state', () => {\n   371→    mockExistsSync.mockReturnValue(true);\n   372→    mockReadFileSync.mockReturnValue(\n   373→      makeState({\n   374→        static: { coveragePercent: 85, lastScanTimestamp: '', history: [] },\n   375→        runtime: {\n   376→          coveragePercent: 55,\n   377→          lastValidationTimestamp: '',\n   378→          modulesWithTelemetry: 1,\n   379→          totalModules: 2,\n   380→          telemetryDetected: true,\n   381→        },\n   382→        targets: { staticTarget: 80 },\n   383→        // Note: no runtimeTarget in targets\n   384→      }),\n   385→    );\n   386→\n   387→    const result = checkObservabilityCoverageGate('/project');\n   388→    expect(result.success).toBe(true);\n   389→    if (result.success) {\n   390→      expect(result.data.runtimeResult!.target).toBe(60);\n   391→      expect(result.data.runtimeResult!.met).toBe(false);\n   392→    }\n   393→  });\n   394→});\n   395→"}]},"parent_tool_use_id":"toolu_014QEC8wgRDzeoWECp9trCxd","session_id":"c5eaf6a6-ac7c-4707-b82c-6220d711aa9c","uuid":"58a7ce6e-ccb6-4bd8-b045-028a5ba0c1d1","timestamp":"2026-03-20T06:37:50.105Z"}
