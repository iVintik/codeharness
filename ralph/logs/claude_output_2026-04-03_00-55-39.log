{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014t9hmncfJHnUgDNMttfvNW","type":"tool_result","content":"1\timport { mkdirSync, copyFileSync, existsSync, rmSync, readdirSync } from 'node:fs';\n2\timport { join, basename } from 'node:path';\n3\timport { warn } from './output.js';\n4\timport type { DispatchOptions } from './agent-dispatch.js';\n5\t\n6\t// --- Interfaces ---\n7\t\n8\t/**\n9\t * Options for creating an isolated workspace.\n10\t */\n11\texport interface IsolationOptions {\n12\t  /** Unique run identifier used in the temp directory name. */\n13\t  runId: string;\n14\t  /** Absolute paths to story files to copy into the workspace. */\n15\t  storyFiles: string[];\n16\t}\n17\t\n18\t/**\n19\t * An isolated workspace with no source code — only story files and a verdict directory.\n20\t */\n21\texport interface IsolatedWorkspace {\n22\t  /** Root directory of the isolated workspace. */\n23\t  dir: string;\n24\t  /** Directory containing copied story files. */\n25\t  storyFilesDir: string;\n26\t  /** Directory where the evaluator writes its verdict. */\n27\t  verdictDir: string;\n28\t  /** Returns DispatchOptions with cwd set to this workspace. */\n29\t  toDispatchOptions(): DispatchOptions;\n30\t  /** Remove the workspace from disk. Idempotent — safe to call multiple times. */\n31\t  cleanup(): Promise<void>;\n32\t}\n33\t\n34\t// --- Helpers ---\n35\t\n36\t/** Sanitize runId to prevent path traversal — allow only alphanumeric, dash, underscore, dot. */\n37\tfunction sanitizeRunId(runId: string): string {\n38\t  const sanitized = runId.replace(/[^a-zA-Z0-9._-]/g, '_');\n39\t  if (sanitized.length === 0) {\n40\t    throw new Error('Source isolation: runId is empty after sanitization');\n41\t  }\n42\t  return sanitized;\n43\t}\n44\t\n45\t/** Deduplicate a filename within a directory by appending a numeric suffix. */\n46\tfunction deduplicateFilename(dir: string, name: string): string {\n47\t  if (!existsSync(join(dir, name))) {\n48\t    return name;\n49\t  }\n50\t  const dotIdx = name.lastIndexOf('.');\n51\t  const stem = dotIdx > 0 ? name.slice(0, dotIdx) : name;\n52\t  const ext = dotIdx > 0 ? name.slice(dotIdx) : '';\n53\t  let counter = 1;\n54\t  let candidate: string;\n55\t  do {\n56\t    candidate = `${stem}-${counter}${ext}`;\n57\t    counter++;\n58\t  } while (existsSync(join(dir, candidate)));\n59\t  return candidate;\n60\t}\n61\t\n62\t// --- Implementation ---\n63\t\n64\t/**\n65\t * Create an isolated workspace at /tmp/codeharness-verify-{runId}/.\n66\t *\n67\t * The workspace contains only:\n68\t *   - story-files/  — copies of the provided story files\n69\t *   - verdict/      — empty directory for evaluator output\n70\t *\n71\t * No source code, node_modules, package.json, or .git is present.\n72\t * Missing story files are skipped with a warning (no throw).\n73\t */\n74\texport async function createIsolatedWorkspace(\n75\t  options: IsolationOptions,\n76\t): Promise<IsolatedWorkspace> {\n77\t  const safeRunId = sanitizeRunId(options.runId);\n78\t  const dir = `/tmp/codeharness-verify-${safeRunId}`;\n79\t  const storyFilesDir = join(dir, 'story-files');\n80\t  const verdictDir = join(dir, 'verdict');\n81\t\n82\t  // If workspace already exists from a previous crashed run, clean it first\n83\t  if (existsSync(dir)) {\n84\t    rmSync(dir, { recursive: true, force: true });\n85\t  }\n86\t\n87\t  // Create directory structure\n88\t  mkdirSync(storyFilesDir, { recursive: true });\n89\t  mkdirSync(verdictDir, { recursive: true });\n90\t\n91\t  // Copy story files, skipping missing ones; deduplicate basenames\n92\t  for (const filePath of options.storyFiles) {\n93\t    if (!existsSync(filePath)) {\n94\t      warn(`Source isolation: story file not found, skipping: ${filePath}`);\n95\t      continue;\n96\t    }\n97\t    const name = deduplicateFilename(storyFilesDir, basename(filePath));\n98\t    const dest = join(storyFilesDir, name);\n99\t    copyFileSync(filePath, dest);\n100\t  }\n101\t\n102\t  const workspace: IsolatedWorkspace = {\n103\t    dir,\n104\t    storyFilesDir,\n105\t    verdictDir,\n106\t\n107\t    toDispatchOptions(): DispatchOptions {\n108\t      return { cwd: dir };\n109\t    },\n110\t\n111\t    async cleanup(): Promise<void> {\n112\t      if (existsSync(dir)) {\n113\t        rmSync(dir, { recursive: true, force: true });\n114\t      }\n115\t    },\n116\t  };\n117\t\n118\t  return workspace;\n119\t}\n120\t"}]},"parent_tool_use_id":"toolu_016VHKytFCmN6FUa3CVJara9","session_id":"1d3ed03d-179a-4015-85c3-0be0521b6265","uuid":"88ddd4c0-113a-4493-853d-1642bb46e391","timestamp":"2026-04-02T21:21:47.787Z"}
