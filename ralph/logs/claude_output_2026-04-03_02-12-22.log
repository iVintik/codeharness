{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WCREZM6ktQvMgd8D2r65FP","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { parse } from 'yaml';\n3\timport { warn } from './output.js';\n4\timport { dispatchAgent, DispatchError } from './agent-dispatch.js';\n5\timport type { DispatchOptions, DispatchResult } from './agent-dispatch.js';\n6\timport type { SubagentDefinition } from './agent-resolver.js';\n7\timport type { ResolvedWorkflow, ResolvedTask, FlowStep, LoopBlock } from './workflow-parser.js';\n8\timport {\n9\t  readWorkflowState,\n10\t  writeWorkflowState,\n11\t} from './workflow-state.js';\n12\timport type { WorkflowState, TaskCheckpoint } from './workflow-state.js';\n13\timport { createIsolatedWorkspace } from './source-isolation.js';\n14\timport { generateTraceId, formatTracePrompt, recordTraceId } from './trace-id.js';\n15\timport { resolveSessionId, recordSessionId } from './session-manager.js';\n16\timport type { SessionLookupKey } from './session-manager.js';\n17\t\n18\t// --- Interfaces ---\n19\t\n20\t/**\n21\t * Configuration for the workflow engine.\n22\t */\n23\texport interface EngineConfig {\n24\t  /** The resolved workflow with tasks and flow steps. */\n25\t  workflow: ResolvedWorkflow;\n26\t  /** Pre-compiled agent definitions keyed by agent name. */\n27\t  agents: Record<string, SubagentDefinition>;\n28\t  /** Path to sprint-status.yaml for work item discovery. */\n29\t  sprintStatusPath: string;\n30\t  /** Optional path to issues.yaml for additional work items. */\n31\t  issuesPath?: string;\n32\t  /** Unique identifier for this engine run. */\n33\t  runId: string;\n34\t  /** Project root directory. Defaults to process.cwd(). */\n35\t  projectDir?: string;\n36\t  /** Maximum loop iterations before termination. Defaults to 5. */\n37\t  maxIterations?: number;\n38\t}\n39\t\n40\t/**\n41\t * Evaluator verdict returned by a verify task (AD5).\n42\t */\n43\texport interface EvaluatorVerdict {\n44\t  verdict: 'pass' | 'fail';\n45\t  score: {\n46\t    passed: number;\n47\t    failed: number;\n48\t    unknown: number;\n49\t    total: number;\n50\t  };\n51\t  findings: Array<{\n52\t    ac: number;\n53\t    description: string;\n54\t    status: 'pass' | 'fail' | 'unknown';\n55\t    evidence: {\n56\t      commands_run: string[];\n57\t      output_observed: string;\n58\t      reasoning: string;\n59\t    };\n60\t  }>;\n61\t  evaluator_trace_id?: string;\n62\t  duration_seconds?: number;\n63\t}\n64\t\n65\t/**\n66\t * Result returned by executeWorkflow().\n67\t */\n68\texport interface EngineResult {\n69\t  /** Whether the workflow completed without errors. */\n70\t  success: boolean;\n71\t  /** Number of task dispatches completed. */\n72\t  tasksCompleted: number;\n73\t  /** Number of work items (stories/issues) processed. */\n74\t  storiesProcessed: number;\n75\t  /** Errors encountered during execution. */\n76\t  errors: EngineError[];\n77\t  /** Wall-clock duration of the entire workflow in milliseconds. */\n78\t  durationMs: number;\n79\t}\n80\t\n81\t/**\n82\t * Structured error recorded during workflow execution.\n83\t */\n84\texport interface EngineError {\n85\t  taskName: string;\n86\t  storyKey: string;\n87\t  code: string;\n88\t  message: string;\n89\t}\n90\t\n91\t/**\n92\t * A work item (story or issue) ready for execution.\n93\t */\n94\texport interface WorkItem {\n95\t  key: string;\n96\t  title?: string;\n97\t  source: 'sprint' | 'issues';\n98\t}\n99\t\n100\t// --- Constants ---\n101\t\n102\t/** Sentinel story key for per-run tasks. */\n103\tconst PER_RUN_SENTINEL = '__run__';\n104\t\n105\t/** DispatchError codes that should halt execution immediately. */\n106\tconst HALT_ERROR_CODES = new Set(['RATE_LIMIT', 'NETWORK', 'SDK_INIT']);\n107\t\n108\t/** Default maximum loop iterations before termination. */\n109\tconst DEFAULT_MAX_ITERATIONS = 5;\n110\t\n111\t// --- Work Item Loading ---\n112\t\n113\t/**\n114\t * Load work items from sprint-status.yaml and optionally issues.yaml.\n115\t *\n116\t * Stories are extracted from the `development_status` section of sprint-status.yaml.\n117\t * Issues are extracted from the `issues` array of issues.yaml.\n118\t *\n119\t * Only items with status `backlog` or `ready-for-dev` are included.\n120\t * Epic keys (`epic-*`) and retrospective keys (`*-retrospective`) are excluded.\n121\t *\n122\t * If issues.yaml does not exist, returns only stories (no error).\n123\t */\n124\texport function loadWorkItems(sprintStatusPath: string, issuesPath?: string): WorkItem[] {\n125\t  const items: WorkItem[] = [];\n126\t\n127\t  // --- Load stories from sprint-status.yaml ---\n128\t  if (existsSync(sprintStatusPath)) {\n129\t    let raw: string;\n130\t    try {\n131\t      raw = readFileSync(sprintStatusPath, 'utf-8');\n132\t    } catch { // IGNORE: unreadable file — warn and return empty\n133\t      warn(`workflow-engine: could not read sprint-status.yaml at ${sprintStatusPath}`);\n134\t      return items;\n135\t    }\n136\t\n137\t    let parsed: unknown;\n138\t    try {\n139\t      parsed = parse(raw);\n140\t    } catch { // IGNORE: malformed YAML — warn and return empty\n141\t      warn(`workflow-engine: invalid YAML in sprint-status.yaml at ${sprintStatusPath}`);\n142\t      return items;\n143\t    }\n144\t\n145\t    if (parsed && typeof parsed === 'object') {\n146\t      const data = parsed as Record<string, unknown>;\n147\t      const devStatus = data.development_status as Record<string, unknown> | undefined;\n148\t\n149\t      if (devStatus && typeof devStatus === 'object') {\n150\t        for (const [key, status] of Object.entries(devStatus)) {\n151\t          // Skip epic keys and retrospective keys\n152\t          if (key.startsWith('epic-')) continue;\n153\t          if (key.endsWith('-retrospective')) continue;\n154\t\n155\t          // Only include backlog or ready-for-dev\n156\t          if (status === 'backlog' || status === 'ready-for-dev') {\n157\t            items.push({ key, source: 'sprint' });\n158\t          }\n159\t        }\n160\t      }\n161\t    }\n162\t  }\n163\t\n164\t  // --- Load issues from issues.yaml ---\n165\t  if (issuesPath && existsSync(issuesPath)) {\n166\t    let raw: string;\n167\t    try {\n168\t      raw = readFileSync(issuesPath, 'utf-8');\n169\t    } catch { // IGNORE: unreadable issues file — warn and return what we have\n170\t      warn(`workflow-engine: could not read issues.yaml at ${issuesPath}`);\n171\t      return items;\n172\t    }\n173\t\n174\t    let parsed: unknown;\n175\t    try {\n176\t      parsed = parse(raw);\n177\t    } catch { // IGNORE: malformed issues YAML — warn and return what we have\n178\t      warn(`workflow-engine: invalid YAML in issues.yaml at ${issuesPath}`);\n179\t      return items;\n180\t    }\n181\t\n182\t    if (parsed && typeof parsed === 'object') {\n183\t      const data = parsed as Record<string, unknown>;\n184\t      const issuesList = data.issues as Array<Record<string, unknown>> | undefined;\n185\t\n186\t      if (Array.isArray(issuesList)) {\n187\t        for (const issue of issuesList) {\n188\t          if (issue && typeof issue === 'object') {\n189\t            const status = issue.status as string | undefined;\n190\t            if (status === 'backlog' || status === 'ready-for-dev') {\n191\t              items.push({\n192\t                key: issue.id as string,\n193\t                title: issue.title as string | undefined,\n194\t                source: 'issues',\n195\t              });\n196\t            }\n197\t          }\n198\t        }\n199\t      }\n200\t    }\n201\t  }\n202\t\n203\t  return items;\n204\t}\n205\t\n206\t// --- Single Task Dispatch ---\n207\t\n208\t/**\n209\t * Dispatch a single task for a specific work item (or per-run sentinel).\n210\t *\n211\t * Handles: trace ID generation, session resolution, source isolation,\n212\t * agent dispatch, state checkpointing, and cleanup.\n213\t *\n214\t * Returns the updated workflow state after recording the dispatch.\n215\t */\n216\texport async function dispatchTask(\n217\t  task: ResolvedTask,\n218\t  taskName: string,\n219\t  storyKey: string,\n220\t  definition: SubagentDefinition,\n221\t  state: WorkflowState,\n222\t  config: EngineConfig,\n223\t  customPrompt?: string,\n224\t): Promise<WorkflowState> {\n225\t  const projectDir = config.projectDir ?? process.cwd();\n226\t\n227\t  // 1. Generate trace ID\n228\t  const traceId = generateTraceId(config.runId, state.iteration, taskName);\n229\t\n230\t  // 2. Format trace prompt\n231\t  const tracePrompt = formatTracePrompt(traceId);\n232\t\n233\t  // 3. Resolve session ID\n234\t  const sessionKey: SessionLookupKey = { taskName, storyKey };\n235\t  const sessionId = resolveSessionId(task.session, sessionKey, state);\n236\t\n237\t  // 4. Build dispatch options based on source_access\n238\t  let dispatchOptions: DispatchOptions;\n239\t  let workspace: Awaited<ReturnType<typeof createIsolatedWorkspace>> | null = null;\n240\t\n241\t  if (task.source_access === false) {\n242\t    workspace = await createIsolatedWorkspace({ runId: config.runId, storyFiles: [] });\n243\t    dispatchOptions = {\n244\t      ...workspace.toDispatchOptions(),\n245\t      sessionId,\n246\t      appendSystemPrompt: tracePrompt,\n247\t    };\n248\t  } else {\n249\t    dispatchOptions = {\n250\t      cwd: projectDir,\n251\t      sessionId,\n252\t      appendSystemPrompt: tracePrompt,\n253\t    };\n254\t  }\n255\t\n256\t  // 5. Construct prompt\n257\t  const prompt = customPrompt\n258\t    ?? (storyKey === PER_RUN_SENTINEL\n259\t      ? `Execute task \"${taskName}\" for the current run.`\n260\t      : `Implement story ${storyKey}`);\n261\t\n262\t  // 6. Dispatch agent\n263\t  let result: DispatchResult;\n264\t  try {\n265\t    result = await dispatchAgent(definition, prompt, dispatchOptions);\n266\t  } finally {\n267\t    // Cleanup workspace regardless of dispatch success/failure\n268\t    if (workspace) {\n269\t      await workspace.cleanup();\n270\t    }\n271\t  }\n272\t\n273\t  // 7. Record session ID (if dispatch returned one)\n274\t  let updatedState = state;\n275\t  if (result.sessionId) {\n276\t    updatedState = recordSessionId(sessionKey, result.sessionId, updatedState);\n277\t  } else {\n278\t    // Append checkpoint manually when no session ID is returned\n279\t    const checkpoint: TaskCheckpoint = {\n280\t      task_name: taskName,\n281\t      story_key: storyKey,\n282\t      completed_at: new Date().toISOString(),\n283\t    };\n284\t    updatedState = {\n285\t      ...updatedState,\n286\t      tasks_completed: [...updatedState.tasks_completed, checkpoint],\n287\t    };\n288\t  }\n289\t\n290\t  // 8. Record trace ID\n291\t  updatedState = recordTraceId(traceId, updatedState);\n292\t\n293\t  // 9. Write state to disk\n294\t  writeWorkflowState(updatedState, projectDir);\n295\t\n296\t  return updatedState;\n297\t}\n298\t\n299\t// --- Flow Step Type Guard ---\n300\t\n301\tfunction isLoopBlock(step: FlowStep): step is LoopBlock {\n302\t  return typeof step === 'object' && step !== null && 'loop' in step;\n303\t}\n304\t\n305\t// --- Verdict Parsing (Task 2) ---\n306\t\n307\t/**\n308\t * Attempt to parse a DispatchResult.output string as an EvaluatorVerdict.\n309\t * Returns null if parsing fails or required fields are missing.\n310\t */\n311\texport function parseVerdict(output: string): EvaluatorVerdict | null {\n312\t  let parsed: unknown;\n313\t  try {\n314\t    parsed = JSON.parse(output);\n315\t  } catch { // IGNORE: invalid JSON means no verdict — return null\n316\t    return null;\n317\t  }\n318\t\n319\t  if (!parsed || typeof parsed !== 'object') return null;\n320\t\n321\t  const obj = parsed as Record<string, unknown>;\n322\t\n323\t  // Validate required top-level fields\n324\t  if (obj.verdict !== 'pass' && obj.verdict !== 'fail') return null;\n325\t  if (!obj.score || typeof obj.score !== 'object') return null;\n326\t  if (!Array.isArray(obj.findings)) return null;\n327\t\n328\t  const score = obj.score as Record<string, unknown>;\n329\t  if (typeof score.passed !== 'number') return null;\n330\t  if (typeof score.failed !== 'number') return null;\n331\t  if (typeof score.unknown !== 'number') return null;\n332\t  if (typeof score.total !== 'number') return null;\n333\t\n334\t  return parsed as EvaluatorVerdict;\n335\t}\n336\t\n337\t// --- Retry Prompt Construction (Task 3) ---\n338\t\n339\t/**\n340\t * Build a retry prompt with evaluator findings injected.\n341\t * Includes only failed/unknown findings.\n342\t */\n343\texport function buildRetryPrompt(storyKey: string, findings: EvaluatorVerdict['findings']): string {\n344\t  const failedFindings = findings.filter(\n345\t    (f) => f.status === 'fail' || f.status === 'unknown',\n346\t  );\n347\t\n348\t  if (failedFindings.length === 0) {\n349\t    return `Implement story ${storyKey}`;\n350\t  }\n351\t\n352\t  const formattedFindings = failedFindings\n353\t    .map((f) => {\n354\t      const status = f.status.toUpperCase();\n355\t      let entry = `AC #${f.ac} (${status}): ${f.description}`;\n356\t      if (f.evidence?.reasoning) {\n357\t        entry += `\\n  Evidence: ${f.evidence.reasoning}`;\n358\t      }\n359\t      return entry;\n360\t    })\n361\t    .join('\\n\\n');\n362\t\n363\t  return `Retry story ${storyKey}. Previous evaluator findings:\\n\\n${formattedFindings}\\n\\nFocus on fixing the failed criteria above.`;\n364\t}\n365\t\n366\t// --- Failed Story Filtering (Task 4) ---\n367\t\n368\t/**\n369\t * Determine which work items failed based on evaluator findings.\n370\t * If verdict is null (parse failure), returns all items (conservative fallback).\n371\t */\n372\texport function getFailedItems(\n373\t  verdict: EvaluatorVerdict | null,\n374\t  allItems: WorkItem[],\n375\t): WorkItem[] {\n376\t  if (!verdict) return allItems;\n377\t\n378\t  // If verdict passed, no items need retry\n379\t  if (verdict.verdict === 'pass') return [];\n380\t\n381\t  // All items are retried on failure — per-story filtering based on individual\n382\t  // story results is not possible with the current verdict shape (verdict is per-run).\n383\t  // The findings track ACs, not stories. Conservative: retry all on failure.\n384\t  return allItems;\n385\t}\n386\t\n387\t// --- Loop Block Execution (Task 5) ---\n388\t\n389\t/**\n390\t * Result of loop block execution.\n391\t */\n392\tinterface LoopBlockResult {\n393\t  state: WorkflowState;\n394\t  errors: EngineError[];\n395\t  tasksCompleted: number;\n396\t  halted: boolean;\n397\t}\n398\t\n399\t/**\n400\t * Execute a loop block: iterate tasks until pass, max iterations, or circuit breaker.\n401\t */\n402\texport async function executeLoopBlock(\n403\t  loopBlock: LoopBlock,\n404\t  state: WorkflowState,\n405\t  config: EngineConfig,\n406\t  workItems: WorkItem[],\n407\t): Promise<LoopBlockResult> {\n408\t  const projectDir = config.projectDir ?? process.cwd();\n409\t  const maxIterations = config.maxIterations ?? DEFAULT_MAX_ITERATIONS;\n410\t  const errors: EngineError[] = [];\n411\t  let tasksCompleted = 0;\n412\t  let currentState = state;\n413\t  let lastVerdict: EvaluatorVerdict | null = null;\n414\t\n415\t  // Handle empty loop block\n416\t  if (loopBlock.loop.length === 0) {\n417\t    return { state: currentState, errors, tasksCompleted, halted: false };\n418\t  }\n419\t\n420\t  while (true) {\n421\t    // 1. Increment iteration\n422\t    currentState = {\n423\t      ...currentState,\n424\t      iteration: currentState.iteration + 1,\n425\t    };\n426\t    writeWorkflowState(currentState, projectDir);\n427\t\n428\t    let haltedInLoop = false;\n429\t\n430\t    // 2. Execute each task in the loop\n431\t    for (const taskName of loopBlock.loop) {\n432\t      const task = config.workflow.tasks[taskName];\n433\t      if (!task) {\n434\t        warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n435\t        continue;\n436\t      }\n437\t\n438\t      const definition = config.agents[task.agent];\n439\t      if (!definition) {\n440\t        warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n441\t        continue;\n442\t      }\n443\t\n444\t      if (task.scope === 'per-story') {\n445\t        // Determine which items to dispatch for\n446\t        const itemsToRetry = lastVerdict ? getFailedItems(lastVerdict, workItems) : workItems;\n447\t\n448\t        for (const item of itemsToRetry) {\n449\t          // Build prompt: inject findings if we have a previous verdict\n450\t          const prompt = lastVerdict\n451\t            ? buildRetryPrompt(item.key, lastVerdict.findings)\n452\t            : undefined;\n453\t\n454\t          try {\n455\t            currentState = await dispatchTask(\n456\t              task, taskName, item.key, definition, currentState, config, prompt,\n457\t            );\n458\t            tasksCompleted++;\n459\t          } catch (err: unknown) {\n460\t            const engineError = handleDispatchError(err, taskName, item.key);\n461\t            errors.push(engineError);\n462\t            currentState = recordErrorInState(currentState, taskName, item.key, engineError);\n463\t            writeWorkflowState(currentState, projectDir);\n464\t\n465\t            if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n466\t              haltedInLoop = true;\n467\t              break;\n468\t            }\n469\t            continue;\n470\t          }\n471\t        }\n472\t\n473\t        if (haltedInLoop) break;\n474\t      } else {\n475\t        // per-run task (e.g., verify)\n476\t        try {\n477\t          // We need the dispatch result output to parse verdict\n478\t          // dispatchTask doesn't return the DispatchResult directly, so we\n479\t          // intercept via a wrapper that captures the output\n480\t          const dispatchResult = await dispatchTaskWithResult(\n481\t            task, taskName, PER_RUN_SENTINEL, definition, currentState, config,\n482\t          );\n483\t          currentState = dispatchResult.updatedState;\n484\t          tasksCompleted++;\n485\t\n486\t          // Attempt to parse verdict from output\n487\t          const verdict = parseVerdict(dispatchResult.output);\n488\t          lastVerdict = verdict;\n489\t\n490\t          // Record score in state\n491\t          if (verdict) {\n492\t            const score = {\n493\t              iteration: currentState.iteration,\n494\t              passed: verdict.score.passed,\n495\t              failed: verdict.score.failed,\n496\t              unknown: verdict.score.unknown,\n497\t              total: verdict.score.total,\n498\t              timestamp: new Date().toISOString(),\n499\t            };\n500\t            currentState = {\n501\t              ...currentState,\n502\t              evaluator_scores: [...currentState.evaluator_scores, score],\n503\t            };\n504\t          } else {\n505\t            // Parse failure: record all-UNKNOWN score\n506\t            const totalItems = workItems.length;\n507\t            const score = {\n508\t              iteration: currentState.iteration,\n509\t              passed: 0,\n510\t              failed: 0,\n511\t              unknown: totalItems,\n512\t              total: totalItems,\n513\t              timestamp: new Date().toISOString(),\n514\t            };\n515\t            currentState = {\n516\t              ...currentState,\n517\t              evaluator_scores: [...currentState.evaluator_scores, score],\n518\t            };\n519\t          }\n520\t          writeWorkflowState(currentState, projectDir);\n521\t        } catch (err: unknown) {\n522\t          const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n523\t          errors.push(engineError);\n524\t          currentState = recordErrorInState(currentState, taskName, PER_RUN_SENTINEL, engineError);\n525\t          writeWorkflowState(currentState, projectDir);\n526\t\n527\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n528\t            haltedInLoop = true;\n529\t            break;\n530\t          }\n531\t          continue;\n532\t        }\n533\t      }\n534\t    }\n535\t\n536\t    if (haltedInLoop) {\n537\t      return { state: currentState, errors, tasksCompleted, halted: true };\n538\t    }\n539\t\n540\t    // 3. Check termination conditions\n541\t    if (lastVerdict?.verdict === 'pass') {\n542\t      // Success: loop passes\n543\t      return { state: currentState, errors, tasksCompleted, halted: false };\n544\t    }\n545\t\n546\t    if (currentState.iteration >= maxIterations) {\n547\t      currentState = { ...currentState, phase: 'max-iterations' };\n548\t      writeWorkflowState(currentState, projectDir);\n549\t      return { state: currentState, errors, tasksCompleted, halted: false };\n550\t    }\n551\t\n552\t    if (currentState.circuit_breaker.triggered) {\n553\t      currentState = { ...currentState, phase: 'circuit-breaker' };\n554\t      writeWorkflowState(currentState, projectDir);\n555\t      return { state: currentState, errors, tasksCompleted, halted: false };\n556\t    }\n557\t  }\n558\t}\n559\t\n560\t/**\n561\t * Dispatch a task and return both the updated state and the raw dispatch output.\n562\t * Used by loop block execution to capture DispatchResult.output for verdict parsing.\n563\t */\n564\tasync function dispatchTaskWithResult(\n565\t  task: ResolvedTask,\n566\t  taskName: string,\n567\t  storyKey: string,\n568\t  definition: SubagentDefinition,\n569\t  state: WorkflowState,\n570\t  config: EngineConfig,\n571\t  customPrompt?: string,\n572\t): Promise<{ updatedState: WorkflowState; output: string }> {\n573\t  const projectDir = config.projectDir ?? process.cwd();\n574\t\n575\t  // 1. Generate trace ID\n576\t  const traceId = generateTraceId(config.runId, state.iteration, taskName);\n577\t\n578\t  // 2. Format trace prompt\n579\t  const tracePrompt = formatTracePrompt(traceId);\n580\t\n581\t  // 3. Resolve session ID\n582\t  const sessionKey: SessionLookupKey = { taskName, storyKey };\n583\t  const sessionId = resolveSessionId(task.session, sessionKey, state);\n584\t\n585\t  // 4. Build dispatch options based on source_access\n586\t  let dispatchOptions: DispatchOptions;\n587\t  let workspace: Awaited<ReturnType<typeof createIsolatedWorkspace>> | null = null;\n588\t\n589\t  if (task.source_access === false) {\n590\t    workspace = await createIsolatedWorkspace({ runId: config.runId, storyFiles: [] });\n591\t    dispatchOptions = {\n592\t      ...workspace.toDispatchOptions(),\n593\t      sessionId,\n594\t      appendSystemPrompt: tracePrompt,\n595\t    };\n596\t  } else {\n597\t    dispatchOptions = {\n598\t      cwd: projectDir,\n599\t      sessionId,\n600\t      appendSystemPrompt: tracePrompt,\n601\t    };\n602\t  }\n603\t\n604\t  // 5. Construct prompt\n605\t  const prompt = customPrompt\n606\t    ?? (storyKey === PER_RUN_SENTINEL\n607\t      ? `Execute task \"${taskName}\" for the current run.`\n608\t      : `Implement story ${storyKey}`);\n609\t\n610\t  // 6. Dispatch agent\n611\t  let result: DispatchResult;\n612\t  try {\n613\t    result = await dispatchAgent(definition, prompt, dispatchOptions);\n614\t  } finally {\n615\t    if (workspace) {\n616\t      await workspace.cleanup();\n617\t    }\n618\t  }\n619\t\n620\t  // 7. Record session ID\n621\t  let updatedState = state;\n622\t  if (result.sessionId) {\n623\t    updatedState = recordSessionId(sessionKey, result.sessionId, updatedState);\n624\t  } else {\n625\t    const checkpoint: TaskCheckpoint = {\n626\t      task_name: taskName,\n627\t      story_key: storyKey,\n628\t      completed_at: new Date().toISOString(),\n629\t    };\n630\t    updatedState = {\n631\t      ...updatedState,\n632\t      tasks_completed: [...updatedState.tasks_completed, checkpoint],\n633\t    };\n634\t  }\n635\t\n636\t  // 8. Record trace ID\n637\t  updatedState = recordTraceId(traceId, updatedState);\n638\t\n639\t  // 9. Write state to disk\n640\t  writeWorkflowState(updatedState, projectDir);\n641\t\n642\t  return { updatedState, output: result.output };\n643\t}\n644\t\n645\t// --- Main Execution ---\n646\t\n647\t/**\n648\t * Execute a workflow sequentially: iterate through flow steps, dispatch tasks\n649\t * per-story or per-run, checkpoint state after each dispatch.\n650\t *\n651\t * Loop blocks execute iteratively until pass, max-iterations, or circuit-breaker.\n652\t *\n653\t * Returns an EngineResult summarizing the execution.\n654\t */\n655\texport async function executeWorkflow(config: EngineConfig): Promise<EngineResult> {\n656\t  const startMs = Date.now();\n657\t  const projectDir = config.projectDir ?? process.cwd();\n658\t  const errors: EngineError[] = [];\n659\t  let tasksCompleted = 0;\n660\t  const processedStories = new Set<string>();\n661\t\n662\t  // 1. Read or initialize workflow state\n663\t  let state = readWorkflowState(projectDir);\n664\t  state = {\n665\t    ...state,\n666\t    phase: 'executing',\n667\t    started: state.started || new Date().toISOString(),\n668\t    workflow_name: config.workflow.flow.filter((s) => typeof s === 'string').join(' -> '),\n669\t  };\n670\t  writeWorkflowState(state, projectDir);\n671\t\n672\t  // 2. Load work items\n673\t  const workItems = loadWorkItems(config.sprintStatusPath, config.issuesPath);\n674\t\n675\t  // 3. Iterate through flow steps\n676\t  let halted = false;\n677\t  for (const step of config.workflow.flow) {\n678\t    if (halted) break;\n679\t\n680\t    // Execute loop blocks\n681\t    if (isLoopBlock(step)) {\n682\t      const loopResult = await executeLoopBlock(step, state, config, workItems);\n683\t      state = loopResult.state;\n684\t      errors.push(...loopResult.errors);\n685\t      tasksCompleted += loopResult.tasksCompleted;\n686\t\n687\t      // Track processed stories from loop\n688\t      for (const item of workItems) {\n689\t        processedStories.add(item.key);\n690\t      }\n691\t\n692\t      if (loopResult.halted) {\n693\t        halted = true;\n694\t      }\n695\t\n696\t      // If loop ended with max-iterations or circuit-breaker, treat as failure\n697\t      if (state.phase === 'max-iterations' || state.phase === 'circuit-breaker') {\n698\t        halted = true;\n699\t      }\n700\t      continue;\n701\t    }\n702\t\n703\t    // step is a string task name\n704\t    const taskName = step;\n705\t    const task = config.workflow.tasks[taskName];\n706\t\n707\t    if (!task) {\n708\t      warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n709\t      continue;\n710\t    }\n711\t\n712\t    // Look up the agent definition\n713\t    const definition = config.agents[task.agent];\n714\t    if (!definition) {\n715\t      warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n716\t      continue;\n717\t    }\n718\t\n719\t    if (task.scope === 'per-run') {\n720\t      // Per-run: dispatch once with sentinel key\n721\t      try {\n722\t        state = await dispatchTask(task, taskName, PER_RUN_SENTINEL, definition, state, config);\n723\t        tasksCompleted++;\n724\t      } catch (err: unknown) {\n725\t        const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n726\t        errors.push(engineError);\n727\t\n728\t        // Record error checkpoint in state (AC #13)\n729\t        state = recordErrorInState(state, taskName, PER_RUN_SENTINEL, engineError);\n730\t        writeWorkflowState(state, projectDir);\n731\t\n732\t        // Halt on critical errors\n733\t        if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n734\t          halted = true;\n735\t        }\n736\t      }\n737\t    } else {\n738\t      // Per-story: dispatch once per work item\n739\t      for (const item of workItems) {\n740\t        processedStories.add(item.key);\n741\t        try {\n742\t          state = await dispatchTask(task, taskName, item.key, definition, state, config);\n743\t          tasksCompleted++;\n744\t        } catch (err: unknown) {\n745\t          const engineError = handleDispatchError(err, taskName, item.key);\n746\t          errors.push(engineError);\n747\t\n748\t          // Record error checkpoint in state (AC #13)\n749\t          state = recordErrorInState(state, taskName, item.key, engineError);\n750\t          writeWorkflowState(state, projectDir);\n751\t\n752\t          // Halt on critical errors, continue on UNKNOWN\n753\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n754\t            halted = true;\n755\t            break;\n756\t          }\n757\t          // UNKNOWN errors: record and continue to next story\n758\t          continue;\n759\t        }\n760\t      }\n761\t    }\n762\t  }\n763\t\n764\t  // 4. Set final phase if no errors and phase not already set by loop termination\n765\t  if (errors.length === 0 && state.phase !== 'max-iterations' && state.phase !== 'circuit-breaker') {\n766\t    state = { ...state, phase: 'completed' };\n767\t    writeWorkflowState(state, projectDir);\n768\t  }\n769\t\n770\t  // 5. Return result\n771\t  const loopTerminated = state.phase === 'max-iterations' || state.phase === 'circuit-breaker';\n772\t  return {\n773\t    success: errors.length === 0 && !loopTerminated,\n774\t    tasksCompleted,\n775\t    storiesProcessed: processedStories.size,\n776\t    errors,\n777\t    durationMs: Date.now() - startMs,\n778\t  };\n779\t}\n780\t\n781\t// --- Error Handling ---\n782\t\n783\t/**\n784\t * Record a dispatch error in workflow state: set phase to \"error\" and append\n785\t * a TaskCheckpoint with the error details (AC #13).\n786\t */\n787\tfunction recordErrorInState(\n788\t  state: WorkflowState,\n789\t  taskName: string,\n790\t  storyKey: string,\n791\t  error: EngineError,\n792\t): WorkflowState {\n793\t  const errorCheckpoint: TaskCheckpoint = {\n794\t    task_name: taskName,\n795\t    story_key: storyKey,\n796\t    completed_at: new Date().toISOString(),\n797\t  };\n798\t  return {\n799\t    ...state,\n800\t    phase: 'error',\n801\t    tasks_completed: [...state.tasks_completed, errorCheckpoint],\n802\t  };\n803\t}\n804\t\n805\tfunction handleDispatchError(err: unknown, taskName: string, storyKey: string): EngineError {\n806\t  if (err instanceof DispatchError) {\n807\t    return {\n808\t      taskName,\n809\t      storyKey,\n810\t      code: err.code,\n811\t      message: err.message,\n812\t    };\n813\t  }\n814\t\n815\t  const message = err instanceof Error ? err.message : String(err);\n816\t  return {\n817\t    taskName,\n818\t    storyKey,\n819\t    code: 'UNKNOWN',\n820\t    message,\n821\t  };\n822\t}\n823\t"}]},"parent_tool_use_id":"toolu_01V1x6e3c7XZ7fi9gyeDWjD6","session_id":"7447df8e-50f4-441a-b8fe-e85605fee72e","uuid":"0a4620cd-9339-4a10-8886-3b311e315241","timestamp":"2026-04-02T22:25:03.654Z"}
