{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GhkUPrhqQST7WbCuafh1NQ","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { join, resolve, dirname } from 'node:path';\n3\timport { fileURLToPath } from 'node:url';\n4\timport os from 'node:os';\n5\timport { parse } from 'yaml';\n6\timport { validateWorkflowSchema } from './schema-validate.js';\n7\t\n8\tconst __filename = fileURLToPath(import.meta.url);\n9\tconst __dirname = dirname(__filename);\n10\t\n11\tconst TEMPLATES_DIR = resolve(__dirname, '../../templates/workflows');\n12\t\n13\t// --- Interfaces ---\n14\t\n15\texport interface ResolvedTask {\n16\t  agent: string;\n17\t  scope: 'per-story' | 'per-run';\n18\t  session: 'fresh' | 'continue';\n19\t  source_access: boolean;\n20\t  prompt_template?: string;\n21\t  input_contract?: Record<string, unknown>;\n22\t  output_contract?: Record<string, unknown>;\n23\t  max_budget_usd?: number;\n24\t}\n25\t\n26\texport interface LoopBlock {\n27\t  loop: string[];\n28\t}\n29\t\n30\texport type FlowStep = string | LoopBlock;\n31\t\n32\texport interface ResolvedWorkflow {\n33\t  tasks: Record<string, ResolvedTask>;\n34\t  flow: FlowStep[];\n35\t}\n36\t\n37\t// --- Error Class ---\n38\t\n39\texport class WorkflowParseError extends Error {\n40\t  public readonly errors: Array<{ path: string; message: string }>;\n41\t\n42\t  constructor(message: string, errors?: Array<{ path: string; message: string }>) {\n43\t    super(message);\n44\t    this.name = 'WorkflowParseError';\n45\t    this.errors = errors ?? [];\n46\t  }\n47\t}\n48\t\n49\t// --- Shared Validation & Resolution ---\n50\t\n51\t/**\n52\t * Validate parsed YAML against JSON schema, check referential integrity,\n53\t * apply defaults, and return a typed ResolvedWorkflow.\n54\t * Shared between parseWorkflow (direct file) and resolveWorkflow (patch chain).\n55\t */\n56\tfunction validateAndResolve(parsed: unknown): ResolvedWorkflow {\n57\t  // Validate against JSON schema\n58\t  const result = validateWorkflowSchema(parsed);\n59\t  if (!result.valid) {\n60\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n61\t    throw new WorkflowParseError(\n62\t      `Schema validation failed: ${details}`,\n63\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n64\t    );\n65\t  }\n66\t\n67\t  // At this point, parsed has passed schema validation — safe to cast\n68\t  const data = parsed as { tasks: Record<string, Record<string, unknown>>; flow: unknown[] };\n69\t\n70\t  // Referential integrity check\n71\t  const taskNames = new Set(Object.keys(data.tasks));\n72\t  const danglingRefs: Array<{ path: string; message: string }> = [];\n73\t\n74\t  for (let i = 0; i < data.flow.length; i++) {\n75\t    const step = data.flow[i];\n76\t    if (typeof step === 'string') {\n77\t      if (!taskNames.has(step)) {\n78\t        danglingRefs.push({\n79\t          path: `/flow/${i}`,\n80\t          message: `Task \"${step}\" referenced in flow but not defined in tasks`,\n81\t        });\n82\t      }\n83\t    } else if (typeof step === 'object' && step !== null && 'loop' in step) {\n84\t      const loopBlock = step as { loop: string[] };\n85\t      for (let j = 0; j < loopBlock.loop.length; j++) {\n86\t        const ref = loopBlock.loop[j];\n87\t        if (!taskNames.has(ref)) {\n88\t          danglingRefs.push({\n89\t            path: `/flow/${i}/loop/${j}`,\n90\t            message: `Task \"${ref}\" referenced in loop but not defined in tasks`,\n91\t          });\n92\t        }\n93\t      }\n94\t    }\n95\t  }\n96\t\n97\t  if (danglingRefs.length > 0) {\n98\t    const details = danglingRefs.map((e) => e.message).join('; ');\n99\t    throw new WorkflowParseError(`Dangling task references: ${details}`, danglingRefs);\n100\t  }\n101\t\n102\t  // Apply defaults and build resolved tasks\n103\t  const resolvedTasks: Record<string, ResolvedTask> = {};\n104\t  for (const [taskName, task] of Object.entries(data.tasks)) {\n105\t    const resolved: ResolvedTask = {\n106\t      agent: task.agent as string,\n107\t      scope: (task.scope as ResolvedTask['scope']) ?? 'per-story',\n108\t      session: (task.session as ResolvedTask['session']) ?? 'fresh',\n109\t      source_access: (task.source_access as boolean) ?? true,\n110\t    };\n111\t    if (task.prompt_template !== undefined) {\n112\t      resolved.prompt_template = task.prompt_template as string;\n113\t    }\n114\t    if (task.input_contract !== undefined) {\n115\t      resolved.input_contract = task.input_contract as Record<string, unknown>;\n116\t    }\n117\t    if (task.output_contract !== undefined) {\n118\t      resolved.output_contract = task.output_contract as Record<string, unknown>;\n119\t    }\n120\t    if (task.max_budget_usd !== undefined) {\n121\t      resolved.max_budget_usd = task.max_budget_usd as number;\n122\t    }\n123\t    resolvedTasks[taskName] = resolved;\n124\t  }\n125\t\n126\t  // Build resolved flow\n127\t  const resolvedFlow: FlowStep[] = data.flow.map((step) => {\n128\t    if (typeof step === 'string') {\n129\t      return step;\n130\t    }\n131\t    return step as LoopBlock;\n132\t  });\n133\t\n134\t  return { tasks: resolvedTasks, flow: resolvedFlow };\n135\t}\n136\t\n137\t// --- Parser ---\n138\t\n139\t/**\n140\t * Parse a workflow YAML file from disk, validate it against the JSON schema,\n141\t * check referential integrity, apply defaults, and return a typed ResolvedWorkflow.\n142\t */\n143\texport function parseWorkflow(filePath: string): ResolvedWorkflow {\n144\t  // 1. Read file\n145\t  let raw: string;\n146\t  try {\n147\t    raw = readFileSync(filePath, 'utf-8');\n148\t  } catch (err: unknown) {\n149\t    const code = err instanceof Error && 'code' in err ? (err as NodeJS.ErrnoException).code : undefined;\n150\t    const detail = code === 'ENOENT'\n151\t      ? 'File not found'\n152\t      : code === 'EACCES'\n153\t        ? 'Permission denied'\n154\t        : code === 'EISDIR'\n155\t          ? 'Path is a directory'\n156\t          : 'File not found or unreadable';\n157\t    throw new WorkflowParseError(`${detail}: ${filePath}`, [\n158\t      { path: filePath, message: detail },\n159\t    ]);\n160\t  }\n161\t\n162\t  // 2. Parse YAML\n163\t  let parsed: unknown;\n164\t  try {\n165\t    parsed = parse(raw);\n166\t  } catch (err: unknown) {\n167\t    const yamlMsg = err instanceof Error ? err.message : String(err);\n168\t    throw new WorkflowParseError(`Invalid YAML syntax: ${yamlMsg}`, [\n169\t      { path: filePath, message: yamlMsg },\n170\t    ]);\n171\t  }\n172\t\n173\t  return validateAndResolve(parsed);\n174\t}\n175\t\n176\t// --- Patch Interfaces ---\n177\t\n178\t/**\n179\t * Patch file structure for workflow customization.\n180\t * `extends` identifies the base, `overrides` are deep-merged, `replace` sections wholly overwrite.\n181\t */\n182\texport interface WorkflowPatch {\n183\t  extends?: string;\n184\t  overrides?: Record<string, unknown>;\n185\t  replace?: Record<string, unknown>;\n186\t}\n187\t\n188\t// --- Deep Merge ---\n189\t\n190\t/**\n191\t * Deep merge strategy: objects merge recursively, arrays replace, scalars replace.\n192\t * Same semantics as agent-resolver deepMerge.\n193\t */\n194\tfunction deepMerge(base: Record<string, unknown>, patch: Record<string, unknown>): Record<string, unknown> {\n195\t  const result: Record<string, unknown> = { ...base };\n196\t\n197\t  for (const key of Object.keys(patch)) {\n198\t    const baseVal = base[key];\n199\t    const patchVal = patch[key];\n200\t\n201\t    if (\n202\t      patchVal !== null &&\n203\t      typeof patchVal === 'object' &&\n204\t      !Array.isArray(patchVal) &&\n205\t      baseVal !== null &&\n206\t      typeof baseVal === 'object' &&\n207\t      !Array.isArray(baseVal)\n208\t    ) {\n209\t      result[key] = deepMerge(\n210\t        baseVal as Record<string, unknown>,\n211\t        patchVal as Record<string, unknown>,\n212\t      );\n213\t    } else {\n214\t      result[key] = patchVal;\n215\t    }\n216\t  }\n217\t\n218\t  return result;\n219\t}\n220\t\n221\t// --- Patch Loading ---\n222\t\n223\t/**\n224\t * Load a workflow patch file. Returns null if the file does not exist (silent skip).\n225\t * Throws WorkflowParseError on malformed YAML.\n226\t */\n227\texport function loadWorkflowPatch(filePath: string): WorkflowPatch | null {\n228\t  if (!existsSync(filePath)) {\n229\t    return null;\n230\t  }\n231\t\n232\t  let raw: string;\n233\t  try {\n234\t    raw = readFileSync(filePath, 'utf-8');\n235\t  } catch (err: unknown) {\n236\t    const code = err instanceof Error && 'code' in err ? (err as NodeJS.ErrnoException).code : undefined;\n237\t    if (code === 'ENOENT') {\n238\t      return null; // File disappeared between existsSync and readFileSync — treat as missing\n239\t    }\n240\t    const detail = code === 'EACCES' ? 'Permission denied' : 'File unreadable';\n241\t    throw new WorkflowParseError(`${detail}: ${filePath}`, [\n242\t      { path: filePath, message: detail },\n243\t    ]);\n244\t  }\n245\t\n246\t  let parsed: unknown;\n247\t  try {\n248\t    parsed = parse(raw);\n249\t  } catch (err: unknown) {\n250\t    const msg = err instanceof Error ? err.message : String(err);\n251\t    throw new WorkflowParseError(`Invalid YAML in patch file ${filePath}: ${msg}`, [\n252\t      { path: filePath, message: msg },\n253\t    ]);\n254\t  }\n255\t\n256\t  if (parsed === null || typeof parsed !== 'object') {\n257\t    throw new WorkflowParseError(`Patch file is not a valid object: ${filePath}`, [\n258\t      { path: filePath, message: 'Patch must be a YAML object' },\n259\t    ]);\n260\t  }\n261\t\n262\t  return parsed as WorkflowPatch;\n263\t}\n264\t\n265\t// --- Patch Merging ---\n266\t\n267\t/**\n268\t * Merge a workflow patch onto a base config.\n269\t * Deep-merges `overrides`, then applies `replace` sections as full overwrites.\n270\t */\n271\texport function mergeWorkflowPatch(\n272\t  base: Record<string, unknown>,\n273\t  patch: WorkflowPatch,\n274\t): Record<string, unknown> {\n275\t  let result = { ...base };\n276\t\n277\t  // Deep-merge overrides\n278\t  if (patch.overrides) {\n279\t    result = deepMerge(result, patch.overrides);\n280\t  }\n281\t\n282\t  // Full replacement for replace sections\n283\t  if (patch.replace) {\n284\t    for (const key of Object.keys(patch.replace)) {\n285\t      result[key] = patch.replace[key];\n286\t    }\n287\t  }\n288\t\n289\t  return result;\n290\t}\n291\t\n292\t// --- Main Resolution ---\n293\t\n294\t/**\n295\t * Resolve a workflow through the embedded -> user -> project patch chain.\n296\t *\n297\t * 1. Load embedded workflow from templates/workflows/{name}.yaml\n298\t * 2. Apply user-level patch from ~/.codeharness/workflows/{name}.patch.yaml (if exists)\n299\t * 3. Apply project-level patch from .codeharness/workflows/{name}.patch.yaml (if exists)\n300\t * 4. Validate merged result against JSON schema + referential integrity\n301\t * 5. Apply defaults and return ResolvedWorkflow\n302\t *\n303\t * If a full custom workflow (no patch, no extends) exists at project level, it is loaded directly.\n304\t */\n305\texport function resolveWorkflow(options?: { cwd?: string; name?: string }): ResolvedWorkflow {\n306\t  const cwd = options?.cwd ?? process.cwd();\n307\t  const name = options?.name ?? 'default';\n308\t\n309\t  const userPatchPath = join(os.homedir(), '.codeharness', 'workflows', `${name}.patch.yaml`);\n310\t  const projectPatchPath = join(cwd, '.codeharness', 'workflows', `${name}.patch.yaml`);\n311\t\n312\t  // Check for full custom workflow at project level (not a patch — no extends)\n313\t  const projectCustomPath = join(cwd, '.codeharness', 'workflows', `${name}.yaml`);\n314\t  if (existsSync(projectCustomPath)) {\n315\t    const customPatch = loadWorkflowPatch(projectCustomPath);\n316\t    if (customPatch && !customPatch.extends) {\n317\t      // This is a full custom workflow, not a patch — parse directly\n318\t      return parseWorkflow(projectCustomPath);\n319\t    }\n320\t  }\n321\t\n322\t  // Load embedded base\n323\t  const embeddedPath = join(TEMPLATES_DIR, `${name}.yaml`);\n324\t  let raw: string;\n325\t  try {\n326\t    raw = readFileSync(embeddedPath, 'utf-8');\n327\t  } catch (err: unknown) {\n328\t    const detail = err instanceof Error ? err.message : `File not found: ${embeddedPath}`;\n329\t    throw new WorkflowParseError(`Embedded workflow not found: ${name}`, [\n330\t      { path: embeddedPath, message: detail },\n331\t    ]);\n332\t  }\n333\t\n334\t  let baseData: unknown;\n335\t  try {\n336\t    baseData = parse(raw);\n337\t  } catch (err: unknown) {\n338\t    const msg = err instanceof Error ? err.message : String(err);\n339\t    throw new WorkflowParseError(`Invalid YAML in embedded workflow ${name}: ${msg}`, [\n340\t      { path: embeddedPath, message: msg },\n341\t    ]);\n342\t  }\n343\t\n344\t  let merged = baseData as Record<string, unknown>;\n345\t\n346\t  // Apply user-level patch\n347\t  const userPatch = loadWorkflowPatch(userPatchPath);\n348\t  if (userPatch) {\n349\t    merged = mergeWorkflowPatch(merged, userPatch);\n350\t  }\n351\t\n352\t  // Apply project-level patch\n353\t  const projectPatch = loadWorkflowPatch(projectPatchPath);\n354\t  if (projectPatch) {\n355\t    merged = mergeWorkflowPatch(merged, projectPatch);\n356\t  }\n357\t\n358\t  // Validate, check referential integrity, apply defaults, and return\n359\t  return validateAndResolve(merged);\n360\t}\n361\t"}]},"parent_tool_use_id":"toolu_019kDU2rXQxKhW35XzJYDDnv","session_id":"90f775a4-0bf0-4884-b410-4d7f1f50684d","uuid":"6388130f-88d2-480a-8350-9342640b131a","timestamp":"2026-04-03T08:11:34.583Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JLcTF61MjFGDJvZs9qfgHX","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { parse } from 'yaml';\n3\timport { warn } from './output.js';\n4\timport { DispatchError } from './agent-dispatch.js';\n5\timport type { DispatchErrorCode } from './agent-dispatch.js';\n6\t// Note: dispatchAgent is no longer imported — dispatch goes through the driver factory\n7\timport { getDriver } from './agents/drivers/factory.js';\n8\timport { resolveModel } from './agents/model-resolver.js';\n9\timport type { DispatchOpts } from './agents/types.js';\n10\timport type { ResultEvent } from './agents/stream-parser.js';\n11\timport type { SubagentDefinition } from './agent-resolver.js';\n12\timport type { ResolvedWorkflow, ResolvedTask, FlowStep, LoopBlock } from './workflow-parser.js';\n13\timport {\n14\t  readWorkflowState,\n15\t  writeWorkflowState,\n16\t} from './workflow-state.js';\n17\timport type { WorkflowState, TaskCheckpoint } from './workflow-state.js';\n18\timport { createIsolatedWorkspace } from './source-isolation.js';\n19\timport { generateTraceId, formatTracePrompt, recordTraceId } from './trace-id.js';\n20\timport { resolveSessionId, recordSessionId } from './session-manager.js';\n21\timport type { SessionLookupKey } from './session-manager.js';\n22\timport { parseVerdict, VerdictParseError } from './verdict-parser.js';\n23\timport type { EvaluatorVerdict } from './verdict-parser.js';\n24\timport { evaluateProgress } from './circuit-breaker.js';\n25\t\n26\t// Re-export EvaluatorVerdict for downstream consumers that import from workflow-engine\n27\texport type { EvaluatorVerdict } from './verdict-parser.js';\n28\texport { parseVerdict } from './verdict-parser.js';\n29\t\n30\t// --- Interfaces ---\n31\t\n32\t/**\n33\t * Configuration for the workflow engine.\n34\t */\n35\texport interface EngineConfig {\n36\t  /** The resolved workflow with tasks and flow steps. */\n37\t  workflow: ResolvedWorkflow;\n38\t  /** Pre-compiled agent definitions keyed by agent name. */\n39\t  agents: Record<string, SubagentDefinition>;\n40\t  /** Path to sprint-status.yaml for work item discovery. */\n41\t  sprintStatusPath: string;\n42\t  /** Optional path to issues.yaml for additional work items. */\n43\t  issuesPath?: string;\n44\t  /** Unique identifier for this engine run. */\n45\t  runId: string;\n46\t  /** Project root directory. Defaults to process.cwd(). */\n47\t  projectDir?: string;\n48\t  /** Maximum loop iterations before termination. Defaults to 5. */\n49\t  maxIterations?: number;\n50\t}\n51\t\n52\t/**\n53\t * Result returned by executeWorkflow().\n54\t */\n55\texport interface EngineResult {\n56\t  /** Whether the workflow completed without errors. */\n57\t  success: boolean;\n58\t  /** Number of task dispatches completed. */\n59\t  tasksCompleted: number;\n60\t  /** Number of work items (stories/issues) processed. */\n61\t  storiesProcessed: number;\n62\t  /** Errors encountered during execution. */\n63\t  errors: EngineError[];\n64\t  /** Wall-clock duration of the entire workflow in milliseconds. */\n65\t  durationMs: number;\n66\t}\n67\t\n68\t/**\n69\t * Structured error recorded during workflow execution.\n70\t */\n71\texport interface EngineError {\n72\t  taskName: string;\n73\t  storyKey: string;\n74\t  code: string;\n75\t  message: string;\n76\t}\n77\t\n78\t/**\n79\t * A work item (story or issue) ready for execution.\n80\t */\n81\texport interface WorkItem {\n82\t  key: string;\n83\t  title?: string;\n84\t  source: 'sprint' | 'issues';\n85\t}\n86\t\n87\t// --- Constants ---\n88\t\n89\t/** Sentinel story key for per-run tasks. */\n90\texport const PER_RUN_SENTINEL = '__run__';\n91\t\n92\t/** DispatchError codes that should halt execution immediately. */\n93\tconst HALT_ERROR_CODES = new Set(['RATE_LIMIT', 'NETWORK', 'SDK_INIT']);\n94\t\n95\t/** Default maximum loop iterations before termination. */\n96\tconst DEFAULT_MAX_ITERATIONS = 5;\n97\t\n98\t// --- Crash Recovery: Task Completion Check ---\n99\t\n100\t/**\n101\t * Check whether a (taskName, storyKey) combination is already recorded\n102\t * in the workflow state's tasks_completed array.\n103\t *\n104\t * Both fields must match for the task to be considered completed.\n105\t * Used by the resume logic to skip already-completed dispatches.\n106\t */\n107\texport function isTaskCompleted(\n108\t  state: WorkflowState,\n109\t  taskName: string,\n110\t  storyKey: string,\n111\t): boolean {\n112\t  return state.tasks_completed.some(\n113\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey && !cp.error,\n114\t  );\n115\t}\n116\t\n117\t/**\n118\t * Check whether a (taskName, storyKey) combination has been completed\n119\t * enough times to cover the current iteration in a loop block.\n120\t *\n121\t * Loop tasks execute the same (taskName, storyKey) pair each iteration,\n122\t * recording a new checkpoint each time. To determine if a task is done\n123\t * for the current iteration, we count how many matching checkpoints exist\n124\t * and compare to the current iteration number.\n125\t */\n126\texport function isLoopTaskCompleted(\n127\t  state: WorkflowState,\n128\t  taskName: string,\n129\t  storyKey: string,\n130\t  iteration: number,\n131\t): boolean {\n132\t  const count = state.tasks_completed.filter(\n133\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey && !cp.error,\n134\t  ).length;\n135\t  return count >= iteration;\n136\t}\n137\t\n138\t// --- Work Item Loading ---\n139\t\n140\t/**\n141\t * Load work items from sprint-status.yaml and optionally issues.yaml.\n142\t *\n143\t * Stories are extracted from the `development_status` section of sprint-status.yaml.\n144\t * Issues are extracted from the `issues` array of issues.yaml.\n145\t *\n146\t * Only items with status `backlog` or `ready-for-dev` are included.\n147\t * Epic keys (`epic-*`) and retrospective keys (`*-retrospective`) are excluded.\n148\t *\n149\t * If issues.yaml does not exist, returns only stories (no error).\n150\t */\n151\texport function loadWorkItems(sprintStatusPath: string, issuesPath?: string): WorkItem[] {\n152\t  const items: WorkItem[] = [];\n153\t\n154\t  // --- Load stories from sprint-status.yaml ---\n155\t  if (existsSync(sprintStatusPath)) {\n156\t    let raw: string;\n157\t    try {\n158\t      raw = readFileSync(sprintStatusPath, 'utf-8');\n159\t    } catch { // IGNORE: unreadable file — warn and return empty\n160\t      warn(`workflow-engine: could not read sprint-status.yaml at ${sprintStatusPath}`);\n161\t      return items;\n162\t    }\n163\t\n164\t    let parsed: unknown;\n165\t    try {\n166\t      parsed = parse(raw);\n167\t    } catch { // IGNORE: malformed YAML — warn and return empty\n168\t      warn(`workflow-engine: invalid YAML in sprint-status.yaml at ${sprintStatusPath}`);\n169\t      return items;\n170\t    }\n171\t\n172\t    if (parsed && typeof parsed === 'object') {\n173\t      const data = parsed as Record<string, unknown>;\n174\t      const devStatus = data.development_status as Record<string, unknown> | undefined;\n175\t\n176\t      if (devStatus && typeof devStatus === 'object') {\n177\t        for (const [key, status] of Object.entries(devStatus)) {\n178\t          // Skip epic keys and retrospective keys\n179\t          if (key.startsWith('epic-')) continue;\n180\t          if (key.endsWith('-retrospective')) continue;\n181\t\n182\t          // Only include backlog or ready-for-dev\n183\t          if (status === 'backlog' || status === 'ready-for-dev') {\n184\t            items.push({ key, source: 'sprint' });\n185\t          }\n186\t        }\n187\t      }\n188\t    }\n189\t  }\n190\t\n191\t  // --- Load issues from issues.yaml ---\n192\t  if (issuesPath && existsSync(issuesPath)) {\n193\t    let raw: string;\n194\t    try {\n195\t      raw = readFileSync(issuesPath, 'utf-8');\n196\t    } catch { // IGNORE: unreadable issues file — warn and return what we have\n197\t      warn(`workflow-engine: could not read issues.yaml at ${issuesPath}`);\n198\t      return items;\n199\t    }\n200\t\n201\t    let parsed: unknown;\n202\t    try {\n203\t      parsed = parse(raw);\n204\t    } catch { // IGNORE: malformed issues YAML — warn and return what we have\n205\t      warn(`workflow-engine: invalid YAML in issues.yaml at ${issuesPath}`);\n206\t      return items;\n207\t    }\n208\t\n209\t    if (parsed && typeof parsed === 'object') {\n210\t      const data = parsed as Record<string, unknown>;\n211\t      const issuesList = data.issues as Array<Record<string, unknown>> | undefined;\n212\t\n213\t      if (Array.isArray(issuesList)) {\n214\t        for (const issue of issuesList) {\n215\t          if (issue && typeof issue === 'object') {\n216\t            const status = issue.status as string | undefined;\n217\t            if (status === 'backlog' || status === 'ready-for-dev') {\n218\t              items.push({\n219\t                key: issue.id as string,\n220\t                title: issue.title as string | undefined,\n221\t                source: 'issues',\n222\t              });\n223\t            }\n224\t          }\n225\t        }\n226\t      }\n227\t    }\n228\t  }\n229\t\n230\t  return items;\n231\t}\n232\t\n233\t// --- Single Task Dispatch ---\n234\t\n235\t/**\n236\t * Dispatch a single task for a specific work item (or per-run sentinel).\n237\t *\n238\t * Handles: trace ID generation, session resolution, source isolation,\n239\t * agent dispatch, state checkpointing, and cleanup.\n240\t *\n241\t * Returns the updated workflow state after recording the dispatch.\n242\t */\n243\texport async function dispatchTask(\n244\t  task: ResolvedTask,\n245\t  taskName: string,\n246\t  storyKey: string,\n247\t  definition: SubagentDefinition,\n248\t  state: WorkflowState,\n249\t  config: EngineConfig,\n250\t  customPrompt?: string,\n251\t): Promise<WorkflowState> {\n252\t  const { updatedState } = await dispatchTaskWithResult(\n253\t    task, taskName, storyKey, definition, state, config, customPrompt,\n254\t  );\n255\t  return updatedState;\n256\t}\n257\t\n258\t// --- Flow Step Type Guard ---\n259\t\n260\tfunction isLoopBlock(step: FlowStep): step is LoopBlock {\n261\t  return typeof step === 'object' && step !== null && 'loop' in step;\n262\t}\n263\t\n264\t// --- Core Dispatch (shared by dispatchTask and loop block execution) ---\n265\t\n266\t/**\n267\t * Dispatch a task and return both the updated state and the raw dispatch output.\n268\t * This is the single implementation of task dispatch logic. Both `dispatchTask()`\n269\t * and loop block execution delegate here.\n270\t */\n271\tasync function dispatchTaskWithResult(\n272\t  task: ResolvedTask,\n273\t  taskName: string,\n274\t  storyKey: string,\n275\t  definition: SubagentDefinition,\n276\t  state: WorkflowState,\n277\t  config: EngineConfig,\n278\t  customPrompt?: string,\n279\t): Promise<{ updatedState: WorkflowState; output: string }> {\n280\t  const projectDir = config.projectDir ?? process.cwd();\n281\t\n282\t  // 1. Generate trace ID\n283\t  const traceId = generateTraceId(config.runId, state.iteration, taskName);\n284\t\n285\t  // 2. Format trace prompt — injected into driver via DispatchOpts.appendSystemPrompt\n286\t  const tracePrompt = formatTracePrompt(traceId);\n287\t\n288\t  // 3. Resolve session ID\n289\t  const sessionKey: SessionLookupKey = { taskName, storyKey };\n290\t  const sessionId = resolveSessionId(task.session, sessionKey, state);\n291\t\n292\t  // 4. Resolve driver — forward-compat: task.driver field comes in story 11-1\n293\t  const driverName = (task as { driver?: string }).driver ?? 'claude-code';\n294\t  const driver = getDriver(driverName);\n295\t\n296\t  // 5. Resolve model via cascade: task → agent → driver\n297\t  const agentAsModelSource = { model: definition.model };\n298\t  const model = resolveModel(task as { model?: string }, agentAsModelSource, driver);\n299\t\n300\t  // 6. Determine cwd based on source_access\n301\t  let cwd: string;\n302\t  let workspace: Awaited<ReturnType<typeof createIsolatedWorkspace>> | null = null;\n303\t\n304\t  if (task.source_access === false) {\n305\t    workspace = await createIsolatedWorkspace({ runId: config.runId, storyFiles: [] });\n306\t    cwd = workspace.toDispatchOptions().cwd ?? projectDir;\n307\t  } else {\n308\t    cwd = projectDir;\n309\t  }\n310\t\n311\t  // 7. Construct prompt\n312\t  const prompt = customPrompt\n313\t    ?? (storyKey === PER_RUN_SENTINEL\n314\t      ? `Execute task \"${taskName}\" for the current run.`\n315\t      : `Implement story ${storyKey}`);\n316\t\n317\t  // 8. Build DispatchOpts for the driver\n318\t  const dispatchOpts: DispatchOpts = {\n319\t    prompt,\n320\t    model,\n321\t    cwd,\n322\t    sourceAccess: task.source_access !== false,\n323\t    ...(sessionId ? { sessionId } : {}),\n324\t    ...(tracePrompt ? { appendSystemPrompt: tracePrompt } : {}),\n325\t    ...(((task as { plugins?: readonly string[] }).plugins) ? { plugins: (task as { plugins?: readonly string[] }).plugins } : {}),\n326\t    ...(task.max_budget_usd != null ? { timeout: task.max_budget_usd } : {}),\n327\t  };\n328\t\n329\t  // 9. Dispatch through the driver and consume AsyncIterable<StreamEvent>\n330\t  let output = '';\n331\t  let resultSessionId = '';\n332\t  let cost = 0;\n333\t  let errorEvent: { error: string; errorCategory?: string } | null = null;\n334\t\n335\t  try {\n336\t    for await (const event of driver.dispatch(dispatchOpts)) {\n337\t      if (event.type === 'text') {\n338\t        output += event.text;\n339\t      }\n340\t      if (event.type === 'result') {\n341\t        const resultEvt = event as ResultEvent;\n342\t        resultSessionId = resultEvt.sessionId;\n343\t        cost = resultEvt.cost;\n344\t        if (resultEvt.error) {\n345\t          errorEvent = { error: resultEvt.error, errorCategory: resultEvt.errorCategory };\n346\t        }\n347\t      }\n348\t    }\n349\t  } finally {\n350\t    // Cleanup workspace regardless of dispatch success/failure\n351\t    if (workspace) {\n352\t      await workspace.cleanup();\n353\t    }\n354\t  }\n355\t\n356\t  // 10. If the driver reported an error in the result event, throw DispatchError\n357\t  if (errorEvent) {\n358\t    // Map ErrorCategory to DispatchErrorCode\n359\t    const categoryToCode: Record<string, string> = {\n360\t      RATE_LIMIT: 'RATE_LIMIT',\n361\t      NETWORK: 'NETWORK',\n362\t      SDK_INIT: 'SDK_INIT',\n363\t      AUTH: 'UNKNOWN',\n364\t      TIMEOUT: 'UNKNOWN',\n365\t      UNKNOWN: 'UNKNOWN',\n366\t    };\n367\t    const code = categoryToCode[errorEvent.errorCategory ?? 'UNKNOWN'] ?? 'UNKNOWN';\n368\t    throw new DispatchError(\n369\t      errorEvent.error,\n370\t      code as DispatchErrorCode,\n371\t      definition.name,\n372\t      errorEvent,\n373\t    );\n374\t  }\n375\t\n376\t  // 11. Record session ID (if dispatch returned one)\n377\t  let updatedState = state;\n378\t  if (resultSessionId) {\n379\t    updatedState = recordSessionId(sessionKey, resultSessionId, updatedState);\n380\t  } else {\n381\t    // Append checkpoint manually when no session ID is returned\n382\t    const checkpoint: TaskCheckpoint = {\n383\t      task_name: taskName,\n384\t      story_key: storyKey,\n385\t      completed_at: new Date().toISOString(),\n386\t    };\n387\t    updatedState = {\n388\t      ...updatedState,\n389\t      tasks_completed: [...updatedState.tasks_completed, checkpoint],\n390\t    };\n391\t  }\n392\t\n393\t  // 12. Record trace ID\n394\t  updatedState = recordTraceId(traceId, updatedState);\n395\t\n396\t  // 13. Write state to disk\n397\t  writeWorkflowState(updatedState, projectDir);\n398\t\n399\t  return { updatedState, output };\n400\t}\n401\t\n402\t// --- Retry Prompt Construction (Task 3) ---\n403\t\n404\t/**\n405\t * Build a retry prompt with evaluator findings injected.\n406\t * Includes only failed/unknown findings.\n407\t */\n408\texport function buildRetryPrompt(storyKey: string, findings: EvaluatorVerdict['findings']): string {\n409\t  const failedFindings = findings.filter(\n410\t    (f) => f.status === 'fail' || f.status === 'unknown',\n411\t  );\n412\t\n413\t  if (failedFindings.length === 0) {\n414\t    return `Implement story ${storyKey}`;\n415\t  }\n416\t\n417\t  const formattedFindings = failedFindings\n418\t    .map((f) => {\n419\t      const status = f.status.toUpperCase();\n420\t      let entry = `AC #${f.ac} (${status}): ${f.description}`;\n421\t      if (f.evidence?.reasoning) {\n422\t        entry += `\\n  Evidence: ${f.evidence.reasoning}`;\n423\t      }\n424\t      return entry;\n425\t    })\n426\t    .join('\\n\\n');\n427\t\n428\t  return `Retry story ${storyKey}. Previous evaluator findings:\\n\\n${formattedFindings}\\n\\nFocus on fixing the failed criteria above.`;\n429\t}\n430\t\n431\t// --- All-UNKNOWN Verdict Builder ---\n432\t\n433\t/**\n434\t * Build an all-UNKNOWN EvaluatorVerdict as fallback when the evaluator\n435\t * fails to produce valid JSON after retry.\n436\t */\n437\texport function buildAllUnknownVerdict(\n438\t  workItems: WorkItem[],\n439\t  reasoning: string,\n440\t): EvaluatorVerdict {\n441\t  const findings = workItems.map((_, index) => ({\n442\t    ac: index + 1,\n443\t    description: `AC #${index + 1}`,\n444\t    status: 'unknown' as const,\n445\t    evidence: {\n446\t      commands_run: [] as string[],\n447\t      output_observed: '',\n448\t      reasoning,\n449\t    },\n450\t  }));\n451\t\n452\t  return {\n453\t    verdict: 'fail',\n454\t    score: {\n455\t      passed: 0,\n456\t      failed: 0,\n457\t      unknown: findings.length,\n458\t      total: findings.length,\n459\t    },\n460\t    findings,\n461\t  };\n462\t}\n463\t\n464\t// --- Failed Story Filtering (Task 4) ---\n465\t\n466\t/**\n467\t * Determine which work items failed based on evaluator findings.\n468\t * If verdict is null (parse failure), returns all items (conservative fallback).\n469\t */\n470\texport function getFailedItems(\n471\t  verdict: EvaluatorVerdict | null,\n472\t  allItems: WorkItem[],\n473\t): WorkItem[] {\n474\t  if (!verdict) return allItems;\n475\t\n476\t  // If verdict passed, no items need retry\n477\t  if (verdict.verdict === 'pass') return [];\n478\t\n479\t  // All items are retried on failure — per-story filtering based on individual\n480\t  // story results is not possible with the current verdict shape (verdict is per-run).\n481\t  // The findings track ACs, not stories. Conservative: retry all on failure.\n482\t  return allItems;\n483\t}\n484\t\n485\t// --- Loop Block Execution (Task 5) ---\n486\t\n487\t/**\n488\t * Result of loop block execution.\n489\t */\n490\tinterface LoopBlockResult {\n491\t  state: WorkflowState;\n492\t  errors: EngineError[];\n493\t  tasksCompleted: number;\n494\t  halted: boolean;\n495\t}\n496\t\n497\t/**\n498\t * Execute a loop block: iterate tasks until pass, max iterations, or circuit breaker.\n499\t */\n500\texport async function executeLoopBlock(\n501\t  loopBlock: LoopBlock,\n502\t  state: WorkflowState,\n503\t  config: EngineConfig,\n504\t  workItems: WorkItem[],\n505\t): Promise<LoopBlockResult> {\n506\t  const projectDir = config.projectDir ?? process.cwd();\n507\t  const maxIterations = config.maxIterations ?? DEFAULT_MAX_ITERATIONS;\n508\t  const errors: EngineError[] = [];\n509\t  let tasksCompleted = 0;\n510\t  let currentState = state;\n511\t  let lastVerdict: EvaluatorVerdict | null = null;\n512\t\n513\t  // Handle empty loop block\n514\t  if (loopBlock.loop.length === 0) {\n515\t    return { state: currentState, errors, tasksCompleted, halted: false };\n516\t  }\n517\t\n518\t  while (true) {\n519\t    // 1. Determine whether to increment iteration or resume a partial one.\n520\t    //    On fresh start (iteration === 0), always increment.\n521\t    //    On resume (iteration > 0), check if the current iteration is fully done.\n522\t    const nextIteration = currentState.iteration + 1;\n523\t    const allCurrentIterationDone = currentState.iteration > 0 && loopBlock.loop.every((tn) => {\n524\t      const t = config.workflow.tasks[tn];\n525\t      if (!t) return true; // missing task = skip = \"done\"\n526\t      if (t.scope === 'per-story') {\n527\t        return workItems.every((item) =>\n528\t          isLoopTaskCompleted(currentState, tn, item.key, currentState.iteration));\n529\t      }\n530\t      return isLoopTaskCompleted(currentState, tn, PER_RUN_SENTINEL, currentState.iteration);\n531\t    });\n532\t\n533\t    if (currentState.iteration === 0 || allCurrentIterationDone) {\n534\t      // Fresh start or current iteration fully done — advance\n535\t      currentState = {\n536\t        ...currentState,\n537\t        iteration: nextIteration,\n538\t      };\n539\t      writeWorkflowState(currentState, projectDir);\n540\t    }\n541\t    // else: resuming a partially completed iteration — keep current iteration\n542\t\n543\t    let haltedInLoop = false;\n544\t\n545\t    // 2. Execute each task in the loop\n546\t    for (const taskName of loopBlock.loop) {\n547\t      const task = config.workflow.tasks[taskName];\n548\t      if (!task) {\n549\t        warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n550\t        continue;\n551\t      }\n552\t\n553\t      const definition = config.agents[task.agent];\n554\t      if (!definition) {\n555\t        warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n556\t        continue;\n557\t      }\n558\t\n559\t      if (task.scope === 'per-story') {\n560\t        // Determine which items to dispatch for\n561\t        const itemsToRetry = lastVerdict ? getFailedItems(lastVerdict, workItems) : workItems;\n562\t\n563\t        for (const item of itemsToRetry) {\n564\t          // Skip if already completed for this iteration (crash recovery — AC #4)\n565\t          if (isLoopTaskCompleted(currentState, taskName, item.key, currentState.iteration)) {\n566\t            warn(`workflow-engine: skipping completed task ${taskName} for ${item.key}`);\n567\t            continue;\n568\t          }\n569\t\n570\t          // Build prompt: inject findings if we have a previous verdict\n571\t          const prompt = lastVerdict\n572\t            ? buildRetryPrompt(item.key, lastVerdict.findings)\n573\t            : undefined;\n574\t\n575\t          try {\n576\t            currentState = await dispatchTask(\n577\t              task, taskName, item.key, definition, currentState, config, prompt,\n578\t            );\n579\t            tasksCompleted++;\n580\t          } catch (err: unknown) {\n581\t            const engineError = handleDispatchError(err, taskName, item.key);\n582\t            errors.push(engineError);\n583\t            currentState = recordErrorInState(currentState, taskName, item.key, engineError);\n584\t            writeWorkflowState(currentState, projectDir);\n585\t\n586\t            if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n587\t              haltedInLoop = true;\n588\t              break;\n589\t            }\n590\t            continue;\n591\t          }\n592\t        }\n593\t\n594\t        if (haltedInLoop) break;\n595\t      } else {\n596\t        // per-run task (e.g., verify)\n597\t        // Skip if already completed for this iteration (crash recovery — AC #4)\n598\t        if (isLoopTaskCompleted(currentState, taskName, PER_RUN_SENTINEL, currentState.iteration)) {\n599\t          warn(`workflow-engine: skipping completed task ${taskName} for ${PER_RUN_SENTINEL}`);\n600\t          continue;\n601\t        }\n602\t\n603\t        try {\n604\t          // We need the dispatch result output to parse verdict\n605\t          // dispatchTask doesn't return the DispatchResult directly, so we\n606\t          // intercept via a wrapper that captures the output\n607\t          const dispatchResult = await dispatchTaskWithResult(\n608\t            task, taskName, PER_RUN_SENTINEL, definition, currentState, config,\n609\t          );\n610\t          currentState = dispatchResult.updatedState;\n611\t          tasksCompleted++;\n612\t\n613\t          // Attempt to parse verdict from output with retry semantics (story 6-2)\n614\t          let verdict: EvaluatorVerdict | null = null;\n615\t          try {\n616\t            verdict = parseVerdict(dispatchResult.output);\n617\t          } catch (parseErr: unknown) {\n618\t            if (parseErr instanceof VerdictParseError && parseErr.retryable) {\n619\t              // Re-dispatch evaluator for one retry attempt\n620\t              warn(`workflow-engine: verdict parse failed, retrying evaluator for ${taskName}`);\n621\t              try {\n622\t                const retryResult = await dispatchTaskWithResult(\n623\t                  task, taskName, PER_RUN_SENTINEL, definition, currentState, config,\n624\t                );\n625\t                currentState = retryResult.updatedState;\n626\t                tasksCompleted++;\n627\t                verdict = parseVerdict(retryResult.output);\n628\t              } catch { // IGNORE: retry failed — fall back to all-UNKNOWN verdict\n629\t                // Second failure: generate all-UNKNOWN verdict\n630\t                verdict = buildAllUnknownVerdict(\n631\t                  workItems,\n632\t                  'Evaluator failed to produce valid JSON after retry',\n633\t                );\n634\t              }\n635\t            }\n636\t            // If not a VerdictParseError or not retryable, verdict stays null\n637\t          }\n638\t          lastVerdict = verdict;\n639\t\n640\t          // Record score in state\n641\t          if (verdict) {\n642\t            const score = {\n643\t              iteration: currentState.iteration,\n644\t              passed: verdict.score.passed,\n645\t              failed: verdict.score.failed,\n646\t              unknown: verdict.score.unknown,\n647\t              total: verdict.score.total,\n648\t              timestamp: new Date().toISOString(),\n649\t            };\n650\t            currentState = {\n651\t              ...currentState,\n652\t              evaluator_scores: [...currentState.evaluator_scores, score],\n653\t            };\n654\t          } else {\n655\t            // Parse failure: record all-UNKNOWN score\n656\t            const totalItems = workItems.length;\n657\t            const score = {\n658\t              iteration: currentState.iteration,\n659\t              passed: 0,\n660\t              failed: 0,\n661\t              unknown: totalItems,\n662\t              total: totalItems,\n663\t              timestamp: new Date().toISOString(),\n664\t            };\n665\t            currentState = {\n666\t              ...currentState,\n667\t              evaluator_scores: [...currentState.evaluator_scores, score],\n668\t            };\n669\t          }\n670\t          writeWorkflowState(currentState, projectDir);\n671\t\n672\t          // Circuit breaker: evaluate progress after recording score\n673\t          const cbDecision = evaluateProgress(currentState.evaluator_scores);\n674\t          if (cbDecision.halt) {\n675\t            currentState = {\n676\t              ...currentState,\n677\t              circuit_breaker: {\n678\t                triggered: true,\n679\t                reason: cbDecision.reason,\n680\t                score_history: cbDecision.scoreHistory,\n681\t              },\n682\t            };\n683\t            writeWorkflowState(currentState, projectDir);\n684\t          }\n685\t        } catch (err: unknown) {\n686\t          const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n687\t          errors.push(engineError);\n688\t          currentState = recordErrorInState(currentState, taskName, PER_RUN_SENTINEL, engineError);\n689\t          writeWorkflowState(currentState, projectDir);\n690\t\n691\t          // Clear stale verdict so next iteration retries all items\n692\t          lastVerdict = null;\n693\t\n694\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n695\t            haltedInLoop = true;\n696\t            break;\n697\t          }\n698\t          continue;\n699\t        }\n700\t      }\n701\t    }\n702\t\n703\t    if (haltedInLoop) {\n704\t      return { state: currentState, errors, tasksCompleted, halted: true };\n705\t    }\n706\t\n707\t    // 3. Check termination conditions\n708\t    if (lastVerdict?.verdict === 'pass') {\n709\t      // Success: loop passes\n710\t      return { state: currentState, errors, tasksCompleted, halted: false };\n711\t    }\n712\t\n713\t    if (currentState.iteration >= maxIterations) {\n714\t      currentState = { ...currentState, phase: 'max-iterations' };\n715\t      writeWorkflowState(currentState, projectDir);\n716\t      return { state: currentState, errors, tasksCompleted, halted: false };\n717\t    }\n718\t\n719\t    if (currentState.circuit_breaker.triggered) {\n720\t      currentState = { ...currentState, phase: 'circuit-breaker' };\n721\t      writeWorkflowState(currentState, projectDir);\n722\t      return { state: currentState, errors, tasksCompleted, halted: false };\n723\t    }\n724\t  }\n725\t}\n726\t\n727\t\n728\t// --- Main Execution ---\n729\t\n730\t/**\n731\t * Execute a workflow sequentially: iterate through flow steps, dispatch tasks\n732\t * per-story or per-run, checkpoint state after each dispatch.\n733\t *\n734\t * Loop blocks execute iteratively until pass, max-iterations, or circuit-breaker.\n735\t *\n736\t * Returns an EngineResult summarizing the execution.\n737\t */\n738\texport async function executeWorkflow(config: EngineConfig): Promise<EngineResult> {\n739\t  const startMs = Date.now();\n740\t  const projectDir = config.projectDir ?? process.cwd();\n741\t  const errors: EngineError[] = [];\n742\t  let tasksCompleted = 0;\n743\t  const processedStories = new Set<string>();\n744\t\n745\t  // 1. Read or initialize workflow state\n746\t  let state = readWorkflowState(projectDir);\n747\t\n748\t  // Early exit: workflow already completed (AC #6)\n749\t  if (state.phase === 'completed') {\n750\t    return {\n751\t      success: true,\n752\t      tasksCompleted: 0,\n753\t      storiesProcessed: 0,\n754\t      errors: [],\n755\t      durationMs: 0,\n756\t    };\n757\t  }\n758\t\n759\t  state = {\n760\t    ...state,\n761\t    phase: 'executing',\n762\t    started: state.started || new Date().toISOString(),\n763\t    workflow_name: config.workflow.flow.filter((s) => typeof s === 'string').join(' -> '),\n764\t  };\n765\t  writeWorkflowState(state, projectDir);\n766\t\n767\t  // 2. Load work items\n768\t  const workItems = loadWorkItems(config.sprintStatusPath, config.issuesPath);\n769\t\n770\t  // 3. Iterate through flow steps\n771\t  let halted = false;\n772\t  for (const step of config.workflow.flow) {\n773\t    if (halted) break;\n774\t\n775\t    // Execute loop blocks\n776\t    if (isLoopBlock(step)) {\n777\t      const loopResult = await executeLoopBlock(step, state, config, workItems);\n778\t      state = loopResult.state;\n779\t      errors.push(...loopResult.errors);\n780\t      tasksCompleted += loopResult.tasksCompleted;\n781\t\n782\t      // Track processed stories from loop\n783\t      for (const item of workItems) {\n784\t        processedStories.add(item.key);\n785\t      }\n786\t\n787\t      if (loopResult.halted) {\n788\t        halted = true;\n789\t      }\n790\t\n791\t      // If loop ended with max-iterations or circuit-breaker, treat as failure\n792\t      if (state.phase === 'max-iterations' || state.phase === 'circuit-breaker') {\n793\t        halted = true;\n794\t      }\n795\t      continue;\n796\t    }\n797\t\n798\t    // step is a string task name\n799\t    const taskName = step;\n800\t    const task = config.workflow.tasks[taskName];\n801\t\n802\t    if (!task) {\n803\t      warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n804\t      continue;\n805\t    }\n806\t\n807\t    // Look up the