ddedAgent('foo bar')).toThrow(AgentResolveError);\n    });\n\n    it('throws AgentResolveError when embedded YAML is invalid', () => {\n      // Mock readFileSync to return invalid YAML for the parse error branch\n      const readSpy = vi.spyOn(fs, 'readFileSync').mockReturnValue('{ bad yaml [[[');\n      try {\n        expect(() => loadEmbeddedAgent('dev')).toThrow(AgentResolveError);\n        try {\n          loadEmbeddedAgent('dev');\n        } catch (err) {\n          const e = err as AgentResolveError;\n          expect(e.message).toContain('Invalid YAML');\n        }\n      } finally {\n        readSpy.mockRestore();\n      }\n    });\n\n    it('throws AgentResolveError when embedded YAML fails schema validation', () => {\n      // Mock readFileSync to return valid YAML but invalid agent config\n      const readSpy = vi.spyOn(fs, 'readFileSync').mockReturnValue('invalid_field: true');\n      try {\n        expect(() => loadEmbeddedAgent('dev')).toThrow(AgentResolveError);\n        try {\n          loadEmbeddedAgent('dev');\n        } catch (err) {\n          const e = err as AgentResolveError;\n          expect(e.message).toContain('Schema validation failed');\n        }\n      } finally {\n        readSpy.mockRestore();\n      }\n    });"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":715,"cache_read_input_tokens":46377,"cache_creation":{"ephemeral_5m_input_tokens":715,"ephemeral_1h_input_tokens":0},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01TfX7ZQpGDbV1a3EhZ1z5Ve","session_id":"605a3302-c654-40ea-969b-1ce171500852","uuid":"475db600-8028-41c1-b1ff-f8145435bc2c"}
