{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LKAd2tDfCfiZ9vrGm239mp","type":"tool_result","content":"   290в†’      const writeResult = writeStateAtomic(migrated);\n   291в†’      if (!writeResult.success) {\n   292в†’        return fail(writeResult.error);\n   293в†’      }\n   294в†’      return ok(migrated);\n   295в†’    } catch (err: unknown) {\n   296в†’      const msg = err instanceof Error ? err.message : String(err);\n   297в†’      return fail(`Failed to read sprint state: ${msg}`);\n   298в†’    }\n   299в†’  }\n   300в†’\n   301в†’  // No sprint-state.json вЂ” try migration from old scattered files\n   302в†’  const migrationResult = migrateFromOldFormat();\n   303в†’  if (migrationResult.success) {\n   304в†’    return migrationResult;\n   305в†’  }\n   306в†’\n   307в†’  // Migration found nothing or failed вЂ” return default\n   308в†’  return ok(defaultState());\n   309в†’}\n   310в†’\n   311в†’/** Recompute sprint summary counts from story data */\n   312в†’export function computeSprintCounts(\n   313в†’  stories: Record<string, StoryState>,\n   314в†’): SprintState['sprint'] {\n   315в†’  let total = 0;\n   316в†’  let done = 0;\n   317в†’  let failed = 0;\n   318в†’  let blocked = 0;\n   319в†’  let inProgress: string | null = null;\n   320в†’\n   321в†’  for (const [key, story] of Object.entries(stories)) {\n   322в†’    total++;\n   323в†’    if (story.status === 'done') done++;\n   324в†’    else if (story.status === 'failed') failed++;\n   325в†’    else if (story.status === 'blocked') blocked++;\n   326в†’    else if (story.status === 'in-progress') inProgress = key;\n   327в†’  }\n   328в†’\n   329в†’  return { total, done, failed, blocked, inProgress };\n   330в†’}\n   331в†’\n   332в†’/**\n   333в†’ * Update a single story's status in sprint-state.json.\n   334в†’ * Reads current state, merges update, writes atomically.\n   335в†’ */\n   336в†’export function updateStoryStatus(\n   337в†’  key: string,\n   338в†’  status: StoryStatus,\n   339в†’  detail?: StoryDetail,"}]},"parent_tool_use_id":null,"session_id":"2a44c687-0795-47af-a7f4-46576056f827","uuid":"ddaaf4b8-3c24-45b3-a90c-08bc49199115","timestamp":"2026-03-27T15:10:37.973Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ivintik/dev/personal/codeharness/src/modules/sprint/state.ts","content":"      const writeResult = writeStateAtomic(migrated);\n      if (!writeResult.success) {\n        return fail(writeResult.error);\n      }\n      return ok(migrated);\n    } catch (err: unknown) {\n      const msg = err instanceof Error ? err.message : String(err);\n      return fail(`Failed to read sprint state: ${msg}`);\n    }\n  }\n\n  // No sprint-state.json вЂ” try migration from old scattered files\n  const migrationResult = migrateFromOldFormat();\n  if (migrationResult.success) {\n    return migrationResult;\n  }\n\n  // Migration found nothing or failed вЂ” return default\n  return ok(defaultState());\n}\n\n/** Recompute sprint summary counts from story data */\nexport function computeSprintCounts(\n  stories: Record<string, StoryState>,\n): SprintState['sprint'] {\n  let total = 0;\n  let done = 0;\n  let failed = 0;\n  let blocked = 0;\n  let inProgress: string | null = null;\n\n  for (const [key, story] of Object.entries(stories)) {\n    total++;\n    if (story.status === 'done') done++;\n    else if (story.status === 'failed') failed++;\n    else if (story.status === 'blocked') blocked++;\n    else if (story.status === 'in-progress') inProgress = key;\n  }\n\n  return { total, done, failed, blocked, inProgress };\n}\n\n/**\n * Update a single story's status in sprint-state.json.\n * Reads current state, merges update, writes atomically.\n */\nexport function updateStoryStatus(\n  key: string,\n  status: StoryStatus,\n  detail?: StoryDetail,","numLines":50,"startLine":290,"totalLines":575}}}
