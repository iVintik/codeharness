{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01A4CdFzEY8N3BLiW8oYjGCW","type":"tool_result","content":"1\timport Ajv from 'ajv';\n2\timport verdictSchema from '../schemas/verdict.schema.json';\n3\t\n4\t// --- Interfaces ---\n5\t\n6\t/**\n7\t * Evaluator verdict returned by a verify task (AD5).\n8\t */\n9\texport interface EvaluatorVerdict {\n10\t  verdict: 'pass' | 'fail';\n11\t  score: {\n12\t    passed: number;\n13\t    failed: number;\n14\t    unknown: number;\n15\t    total: number;\n16\t  };\n17\t  findings: Array<{\n18\t    ac: number;\n19\t    description: string;\n20\t    status: 'pass' | 'fail' | 'unknown';\n21\t    evidence: {\n22\t      commands_run: string[];\n23\t      output_observed: string;\n24\t      reasoning: string;\n25\t    };\n26\t  }>;\n27\t  evaluator_trace_id?: string;\n28\t  duration_seconds?: number;\n29\t}\n30\t\n31\t/**\n32\t * Result of verdict validation.\n33\t */\n34\texport interface VerdictValidationResult {\n35\t  valid: boolean;\n36\t  errors?: string[];\n37\t  verdict?: EvaluatorVerdict;\n38\t}\n39\t\n40\t// --- Errors ---\n41\t\n42\t/**\n43\t * Error thrown when verdict parsing fails.\n44\t * `retryable: true` signals the caller should re-dispatch the evaluator.\n45\t * `retryable: false` signals no further retries should be attempted.\n46\t */\n47\texport class VerdictParseError extends Error {\n48\t  public readonly retryable: boolean;\n49\t  public readonly rawOutput: string;\n50\t  public readonly validationErrors?: string[];\n51\t\n52\t  constructor(\n53\t    message: string,\n54\t    retryable: boolean,\n55\t    rawOutput: string,\n56\t    validationErrors?: string[],\n57\t  ) {\n58\t    super(message);\n59\t    this.name = 'VerdictParseError';\n60\t    this.retryable = retryable;\n61\t    this.rawOutput = rawOutput;\n62\t    this.validationErrors = validationErrors;\n63\t  }\n64\t}\n65\t\n66\t// --- Schema Validator (compiled once at module load) ---\n67\t\n68\tconst ajv = new Ajv({ allErrors: true });\n69\tconst validateSchema = ajv.compile(verdictSchema);\n70\t\n71\t// --- Functions ---\n72\t\n73\t/**\n74\t * Validate an unknown value against the verdict JSON schema.\n75\t * Returns a VerdictValidationResult with typed verdict on success,\n76\t * or error messages on failure.\n77\t */\n78\texport function validateVerdict(data: unknown): VerdictValidationResult {\n79\t  const valid = validateSchema(data);\n80\t\n81\t  if (valid) {\n82\t    return { valid: true, verdict: data as unknown as EvaluatorVerdict };\n83\t  }\n84\t\n85\t  const errors = (validateSchema.errors ?? []).map((err) => {\n86\t    const path = err.instancePath || '/';\n87\t    return `${path}: ${err.message ?? 'unknown error'}`;\n88\t  });\n89\t\n90\t  return { valid: false, errors };\n91\t}\n92\t\n93\t/**\n94\t * Parse raw evaluator output into a typed EvaluatorVerdict.\n95\t *\n96\t * On success: returns a fully typed EvaluatorVerdict with PASS-evidence\n97\t * invariant enforced (PASS findings without commands_run are downgraded\n98\t * to UNKNOWN).\n99\t *\n100\t * On failure: throws VerdictParseError with `retryable: true`.\n101\t * The caller (workflow engine) decides whether to retry. On a second\n102\t * failure, the caller should catch and generate an all-UNKNOWN verdict.\n103\t */\n104\texport function parseVerdict(output: string): EvaluatorVerdict {\n105\t  // Step 1: JSON.parse\n106\t  let parsed: unknown;\n107\t  try {\n108\t    parsed = JSON.parse(output);\n109\t  } catch { // IGNORE: invalid JSON — rethrow as VerdictParseError\n110\t    throw new VerdictParseError(\n111\t      'Failed to parse verdict: invalid JSON',\n112\t      true,\n113\t      output,\n114\t    );\n115\t  }\n116\t\n117\t  // Step 2: Schema validation\n118\t  const result = validateVerdict(parsed);\n119\t  if (!result.valid) {\n120\t    throw new VerdictParseError(\n121\t      `Failed to parse verdict: schema validation failed`,\n122\t      true,\n123\t      output,\n124\t      result.errors,\n125\t    );\n126\t  }\n127\t\n128\t  const verdict = result.verdict!;\n129\t\n130\t  // Step 3: Enforce PASS-evidence invariant (AD5 / FR26)\n131\t  // If a finding has status 'pass' but empty commands_run, downgrade to 'unknown'.\n132\t  let passDowngraded = false;\n133\t  for (const finding of verdict.findings) {\n134\t    if (\n135\t      finding.status === 'pass' &&\n136\t      (!finding.evidence.commands_run || finding.evidence.commands_run.length === 0)\n137\t    ) {\n138\t      finding.status = 'unknown';\n139\t      finding.evidence.reasoning +=\n140\t        ' [Downgraded from PASS: no commands_run evidence provided]';\n141\t      passDowngraded = true;\n142\t    }\n143\t  }\n144\t\n145\t  // Step 4: Recalculate score if any findings were downgraded\n146\t  if (passDowngraded) {\n147\t    let passed = 0;\n148\t    let failed = 0;\n149\t    let unknown = 0;\n150\t    for (const finding of verdict.findings) {\n151\t      if (finding.status === 'pass') passed++;\n152\t      else if (finding.status === 'fail') failed++;\n153\t      else unknown++;\n154\t    }\n155\t    verdict.score = {\n156\t      passed,\n157\t      failed,\n158\t      unknown,\n159\t      total: verdict.findings.length,\n160\t    };\n161\t\n162\t    // Flip verdict to 'fail' if no PASSes remain\n163\t    if (passed === 0) {\n164\t      verdict.verdict = 'fail';\n165\t    }\n166\t  }\n167\t\n168\t  return verdict;\n169\t}\n170\t"}]},"parent_tool_use_id":"toolu_01Lp1WM9dkDn419erDDCd9nG","session_id":"64d7a6a2-a6f8-43cb-b618-df314a0f5500","uuid":"015ce0f1-7088-4952-9048-00a674c84cdd","timestamp":"2026-04-03T00:08:54.251Z"}
