{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Reue1bN1ZkhkygRUuXcmgi","type":"tool_result","content":"80\t  storyKey: string;\n81\t  code: string;\n82\t  message: string;\n83\t}\n84\t\n85\t/**\n86\t * A work item (story or issue) ready for execution.\n87\t */\n88\texport interface WorkItem {\n89\t  key: string;\n90\t  title?: string;\n91\t  source: 'sprint' | 'issues';\n92\t}\n93\t\n94\t// --- Constants ---\n95\t\n96\t/** Sentinel story key for per-run tasks. */\n97\texport const PER_RUN_SENTINEL = '__run__';\n98\t\n99\t/** DispatchError codes that should halt execution immediately. */\n100\tconst HALT_ERROR_CODES = new Set(['RATE_LIMIT', 'NETWORK', 'SDK_INIT']);\n101\t\n102\t/** Default maximum loop iterations before termination. */\n103\tconst DEFAULT_MAX_ITERATIONS = 5;\n104\t\n105\t// --- Coverage Deduplication (Story 16-5) ---\n106\t\n107\t/**\n108\t * Build a coverage context string for injection into the verify task prompt.\n109\t *\n110\t * Returns a formatted coverage context line if:\n111\t * 1. `coverage_met` is `true` in harness state\n112\t * 2. The previous output contract has non-null `testResults.coverage`\n113\t *\n114\t * Returns null if coverage deduplication should not apply (coverage not met,\n115\t * no contract data, or state unreadable).\n116\t */\n117\texport function buildCoverageDeduplicationContext(\n118\t  contract: OutputContract | null,\n119\t  projectDir: string,\n120\t): string | null {\n121\t  // Guard: no contract or no test results\n122\t  if (!contract?.testResults) return null;\n123\t\n124\t  const { coverage } = contract.testResults;\n125\t  if (coverage === null || coverage === undefined) return null;\n126\t\n127\t  // Check harness state for coverage_met flag\n128\t  try {\n129\t    const { state } = readStateWithBody(projectDir);\n130\t    if (!state.session_flags.coverage_met) return null;\n131\t\n132\t    const target = state.coverage.target ?? 90;\n133\t    return formatCoverageContextMessage(coverage, target);\n134\t  } catch {\n135\t    // IGNORE: state unreadable — no deduplication\n136\t    return null;\n137\t  }\n138\t}\n139\t\n140\t// --- Verify Flag Propagation (Story 16-4) ---\n141\t\n142\t/**\n143\t * Propagate test/coverage flags from the implement task's output contract\n144\t * to the harness state file. Only runs for tasks named 'implement' whose\n145\t * output contract contains a non-null `testResults`.\n146\t *\n147\t * This sets `session_flags.tests_passed` and `session_flags.coverage_met`\n148\t * before the verify task runs, so verify's precondition check passes\n149\t * without re-running coverage.\n150\t */\n151\tfunction propagateVerifyFlags(\n152\t  taskName: string,\n153\t  contract: OutputContract | null,\n154\t  projectDir: string,\n155\t): void {\n156\t  // Guard: only run for implement tasks\n157\t  if (taskName !== 'implement') return;\n158\t\n159\t  // Guard: skip if no contract or no test results"}]},"parent_tool_use_id":"toolu_01VgpeTZfnrFArETEmV1Y2uT","session_id":"1e0d780f-040f-4c10-b8e5-df49ae6fae2c","uuid":"0572a81e-37c1-4558-bbac-59d8c4c103dc","timestamp":"2026-04-03T20:40:37.644Z"}
