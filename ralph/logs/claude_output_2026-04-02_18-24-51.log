{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01V2RRb9Gi7xQ6G7tXHhHXqV","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n2\timport { mkdtempSync, rmSync, writeFileSync, existsSync } from 'node:fs';\n3\timport { tmpdir } from 'node:os';\n4\timport { join } from 'node:path';\n5\t\n6\t// Mock all lib modules\n7\tvi.mock('../../../lib/stacks/index.js', async (importOriginal) => {\n8\t  const orig = await importOriginal<typeof import('../../../lib/stacks/index.js')>();\n9\t  return { ...orig, detectStacks: vi.fn(orig.detectStacks), detectAppType: vi.fn(orig.detectAppType) };\n10\t});\n11\t\n12\tvi.mock('../docs-scaffold.js', async (importOriginal) => {\n13\t  const orig = await importOriginal<typeof import('../docs-scaffold.js')>();\n14\t  return { ...orig, getCoverageTool: vi.fn(orig.getCoverageTool), getStackLabel: vi.fn(orig.getStackLabel) };\n15\t});\n16\t\n17\tvi.mock('../../../lib/stack-path.js', () => ({\n18\t  getComposeFilePath: vi.fn(() => '/mock/.codeharness/stack/docker-compose.harness.yml'),\n19\t  getElkComposeFilePath: vi.fn(() => '/mock/.codeharness/stack/docker-compose.elk.yml'),\n20\t  ensureStackDir: vi.fn(),\n21\t}));\n22\t\n23\tvi.mock('../../../lib/docker/index.js', () => ({\n24\t  isDockerAvailable: vi.fn(() => true),\n25\t  isSharedStackRunning: vi.fn(() => false),\n26\t  startSharedStack: vi.fn(() => ({\n27\t    started: true,\n28\t    services: [{ name: 'otel-collector', status: 'running', port: '4317,4318' }],\n29\t  })),\n30\t  startCollectorOnly: vi.fn(() => ({\n31\t    started: true,\n32\t    services: [{ name: 'otel-collector', status: 'running', port: '4317,4318' }],\n33\t  })),\n34\t}));\n35\t\n36\tvi.mock('../../../lib/deps.js', () => ({\n37\t  installAllDependencies: vi.fn(() => [\n38\t    { name: 'showboat', displayName: 'Showboat', status: 'already-installed', version: '0.6.1' },\n39\t  ]),\n40\t  checkInstalled: vi.fn(() => ({ installed: true, version: '1.0.0' })),\n41\t  DEPENDENCY_REGISTRY: [\n42\t    {\n43\t      name: 'showboat',\n44\t      displayName: 'Showboat',\n45\t      installCommands: [{ cmd: 'pip', args: ['install', 'showboat'] }],\n46\t      checkCommand: { cmd: 'showboat', args: ['--version'] },\n47\t      critical: false,\n48\t    },\n49\t  ],\n50\t  CriticalDependencyError: class extends Error {\n51\t    constructor(d: string, r: string) { super(`Critical dependency '${d}' failed: ${r}`); this.name = 'CriticalDependencyError'; }\n52\t  },\n53\t}));\n54\t\n55\t\n56\tvi.mock('../../../lib/bmad.js', () => ({\n57\t  isBmadInstalled: vi.fn(() => false),\n58\t  installBmad: vi.fn(() => ({ status: 'installed', version: '6.0.0', patches_applied: [] })),\n59\t  applyAllPatches: vi.fn(() => []),\n60\t  detectBmadVersion: vi.fn(() => '6.0.0'),\n61\t  detectBmalph: vi.fn(() => ({ detected: false, files: [] })),\n62\t  BmadError: class extends Error {\n63\t    constructor(c: string, m: string) { super(`BMAD failed: ${m}`); this.name = 'BmadError'; }\n64\t  },\n65\t}));\n66\t\n67\tvi.mock('../../../lib/observability/index.js', () => ({\n68\t  instrumentProject: vi.fn(() => ({\n69\t    status: 'configured',\n70\t    packages_installed: true,\n71\t    start_script_patched: true,\n72\t    env_vars_configured: true,\n73\t  })),\n74\t  configureOtlpEnvVars: vi.fn(),\n75\t}));\n76\t\n77\tvi.mock('../../../lib/templates.js', async () => {\n78\t  const { readFileSync } = await vi.importActual<typeof import('node:fs')>('node:fs');\n79\t  const { resolve, dirname } = await vi.importActual<typeof import('node:path')>('node:path');\n80\t  const { fileURLToPath } = await vi.importActual<typeof import('node:url')>('node:url');\n81\t  const pkgRoot = resolve(dirname(fileURLToPath(import.meta.url)), '..', '..', '..', '..');\n82\t  return {\n83\t    generateFile: vi.fn(),\n84\t    renderTemplate(template: string, vars: Record<string, string>): string {\n85\t      return template.replace(/\\{\\{(\\w+)\\}\\}/g, (match: string, key: string) => vars[key] ?? match);\n86\t    },\n87\t    renderTemplateFile(templatePath: string, vars: Record<string, string> = {}): string {\n88\t      const fullPath = resolve(pkgRoot, templatePath);\n89\t      const content = readFileSync(fullPath, 'utf-8');\n90\t      if (Object.keys(vars).length === 0) return content;\n91\t      return content.replace(/\\{\\{(\\w+)\\}\\}/g, (match: string, key: string) => vars[key] ?? match);\n92\t    },\n93\t    getPackageRoot() { return pkgRoot; },\n94\t  };\n95\t});\n96\t\n97\tvi.mock('../../../templates/readme.js', () => ({\n98\t  readmeTemplate: vi.fn(() => '# README'),\n99\t}));\n100\t\n101\timport { isDockerAvailable } from '../../../lib/docker/index.js';\n102\timport { installAllDependencies, CriticalDependencyError } from '../../../lib/deps.js';\n103\timport { readState, writeState, getDefaultState } from '../../../lib/state.js';\n104\timport { detectStacks, detectAppType } from '../../../lib/stacks/index.js';\n105\timport { instrumentProject } from '../../../lib/observability/index.js';\n106\timport { getCoverageTool } from '../docs-scaffold.js';\n107\timport { initProject } from '../init-project.js';\n108\t\n109\tconst mockIsDockerAvailable = vi.mocked(isDockerAvailable);\n110\tconst mockInstallAll = vi.mocked(installAllDependencies);\n111\tconst mockDetectStacks = vi.mocked(detectStacks);\n112\tconst mockInstrumentProject = vi.mocked(instrumentProject);\n113\tconst mockGetCoverageTool = vi.mocked(getCoverageTool);\n114\t\n115\tlet testDir: string;\n116\tlet originalCwd: string;\n117\t\n118\tbeforeEach(() => {\n119\t  testDir = mkdtempSync(join(tmpdir(), 'ch-init-project-test-'));\n120\t  originalCwd = process.cwd();\n121\t  process.chdir(testDir);\n122\t  vi.spyOn(console, 'log').mockImplementation(() => {});\n123\t  process.exitCode = undefined;\n124\t  // Reset mocks to default implementations\n125\t  mockIsDockerAvailable.mockReturnValue(true);\n126\t  mockInstallAll.mockReturnValue([\n127\t    { name: 'showboat', displayName: 'Showboat', status: 'already-installed', version: '0.6.1' },\n128\t  ]);\n129\t});\n130\t\n131\tafterEach(() => {\n132\t  process.chdir(originalCwd);\n133\t  rmSync(testDir, { recursive: true, force: true });\n134\t  vi.restoreAllMocks();\n135\t  process.exitCode = undefined;\n136\t});\n137\t\n138\tdescribe('initProject — fresh init', () => {\n139\t  it('returns ok result with correct structure', async () => {\n140\t    writeFileSync(join(testDir, 'package.json'), '{}');\n141\t    const result = await initProject({\n142\t      projectDir: testDir,\n143\t      frontend: true,\n144\t      database: true,\n145\t      api: true,\n146\t      observability: false,\n147\t    });\n148\t    expect(result.success).toBe(true);\n149\t    if (result.success) {\n150\t      expect(result.data.status).toBe('ok');\n151\t      expect(result.data.stack).toBe('nodejs');\n152\t      expect(result.data.enforcement).toEqual({ frontend: true, database: true, api: true });\n153\t    }\n154\t  });\n155\t\n156\t  it('creates state file', async () => {\n157\t    writeFileSync(join(testDir, 'package.json'), '{}');\n158\t    await initProject({\n159\t      projectDir: testDir,\n160\t      frontend: true,\n161\t      database: true,\n162\t      api: true,\n163\t      observability: false,\n164\t    });\n165\t    const state = readState(testDir);\n166\t    expect(state.initialized).toBe(true);\n167\t    expect(state.stack).toBe('nodejs');\n168\t  });\n169\t\n170\t  it('includes beads result (skipped since beads removed)', async () => {\n171\t    writeFileSync(join(testDir, 'package.json'), '{}');\n172\t    const result = await initProject({\n173\t      projectDir: testDir,\n174\t      frontend: true,\n175\t      database: true,\n176\t      api: true,\n177\t      observability: false,\n178\t    });\n179\t    if (result.success) {\n180\t      expect(result.data.beads).toBeDefined();\n181\t      expect(result.data.beads!.status).toBe('skipped');\n182\t    }\n183\t  });\n184\t\n185\t  it('includes bmad result', async () => {\n186\t    writeFileSync(join(testDir, 'package.json'), '{}');\n187\t    const result = await initProject({\n188\t      projectDir: testDir,\n189\t      frontend: true,\n190\t      database: true,\n191\t      api: true,\n192\t      observability: false,\n193\t    });\n194\t    if (result.success) {\n195\t      expect(result.data.bmad).toBeDefined();\n196\t      expect(result.data.bmad!.status).toBe('installed');\n197\t    }\n198\t  });\n199\t\n200\t  it('includes dependencies result', async () => {\n201\t    writeFileSync(join(testDir, 'package.json'), '{}');\n202\t    const result = await initProject({\n203\t      projectDir: testDir,\n204\t      frontend: true,\n205\t      database: true,\n206\t      api: true,\n207\t      observability: false,\n208\t    });\n209\t    if (result.success) {\n210\t      expect(result.data.dependencies).toBeDefined();\n211\t      expect(result.data.dependencies!.length).toBeGreaterThan(0);\n212\t    }\n213\t  });\n214\t});\n215\t\n216\tdescribe('initProject — idempotent re-run', () => {\n217\t  it('detects already initialized and returns early', async () => {\n218\t    writeFileSync(join(testDir, 'package.json'), '{}');\n219\t    // First init\n220\t    await initProject({\n221\t      projectDir: testDir,\n222\t      frontend: true,\n223\t      database: true,\n224\t      api: true,\n225\t      observability: false,\n226\t    });\n227\t    // Second init (re-run)\n228\t    const result = await initProject({\n229\t      projectDir: testDir,\n230\t      frontend: true,\n231\t      database: true,\n232\t      api: true,\n233\t      observability: false,\n234\t    });\n235\t    expect(result.success).toBe(true);\n236\t    if (result.success) {\n237\t      expect(result.data.documentation.agents_md).toBe('exists');\n238\t    }\n239\t  });\n240\t});\n241\t\n242\tdescribe('initProject — critical failures', () => {\n243\t  it('returns ok with fail status when Docker missing and observability on', async () => {\n244\t    writeFileSync(join(testDir, 'package.json'), '{}');\n245\t    mockIsDockerAvailable.mockReturnValue(false);\n246\t    const result = await initProject({\n247\t      projectDir: testDir,\n248\t      frontend: true,\n249\t      database: true,\n250\t      api: true,\n251\t      observability: true,\n252\t    });\n253\t    expect(result.success).toBe(true);\n254\t    if (result.success) {\n255\t      expect(result.data.status).toBe('fail');\n256\t      expect(result.data.error).toBe('Docker not installed');\n257\t    }\n258\t    expect(process.exitCode).toBe(1);\n259\t  });\n260\t\n261\t  it('returns ok with fail status on critical dep failure', async () => {\n262\t    writeFileSync(join(testDir, 'package.json'), '{}');\n263\t    mockInstallAll.mockImplementation(() => {\n264\t      throw new CriticalDependencyError('git', 'not found');\n265\t    });\n266\t    const result = await initProject({\n267\t      projectDir: testDir,\n268\t      frontend: true,\n269\t      database: true,\n270\t      api: true,\n271\t      observability: false,\n272\t    });\n273\t    expect(result.success).toBe(true);\n274\t    if (result.success) {\n275\t      expect(result.data.status).toBe('fail');\n276\t    }\n277\t    expect(process.exitCode).toBe(1);\n278\t  });\n279\t});\n280\t\n281\t// beads failure test removed — beads integration removed (Epic 8 replacement pending)\n282\t\n283\tdescribe('initProject — URL validation', () => {\n284\t  it('rejects invalid URL', async () => {\n285\t    writeFileSync(join(testDir, 'package.json'), '{}');\n286\t    const result = await initProject({\n287\t      projectDir: testDir,\n288\t      frontend: true,\n289\t      database: true,\n290\t      api: true,\n291\t      observability: true,\n292\t      otelEndpoint: 'not-a-url',\n293\t    });\n294\t    expect(result.success).toBe(true);\n295\t    if (result.success) {\n296\t      expect(result.data.status).toBe('fail');\n297\t      expect(result.data.error).toContain('Invalid URL');\n298\t    }\n299\t  });\n300\t\n301\t  it('rejects combining otel-endpoint with backend URLs', async () => {\n302\t    writeFileSync(join(testDir, 'package.json'), '{}');\n303\t    const result = await initProject({\n304\t      projectDir: testDir,\n305\t      frontend: true,\n306\t      database: true,\n307\t      api: true,\n308\t      observability: true,\n309\t      otelEndpoint: 'http://remote:4318',\n310\t      logsUrl: 'http://logs:9428',\n311\t    });\n312\t    expect(result.success).toBe(true);\n313\t    if (result.success) {\n314\t      expect(result.data.status).toBe('fail');\n315\t      expect(result.data.error).toContain('Cannot combine');\n316\t    }\n317\t  });\n318\t\n319\t  it('requires all three backend URLs', async () => {\n320\t    writeFileSync(join(testDir, 'package.json'), '{}');\n321\t    const result = await initProject({\n322\t      projectDir: testDir,\n323\t      frontend: true,\n324\t      database: true,\n325\t      api: true,\n326\t      observability: true,\n327\t      logsUrl: 'http://logs:9428',\n328\t    });\n329\t    expect(result.success).toBe(true);\n330\t    if (result.success) {\n331\t      expect(result.data.status).toBe('fail');\n332\t      expect(result.data.error).toContain('all three are required');\n333\t    }\n334\t  });\n335\t});\n336\t\n337\tdescribe('initProject — observability modes', () => {\n338\t  it('skips OTLP when observability off', async () => {\n339\t    writeFileSync(join(testDir, 'package.json'), '{}');\n340\t    const result = await initProject({\n341\t      projectDir: testDir,\n342\t      frontend: true,\n343\t      database: true,\n344\t      api: true,\n345\t      observability: false,\n346\t    });\n347\t    expect(result.success).toBe(true);\n348\t    if (result.success) {\n349\t      expect(result.data.otlp!.status).toBe('skipped');\n350\t      expect(result.data.docker).toBeNull();\n351\t    }\n352\t  });\n353\t});\n354\t\n355\tdescribe('initProject — observability backend choice', () => {\n356\t  it('stores otlp.backend: victoria when --observability-backend victoria', async () => {\n357\t    writeFileSync(join(testDir, 'package.json'), '{}');\n358\t    await initProject({\n359\t      projectDir: testDir,\n360\t      frontend: true,\n361\t      database: true,\n362\t      api: true,\n363\t      observability: true,\n364\t      observabilityBackend: 'victoria',\n365\t    });\n366\t    const state = readState(testDir);\n367\t    expect(state.otlp?.backend).toBe('victoria');\n368\t  });\n369\t\n370\t  it('stores otlp.backend: elk when --observability-backend elk', async () => {\n371\t    writeFileSync(join(testDir, 'package.json'), '{}');\n372\t    await initProject({\n373\t      projectDir: testDir,\n374\t      frontend: true,\n375\t      database: true,\n376\t      api: true,\n377\t      observability: true,\n378\t      observabilityBackend: 'elk',\n379\t    });\n380\t    const state = readState(testDir);\n381\t    expect(state.otlp?.backend).toBe('elk');\n382\t  });\n383\t\n384\t  it('stores otlp.backend: none and skips Docker when --observability-backend none', async () => {\n385\t    writeFileSync(join(testDir, 'package.json'), '{}');\n386\t    const result = await initProject({\n387\t      projectDir: testDir,\n388\t      frontend: true,\n389\t      database: true,\n390\t      api: true,\n391\t      observability: true,\n392\t      observabilityBackend: 'none',\n393\t    });\n394\t    const state = readState(testDir);\n395\t    expect(state.otlp?.backend).toBe('none');\n396\t    expect(state.otlp?.enabled).toBe(false);\n397\t    if (result.success) {\n398\t      expect(result.data.otlp?.status).toBe('skipped');\n399\t    }\n400\t  });\n401\t\n402\t  it('remote endpoint with elk backend stores both mode and backend', async () => {\n403\t    writeFileSync(join(testDir, 'package.json'), '{}');\n404\t    await initProject({\n405\t      projectDir: testDir,\n406\t      frontend: true,\n407\t      database: true,\n408\t      api: true,\n409\t      observability: true,\n410\t      observabilityBackend: 'elk',\n411\t      otelEndpoint: 'http://remote:4318',\n412\t    });\n413\t    const state = readState(testDir);\n414\t    expect(state.otlp?.backend).toBe('elk');\n415\t    expect(state.otlp?.mode).toBe('remote-direct');\n416\t  });\n417\t\n418\t  it('defaults to victoria when no --observability-backend flag', async () => {\n419\t    writeFileSync(join(testDir, 'package.json'), '{}');\n420\t    await initProject({\n421\t      projectDir: testDir,\n422\t      frontend: true,\n423\t      database: true,\n424\t      api: true,\n425\t      observability: true,\n426\t    });\n427\t    const state = readState(testDir);\n428\t    expect(state.otlp?.backend).toBe('victoria');\n429\t  });\n430\t\n431\t  it('rejects invalid --observability-backend value', async () => {\n432\t    writeFileSync(join(testDir, 'package.json'), '{}');\n433\t    const result = await initProject({\n434\t      projectDir: testDir,\n435\t      frontend: true,\n436\t      database: true,\n437\t      api: true,\n438\t      observability: true,\n439\t      observabilityBackend: 'foobar' as 'victoria',\n440\t    });\n441\t    expect(result.success).toBe(true);\n442\t    if (result.success) {\n443\t      expect(result.data.status).toBe('fail');\n444\t      expect(result.data.error).toContain('Invalid --observability-backend');\n445\t      expect(result.data.error).toContain('foobar');\n446\t    }\n447\t  });\n448\t});\n449\t\n450\tdescribe('initProject — unexpected errors', () => {\n451\t  it('returns fail instead of throwing on unexpected error', async () => {\n452\t    // Force an unexpected error by making detectStacks throw\n453\t    mockDetectStacks.mockImplementation(() => { throw new Error('kaboom'); });\n454\t    writeFileSync(join(testDir, 'package.json'), '{}');\n455\t    const result = await initProject({\n456\t      projectDir: testDir,\n457\t      frontend: true,\n458\t      database: true,\n459\t      api: true,\n460\t      observability: false,\n461\t    });\n462\t    expect(result.success).toBe(false);\n463\t    if (!result.success) {\n464\t      expect(result.error).toContain('kaboom');\n465\t    }\n466\t  });\n467\t});\n468\t\n469\tdescribe('initProject — multi-stack orchestration', () => {\n470\t  const defaultOpts = {\n471\t    projectDir: '', // set in beforeEach via testDir\n472\t    frontend: true,\n473\t    database: true,\n474\t    api: true,\n475\t    observability: true,\n476\t  };\n477\t\n478\t  function makeOpts(overrides: Partial<typeof defaultOpts> = {}) {\n479\t    return { ...defaultOpts, projectDir: testDir, ...overrides };\n480\t  }\n481\t\n482\t  it('calls getCoverageTool() once per detected stack and stores tools map (Task 6)', async () => {\n483\t    writeFileSync(join(testDir, 'package.json'), '{}');\n484\t    writeFileSync(join(testDir, 'Cargo.toml'), '[package]\\nname = \"test\"');\n485\t    mockDetectStacks.mockReturnValue([\n486\t      { stack: 'nodejs', dir: '.' },\n487\t      { stack: 'rust', dir: '.' },\n488\t    ]);\n489\t    mockGetCoverageTool.mockClear();\n490\t\n491\t    await initProject(makeOpts({ observability: false }));\n492\t\n493\t    // getCoverageTool called for each stack in the loop + once for primary stack backward compat\n494\t    const calls = mockGetCoverageTool.mock.calls.map(c => c[0]);\n495\t    expect(calls).toContain('nodejs');\n496\t    expect(calls).toContain('rust');\n497\t\n498\t    // Verify per-stack tools map is persisted in state\n499\t    const state = readState(testDir);\n500\t    expect(state.coverage.tools).toBeDefined();\n501\t    expect(state.coverage.tools!['nodejs']).toBe('c8');\n502\t    expect(state.coverage.tools!['rust']).toBe('cargo-tarpaulin');\n503\t  });\n504\t\n505\t  it('calls instrumentProject() once per detected stack with correct dir (Task 7)', async () => {\n506\t    writeFileSync(join(testDir, 'package.json'), '{}');\n507\t    writeFileSync(join(testDir, 'Cargo.toml'), '[package]\\nname = \"test\"');\n508\t    mockDetectStacks.mockReturnValue([\n509\t      { stack: 'nodejs', dir: '.' },\n510\t      { stack: 'rust', dir: 'services/backend' },\n511\t    ]);\n512\t    mockInstrumentProject.mockClear();\n513\t\n514\t    await initProject(makeOpts({ observability: true }));\n515\t\n516\t    expect(mockInstrumentProject).toHaveBeenCalledTimes(2);\n517\t    // First call: nodejs at project root\n518\t    expect(mockInstrumentProject.mock.calls[0][0]).toBe(testDir);\n519\t    expect(mockInstrumentProject.mock.calls[0][1]).toBe('nodejs');\n520\t    // Second call: rust at subdirectory\n521\t    expect(mockInstrumentProject.mock.calls[1][0]).toBe(join(testDir, 'services/backend'));\n522\t    expect(mockInstrumentProject.mock.calls[1][1]).toBe('rust');\n523\t  });\n524\t\n525\t  it('info output includes all detected stacks label (Task 8)', async () => {\n526\t    writeFileSync(join(testDir, 'package.json'), '{}');\n527\t    writeFileSync(join(testDir, 'Cargo.toml'), '[package]\\nname = \"test\"');\n528\t    mockDetectStacks.mockReturnValue([\n529\t      { stack: 'nodejs', dir: '.' },\n530\t      { stack: 'rust', dir: '.' },\n531\t    ]);\n532\t\n533\t    await initProject(makeOpts({ observability: false }));\n534\t\n535\t    const logCalls = (console.log as ReturnType<typeof vi.fn>).mock.calls.map(\n536\t      (c: unknown[]) => String(c[0])\n537\t    );\n538\t    const stackLine = logCalls.find((l: string) => l.includes('Stack detected:'));\n539\t    expect(stackLine).toBeDefined();\n540\t    expect(stackLine).toContain('Node.js (package.json)');\n541\t    expect(stackLine).toContain('Rust (Cargo.toml)');\n542\t  });\n543\t\n544\t  it('state file has stacks array and app_type from primary stack (Task 9)', async () => {\n545\t    writeFileSync(join(testDir, 'package.json'), '{}');\n546\t    writeFileSync(join(testDir, 'Cargo.toml'), '[package]\\nname = \"test\"');\n547\t    mockDetectStacks.mockReturnValue([\n548\t      { stack: 'nodejs', dir: '.' },\n549\t      { stack: 'rust', dir: '.' },\n550\t    ]);\n551\t\n552\t    await initProject(makeOpts({ observability: false }));\n553\t\n554\t    const state = readState(testDir);\n555\t    expect(state.stacks).toEqual(['nodejs', 'rust']);\n556\t    expect(state.app_type).toBeDefined();\n557\t    // Primary stack coverage tool should be set for backward compat\n558\t    expect(state.coverage.tool).toBe('c8'); // nodejs primary\n559\t  });\n560\t\n561\t  it('single-stack backward compat — single-stack project still works identically (Task 10)', async () => {\n562\t    writeFileSync(join(testDir, 'package.json'), '{}');\n563\t    mockDetectStacks.mockReturnValue([{ stack: 'nodejs', dir: '.' }]);\n564\t    mockInstrumentProject.mockClear();\n565\t\n566\t    const result = await initProject(makeOpts({ observability: true }));\n567\t\n568\t    expect(result.success).toBe(true);\n569\t    if (result.success) {\n570\t      expect(result.data.stack).toBe('nodejs');\n571\t      expect(result.data.stacks).toEqual(['nodejs']);\n572\t    }\n573\t\n574\t    const state = readState(testDir);\n575\t    expect(state.stack).toBe('nodejs');\n576\t    expect(state.stacks).toEqual(['nodejs']);\n577\t    expect(state.coverage.tool).toBe('c8');\n578\t\n579\t    // instrumentProject called exactly once for single stack\n580\t    expect(mockInstrumentProject).toHaveBeenCalledTimes(1);\n581\t    expect(mockInstrumentProject.mock.calls[0][1]).toBe('nodejs');\n582\t  });\n583\t\n584\t  it('OTLP result.otlp comes from root detection, not first matching stack name', async () => {\n585\t    writeFileSync(join(testDir, 'package.json'), '{}');\n586\t    // Subdirectory detection appears first but root detection appears second\n587\t    mockDetectStacks.mockReturnValue([\n588\t      { stack: 'nodejs', dir: 'packages/app' },\n589\t      { stack: 'nodejs', dir: '.' },\n590\t    ]);\n591\t    const rootOtlp = { status: 'configured' as const, packages_installed: true, start_script_patched: true, env_vars_configured: true };\n592\t    const subOtlp = { status: 'configured' as const, packages_installed: false, start_script_patched: false, env_vars_configured: false };\n593\t    mockInstrumentProject.mockClear();\n594\t    mockInstrumentProject.mockReturnValueOnce(subOtlp).mockReturnValueOnce(rootOtlp);\n595\t\n596\t    const result = await initProject(makeOpts({ observability: true }));\n597\t\n598\t    expect(result.success).toBe(true);\n599\t    if (result.success) {\n600\t      // result.otlp should be from the root detection (dir === '.'), not the subdirectory\n601\t      expect(result.data.otlp).toEqual(rootOtlp);\n602\t    }\n603\t  });\n604\t});\n605\t"}]},"parent_tool_use_id":"toolu_01NHkhcMSk3T2Xeht2RXYVq5","session_id":"5e9a7eca-0e0b-47b2-8610-117311a6629c","uuid":"98eb4e88-30bf-4d55-9a8e-8e496c887c09","timestamp":"2026-04-02T14:31:26.028Z"}
