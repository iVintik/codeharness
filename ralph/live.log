{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0189LgQnbGuLaep54h1QbtcW","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { parseStreamLine } from '../stream-parser.js';\n     3→import type {\n     4→  ToolStartEvent,\n     5→  ToolInputEvent,\n     6→  ToolCompleteEvent,\n     7→  TextEvent,\n     8→  RetryEvent,\n     9→  ResultEvent,\n    10→  StreamEvent,\n    11→} from '../stream-parser.js';\n    12→\n    13→// --- Helpers ---\n    14→\n    15→function line(obj: Record<string, unknown>): string {\n    16→  return JSON.stringify(obj);\n    17→}\n    18→\n    19→function streamEvent(event: Record<string, unknown>): string {\n    20→  return line({ type: 'stream_event', event });\n    21→}\n    22→\n    23→// --- AC #1: content_block_start with tool_use → tool-start ---\n    24→\n    25→describe('AC #1: tool-start', () => {\n    26→  it('parses content_block_start with tool_use', () => {\n    27→    const input = streamEvent({\n    28→      type: 'content_block_start',\n    29→      content_block: { type: 'tool_use', name: 'Bash', id: 'toolu_abc123' },\n    30→    });\n    31→    const result = parseStreamLine(input) as ToolStartEvent;\n    32→    expect(result).toEqual({\n    33→      type: 'tool-start',\n    34→      name: 'Bash',\n    35→      id: 'toolu_abc123',\n    36→    });\n    37→  });\n    38→\n    39→  it('handles different tool names', () => {\n    40→    const input = streamEvent({\n    41→      type: 'content_block_start',\n    42→      content_block: { type: 'tool_use', name: 'Read', id: 'toolu_xyz789' },\n    43→    });\n    44→    const result = parseStreamLine(input) as ToolStartEvent;\n    45→    expect(result).toEqual({\n    46→      type: 'tool-start',\n    47→      name: 'Read',\n    48→      id: 'toolu_xyz789',\n    49→    });\n    50→  });\n    51→\n    52→  it('returns null for content_block_start with text type', () => {\n    53→    const input = streamEvent({\n    54→      type: 'content_block_start',\n    55→      content_block: { type: 'text', text: '' },\n    56→    });\n    57→    expect(parseStreamLine(input)).toBeNull();\n    58→  });\n    59→\n    60→  it('returns null when content_block is missing', () => {\n    61→    const input = streamEvent({ type: 'content_block_start' });\n    62→    expect(parseStreamLine(input)).toBeNull();\n    63→  });\n    64→\n    65→  it('returns null when tool_use name is missing', () => {\n    66→    const input = streamEvent({\n    67→      type: 'content_block_start',\n    68→      content_block: { type: 'tool_use', id: 'toolu_xxx' },\n    69→    });\n    70→    expect(parseStreamLine(input)).toBeNull();\n    71→  });\n    72→\n    73→  it('returns null when tool_use id is missing', () => {\n    74→    const input = streamEvent({\n    75→      type: 'content_block_start',\n    76→      content_block: { type: 'tool_use', name: 'Bash' },\n    77→    });\n    78→    expect(parseStreamLine(input)).toBeNull();\n    79→  });\n    80→});\n    81→\n    82→// --- AC #2: content_block_delta with input_json_delta → tool-input ---\n    83→\n    84→describe('AC #2: tool-input', () => {\n    85→  it('parses input_json_delta', () => {\n    86→    const input = streamEvent({\n    87→      type: 'content_block_delta',\n    88→      delta: { type: 'input_json_delta', partial_json: '{\"command\":\"npm test\"}' },\n    89→    });\n    90→    const result = parseStreamLine(input) as ToolInputEvent;\n    91→    expect(result).toEqual({\n    92→      type: 'tool-input',\n    93→      partial: '{\"command\":\"npm test\"}',\n    94→    });\n    95→  });\n    96→\n    97→  it('handles empty partial_json', () => {\n    98→    const input = streamEvent({\n    99→      type: 'content_block_delta',\n   100→      delta: { type: 'input_json_delta', partial_json: '' },\n   101→    });\n   102→    const result = parseStreamLine(input) as ToolInputEvent;\n   103→    expect(result).toEqual({ type: 'tool-input', partial: '' });\n   104→  });\n   105→\n   106→  it('returns null when partial_json is not a string', () => {\n   107→    const input = streamEvent({\n   108→      type: 'content_block_delta',\n   109→      delta: { type: 'input_json_delta', partial_json: 42 },\n   110→    });\n   111→    expect(parseStreamLine(input)).toBeNull();\n   112→  });\n   113→\n   114→  it('returns null when delta is missing', () => {\n   115→    const input = streamEvent({ type: 'content_block_delta' });\n   116→    expect(parseStreamLine(input)).toBeNull();\n   117→  });\n   118→});\n   119→\n   120→// --- AC #3: content_block_stop → tool-complete ---\n   121→\n   122→describe('AC #3: tool-complete', () => {\n   123→  it('parses content_block_stop', () => {\n   124→    const input = streamEvent({ type: 'content_block_stop' });\n   125→    const result = parseStreamLine(input) as ToolCompleteEvent;\n   126→    expect(result).toEqual({ type: 'tool-complete' });\n   127→  });\n   128→\n   129→  it('ignores extra fields on content_block_stop', () => {\n   130→    const input = streamEvent({ type: 'content_block_stop', index: 0 });\n   131→    const result = parseStreamLine(input) as ToolCompleteEvent;\n   132→    expect(result).toEqual({ type: 'tool-complete' });\n   133→  });\n   134→});\n   135→\n   136→// --- AC #4: content_block_delta with text_delta → text ---\n   137→\n   138→describe('AC #4: text', () => {\n   139→  it('parses text_delta', () => {\n   140→    const input = streamEvent({\n   141→      type: 'content_block_delta',\n   142→      delta: { type: 'text_delta', text: \"I'll read the file...\" },\n   143→    });\n   144→    const result = parseStreamLine(input) as TextEvent;\n   145→    expect(result).toEqual({ type: 'text', text: \"I'll read the file...\" });\n   146→  });\n   147→\n   148→  it('handles empty text', () => {\n   149→    const input = streamEvent({\n   150→      type: 'content_block_delta',\n   151→      delta: { type: 'text_delta', text: '' },\n   152→    });\n   153→    const result = parseStreamLine(input) as TextEvent;\n   154→    expect(result).toEqual({ type: 'text', text: '' });\n   155→  });\n   156→\n   157→  it('returns null when text is not a string', () => {\n   158→    const input = streamEvent({\n   159→      type: 'content_block_delta',\n   160→      delta: { type: 'text_delta', text: 123 },\n   161→    });\n   162→    expect(parseStreamLine(input)).toBeNull();\n   163→  });\n   164→});\n   165→\n   166→// --- AC #5: system/api_retry → retry ---\n   167→\n   168→describe('AC #5: retry', () => {\n   169→  it('parses api_retry event', () => {\n   170→    const input = line({\n   171→      type: 'system',\n   172→      subtype: 'api_retry',\n   173→      attempt: 2,\n   174→      max_retries: 5,\n   175→      retry_delay_ms: 3000,\n   176→      error: 'overloaded_error',\n   177→    });\n   178→    const result = parseStreamLine(input) as RetryEvent;\n   179→    expect(result).toEqual({ type: 'retry', attempt: 2, delay: 3000 });\n   180→  });\n   181→\n   182→  it('returns null for system events without api_retry subtype', () => {\n   183→    const input = line({ type: 'system', subtype: 'init' });\n   184→    expect(parseStreamLine(input)).toBeNull();\n   185→  });\n   186→\n   187→  it('returns null when attempt is missing', () => {\n   188→    const input = line({\n   189→      type: 'system',\n   190→      subtype: 'api_retry',\n   191→      retry_delay_ms: 1000,\n   192→    });\n   193→    expect(parseStreamLine(input)).toBeNull();\n   194→  });\n   195→\n   196→  it('returns null when retry_delay_ms is missing', () => {\n   197→    const input = line({\n   198→      type: 'system',\n   199→      subtype: 'api_retry',\n   200→      attempt: 1,\n   201→    });\n   202→    expect(parseStreamLine(input)).toBeNull();\n   203→  });\n   204→});\n   205→\n   206→// --- AC #6: result → result ---\n   207→\n   208→describe('AC #6: result', () => {\n   209→  it('parses result event', () => {\n   210→    const input = line({\n   211→      type: 'result',\n   212→      cost_usd: 4.2,\n   213→      session_id: 'sess_abc123',\n   214→      result: 'All tasks completed successfully.',\n   215→    });\n   216→    const result = parseStreamLine(input) as ResultEvent;\n   217→    expect(result).toEqual({\n   218→      type: 'result',\n   219→      cost: 4.2,\n   220→      sessionId: 'sess_abc123',\n   221→    });\n   222→  });\n   223→\n   224→  it('handles zero cost', () => {\n   225→    const input = line({\n   226→      type: 'result',\n   227→      cost_usd: 0,\n   228→      session_id: 'sess_zero',\n   229→      result: '',\n   230→    });\n   231→    const result = parseStreamLine(input) as ResultEvent;\n   232→    expect(result).toEqual({ type: 'result', cost: 0, sessionId: 'sess_zero' });\n   233→  });\n   234→\n   235→  it('returns null when cost_usd is missing', () => {\n   236→    const input = line({ type: 'result', session_id: 'sess_xxx' });\n   237→    expect(parseStreamLine(input)).toBeNull();\n   238→  });\n   239→\n   240→  it('returns null when session_id is missing', () => {\n   241→    const input = line({ type: 'result', cost_usd: 1.5 });\n   242→    expect(parseStreamLine(input)).toBeNull();\n   243→  });\n   244→});\n   245→\n   246→// --- Edge Cases ---\n   247→\n   248→describe('edge cases', () => {\n   249→  it('returns null for empty string', () => {\n   250→    expect(parseStreamLine('')).toBeNull();\n   251→  });\n   252→\n   253→  it('returns null for whitespace-only string', () => {\n   254→    expect(parseStreamLine('   \\t  ')).toBeNull();\n   255→  });\n   256→\n   257→  it('returns null for invalid JSON', () => {\n   258→    expect(parseStreamLine('{invalid json}')).toBeNull();\n   259→  });\n   260→\n   261→  it('returns null for JSON primitive', () => {\n   262→    expect(parseStreamLine('\"just a string\"')).toBeNull();\n   263→  });\n   264→\n   265→  it('returns null for JSON array', () => {\n   266→    expect(parseStreamLine('[1, 2, 3]')).toBeNull();\n   267→  });\n   268→\n   269→  it('returns null for JSON number', () => {\n   270→    expect(parseStreamLine('42')).toBeNull();\n   271→  });\n   272→\n   273→  it('returns null for JSON boolean', () => {\n   274→    expect(parseStreamLine('true')).toBeNull();\n   275→  });\n   276→\n   277→  it('returns null for JSON null', () => {\n   278→    expect(parseStreamLine('null')).toBeNull();\n   279→  });\n   280→\n   281→  it('returns null for truncated JSON', () => {\n   282→    expect(parseStreamLine('{\"type\": \"stream_ev')).toBeNull();\n   283→  });\n   284→\n   285→  it('returns null for message_start', () => {\n   286→    const input = streamEvent({ type: 'message_start', message: {} });\n   287→    expect(parseStreamLine(input)).toBeNull();\n   288→  });\n   289→\n   290→  it('returns null for message_stop', () => {\n   291→    const input = streamEvent({ type: 'message_stop' });\n   292→    expect(parseStreamLine(input)).toBeNull();\n   293→  });\n   294→\n   295→  it('returns null for message_delta', () => {\n   296→    const input = streamEvent({\n   297→      type: 'message_delta',\n   298→      delta: { stop_reason: 'end_turn' },\n   299→    });\n   300→    expect(parseStreamLine(input)).toBeNull();\n   301→  });\n   302→\n   303→  it('returns null for unknown wrapper type', () => {\n   304→    const input = line({ type: 'ping' });\n   305→    expect(parseStreamLine(input)).toBeNull();\n   306→  });\n   307→\n   308→  it('returns null for stream_event without event field', () => {\n   309→    const input = line({ type: 'stream_event' });\n   310→    expect(parseStreamLine(input)).toBeNull();\n   311→  });\n   312→\n   313→  it('returns null for unknown delta type', () => {\n   314→    const input = streamEvent({\n   315→      type: 'content_block_delta',\n   316→      delta: { type: 'thinking_delta', thinking: 'hmm' },\n   317→    });\n   318→    expect(parseStreamLine(input)).toBeNull();\n   319→  });\n   320→\n   321→  it('handles line with trailing newline', () => {\n   322→    const input = streamEvent({\n   323→      type: 'content_block_stop',\n   324→    }) + '\\n';\n   325→    const result = parseStreamLine(input);\n   326→    expect(result).toEqual({ type: 'tool-complete' });\n   327→  });\n   328→});\n   329→\n   330→// --- Type exhaustiveness check ---\n   331→\n   332→describe('type safety', () => {\n   333→  it('StreamEvent type covers all variants', () => {\n   334→    // This is a compile-time check. If a new variant is added to StreamEvent\n   335→    // without being handled, TypeScript will error on exhaustive switches.\n   336→    const events: StreamEvent[] = [\n   337→      { type: 'tool-start', name: 'Bash', id: 'x' },\n   338→      { type: 'tool-input', partial: '{}' },\n   339→      { type: 'tool-complete' },\n   340→      { type: 'text', text: 'hello' },\n   341→      { type: 'retry', attempt: 1, delay: 1000 },\n   342→      { type: 'result', cost: 1.0, sessionId: 's' },\n   343→    ];\n   344→    expect(events).toHaveLength(6);\n   345→  });\n   346→});\n   347→"}]},"parent_tool_use_id":"toolu_01JZ7cmNZZkp82ndK5epjGGA","session_id":"eb26302c-c52a-41c7-9204-5eb8c12a854c","uuid":"496147e6-2458-4164-bef1-01ba0ddb8af4","timestamp":"2026-03-21T11:17:01.664Z"}
{"type":"system","subtype":"task_progress","task_id":"a91702976b13db5cb","tool_use_id":"toolu_01JZ7cmNZZkp82ndK5epjGGA","description":"Reading src/lib/run-helpers.ts","usage":{"total_tokens":23424,"tool_uses":10,"duration_ms":18042},"last_tool_name":"Read","uuid":"68017085-3013-49c2-9086-0c9c98b6d94e","session_id":"eb26302c-c52a-41c7-9204-5eb8c12a854c"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01TNGyDkLeLpgrFfJV67ESzr","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_015oU3SRY72hrKKJyPEHB3kX","name":"Read","input":{"file_path":"/Users/ivintik/dev/personal/codeharness/src/lib/run-helpers.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":11331,"cache_read_input_tokens":11905,"cache_creation":{"ephemeral_5m_input_tokens":11331,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01JZ7cmNZZkp82ndK5epjGGA","session_id":"eb26302c-c52a-41c7-9204-5eb8c12a854c","uuid":"ab4a6ba3-6b09-42a0-b3bc-128c374f3166"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015oU3SRY72hrKKJyPEHB3kX","type":"tool_result","content":"     1→/**\n     2→ * Helper functions for the run command.\n     3→ *\n     4→ * Extracted from run.ts to comply with NFR9 (max 300 lines per file).\n     5→ * Contains: elapsed time formatting, sprint status → story status mapping,\n     6→ * and ralph stderr → story message parsing.\n     7→ */\n     8→\n     9→import type { StoryStatusEntry, StoryStatusValue, StoryMessage } from './ink-components.js';\n    10→\n    11→// --- Story Counting ---\n    12→\n    13→/** Story key pattern: digit-digit-name */\n    14→const STORY_KEY_PATTERN = /^\\d+-\\d+-/;\n    15→\n    16→/**\n    17→ * Counts stories by status from sprint-status.yaml.\n    18→ */\n    19→export function countStories(statuses: Record<string, string>): {\n    20→  total: number;\n    21→  ready: number;\n    22→  done: number;\n    23→  inProgress: number;\n    24→  // eslint-disable-next-line @typescript-eslint/naming-convention\n    25→  verified: number;\n    26→} {\n    27→  let total = 0;\n    28→  let ready = 0;\n    29→  let done = 0;\n    30→  let inProgress = 0;\n    31→  // eslint-disable-next-line @typescript-eslint/naming-convention\n    32→  let verified = 0;\n    33→\n    34→  for (const [key, status] of Object.entries(statuses)) {\n    35→    if (!STORY_KEY_PATTERN.test(key)) continue;\n    36→    total++;\n    37→    if (status === 'backlog' || status === 'ready-for-dev') ready++;\n    38→    else if (status === 'done') done++;\n    39→    else if (status === 'in-progress' || status === 'review') inProgress++;\n    40→    else if (status === 'verifying') verified++;\n    41→  }\n    42→\n    43→  return { total, ready, done, inProgress, verified };\n    44→}\n    45→\n    46→// --- Spawn Args Builder ---\n    47→\n    48→/**\n    49→ * Builds the argument array for spawning Ralph.\n    50→ */\n    51→export function buildSpawnArgs(opts: {\n    52→  ralphPath: string;\n    53→  pluginDir: string;\n    54→  promptFile: string;\n    55→  maxIterations: number;\n    56→  timeout: number;\n    57→  iterationTimeout: number;\n    58→  calls: number;\n    59→  quiet: boolean;\n    60→  maxStoryRetries?: number;\n    61→  reset?: boolean;\n    62→}): string[] {\n    63→  const args = [\n    64→    opts.ralphPath,\n    65→    '--plugin-dir', opts.pluginDir,\n    66→    '--max-iterations', String(opts.maxIterations),\n    67→    '--timeout', String(opts.timeout),\n    68→    '--iteration-timeout', String(opts.iterationTimeout),\n    69→    '--calls', String(opts.calls),\n    70→    '--prompt', opts.promptFile,\n    71→  ];\n    72→\n    73→  // When not quiet, pass --live so ralph tees Claude's stream-json to stdout.\n    74→  // The Ink renderer reads stdout to show live tool calls and thoughts.\n    75→  if (!opts.quiet) {\n    76→    args.push('--live');\n    77→  }\n    78→\n    79→  if (opts.maxStoryRetries !== undefined) {\n    80→    args.push('--max-story-retries', String(opts.maxStoryRetries));\n    81→  }\n    82→\n    83→  if (opts.reset) {\n    84→    args.push('--reset');\n    85→  }\n    86→\n    87→  return args;\n    88→}\n    89→\n    90→// --- Elapsed Time Formatting (AC #6) ---\n    91→\n    92→/**\n    93→ * Format elapsed milliseconds as \"Xm\" or \"XhYm\".\n    94→ * Matches the UX spec format (not the DashboardFormatter \"Xm Ys\" format).\n    95→ */\n    96→export function formatElapsed(ms: number): string {\n    97→  const totalMinutes = Math.max(0, Math.floor(ms / 60_000));\n    98→  const hours = Math.floor(totalMinutes / 60);\n    99→  const minutes = totalMinutes % 60;\n   100→  if (hours > 0) {\n   101→    return `${hours}h${minutes}m`;\n   102→  }\n   103→  return `${totalMinutes}m`;\n   104→}\n   105→\n   106→// --- Sprint Status → Story Status Mapping (AC #7) ---\n   107→\n   108→/**\n   109→ * Maps a sprint-status.yaml status value to a StoryStatusValue for the Ink renderer.\n   110→ *\n   111→ * Mapping:\n   112→ *   done → done\n   113→ *   in-progress, review, verifying → in-progress\n   114→ *   backlog, ready-for-dev → pending\n   115→ *   failed → failed\n   116→ *   blocked, exhausted → blocked\n   117→ */\n   118→export function mapSprintStatus(status: string): StoryStatusValue {\n   119→  switch (status) {\n   120→    case 'done':\n   121→      return 'done';\n   122→    case 'in-progress':\n   123→    case 'review':\n   124→    case 'verifying':\n   125→      return 'in-progress';\n   126→    case 'backlog':\n   127→    case 'ready-for-dev':\n   128→      return 'pending';\n   129→    case 'failed':\n   130→      return 'failed';\n   131→    case 'blocked':\n   132→    case 'exhausted':\n   133→      return 'blocked';\n   134→    default:\n   135→      return 'pending';\n   136→  }\n   137→}\n   138→\n   139→/**\n   140→ * Converts sprint-status.yaml entries to StoryStatusEntry[] for the Ink renderer.\n   141→ * Filters out epic keys, retrospective keys, and optional entries.\n   142→ */\n   143→export function mapSprintStatuses(statuses: Record<string, string>): StoryStatusEntry[] {\n   144→  const entries: StoryStatusEntry[] = [];\n   145→  for (const [key, status] of Object.entries(statuses)) {\n   146→    if (!STORY_KEY_PATTERN.test(key)) continue;\n   147→    if (status === 'optional') continue;\n   148→    entries.push({ key, status: mapSprintStatus(status) });\n   149→  }\n   150→  return entries;\n   151→}\n   152→\n   153→// --- Ralph Stderr → Story Messages (AC #8) ---\n   154→\n   155→/** Strip ANSI color codes */\n   156→const ANSI_ESCAPE = /\\x1b\\[[0-9;]*m/g;\n   157→\n   158→/** Strip timestamp prefix from ralph output lines */\n   159→const TIMESTAMP_PREFIX = /^\\[[\\d-]+\\s[\\d:]+\\]\\s*/;\n   160→\n   161→/** Matches: [SUCCESS] Story {key}: DONE ... */\n   162→const SUCCESS_STORY = /\\[SUCCESS\\]\\s+Story\\s+([\\w-]+):\\s+DONE(.*)/;\n   163→\n   164→/** Matches: [WARN] Story {key} exceeded retry limit ... flagging */\n   165→const WARN_STORY_RETRY = /\\[WARN\\]\\s+Story\\s+([\\w-]+)\\s+exceeded retry limit/;\n   166→\n   167→/** Matches: [WARN] Story {key} ... retry N/M */\n   168→const WARN_STORY_RETRYING = /\\[WARN\\]\\s+Story\\s+([\\w-]+)\\s+.*retry\\s+(\\d+)\\/(\\d+)/;\n   169→\n   170→/** Matches: [LOOP] iteration N */\n   171→const LOOP_ITERATION = /\\[LOOP\\]\\s+iteration\\s+(\\d+)/;\n   172→\n   173→/** Matches: [ERROR] ... */\n   174→const ERROR_LINE = /\\[ERROR\\]\\s+(.+)/;\n   175→\n   176→/**\n   177→ * Parse a ralph output line and return a StoryMessage if it matches\n   178→ * a story completion, failure, or warning pattern.\n   179→ * Returns null for non-matching lines.\n   180→ */\n   181→export function parseRalphMessage(rawLine: string): StoryMessage | null {\n   182→  const clean = rawLine.replace(ANSI_ESCAPE, '').replace(TIMESTAMP_PREFIX, '').trim();\n   183→  if (clean.length === 0) return null;\n   184→\n   185→  // [SUCCESS] Story {key}: DONE ...\n   186→  const success = SUCCESS_STORY.exec(clean);\n   187→  if (success) {\n   188→    const key = success[1];\n   189→    const rest = success[2].trim().replace(/^—\\s*/, '');\n   190→    return {\n   191→      type: 'ok',\n   192→      key,\n   193→      message: rest ? `DONE — ${rest}` : 'DONE',\n   194→    };\n   195→  }\n   196→\n   197→  // [WARN] Story {key} exceeded retry limit\n   198→  const retryExceeded = WARN_STORY_RETRY.exec(clean);\n   199→  if (retryExceeded) {\n   200→    return {\n   201→      type: 'fail',\n   202→      key: retryExceeded[1],\n   203→      message: 'exceeded retry limit',\n   204→    };\n   205→  }\n   206→\n   207→  // [WARN] Story {key} — retry N/M\n   208→  const retrying = WARN_STORY_RETRYING.exec(clean);\n   209→  if (retrying) {\n   210→    return {\n   211→      type: 'warn',\n   212→      key: retrying[1],\n   213→      message: `retry ${retrying[2]}/${retrying[3]}`,\n   214→    };\n   215→  }\n   216→\n   217→  // [ERROR] ... — surface as a generic error message\n   218→  const errorMatch = ERROR_LINE.exec(clean);\n   219→  if (errorMatch) {\n   220→    // Try to extract story key from error message\n   221→    const keyMatch = errorMatch[1].match(/Story\\s+([\\w-]+)/);\n   222→    if (keyMatch) {\n   223→      return {\n   224→        type: 'fail',\n   225→        key: keyMatch[1],\n   226→        message: errorMatch[1].trim(),\n   227→      };\n   228→    }\n   229→    // Generic error without a story key — skip (no key to associate)\n   230→    return null;\n   231→  }\n   232→\n   233→  return null;\n   234→}\n   235→\n   236→/**\n   237→ * Parse a ralph stderr line for [LOOP] iteration messages.\n   238→ * Returns the iteration number if found, or null otherwise.\n   239→ */\n   240→export function parseIterationMessage(rawLine: string): number | null {\n   241→  const clean = rawLine.replace(ANSI_ESCAPE, '').replace(TIMESTAMP_PREFIX, '').trim();\n   242→  if (clean.length === 0) return null;\n   243→  const match = LOOP_ITERATION.exec(clean);\n   244→  if (match) {\n   245→    return parseInt(match[1], 10);\n   246→  }\n   247→  return null;\n   248→}\n   249→"}]},"parent_tool_use_id":"toolu_01JZ7cmNZZkp82ndK5epjGGA","session_id":"eb26302c-c52a-41c7-9204-5eb8c12a854c","uuid":"20d9eb6c-9f41-4f73-87e4-1fd3c22098f8","timestamp":"2026-03-21T11:17:05.948Z"}
