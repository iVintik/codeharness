{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01THxaASSy7XC14XazmE37pD","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { validateWorkflowSchema, validateAgainstSchema } from '../schema-validate.js';\n3\t\n4\t// --- Helpers ---\n5\t\n6\tfunction minimalValidWorkflow() {\n7\t  return {\n8\t    tasks: {\n9\t      implement: {\n10\t        agent: 'dev',\n11\t      },\n12\t    },\n13\t    flow: ['implement'],\n14\t  };\n15\t}\n16\t\n17\tfunction fullValidWorkflow() {\n18\t  return {\n19\t    tasks: {\n20\t      implement: {\n21\t        agent: 'dev',\n22\t        scope: 'per-story',\n23\t        session: 'fresh',\n24\t        source_access: true,\n25\t        prompt_template: 'Implement story {{story_key}}',\n26\t        input_contract: { type: 'object' },\n27\t        output_contract: { type: 'object' },\n28\t        max_budget_usd: 5.0,\n29\t      },\n30\t      verify: {\n31\t        agent: 'evaluator',\n32\t        scope: 'per-run',\n33\t        session: 'continue',\n34\t        source_access: false,\n35\t      },\n36\t      retry: {\n37\t        agent: 'dev',\n38\t        scope: 'per-story',\n39\t        session: 'fresh',\n40\t        source_access: true,\n41\t        prompt_template: 'Fix failures: {{findings}}',\n42\t      },\n43\t    },\n44\t    flow: ['implement', 'verify', { loop: ['retry', 'verify'] }],\n45\t  };\n46\t}\n47\t\n48\t// --- Tests ---\n49\t\n50\tdescribe('validateWorkflowSchema', () => {\n51\t  describe('valid workflows', () => {\n52\t    it('accepts a minimal valid workflow (AC #1)', () => {\n53\t      const result = validateWorkflowSchema(minimalValidWorkflow());\n54\t      expect(result.valid).toBe(true);\n55\t      expect(result.errors).toEqual([]);\n56\t    });\n57\t\n58\t    it('accepts a full workflow with all optional fields (AC #9)', () => {\n59\t      const result = validateWorkflowSchema(fullValidWorkflow());\n60\t      expect(result.valid).toBe(true);\n61\t      expect(result.errors).toEqual([]);\n62\t    });\n63\t\n64\t    it('accepts empty tasks object', () => {\n65\t      const result = validateWorkflowSchema({ tasks: {}, flow: [] });\n66\t      expect(result.valid).toBe(true);\n67\t    });\n68\t\n69\t    it('accepts empty flow array', () => {\n70\t      const result = validateWorkflowSchema({ tasks: {}, flow: [] });\n71\t      expect(result.valid).toBe(true);\n72\t    });\n73\t\n74\t    it('accepts a loop block in flow (AC #6)', () => {\n75\t      const workflow = {\n76\t        tasks: {\n77\t          retry: { agent: 'dev' },\n78\t          verify: { agent: 'evaluator' },\n79\t        },\n80\t        flow: [{ loop: ['retry', 'verify'] }],\n81\t      };\n82\t      const result = validateWorkflowSchema(workflow);\n83\t      expect(result.valid).toBe(true);\n84\t    });\n85\t\n86\t    it('accepts optional fields when present and passes when absent (AC #9)', () => {\n87\t      // With all optional fields\n88\t      const withOptional = validateWorkflowSchema(fullValidWorkflow());\n89\t      expect(withOptional.valid).toBe(true);\n90\t\n91\t      // Without optional fields (only required agent)\n92\t      const withoutOptional = validateWorkflowSchema(minimalValidWorkflow());\n93\t      expect(withoutOptional.valid).toBe(true);\n94\t    });\n95\t  });\n96\t\n97\t  describe('missing required fields', () => {\n98\t    it('rejects missing tasks field (AC #2)', () => {\n99\t      const result = validateWorkflowSchema({ flow: ['implement'] });\n100\t      expect(result.valid).toBe(false);\n101\t      expect(result.errors.some((e) => e.message.includes('tasks'))).toBe(true);\n102\t      expect(result.errors.some((e) => e.keyword === 'required')).toBe(true);\n103\t    });\n104\t\n105\t    it('rejects missing flow field (AC #3)', () => {\n106\t      const result = validateWorkflowSchema({ tasks: {} });\n107\t      expect(result.valid).toBe(false);\n108\t      expect(result.errors.some((e) => e.message.includes('flow'))).toBe(true);\n109\t      expect(result.errors.some((e) => e.keyword === 'required')).toBe(true);\n110\t    });\n111\t\n112\t    it('rejects missing agent in task (AC #7)', () => {\n113\t      const workflow = {\n114\t        tasks: {\n115\t          implement: { scope: 'per-story' },\n116\t        },\n117\t        flow: ['implement'],\n118\t      };\n119\t      const result = validateWorkflowSchema(workflow);\n120\t      expect(result.valid).toBe(false);\n121\t      expect(result.errors.some((e) => e.keyword === 'required')).toBe(true);\n122\t    });\n123\t  });\n124\t\n125\t  describe('invalid enum values', () => {\n126\t    it('rejects invalid scope value (AC #4)', () => {\n127\t      const workflow = {\n128\t        tasks: {\n129\t          implement: { agent: 'dev', scope: 'invalid-scope' },\n130\t        },\n131\t        flow: ['implement'],\n132\t      };\n133\t      const result = validateWorkflowSchema(workflow);\n134\t      expect(result.valid).toBe(false);\n135\t      expect(result.errors.some((e) => e.keyword === 'enum')).toBe(true);\n136\t      expect(result.errors.some((e) => e.path.includes('scope'))).toBe(true);\n137\t    });\n138\t\n139\t    it('rejects invalid session value (AC #5)', () => {\n140\t      const workflow = {\n141\t        tasks: {\n142\t          implement: { agent: 'dev', session: 'invalid-session' },\n143\t        },\n144\t        flow: ['implement'],\n145\t      };\n146\t      const result = validateWorkflowSchema(workflow);\n147\t      expect(result.valid).toBe(false);\n148\t      expect(result.errors.some((e) => e.keyword === 'enum')).toBe(true);\n149\t      expect(result.errors.some((e) => e.path.includes('session'))).toBe(true);\n150\t    });\n151\t  });\n152\t\n153\t  describe('invalid types', () => {\n154\t    it('rejects source_access as non-boolean', () => {\n155\t      const workflow = {\n156\t        tasks: {\n157\t          implement: { agent: 'dev', source_access: 'yes' },\n158\t        },\n159\t        flow: ['implement'],\n160\t      };\n161\t      const result = validateWorkflowSchema(workflow);\n162\t      expect(result.valid).toBe(false);\n163\t      expect(result.errors.some((e) => e.keyword === 'type')).toBe(true);\n164\t    });\n165\t\n166\t    it('rejects max_budget_usd as non-number', () => {\n167\t      const workflow = {\n168\t        tasks: {\n169\t          implement: { agent: 'dev', max_budget_usd: 'five' },\n170\t        },\n171\t        flow: ['implement'],\n172\t      };\n173\t      const result = validateWorkflowSchema(workflow);\n174\t      expect(result.valid).toBe(false);\n175\t      expect(result.errors.some((e) => e.keyword === 'type')).toBe(true);\n176\t    });\n177\t  });\n178\t\n179\t  describe('flow validation', () => {\n180\t    it('rejects invalid flow item types', () => {\n181\t      const workflow = {\n182\t        tasks: { implement: { agent: 'dev' } },\n183\t        flow: [123],\n184\t      };\n185\t      const result = validateWorkflowSchema(workflow);\n186\t      expect(result.valid).toBe(false);\n187\t    });\n188\t\n189\t    it('rejects loop with empty array', () => {\n190\t      const workflow = {\n191\t        tasks: { retry: { agent: 'dev' } },\n192\t        flow: [{ loop: [] }],\n193\t      };\n194\t      const result = validateWorkflowSchema(workflow);\n195\t      expect(result.valid).toBe(false);\n196\t    });\n197\t\n198\t    it('rejects loop with non-string items', () => {\n199\t      const workflow = {\n200\t        tasks: { retry: { agent: 'dev' } },\n201\t        flow: [{ loop: [123] }],\n202\t      };\n203\t      const result = validateWorkflowSchema(workflow);\n204\t      expect(result.valid).toBe(false);\n205\t    });\n206\t\n207\t    it('rejects flow object with unknown properties', () => {\n208\t      const workflow = {\n209\t        tasks: { implement: { agent: 'dev' } },\n210\t        flow: [{ loop: ['implement'], extra: true }],\n211\t      };\n212\t      const result = validateWorkflowSchema(workflow);\n213\t      expect(result.valid).toBe(false);\n214\t    });\n215\t  });\n216\t\n217\t  describe('additional properties', () => {\n218\t    it('rejects unknown top-level properties', () => {\n219\t      const workflow = {\n220\t        tasks: {},\n221\t        flow: [],\n222\t        extra: 'nope',\n223\t      };\n224\t      const result = validateWorkflowSchema(workflow);\n225\t      expect(result.valid).toBe(false);\n226\t      expect(result.errors.some((e) => e.keyword === 'additionalProperties')).toBe(true);\n227\t    });\n228\t\n229\t    it('rejects unknown task properties', () => {\n230\t      const workflow = {\n231\t        tasks: {\n232\t          implement: { agent: 'dev', unknown_field: true },\n233\t        },\n234\t        flow: ['implement'],\n235\t      };\n236\t      const result = validateWorkflowSchema(workflow);\n237\t      expect(result.valid).toBe(false);\n238\t    });\n239\t  });\n240\t\n241\t  describe('error structure', () => {\n242\t    it('returns errors with path, message, and keyword', () => {\n243\t      const result = validateWorkflowSchema({});\n244\t      expect(result.valid).toBe(false);\n245\t      expect(result.errors.length).toBeGreaterThan(0);\n246\t      for (const err of result.errors) {\n247\t        expect(err).toHaveProperty('path');\n248\t        expect(err).toHaveProperty('message');\n249\t        expect(err).toHaveProperty('keyword');\n250\t        expect(typeof err.path).toBe('string');\n251\t        expect(typeof err.message).toBe('string');\n252\t        expect(typeof err.keyword).toBe('string');\n253\t      }\n254\t    });\n255\t  });\n256\t\n257\t  describe('edge cases', () => {\n258\t    it('rejects null input', () => {\n259\t      const result = validateWorkflowSchema(null);\n260\t      expect(result.valid).toBe(false);\n261\t    });\n262\t\n263\t    it('rejects non-object input', () => {\n264\t      const result = validateWorkflowSchema('not an object');\n265\t      expect(result.valid).toBe(false);\n266\t    });\n267\t\n268\t    it('rejects array input', () => {\n269\t      const result = validateWorkflowSchema([]);\n270\t      expect(result.valid).toBe(false);\n271\t    });\n272\t  });\n273\t});\n274\t\n275\tdescribe('validateAgainstSchema', () => {\n276\t  it('works with the workflow schema via the generic API (valid input)', () => {\n277\t    // Use a fake validator that returns true to test the generic path\n278\t    const fakeValidate = Object.assign(\n279\t      (_data: unknown) => true,\n280\t      { errors: null, schema: {} },\n281\t    ) as unknown as Parameters<typeof validateAgainstSchema>[1];\n282\t    const result = validateAgainstSchema(minimalValidWorkflow(), fakeValidate);\n283\t    expect(result.valid).toBe(true);\n284\t    expect(result.errors).toEqual([]);\n285\t  });\n286\t\n287\t  it('works with the workflow schema via the generic API (invalid input)', () => {\n288\t    // Use a fake validator that returns false with errors\n289\t    const fakeValidate = Object.assign(\n290\t      (_data: unknown) => false,\n291\t      {\n292\t        errors: [\n293\t          { instancePath: '/tasks', keyword: 'required', message: \"must have required property 'agent'\" },\n294\t        ],\n295\t        schema: {},\n296\t      },\n297\t    ) as unknown as Parameters<typeof validateAgainstSchema>[1];\n298\t    const result = validateAgainstSchema({}, fakeValidate);\n299\t    expect(result.valid).toBe(false);\n300\t    expect(result.errors).toHaveLength(1);\n301\t    expect(result.errors[0].path).toBe('/tasks');\n302\t    expect(result.errors[0].keyword).toBe('required');\n303\t  });\n304\t\n305\t  it('returns empty errors when validate.errors is null/undefined', () => {\n306\t    // Simulate a validator that returns true with no errors array\n307\t    const fakeValidate = Object.assign(\n308\t      (_data: unknown) => true,\n309\t      { errors: null, schema: {} },\n310\t    ) as unknown as Parameters<typeof validateAgainstSchema>[1];\n311\t    const result = validateAgainstSchema({}, fakeValidate);\n312\t    expect(result.valid).toBe(true);\n313\t    expect(result.errors).toEqual([]);\n314\t  });\n315\t\n316\t  it('handles errors with undefined message', () => {\n317\t    // Simulate a validator that returns false with an error missing .message\n318\t    const fakeValidate = Object.assign(\n319\t      (_data: unknown) => false,\n320\t      {\n321\t        errors: [\n322\t          { instancePath: '/foo', keyword: 'type', message: undefined },\n323\t        ],\n324\t        schema: {},\n325\t      },\n326\t    ) as unknown as Parameters<typeof validateAgainstSchema>[1];\n327\t    const result = validateAgainstSchema({}, fakeValidate);\n328\t    expect(result.valid).toBe(false);\n329\t    expect(result.errors).toHaveLength(1);\n330\t    expect(result.errors[0].message).toBe('Unknown validation error');\n331\t    expect(result.errors[0].path).toBe('/foo');\n332\t    expect(result.errors[0].keyword).toBe('type');\n333\t  });\n334\t\n335\t  it('handles errors with undefined errors array', () => {\n336\t    // Simulate a validator that fails but errors is undefined\n337\t    const fakeValidate = Object.assign(\n338\t      (_data: unknown) => false,\n339\t      { errors: undefined, schema: {} },\n340\t    ) as unknown as Parameters<typeof validateAgainstSchema>[1];\n341\t    const result = validateAgainstSchema({}, fakeValidate);\n342\t    expect(result.valid).toBe(false);\n343\t    expect(result.errors).toEqual([]);\n344\t  });\n345\t});\n346\t"}]},"parent_tool_use_id":"toolu_01X2y1FD6KbLFgE8hfkF9ERZ","session_id":"c54cfa66-957c-4f2c-a205-da1113d93a9b","uuid":"46a71d17-ab1e-4d93-bac9-ca7ebb7fe855","timestamp":"2026-04-02T11:16:45.078Z"}
