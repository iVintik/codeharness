{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LhoKfDLNRsPAaqu5MwfrH9","type":"tool_result","content":"1\timport { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n2\timport { join } from 'node:path';\n3\timport { parse, stringify } from 'yaml';\n4\timport { warn } from './output.js';\n5\t\n6\t// --- Interfaces ---\n7\t\n8\texport interface TaskCheckpoint {\n9\t  task_name: string;\n10\t  story_key: string;\n11\t  completed_at: string;\n12\t  session_id?: string;\n13\t  /** When present, indicates this checkpoint records a failed dispatch (not a success). */\n14\t  error?: boolean;\n15\t}\n16\t\n17\texport interface EvaluatorScore {\n18\t  iteration: number;\n19\t  passed: number;\n20\t  failed: number;\n21\t  unknown: number;\n22\t  total: number;\n23\t  timestamp: string;\n24\t}\n25\t\n26\texport interface CircuitBreakerState {\n27\t  triggered: boolean;\n28\t  reason: string | null;\n29\t  score_history: number[];\n30\t}\n31\t\n32\texport interface WorkflowState {\n33\t  workflow_name: string;\n34\t  started: string;\n35\t  iteration: number;\n36\t  phase: string;\n37\t  tasks_completed: TaskCheckpoint[];\n38\t  evaluator_scores: EvaluatorScore[];\n39\t  circuit_breaker: CircuitBreakerState;\n40\t  trace_ids?: string[];\n41\t}\n42\t\n43\t// --- Constants ---\n44\t\n45\tconst STATE_DIR = '.codeharness';\n46\tconst STATE_FILE = 'workflow-state.yaml';\n47\t\n48\t// --- Functions ---\n49\t\n50\texport function getDefaultWorkflowState(): WorkflowState {\n51\t  return {\n52\t    workflow_name: '',\n53\t    started: '',\n54\t    iteration: 0,\n55\t    phase: 'idle',\n56\t    tasks_completed: [],\n57\t    evaluator_scores: [],\n58\t    circuit_breaker: {\n59\t      triggered: false,\n60\t      reason: null,\n61\t      score_history: [],\n62\t    },\n63\t    trace_ids: [],\n64\t  };\n65\t}\n66\t\n67\texport function writeWorkflowState(state: WorkflowState, dir?: string): void {\n68\t  const baseDir = dir ?? process.cwd();\n69\t  const stateDir = join(baseDir, STATE_DIR);\n70\t  mkdirSync(stateDir, { recursive: true });\n71\t  const yamlContent = stringify(state, { nullStr: 'null' });\n72\t  writeFileSync(join(stateDir, STATE_FILE), yamlContent, 'utf-8');\n73\t}\n74\t\n75\texport function readWorkflowState(dir?: string): WorkflowState {\n76\t  const baseDir = dir ?? process.cwd();\n77\t  const filePath = join(baseDir, STATE_DIR, STATE_FILE);\n78\t\n79\t  if (!existsSync(filePath)) {\n80\t    return getDefaultWorkflowState();"}]},"parent_tool_use_id":"toolu_01TdcdH5REoSz2RuqciPx8Mr","session_id":"2800a04b-8151-4215-bf66-1f43973b9365","uuid":"14f889cc-da1c-48da-9733-b8c002ab1373","timestamp":"2026-04-03T01:51:49.283Z"}
