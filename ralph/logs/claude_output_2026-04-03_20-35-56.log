{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Tm3raWaVi1ZgmzsiVvoA9R","type":"tool_result","content":"168\t\n169\tdescribe('checkDriverHealth', () => {\n170\t  beforeEach(() => {\n171\t    vi.clearAllMocks();\n172\t  });\n173\t\n174\t  it('succeeds when a single driver passes health check', async () => {\n175\t    const workflow: ResolvedWorkflow = {\n176\t      tasks: { implement: makeTask({ driver: 'claude-code' }) },\n177\t      flow: ['implement'],\n178\t    };\n179\t\n180\t    const driver = makeMockDriver('claude-code', makeHealthy());\n181\t    mockGetDriver.mockReturnValue(driver);\n182\t\n183\t    await expect(checkDriverHealth(workflow)).resolves.toBeUndefined();\n184\t    expect(driver.healthCheck).toHaveBeenCalledOnce();\n185\t  });\n186\t\n187\t  it('succeeds when multiple unique drivers all pass', async () => {\n188\t    const workflow: ResolvedWorkflow = {\n189\t      tasks: {\n190\t        implement: makeTask({ driver: 'claude-code' }),\n191\t        codexTask: makeTask({ driver: 'codex' }),\n192\t      },\n193\t      flow: ['implement', 'codexTask'],\n194\t    };\n195\t\n196\t    const claudeDriver = makeMockDriver('claude-code', makeHealthy());\n197\t    const codexDriver = makeMockDriver('codex', makeHealthy());\n198\t    mockGetDriver.mockImplementation((name: string) => {\n199\t      if (name === 'claude-code') return claudeDriver;\n200\t      if (name === 'codex') return codexDriver;\n201\t      throw new Error(`Unknown driver: ${name}`);\n202\t    });\n203\t\n204\t    await expect(checkDriverHealth(workflow)).resolves.toBeUndefined();\n205\t    expect(claudeDriver.healthCheck).toHaveBeenCalledOnce();\n206\t    expect(codexDriver.healthCheck).toHaveBeenCalledOnce();\n207\t  });\n208\t\n209\t  it('deduplicates drivers — healthCheck called once per unique driver', async () => {\n210\t    const workflow: ResolvedWorkflow = {\n211\t      tasks: {\n212\t        task1: makeTask({ driver: 'claude-code' }),\n213\t        task2: makeTask({ driver: 'claude-code' }),\n214\t        task3: makeTask({ driver: 'claude-code' }),\n215\t      },\n216\t      flow: ['task1', 'task2', 'task3'],\n217\t    };\n218\t\n219\t    const driver = makeMockDriver('claude-code', makeHealthy());\n220\t    mockGetDriver.mockReturnValue(driver);\n221\t\n222\t    await expect(checkDriverHealth(workflow)).resolves.toBeUndefined();\n223\t    expect(mockGetDriver).toHaveBeenCalledTimes(1);\n224\t    expect(driver.healthCheck).toHaveBeenCalledOnce();\n225\t  });\n226\t\n227\t  it('throws when one driver fails, listing the failing driver and error', async () => {\n228\t    const workflow: ResolvedWorkflow = {\n229\t      tasks: {\n230\t        implement: makeTask({ driver: 'claude-code' }),\n231\t        codexTask: makeTask({ driver: 'codex' }),\n232\t      },\n233\t      flow: ['implement', 'codexTask'],\n234\t    };\n235\t\n236\t    const claudeDriver = makeMockDriver('claude-code', makeHealthy());\n237\t    const codexDriver = makeMockDriver('codex', makeUnhealthy('codex CLI not found'));\n238\t    mockGetDriver.mockImplementation((name: string) => {\n239\t      if (name === 'claude-code') return claudeDriver;\n240\t      if (name === 'codex') return codexDriver;\n241\t      throw new Error(`Unknown driver: ${name}`);\n242\t    });\n243\t\n244\t    const err = await checkDriverHealth(workflow).catch((e: Error) => e);\n245\t    expect(err).toBeInstanceOf(Error);\n246\t    expect((err as Error).message).toContain('Driver health check failed');\n247\t    expect((err as Error).message).toContain('codex: codex CLI not found');\n248\t  });\n249\t\n250\t  it('throws listing ALL failing drivers when multiple fail', async () => {\n251\t    const workflow: ResolvedWorkflow = {\n252\t      tasks: {\n253\t        task1: makeTask({ driver: 'claude-code' }),\n254\t        task2: makeTask({ driver: 'codex' }),\n255\t        task3: makeTask({ driver: 'opencode' }),\n256\t      },\n257\t      flow: ['task1', 'task2', 'task3'],\n258\t    };\n259\t\n260\t    const claudeDriver = makeMockDriver('claude-code', makeUnhealthy('claude not found'));\n261\t    const codexDriver = makeMockDriver('codex', makeUnhealthy('codex not found'));\n262\t    const opencodeDriver = makeMockDriver('opencode', makeHealthy());\n263\t    mockGetDriver.mockImplementation((name: string) => {\n264\t      if (name === 'claude-code') return claudeDriver;\n265\t      if (name === 'codex') return codexDriver;\n266\t      if (name === 'opencode') return opencodeDriver;\n267\t      throw new Error(`Unknown driver: ${name}`);\n268\t    });\n269\t\n270\t    try {\n271\t      await checkDriverHealth(workflow);\n272\t      expect.fail('Should have thrown');\n273\t    } catch (err: unknown) {\n274\t      const message = (err as Error).message;\n275\t      expect(message).toContain('claude-code: claude not found');\n276\t      expect(message).toContain('codex: codex not found');\n277\t    }\n278\t  });\n279\t\n280\t  it('defaults to claude-code when task has no driver field', async () => {\n281\t    const workflow: ResolvedWorkflow = {\n282\t      tasks: {\n283\t        task1: makeTask(), // no driver field — defaults to claude-code\n284\t        task2: makeTask(), // also no driver field\n285\t      },\n286\t      flow: ['task1', 'task2'],\n287\t    };\n288\t\n289\t    const driver = makeMockDriver('claude-code', makeHealthy());\n290\t    mockGetDriver.mockReturnValue(driver);\n291\t\n292\t    await expect(checkDriverHealth(workflow)).resolves.toBeUndefined();\n293\t    expect(mockGetDriver).toHaveBeenCalledTimes(1);\n294\t    expect(mockGetDriver).toHaveBeenCalledWith('claude-code');\n295\t    expect(driver.healthCheck).toHaveBeenCalledOnce();\n296\t  });\n297\t\n298\t  it('throws on timeout when health check hangs', async () => {\n299\t    const workflow: ResolvedWorkflow = {\n300\t      tasks: { implement: makeTask({ driver: 'claude-code' }) },\n301\t      flow: ['implement'],\n302\t    };\n303\t\n304\t    const hangingDriver 