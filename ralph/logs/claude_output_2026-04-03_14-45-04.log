{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013i99rStcEuot13xGw9p2Kd","type":"tool_result","content":"598\t      if (t.scope === 'per-story') {\n599\t        return workItems.every((item) =>\n600\t          isLoopTaskCompleted(currentState, tn, item.key, currentState.iteration));\n601\t      }\n602\t      return isLoopTaskCompleted(currentState, tn, PER_RUN_SENTINEL, currentState.iteration);\n603\t    });\n604\t\n605\t    if (currentState.iteration === 0 || allCurrentIterationDone) {\n606\t      // Fresh start or current iteration fully done — advance\n607\t      currentState = {\n608\t        ...currentState,\n609\t        iteration: nextIteration,\n610\t      };\n611\t      writeWorkflowState(currentState, projectDir);\n612\t    }\n613\t    // else: resuming a partially completed iteration — keep current iteration\n614\t\n615\t    let haltedInLoop = false;\n616\t\n617\t    // 2. Execute each task in the loop\n618\t    for (const taskName of loopBlock.loop) {\n619\t      const task = config.workflow.tasks[taskName];\n620\t      if (!task) {\n621\t        warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n622\t        continue;\n623\t      }\n624\t\n625\t      const definition = config.agents[task.agent];\n626\t      if (!definition) {\n627\t        warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n628\t        continue;\n629\t      }\n630\t\n631\t      if (task.scope === 'per-story') {\n632\t        // Determine which items to dispatch for\n633\t        const itemsToRetry = lastVerdict ? getFailedItems(lastVerdict, workItems) : workItems;\n634\t\n635\t        for (const item of itemsToRetry) {\n636\t          // Skip if already completed for this iteration (crash recovery — AC #4)\n637\t          if (isLoopTaskCompleted(currentState, taskName, item.key, currentState.iteration)) {\n638\t            warn(`workflow-engine: skipping completed task ${taskName} for ${item.key}`);\n639\t            continue;\n640\t          }\n641\t\n642\t          // Build prompt: inject findings if we have a previous verdict\n643\t          const prompt = lastVerdict\n644\t            ? buildRetryPrompt(item.key, lastVerdict.findings)\n645\t            : undefined;\n646\t\n647\t          try {\n648\t            const dispatchResult = await dispatchTaskWithResult(\n649\t              task, taskName, item.key, definition, currentState, config, prompt, lastOutputContract ?? undefined,\n650\t            );\n651\t            currentState = dispatchResult.updatedState;\n652\t            lastOutputContract = dispatchResult.contract;\n653\t            tasksCompleted++;\n654\t          } catch (err: unknown) {\n655\t            const engineError = handleDispatchError(err, taskName, item.key);\n656\t            errors.push(engineError);\n657\t            currentState = recordErrorInState(currentState, taskName, item.key, engineError);\n658\t            writeWorkflowState(currentState, projectDir);\n659\t\n660\t            if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n661\t              haltedInLoop = true;\n662\t              break;\n663\t            }\n664\t            continue;\n665\t          }\n666\t        }\n667\t\n668\t        if (haltedInLoop) break;\n669\t      } else {\n670\t        // per-run task (e.g., verify)\n671\t        // Skip if already completed for this iteration (crash recovery — AC #4)\n672\t        if (isLoopTaskCompleted(currentState, taskName, PER_RUN_SENTINEL, currentState.iteration)) {\n673\t          warn(`workflow-engine: skipping completed task ${taskName} for ${PER_RUN_SENTINEL}`);\n674\t          continue;\n675\t        }\n676\t\n677\t        try {\n678\t          // We need the dispatch result output to parse verdict\n679\t          const dispatchResult = await dispatchTaskWithResult(\n680\t            task, taskName, PER_RUN_SENTINEL, definition, currentState, config,\n681\t            undefined, lastOutputContract ?? undefined,\n682\t          );\n683\t          currentState = dispatchResult.updatedState;\n684\t          lastOutputContract = dispatchResult.contract;\n685\t          tasksCompleted++;\n686\t\n687\t          // Attempt to parse verdict from output with retry semantics (story 6-2)\n688\t          let verdict: EvaluatorVerdict | null = null;\n689\t          try {\n690\t            verdict = parseVerdict(dispatchResult.output);\n691\t          } catch (parseErr: unknown) {\n692\t            if (parseErr instanceof VerdictParseError && parseErr.retryable) {\n693\t              // Re-dispatch evaluator for one retry attempt\n694\t              warn(`workflow-engine: verdict parse failed, retrying evaluator for ${taskName}`);\n695\t              try {\n696\t                const retryResult = await dispatchTaskWithResult(\n697\t                  task, taskName, PER_RUN_SENTINEL, definition, currentState, config,\n698\t                  undefined, lastOutputContract ?? undefined,\n699\t                );\n700\t                currentState = retryResult.updatedState;\n701\t                lastOutputContract = retryResult.contract;\n702\t                tasksCompleted++;\n703\t                verdict = parseVerdict(retryResult.output);\n704\t              } catch { // IGNORE: retry failed — fall back to all-UNKNOWN verdict\n705\t                // Second failure: generate all-UNKNOWN verdict\n706\t                verdict = buildAllUnknownVerdict(\n707\t                  workItems,\n708\t                  'Evaluator failed to produce valid JSON after retry',\n709\t                );\n710\t              }\n711\t            }\n712\t            // If not a VerdictParseError or not retryable, verdict stays null\n713\t          }\n714\t          lastVerdict = verdict;\n715\t\n716\t          // Record score in state\n717\t          if (verdict) {\n718\t            const score = {\n719\t              iteration: currentState.iteration,\n720\t              passed: verdict.score.passed,\n721\t              failed: verdict.score.failed,\n722\t              unknown: verdict.score.unknown,\n723\t              total: verdict.score.total,\n724\t              timestamp: new Date().toISOString(),\n725\t            };\n726\t            currentState = {\n727\t              ...currentState,\n728\t              evaluator_scores: [...currentState.evaluator_scores, score],\n729\t            };\n730\t          } else {\n731\t            // Parse failure: record all-UNKNOWN score\n732\t            const totalItems = workItems.length;\n733\t            const score = {\n734\t              iteration: currentState.iteration,\n735\t              passed: 0,\n736\t              failed: 0,\n737\t              unknown: totalItems,\n738\t              total: totalItems,\n739\t              timestamp: new Date().toISOString(),\n740\t            };\n741\t            currentState = {\n742\t              ...currentState,\n743\t              evaluator_scores: [...currentState.evaluator_scores, score],\n744\t            };\n745\t          }\n746\t          writeWorkflowState(currentState, projectDir);\n747\t\n748\t          // Circuit breaker: evaluate progress after recording score\n749\t          const cbDecision = evaluateProgress(currentState.evaluator_scores);\n750\t          if (cbDecision.halt) {\n751\t            currentState = {\n752\t              ...currentState,\n753\t              circuit_breaker: {\n754\t                triggered: true,\n755\t                reason: cbDecision.reason,\n756\t                score_history: cbDecision.scoreHistory,\n757\t              },\n758\t            };\n759\t            writeWorkflowState(currentState, projectDir);\n760\t          }\n761\t        } catch (err: unknown) {\n762\t          const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n763\t          errors.push(engineError);\n764\t          currentState = recordErrorInState(currentState, taskName, PER_RUN_SENTINEL, engineError);\n765\t          writeWorkflowState(currentState, projectDir);\n766\t\n767\t          // Clear stale verdict so next iteration retries all items\n768\t          lastVerdict = null;\n769\t\n770\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n771\t            haltedInLoop = true;\n772\t            break;\n773\t          }\n774\t          continue;\n775\t        }\n776\t      }\n777\t    }\n778\t\n779\t    if (haltedInLoop) {\n780\t      return { state: currentState, errors, tasksCompleted, halted: true, lastContract: lastOutputContract };\n781\t    }\n782\t\n783\t    // 3. Check termination conditions\n784\t    if (lastVerdict?.verdict === 'pass') {\n785\t      // Success: loop passes\n786\t      return { state: currentState, errors, tasksCompleted, halted: false, lastContract: lastOutputContract };\n787\t    }\n788\t\n789\t    if (currentState.iteration >= maxIterations) {\n790\t      currentState = { ...currentState, phase: 'max-iterations' };\n791\t      writeWorkflowState(currentState, projectDir);\n792\t      return { state: currentState, errors, tasksCompleted, halted: false, lastContract: lastOutputContract };\n793\t    }\n794\t\n795\t    if (currentState.circuit_breaker.triggered) {\n796\t      currentState = { ...currentState, phase: 'circuit-breaker' };\n797\t      writeWorkflowState(currentState, projectDir);\n798\t      return { state: currentState, errors, tasksCompleted, halted: false, lastContract: lastOutputContract };\n799\t    }\n800\t  }\n801\t}\n802\t\n803\t\n804\t// --- Driver Health Check ---\n805\t\n806\t/** Default timeout for the health check phase (NFR6). */\n807\tconst HEALTH_CHECK_TIMEOUT_MS = 5000;\n808\t\n809\t/**\n810\t * Run health checks on all unique drivers referenced in a workflow.\n811\t *\n812\t * Collects unique driver names from `workflow.tasks`, resolves each via\n813\t * `getDriver()`, and runs all `healthCheck()` calls concurrently with a\n814\t * 5-second timeout (NFR6).\n815\t *\n816\t * Throws if any driver is unavailable or if the timeout fires.\n817\t */\n818\texport async function checkDriverHealth(workflow: ResolvedWorkflow, timeoutMs?: number): Promise<void> {\n819\t  // 1. Collect unique driver names from all tasks\n820\t  const driverNames = new Set<string>();\n821\t  for (const task of Object.values(workflow.tasks)) {\n822\t    driverNames.add(task.driver ?? 'claude-code');\n823\t  }\n824\t\n825\t  // 2. Resolve drivers\n826\t  const drivers = new Map<string, ReturnType<typeof getDriver>>();\n827\t  for (const name of driverNames) {\n828\t    drivers.set(name, getDriver(name));\n829\t  }\n830\t\n831\t  // 3. Run health checks concurrently, tracking which drivers responded\n832\t  interface HealthResult { name: string; health: DriverHealth }\n833\t  const responded = new Set<string>();\n834\t  const healthChecks = Promise.all(\n835\t    [...drivers.entries()].map(async ([name, driver]): Promise<HealthResult> => {\n836\t      const health = await driver.healthCheck();\n837\t      responded.add(name);\n838\t      return { name, health };\n839\t    }),\n840\t  );\n841\t\n842\t  // 4. Race against timeout (NFR6) — clear timer on success to prevent leaks\n843\t  const effectiveTimeout = timeoutMs ?? HEALTH_CHECK_TIMEOUT_MS;\n844\t  let timer: ReturnType<typeof setTimeout>;\n845\t  const timeoutPromise = new Promise<'timeout'>((resolve) => {\n846\t    timer = setTimeout(() => resolve('timeout'), effectiveTimeout);\n847\t  });"}]},"parent_tool_use_id":"toolu_01SkXPMmo5ukZsEWidXQjyr7","session_id":"d2473842-56c4-49f2-ab43-68fabe9113bb","uuid":"602c7055-6f2e-414f-ae4a-5c6ee9cbabf1","timestamp":"2026-04-03T10:58:16.284Z"}
