{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KkEyHgBHr3mHD1F1xXXfg5","type":"tool_result","content":"     1→/**\n     2→ * Coverage state persistence — tracks observability coverage in sprint-state.json.\n     3→ *\n     4→ * Implements Story 1.3: read/write/trend/target comparison for static analysis coverage.\n     5→ * Only the `static` section is managed here; `runtime` is deferred to Epic 2.\n     6→ */\n     7→\n     8→import { readFileSync, writeFileSync, renameSync, existsSync } from 'node:fs';\n     9→import { join } from 'node:path';\n    10→import { ok, fail } from '../../types/result.js';\n    11→import type { Result } from '../../types/result.js';\n    12→import type {\n    13→  AnalyzerResult,\n    14→  ObservabilityCoverageState,\n    15→  CoverageTrend,\n    16→  CoverageTargetResult,\n    17→} from './types.js';\n    18→\n    19→const STATE_FILE = 'sprint-state.json';\n    20→const TMP_FILE = '.sprint-state.json.tmp';\n    21→const DEFAULT_STATIC_TARGET = 80;\n    22→const MAX_HISTORY_ENTRIES = 100;\n    23→\n    24→/**\n    25→ * Default observability coverage state when none exists.\n    26→ */\n    27→function defaultCoverageState(): ObservabilityCoverageState {\n    28→  return {\n    29→    static: {\n    30→      coveragePercent: 0,\n    31→      lastScanTimestamp: '',\n    32→      history: [],\n    33→    },\n    34→    targets: {\n    35→      staticTarget: DEFAULT_STATIC_TARGET,\n    36→    },\n    37→  };\n    38→}\n    39→\n    40→/**\n    41→ * Read the full sprint-state.json as a generic record.\n    42→ */\n    43→function readStateFile(projectDir: string): Result<Record<string, unknown>> {\n    44→  const fp = join(projectDir, STATE_FILE);\n    45→  if (!existsSync(fp)) {\n    46→    return ok({});\n    47→  }\n    48→  try {\n    49→    const raw = readFileSync(fp, 'utf-8');\n    50→    const parsed = JSON.parse(raw) as Record<string, unknown>;\n    51→    return ok(parsed);\n    52→  } catch (err: unknown) {\n    53→    const msg = err instanceof Error ? err.message : String(err);\n    54→    return fail(`Failed to read ${STATE_FILE}: ${msg}`);\n    55→  }\n    56→}\n    57→\n    58→/**\n    59→ * Write sprint-state.json atomically (write to temp, then rename).\n    60→ */\n    61→function writeStateAtomic(\n    62→  projectDir: string,\n    63→  state: Record<string, unknown>,\n    64→): Result<void> {\n    65→  try {\n    66→    const data = JSON.stringify(state, null, 2) + '\\n';\n    67→    const tmp = join(projectDir, TMP_FILE);\n    68→    const final = join(projectDir, STATE_FILE);\n    69→    writeFileSync(tmp, data, 'utf-8');\n    70→    renameSync(tmp, final);\n    71→    return ok(undefined);\n    72→  } catch (err: unknown) {\n    73→    const msg = err instanceof Error ? err.message : String(err);\n    74→    return fail(`Failed to write ${STATE_FILE}: ${msg}`);\n    75→  }\n    76→}\n    77→\n    78→/**\n    79→ * Save coverage result from an analysis run into sprint-state.json.\n    80→ *\n    81→ * Updates `observability.static.coveragePercent`, `observability.static.lastScanTimestamp`,\n    82→ * and appends to `observability.static.history`. Preserves all other state fields.\n    83→ */\n    84→export function saveCoverageResult(\n    85→  projectDir: string,\n    86→  result: AnalyzerResult,\n    87→): Result<void> {\n    88→  if (!projectDir || typeof projectDir !== 'string') {\n    89→    return fail('projectDir is required and must be a non-empty string');\n    90→  }\n    91→\n    92→  const stateResult = readStateFile(projectDir);\n    93→  if (!stateResult.success) {\n    94→    return fail(stateResult.error);\n    95→  }\n    96→\n    97→  const state = stateResult.data;\n    98→  const existing = extractCoverageState(state);\n    99→  const timestamp = new Date().toISOString();\n   100→\n   101→  const fullHistory = [\n   102→    ...existing.static.history,\n   103→    { coveragePercent: result.summary.coveragePercent, timestamp },\n   104→  ];\n   105→  // Keep only the most recent entries to prevent unbounded growth\n   106→  const trimmedHistory =\n   107→    fullHistory.length > MAX_HISTORY_ENTRIES\n   108→      ? fullHistory.slice(fullHistory.length - MAX_HISTORY_ENTRIES)\n   109→      : fullHistory;\n   110→\n   111→  const updatedStatic = {\n   112→    coveragePercent: result.summary.coveragePercent,\n   113→    lastScanTimestamp: timestamp,\n   114→    history: trimmedHistory,\n   115→  };\n   116→\n   117→  const updatedObservability: ObservabilityCoverageState = {\n   118→    static: updatedStatic,\n   119→    targets: existing.targets,\n   120→  };\n   121→\n   122→  const updatedState = {\n   123→    ...state,\n   124→    observability: updatedObservability,\n   125→  };\n   126→\n   127→  return writeStateAtomic(projectDir, updatedState);\n   128→}\n   129→\n   130→/**\n   131→ * Read the observability coverage state from sprint-state.json.\n   132→ *\n   133→ * Returns the typed `ObservabilityCoverageState` from the `observability` key.\n   134→ * If no observability section exists, returns default state.\n   135→ */\n   136→export function readCoverageState(\n   137→  projectDir: string,\n   138→): Result<ObservabilityCoverageState> {\n   139→  if (!projectDir || typeof projectDir !== 'string') {\n   140→    return fail('projectDir is required and must be a non-empty string');\n   141→  }\n   142→\n   143→  const stateResult = readStateFile(projectDir);\n   144→  if (!stateResult.success) {\n   145→    return fail(stateResult.error);\n   146→  }\n   147→\n   148→  return ok(extractCoverageState(stateResult.data));\n   149→}\n   150→\n   151→/**\n   152→ * Get coverage trend by comparing latest vs previous history entries.\n   153→ */\n   154→export function getCoverageTrend(projectDir: string): Result<CoverageTrend> {\n   155→  if (!projectDir || typeof projectDir !== 'string') {\n   156→    return fail('projectDir is required and must be a non-empty string');\n   157→  }\n   158→\n   159→  const stateResult = readCoverageState(projectDir);\n   160→  if (!stateResult.success) {\n   161→    return fail(stateResult.error);\n   162→  }\n   163→\n   164→  const { history } = stateResult.data.static;\n   165→\n   166→  if (history.length === 0) {\n   167→    return ok({\n   168→      current: 0,\n   169→      previous: null,\n   170→      delta: null,\n   171→      currentTimestamp: '',\n   172→      previousTimestamp: null,\n   173→    });\n   174→  }\n   175→\n   176→  const latest = history[history.length - 1];\n   177→\n   178→  if (history.length === 1) {\n   179→    return ok({\n   180→      current: latest.coveragePercent,\n   181→      previous: null,\n   182→      delta: null,\n   183→      currentTimestamp: latest.timestamp,\n   184→      previousTimestamp: null,\n   185→    });\n   186→  }\n   187→\n   188→  const prev = history[history.length - 2];\n   189→  return ok({\n   190→    current: latest.coveragePercent,\n   191→    previous: prev.coveragePercent,\n   192→    delta: latest.coveragePercent - prev.coveragePercent,\n   193→    currentTimestamp: latest.timestamp,\n   194→    previousTimestamp: prev.timestamp,\n   195→  });\n   196→}\n   197→\n   198→/**\n   199→ * Check current coverage against a target threshold.\n   200→ *\n   201→ * @param projectDir - Project root directory\n   202→ * @param target - Target percentage (default 80%)\n   203→ * @returns Structured result indicating whether coverage meets the target\n   204→ */\n   205→export function checkCoverageTarget(\n   206→  projectDir: string,\n   207→  target?: number,\n   208→): Result<CoverageTargetResult> {\n   209→  if (!projectDir || typeof projectDir !== 'string') {\n   210→    return fail('projectDir is required and must be a non-empty string');\n   211→  }\n   212→\n   213→  const stateResult = readCoverageState(projectDir);\n   214→  if (!stateResult.success) {\n   215→    return fail(stateResult.error);\n   216→  }\n   217→\n   218→  const effectiveTarget = target ?? stateResult.data.targets.staticTarget;\n   219→  const current = stateResult.data.static.coveragePercent;\n   220→  const met = current >= effectiveTarget;\n   221→  const gap = met ? 0 : effectiveTarget - current;\n   222→\n   223→  return ok({ met, current, target: effectiveTarget, gap });\n   224→}\n   225→\n   226→/**\n   227→ * Extract typed ObservabilityCoverageState from raw sprint-state.json data.\n   228→ * Returns defaults when the observability section doesn't exist.\n   229→ */\n   230→function extractCoverageState(\n   231→  state: Record<string, unknown>,\n   232→): ObservabilityCoverageState {\n   233→  const obs = state.observability as Record<string, unknown> | undefined;\n   234→  if (!obs) {\n   235→    return defaultCoverageState();\n   236→  }\n   237→\n   238→  const staticSection = obs.static as Record<string, unknown> | undefined;\n   239→  const targets = obs.targets as Record<string, unknown> | undefined;\n   240→\n   241→  return {\n   242→    static: {\n   243→      coveragePercent:\n   244→        typeof staticSection?.coveragePercent === 'number'\n   245→          ? staticSection.coveragePercent\n   246→          : 0,\n   247→      lastScanTimestamp:\n   248→        typeof staticSection?.lastScanTimestamp === 'string'\n   249→          ? staticSection.lastScanTimestamp\n   250→          : '',\n   251→      history: Array.isArray(staticSection?.history)\n   252→        ? (staticSection.history as unknown[]).filter(\n   253→            (entry): entry is { coveragePercent: number; timestamp: string } =>\n   254→              typeof entry === 'object' &&\n   255→              entry !== null &&\n   256→              typeof (entry as Record<string, unknown>).coveragePercent ===\n   257→                'number' &&\n   258→              typeof (entry as Record<string, unknown>).timestamp === 'string',\n   259→          )\n   260→        : [],\n   261→    },\n   262→    targets: {\n   263→      staticTarget:\n   264→        typeof targets?.staticTarget === 'number'\n   265→          ? targets.staticTarget\n   266→          : DEFAULT_STATIC_TARGET,\n   267→    },\n   268→  };\n   269→}\n   270→"}]},"parent_tool_use_id":"toolu_01HT5DTtnKuNpCvNvjzkcPm4","session_id":"f7a66acd-0cc1-40de-a592-d59e75273c0b","uuid":"ef81f1fb-bd75-47b1-9acc-2df2b4bc4f81","timestamp":"2026-03-20T05:50:20.064Z"}
