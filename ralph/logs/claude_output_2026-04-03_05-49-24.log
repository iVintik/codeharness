{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01R65T14HJdPrfiRHnzZeBpi","type":"tool_result","content":"1\timport { Command } from 'commander';\n2\timport { stringify } from 'yaml';\n3\timport {\n4\t  readState,\n5\t  readStateWithBody,\n6\t  writeState,\n7\t  getNestedValue,\n8\t  setNestedValue,\n9\t  parseValue,\n10\t  StateFileNotFoundError,\n11\t} from '../lib/state.js';\n12\timport { fail, info, jsonOutput } from '../lib/output.js';\n13\t\n14\texport function registerStateCommand(program: Command): void {\n15\t  const stateCmd = program\n16\t    .command('state')\n17\t    .description('Manage harness state');\n18\t\n19\t  // Hide 'state' from top-level --help (internal utility command)\n20\t  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n21\t  (stateCmd as any)._hidden = true;\n22\t\n23\t  stateCmd\n24\t    .command('show')\n25\t    .description('Display full harness state')\n26\t    .action((_, cmd) => {\n27\t      const opts = cmd.optsWithGlobals();\n28\t      try {\n29\t        const state = readState();\n30\t        if (opts.json) {\n31\t          jsonOutput(state as unknown as Record<string, unknown>);\n32\t        } else {\n33\t          info('Current state:');\n34\t          process.stdout.write(stringify(state, { nullStr: 'null' }));\n35\t        }\n36\t      } catch (err) {\n37\t        if (err instanceof StateFileNotFoundError) {\n38\t          fail(\"No state file found. Run 'codeharness init' first.\", { json: opts.json });\n39\t          process.exitCode = 1;\n40\t        } else {\n41\t          throw err;\n42\t        }\n43\t      }\n44\t    });\n45\t\n46\t  stateCmd\n47\t    .command('get <key>')\n48\t    .description('Get a state value by dot-notation key')\n49\t    .action((key: string, _, cmd) => {\n50\t      const opts = cmd.optsWithGlobals();\n51\t      try {\n52\t        const state = readState();\n53\t        const value = getNestedValue(state as unknown as Record<string, unknown>, key);\n54\t        if (value === undefined) {\n55\t          fail(`Key '${key}' not found in state.`, { json: opts.json });\n56\t          process.exitCode = 1;\n57\t        } else if (opts.json) {\n58\t          jsonOutput({ key, value: value as string });\n59\t        } else {\n60\t          process.stdout.write(`${String(value)}\\n`);\n61\t        }\n62\t      } catch (err) {\n63\t        if (err instanceof StateFileNotFoundError) {\n64\t          fail(\"No state file found. Run 'codeharness init' first.\", { json: opts.json });\n65\t          process.exitCode = 1;\n66\t        } else {\n67\t          throw err;\n68\t        }\n69\t      }\n70\t    });\n71\t\n72\t  stateCmd\n73\t    .command('reset-session')\n74\t    .description('Reset all session flags to false')\n75\t    .action((_, cmd) => {\n76\t      const opts = cmd.optsWithGlobals();\n77\t      try {\n78\t        const { state, body } = readStateWithBody();\n79\t        state.session_flags.tests_passed = false;\n80\t        state.session_flags.coverage_met = false;\n81\t        state.session_flags.verification_run = false;\n82\t        state.session_flags.logs_queried = false;\n83\t        writeState(state, undefined, body);\n84\t        if (opts.json) {\n85\t          jsonOutput({\n86\t            status: 'ok',\n87\t            reset: {\n88\t              tests_passed: false,\n89\t              coverage_met: false,\n90\t              verification_run: false,\n91\t              logs_queried: false,\n92\t            },\n93\t          });\n94\t        } else {\n95\t          info('Session flags reset to false: tests_passed, coverage_met, verification_run, logs_queried');\n96\t        }\n97\t      } catch (err) {\n98\t        if (err instanceof StateFileNotFoundError) {\n99\t          fail(\"No state file found. Run 'codeharness init' first.\", { json: opts.json });\n100\t          process.exitCode = 1;\n101\t        } else {\n102\t          throw err;\n103\t        }\n104\t      }\n105\t    });\n106\t\n107\t  stateCmd\n108\t    .command('set <key> <value>')\n109\t    .description('Set a state value by dot-notation key')\n110\t    .action((key: string, rawValue: string, _, cmd) => {\n111\t      const opts = cmd.optsWithGlobals();\n112\t      try {\n113\t        const { state, body } = readStateWithBody();\n114\t        const parsed = parseValue(rawValue);\n115\t        setNestedValue(state as unknown as Record<string, unknown>, key, parsed);\n116\t        writeState(state, undefined, body);\n117\t        if (opts.json) {\n118\t          jsonOutput({ status: 'ok', key, value: parsed as string });\n119\t        } else {\n120\t          info(`Set ${key} = ${String(parsed)}`);\n121\t        }\n122\t      } catch (err) {\n123\t        if (err instanceof StateFileNotFoundError) {\n124\t          fail(\"No state file found. Run 'codeharness init' first.\", { json: opts.json });\n125\t          process.exitCode = 1;\n126\t        } else {\n127\t          throw err;\n128\t        }\n129\t      }\n130\t    });\n131\t}\n132\t"}]},"parent_tool_use_id":"toolu_01GdhC1X7g9GGNGw533oGrRU","session_id":"2800a04b-8151-4215-bf66-1f43973b9365","uuid":"47babf98-ea93-43cb-b644-dd1f0b654cb0","timestamp":"2026-04-03T01:54:32.485Z"}
