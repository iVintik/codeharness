{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xc8vngtzZR8v5XDhrHdTfo","type":"tool_result","content":"900\t      errors: [],\n901\t      durationMs: 0,\n902\t    };\n903\t  }\n904\t\n905\t  state = {\n906\t    ...state,\n907\t    phase: 'executing',\n908\t    started: state.started || new Date().toISOString(),\n909\t    workflow_name: config.workflow.flow.filter((s) => typeof s === 'string').join(' -> '),\n910\t  };\n911\t  writeWorkflowState(state, projectDir);\n912\t\n913\t  // 1b. Pre-flight driver health check\n914\t  try {\n915\t    await checkDriverHealth(config.workflow);\n916\t  } catch (err: unknown) { // IGNORE: health check failure — record and abort\n917\t    const message = err instanceof Error ? err.message : String(err);\n918\t    state = { ...state, phase: 'failed' };\n919\t    const engineError: EngineError = {\n920\t      taskName: '__health_check__',\n921\t      storyKey: '__health_check__',\n922\t      code: 'HEALTH_CHECK',\n923\t      message,\n924\t    };\n925\t    errors.push(engineError);\n926\t    writeWorkflowState(state, projectDir);\n927\t    return {\n928\t      success: false,\n929\t      tasksCompleted: 0,\n930\t      storiesProcessed: 0,\n931\t      errors,\n932\t      durationMs: Date.now() - startMs,\n933\t    };\n934\t  }\n935\t\n936\t  // 1c. Pre-flight capability conflict check (advisory only — never aborts)\n937\t  const capWarnings = checkCapabilityConflicts(config.workflow);\n938\t  for (const cw of capWarnings) {\n939\t    warn(cw.message);\n940\t  }\n941\t\n942\t  // 2. Load work items\n943\t  const workItems = loadWorkItems(config.sprintStatusPath, config.issuesPath);\n944\t\n945\t  // 3. Iterate through flow steps\n946\t  let halted = false;\n947\t  let lastOutputContract: OutputContract | null = null;\n948\t  for (const step of config.workflow.flow) {\n949\t    if (halted) break;\n950\t\n951\t    // Execute loop blocks\n952\t    if (isLoopBlock(step)) {\n953\t      const loopResult = await executeLoopBlock(step, state, config, workItems, lastOutputContract);\n954\t      state = loopResult.state;\n955\t      errors.push(...loopResult.errors);\n956\t      tasksCompleted += loopResult.tasksCompleted;\n957\t      lastOutputContract = loopResult.lastContract;\n958\t\n959\t      // Track processed stories from loop\n960\t      for (const item of workItems) {\n961\t        processedStories.add(item.key);\n962\t      }\n963\t\n964\t      if (loopResult.halted) {\n965\t        halted = true;\n966\t      }\n967\t\n968\t      // If loop ended with max-iterations or circuit-breaker, treat as failure\n969\t      if (state.phase === 'max-iterations' || state.phase === 'circuit-breaker') {\n970\t        halted = true;\n971\t      }\n972\t      continue;\n973\t    }\n974\t\n975\t    // step is a string task name\n976\t    const taskName = step;\n977\t    const task = config.workflow.tasks[taskName];\n978\t\n979\t    if (!task) {\n980\t      warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n981\t      continue;\n982\t    }\n983\t\n984\t    // Look up the agent definition\n985\t    const definition = config.agents[task.agent];\n986\t    if (!definition) {\n987\t      warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n988\t      continue;\n989\t    }\n990\t\n991\t    if (task.scope === 'per-run') {\n992\t      // Skip if already completed (crash recovery — AC #3)\n993\t      if (isTaskCompleted(state, taskName, PER_RUN_SENTINEL)) {\n994\t        warn(`workflow-engine: skipping completed task ${taskName} for ${PER_RUN_SENTINEL}`);\n995\t        continue;\n996\t      }\n997\t\n998\t      // Per-run: dispatch once with sentinel key\n999\t      try {\n1000\t        const dispatchResult = await dispatchTaskWithResult(\n1001\t          task, taskName, PER_RUN_SENTINEL, definition, state, config, undefined, lastOutputContract ?? undefined,\n1002\t        );\n1003\t        state = dispatchResult.updatedState;\n1004\t        lastOutputContract = dispatchResult.contract;\n1005\t        tasksCompleted++;\n1006\t      } catch (err: unknown) {\n1007\t        const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n1008\t        errors.push(engineError);\n1009\t\n1010\t        // Record error checkpoint in state (AC #13)\n1011\t        state = recordErrorInState(state, taskName, PER_RUN_SENTINEL, engineError);\n1012\t        writeWorkflowState(state, projectDir);\n1013\t\n1014\t        // Halt on critical errors\n1015\t        if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n1016\t          halted = true;\n1017\t        }\n1018\t      }\n1019\t    } else {\n1020\t      // Per-story: dispatch once per work item\n1021\t      for (const item of workItems) {\n1022\t        processedStories.add(item.key);\n1023\t\n1024\t        // Skip if already completed (crash recovery — AC #1, #2, #7)\n1025\t        if (isTaskCompleted(state, taskName, item.key)) {\n1026\t          warn(`workflow-engine: skipping completed task ${taskName} for ${item.key}`);\n1027\t          continue;\n1028\t        }\n1029\t\n1030\t        try {\n1031\t          const dispatchResult = await dispatchTaskWithResult(\n1032\t            task, taskName, item.key, definition, state, config, undefined, lastOutputContract ?? undefined,\n1033\t          );\n1034\t          state = dispatchResult.updatedState;\n1035\t          lastOutputContract = dispatchResult.contract;\n1036\t          tasksCompleted++;\n1037\t        } catch (err: unknown) {\n1038\t          const engineError = handleDispatchError(err, taskName, item.key);\n1039\t          errors.push(engineError);\n1040\t\n1041\t          // Record error checkpoint in state (AC #13)\n1042\t          state = recordErrorInState(state, taskName, item.key, engineError);\n1043\t          writeWorkflowState(state, projectDir);\n1044\t\n1045\t          // Halt on critical errors, continue on UNKNOWN\n1046\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n1047\t            halted = true;\n1048\t            break;\n1049\t          }\n1050\t          // UNKNOWN errors: record and continue to next story\n1051\t          continue;\n1052\t        }\n1053\t      }\n1054\t    }\n1055\t  }\n1056\t\n1057\t  // 4. Set final phase if no errors and phase not already set by loop termination\n1058\t  if (errors.length === 0 && state.phase !== 'max-iterations' && state.phase !== 'circuit-breaker') {\n1059\t    state = { ...state, phase: 'completed' };\n1060\t    writeWorkflowState(state, projectDir);\n1061\t  }\n1062\t\n1063\t  // 5. Return result\n1064\t  const loopTerminated = state.phase === 'max-iterations' || state.phase === 'circuit-breaker';\n1065\t  return {\n1066\t    success: errors.length === 0 && !loopTerminated,\n1067\t    tasksCompleted,\n1068\t    storiesProcessed: processedStories.size,\n1069\t    errors,\n1070\t    durationMs: Date.now() - startMs,\n1071\t  };\n1072\t}\n1073\t\n1074\t// --- Error Handling ---\n1075\t\n1076\t/**\n1077\t * Record a dispatch error in workflow state: set phase to \"error\" and append\n1078\t * a TaskCheckpoint with the error details (AC #13).\n1079\t */\n1080\tfunction recordErrorInState(\n1081\t  state: WorkflowState,\n1082\t  taskName: string,\n1083\t  storyKey: string,\n1084\t  error: EngineError,\n1085\t): WorkflowState {\n1086\t  const errorCheckpoint: TaskCheckpoint = {\n1087\t    task_name: taskName,\n1088\t    story_key: storyKey,\n1089\t    completed_at: new Date().toISOString(),\n1090\t    error: true,\n1091\t  };\n1092\t  return {\n1093\t    ...state,\n1094\t    phase: 'error',\n1095\t    tasks_completed: [...state.tasks_completed, errorCheckpoint],\n1096\t  };\n1097\t}\n1098\t\n1099\tfunction handleDispatchError(err: unknown, taskName: string, storyKey: string): EngineError {\n1100\t  if (err instanceof DispatchError) {\n1101\t    return {\n1102\t      taskName,\n1103\t      storyKey,\n1104\t      code: err.code,\n1105\t      message: err.message,\n1106\t    };\n1107\t  }\n1108\t\n1109\t  const message = err instanceof Error ? err.message : String(err);\n1110\t  return {\n1111\t    taskName,\n1112\t    storyKey,\n1113\t    code: 'UNKNOWN',\n1114\t    message,\n1115\t  };"}]},"parent_tool_use_id":"toolu_01E368mBox6AGS9E4aPFSS48","session_id":"8a461711-53e2-475a-88dd-c7013f6080c5","uuid":"d414ca12-7c92-4b8a-a894-c0bde28e7585","timestamp":"2026-04-03T17:13:18.789Z"}
