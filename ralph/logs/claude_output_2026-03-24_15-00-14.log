{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BWhETVCzdtip6VNGVr3MEJ","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, afterEach } from 'vitest';\n     2→import {\n     3→  existsSync,\n     4→  readFileSync,\n     5→  writeFileSync,\n     6→  unlinkSync,\n     7→  mkdirSync,\n     8→  rmSync,\n     9→} from 'node:fs';\n    10→import { join } from 'node:path';\n    11→import { parse } from 'yaml';\n    12→import type { SprintState } from '../../../types/state.js';\n    13→\n    14→// Import functions under test\n    15→const {\n    16→  generateSprintStatusYaml,\n    17→  getStoryStatusesFromState,\n    18→  writeStateAtomic,\n    19→  defaultState,\n    20→  sprintStatusYamlPath,\n    21→} = await import('../state.js');\n    22→\n    23→const STATE_FILE = join(process.cwd(), 'sprint-state.json');\n    24→const TMP_FILE = join(process.cwd(), '.sprint-state.json.tmp');\n    25→const YAML_DIR = join(process.cwd(), '_bmad-output', 'implementation-artifacts');\n    26→const YAML_FILE = join(YAML_DIR, 'sprint-status.yaml');\n    27→\n    28→function cleanup(): void {\n    29→  for (const f of [STATE_FILE, TMP_FILE]) {\n    30→    try { unlinkSync(f); } catch { /* ignore */ }\n    31→  }\n    32→  // Don't remove the actual YAML dir if it exists; just clean our test state file\n    33→}\n    34→\n    35→function mkStory(status: string): SprintState['stories'][string] {\n    36→  return {\n    37→    status: status as 'done',\n    38→    attempts: 0,\n    39→    lastAttempt: null,\n    40→    lastError: null,\n    41→    proofPath: null,\n    42→    acResults: null,\n    43→  };\n    44→}\n    45→\n    46→// ─── getStoryStatusesFromState ──────────────────────────────────────────────\n    47→\n    48→describe('getStoryStatusesFromState', () => {\n    49→  it('returns empty map for empty state', () => {\n    50→    const state = defaultState();\n    51→    const result = getStoryStatusesFromState(state);\n    52→    expect(result).toEqual({});\n    53→  });\n    54→\n    55→  it('returns flat key→status map from state stories', () => {\n    56→    const state: SprintState = {\n    57→      ...defaultState(),\n    58→      stories: {\n    59→        '1-1-first-story': mkStory('done'),\n    60→        '1-2-second-story': mkStory('in-progress'),\n    61→        '2-1-third-story': mkStory('backlog'),\n    62→      },\n    63→    };\n    64→    const result = getStoryStatusesFromState(state);\n    65→    expect(result).toEqual({\n    66→      '1-1-first-story': 'done',\n    67→      '1-2-second-story': 'in-progress',\n    68→      '2-1-third-story': 'backlog',\n    69→    });\n    70→  });\n    71→\n    72→  it('preserves all status types', () => {\n    73→    const state: SprintState = {\n    74→      ...defaultState(),\n    75→      stories: {\n    76→        '1-1-a': mkStory('done'),\n    77→        '1-2-b': mkStory('failed'),\n    78→        '1-3-c': mkStory('blocked'),\n    79→        '2-1-d': mkStory('verifying'),\n    80→        '2-2-e': mkStory('review'),\n    81→        '2-3-f': mkStory('ready'),\n    82→      },\n    83→    };\n    84→    const result = getStoryStatusesFromState(state);\n    85→    expect(result['1-1-a']).toBe('done');\n    86→    expect(result['1-2-b']).toBe('failed');\n    87→    expect(result['1-3-c']).toBe('blocked');\n    88→    expect(result['2-1-d']).toBe('verifying');\n    89→    expect(result['2-2-e']).toBe('review');\n    90→    expect(result['2-3-f']).toBe('ready');\n    91→  });\n    92→});\n    93→\n    94→// ─── generateSprintStatusYaml ───────────────────────────────────────────────\n    95→\n    96→describe('generateSprintStatusYaml', () => {\n    97→  it('produces valid YAML for empty state', () => {\n    98→    const state = defaultState();\n    99→    const yaml = generateSprintStatusYaml(state);\n   100→    expect(yaml).toContain('development_status:');\n   101→    // Should parse without error\n   102→    const parsed = parse(yaml);\n   103→    expect(parsed).toBeDefined();\n   104→  });\n   105→\n   106→  it('groups stories by epic and sorts by epic/story number', () => {\n   107→    const state: SprintState = {\n   108→      ...defaultState(),\n   109→      stories: {\n   110→        '2-1-beta': mkStory('backlog'),\n   111→        '1-2-second': mkStory('done'),\n   112→        '1-1-first': mkStory('done'),\n   113→        '2-2-gamma': mkStory('in-progress'),\n   114→      },\n   115→    };\n   116→    const yaml = generateSprintStatusYaml(state);\n   117→\n   118→    // Epic 1 should appear before Epic 2\n   119→    const epic1Pos = yaml.indexOf('# Epic 1');\n   120→    const epic2Pos = yaml.indexOf('# Epic 2');\n   121→    expect(epic1Pos).toBeLessThan(epic2Pos);\n   122→\n   123→    // Within Epic 1, story 1-1 should appear before 1-2\n   124→    const story11Pos = yaml.indexOf('1-1-first');\n   125→    const story12Pos = yaml.indexOf('1-2-second');\n   126→    expect(story11Pos).toBeLessThan(story12Pos);\n   127→  });\n   128→\n   129→  it('computes epic status as done when all stories done', () => {\n   130→    const state: SprintState = {\n   131→      ...defaultState(),\n   132→      stories: {\n   133→        '1-1-first': mkStory('done'),\n   134→        '1-2-second': mkStory('done'),\n   135→      },\n   136→    };\n   137→    const yaml = generateSprintStatusYaml(state);\n   138→    expect(yaml).toContain('epic-1: done');\n   139→  });\n   140→\n   141→  it('computes epic status as backlog when not all stories done', () => {\n   142→    const state: SprintState = {\n   143→      ...defaultState(),\n   144→      stories: {\n   145→        '1-1-first': mkStory('done'),\n   146→        '1-2-second': mkStory('in-progress'),\n   147→      },\n   148→    };\n   149→    const yaml = generateSprintStatusYaml(state);\n   150→    expect(yaml).toContain('epic-1: backlog');\n   151→  });\n   152→\n   153→  it('maps \"ready\" status to \"ready-for-dev\" in YAML', () => {\n   154→    const state: SprintState = {\n   155→      ...defaultState(),\n   156→      stories: {\n   157→        '3-1-some-story': mkStory('ready'),\n   158→      },\n   159→    };\n   160→    const yaml = generateSprintStatusYaml(state);\n   161→    expect(yaml).toContain('3-1-some-story: ready-for-dev');\n   162→  });\n   163→\n   164→  it('produces parseable YAML with correct development_status', () => {\n   165→    const state: SprintState = {\n   166→      ...defaultState(),\n   167→      stories: {\n   168→        '1-1-alpha': mkStory('done'),\n   169→        '2-1-beta': mkStory('backlog'),\n   170→      },\n   171→    };\n   172→    const yaml = generateSprintStatusYaml(state);\n   173→    const parsed = parse(yaml) as Record<string, unknown>;\n   174→    expect(parsed.development_status).toBeDefined();\n   175→\n   176→    const devStatus = parsed.development_status as Record<string, string>;\n   177→    expect(devStatus['1-1-alpha']).toBe('done');\n   178→    expect(devStatus['2-1-beta']).toBe('backlog');\n   179→    expect(devStatus['epic-1']).toBe('done');\n   180→    expect(devStatus['epic-2']).toBe('backlog');\n   181→  });\n   182→\n   183→  it('includes auto-generated header comment', () => {\n   184→    const state = defaultState();\n   185→    const yaml = generateSprintStatusYaml(state);\n   186→    expect(yaml).toContain('auto-generated from sprint-state.json');\n   187→    expect(yaml).toContain('do NOT edit manually');\n   188→  });\n   189→\n   190→  it('handles multiple epics with mixed statuses', () => {\n   191→    const state: SprintState = {\n   192→      ...defaultState(),\n   193→      stories: {\n   194→        '1-1-a': mkStory('done'),\n   195→        '1-2-b': mkStory('done'),\n   196→        '2-1-c': mkStory('done'),\n   197→        '2-2-d': mkStory('failed'),\n   198→        '3-1-e': mkStory('backlog'),\n   199→      },\n   200→    };\n   201→    const yaml = generateSprintStatusYaml(state);\n   202→    expect(yaml).toContain('epic-1: done');\n   203→    expect(yaml).toContain('epic-2: backlog'); // 2-2-d is failed, not done\n   204→    expect(yaml).toContain('epic-3: backlog');\n   205→  });\n   206→});\n   207→\n   208→// ─── writeStateAtomic regenerates YAML ──────────────────────────────────────\n   209→\n   210→describe('writeStateAtomic regenerates sprint-status.yaml', () => {\n   211→  beforeEach(cleanup);\n   212→  afterEach(cleanup);\n   213→\n   214→  it('writes sprint-status.yaml when directory exists', () => {\n   215→    // The YAML_DIR should exist in this project\n   216→    if (!existsSync(YAML_DIR)) {\n   217→      mkdirSync(YAML_DIR, { recursive: true });\n   218→    }\n   219→\n   220→    const state: SprintState = {\n   221→      ...defaultState(),\n   222→      stories: {\n   223→        '1-1-test-story': mkStory('done'),\n   224→      },\n   225→    };\n   226→    const result = writeStateAtomic(state);\n   227→    expect(result.success).toBe(true);\n   228→\n   229→    // Verify sprint-status.yaml was written\n   230→    expect(existsSync(YAML_FILE)).toBe(true);\n   231→    const yamlContent = readFileSync(YAML_FILE, 'utf-8');\n   232→    expect(yamlContent).toContain('1-1-test-story: done');\n   233→    expect(yamlContent).toContain('auto-generated');\n   234→  });\n   235→\n   236→  it('YAML updates on every state write', () => {\n   237→    if (!existsSync(YAML_DIR)) {\n   238→      mkdirSync(YAML_DIR, { recursive: true });\n   239→    }\n   240→\n   241→    // First write\n   242→    const state1: SprintState = {\n   243→      ...defaultState(),\n   244→      stories: {\n   245→        '1-1-story': mkStory('backlog'),\n   246→      },\n   247→    };\n   248→    writeStateAtomic(state1);\n   249→    const yaml1 = readFileSync(YAML_FILE, 'utf-8');\n   250→    expect(yaml1).toContain('1-1-story: backlog');\n   251→\n   252→    // Second write with updated status\n   253→    const state2: SprintState = {\n   254→      ...defaultState(),\n   255→      stories: {\n   256→        '1-1-story': mkStory('done'),\n   257→      },\n   258→    };\n   259→    writeStateAtomic(state2);\n   260→    const yaml2 = readFileSync(YAML_FILE, 'utf-8');\n   261→    expect(yaml2).toContain('1-1-story: done');\n   262→    expect(yaml2).not.toContain('1-1-story: backlog');\n   263→  });\n   264→});\n   265→\n   266→// ─── sprintStatusYamlPath ───────────────────────────────────────────────────\n   267→\n   268→describe('sprintStatusYamlPath', () => {\n   269→  it('returns expected path', () => {\n   270→    const path = sprintStatusYamlPath();\n   271→    expect(path).toContain('_bmad-output');\n   272→    expect(path).toContain('implementation-artifacts');\n   273→    expect(path).toContain('sprint-status.yaml');\n   274→  });\n   275→});\n   276→"}]},"parent_tool_use_id":"toolu_01S1Fmwybv95nEtmZySwttre","session_id":"bd5543f6-f408-4218-88bd-6e3bcdc37563","uuid":"b3ce85d1-e567-4068-87f4-5ef0ac6a8f9e","timestamp":"2026-03-24T11:12:45.506Z"}
