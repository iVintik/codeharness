{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KmEZvfKJP56z95BUtrtaxw","type":"tool_result","content":"     1→/**\n     2→ * AgentDriver abstraction types.\n     3→ *\n     4→ * Defines the contract that all agent drivers (Ralph, future API-based agents)\n     5→ * must implement. See architecture-v3.md Decision 3.\n     6→ */\n     7→\n     8→import type { Readable } from 'node:stream';\n     9→\n    10→/**\n    11→ * Options for spawning an agent process.\n    12→ */\n    13→export interface SpawnOpts {\n    14→  storyKey: string;\n    15→  prompt: string;\n    16→  workDir: string;\n    17→  timeout: number;\n    18→  env?: Record<string, string>;\n    19→}\n    20→\n    21→/**\n    22→ * Abstraction over a running agent process.\n    23→ * Wraps Node.js ChildProcess but allows non-process-based drivers\n    24→ * (direct API calls, WebSocket connections) to implement the same interface.\n    25→ */\n    26→export interface AgentProcess {\n    27→  stdout: Readable;\n    28→  stderr: Readable;\n    29→  on(event: 'close', handler: (code: number) => void): void;\n    30→  kill(signal?: string): void;\n    31→}\n    32→\n    33→/**\n    34→ * Discriminated union of events emitted by an agent driver.\n    35→ * The `parseOutput()` method converts raw agent output lines into these typed events.\n    36→ */\n    37→export type AgentEvent =\n    38→  | { type: 'tool-start'; name: string }\n    39→  | { type: 'tool-complete'; name: string; args: string }\n    40→  | { type: 'text'; text: string }\n    41→  | { type: 'story-complete'; key: string; details: string }\n    42→  | { type: 'story-failed'; key: string; reason: string }\n    43→  | { type: 'iteration'; count: number }\n    44→  | { type: 'retry'; attempt: number; delay: number }\n    45→  | { type: 'result'; cost: number; sessionId: string };\n    46→\n    47→/**\n    48→ * The core agent driver interface.\n    49→ * Each driver knows how to spawn an agent, parse its output, and locate its status file.\n    50→ */\n    51→export interface AgentDriver {\n    52→  readonly name: string;\n    53→  spawn(opts: SpawnOpts): AgentProcess;\n    54→  parseOutput(line: string): AgentEvent | null;\n    55→  getStatusFile(): string;\n    56→}\n    57→"}]},"parent_tool_use_id":"toolu_01MLby4BNS4m4k61v3WBT7EW","session_id":"8c35c2f7-0e10-4994-a438-2b5cecce3396","uuid":"fa777ee5-3bf4-4f34-b1f3-81c5deec828e","timestamp":"2026-03-24T14:34:34.860Z"}
