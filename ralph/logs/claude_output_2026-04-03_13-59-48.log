{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014emMpMyM9Aq2J8HipwaSRH","type":"tool_result","content":"1\t/**\n2\t * Output contract serialization and deserialization.\n3\t *\n4\t * Provides atomic write/read for OutputContract JSON files.\n5\t * Written atomically: first to a .tmp file, then renamed to final path.\n6\t * See architecture-multi-framework.md Decision 3.\n7\t */\n8\t\n9\timport { writeFileSync, readFileSync, renameSync, mkdirSync, existsSync } from 'node:fs';\n10\timport { join } from 'node:path';\n11\timport type { OutputContract } from './types.js';\n12\t\n13\t/**\n14\t * Compute the file path for a contract.\n15\t */\n16\tfunction contractFilePath(taskName: string, storyId: string, contractDir: string): string {\n17\t  return join(contractDir, `${taskName}-${storyId}.json`);\n18\t}\n19\t\n20\t/**\n21\t * Write an OutputContract to disk atomically.\n22\t *\n23\t * Creates the target directory if it does not exist.\n24\t * Writes to a .tmp file first, then renames to the final path.\n25\t * On failure, throws an error with a descriptive message including the file path.\n26\t */\n27\texport function writeOutputContract(contract: OutputContract, contractDir: string): void {\n28\t  const finalPath = contractFilePath(contract.taskName, contract.storyId, contractDir);\n29\t  const tmpPath = finalPath + '.tmp';\n30\t\n31\t  try {\n32\t    mkdirSync(contractDir, { recursive: true });\n33\t    writeFileSync(tmpPath, JSON.stringify(contract, null, 2) + '\\n', 'utf-8');\n34\t    renameSync(tmpPath, finalPath);\n35\t  } catch (err) {\n36\t    const message = err instanceof Error ? err.message : String(err);\n37\t    throw new Error(`Failed to write output contract to ${finalPath}: ${message}`);\n38\t  }\n39\t}\n40\t\n41\t/**\n42\t * Read an OutputContract from disk.\n43\t *\n44\t * Returns null if the file does not exist.\n45\t */\n46\texport function readOutputContract(\n47\t  taskName: string,\n48\t  storyId: string,\n49\t  contractDir: string,\n50\t): OutputContract | null {\n51\t  const filePath = contractFilePath(taskName, storyId, contractDir);\n52\t\n53\t  if (!existsSync(filePath)) {\n54\t    return null;\n55\t  }\n56\t\n57\t  const raw = readFileSync(filePath, 'utf-8');\n58\t  return JSON.parse(raw) as OutputContract;\n59\t}\n60\t"}]},"parent_tool_use_id":"toolu_01YSacQvkrW7LZee36oBUg8s","session_id":"be33ba5d-0e81-49c4-ae53-e69ac56cd1fb","uuid":"2d51d9c8-758f-4cf9-b839-2c0f5fd92203","timestamp":"2026-04-03T10:11:04.851Z"}
