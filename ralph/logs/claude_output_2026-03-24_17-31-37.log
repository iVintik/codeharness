\n   235→    expect(stdout).toContain('logs=http://localhost:9428');\n   236→    expect(stdout).toContain('metrics=http://localhost:8428');\n   237→    expect(stdout).toContain('traces=http://localhost:16686');\n   238→  });\n   239→\n   240→  it('does not print endpoint URLs when stack is unhealthy', async () => {\n   241→    const state = getDefaultState('nodejs');\n   242→    state.initialized = true;\n   243→    writeState(state, testDir);\n   244→\n   245→    mockGetStackHealth.mockReturnValue({\n   246→      healthy: false,\n   247→      services: [\n   248→        { name: 'victoria-logs', running: false },\n   249→        { name: 'victoria-metrics', running: false },\n   250→        { name: 'victoria-traces', running: false },\n   251→        { name: 'otel-collector', running: false },\n   252→      ],\n   253→      remedy: 'Restart: docker compose -f docker-compose.harness.yml up -d',\n   254→    });\n   255→\n   256→    const { stdout } = await runCli(['status', '--check-docker']);\n   257→    expect(stdout).not.toContain('Endpoints:');\n   258→  });\n   259→\n   260→  it('JSON output includes endpoints when stack is healthy', async () => {\n   261→    const state = getDefaultState('nodejs');\n   262→    state.initialized = true;\n   263→    writeState(state, testDir);\n   264→\n   265→    const { stdout } = await runCli(['--json', 'status', '--check-docker']);\n   266→    const jsonLine = stdout.split('\\n').find(l => l.startsWith('{'));\n   267→    const parsed = JSON.parse(jsonLine!);\n   268→    expect(parsed.endpoints).toEqual(DEFAULT_ENDPOINTS);\n   269→    expect(parsed.endpoints.logs).toBe('http://localhost:9428');\n   270→    expect(parsed.endpoints.metrics).toBe('http://localhost:8428');\n   271→    expect(parsed.endpoints.traces).toBe('http://localhost:16686');\n   272→    expect(parsed.endpoints.otel_http).toBe('http://localhost:4318');\n   273→  });\n   274→\n   275→  it('JSON output omits endpoints when stack is unhealthy', async () => {\n   276→    const state = getDefaultState('nodejs');\n   277→    state.initialized = true;\n   278→    writeState(state, testDir);\n   279→\n   280→    mockGetStackHealth.mockReturnValue({\n   281→      healthy: false,\n   282→      services: [\n   283→        { name: 'victoria-logs', running: false },\n   284→        { name: 'victoria-metrics', running: false },\n   285→        { name: 'victoria-traces', running: false },\n   286→        { name: 'otel-collector', running: false },\n   287→      ],\n   288→      remedy: 'Restart',\n   289→    });\n   290→\n   291→    const { stdout } = await runCli(['--json', 'status', '--check-docker']);\n   292→    const jsonLine = stdout.split('\\n').find(l => l.startsWith('{'));\n   293→    const parsed = JSON.parse(jsonLine!);\n   294→    expect(parsed.endpoints).toBeUndefined();\n   295→  });\n   296→});\n   297→\n   298→// ─── Full status display ────────────────────────────────────────────────────\n   299→"}]},"parent_tool_use_id":"toolu_01VNjZAjpP2pH4BGjYH7gZ11","session_id":"a74f233b-d75f-4731-af98-d5f8de661326","uuid":"1b1f641e-14a9-409c-a95d-119f836af5aa","timestamp":"2026-03-24T13:42:53.534Z"}
