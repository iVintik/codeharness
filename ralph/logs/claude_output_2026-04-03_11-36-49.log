{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ESQuMJXbUTRsrY2vrv4V5P","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach } from 'vitest';\n2\t\n3\t// --- Hoisted Mocks ---\n4\t\n5\tconst {\n6\t  mockDispatchAgent,\n7\t  mockReadWorkflowState,\n8\t  mockWriteWorkflowState,\n9\t  mockCreateIsolatedWorkspace,\n10\t  mockGenerateTraceId,\n11\t  mockFormatTracePrompt,\n12\t  mockRecordTraceId,\n13\t  mockResolveSessionId,\n14\t  mockRecordSessionId,\n15\t  mockWarn,\n16\t  mockReadFileSync,\n17\t  mockExistsSync,\n18\t  mockParse,\n19\t  mockGetDriver,\n20\t  mockResolveModel,\n21\t  mockDriverDispatch,\n22\t} = vi.hoisted(() => ({\n23\t  mockDispatchAgent: vi.fn(),\n24\t  mockReadWorkflowState: vi.fn(),\n25\t  mockWriteWorkflowState: vi.fn(),\n26\t  mockCreateIsolatedWorkspace: vi.fn(),\n27\t  mockGenerateTraceId: vi.fn(),\n28\t  mockFormatTracePrompt: vi.fn(),\n29\t  mockRecordTraceId: vi.fn(),\n30\t  mockResolveSessionId: vi.fn(),\n31\t  mockRecordSessionId: vi.fn(),\n32\t  mockWarn: vi.fn(),\n33\t  mockReadFileSync: vi.fn(),\n34\t  mockExistsSync: vi.fn(),\n35\t  mockParse: vi.fn(),\n36\t  mockGetDriver: vi.fn(),\n37\t  mockResolveModel: vi.fn(),\n38\t  mockDriverDispatch: vi.fn(),\n39\t}));\n40\t\n41\tvi.mock('../agent-dispatch.js', () => ({\n42\t  dispatchAgent: mockDispatchAgent,\n43\t  DispatchError: class DispatchError extends Error {\n44\t    public readonly code: string;\n45\t    public readonly agentName: string;\n46\t    public readonly cause: unknown;\n47\t    constructor(message: string, code: string, agentName: string, cause: unknown) {\n48\t      super(message);\n49\t      this.name = 'DispatchError';\n50\t      this.code = code;\n51\t      this.agentName = agentName;\n52\t      this.cause = cause;\n53\t    }\n54\t  },\n55\t}));\n56\t\n57\tvi.mock('../agents/drivers/factory.js', () => ({\n58\t  getDriver: mockGetDriver,\n59\t}));\n60\t\n61\tvi.mock('../agents/model-resolver.js', () => ({\n62\t  resolveModel: mockResolveModel,\n63\t}));\n64\t\n65\tvi.mock('../workflow-state.js', () => ({\n66\t  readWorkflowState: mockReadWorkflowState,\n67\t  writeWorkflowState: mockWriteWorkflowState,\n68\t  getDefaultWorkflowState: () => ({\n69\t    workflow_name: '',\n70\t    started: '',\n71\t    iteration: 0,\n72\t    phase: 'idle',\n73\t    tasks_completed: [],\n74\t    evaluator_scores: [],\n75\t    circuit_breaker: { triggered: false, reason: null, score_history: [] },\n76\t    trace_ids: [],\n77\t  }),\n78\t}));\n79\t\n80\tvi.mock('../source-isolation.js', () => ({\n81\t  createIsolatedWorkspace: mockCreateIsolatedWorkspace,\n82\t}));\n83\t\n84\tvi.mock('../trace-id.js', () => ({\n85\t  generateTraceId: mockGenerateTraceId,\n86\t  formatTracePrompt: mockFormatTracePrompt,\n87\t  recordTraceId: mockRecordTraceId,\n88\t}));\n89\t\n90\tvi.mock('../session-manager.js', () => ({\n91\t  resolveSessionId: mockResolveSessionId,\n92\t  recordSessionId: mockRecordSessionId,\n93\t}));\n94\t\n95\tvi.mock('../output.js', () => ({\n96\t  warn: mockWarn,\n97\t}));\n98\t\n99\tvi.mock('node:fs', () => ({\n100\t  readFileSync: mockReadFileSync,\n101\t  existsSync: mockExistsSync,\n102\t}));\n103\t\n104\tvi.mock('yaml', () => ({\n105\t  parse: mockParse,\n106\t}));\n107\t\n108\timport {\n109\t  executeWorkflow,\n110\t  loadWorkItems,\n111\t  dispatchTask,\n112\t  parseVerdict,\n113\t  buildRetryPrompt,\n114\t  getFailedItems,\n115\t  executeLoopBlock,\n116\t  isTaskCompleted,\n117\t  isLoopTaskCompleted,\n118\t  PER_RUN_SENTINEL,\n119\t} from '../workflow-engine.js';\n120\timport type {\n121\t  EngineConfig,\n122\t  EngineError,\n123\t  WorkItem,\n124\t  EvaluatorVerdict,\n125\t} from '../workflow-engine.js';\n126\timport type { WorkflowState } from '../workflow-state.js';\n127\timport type { ResolvedWorkflow, ResolvedTask } from '../workflow-parser.js';\n128\timport type { SubagentDefinition } from '../agent-resolver.js';\n129\t\n130\t// --- Helpers ---\n131\t\n132\t/**\n133\t * Helper: create an async iterable that yields stream events for the driver mock.\n134\t * Simulates what the real driver.dispatch() returns.\n135\t */\n136\tfunction makeDriverStream(output: string, sessionId: string, opts?: { error?: string; errorCategory?: string }) {\n137\t  return (async function* () {\n138\t    if (output) {\n139\t      yield { type: 'text' as const, text: output };\n140\t    }\n141\t    yield {\n142\t      type: 'result' as const,\n143\t      cost: 0.05,\n144\t      sessionId,\n145\t      ...(opts?.error ? { error: opts.error, errorCategory: opts.errorCategory ?? 'UNKNOWN' } : {}),\n146\t    };\n147\t  })();\n148\t}\n149\t\n150\t/**\n151\t * Helper: create an async iterable that throws an error (for testing dispatch failures).\n152\t */\n153\tfunction makeDriverStreamError(err: unknown) {\n154\t  return (async function* () {\n155\t    throw err;\n156\t  })();\n157\t}\n158\t\n159\tfunction makeDefaultState(overrides?: Partial<WorkflowState>): WorkflowState {\n160\t  return {\n161\t    workflow_name: '',\n162\t    started: '',\n163\t    iteration: 0,\n164\t    phase: 'idle',\n165\t    tasks_completed: [],\n166\t    evaluator_scores: [],\n167\t    circuit_breaker: { triggered: false, reason: null, score_history: [] },\n168\t    trace_ids: [],\n169\t    ...overrides,\n170\t  };\n171\t}\n172\t\n173\tfunction makeDefinition(overrides?: Partial<SubagentDefinition>): SubagentDefinition {\n174\t  return {\n175\t    name: 'test-agent',\n176\t    model: 'claude-sonnet-4-20250514',\n177\t    instructions: 'You are a test agent.',\n178\t    disallowedTools: [],\n179\t    bare: true,\n180\t    ...overrides,\n181\t  };\n182\t}\n183\t\n184\tfunction makeTask(overrides?: Partial<ResolvedTask>): ResolvedTask {\n185\t  return {\n186\t    agent: 'dev',\n187\t    scope: 'per-story',\n188\t    session: 'fresh',\n189\t    source_access: true,\n190\t    ...overrides,\n191\t  };\n192\t}\n193\t\n194\tfunction makeConfig(overrides?: Partial<EngineConfig>): EngineConfig {\n195\t  return {\n196\t    workflow: {\n197\t      tasks: {\n198\t        implement: makeTask(),\n199\t        verify: makeTask({ scope: 'per-run', source_access: false }),\n200\t      },"}]},"parent_tool_use_id":"toolu_01WzzY2TpSn4HBX8Gw2yuQNF","session_id":"f83470b7-c271-483e-ae93-7fe9bce4b683","uuid":"72692955-7a07-47f5-af83-94a968455bfa","timestamp":"2026-04-03T07:55:03.608Z"}
