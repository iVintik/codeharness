s.some(g => g.description.includes('No verification proofs'))).toBe(true);\n   517→    }\n   518→  });\n   519→\n   520→  it('returns warn when checkVerification outer catch fires', () => {\n   521→    mockExistsSync.mockImplementation(() => {\n   522→      throw new Error('Filesystem error');\n   523→    });\n   524→\n   525→    const result = checkVerification('/project');\n   526→    expect(result.success).toBe(true);\n   527→    if (result.success) {\n   528→      expect(result.data.status).toBe('warn');\n   529→      expect(result.data.gaps[0].description).toContain('Filesystem error');\n   530→    }\n   531→  });\n   532→\n   533→  it('returns warn when no proofs found', () => {\n   534→    mockExistsSync.mockImplementation((p: unknown) => {\n   535→      const path = String(p);\n   536→      if (path.includes('sprint-status.yaml')) return true;\n   537→      return false;\n   538→    });\n   539→\n   540→    const result = checkVerification('/project');\n   541→    expect(result.success).toBe(true);\n   542→    if (result.success) {\n   543→      expect(result.data.status).toBe('warn');\n   544→      expect(result.data.gaps.some(g => g.description.includes('No verification proofs'))).toBe(true);\n   545→    }\n   546→  });\n   547→});\n   548→\n   549→// ─── checkInfrastructure ────────────────────────────────────────────────────\n   550→\n   551→describe('checkInfrastructure', () => {\n   552→  it('returns fail when no Dockerfile', () => {\n   553→    mockExistsSync.mockReturnValue(false);\n   554→\n   555→    const result = checkInfrastructure('/project');\n   556→    expect(result.success).toBe(true);\n   557→    if (result.success) {\n   558→      expect(result.data.status).toBe('fail');\n   559→      expect(result.data.metric).toBe('no Dockerfile');\n   560→      expect(result.data.gaps[0].description).toBe('No Dockerfile found');\n   561→    }\n   562→  });\n   563→\n   564→  it('returns pass with properly pinned Dockerfile', () => {\n   565→    mockExistsSync.mockReturnValue(true);\n   566→    mockReadFileSync.mockReturnValue('FROM node:22-slim\\nRUN npm install\\n');\n   567→\n   568→    const result = checkInfrastructure('/project');\n   569→    expect(result.success).toBe(true);\n   570→    if (result.success) {\n   571→      expect(result.data.status).toBe('pass');\n   572→      expect(result.data.metric).toBe('Dockerfile valid');\n   573→      expect(result.data.gaps).toHaveLength(0);\n   574→    }\n   575→  });\n   576→\n   577→  it('returns warn for unpinned base image (:latest)', () => {\n   578→    mockExistsSync.mockReturnValue(true);\n   579→    mockReadFileSync.mockReturnValue('FROM node:latest\\nRUN npm install\\n');\n   580→\n   581→    const result = checkInfrastructure('/project');\n   582→    expect(result.success).toBe(true);\n   583→    if (result.success) {\n   584→      expect(result.data.status).toBe('warn');\n   585→      expect(result.data.gaps.some(g => g.description.includes('Unpinned base image'))).toBe(true);\n   586→    }\n   587→  });\n   588→\n   589→  it('returns warn for base image with no tag', () => {\n   590→    mockExistsSync.mockReturnValue(true);\n   591→    mockReadFileSync.mockReturnValue('FROM node\\nRUN npm install\\n');\n   592→\n   593→    const result = checkInfrastructure('/project');\n   594→    expect(result.success).toBe(true);\n   595→    if (result.success) {\n   596→      expect(result.data.status).toBe('warn');\n   597→      expect(result.data.gaps.some(g => g.description.includes('no tag'))).toBe(true);\n   598→    }\n   599→  });\n   600→\n   601→  it('returns fail when Dockerfile has no FROM', () => {\n   602→    mockExistsSync.mockReturnValue(true);\n   603→    mockReadFileSync.mockReturnValue('RUN npm install\\n');\n   604→\n   605→    const result = checkInfrastructure('/project');\n   606→    expect(result.success).toBe(true);\n   607→    if (result.success) {\n   608→      expect(result.data.status).toBe('fail');\n   609→      expect(result.data.metric).toBe('invalid Dockerfile');\n   610→    }\n   611→  });\n   612→\n   613→  it('returns warn when Dockerfile is unreadable', () => {\n   614→    mockExistsSync.mockReturnValue(true);\n   615→    mockReadFileSync.mockImplementation(() => {\n   616→      throw new Error('Permission denied');\n   617→    });\n   618→\n   619→    const result = checkInfrastructure('/project');\n   620→    expect(result.success).toBe(true);\n   621→    if (result.success) {\n   622→      expect(result.data.status).toBe('warn');\n   623→      expect(result.data.metric).toBe('Dockerfile unreadable');\n   624→      expect(result.data.gaps[0].description).toContain('could not be read');\n   625→    }\n   626→  });\n   627→\n   628→  it('returns warn when checkInfrastructure outer catch fires', () => {\n   629→    // Force the outer catch by making existsSync throw on first call\n   630→    let callCount = 0;\n   631→    mockExistsSync.mockImplementation(() => {\n   632→      callCount++;\n   633→      if (callCount === 1) throw new Error('Disk error');\n   634→      return false;\n   635→    });\n   636→\n   637→    const result = checkInfrastructure('/project');\n   638→    expect(result.success).toBe(true);\n   639→    if (result.success) {\n   640→      expect(result.data.status).toBe('warn');\n   641→      expect(result.data.gaps[0].description).toContain('Disk error');\n   642→    }\n   643→  });\n   644→\n   645→  it('returns pass with digest-pinned image', () => {\n   646→    mockExistsSync.mockReturnValue(true);\n   647→    mockReadFileSync.mockReturnValue('FROM node@sha256:abc123\\nRUN npm install\\n');\n   648→\n   649→    const result = checkInfrastructure('/project');\n   650→    expect(result.success).toBe(true);\n   651→    if (result.success) {\n   652→      expect(result.data.status).toBe('pass');\n   653→    }\n   654→  });\n   655→});\n   656→"}]},"parent_tool_use_id":"toolu_01TyVq55huB8WDwxXQnVa2vD","session_id":"d06dabce-ed3c-4abf-ad84-f2845532d39a","uuid":"5a58fafd-c7b9