{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GUnNUoC7hsbdeBGuMMGMvK","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';\n     2→import { mkdtempSync, rmSync, writeFileSync, mkdirSync } from 'node:fs';\n     3→import { existsSync as origExistsSync, readFileSync as origReadFileSync } from 'node:fs';\n     4→import { tmpdir } from 'node:os';\n     5→import { join } from 'node:path';\n     6→import { EventEmitter } from 'node:events';\n     7→import { Command } from 'commander';\n     8→import { resolveRalphPath, resolvePluginDir, countStories, buildSpawnArgs } from '../run.js';\n     9→\n    10→// --- Hoisted mocks ---\n    11→// Capture the real existsSync before vi.mock replaces node:fs\n    12→const {\n    13→  spawnMock, getChildOnHandlers, existsSyncMock, readSprintStatusMock,\n    14→  realExistsSync, getStdoutEmitter, getStderrEmitter,\n    15→  startRendererMock, rendererUpdateMock, rendererUpdateSprintStateMock, rendererCleanupMock,\n    16→  rendererUpdateStoriesMock, rendererAddMessageMock,\n    17→  parseStreamLineMock, getSprintStateMock, reconcileStateMock,\n    18→} = vi.hoisted(() => {\n    19→  // eslint-disable-next-line @typescript-eslint/no-require-imports\n    20→  const fs = require('node:fs');\n    21→  const realFn = fs.existsSync.bind(fs);\n    22→\n    23→  const handlers: Record<string, (...args: unknown[]) => void> = {};\n    24→  let stdoutEmitter: EventEmitter | null = null;\n    25→  let stderrEmitter: EventEmitter | null = null;\n    26→\n    27→  const rendererUpdateMock = vi.fn();\n    28→  const rendererUpdateSprintStateMock = vi.fn();\n    29→  const rendererCleanupMock = vi.fn();\n    30→  const rendererUpdateStoriesMock = vi.fn();\n    31→  const rendererAddMessageMock = vi.fn();\n    32→\n    33→  return {\n    34→    spawnMock: vi.fn(() => {\n    35→      stdoutEmitter = new EventEmitter();\n    36→      stderrEmitter = new EventEmitter();\n    37→      return {\n    38→        on: vi.fn((event: string, handler: (...args: unknown[]) => void) => {\n    39→          handlers[event] = handler;\n    40→        }),\n    41→        pid: 12345,\n    42→        stdin: null,\n    43→        stdout: stdoutEmitter,\n    44→        stderr: stderrEmitter,\n    45→      };\n    46→    }),\n    47→    getChildOnHandlers: () => handlers,\n    48→    existsSyncMock: vi.fn(realFn),\n    49→    readSprintStatusMock: vi.fn(() => ({}) as Record<string, string>),\n    50→    realExistsSync: realFn as (path: string) => boolean,\n    51→    getStdoutEmitter: () => stdoutEmitter,\n    52→    getStderrEmitter: () => stderrEmitter,\n    53→    startRendererMock: vi.fn(() => ({\n    54→      update: rendererUpdateMock,\n    55→      updateSprintState: rendererUpdateSprintStateMock,\n    56→      updateStories: rendererUpdateStoriesMock,\n    57→      addMessage: rendererAddMessageMock,\n    58→      cleanup: rendererCleanupMock,\n    59→    })),\n    60→    rendererUpdateMock,\n    61→    rendererUpdateSprintStateMock,\n    62→    rendererCleanupMock,\n    63→    rendererUpdateStoriesMock,\n    64→    rendererAddMessageMock,\n    65→    parseStreamLineMock: vi.fn(() => null),\n    66→    getSprintStateMock: vi.fn(() => ({ success: false, error: 'no state' })),\n    67→    reconcileStateMock: vi.fn(() => ({ success: true, data: { corrections: [], stateChanged: false } })),\n    68→  };\n    69→});\n    70→\n    71→vi.mock('node:child_process', () => ({ spawn: spawnMock }));\n    72→\n    73→vi.mock('node:fs', async (importOriginal) => {\n    74→  const actual = await importOriginal<typeof import('node:fs')>();\n    75→  return { ...actual, existsSync: existsSyncMock };\n    76→});\n    77→\n    78→vi.mock('../../lib/sync/index.js', () => ({\n    79→  readSprintStatus: (...args: unknown[]) => readSprintStatusMock(...args),\n    80→}));\n    81→\n    82→vi.mock('../../lib/agents/ralph-prompt.js', () => ({\n    83→  generateRalphPrompt: vi.fn(() => 'mock prompt content'),\n    84→}));\n    85→\n    86→vi.mock('../../lib/agents/stream-parser.js', () => ({\n    87→  parseStreamLine: (...args: unknown[]) => parseStreamLineMock(...args),\n    88→}));\n    89→\n    90→vi.mock('../../lib/ink-renderer.js', () => ({\n    91→  startRenderer: (...args: unknown[]) => startRendererMock(...args),\n    92→}));\n    93→\n    94→vi.mock('../../modules/sprint/index.js', () => ({\n    95→  getSprintState: (...args: unknown[]) => getSprintStateMock(...args),\n    96→  readSprintStatusFromState: (...args: unknown[]) => readSprintStatusMock(...args),\n    97→  reconcileState: (...args: unknown[]) => reconcileStateMock(...args),\n    98→}));\n    99→\n   100→describe('run command', () => {\n   101→  let tmpDir: string;\n   102→\n   103→  beforeEach(() => {\n   104→    tmpDir = mkdtempSync(join(tmpdir(), 'run-test-'));\n   105→    spawnMock.mockClear();\n   106→    existsSyncMock.mockReset();\n   107→    existsSyncMock.mockImplementation((p: unknown) => realExistsSync(String(p)));\n   108→    readSprintStatusMock.mockReset();\n   109→    readSprintStatusMock.mockReturnValue({});\n   110→    startRendererMock.mockClear();\n   111→    rendererUpdateMock.mockClear();\n   112→    rendererUpdateSprintStateMock.mockClear();\n   113→    rendererCleanupMock.mockClear();\n   114→    rendererUpdateStoriesMock.mockClear();\n   115→    rendererAddMessageMock.mockClear();\n   116→    parseStreamLineMock.mockClear();\n   117→    parseStreamLineMock.mockReturnValue(null);\n   118→    getSprintStateMock.mockClear();\n   119→    getSprintStateMock.mockReturnValue({ success: false, error: 'no state' });\n   120→    reconcileStateMock.mockClear();\n   121→    reconcileStateMock.mockReturnValue({ success: true, data: { corrections: [], stateChanged: false } });\n   122→    process.exitCode = undefined;\n   123→  });\n   124→\n   125→  afterEach(() => {\n   126→    rmSync(tmpDir, { recursive: true, force: true });\n   127→    vi.restoreAllMocks();\n   128→    process.exitCode = undefined;\n   129→  });\n   130→\n   131→  // Helper to control existsSync per path pattern\n   132→  function mockPaths(overrides: Record<string, boolean>) {\n   133→    existsSyncMock.mockImplementation((p: unknown) => {\n   134→      const path = String(p);\n   135→      for (const [pattern, value] of Object.entries(overrides)) {\n   136→        if (path.includes(pattern)) return value;\n   137→      }\n   138→      return realExistsSync(path);\n   139→    });\n   140→  }\n   141→\n   142→  // Helper to invoke the run command via Commander\n   143→  async function runCommand(args: string[] = []) {\n   144→    const { registerRunCommand } = await import('../run.js');\n   145→    const program = new Command();\n   146→    program.exitOverride();\n   147→    program.option('--json', 'JSON output');\n   148→    registerRunCommand(program);\n   149→    await program.parseAsync(['node', 'codeharness', 'run', ...args]);\n   150→  }"}]},"parent_tool_use_id":"toolu_01ALnzs9UBL7tEMvwMy9zEAC","session_id":"110312c9-09eb-45d4-bc39-1124b22b5753","uuid":"05415074-24bd-459f-bc8a-0bf283fb5237","timestamp":"2026-03-24T16:18:48.295Z"}
