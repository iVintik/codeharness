{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01P5fRimqb6PdoBrh4rYUQnp","type":"tool_result","content":"     1→/**\n     2→ * Audit fix story generator — creates BMAD-format stories for audit gaps.\n     3→ *\n     4→ * FR15: `audit --fix` generates stories for gaps.\n     5→ * NFR6: Generated stories follow BMAD format.\n     6→ *\n     7→ * Architecture Decision 4: Coordinator Pattern extension.\n     8→ */\n     9→\n    10→import { existsSync, writeFileSync, mkdirSync } from 'node:fs';\n    11→import { join, dirname } from 'node:path';\n    12→import { ok, fail } from '../../types/result.js';\n    13→import type { Result } from '../../types/result.js';\n    14→import type { AuditResult, AuditGap } from './types.js';\n    15→import type { FixStoryResult, FixGenerationResult } from './fix-types.js';\n    16→import {\n    17→  getSprintState,\n    18→  writeStateAtomic,\n    19→  computeSprintCounts,\n    20→} from '../sprint/index.js';\n    21→import type { StoryState } from '../../types/state.js';\n    22→\n    23→// ─── Story Key Generation (Task 2.2) ────────────────────────────────────────\n    24→\n    25→/**\n    26→ * Generate a deterministic, filesystem-safe key for an audit gap.\n    27→ * Format: audit-fix-{dimension}-{index}\n    28→ */\n    29→export function buildStoryKey(gap: AuditGap, index: number): string {\n    30→  const safeDimension = gap.dimension\n    31→    .toLowerCase()\n    32→    .replace(/[^a-z0-9]+/g, '-')\n    33→    .replace(/(^-|-$)/g, '');\n    34→  return `audit-fix-${safeDimension}-${index}`;\n    35→}\n    36→\n    37→// ─── Story Markdown Rendering (Task 2.3) ────────────────────────────────────\n    38→\n    39→/**\n    40→ * Render BMAD-format markdown for a fix story.\n    41→ * Includes user story, Given/When/Then AC, and Dev Notes with gap details.\n    42→ */\n    43→export function buildStoryMarkdown(gap: AuditGap, key: string): string {\n    44→  return [\n    45→    `# Fix: ${gap.dimension} — ${gap.description}`,\n    46→    '',\n    47→    'Status: backlog',\n    48→    '',\n    49→    '## Story',\n    50→    '',\n    51→    `As an operator, I need ${gap.description} fixed so that audit compliance improves.`,\n    52→    '',\n    53→    '## Acceptance Criteria',\n    54→    '',\n    55→    `1. **Given** ${gap.description}, **When** the fix is applied, **Then** ${gap.suggestedFix}.`,\n    56→    '',\n    57→    '## Dev Notes',\n    58→    '',\n    59→    'This is an auto-generated fix story created by `codeharness audit --fix`.',\n    60→    `**Audit Gap:** ${gap.dimension}: ${gap.description}`,\n    61→    `**Suggested Fix:** ${gap.suggestedFix}`,\n    62→    '',\n    63→  ].join('\\n');\n    64→}\n    65→\n    66→// ─── Fix Story Generation (Task 2.1) ────────────────────────────────────────\n    67→\n    68→/**\n    69→ * Generate fix stories for all gaps in the audit result.\n    70→ * Skips gaps whose story file already exists (idempotent).\n    71→ */\n    72→export function generateFixStories(\n    73→  auditResult: AuditResult,\n    74→): Result<FixGenerationResult> {\n    75→  try {\n    76→    const stories: FixStoryResult[] = [];\n    77→    let created = 0;\n    78→    let skipped = 0;\n    79→\n    80→    const artifactsDir = join(\n    81→      process.cwd(),\n    82→      '_bmad-output',\n    83→      'implementation-artifacts',\n    84→    );\n    85→\n    86→    // Iterate all gaps across all dimensions\n    87→    for (const dimension of Object.values(auditResult.dimensions)) {\n    88→      for (let i = 0; i < dimension.gaps.length; i++) {\n    89→        const gap = dimension.gaps[i];\n    90→        const key = buildStoryKey(gap, i + 1);\n    91→        const filePath = join(artifactsDir, `${key}.md`);\n    92→\n    93→        // AC #6: Skip if file already exists\n    94→        if (existsSync(filePath)) {\n    95→          stories.push({\n    96→            key,\n    97→            filePath,\n    98→            gap,\n    99→            skipped: true,\n   100→            skipReason: 'Story file already exists',\n   101→          });\n   102→          skipped++;\n   103→          continue;\n   104→        }\n   105→\n   106→        // Write story file\n   107→        const markdown = buildStoryMarkdown(gap, key);\n   108→        mkdirSync(dirname(filePath), { recursive: true });\n   109→        writeFileSync(filePath, markdown, 'utf-8');\n   110→\n   111→        stories.push({ key, filePath, gap, skipped: false });\n   112→        created++;\n   113→      }\n   114→    }\n   115→\n   116→    return ok({ stories, created, skipped });\n   117→  } catch (err: unknown) {\n   118→    const msg = err instanceof Error ? err.message : String(err);\n   119→    return fail(`Failed to generate fix stories: ${msg}`);\n   120→  }\n   121→}\n   122→\n   123→// ─── Sprint State Integration (Task 3) ──────────────────────────────────────\n   124→\n   125→/**\n   126→ * Add generated fix stories to sprint-state.json as backlog entries.\n   127→ * Uses atomic write pattern. Creates default state if file missing.\n   128→ */\n   129→export function addFixStoriesToState(\n   130→  stories: FixStoryResult[],\n   131→): Result<void> {\n   132→  // Filter to only non-skipped stories\n   133→  const newStories = stories.filter(s => !s.skipped);\n   134→  if (newStories.length === 0) {\n   135→    return ok(undefined);\n   136→  }\n   137→\n   138→  // AC #9: getSprintState returns defaultState() when file missing\n   139→  const stateResult = getSprintState();\n   140→  if (!stateResult.success) {\n   141→    return fail(stateResult.error);\n   142→  }\n   143→\n   144→  const current = stateResult.data;\n   145→\n   146→  // Add each new story as a backlog entry\n   147→  const updatedStories: Record<string, StoryState> = { ...current.stories };\n   148→  for (const story of newStories) {\n   149→    updatedStories[story.key] = {\n   150→      status: 'backlog',\n   151→      attempts: 0,\n   152→      lastAttempt: null,\n   153→      lastError: null,\n   154→      proofPath: null,\n   155→      acResults: null,\n   156→    };\n   157→  }\n   158→\n   159→  // Recompute sprint counts\n   160→  const updatedSprint = computeSprintCounts(updatedStories);\n   161→\n   162→  // AC #8: Write atomically\n   163→  return writeStateAtomic({\n   164→    ...current,\n   165→    sprint: updatedSprint,\n   166→    stories: updatedStories,\n   167→  });\n   168→}\n   169→"}]},"parent_tool_use_id":"toolu_01KBt1xzNkF45pjf2bZesegY","session_id":"0deb1693-f450-4ee3-ba9f-130c7ba0aec5","uuid":"a3fa80ed-92a4-46d8-9c47-02dd01180051","timestamp":"2026-03-20T09:21:33.329Z"}
