{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SB8jsR8vgtjWTQLXrneG7y","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n2\t\n3\t// --- Hoisted mocks ---\n4\tconst { readWorkflowStateMock } = vi.hoisted(() => ({\n5\t  readWorkflowStateMock: vi.fn(),\n6\t}));\n7\t\n8\tvi.mock('../../../lib/state.js', () => ({\n9\t  readState: vi.fn(() => ({\n10\t    harness_version: '0.0.0-dev',\n11\t    initialized: true,\n12\t    stack: 'nodejs',\n13\t    stacks: ['nodejs'],\n14\t    enforcement: { frontend: true, database: true, api: true },\n15\t    coverage: { target: 90, baseline: null, current: null, tool: 'c8' },\n16\t    session_flags: { logs_queried: false, tests_passed: false, coverage_met: false, verification_run: false },\n17\t    verification_log: [],\n18\t    otlp: { enabled: false, endpoint: '', service_name: 'test', mode: 'local-shared', backend: 'none' },\n19\t  })),\n20\t  StateFileNotFoundError: class extends Error {\n21\t    constructor() { super('No state file found.'); this.name = 'StateFileNotFoundError'; }\n22\t  },\n23\t}));\n24\t\n25\tvi.mock('../../../lib/docker/index.js', () => ({\n26\t  getStackHealth: vi.fn(() => ({ healthy: true, services: [], remedy: undefined })),\n27\t  getCollectorHealth: vi.fn(() => ({ healthy: true, services: [], remedy: undefined })),\n28\t  checkRemoteEndpoint: vi.fn(async () => ({ reachable: true })),\n29\t}));\n30\t\n31\tvi.mock('../../../lib/stack-path.js', () => ({\n32\t  getStackDir: vi.fn(() => '/mock/.codeharness/stack'),\n33\t  getComposeFilePath: vi.fn(() => '/mock/.codeharness/stack/docker-compose.harness.yml'),\n34\t  getElkComposeFilePath: vi.fn(() => '/mock/.codeharness/stack/docker-compose.elk.yml'),\n35\t}));\n36\t\n37\tvi.mock('../../../lib/onboard-checks.js', () => ({\n38\t  getOnboardingProgress: vi.fn(() => null),\n39\t}));\n40\t\n41\tvi.mock('../../sprint/index.js', () => ({\n42\t  generateReport: vi.fn(() => ({ success: false })),\n43\t}));\n44\t\n45\tvi.mock('../../verify/index.js', () => ({\n46\t  getValidationProgress: vi.fn(() => ({ success: false })),\n47\t}));\n48\t\n49\tvi.mock('../../../lib/workflow-state.js', () => ({\n50\t  readWorkflowState: (...args: unknown[]) => readWorkflowStateMock(...args),\n51\t}));\n52\t\n53\timport { handleFullStatus, formatElapsed } from '../formatters.js';\n54\timport type { WorkflowState } from '../../../lib/workflow-state.js';\n55\t\n56\tfunction makeDefaultState(): WorkflowState {\n57\t  return {\n58\t    workflow_name: '',\n59\t    started: '',\n60\t    iteration: 0,\n61\t    phase: 'idle',\n62\t    tasks_completed: [],\n63\t    evaluator_scores: [],\n64\t    circuit_breaker: { triggered: false, reason: null, score_history: [] },\n65\t    trace_ids: [],\n66\t  };\n67\t}\n68\t\n69\tfunction makeActiveState(overrides?: Partial<WorkflowState>): WorkflowState {\n70\t  return {\n71\t    workflow_name: 'implement -> verify',\n72\t    started: new Date(Date.now() - 3600000).toISOString(), // 1 hour ago\n73\t    iteration: 2,\n74\t    phase: 'executing',\n75\t    tasks_completed: [\n76\t      { task_name: 'implement', story_key: '5-1-story', completed_at: new Date().toISOString() },\n77\t      { task_name: 'verify', story_key: '__run__', completed_at: new Date().toISOString() },\n78\t    ],\n79\t    evaluator_scores: [\n80\t      { iteration: 1, passed: 3, failed: 1, unknown: 0, total: 4, timestamp: new Date().toISOString() },\n81\t    ],\n82\t    circuit_breaker: { triggered: false, reason: null, score_history: [] },\n83\t    trace_ids: [],\n84\t    ...overrides,\n85\t  };\n86\t}\n87\t\n88\tlet consoleSpy: ReturnType<typeof vi.spyOn>;\n89\t\n90\tbeforeEach(() => {\n91\t  vi.clearAllMocks();\n92\t  consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n93\t  process.exitCode = undefined;\n94\t});\n95\t\n96\tafterEach(() => {\n97\t  consoleSpy.mockRestore();\n98\t  process.exitCode = undefined;\n99\t});\n100\t\n101\tfunction getLogOutput(): string {\n102\t  return consoleSpy.mock.calls.map((c: unknown[]) => String(c[0])).join('\\n');\n103\t}\n104\t\n105\t// --- formatElapsed tests ---\n106\t\n107\tdescribe('formatElapsed', () => {\n108\t  it('formats seconds only', () => {\n109\t    expect(formatElapsed(5000)).toBe('5s');\n110\t  });\n111\t\n112\t  it('formats minutes and seconds', () => {\n113\t    expect(formatElapsed(195000)).toBe('3m15s');\n114\t  });\n115\t\n116\t  it('formats hours and minutes', () => {\n117\t    expect(formatElapsed(8040000)).toBe('2h14m');\n118\t  });\n119\t\n120\t  it('formats zero', () => {\n121\t    expect(formatElapsed(0)).toBe('0s');\n122\t  });\n123\t});\n124\t\n125\t// --- printWorkflowState tests (via handleFullStatus) ---\n126\t\n127\tdescribe('handleFullStatus — workflow engine section', () => {\n128\t  it('displays \"No active workflow run\" when no state exists', () => {\n129\t    readWorkflowStateMock.mockReturnValue(makeDefaultState());\n130\t    handleFullStatus(false);\n131\t\n132\t    const output = getLogOutput();\n133\t    expect(output).toContain('No active workflow run');\n134\t  });\n135\t\n136\t  it('displays workflow state fields when executing', () => {\n137\t    readWorkflowStateMock.mockReturnValue(makeActiveState());\n138\t    handleFullStatus(false);\n139\t\n140\t    const output = getLogOutput();\n141\t    expect(output).toContain('Workflow Engine');\n142\t    expect(output).toContain('Phase: executing');\n143\t    expect(output).toContain('Iteration: 2');\n144\t    expect(output).toContain('Tasks completed: 2');\n145\t    expect(output).toContain('Elapsed:');\n146\t    expect(output).toContain('Evaluator: 3/4 passed');\n147\t    expect(output).toContain('Circuit breaker: no');\n148\t  });\n149\t\n150\t  it('displays circuit breaker triggered state with reason', () => {\n151\t    readWorkflowStateMock.mockReturnValue(makeActiveState({\n152\t      phase: 'circuit-breaker',\n153\t      circuit_breaker: { triggered: true, reason: 'Score plateau detected', score_history: [50, 50, 50] },\n154\t    }));\n155\t    handleFullStatus(false);\n156\t\n157\t    const output = getLogOutput();\n158\t    expect(output).toContain('Circuit breaker: TRIGGERED');\n159\t    expect(output).toContain('Score plateau detected');\n160\t  });\n161\t\n162\t  it('does not show elapsed time when phase is not executing', () => {\n163\t    readWorkflowStateMock.mockReturnValue(makeActiveState({ phase: 'completed' }));\n164\t    handleFullStatus(false);\n165\t\n166\t    const output = getLogOutput();\n167\t    expect(output).toContain('Phase: completed');\n168\t    expect(output).not.toContain('Elapsed:');\n169\t  });\n170\t});\n171\t\n172\t// --- handleFullStatusJson — workflow state in JSON ---\n173\t\n174\tdescribe('handleFullStatusJson — workflow state', () => {\n175\t  it('includes workflow field in JSON when state is active', () => {\n176\t    readWorkflowStateMock.mockReturnValue(makeActiveState());\n177\t    handleFullStatus(true);\n178\t\n179\t    const jsonCall = consoleSpy.mock.calls[0]?.[0];\n180\t    expect(jsonCall).toBeDefined();\n181\t    const parsed = JSON.parse(String(jsonCall));\n182\t    expect(parsed.workflow).toBeDefined();\n183\t    expect(parsed.workflow.phase).toBe('executing');\n184\t    expect(parsed.workflow.iteration).toBe(2);\n185\t    expect(parsed.workflow.tasks_completed).toBe(2);\n186\t    expect(parsed.workflow.workflow_name).toBe('implement -> verify');\n187\t    expect(parsed.workflow.evaluator_scores).toHaveLength(1);\n188\t    expect(parsed.workflow.circuit_breaker.triggered).toBe(false);\n189\t    expect(parsed.workflow.elapsed_ms).toBeGreaterThan(0);\n190\t    expect(parsed.workflow.elapsed).toBeDefined();\n191\t  });\n192\t\n193\t  it('omits workflow field in JSON when no active run', () => {\n194\t    readWorkflowStateMock.mockReturnValue(makeDefaultState());\n195\t    handleFullStatus(true);\n196\t\n197\t    const jsonCall = consoleSpy.mock.calls[0]?.[0];\n198\t    const parsed = JSON.parse(String(jsonCall));\n199\t    expect(parsed.workflow).toBeUndefined();\n200\t  });\n201\t});\n202\t"}]},"parent_tool_use_id":"toolu_01FkgyC9DWuTXJxpDeAr6BwS","session_id":"452c48b4-eed2-4c96-83e9-8c71df0bbdac","uuid":"078fbd19-8c4b-4bc2-8719-52bb65e9230e","timestamp":"2026-04-02T23:24:28.329Z"}
