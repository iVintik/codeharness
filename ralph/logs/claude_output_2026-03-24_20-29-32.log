int state and stories on polling interval tick', async () => {\n   723→      vi.useFakeTimers({ shouldAdvanceTime: true });\n   724→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   725→      mockPaths({ '.claude': true });\n   726→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   727→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   728→\n   729→      getSprintStateMock.mockReturnValue({\n   730→        success: true,\n   731→        data: {\n   732→          sprint: { total: 5, done: 2, failed: 0, blocked: 0, inProgress: '1-1-story' },\n   733→          run: { currentStory: '1-1-story', currentPhase: 'dev', active: true },\n   734→          stories: {},\n   735→          actionItems: [],\n   736→        },\n   737→      });\n   738→\n   739→      const p = runCommand();\n   740→      await vi.waitFor(() => expect(mockDriverInstance.spawn).toHaveBeenCalled());\n   741→\n   742→      rendererUpdateSprintStateMock.mockClear();\n   743→      rendererUpdateStoriesMock.mockClear();\n   744→\n   745→      vi.advanceTimersByTime(5_000);\n   746→\n   747→      expect(rendererUpdateSprintStateMock).toHaveBeenCalledTimes(1);\n   748→      expect(rendererUpdateSprintStateMock).toHaveBeenCalledWith(expect.objectContaining({\n   749→        elapsed: expect.stringMatching(/^\\d+m$|^\\d+h\\d+m$/),\n   750→      }));\n   751→      expect(rendererUpdateStoriesMock).toHaveBeenCalledTimes(1);\n   752→\n   753→      mockDriverInstance._getChildOnHandlers()['close'](0);\n   754→      await p;\n   755→\n   756→      vi.useRealTimers();\n   757→    });\n   758→  });\n   759→\n   760→  describe('result event extraction', () => {\n   761→    it('result events are parsed and fed to renderer', async () => {\n   762→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   763→      mockPaths({ '.claude': true });\n   764→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   765→      vi.spyOn(console, 'log').mockImple