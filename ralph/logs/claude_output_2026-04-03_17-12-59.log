{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_014SetvbXRm58rq4WEGWMTee","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_016mzXpYRoT8mmVyr9c8XXYV","name":"Read","input":{"file_path":"/Users/ivintik/dev/personal/codeharness/src/lib/agents/drivers/claude-code.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1791,"cache_read_input_tokens":42387,"cache_creation":{"ephemeral_5m_input_tokens":1791,"ephemeral_1h_input_tokens":0},"output_tokens":71,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01FEeigjd5nRWkRCota9R2KA","session_id":"cf16e575-8267-4c58-a992-20b07458710f","uuid":"243b8f07-9d6a-4650-8cf5-d715cc594154"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016mzXpYRoT8mmVyr9c8XXYV","type":"tool_result","content":"1\t/**\n2\t * Claude Code Driver — in-process driver using the Agent SDK.\n3\t *\n4\t * Unlike CLI-wrapped drivers (Codex, OpenCode), this driver calls the\n5\t * Agent SDK `query()` function directly. No process spawning needed.\n6\t *\n7\t * @see architecture-multi-framework.md — Decision 1: Driver Interface Design\n8\t * @see architecture-multi-framework.md — Decision 2: CLI-Wrapping Strategy (in-process variant)\n9\t */\n10\t\n11\timport { query } from '@anthropic-ai/claude-agent-sdk';\n12\timport type {\n13\t  AgentDriver,\n14\t  DispatchOpts,\n15\t  DriverHealth,\n16\t  DriverCapabilities,\n17\t  ErrorCategory,\n18\t} from '../types.js';\n19\timport type { StreamEvent, ResultEvent } from '../stream-parser.js';\n20\t\n21\t// --- Error Classification ---\n22\t\n23\tconst NETWORK_CODES = new Set([\n24\t  'ECONNREFUSED',\n25\t  'ETIMEDOUT',\n26\t  'ENOTFOUND',\n27\t  'ENETUNREACH',\n28\t  'ECONNRESET',\n29\t  'EPIPE',\n30\t]);\n31\t\n32\t/**\n33\t * Classify an error into a standard ErrorCategory.\n34\t *\n35\t * Priority order:\n36\t * 1. HTTP 429 or \"rate limit\" -> RATE_LIMIT\n37\t * 2. Known network error codes -> NETWORK\n38\t * 3. HTTP 401/403 or \"unauthorized\"/\"forbidden\" -> AUTH\n39\t * 4. Timeout -> TIMEOUT\n40\t * 5. Everything else -> UNKNOWN\n41\t */\n42\tfunction classifyError(err: unknown): ErrorCategory {\n43\t  const message = err instanceof Error ? err.message : String(err);\n44\t  const code = (err as { code?: string })?.code;\n45\t  const status = (err as { status?: number })?.status;\n46\t\n47\t  // Rate limit: HTTP 429 or message containing \"rate limit\"\n48\t  if (status === 429 || /rate.?limit/i.test(message)) {\n49\t    return 'RATE_LIMIT';\n50\t  }\n51\t\n52\t  // Network errors: known error codes\n53\t  if (code && NETWORK_CODES.has(code)) {\n54\t    return 'NETWORK';\n55\t  }\n56\t  if (/fetch|network|dns/i.test(message) && /fail|error|timeout/i.test(message)) {\n57\t    return 'NETWORK';\n58\t  }\n59\t\n60\t  // Auth errors: HTTP 401/403 or auth-related messages\n61\t  if (status === 401 || status === 403 || /unauthorized|forbidden/i.test(message)) {\n62\t    return 'AUTH';\n63\t  }\n64\t\n65\t  // Timeout: AbortError or timeout-related messages\n66\t  if (\n67\t    (err instanceof Error && err.name === 'AbortError') ||\n68\t    /timeout|timed.?out|aborted/i.test(message)\n69\t  ) {\n70\t    return 'TIMEOUT';\n71\t  }\n72\t\n73\t  return 'UNKNOWN';\n74\t}\n75\t\n76\t// --- SDK Message to StreamEvent mapping ---\n77\t\n78\t/**\n79\t * Map an SDK message object to a StreamEvent, or return null if unrecognized.\n80\t */\n81\tfunction mapSdkMessage(message: Record<string, unknown>): StreamEvent | null {\n82\t  const type = message.type as string | undefined;\n83\t\n84\t  if (type === 'stream_event') {\n85\t    const event = message.event as Record<string, unknown> | undefined;\n86\t    if (!event || typeof event !== 'object') return null;\n87\t\n88\t    const eventType = event.type as string | undefined;\n89\t\n90\t    if (eventType === 'content_block_start') {\n91\t      const contentBlock = event.content_block as Record<string, unknown> | undefined;\n92\t      if (contentBlock?.type === 'tool_use') {\n93\t        const name = contentBlock.name;\n94\t        const id = contentBlock.id;\n95\t        if (typeof name === 'string' && typeof id === 'string') {\n96\t          return { type: 'tool-start', name, id };\n97\t        }\n98\t      }\n99\t      return null;\n100\t    }\n101\t\n102\t    if (eventType === 'content_block_delta') {\n103\t      const delta = event.delta as Record<string, unknown> | undefined;\n104\t      if (!delta) return null;\n105\t\n106\t      if (delta.type === 'input_json_delta') {\n107\t        const partialJson = delta.partial_json;\n108\t        if (typeof partialJson === 'string') {\n109\t          return { type: 'tool-input', partial: partialJson };\n110\t        }\n111\t        return null;\n112\t      }\n113\t\n114\t      if (delta.type === 'text_delta') {\n115\t        const text = delta.text;\n116\t        if (typeof text === 'string') {\n117\t          return { type: 'text', text };\n118\t        }\n119\t        return null;\n120\t      }\n121\t\n122\t      return null;\n123\t    }\n124\t\n125\t    if (eventType === 'content_block_stop') {\n126\t      return { type: 'tool-complete' };\n127\t    }\n128\t\n129\t    return null;\n130\t  }\n131\t\n132\t  if (type === 'system') {\n133\t    const subtype = message.subtype as string | undefined;\n134\t    if (subtype === 'api_retry') {\n135\t      const attempt = message.attempt;\n136\t      const delay = message.retry_delay_ms;\n137\t      if (typeof attempt === 'number' && typeof delay === 'number') {\n138\t        return { type: 'retry', attempt, delay };\n139\t      }\n140\t    }\n141\t    return null;\n142\t  }\n143\t\n144\t  // 'result' type is handled separately in dispatch() to capture cost\n145\t  return null;\n146\t}\n147\t\n148\t// --- Driver Implementation ---\n149\t\n150\t/**\n151\t * ClaudeCodeDriver — in-process AgentDriver using the Agent SDK query() API.\n152\t *\n153\t * This driver is always available (in-process dependency). Auth is checked\n154\t * lazily on first API call, not eagerly.\n155\t */\n156\texport class ClaudeCodeDriver implements AgentDriver {\n157\t  readonly name = 'claude-code' as const;\n158\t  readonly defaultModel = 'claude-sonnet-4-20250514' as const;\n159\t  readonly capabilities: DriverCapabilities = {\n160\t    supportsPlugins: true,\n161\t    supportsStreaming: true,\n162\t    costReporting: true,\n163\t  };\n164\t\n165\t  private lastCost: number | null = null;\n166\t\n167\t  async healthCheck(): Promise<DriverHealth> {\n168\t    return { available: true, authenticated: true, version: null };\n169\t  }\n170\t\n171\t  async *dispatch(opts: DispatchOpts): AsyncGenerator<StreamEvent> {\n172\t    this.lastCost = null;\n173\t\n174\t    // Build query options\n175\t    const queryOptions: Record<string, unknown> = {\n176\t      model: opts.model,\n177\t      cwd: opts.cwd,\n178\t      permissionMode: opts.sourceAccess ? 'bypassPermissions' : 'default',\n179\t      ...(opts.sourceAccess ? { allowDangerouslySkipPermissions: true } : {}),\n180\t      ...(opts.sessionId ? { resume: opts.sessionId } : {}),\n181\t      ...(opts.appendSystemPrompt ? { appendSystemPrompt: opts.appendSystemPrompt } : {}),\n182\t    };\n183\t\n184\t    // Plugin pass-through\n185\t    if (opts.plugins && opts.plugins.length > 0) {\n186\t      queryOptions.plugins = [...opts.plugins];\n187\t    }\n188\t\n189\t    // Timeout handling via AbortController\n190\t    let abortController: AbortController | undefined;\n191\t    let timeoutId: ReturnType<typeof setTimeout> | undefined;\n192\t\n193\t    if (opts.timeout) {\n194\t      abortController = new AbortController();\n195\t      timeoutId = setTimeout(() => {\n196\t        abortController!.abort();\n197\t      }, opts.timeout);\n198\t    }\n199\t\n200\t    let yieldedResult = false;\n201\t\n202\t    try {\n203\t      const queryGenerator = query({\n204\t        prompt: opts.prompt,\n205\t        options: queryOptions,\n206\t        ...(abortController ? { abortController } : {}),\n207\t      });\n208\t\n209\t      for await (const message of queryGenerator) {\n210\t        const msg = message as Record<string, unknown>;\n211\t\n212\t        // Handle result message specially to capture cost\n213\t        if (msg.type === 'result') {\n214\t          const costUsd = msg.total_cost_usd;\n215\t          const sessionId = msg.session_id;\n216\t\n217\t          if (typeof costUsd === 'number') {\n218\t            this.lastCost = costUsd;\n219\t          }\n220\t\n221\t          const resultEvent: ResultEvent = {\n222\t            type: 'result',\n223\t            cost: typeof costUsd === 'number' ? costUsd : 0,\n224\t            sessionId: typeof sessionId === 'string' ? sessionId : '',\n225\t            cost_usd: typeof costUsd === 'number' ? costUsd : null,\n226\t          };\n227\t          yield resultEvent;\n228\t          yieldedResult = true;\n229\t          continue;\n230\t        }\n231\t\n232\t        // Map other SDK messages to StreamEvents\n233\t        const streamEvent = mapSdkMessage(msg);\n234\t        if (streamEvent) {\n235\t          yield streamEvent;\n236\t        }\n237\t      }\n238\t    } catch (err: unknown) {\n239\t      const category = classifyError(err);\n240\t      const errorMessage = err instanceof Error ? err.message : String(err);\n241\t\n242\t      // If abort was triggered by our timeout, classify as TIMEOUT\n243\t      const finalCategory =\n244\t        abortController?.signal.aborted && category !== 'RATE_LIMIT'\n245\t          ? 'TIMEOUT'\n246\t          : category;\n247\t\n248\t      const resultEvent: ResultEvent = {\n249\t        type: 'result',\n250\t        cost: this.lastCost ?? 0,\n251\t        sessionId: '',\n252\t        cost_usd: this.lastCost,\n253\t      };\n254\t\n255\t      yield {\n256\t        ...resultEvent,\n257\t        error: errorMessage,\n258\t        errorCategory: finalCategory,\n259\t      };\n260\t      yieldedResult = true;\n261\t    } finally {\n262\t      if (timeoutId) {\n263\t        clearTimeout(timeoutId);\n264\t      }\n265\t    }\n266\t\n267\t    // Guarantee a result event is always yielded\n268\t    if (!yieldedResult) {\n269\t      yield {\n270\t        type: 'result',\n271\t        cost: this.lastCost ?? 0,\n272\t        sessionId: '',\n273\t        cost_usd: this.lastCost,\n274\t      } as ResultEvent;\n275\t    }\n276\t  }\n277\t\n278\t  getLastCost(): number | null {\n279\t    return this.lastCost;\n280\t  }\n281\t}\n282\t"}]},"parent_tool_use_id":"toolu_01FEeigjd5nRWkRCota9R2KA","session_id":"cf16e575-8267-4c58-a992-20b07458710f","uuid":"a03ac2d5-6f59-4b62-981b-06dafb6f1620","timestamp":"2026-04-03T13:14:58.003Z"}
