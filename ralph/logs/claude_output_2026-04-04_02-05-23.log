{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HGw2Ky1Mz54kZepZqAGZJF","type":"tool_result","content":"1\t/**\n2\t * Null Task Handler Registry.\n3\t *\n4\t * Provides a registry pattern for tasks with `agent: null` that execute\n5\t * directly in the engine without LLM dispatch. Handlers are registered at\n6\t * module initialization time. The engine calls `getNullTask(name)` to look\n7\t * up a handler and execute it inline.\n8\t *\n9\t * @see Story 16-2: Engine-Handled Null Tasks\n10\t */\n11\t\n12\timport type { OutputContract } from './agents/types.js';\n13\timport { writeTelemetryEntry } from './telemetry-writer.js';\n14\t\n15\t// --- Interfaces ---\n16\t\n17\t/**\n18\t * Context passed to a null task handler.\n19\t */\n20\texport interface TaskContext {\n21\t  /** Story key (e.g., \"16-2-engine-handled-null-tasks\") or \"__run__\" for per-run. */\n22\t  storyKey: string;\n23\t  /** Task name (e.g., \"telemetry\"). */\n24\t  taskName: string;\n25\t  /** Accumulated cost from previous tasks (USD). */\n26\t  cost: number;\n27\t  /** Elapsed time since workflow start (ms). */\n28\t  durationMs: number;\n29\t  /** Previous task's output contract, or null if first task. */\n30\t  outputContract: OutputContract | null;\n31\t  /** Project root directory. */\n32\t  projectDir: string;\n33\t}\n34\t\n35\t/**\n36\t * Result returned by a null task handler.\n37\t */\n38\texport interface NullTaskResult {\n39\t  /** Whether the handler completed successfully. */\n40\t  success: boolean;\n41\t  /** Optional text output for logging. */\n42\t  output?: string;\n43\t}\n44\t\n45\t/**\n46\t * A null task handler function.\n47\t */\n48\texport type NullTaskHandler = (ctx: TaskContext) => Promise<NullTaskResult>;\n49\t\n50\t// --- Registry ---"}]},"parent_tool_use_id":"toolu_0175npHDGRfVyrbCzjafE5Mk","session_id":"22206bba-5847-41b1-b510-883e1dd8c0da","uuid":"46d7f87b-4a30-4143-a90a-0eb343e04364","timestamp":"2026-04-03T22:13:46.645Z"}
