{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016R91gnakcqGnwK95aHwky7","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach } from 'vitest';\n2\t\n3\t// --- Mock the Agent SDK ---\n4\t\n5\tconst { mockQuery } = vi.hoisted(() => ({\n6\t  mockQuery: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock('@anthropic-ai/claude-agent-sdk', () => ({\n10\t  query: mockQuery,\n11\t}));\n12\t\n13\timport { ClaudeCodeDriver } from '../drivers/claude-code.js';\n14\timport type { DispatchOpts } from '../types.js';\n15\timport type { StreamEvent, ResultEvent } from '../stream-parser.js';\n16\t\n17\t// --- Helpers ---\n18\t\n19\tfunction makeOpts(overrides?: Partial<DispatchOpts>): DispatchOpts {\n20\t  return {\n21\t    prompt: 'Do the thing',\n22\t    model: 'claude-sonnet-4-20250514',\n23\t    cwd: '/tmp/test',\n24\t    sourceAccess: true,\n25\t    ...overrides,\n26\t  };\n27\t}\n28\t\n29\t/**\n30\t * Create an async generator that yields the given messages.\n31\t */\n32\tasync function* fakeStream(messages: Array<Record<string, unknown>>) {\n33\t  for (const msg of messages) {\n34\t    yield msg;\n35\t  }\n36\t}\n37\t\n38\tfunction makeResultMessage(overrides?: Record<string, unknown>) {\n39\t  return {\n40\t    type: 'result',\n41\t    subtype: 'success',\n42\t    result: 'Agent completed the task.',\n43\t    session_id: 'sess-abc-123',\n44\t    total_cost_usd: 0.05,\n45\t    ...overrides,\n46\t  };\n47\t}\n48\t\n49\t/**\n50\t * Collect all events from an AsyncIterable.\n51\t */\n52\tasync function collectEvents(iterable: AsyncIterable<StreamEvent>): Promise<StreamEvent[]> {\n53\t  const events: StreamEvent[] = [];\n54\t  for await (const event of iterable) {\n55\t    events.push(event);\n56\t  }\n57\t  return events;\n58\t}\n59\t\n60\t// --- Tests ---"}]},"parent_tool_use_id":"toolu_01RMnci4JBW5N3n4PYpHDPEs","session_id":"576f74f4-0d7f-4316-a569-4c3ab5c122fd","uuid":"2a151e54-1a30-4ae7-a6d9-12dad0102dd2","timestamp":"2026-04-03T08:51:14.2