{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ThmQqcocJrH75e6Qew4AZf","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n     2→import { mkdtempSync, rmSync, writeFileSync, existsSync } from 'node:fs';\n     3→import { tmpdir } from 'node:os';\n     4→import { join } from 'node:path';\n     5→\n     6→// Mock all lib modules\n     7→vi.mock('../../../lib/stack-detect.js', async (importOriginal) => {\n     8→  const orig = await importOriginal<typeof import('../../../lib/stack-detect.js')>();\n     9→  return { ...orig, detectStack: vi.fn(orig.detectStack), detectAppType: vi.fn(orig.detectAppType) };\n    10→});\n    11→\n    12→vi.mock('../../../lib/stack-path.js', () => ({\n    13→  getComposeFilePath: vi.fn(() => '/mock/.codeharness/stack/docker-compose.harness.yml'),\n    14→  ensureStackDir: vi.fn(),\n    15→}));\n    16→\n    17→vi.mock('../../../lib/docker.js', () => ({\n    18→  isDockerAvailable: vi.fn(() => true),\n    19→  isSharedStackRunning: vi.fn(() => false),\n    20→  startSharedStack: vi.fn(() => ({\n    21→    started: true,\n    22→    services: [{ name: 'otel-collector', status: 'running', port: '4317,4318' }],\n    23→  })),\n    24→  startCollectorOnly: vi.fn(() => ({\n    25→    started: true,\n    26→    services: [{ name: 'otel-collector', status: 'running', port: '4317,4318' }],\n    27→  })),\n    28→}));\n    29→\n    30→vi.mock('../../../lib/deps.js', () => ({\n    31→  installAllDependencies: vi.fn(() => [\n    32→    { name: 'showboat', displayName: 'Showboat', status: 'already-installed', version: '0.6.1' },\n    33→  ]),\n    34→  checkInstalled: vi.fn(() => ({ installed: true, version: '1.0.0' })),\n    35→  DEPENDENCY_REGISTRY: [\n    36→    {\n    37→      name: 'showboat',\n    38→      displayName: 'Showboat',\n    39→      installCommands: [{ cmd: 'pip', args: ['install', 'showboat'] }],\n    40→      checkCommand: { cmd: 'showboat', arg