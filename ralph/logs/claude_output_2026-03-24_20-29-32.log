{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ASVxUr27FhwBW4hwmmnEwr","type":"tool_result","content":"     1→/**\n     2→ * Stream Event Parser — converts Claude stream-json NDJSON lines into typed events.\n     3→ *\n     4→ * Stateless per-line: accepts one NDJSON line, returns one typed event or null.\n     5→ * Accumulation (e.g., building full tool input from deltas) is the caller's responsibility.\n     6→ *\n     7→ * Event format reference:\n     8→ * - Wrapper type \"stream_event\" contains API events (content_block_start, etc.)\n     9→ * - Wrapper type \"system\" contains Claude Code events (api_retry, etc.)\n    10→ * - Wrapper type \"result\" is the final event with session_id, cost, result text\n    11→ */\n    12→\n    13→// --- Event Types ---\n    14→\n    15→export interface ToolStartEvent {\n    16→  readonly type: 'tool-start';\n    17→  readonly name: string;\n    18→  readonly id: string;\n    19→}\n    20→\n    21→export interface ToolInputEvent {\n    22→  readonly type: 'tool-input';\n    23→  readonly partial: string;\n    24→}\n    25→\n    26→export interface ToolCompleteEvent {\n    27→  readonly type: 'tool-complete';\n    28→}\n    29→\n    30→export interface TextEvent {\n    31→  readonly type: 'text';\n    32→  readonly text: string;\n    33→}\n    34→\n    35→export interface RetryEvent {\n    36→  readonly type: 'retry';\n    37→  readonly attempt: number;\n    38→  readonly delay: number;\n    39→}\n    40→\n    41→export interface ResultEvent {\n    42→  readonly type: 'result';\n    43→  readonly cost: number;\n    44→  readonly sessionId: string;\n    45→}\n    46→\n    47→/** Discriminated union of all stream events the parser can emit. */\n    48→export type StreamEvent =\n    49→  | ToolStartEvent\n    50→  | ToolInputEvent\n    51→  | ToolCompleteEvent\n    52→  | TextEvent\n    53→  | RetryEvent\n    54→  | ResultEvent;\n    55→\n    56→// --- Parser ---\n    57→\n    58→/**\n    59→ * Parse a single NDJSON line from Claude's stream-json output.\n    60→ *\n    61→ * Returns a typed StreamEvent for recognized events, or null for:\n    62→ * - Invalid JSON\n    63→ * - Empty/whitespace lines\n    64→ * - Unrecognized or irrelevant event types (message_start, message_stop, etc.)\n    65→ */\n    66→export function parseStreamLine(line: string): StreamEvent | null {\n    67→  const trimmed = line.trim();\n    68→  if (trimmed.length === 0) {\n    69→    return null;\n    70→  }\n    71→\n    72→  let parsed: Record<string, unknown>;\n    73→  try {\n    74→    parsed = JSON.parse(trimmed) as Record<string, unknown>;\n    75→  } catch {\n    76→    return null;\n    77→  }\n    78→\n    79→  if (typeof parsed !== 'object' || parsed === null || Array.isArray(parsed)) {\n    80→    return null;\n    81→  }\n    82→\n    83→  const wrapperType = parsed.type;\n    84→\n    85→  if (wrapperType === 'stream_event') {\n    86→    return parseStreamEvent(parsed);\n    87→  }\n    88→\n    89→  if (wrapperType === 'system') {\n    90→    return parseSystemEvent(parsed);\n    91→  }\n    92→\n    93→  if (wrapperType === 'result') {\n    94→    return parseResultEvent(parsed);\n    95→  }\n    96→\n    97→  return null;\n    98→}\n    99→\n   100→// --- Internal Parsers ---\n   101→\n   102→function parseStreamEvent(parsed: Record<string, unknown>): StreamEvent | null {\n   103→  const event = parsed.event as Record<string, unknown> | undefined;\n   104→  if (!event || typeof event !== 'object') {\n   105→    return null;\n   106→  }\n   107→\n   108→  const eventType = event.type as string | undefined;\n   109→\n   110→  if (eventType === 'content_block_start') {\n   111→    return parseContentBlockStart(event);\n   112→  }\n   113→\n   114→  if (eventType === 'content_block_delta') {\n   115→    return parseContentBlockDelta(event);\n   116→  }\n   117→\n   118→  if (eventType === 'content_block_stop') {\n   119→    // NOTE: content_block_stop fires for both tool_use and text blocks.\n   120→    // The parser is stateless and cannot distinguish them. The consumer\n   121→    // (renderer) must track whether the preceding block was a tool_use.\n   122→    return { type: 'tool-complete' };\n   123→  }\n   124→\n   125→  // message_start, message_stop, message_delta — skip\n   126→  return null;\n   127→}\n   128→\n   129→function parseContentBlockStart(event: Record<string, unknown>): StreamEvent | null {\n   130→  const contentBlock = event.content_block as Record<string, unknown> | undefined;\n   131→  if (!contentBlock || typeof contentBlock !== 'object') {\n   132→    return null;\n   133→  }\n   134→\n   135→  if (contentBlock.type === 'tool_use') {\n   136→    const name = contentBlock.name;\n   137→    const id = contentBlock.id;\n   138→    if (typeof name === 'string' && typeof id === 'string') {\n   139→      return { type: 'tool-start', name, id };\n   140→    }\n   141→  }\n   142→\n   143→  // content_block_start with type \"text\" — skip (the actual text comes via deltas)\n   144→  return null;\n   145→}\n   146→\n   147→function parseContentBlockDelta(event: Record<string, unknown>): StreamEvent | null {\n   148→  const delta = event.delta as Record<string, unknown> | undefined;\n   149→  if (!delta || typeof delta !== 'object') {\n   150→    return null;\n   151→  }\n   152→\n   153→  if (delta.type === 'input_json_delta') {\n   154→    const partialJson = delta.partial_json;\n   155→    if (typeof partialJson === 'string') {\n   156→      return { type: 'tool-input', partial: partialJson };\n   157→    }\n   158→    return null;\n   159→  }\n   160→\n   161→  if (delta.type === 'text_delta') {\n   162→    const text = delta.text;\n   163→    if (typeof text === 'string') {\n   164→      return { type: 'text', text };\n   165→    }\n   166→    return null;\n   167→  }\n   168→\n   169→  return null;\n   170→}\n   171→\n   172→function parseSystemEvent(parsed: Record<string, unknown>): StreamEvent | null {\n   173→  const subtype = parsed.subtype as string | undefined;\n   174→  if (subtype === 'api_retry') {\n   175→    const attempt = parsed.attempt;\n   176→    const delay = parsed.retry_delay_ms;\n   177→    if (typeof attempt === 'number' && typeof delay === 'number') {\n   178→      return { type: 'retry', attempt, delay };\n   179→    }\n   180→    return null;\n   181→  }\n   182→\n   183→  return null;\n   184→}\n   185→\n   186→function parseResultEvent(parsed: Record<string, unknown>): StreamEvent | null {\n   187→  const costUsd = parsed.cost_usd;\n   188→  const sessionId = parsed.session_id;\n   189→  if (typeof costUsd === 'number' && typeof sessionId === 'string') {\n   190→    return { type: 'result', cost: costUsd, sessionId };\n   191→  }\n   192→  return null;\n   193→}\n   194→"}]},"parent_tool_use_id":"toolu_01AeYymucNLjmuqL83DiV485","session_id":"a5a043ae-cfd1-4d51-82dd-d0069edc63ef","uuid":"ed1f1324-fbd9-4977-a47b-68b43e13493a","timestamp":"2026-03-24T16:30:36.726Z"}
