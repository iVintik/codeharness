{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01JhdELu4UARLWuhJ4qCx5g4","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01AHPLmSfouAihXADPsywXqt","name":"Write","input":{"file_path":"/Users/ivintik/dev/personal/codeharness/src/schemas/workflow.schema.json","content":"{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"$id\": \"https://codeharness.dev/schemas/workflow.schema.json\",\n  \"title\": \"Codeharness Workflow\",\n  \"description\": \"Schema for codeharness workflow YAML files\",\n  \"type\": \"object\",\n  \"required\": [\"tasks\", \"flow\"],\n  \"properties\": {\n    \"tasks\": {\n      \"type\": \"object\",\n      \"description\": \"Named task definitions\",\n      \"additionalProperties\": {\n        \"$ref\": \"#/definitions/task\"\n      }\n    },\n    \"flow\": {\n      \"type\": \"array\",\n      \"description\": \"Ordered execution steps — task references or loop blocks\",\n      \"items\": {\n        \"oneOf\": [\n          {\n            \"type\": \"string\",\n            \"description\": \"Task reference by name\"\n          },\n          {\n            \"type\": \"object\",\n            \"required\": [\"loop\"],\n            \"properties\": {\n              \"loop\": {\n                \"type\": \"array\",\n                \"items\": {\n                  \"type\": \"string\"\n                },\n                \"minItems\": 1,\n                \"description\": \"Task names to repeat in a loop\"\n              }\n            },\n            \"additionalProperties\": false,\n            \"description\": \"Loop block containing task references\"\n          }\n        ]\n      }\n    }\n  },\n  \"additionalProperties\": false,\n  \"definitions\": {\n    \"task\": {\n      \"type\": \"object\",\n      \"required\": [\"agent\"],\n      \"properties\": {\n        \"agent\": {\n          \"type\": \"string\",\n          \"description\": \"Agent identifier for this task\"\n        },\n        \"scope\": {\n          \"type\": \"string\",\n          \"enum\": [\"per-story\", \"per-run\"],\n          \"default\": \"per-story\",\n          \"description\": \"Execution scope — per-story or per-run\"\n        },\n        \"session\": {\n          \"type\": \"string\",\n          \"enum\": [\"fresh\", \"continue\"],\n          \"default\": \"fresh\",\n          \"description\": \"Session strategy — fresh or continue\"\n        },\n        \"source_access\": {\n          \"type\": \"boolean\",\n          \"default\": true,\n          \"description\": \"Whether the agent has source code access\"\n        },\n        \"prompt_template\": {\n          \"type\": \"string\",\n          \"description\": \"Prompt template with {{variable}} placeholders\"\n        },\n        \"input_contract\": {\n          \"type\": \"object\",\n          \"description\": \"Input contract schema for this task\"\n        },\n        \"output_contract\": {\n          \"type\": \"object\",\n          \"description\": \"Output contract schema for this task\"\n        },\n        \"max_budget_usd\": {\n          \"type\": \"number\",\n          \"description\": \"Maximum budget in USD for this task execution\"\n        }\n      },\n      \"additionalProperties\": false\n    }\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":91,"cache_read_input_tokens":25501,"cache_creation":{"ephemeral_5m_input_tokens":91,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01T5izCnprn3BanMVUeAKGXz","session_id":"c54cfa66-957c-4f2c-a205-da1113d93a9b","uuid":"0bd1ffea-58e1-4ea1-9971-596c798e6454"}
