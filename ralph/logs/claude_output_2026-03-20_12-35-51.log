0→    const lines = formatAuditHuman(result);\n   111→\n   112→    expect(lines.some(l => l.includes('[WARN] Unpinned base image'))).toBe(true);\n   113→    expect(lines.some(l => l.includes('-- fix: Pin to a specific version'))).toBe(true);\n   114→  });\n   115→\n   116→  it('includes summary line with gap count and duration', () => {\n   117→    const result = makeAuditResult({ gapCount: 3, durationMs: 200 });\n   118→    const lines = formatAuditHuman(result);\n   119→\n   120→    const summaryLine = lines.find(l => l.includes('Audit complete'));\n   121→    expect(summaryLine).toBeDefined();\n   122→    expect(summaryLine).toContain('3 gaps');\n   123→    expect(summaryLine).toContain('200ms');\n   124→  });\n   125→\n   126→  it('uses singular \"gap\" for 1 gap', () => {\n   127→    const result = makeAuditResult({ gapCount: 1, durationMs: 100 });\n   128→    const lines = formatAuditHuman(result);\n   129→    const summaryLine = lines.find(l => l.includes('Audit complete'));\n   130→    expect(summaryLine).toContain('1 gap found');\n   131→  });\n   132→});\n   133→\n   134→describe('formatAuditJson', () => {\n   135→  it('returns object matching AuditResult structure', () => {\n   136→    const result = makeAuditResult();\n   137→    const json = formatAuditJson(result);\n   138→\n   139→    expect(json).toHaveProperty('dimensions');\n   140→    expect(json).toHaveProperty('overallStatus', 'pass');\n   141→    expect(json).toHaveProperty('gapCount', 0);\n   142→    expect(json).toHaveProperty('durationMs', 150);\n   143→  });\n   144→\n   145→  it('includes all dimension results in JSON', () => {\n   146→    const result = makeAuditResult();\n   147→    const json = formatAuditJson(result) as { dimensions: Record<string, unknown> };\n   148→\n   149→    expect(Object.keys(json.dimensions)).toHaveLength(5);\n   150→    expect(json.dimensions).toHaveProperty('observability');\n   151→    expect(json.dimensions).toHaveProperty('testing');\n   152→    expect(json.dimensions).toHaveProperty('documentation');\n   153→    expect(json.dimensions).toHaveProperty('verification');\n   154→    expect(json.dimensions).toHaveProperty('infrastructure');\n   155→  });\n   156→\n   157→  it('includes gaps array in each dimension', () => {\n   158→    const result = makeAuditResult({\n   159→      dimensions: {\n   160→        ...makeAuditResult().dimensions,\n   161→        testing: {\n   162→          name: 'testing',\n   163→          status: 'fail',\n   164→          metric: '30%',\n   165→          gaps: [{ dimension: 'testing', description: 'Low coverage', suggestedFix: 'Add tests' }],\n   166→        },\n   167→      },\n   168→      overallStatus: 'fail',\n   169→      gapCount: 1,\n   170→    });\n   171→    const json = formatAuditJson(result) as {\n   172→      dimensions: Record<string, { status: string; metric: string; gaps: unknown[] }>;\n   173→    };\n   174→\n   175→    expect(json.dimensions.testing.status).toBe('fail');\n   176→    expect(json.dimensions.testing.gaps).toHaveLength(1);\n   177→  });\n   178→});\n   179→"}]},"parent_tool_use_id":"toolu_01UmDTVZ4iS72Xuw7ncmN4YZ","session_id":"e1f3df9b-d919-466e-880e-1001c8652ee8","uuid":"2fc15979-9aee-408b-9e9d-fdac4318b696","timestamp":"2026-03-20T08:52:13.610Z"}
