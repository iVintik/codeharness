unrecognized lines', () => {\n   213→      it('returns null for non-matching lines', () => {\n   214→        expect(driver.parseOutput('[INFO] Starting iteration 5')).toBeNull();\n   215→        expect(driver.parseOutput('[DEBUG] some debug info')).toBeNull();\n   216→        expect(driver.parseOutput('')).toBeNull();\n   217→        expect(driver.parseOutput('   ')).toBeNull();\n   218→        expect(driver.parseOutput('random garbage')).toBeNull();\n   219→      });\n   220→\n   221→      it('returns null for [ERROR] without story key', () => {\n   222→        expect(driver.parseOutput('[ERROR] Connection timeout')).toBeNull();\n   223→      });\n   224→    });\n   225→  });\n   226→});\n   227→\n   228→describe('parseRalphMessage (migrated)', () => {\n   229→  it('parses [SUCCESS] Story completion', () => {\n   230→    const msg = parseRalphMessage('[SUCCESS] Story 1-1-foo: DONE — title here');\n   231→    expect(msg).toEqual({\n   232→      type: 'ok',\n   233→      key: '1-1-foo',\n   234→      message: 'DONE — title here',\n   235→    });\n   236→  });\n   237→\n   238→  it('parses [SUCCESS] Story completion without details', () => {\n   239→    const msg = parseRalphMessage('[SUCCESS] Story 2-3-bar: DONE');\n   240→    expect(msg).toEqual({\n   241→      type: 'ok',\n   242→      key: '2-3-bar',\n   243→      message: 'DONE',\n   244→    });\n   245→  });\n   246→\n   247→  it('parses [WARN] retry exceeded', () => {\n   248→    const msg = parseRalphMessage('[WARN] Story 3-2-baz exceeded retry limit');\n   249→    expect(msg).toEqual({\n   250→      type: 'fail',\n   251→      key: '3-2-baz',\n   252→      message: 'exceeded retry limit',\n   253→    });\n   254→  });\n   255→\n   256→  it('parses [WARN] retry N/M', () => {\n   257→    const msg = parseRalphMessage('[WARN] Story 1-1-foo — retry 2/5');\n   258→    expect(msg).toEqual({\n   259→      type: 'warn',\n   260→      key: '1-1-foo',\n   261→      message: 'retry 2/5',\n   262→    });\n   263→  });\n   264→\n   265→  it('returns null for unrecognized lines', () => {\n   266→    expect(parseRalphMessage('')).toBeNull();\n   267→    expect(parseRalphMessage('   ')).toBeNull();\n   268→    expect(parseRalphMessage('[INFO] Starting iteration 5')).toBeNull();\n   269→  });\n   270→});\n   271→\n   272→describe('parseIterationMessage (migrated)', () => {\n   273→  it('parses [LOOP] iteration N', () => {\n   274→    expect(parseIterationMessage('[LOOP] iteration 3')).toBe(3);\n   275→  });\n   276→\n   277→  it('returns null for non-LOOP lines', () => {\n   278→    expect(parseIterationMessage('[SUCCESS] Story 1-1-foo: DONE')).toBeNull();\n   279→    expect(parseIterationMessage('')).toBeNull();\n   280→  });\n   281→});\n   282→\n   283→describe('buildSpawnArgs (migrated)', () => {\n   284→  const baseOpts = {\n   285→    ralphPath: '/path/to/ralph.sh',\n   286→    pluginDir: '/path/to/.claude',\n   287→    promptFile: '/path/to/prompt.md',\n   288→    maxIterations: 50,\n   289→    timeout: 14400,\n   290→    iterationTimeout: 15,\n   291→    calls: 100,\n   292→    quiet: false,\n   293→  };\n   294→\n   295→  it('builds basic argument array', () => {\n   296→    const args = buildSpawnArgs(baseOpts);\n   297→    expect(args).toContain('/path/to/ralph.sh');\n   298→    expect(args).toContain('--plugin-dir');\n   299→    expect(args).toContain('50');\n   300→  });\n   301→\n   302→  it('includes --live flag when not quiet', () => {\n   303→    expect(buildSpawnArgs(baseOpts)).toContain('--live');\n   304→  });\n   305→\n   306→  it('does not include --live flag when quiet', () => {\n   307→    expect(buildSpawnArgs({ ...baseOpts, quiet: true })).not.toContain('--live');\n   308→  });\n   309→\n   310→  it('includes --max-story-retries when provided', () => {\n   311→    const args = buildSpawnArgs({ ...baseOpts, maxStoryRetries: 5 });\n   312→    expect(args).toContain('--max-story-retries');\n   313→    expect(args).toContain('5');\n   314→  });\n   315→\n   316→  i