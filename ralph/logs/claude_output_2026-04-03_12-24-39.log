{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012QPCzXKtAbWRjozvebuyJ4","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach, afterEach } from 'vitest';\n2\timport { mkdtempSync, rmSync, writeFileSync, readFileSync, mkdirSync } from 'node:fs';\n3\timport { tmpdir, homedir } from 'node:os';\n4\timport os from 'node:os';\n5\timport { join } from 'node:path';\n6\timport {\n7\t  parseWorkflow,\n8\t  resolveWorkflow,\n9\t  loadWorkflowPatch,\n10\t  mergeWorkflowPatch,\n11\t  WorkflowParseError,\n12\t  type ResolvedWorkflow,\n13\t  type ResolvedTask,\n14\t  type LoopBlock,\n15\t  type FlowStep,\n16\t  type WorkflowPatch,\n17\t} from '../workflow-parser.js';\n18\timport { registerDriver, resetDrivers } from '../agents/drivers/factory.js';\n19\timport type { AgentDriver } from '../agents/types.js';\n20\t\n21\tlet testDir: string;\n22\t\n23\tbeforeEach(() => {\n24\t  testDir = mkdtempSync(join(tmpdir(), 'ch-wfparser-test-'));\n25\t});\n26\t\n27\tafterEach(() => {\n28\t  rmSync(testDir, { recursive: true, force: true });\n29\t});\n30\t\n31\tfunction writeYaml(filename: string, content: string): string {\n32\t  const filePath = join(testDir, filename);\n33\t  writeFileSync(filePath, content, 'utf-8');\n34\t  return filePath;\n35\t}\n36\t\n37\t// --- Helpers: YAML content ---\n38\t\n39\tconst minimalYaml = `\n40\ttasks:\n41\t  implement:\n42\t    agent: dev\n43\tflow:\n44\t  - implement\n45\t`;\n46\t\n47\tconst fullYaml = `\n48\ttasks:\n49\t  implement:\n50\t    agent: dev\n51\t    scope: per-story\n52\t    session: fresh\n53\t    source_access: true\n54\t    prompt_template: \"Implement story {{story_key}}\"\n55\t    input_contract:\n56\t      type: object\n57\t    output_contract:\n58\t      type: object\n59\t    max_budget_usd: 5.0\n60\t  verify:\n61\t    agent: evaluator\n62\t    scope: per-run\n63\t    session: continue\n64\t    source_access: false\n65\tflow:\n66\t  - implement\n67\t  - verify\n68\t`;\n69\t\n70\tconst loopYaml = `\n71\ttasks:\n72\t  implement:\n73\t    agent: dev\n74\t  verify:\n75\t    agent: evaluator\n76\t  retry:\n77\t    agent: dev\n78\tflow:\n79\t  - implement\n80\t  - verify\n81\t  - loop:\n82\t      - retry\n83\t      - verify\n84\t`;\n85\t\n86\tconst emptyYaml = `\n87\ttasks: {}\n88\tflow: []\n89\t`;\n90\t\n91\t// --- Tests ---\n92\t\n93\tdescribe('parseWorkflow', () => {\n94\t  describe('valid workflows (AC #1)', () => {\n95\t    it('parses a minimal valid workflow and returns ResolvedWorkflow', () => {\n96\t      const filePath = writeYaml('minimal.yaml', minimalYaml);\n97\t      const result = parseWorkflow(filePath);\n98\t\n99\t      expect(result.tasks).toBeDefined();\n100\t      expect(result.flow).toBeDefined();\n101\t      expect(result.tasks.implement).toBeDefined();\n102\t      expect(result.tasks.implement.agent).toBe('dev');\n103\t      expect(result.flow).toEqual(['implement']);\n104\t    });\n105\t\n106\t    it('parses a full workflow with all optional fields (AC #1)', () => {\n107\t      const filePath = writeYaml('full.yaml', fullYaml);\n108\t      const result = parseWorkflow(filePath);\n109\t\n110\t      expect(result.tasks.implement.agent).toBe('dev');\n111\t      expect(result.tasks.implement.scope).toBe('per-story');\n112\t      expect(result.tasks.implement.session).toBe('fresh');\n113\t      expect(result.tasks.implement.source_access).toBe(true);\n114\t      expect(result.tasks.implement.prompt_template).toBe('Implement story {{story_key}}');\n115\t      expect(result.tasks.implement.input_contract).toEqual({ type: 'object' });\n116\t      expect(result.tasks.implement.output_contract).toEqual({ type: 'object' });\n117\t      expect(result.tasks.implement.max_budget_usd).toBe(5.0);\n118\t\n119\t      expect(result.tasks.verify.agent).toBe('evaluator');\n120\t      expect(result.tasks.verify.scope).toBe('per-run');\n121\t      expect(result.tasks.verify.session).toBe('continue');\n122\t      expect(result.tasks.verify.source_access).toBe(false);\n123\t    });\n124\t\n125\t    it('applies defaults when optional fields are omitted (AC #1)', () => {\n126\t      const filePath = writeYaml('defaults.yaml', minimalYaml);\n127\t      const result = parseWorkflow(filePath);\n128\t      const task = result.tasks.implement;\n129\t\n130\t      expect(task.scope).toBe('per-story');\n131\t      expect(task.session).toBe('fresh');\n132\t      expect(task.source_access).toBe(true);\n133\t      expect(task.prompt_template).toBeUndefined();\n134\t      expect(task.input_contract).toBeUndefined();\n135\t      expect(task.output_contract).toBeUndefined();\n136\t      expect(task.max_budget_usd).toBeUndefined();\n137\t    });\n138\t\n139\t    it('parses empty tasks and flow as valid degenerate case', () => {\n140\t      const filePath = writeYaml('empty.yaml', emptyYaml);\n141\t      const result = parseWorkflow(filePath);\n142\t\n143\t      expect(result.tasks).toEqual({});\n144\t      expect(result.flow).toEqual([]);\n145\t    });\n146\t  });\n147\t\n148\t  describe('invalid YAML syntax (AC #2)', () => {\n149\t    it('throws WorkflowParseError for bad YAML', () => {\n150\t      const filePath = writeYaml('bad.yaml', '{{{{not yaml at all');\n151\t\n152\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n153\t      try {\n154\t        parseWorkflow(filePath);\n155\t      } catch (err) {\n156\t        expect(err).toBeInstanceOf(WorkflowParseError);\n157\t        const pe = err as WorkflowParseError;\n158\t        expect(pe.message).toContain('Invalid YAML syntax');\n159\t        expect(pe.errors.length).toBeGreaterThan(0);\n160\t      }\n161\t    });\n162\t\n163\t    it('throws WorkflowParseError for unclosed quotes in YAML', () => {\n164\t      const badYaml = `\n165\ttasks:\n166\t  implement:\n167\t    agent: \"dev\n168\tflow:\n169\t  - implement\n170\t`;\n171\t      const filePath = writeYaml('unclosed.yaml', badYaml);\n172\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n173\t    });\n174\t  });\n175\t\n176\t  describe('schema validation failures (AC #3)', () => {\n177\t    it('throws WorkflowParseError when tasks is missing', () => {\n178\t      const yaml = 'flow:\\n  - implement\\n';\n179\t      const filePath = writeYaml('no-tasks.yaml', yaml);\n180\t\n181\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n182\t      try {\n183\t        parseWorkflow(filePath);\n184\t      } catch (err) {\n185\t        const pe = err as WorkflowParseError;\n186\t        expect(pe.message).toContain('Schema validation failed');\n187\t        expect(pe.errors.length).toBeGreaterThan(0);\n188\t        expect(pe.errors.some((e) => e.message.includes('tasks'))).toBe(true);\n189\t      }\n190\t    });\n191\t\n192\t    it('throws WorkflowParseError for empty file (null YAML)', () => {\n193\t      const filePath = writeYaml('empty-file.yaml', '');\n194\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n195\t      try {\n196\t        parseWorkflow(filePath);\n197\t      } catch (err) {\n198\t        const pe = err as WorkflowParseError;\n199\t        expect(pe.message).toContain('Schema validation failed');\n200\t      }"}]},"parent_tool_use_id":"toolu_01U85MaKaYFD6RV3D181SmSg","session_id":"4b1f7711-6ed7-4488-a0af-b261e761b450","uuid":"ae6593ba-d4bd-4bee-af12-df59b5a52a7e","timestamp":"2026-04-03T08:37:01.947Z"}
