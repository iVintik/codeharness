{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TfodV3kndxrDy6JNFigBt9","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→\n     3→vi.mock('node:fs', () => ({\n     4→  readFileSync: vi.fn(),\n     5→  writeFileSync: vi.fn(),\n     6→  renameSync: vi.fn(),\n     7→  existsSync: vi.fn(),\n     8→}));\n     9→\n    10→import { checkObservabilityCoverageGate } from '../coverage-gate.js';\n    11→import {\n    12→  checkObservabilityCoverageGate as barrelGate,\n    13→  type ObservabilityCoverageGateResult,\n    14→} from '../index.js';\n    15→import { readFileSync, existsSync } from 'node:fs';\n    16→\n    17→const mockReadFileSync = vi.mocked(readFileSync);\n    18→const mockExistsSync = vi.mocked(existsSync);\n    19→\n    20→beforeEach(() => {\n    21→  vi.resetAllMocks();\n    22→});\n    23→\n    24→function makeState(obs: Record<string, unknown>): string {\n    25→  return JSON.stringify({\n    26→    version: 1,\n    27→    sprint: { total: 0, done: 0 },\n    28→    observability: obs,\n    29→  });\n    30→}\n    31→\n    32→// ============================================================\n    33→// Module barrel exports\n    34→// ============================================================\n    35→\n    36→describe('module barrel exports', () => {\n    37→  it('re-exports checkObservabilityCoverageGate from index.ts', () => {\n    38→    expect(barrelGate).toBe(checkObservabilityCoverageGate);\n    39→  });\n    40→});\n    41→\n    42→// ============================================================\n    43→// Gate passes\n    44→// ============================================================\n    45→\n    46→describe('checkObservabilityCoverageGate — pass scenarios', () => {\n    47→  it('passes when static >= 80% and runtime >= 60%', () => {\n    48→    mockExistsSync.mockReturnValue(true);\n    49→    mockReadFileSync.mockReturnValue(\n    50→      makeState({\n    51→  