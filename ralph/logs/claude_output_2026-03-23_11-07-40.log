{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017hZA2nCkbHzg97miBpJvHy","type":"tool_result","content":"     1в†’/**\n     2в†’ * Verification environment management: Docker image lifecycle, clean workspace,\n     3в†’ * and environment checks for black-box verification.\n     4в†’ */\n     5в†’import { execFileSync } from 'node:child_process';\n     6в†’import { existsSync, mkdirSync, readdirSync, readFileSync, cpSync, rmSync, statSync } from 'node:fs';\n     7в†’import { join, basename } from 'node:path';\n     8в†’import { createHash } from 'node:crypto';\n     9в†’import { info } from '../../lib/output.js';\n    10в†’import { detectStack } from '../../lib/stack-detect.js';\n    11в†’import { readStateWithBody, writeState } from '../../lib/state.js';\n    12в†’import { isDockerAvailable } from '../../lib/docker.js';\n    13в†’import type { BuildOptions, BuildResult, CheckResult, ProjectType } from './types.js';\n    14в†’\n    15в†’const IMAGE_TAG = 'codeharness-verify';\n    16в†’const STORY_DIR = '_bmad-output/implementation-artifacts';\n    17в†’const TEMP_PREFIX = '/tmp/codeharness-verify-';\n    18в†’const STATE_KEY_DIST_HASH = 'verify_env_dist_hash';\n    19в†’\n    20в†’/** Validates that a story key is safe for file paths and container names. */\n    21в†’export function isValidStoryKey(storyKey: string): boolean {\n    22в†’  if (!storyKey || storyKey.includes('..') || storyKey.includes('/') || storyKey.includes('\\\\')) {\n    23в†’    return false;\n    24в†’  }\n    25в†’  return /^[a-zA-Z0-9_-]+$/.test(storyKey);\n    26в†’}\n    27в†’\n    28в†’/** Computes a SHA-256 hash of all files in dist/ for cache invalidation. */\n    29в†’export function computeDistHash(projectDir: string): string | null {\n    30в†’  const distDir = join(projectDir, 'dist');\n    31в†’  if (!existsSync(distDir)) return null;\n    32в†’  const hash = createHash('sha256');\n    33в†’  const files = collectFiles(distDir).sort();\n    34в†’  for (const file of files) {\n    35в†’    hash.update(file.slice(distDir.length));\n    36в†’    hash.update(readFileSync(file));\n    37в†’  }\n    38в†’  return hash.digest('hex');\n    39в†’}\n    40в†’\n    41в†’function collectFiles(dir: string): string[] {\n    42в†’  const results: string[] = [];\n    43в†’  for (const entry of readdirSync(dir, { withFileTypes: true })) {\n    44в†’    const fullPath = join(dir, entry.name);\n    45в†’    if (entry.isDirectory()) { results.push(...collectFiles(fullPath)); }\n    46в†’    else { results.push(fullPath); }\n    47в†’  }\n    48в†’  return results;\n    49в†’}\n    50в†’\n    51в†’function getStoredDistHash(projectDir: string): string | null {\n    52в†’  try {\n    53в†’    const { state } = readStateWithBody(projectDir);\n    54в†’    return ((state as unknown as Record<string, unknown>)[STATE_KEY_DIST_HASH] as string) ?? null;\n    55в†’  } catch { return null; }\n    56в†’}\n    57в†’\n    58в†’function storeDistHash(projectDir: string, hash: string): void {\n    59в†’  try {\n    60в†’    const { state, body } = readStateWithBody(projectDir);\n    61в†’    (state as unknown as Record<string, unknown>)[STATE_KEY_DIST_HASH] = hash;\n    62в†’    writeState(state, projectDir, body);\n    63в†’  } catch {\n    64в†’    info('Could not persist dist hash to state file вЂ” cache will not be available until state is initialized');\n    65в†’  }\n    66в†’}\n    67в†’\n    68в†’/** Detects the project type for verification strategy selection. */\n    69в†’export function detectProjectType(projectDir: string): ProjectType {\n    70в†’  const stack = detectStack(projectDir);\n    71в†’  // Prefer nodejs/python when the project has a buildable package вЂ” the npm tarball\n    72в†’  // or Python wheel includes all distributable files. Plugin-only detection is the\n    73в†’  // fallback for projects that are purely Claude Code plugins with no build artifact.\n    74в†’  if (stack === 'nodejs') return 'nodejs';\n    75в†’  if (stack === 'python') return 'python';\n    76в†’  if (existsSync(join(projectDir, '.claude-plugin', 'plugin.json'))) return 'plugin';\n    77в†’  return 'generic';\n    78в†’}\n    79в†’\n    80в†’/** Builds the verification Docker image with cache invalidation. */\n    81в†’export function buildVerifyImage(options: BuildOptions = {}): BuildResult {\n    82в†’  const projectDir = options.projectDir ?? process.cwd();\n    83в†’  if (!isDockerAvailable()) {\n    84в†’    throw new Error('Docker is not available. Install Docker and ensure the daemon is running.');\n    85в†’  }\n    86в†’  const projectType = detectProjectType(projectDir);\n    87в†’  const currentHash = computeDistHash(projectDir);\n    88в†’  if (projectType === 'generic' || projectType === 'plugin') {\n    89в†’    // Generic and plugin projects may not have dist/ вЂ” skip hash check\n    90в†’  } else if (!currentHash) {\n    91в†’    throw new Error('No dist/ directory found. Run your build command first (e.g., npm run build).');\n    92в†’  }\n    93в†’  if (currentHash) {\n    94в†’    const storedHash = getStoredDistHash(projectDir);\n    95в†’    if (storedHash === currentHash && dockerImageExists(IMAGE_TAG)) {\n    96в†’      return { imageTag: IMAGE_TAG, imageSize: getImageSize(IMAGE_TAG), buildTimeMs: 0, cached: true };\n    97в†’    }\n    98в†’  }\n    99в†’  const startTime = Date.now();\n   100в†’  if (projectType === 'nodejs') { buildNodeImage(projectDir); }\n   101в†’  else if (projectType === 'python') { buildPythonImage(projectDir); }\n   102в†’  else if (projectType === 'plugin') { buildPluginImage(projectDir); }\n   103в†’  else { buildGenericImage(projectDir); }\n   104в†’  if (currentHash) { storeDistHash(projectDir, currentHash); }\n   105в†’  return { imageTag: IMAGE_TAG, imageSize: getImageSize(IMAGE_TAG), buildTimeMs: Date.now() - startTime, cached: false };\n   106в†’}\n   107в†’\n   108в†’function buildNodeImage(projectDir: string): void {\n   109в†’  const packOutput = execFileSync('npm', ['pack', '--pack-destination', '/tmp'], {\n   110в†’    cwd: projectDir, stdio: 'pipe', timeout: 60_000,\n   111в†’  }).toString().trim();\n   112в†’  const lastLine = packOutput.split('\\n').pop()?.trim();\n   113в†’  if (!lastLine) throw new Error('npm pack produced no output вЂ” cannot determine tarball filename.');\n   114в†’  const tarballName = basename(lastLine);\n   115в†’  const tarballPath = join('/tmp', tarballName);\n   116в†’  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   117в†’  mkdirSync(buildContext, { recursive: true });\n   118в†’  try {\n   119в†’    cpSync(tarballPath, join(buildContext, tarballName));\n   120в†’    cpSync(resolveDockerfileTemplate(projectDir), join(buildContext, 'Dockerfile'));\n   121в†’    execFileSync('docker', ['build', '-t', IMAGE_TAG, '--build-arg', `TARBALL=${tarballName}`, '.'], {\n   122в†’      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   123в†’    });\n   124в†’  } finally {\n   125в†’    rmSync(buildContext, { recursive: true, force: true });\n   126в†’    rmSync(tarballPath, { force: true });\n   127в†’  }\n   128в†’}\n   129в†’\n   130в†’function buildPythonImage(projectDir: string): void {\n   131в†’  const distDir = join(projectDir, 'dist');\n   132в†’  const distFiles = readdirSync(distDir).filter(f => f.endsWith('.tar.gz') || f.endsWith('.whl'));\n   133в†’  if (distFiles.length === 0) {\n   134в†’    throw new Error('No distribution files found in dist/. Run your build command first (e.g., python -m build).');\n   135в†’  }\n   136в†’  const distFile = distFiles.filter(f => f.endsWith('.tar.gz'))[0] ?? distFiles[0];\n   137в†’  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   138в†’  mkdirSync(buildContext, { recursive: true });\n   139в†’  try {\n   140в†’    cpSync(join(distDir, distFile), join(buildContext, distFile));\n   141в†’    cpSync(resolveDockerfileTemplate(projectDir), join(buildContext, 'Dockerfile'));\n   142в†’    execFileSync('docker', ['build', '-t', IMAGE_TAG, '--build-arg', `TARBALL=${distFile}`, '.'], {\n   143в†’      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   144в†’    });\n   145в†’  } finally {\n   146в†’    rmSync(buildContext, { recursive: true, force: true });\n   147в†’  }\n   148в†’}\n   149в†’\n   150в†’/** Creates a clean temp workspace for verification (no src/, tests/, .git/). */\n   151в†’export function prepareVerifyWorkspace(storyKey: string, projectDir?: string): string {\n   152в†’  const root = projectDir ?? process.cwd();\n   153в†’  if (!isValidStoryKey(storyKey)) {\n   154в†’    throw new Error(`Invalid story key: ${storyKey}. Keys must contain only alphanumeric characters, hyphens, and underscores.`);\n   155в†’  }\n   156в†’  const storyFile = join(root, STORY_DIR, `${storyKey}.md`);\n   157в†’  if (!existsSync(storyFile)) throw new Error(`Story file not found: ${storyFile}`);\n   158в†’  const workspace = `${TEMP_PREFIX}${storyKey}`;\n   159в†’  if (existsSync(workspace)) rmSync(workspace, { recursive: true, force: true });\n   160в†’  mkdirSync(workspace, { recursive: true });\n   161в†’  cpSync(storyFile, join(workspace, 'story.md'));\n   162в†’  const readmePath = join(root, 'README.md');\n   163в†’  if (existsSync(readmePath)) cpSync(readmePath, join(workspace, 'README.md'));\n   164в†’  const docsDir = join(root, 'docs');\n   165в†’  if (existsSync(docsDir) && statSync(docsDir).isDirectory()) {\n   166в†’    cpSync(docsDir, join(workspace, 'docs'), { recursive: true });\n   167в†’  }\n   168в†’  mkdirSync(join(workspace, 'verification'), { recursive: true });\n   169в†’  return workspace;\n   170в†’}\n   171в†’\n   172в†’/** Validates verification environment: image, CLI, observability. */\n   173в†’export function checkVerifyEnv(): CheckResult {\n   174в†’  let imageExists = false;\n   175в†’  let cliWorks = false;\n   176в†’  let otelReachable = false;\n   177в†’\n   178в†’  imageExists = dockerImageExists(IMAGE_TAG);\n   179в†’  if (!imageExists) return { imageExists, cliWorks, otelReachable };\n   180в†’  try {\n   181в†’    execFileSync('docker', ['run', '--rm', IMAGE_TAG, 'codeharness', '--help'], {\n   182в†’      stdio: 'pipe', timeout: 30_000,\n   183в†’    });\n   184в†’    cliWorks = true;\n   185в†’  } catch { cliWorks = false; }\n   186в†’  try {\n   187в†’    execFileSync('docker', [\n   188в†’      'run', '--rm', '--add-host=host.docker.internal:host-gateway', IMAGE_TAG,\n   189в†’      'curl', '-sf', '--max-time', '5', 'http://host.docker.internal:4318/v1/status',\n   190в†’    ], { stdio: 'pipe', timeout: 30_000 });\n   191в†’    otelReachable = true;\n   192в†’  } catch { otelReachable = false; }\n   193в†’  return { imageExists, cliWorks, otelReachable };\n   194в†’}\n   195в†’\n   196в†’/** Cleans up all stale containers matching `codeharness-verify-*` pattern. Idempotent. */\n   197в†’export function cleanupStaleContainers(): void {\n   198в†’  try {\n   199в†’    const output = execFileSync(\n   200в†’      'docker', ['ps', '-a', '--filter', 'name=codeharness-verify-', '--format', '{{.Names}}'],\n   201в†’      { stdio: 'pipe', timeout: 15_000 },\n   202в†’    ).toString('utf-8').trim();\n   203в†’    if (output.length === 0) return;\n   204в†’    const containers = output.split('\\n').filter(name => name.length > 0);\n   205в†’    for (const name of containers) {\n   206в†’      try {\n   207в†’        execFileSync('docker', ['rm', '-f', name], { stdio: 'pipe', timeout: 15_000 });\n   208в†’      } catch { /* container may already be removed */ }\n   209в†’    }\n   210в†’  } catch { /* docker not available or no containers вЂ” ignore */ }\n   211в†’}\n   212в†’\n   213в†’/** Removes temp workspace and stops/removes the container. Idempotent. */\n   214в†’export function cleanupVerifyEnv(storyKey: string): void {\n   215в†’  if (!isValidStoryKey(storyKey)) {\n   216в†’    throw new Error(`Invalid story key: ${storyKey}. Keys must contain only alphanumeric characters, hyphens, and underscores.`);\n   217в†’  }\n   218в†’  const workspace = `${TEMP_PREFIX}${storyKey}`;\n   219в†’  const containerName = `codeharness-verify-${storyKey}`;\n   220в†’  if (existsSync(workspace)) rmSync(workspace, { recursive: true, force: true });\n   221в†’  try { execFileSync('docker', ['stop', containerName], { stdio: 'pipe', timeout: 15_000 }); }\n   222в†’  catch { /* container may not exist */ }\n   223в†’  try { execFileSync('docker', ['rm', '-f', containerName], { stdio: 'pipe', timeout: 15_000 }); }\n   224в†’  catch { /* container may not exist */ }\n   225в†’}\n   226в†’\n   227в†’function buildPluginImage(projectDir: string): void {\n   228в†’  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   229в†’  mkdirSync(buildContext, { recursive: true });\n   230в†’  try {\n   231в†’    // Copy plugin source into build context\n   232в†’    const pluginDir = join(projectDir, '.claude-plugin');\n   233в†’    cpSync(pluginDir, join(buildContext, '.claude-plugin'), { recursive: true });\n   234в†’    // Copy any commands, hooks, knowledge, skills directories if they exist\n   235в†’    for (const dir of ['commands', 'hooks', 'knowledge', 'skills']) {\n   236в†’      const src = join(projectDir, dir);\n   237в†’      if (existsSync(src) && statSync(src).isDirectory()) {\n   238в†’        cpSync(src, join(buildContext, dir), { recursive: true });\n   239в†’      }\n   240в†’    }\n   241в†’    cpSync(resolveDockerfileTemplate(projectDir, 'generic'), join(buildContext, 'Dockerfile'));\n   242в†’    execFileSync('docker', ['build', '-t', IMAGE_TAG, '.'], {\n   243в†’      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   244в†’    });\n   245в†’  } finally {\n   246в†’    rmSync(buildContext, { recursive: true, force: true });\n   247в†’  }\n   248в†’}\n   249в†’\n   250в†’function buildGenericImage(projectDir: string): void {\n   251в†’  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   252в†’  mkdirSync(buildContext, { recursive: true });\n   253в†’  try {\n   254в†’    cpSync(resolveDockerfileTemplate(projectDir, 'generic'), join(buildContext, 'Dockerfile'));\n   255в†’    execFileSync('docker', ['build', '-t', IMAGE_TAG, '.'], {\n   256в†’      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   257в†’    });\n   258в†’  } finally {\n   259в†’    rmSync(buildContext, { recursive: true, force: true });\n   260в†’  }\n   261в†’}\n   262в†’\n   263в†’function resolveDockerfileTemplate(projectDir: string, variant?: string): string {\n   264в†’  const filename = variant === 'generic' ? 'Dockerfile.verify.generic' : 'Dockerfile.verify';\n   265в†’  const local = join(projectDir, 'templates', filename);\n   266в†’  if (existsSync(local)) return local;\n   267в†’  const pkgDir = new URL('../../', import.meta.url).pathname;\n   268в†’  const pkg = join(pkgDir, 'templates', filename);\n   269в†’  if (existsSync(pkg)) return pkg;\n   270в†’  throw new Error(`${filename} not found. Ensure templates/${filename} exists.`);\n   271в†’}\n   272в†’\n   273в†’function dockerImageExists(tag: string): boolean {\n   274в†’  try {\n   275в†’    execFileSync('docker', ['image', 'inspect', tag], { stdio: 'pipe', timeout: 10_000 });\n   276в†’    return true;\n   277в†’  } catch { return false; }\n   278в†’}\n   279в†’\n   280в†’function getImageSize(tag: string): string {\n   281в†’  try {\n   282в†’    const output = execFileSync('docker', ['image', 'inspect', tag, '--format', '{{.Size}}'], {\n   283в†’      stdio: 'pipe', timeout: 10_000,\n   284в†’    }).toString().trim();\n   285в†’    const bytes = parseInt(output, 10);\n   286в†’    if (isNaN(bytes)) return output;\n   287в†’    if (bytes >= 1_000_000_000) return `${(bytes / 1_000_000_000).toFixed(1)}GB`;\n   288в†’    if (bytes >= 1_000_000) return `${(bytes / 1_000_000).toFixed(1)}MB`;\n   289в†’    if (bytes >= 1_000) return `${(bytes / 1_000).toFixed(1)}KB`;\n   290в†’    return `${bytes}B`;\n   291в†’  } catch { return 'unknown'; }\n   292в†’}\n   293в†’"}]},"parent_tool_use_id":"toolu_01MpYJycPJfk2nBuCCAUW85g","session_id":"51b9d113-d480-4846-9e18-693f5f89566d","uuid":"7a9b0b21-8eac-414c-98f9-2417c2682dd2","timestamp":"2026-03-23T07:09:12.530Z"}
