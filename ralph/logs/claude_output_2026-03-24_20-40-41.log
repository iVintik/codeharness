{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HvLBLVvuLaJKEfViwRUW9U","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';\n     2→import {\n     3→  existsSync,\n     4→  readFileSync,\n     5→  writeFileSync,\n     6→  unlinkSync,\n     7→  mkdirSync,\n     8→  mkdtempSync,\n     9→  rmSync,\n    10→} from 'node:fs';\n    11→import { join } from 'node:path';\n    12→import { tmpdir } from 'node:os';\n    13→import { parse } from 'yaml';\n    14→import type { SprintState } from '../../../types/state.js';\n    15→\n    16→// Mock migration so tests are isolated from real project files\n    17→vi.mock('../migration.js', () => ({\n    18→  migrateFromOldFormat: vi.fn(() => ({\n    19→    success: false,\n    20→    error: 'No old format files found for migration',\n    21→  })),\n    22→  migrateV1ToV2: vi.fn((v1: Record<string, unknown>) => ({\n    23→    ...v1,\n    24→    version: 2,\n    25→    retries: {},\n    26→    flagged: [],\n    27→    epics: {},\n    28→    session: { active: false, startedAt: null, iteration: 0, elapsedSeconds: 0 },\n    29→    observability: { statementCoverage: null, branchCoverage: null, functionCoverage: null, lineCoverage: null },\n    30→  })),\n    31→}));\n    32→\n    33→// Import functions under test\n    34→const {\n    35→  generateSprintStatusYaml,\n    36→  getStoryStatusesFromState,\n    37→  writeStateAtomic,\n    38→  defaultState,\n    39→  sprintStatusYamlPath,\n    40→} = await import('../state.js');\n    41→\n    42→function mkStory(status: string): SprintState['stories'][string] {\n    43→  return {\n    44→    status: status as 'done',\n    45→    attempts: 0,\n    46→    lastAttempt: null,\n    47→    lastError: null,\n    48→    proofPath: null,\n    49→    acResults: null,\n    50→  };\n    51→}\n    52→\n    53→// ─── getStoryStatusesFromState ──────────────────────────────────────────────\n    54→\n    55→describe('getStoryStatusesFromState', () => {\n    56→  it('returns empty map for empty state', () => {\n    57→    const state = defaultState();\n    58→    const result = getStoryStatusesFromState(state);\n    59→    expect(result).toEqual({});\n    60→  });\n    61→\n    62→  it('returns flat key->status map from state stories', () => {\n    63→    const state: SprintState = {\n    64→      ...defaultState(),\n    65→      stories: {\n    66→        '1-1-first-story': mkStory('done'),\n    67→        '1-2-second-story': mkStory('in-progress'),\n    68→        '2-1-third-story': mkStory('backlog'),\n    69→      },\n    70→    };\n    71→    const result = getStoryStatusesFromState(state);\n    72→    expect(result).toEqual({\n    73→      '1-1-first-story': 'done',\n    74→      '1-2-second-story': 'in-progress',\n    75→      '2-1-third-story': 'backlog',\n    76→    });\n    77→  });\n    78→\n    79→  it('preserves all status types', () => {\n    80→    const state: SprintState = {\n    81→      ...defaultState(),\n    82→      stories: {\n    83→        '1-1-a': mkStory('done'),\n    84→        '1-2-b': mkStory('failed'),\n    85→        '1-3-c': mkStory('blocked'),\n    86→        '2-1-d': mkStory('verifying'),\n    87→        '2-2-e': mkStory('review'),\n    88→        '2-3-f': mkStory('ready'),\n    89→      },\n    90→    };\n    91→    const result = getStoryStatusesFromState(state);\n    92→    expect(result['1-1-a']).toBe('done');\n    93→    expect(result['1-2-b']).toBe('failed');\n    94→    expect(result['1-3-c']).toBe('blocked');\n    95→    expect(result['2-1-d']).toBe('verifying');\n    96→    expect(result['2-2-e']).toBe('review');\n    97→    expect(result['2-3-f']).toBe('ready');\n    98→  });\n    99→});\n   100→\n   101→// ─── generateSprintStatusYaml ───────────────────────────────────────────────\n   102→\n   103→describe('generateSprintStatusYaml', () => {\n   104→  it('produces valid YAML for empty state', () => {\n   105→    const state = defaultState();\n   106→    const yaml = generateSprintStatusYaml(state);\n   107→    expect(yaml).toContain('development_status:');\n   108→    // Should parse without error\n   109→    const parsed = parse(yaml);\n   110→    expect(parsed).toBeDefined();\n   111→  });\n   112→\n   113→  it('groups stories by epic and sorts by epic/story number', () => {\n   114→    const state: SprintState = {\n   115→      ...defaultState(),\n   116→      stories: {\n   117→        '2-1-beta': mkStory('backlog'),\n   118→        '1-2-second': mkStory('done'),\n   119→        '1-1-first': mkStory('done'),\n   120→        '2-2-gamma': mkStory('in-progress'),\n   121→      },\n   122→    };\n   123→    const yaml = generateSprintStatusYaml(state);\n   124→\n   125→    // Epic 1 should appear before Epic 2\n   126→    const epic1Pos = yaml.indexOf('# Epic 1');\n   127→    const epic2Pos = yaml.indexOf('# Epic 2');\n   128→    expect(epic1Pos).toBeLessThan(epic2Pos);\n   129→\n   130→    // Within Epic 1, story 1-1 should appear before 1-2\n   131→    const story11Pos = yaml.indexOf('1-1-first');\n   132→    const story12Pos = yaml.indexOf('1-2-second');\n   133→    expect(story11Pos).toBeLessThan(story12Pos);\n   134→  });\n   135→\n   136→  it('computes epic status as done when all stories done', () => {\n   137→    const state: SprintState = {\n   138→      ...defaultState(),\n   139→      stories: {\n   140→        '1-1-first': mkStory('done'),\n   141→        '1-2-second': mkStory('done'),\n   142→      },\n   143→    };\n   144→    const yaml = generateSprintStatusYaml(state);\n   145→    expect(yaml).toContain('epic-1: done');\n   146→  });\n   147→\n   148→  it('computes epic status as backlog when not all stories done', () => {\n   149→    const state: SprintState = {\n   150→      ...defaultState(),\n   151→      stories: {\n   152→        '1-1-first': mkStory('done'),\n   153→        '1-2-second': mkStory('in-progress'),\n   154→      },\n   155→    };\n   156→    const yaml = generateSprintStatusYaml(state);\n   157→    expect(yaml).toContain('epic-1: backlog');\n   158→  });\n   159→\n   160→  it('maps \"ready\" status to \"ready-for-dev\" in YAML', () => {\n   161→    const state: SprintState = {\n   162→      ...defaultState(),\n   163→      stories: {\n   164→        '3-1-some-story': mkStory('ready'),\n   165→      },\n   166→    };\n   167→    const yaml = generateSprintStatusYaml(state);\n   168→    expect(yaml).toContain('3-1-some-story: ready-for-dev');\n   169→  });\n   170→\n   171→  it('produces parseable YAML with correct development_status', () => {\n   172→    const state: SprintState = {\n   173→      ...defaultState(),\n   174→      stories: {\n   175→        '1-1-alpha': mkStory('done'),\n   176→        '2-1-beta': mkStory('backlog'),\n   177→      },\n   178→    };\n   179→    const yaml = generateSprintStatusYaml(state);\n   180→    const parsed = parse(yaml) as Record<string, unknown>;\n   181→    expect(parsed.development_status).toBeDefined();\n   182→\n   183→    const devStatus = parsed.development_status as Record<string, string>;\n   184→    expect(devStatus['1-1-alpha']).toBe('done');\n   185→    expect(devStatus['2-1-beta']).toBe('backlog');\n   186→    expect(devStatus['epic-1']).toBe('done');\n   187→    expect(devStatus['epic-2']).toBe('backlog');\n   188→  });\n   189→\n   190→  it('includes auto-generated header comment', () => {\n   191→    const state = defaultState();\n   192→    const yaml = generateSprintStatusYaml(state);\n   193→    expect(yaml).toContain('auto-generated from sprint-state.json');\n   194→    expect(yaml).toContain('do NOT edit manually');\n   195→  });\n   196→\n   197→  it('handles multiple epics with mixed statuses', () => {\n   198→    const state: SprintState = {\n   199→      ...defaultState(),\n   200→      stories: {\n   201→        '1-1-a': mkStory('done'),\n   202→        '1-2-b': mkStory('done'),\n   203→        '2-1-c': mkStory('done'),\n   204→        '2-2-d': mkStory('failed'),\n   205→        '3-1-e': mkStory('backlog'),\n   206→      },\n   207→    };\n   208→    const yaml = generateSprintStatusYaml(state);\n   209→    expect(yaml).toContain('epic-1: done');\n   210→    expect(yaml).toContain('epic-2: backlog'); // 2-2-d is failed, not done\n   211→    expect(yaml).toContain('epic-3: backlog');\n   212→  });\n   213→\n   214→  it('handles stories with non-standard keys gracefully (sorted last)', () => {\n   215→    const state: SprintState = {\n   216→      ...defaultState(),\n   217→      stories: {\n   218→        '1-1-normal': mkStory('done'),\n   219→        'no-match-key': mkStory('backlog'),\n   220→      },\n   221→    };\n   222→    // Should not throw\n   223→    const yaml = generateSprintStatusYaml(state);\n   224→    expect(yaml).toContain('1-1-normal: done');\n   225→    expect(yaml).toContain('no-match-key: backlog');\n   226→  });\n   227→\n   228→  it('handles state with epics field populated (ignored — epics derived from stories)', () => {\n   229→    const state: SprintState = {\n   230→      ...defaultState(),\n   231→      epics: {\n   232→        '1': { status: 'done', storiesTotal: 2, storiesDone: 2 },\n   233→      },\n   234→      stories: {\n   235→        '1-1-a': mkStory('done'),\n   236→        '1-2-b': mkStory('backlog'),\n   237→      },\n   238→    };\n   239→    const yaml = generateSprintStatusYaml(state);\n   240→    // Epic status should be derived from stories, not from epics field\n   241→    expect(yaml).toContain('epic-1: backlog');\n   242→  });\n   243→});\n   244→\n   245→// ─── writeStateAtomic regenerates YAML (filesystem-isolated) ─────────────────\n   246→\n   247→describe('writeStateAtomic regenerates sprint-status.yaml', () => {\n   248→  let testDir: string;\n   249→  let originalCwd: string;\n   250→\n   251→  beforeEach(() => {\n   252→    testDir = mkdtempSync(join(tmpdir(), 'ch-yaml-'));\n   253→    originalCwd = process.cwd();\n   254→    process.chdir(testDir);\n   255→  });\n   256→\n   257→  afterEach(() => {\n   258→    process.chdir(originalCwd);\n   259→    rmSync(testDir, { recursive: true, force: true });\n   260→  });\n   261→\n   262→  it('writes sprint-status.yaml when directory exists', () => {\n   263→    const yamlDir = join(testDir, '_bmad-output', 'implementation-artifacts');\n   264→    mkdirSync(yamlDir, { recursive: true });\n   265→\n   266→    const state: SprintState = {\n   267→      ...defaultState(),\n   268→      stories: {\n   269→        '1-1-test-story': mkStory('done'),\n   270→      },\n   271→    };\n   272→    const result = writeStateAtomic(state);\n   273→    expect(result.success).toBe(true);\n   274→\n   275→    // Verify sprint-status.yaml was written\n   276→    const yamlFile = join(yamlDir, 'sprint-status.yaml');\n   277→    expect(existsSync(yamlFile)).toBe(true);\n   278→    const yamlContent = readFileSync(yamlFile, 'utf-8');\n   279→    expect(yamlContent).toContain('1-1-test-story: done');\n   280→    expect(yamlContent).toContain('auto-generated');\n   281→  });\n   282→\n   283→  it('YAML updates on every state write', () => {\n   284→    const yamlDir = join(testDir, '_bmad-output', 'implementation-artifacts');\n   285→    mkdirSync(yamlDir, { recursive: true });\n   286→\n   287→    // First write\n   288→    const state1: SprintState = {\n   289→      ...defaultState(),\n   290→      stories: {\n   291→        '1-1-story': mkStory('backlog'),\n   292→      },\n   293→    };\n   294→    writeStateAtomic(state1);\n   295→    const yamlFile = join(yamlDir, 'sprint-status.yaml');\n   296→    const yaml1 = readFileSync(yamlFile, 'utf-8');\n   297→    expect(yaml1).toContain('1-1-story: backlog');\n   298→\n   299→    // Second write with updated status\n   300→    const state2: SprintState = {\n   301→      ...defaultState(),\n   302→      stories: {\n   303→        '1-1-story': mkStory('done'),\n   304→      },\n   305→    };\n   306→    writeStateAtomic(state2);\n   307→    const yaml2 = readFileSync(yamlFile, 'utf-8');\n   308→    expect(yaml2).toContain('1-1-story: done');\n   309→    expect(yaml2).not.toContain('1-1-story: backlog');\n   310→  });\n   311→\n   312→  it('skips YAML write when output directory does not exist', () => {\n   313→    // No _bmad-output dir created — should not throw\n   314→    const state: SprintState = {\n   315→      ...defaultState(),\n   316→      stories: {\n   317→        '1-1-test': mkStory('done'),\n   318→      },\n   319→    };\n   320→    const result = writeStateAtomic(state);\n   321→    expect(result.success).toBe(true);\n   322→\n   323→    // YAML file should not exist\n   324→    const yamlFile = join(testDir, '_bmad-output', 'implementation-artifacts', 'sprint-status.yaml');\n   325→    expect(existsSync(yamlFile)).toBe(false);\n   326→  });\n   327→\n   328→  it('YAML write failure does not fail the state write', () => {\n   329→    // Create directory as a file to force YAML write failure\n   330→    const yamlDir = join(testDir, '_bmad-output', 'implementation-artifacts');\n   331→    mkdirSync(join(testDir, '_bmad-output'), { recursive: true });\n   332→    // Create a file where the yaml file should go, making writeFileSync fail\n   333→    mkdirSync(yamlDir, { recursive: true });\n   334→    const yamlFile = join(yamlDir, 'sprint-status.yaml');\n   335→    mkdirSync(yamlFile); // directory instead of file — writeFileSync will fail\n   336→\n   337→    const state: SprintState = {\n   338→      ...defaultState(),\n   339→      stories: { '1-1-x': mkStory('done') },\n   340→    };\n   341→    const result = writeStateAtomic(state);\n   342→    // State write should succeed even though YAML write fails\n   343→    expect(result.success).toBe(true);\n   344→\n   345→    // Verify JSON state was written\n   346→    const stateFile = join(testDir, 'sprint-state.json');\n   347→    expect(existsSync(stateFile)).toBe(true);\n   348→  });\n   349→});\n   350→\n   351→// ─── sprintStatusYamlPath ───────────────────────────────────────────────────\n   352→\n   353→describe('sprintStatusYamlPath', () => {\n   354→  it('returns expected path', () => {\n   355→    const path = sprintStatusYamlPath();\n   356→    expect(path).toContain('_bmad-output');\n   357→    expect(path).toContain('implementation-artifacts');\n   358→    expect(path).toContain('sprint-status.yaml');\n   359→  });\n   360→});\n   361→"}]},"parent_tool_use_id":"toolu_01Kp4vg8QbGP4qihFNHowzNE","session_id":"d308c3c3-ed4a-4164-bef5-0fade3bd8d38","uuid":"70b897e8-10b9-4815-b9c8-554fbc3b5ac0","timestamp":"2026-03-24T16:46:58.686Z"}
