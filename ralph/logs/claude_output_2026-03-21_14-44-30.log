{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KGspEceu4YXTzdoAGYhd8w","type":"tool_result","content":"     1→/**\n     2→ * Ink UI components for the terminal activity dashboard.\n     3→ *\n     4→ * Uses Ink's Box/flexbox layout with borders for a panel-based dashboard.\n     5→ * Static component is used for permanent messages (story completions).\n     6→ */\n     7→\n     8→import React from 'react';\n     9→import { Text, Box, Static } from 'ink';\n    10→import { Spinner } from '@inkjs/ui';\n    11→\n    12→// --- Types ---\n    13→\n    14→export interface SprintInfo {\n    15→  storyKey: string;\n    16→  phase: string;\n    17→  done: number;\n    18→  total: number;\n    19→  elapsed?: string;\n    20→}\n    21→\n    22→export interface CompletedToolEntry {\n    23→  name: string;\n    24→  args: string;\n    25→}\n    26→\n    27→export type StoryStatusValue = 'done' | 'in-progress' | 'pending' | 'failed' | 'blocked';\n    28→\n    29→export interface StoryStatusEntry {\n    30→  key: string;\n    31→  status: StoryStatusValue;\n    32→}\n    33→\n    34→export interface RetryInfo {\n    35→  attempt: number;\n    36→  delay: number;\n    37→}\n    38→\n    39→export interface StoryMessage {\n    40→  type: 'ok' | 'warn' | 'fail';\n    41→  key: string;\n    42→  message: string;\n    43→  details?: string[];\n    44→}\n    45→\n    46→export interface RendererState {\n    47→  sprintInfo: SprintInfo | null;\n    48→  stories: StoryStatusEntry[];\n    49→  messages: StoryMessage[];\n    50→  completedTools: CompletedToolEntry[];\n    51→  activeTool: { name: string } | null;\n    52→  activeToolArgs: string;\n    53→  lastThought: string | null;\n    54→  retryInfo: RetryInfo | null;\n    55→}\n    56→\n    57→// --- Components ---\n    58→\n    59→export function Header({ info }: { info: SprintInfo | null }) {\n    60→  if (!info) return null;\n    61→  const pct = info.total > 0 ? Math.round((info.done / info.total) * 100) : 0;\n    62→  return (\n    63→    <Box borderStyle=\"round\" borderColor=\"cyan\" paddingX={1}>\n    64→      <Text bold color=\"cyan\">{'◆ '}</Text>\n    65→      <Text bold>{info.storyKey || '(waiting)'}</Text>\n    66→      <Text dimColor>{' — '}</Text>\n    67→      <Text color=\"yellow\">{info.phase || '...'}</Text>\n    68→      {info.elapsed && <Text dimColor>{` │ ${info.elapsed}`}</Text>}\n    69→      <Text dimColor>{' │ Sprint: '}</Text>\n    70→      <Text bold color=\"green\">{info.done}</Text>\n    71→      <Text dimColor>{'/'}</Text>\n    72→      <Text>{String(info.total)}</Text>\n    73→      <Text dimColor>{` (${pct}%)`}</Text>\n    74→    </Box>\n    75→  );\n    76→}\n    77→\n    78→const STATUS_SYMBOLS: Record<StoryStatusValue, string> = {\n    79→  'done': '✓',\n    80→  'in-progress': '◆',\n    81→  'pending': '○',\n    82→  'failed': '✗',\n    83→  'blocked': '✕',\n    84→};\n    85→\n    86→const STATUS_COLORS: Record<StoryStatusValue, string> = {\n    87→  'done': 'green',\n    88→  'in-progress': 'cyan',\n    89→  'pending': 'gray',\n    90→  'failed': 'red',\n    91→  'blocked': 'yellow',\n    92→};\n    93→\n    94→function shortKey(key: string): string {\n    95→  const m = key.match(/^(\\d+-\\d+)/);\n    96→  return m ? m[1] : key;\n    97→}\n    98→\n    99→export function StoryBreakdown({ stories }: { stories: StoryStatusEntry[] }) {\n   100→  if (stories.length === 0) return null;\n   101→\n   102→  const groups: Partial<Record<StoryStatusValue, string[]>> = {};\n   103→  for (const s of stories) {\n   104→    if (!groups[s.status]) groups[s.status] = [];\n   105→    groups[s.status]!.push(s.key);\n   106→  }\n   107→\n   108→  return (\n   109→    <Box paddingX={1} gap={2}>\n   110→      {groups['done']?.length && (\n   111→        <Text>\n   112→          <Text color=\"green\">{groups['done'].length} ✓</Text>\n   113→          <Text dimColor> done</Text>\n   114→        </Text>\n   115→      )}\n   116→      {groups['in-progress']?.map(k => (\n   117→        <Text key={k}>\n   118→          <Text color=\"cyan\">◆ </Text>\n   119→          <Text bold>{k}</Text>\n   120→        </Text>\n   121→      ))}\n   122→      {groups['pending']?.length && (\n   123→        <Text>\n   124→          <Text dimColor>next: </Text>\n   125→          <Text>{groups['pending'].slice(0, 3).map(k => shortKey(k)).join(' ')}</Text>\n   126→          {groups['pending'].length > 3 && <Text dimColor>{` +${groups['pending'].length - 3}`}</Text>}\n   127→        </Text>\n   128→      )}\n   129→      {groups['failed']?.map(k => (\n   130→        <Text key={k}><Text color=\"red\">✗ {shortKey(k)}</Text></Text>\n   131→      ))}\n   132→      {groups['blocked']?.map(k => (\n   133→        <Text key={k}><Text color=\"yellow\">✕ {shortKey(k)}</Text></Text>\n   134→      ))}\n   135→    </Box>\n   136→  );\n   137→}\n   138→\n   139→const MESSAGE_STYLE: Record<StoryMessage['type'], { prefix: string; color: string }> = {\n   140→  ok: { prefix: '[OK]', color: 'green' },\n   141→  warn: { prefix: '[WARN]', color: 'yellow' },\n   142→  fail: { prefix: '[FAIL]', color: 'red' },\n   143→};\n   144→\n   145→export function StoryMessageLine({ msg }: { msg: StoryMessage }) {\n   146→  const style = MESSAGE_STYLE[msg.type];\n   147→  return (\n   148→    <Box flexDirection=\"column\">\n   149→      <Text>\n   150→        <Text color={style.color} bold>{style.prefix}</Text>\n   151→        <Text>{` Story ${msg.key}: ${msg.message}`}</Text>\n   152→      </Text>\n   153→      {msg.details?.map((d, j) => (\n   154→        <Text key={j} dimColor>{`  └ ${d}`}</Text>\n   155→      ))}\n   156→    </Box>\n   157→  );\n   158→}\n   159→\n   160→export function CompletedTool({ entry }: { entry: CompletedToolEntry }) {\n   161→  const argsSummary = entry.args.length > 60\n   162→    ? entry.args.slice(0, 60) + '…'\n   163→    : entry.args;\n   164→  return (\n   165→    <Text wrap=\"truncate-end\">\n   166→      <Text color=\"green\">{'✓ '}</Text>\n   167→      <Text dimColor>{'['}</Text>\n   168→      <Text>{entry.name}</Text>\n   169→      <Text dimColor>{'] '}</Text>\n   170→      <Text dimColor>{argsSummary}</Text>\n   171→    </Text>\n   172→  );\n   173→}\n   174→\n   175→/** Show only the last N completed tools to keep output compact. */\n   176→const VISIBLE_COMPLETED_TOOLS = 5;\n   177→\n   178→export function CompletedTools({ tools }: { tools: CompletedToolEntry[] }) {\n   179→  const visible = tools.slice(-VISIBLE_COMPLETED_TOOLS);\n   180→  const hidden = tools.length - visible.length;\n   181→  return (\n   182→    <Box flexDirection=\"column\">\n   183→      {hidden > 0 && <Text dimColor>{`  … ${hidden} earlier tools`}</Text>}\n   184→      {visible.map((entry, i) => (\n   185→        <CompletedTool key={i} entry={entry} />\n   186→      ))}\n   187→    </Box>\n   188→  );\n   189→}\n   190→\n   191→export function ActiveTool({ name }: { name: string }) {\n   192→  return (\n   193→    <Box>\n   194→      <Text color=\"yellow\">{'⚡ '}</Text>\n   195→      <Text dimColor>{'['}</Text>\n   196→      <Text bold>{name}</Text>\n   197→      <Text dimColor>{'] '}</Text>\n   198→      <Spinner label=\"\" />\n   199→    </Box>\n   200→  );\n   201→}\n   202→\n   203→export function LastThought({ text }: { text: string }) {\n   204→  return (\n   205→    <Text wrap=\"truncate-end\">\n   206→      <Text>{'💭 '}</Text>\n   207→      <Text dimColor>{text}</Text>\n   208→    </Text>\n   209→  );\n   210→}\n   211→\n   212→export function RetryNotice({ info }: { info: RetryInfo }) {\n   213→  return (\n   214→    <Text color=\"yellow\">\n   215→      {'⏳ API retry '}\n   216→      {info.attempt}\n   217→      {' (waiting '}\n   218→      {info.delay}\n   219→      {'ms)'}\n   220→    </Text>\n   221→  );\n   222→}\n   223→\n   224→// --- Root App ---\n   225→\n   226→export function App({\n   227→  state,\n   228→}: {\n   229→  state: RendererState;\n   230→}) {\n   231→  return (\n   232→    <Box flexDirection=\"column\">\n   233→      {/* Permanent messages — rendered once via Static, scroll up */}\n   234→      <Static items={state.messages}>\n   235→        {(msg, i) => (\n   236→          <StoryMessageLine key={i} msg={msg} />\n   237→        )}\n   238→      </Static>\n   239→\n   240→      {/* Dynamic section — re-renders on every state change */}\n   241→      <Header info={state.sprintInfo} />\n   242→      <StoryBreakdown stories={state.stories} />\n   243→      <Box flexDirection=\"column\" paddingLeft={1}>\n   244→        <CompletedTools tools={state.completedTools} />\n   245→        {state.activeTool && <ActiveTool name={state.activeTool.name} />}\n   246→        {state.lastThought && <LastThought text={state.lastThought} />}\n   247→        {state.retryInfo && <RetryNotice info={state.retryInfo} />}\n   248→      </Box>\n   249→    </Box>\n   250→  );\n   251→}\n   252→"}]},"parent_tool_use_id":"toolu_01V53hNpMF7bCUCk5waNmUeL","session_id":"3e8c45fc-a757-4d77-9a55-f32a41bfdb65","uuid":"21f41557-2015-4305-b4e3-57be031f8484","timestamp":"2026-03-21T10:48:48.016Z"}
