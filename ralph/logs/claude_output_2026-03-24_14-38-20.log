 });\n   443→    const result = getStoryDrillDown(state, '2-3-status');\n   444→    expect(result.success).toBe(true);\n   445→    if (!result.success) return;\n   446→    expect(result.data.proofSummary).not.toBeNull();\n   447→    expect(result.data.proofSummary!.passCount).toBe(1);\n   448→    expect(result.data.proofSummary!.failCount).toBe(1);\n   449→    expect(result.data.proofSummary!.escalateCount).toBe(1);\n   450→    expect(result.data.proofSummary!.pendingCount).toBe(1);\n   451→  });\n   452→\n   453→  it('includes timeoutSummary when passed via opts', () => {\n   454→    const state = makeState({\n   455→      stories: {\n   456→        '3-1-timeout': s({ status: 'in-progress', attempts: 2 }),\n   457→      },\n   458→    });\n   459→    const timeoutSummary = {\n   460→      reportPath: '/project/ralph/logs/timeout-report-5-3-1-timeout.md',\n   461→      iteration: 5,\n   462→      durationMinutes: 30,\n   463→      filesChanged: 3,\n   464→    };\n   465→    const result = getStoryDrillDown(state, '3-1-timeout', { timeoutSummary });\n   466→    expect(result.success).toBe(true);\n   467→    if (!result.success) return;\n   468→    expect(result.data.timeoutSummary).not.toBeNull();\n   469→    expect(result.data.timeoutSummary!.iteration).toBe(5);\n   470→    expect(result.data.timeoutSummary!.durationMinutes).toBe(30);\n   471→    expect(result.data.timeoutSummary!.filesChanged).toBe(3);\n   472→    expect(result.data.timeoutSummary!.reportPath).toContain('timeout-report-5-3-1-timeout.md');\n   473→  });\n   474→\n   475→  it('returns null timeoutSummary when opts not provided', () => {\n   476→    const state = makeState({\n   477→      stories: {\n   478→        '1-1-story': s({ status: 'backlog', attempts: 0 }),\n   479→      },\n   480→    });\n   481→    const result = getStoryDrillDown(state, '1-1-story');\n   482→    expect(result.success).toBe(true);\n   483→    if (!result.success) return;\n   484→    expect(result.data.timeoutSummary).toBeNull();\n   485→  });\n   486→\n   487→  it('returns null timeoutSummary when opts.timeoutSummary is null', () => {\n   488→    const state = makeState({\n   489→      stories: {\n   490→        '1-1-story': s({ status: 'backlog', attempts: 0 }),\n   491→      },\n   492→    });\n   493→    const result = getStoryDrillDown(state, '1-1-story', { timeoutSummary: null });\n   494→    expect(result.success).toBe(true);\n   495→    if (!result.success) return;\n   496→    expect(result.data.timeoutSummary).toBeNull();\n   497→  });\n   498→\n   499→  it('extracts multi-digit epic prefix correctly', () => {\n   500→    const state = makeState({\n   501→      stories: {\n   502→        '10-1-validation': s({ status: 'backlog', attempts: 0 }),\n   503→      },\n   504→    });\n   505→    const result = getStoryDrillDown(state, '10-1-validation');\n   506→    expect(result.success).toBe(true);\n   507→    if (!result.success) return;\n   508→    expect(result.data.epic).toBe('10');\n   509→  });\n   510→});\n   511→"}]},"parent_tool_use_id":"toolu_01CfvkxunN8dwVBkgTqCVyZN","session_id":"0e449f80-823c-4489-a784-b43b6c7039d6","uuid":"810e8ed9-2e84-4030-9671-a40a78290a68","timestamp":"2026-03-24T10:39:46.477Z"}
