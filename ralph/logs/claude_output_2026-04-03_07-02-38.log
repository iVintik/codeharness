{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YV2yUxmp6djni7QhbtqFg6","type":"tool_result","content":"1\timport { existsSync } from 'node:fs';\n2\timport { join } from 'node:path';\n3\timport { Command } from 'commander';\n4\timport { fail, info, ok } from '../lib/output.js';\n5\timport { isDockerAvailable } from '../lib/docker/index.js';\n6\timport { cleanupContainers } from '../modules/infra/index.js';\n7\timport { readSprintStatusFromState, reconcileState } from '../modules/sprint/index.js';\n8\timport { countStories, formatElapsed } from '../lib/run-helpers.js';\n9\timport { parseWorkflow, resolveWorkflow } from '../lib/workflow-parser.js';\n10\timport { resolveAgent, compileSubagentDefinition } from '../lib/agent-resolver.js';\n11\timport { executeWorkflow } from '../lib/workflow-engine.js';\n12\timport { readWorkflowState, writeWorkflowState } from '../lib/workflow-state.js';\n13\timport type { EngineConfig } from '../lib/workflow-engine.js';\n14\timport type { SubagentDefinition } from '../lib/agent-resolver.js';\n15\t\n16\t/** Resolves the plugin directory path (.claude/ in project root). */\n17\texport function resolvePluginDir(): string {\n18\t  return join(process.cwd(), '.claude');\n19\t}\n20\t\n21\t// Re-export helpers that tests import from run.ts\n22\texport { countStories } from '../lib/run-helpers.js';\n23\t\n24\texport function registerRunCommand(program: Command): void {\n25\t  program\n26\t    .command('run')\n27\t    .description('Execute the autonomous coding loop')\n28\t    .option('--max-iterations <n>', 'Maximum loop iterations', '50')\n29\t    .option('--timeout <seconds>', 'Total loop timeout in seconds', '43200')\n30\t    .option('--iteration-timeout <minutes>', 'Per-iteration timeout in minutes', '30')\n31\t    .option('--quiet', 'Suppress terminal output (background mode)', false)\n32\t    .option('--calls <n>', 'Max API calls per hour', '100')\n33\t    .option('--max-story-retries <n>', 'Max retries per story before flagging', '10')\n34\t    .option('--reset', 'Clear retry counters, flagged stories, and circuit breaker before starting', false)\n35\t    .option('--resume', 'Resume from last checkpoint (engine resumes by default)', false)\n36\t    .option('--workflow <name>', 'Workflow name to load (default: \"default\")')\n37\t    .action(async (options, cmd) => {\n38\t      const globalOpts = cmd.optsWithGlobals();\n39\t      const isJson = !!globalOpts.json;\n40\t      const outputOpts = { json: isJson };\n41\t\n42\t      // 1. Resolve plugin directory\n43\t      const pluginDir = resolvePluginDir();\n44\t      if (!existsSync(pluginDir)) {\n45\t        fail('Plugin directory not found — run codeharness init first', outputOpts);\n46\t        process.exitCode = 1;\n47\t        return;\n48\t      }\n49\t\n50\t      // 1b. Reconcile state (best-effort — failures warn but don't abort)\n51\t      const reconciliation = reconcileState();\n52\t      if (reconciliation.success && reconciliation.data.corrections.length > 0) {\n53\t        for (const correction of reconciliation.data.corrections) {\n54\t          info(`[INFO] Reconciled: ${correction}`, outputOpts);\n55\t        }\n56\t      } else if (!reconciliation.success) {\n57\t        info(`[WARN] State reconciliation failed: ${reconciliation.error}`, outputOpts);\n58\t      }\n59\t\n60\t      // 1c. Docker pre-flight: fail fast if Docker unavailable\n61\t      if (!isDockerAvailable()) {\n62\t        fail('[FAIL] Docker not available — install Docker or start the daemon', outputOpts);\n63\t        process.exitCode = 1;\n64\t        return;\n65\t      }\n66\t      // 1d. Orphan container cleanup (best-effort — failures warn but don't abort)\n67\t      const cleanup = cleanupContainers();\n68\t      if (cleanup.success && cleanup.data.containersRemoved > 0) {\n69\t        info(`[INFO] Cleaned up ${cleanup.data.containersRemoved} orphaned container(s): ${cleanup.data.names.join(', ')}`, outputOpts);\n70\t      } else if (!cleanup.success) {\n71\t        info(`[WARN] Container cleanup failed: ${cleanup.error}`, outputOpts);\n72\t      }\n73\t      // 2. Read sprint status for story count (from sprint-state.json)\n74\t      const statuses = readSprintStatusFromState();\n75\t      const counts = countStories(statuses);\n76\t\n77\t      if (counts.total === 0) {\n78\t        fail('No stories found in sprint-state.json — nothing to execute', outputOpts);\n79\t        process.exitCode = 1;\n80\t        return;\n81\t      }\n82\t\n83\t      if (counts.ready === 0) {\n84\t        fail('No stories ready for execution', outputOpts);\n85\t        process.exitCode = 1;\n86\t        return;\n87\t      }\n88\t\n89\t      info(`Starting autonomous execution — ${counts.ready} ready, ${counts.inProgress} in progress, ${counts.verified} verified, ${counts.done}/${counts.total} done`, outputOpts);\n90\t      // 3. Parse and validate numeric options\n91\t      const maxIterations = parseInt(options.maxIterations, 10);\n92\t      const timeout = parseInt(options.timeout, 10);\n93\t      const iterationTimeout = parseInt(options.iterationTimeout, 10);\n94\t      const calls = parseInt(options.calls, 10);\n95\t      const maxStoryRetries = parseInt(options.maxStoryRetries, 10);\n96\t      if (isNaN(maxIterations) || isNaN(timeout) || isNaN(iterationTimeout) || isNaN(calls) || isNaN(maxStoryRetries)) {\n97\t        fail('Invalid numeric option — --max-iterations, --timeout, --iteration-timeout, --calls, and --max-story-retries must be numbers', outputOpts);\n98\t        process.exitCode = 1;\n99\t        return;\n100\t      }\n101\t\n102\t      // 4. Resolve workflow (embedded -> user patch -> project patch)\n103\t      const projectDir = process.cwd();\n104\t      const workflowName = options.workflow ?? 'default';\n105\t\n106\t      let parsedWorkflow;\n107\t      try {\n108\t        parsedWorkflow = resolveWorkflow({ cwd: projectDir, name: workflowName });\n109\t      } catch (err: unknown) {\n110\t        // Fallback: try direct file parsing for backward compatibility (only for default)\n111\t        if (workflowName !== 'default') {\n112\t          const msg = err instanceof Error ? err.message : String(err);\n113\t          fail(`Failed to resolve workflow: ${msg}`, outputOpts);\n114\t          process.exitCode = 1;\n115\t          return;\n116\t        }\n117\t        const projectWorkflowPath = join(projectDir, '.codeharness', 'workflows', 'default.yaml');\n118\t        const templateWorkflowPath = join(projectDir, 'templates', 'workflows', 'default.yaml');\n119\t        const workflowPath = existsSync(projectWorkflowPath) ? projectWorkflowPath : templateWorkflowPath;\n120\t        try {\n121\t          parsedWorkflow = parseWorkflow(workflowPath);\n122\t        } catch (fallbackErr: unknown) {\n123\t          const msg = err instanceof Error ? err.message : String(err);\n124\t          fail(`Failed to resolve workflow: ${msg}`, outputOpts);\n125\t          process.exitCode = 1;\n126\t          return;\n127\t        }\n128\t      }\n129\t\n130\t      // 5. Resolve agents referenced in workflow\n131\t      const agents: Record<string, SubagentDefinition> = {};\n132\t      try {\n133\t        for (const [, task] of Object.entries(parsedWorkflow.tasks)) {\n134\t          if (!agents[task.agent]) {\n135\t            const resolved = resolveAgent(task.agent, { cwd: projectDir });\n136\t            agents[task.agent] = compileSubagentDefinition(resolved);\n137\t          }\n138\t        }\n139\t      } catch (err: unknown) {\n140\t        const msg = err instanceof Error ? err.message : String(err);\n141\t        fail(`Failed to resolve agents: ${msg}`, outputOpts);\n142\t        process.exitCode = 1;\n143\t        return;\n144\t      }\n145\t\n146\t      // 6. Handle --resume: reset completed or circuit-breaker state so the engine re-enters execution\n147\t      if (options.resume) {\n148\t        const currentState = readWorkflowState(projectDir);\n149\t        if (currentState.phase === 'completed') {\n150\t          writeWorkflowState({ ...currentState, phase: 'idle' }, projectDir);\n151\t          info('Resuming from completed state — phase reset to idle', outputOpts);\n152\t        } else if (currentState.phase === 'circuit-breaker') {\n153\t          writeWorkflowState({\n154\t            ...currentState,\n155\t            phase: 'idle',\n156\t            circuit_breaker: {\n157\t              ...currentState.circuit_breaker,\n158\t              triggered: false,\n159\t              reason: null,\n160\t              // score_history is PRESERVED\n161\t            },\n162\t          }, projectDir);\n163\t          info('Resuming after circuit breaker — previous findings preserved', outputOpts);\n164\t        }\n165\t      }\n166\t\n167\t      // 7. Build EngineConfig and execute\n168\t      const config: EngineConfig = {\n169\t        workflow: parsedWorkflow,\n170\t        agents,\n171\t        sprintStatusPath: join(projectDir, '_bmad-output', 'implementation-artifacts', 'sprint-status.yaml'),\n172\t        issuesPath: join(projectDir, '.codeharness', 'issues.yaml'),\n173\t        runId: `run-${Date.now()}`,\n174\t        projectDir,\n175\t        maxIterations,\n176\t      };\n177\t\n178\t      try {\n179\t        const result = await executeWorkflow(config);\n180\t\n181\t        if (result.success) {\n182\t          ok(`Workflow completed — ${result.storiesProcessed} stories processed, ${result.tasksCompleted} tasks completed in ${formatElapsed(result.durationMs)}`, outputOpts);\n183\t        } else {\n184\t          fail(`Workflow failed — ${result.storiesProcessed} stories processed, ${result.tasksCompleted} tasks completed, ${result.errors.length} error(s) in ${formatElapsed(result.durationMs)}`, outputOpts);\n185\t          for (const err of result.errors) {\n186\t            info(`  ${err.taskName}/${err.storyKey}: [${err.code}] ${err.message}`, outputOpts);\n187\t          }\n188\t          process.exitCode = 1;\n189\t        }\n190\t      } catch (err: unknown) {\n191\t        const msg = err instanceof Error ? err.message : String(err);\n192\t        fail(`Workflow engine error: ${msg}`, outputOpts);\n193\t        process.exitCode = 1;\n194\t      }\n195\t    });\n196\t}\n197\t"}]},"parent_tool_use_id":"toolu_01Rc1jZLz1bpJyVVhPKGgdgx","session_id":"c2800ecc-75a3-43b2-b3d8-396855aa3c3c","uuid":"6be4c0a2-852b-4a24-8f61-15867ef5a2e4","timestamp":"2026-04-03T03:10:44.165Z"}
