{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HDYYmy4fiuWv4KgecyLTQ3","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { join, resolve, dirname } from 'node:path';\n3\timport { fileURLToPath } from 'node:url';\n4\timport os from 'node:os';\n5\timport { parse } from 'yaml';\n6\timport { validateWorkflowSchema } from './schema-validate.js';\n7\timport { listDrivers } from './agents/drivers/factory.js';\n8\timport { listEmbeddedAgents, resolveAgent, AgentResolveError } from './agent-resolver.js';\n9\timport {\n10\t  resolveHierarchicalFlow,\n11\t  HierarchicalFlowError,\n12\t  BUILTIN_EPIC_FLOW_TASKS,\n13\t  type ExecutionConfig,\n14\t  type HierarchicalFlow,\n15\t} from './hierarchical-flow.js';\n16\t\n17\t// Re-export hierarchical flow types for consumers\n18\texport type { ExecutionConfig, HierarchicalFlow } from './hierarchical-flow.js';\n19\texport { BUILTIN_EPIC_FLOW_TASKS } from './hierarchical-flow.js';\n20\t\n21\tconst __filename = fileURLToPath(import.meta.url);\n22\tconst __dirname = dirname(__filename);\n23\t\n24\tconst TEMPLATES_DIR = resolve(__dirname, '../../templates/workflows');\n25\t\n26\t// --- Interfaces ---\n27\t\n28\texport interface ResolvedTask {\n29\t  agent: string | null;\n30\t  scope: 'per-story' | 'per-run' | 'per-epic';\n31\t  session: 'fresh' | 'continue';\n32\t  source_access: boolean;\n33\t  prompt_template?: string;\n34\t  input_contract?: Record<string, unknown>;\n35\t  output_contract?: Record<string, unknown>;\n36\t  max_budget_usd?: number;\n37\t  driver?: string;\n38\t  model?: string;\n39\t  plugins?: string[];\n40\t}\n41\t\n42\texport interface LoopBlock {\n43\t  loop: string[];\n44\t}\n45\t\n46\texport type FlowStep = string | LoopBlock;\n47\t\n48\texport interface ResolvedWorkflow {\n49\t  tasks: Record<string, ResolvedTask>;\n50\t  flow: FlowStep[];\n51\t  /** Execution configuration (parallel, isolation, merge strategy). */\n52\t  execution: ExecutionConfig;\n53\t  /** Story-level flow steps (normalized from `flow` or `story_flow`). */\n54\t  storyFlow: FlowStep[];\n55\t  /** Epic-level flow steps (empty if not defined). */\n56\t  epicFlow: FlowStep[];\n57\t}\n58\t\n59\t// --- Error Class ---\n60\t"}]},"parent_tool_use_id":"toolu_01P6VJWwxyDkdUjYM8CN6t2V","session_id":"8a461711-53e2-475a-88dd-c7013f6080c5","uuid":"10c50b19-fc0f-44b5-b7a8-1a0a72dddd42","timestamp":"2026-04-03T17:09:16.887Z"}
