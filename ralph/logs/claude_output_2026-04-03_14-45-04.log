{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Lqpi1RH8ZjMgCHzKrN5o1a","type":"tool_result","content":"870\t/**\n871\t * Execute a workflow sequentially: iterate through flow steps, dispatch tasks\n872\t * per-story or per-run, checkpoint state after each dispatch.\n873\t *\n874\t * Loop blocks execute iteratively until pass, max-iterations, or circuit-breaker.\n875\t *\n876\t * Returns an EngineResult summarizing the execution.\n877\t */\n878\texport async function executeWorkflow(config: EngineConfig): Promise<EngineResult> {\n879\t  const startMs = Date.now();\n880\t  const projectDir = config.projectDir ?? process.cwd();\n881\t  const errors: EngineError[] = [];\n882\t  let tasksCompleted = 0;\n883\t  const processedStories = new Set<string>();\n884\t\n885\t  // 1. Read or initialize workflow state\n886\t  let state = readWorkflowState(projectDir);\n887\t\n888\t  // Early exit: workflow already completed (AC #6)\n889\t  if (state.phase === 'completed') {\n890\t    return {\n891\t      success: true,\n892\t      tasksCompleted: 0,\n893\t      storiesProcessed: 0,\n894\t      errors: [],\n895\t      durationMs: 0,\n896\t    };\n897\t  }\n898\t\n899\t  state = {\n900\t    ...state,\n901\t    phase: 'executing',\n902\t    started: state.started || new Date().toISOString(),\n903\t    workflow_name: config.workflow.flow.filter((s) => typeof s === 'string').join(' -> '),\n904\t  };\n905\t  writeWorkflowState(state, projectDir);\n906\t\n907\t  // 1b. Pre-flight driver health check\n908\t  try {\n909\t    await checkDriverHealth(config.workflow);\n910\t  } catch (err: unknown) { // IGNORE: health check failure — record and abort\n911\t    const message = err instanceof Error ? err.message : String(err);\n912\t    state = { ...state, phase: 'failed' };\n913\t    const engineError: EngineError = {\n914\t      taskName: '__health_check__',\n915\t      storyKey: '__health_check__',\n916\t      code: 'HEALTH_CHECK',\n917\t      message,\n918\t    };\n919\t    errors.push(engineError);\n920\t    writeWorkflowState(state, projectDir);\n921\t    return {\n922\t      success: false,\n923\t      tasksCompleted: 0,\n924\t      storiesProcessed: 0,\n925\t      errors,\n926\t      durationMs: Date.now() - startMs,\n927\t    };\n928\t  }\n929\t\n930\t  // 2. Load work items\n931\t  const workItems = loadWorkItems(config.sprintStatusPath, config.issuesPath);\n932\t\n933\t  // 3. Iterate through flow steps\n934\t  let halted = false;\n935\t  for (const step of config.workflow.flow) {\n936\t    if (halted) break;\n937\t\n938\t    // Execute loop blocks\n939\t    if (isLoopBlock(step)) {\n940\t      const loopResult = await executeLoopBlock(step, state, config, workItems);\n941\t      state = loopResult.state;\n942\t      errors.push(...loopResult.errors);\n943\t      tasksCompleted += loopResult.tasksCompleted;\n944\t\n945\t      // Track processed stories from loop\n946\t      for (const item of workItems) {\n947\t        processedStories.add(item.key);\n948\t      }\n949\t\n950\t      if (loopResult.halted) {\n951\t        halted = true;\n952\t      }\n953\t\n954\t      // If loop ended with max-iterations or circuit-breaker, treat as failure\n955\t      if (state.phase === 'max-iterations' || state.phase === 'circuit-breaker') {\n956\t        halted = true;\n957\t      }\n958\t      continue;\n959\t    }\n960\t\n961\t    // step is a string task name\n962\t    const taskName = step;\n963\t    const task = config.workflow.tasks[taskName];\n964\t\n965\t    if (!task) {\n966\t      warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n967\t      continue;\n968\t    }\n969\t\n970\t    // Look up the agent definition\n971\t    const definition = config.agents[task.agent];\n972\t    if (!definition) {\n973\t      warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n974\t      continue;\n975\t    }\n976\t\n977\t    if (task.scope === 'per-run') {\n978\t      // Skip if already completed (crash recovery — AC #3)\n979\t      if (isTaskCompleted(state, taskName, PER_RUN_SENTINEL)) {\n980\t        warn(`workflow-engine: skipping completed task ${taskName} for ${PER_RUN_SENTINEL}`);\n981\t        continue;\n982\t      }\n983\t\n984\t      // Per-run: dispatch once with sentinel key\n985\t      try {\n986\t        state = await dispatchTask(task, taskName, PER_RUN_SENTINEL, definition, state, config);\n987\t        tasksCompleted++;\n988\t      } catch (err: unknown) {\n989\t        const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);"}]},"parent_tool_use_id":"toolu_01YBicm9mTokZCKuJz78on3G","session_id":"d2473842-56c4-49f2-ab43-68fabe9113bb","uuid":"590525e2-3980-4f79-b7fd-25cca483890a","timestamp":"2026-04-03T10:52:20.282Z"}
