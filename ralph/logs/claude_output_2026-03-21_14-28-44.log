{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014tu4xJELU7j9DhWPJgUfkX","type":"tool_result","content":"     1→#!/bin/bash\n     2→# codeharness: PreToolUse hook for Bash tool\n     3→# Blocks git commit if quality gates haven't passed.\n     4→# Must complete within 500ms (NFR1).\n     5→# Canonical pattern: exit 0 = allow, exit 2 = intentional block, never exit 1.\n     6→# Always output valid JSON. Fail open on errors.\n     7→\n     8→# Error trap: fail open on script errors — always produce valid JSON\n     9→trap 'echo \"{\\\"decision\\\": \\\"allow\\\"}\"; exit 0' ERR\n    10→\n    11→STATE_FILE=\".claude/codeharness.local.md\"\n    12→HARNESS_CLI=\"${CLAUDE_PLUGIN_ROOT}/bin/codeharness\"\n    13→\n    14→# Read the hook input from stdin\n    15→HOOK_INPUT=$(cat)\n    16→\n    17→# Only intercept git commit commands\n    18→COMMAND=$(echo \"$HOOK_INPUT\" | grep -o '\"command\"[[:space:]]*:[[:space:]]*\"[^\"]*\"' | head -1 | sed 's/.*\"command\"[[:space:]]*:[[:space:]]*\"//' | sed 's/\"$//' || true)\n    19→\n    20→# Check if this is a git commit command\n    21→case \"$COMMAND\" in\n    22→  *\"git commit\"*|*\"git -c\"*\"commit\"*)\n    23→    ;;\n    24→  *)\n    25→    # Not a commit command, allow it\n    26→    exit 0\n    27→    ;;\n    28→esac\n    29→\n    30→# If harness not initialized, allow (fail open)\n    31→if [ ! -f \"$STATE_FILE\" ]; then\n    32→  echo \"[WARN] State file not found — allowing commit\" >&2\n    33→  echo '{\"decision\": \"allow\"}'\n    34→  exit 0\n    35→fi\n    36→\n    37→# Read state values using get_state helper\n    38→get_state() {\n    39→  local key=\"$1\"\n    40→  local value\n    41→  value=$(sed -n '/^---$/,/^---$/p' \"$STATE_FILE\" | grep \"^  ${key}:\" | sed \"s/^  ${key}: *//\" || true)\n    42→  # Trim whitespace and quotes\n    43→  value=$(echo \"$value\" | tr -d '\"' | tr -d \"'\" | xargs 2>/dev/null || echo \"$value\")\n    44→  echo \"$value\"\n    45→}\n    46→\n    47→TESTS_PASSED=$(get_state \"tests_passed\")\n    48→COVERAGE_MET=$(get_state \"coverage_met\")\n    49→VERIFICATION_RUN=$(get_state \"verification_run\")\n    50→\n    51→# Build failure report\n    52→FAILURES=\"\"\n    53→FAIL_COUNT=0\n    54→\n    55→if [ \"$TESTS_PASSED\" != \"true\" ]; then\n    56→  FAILURES=\"${FAILURES}\\\\n  tests_passed: ${TESTS_PASSED:-false}\"\n    57→  FAIL_COUNT=$((FAIL_COUNT + 1))\n    58→fi\n    59→\n    60→if [ \"$COVERAGE_MET\" != \"true\" ]; then\n    61→  FAILURES=\"${FAILURES}\\\\n  coverage_met: ${COVERAGE_MET:-false}\"\n    62→  FAIL_COUNT=$((FAIL_COUNT + 1))\n    63→fi\n    64→\n    65→if [ \"$VERIFICATION_RUN\" != \"true\" ]; then\n    66→  FAILURES=\"${FAILURES}\\\\n  verification_run: ${VERIFICATION_RUN:-false}\"\n    67→  FAIL_COUNT=$((FAIL_COUNT + 1))\n    68→fi\n    69→\n    70→if [ \"$FAIL_COUNT\" -gt 0 ]; then\n    71→  # Build status line for all flags (show which passed and which failed)\n    72→  STATUS_LINE=\"\\\\n  tests_passed: ${TESTS_PASSED:-false}\\\\n  coverage_met: ${COVERAGE_MET:-false}\\\\n  verification_run: ${VERIFICATION_RUN:-false}\"\n    73→  echo \"{\\\"decision\\\": \\\"block\\\", \\\"reason\\\": \\\"Quality gates not met.${STATUS_LINE}\\\\n\\\\n-> Run tests before committing.\\\"}\"\n    74→  exit 2\n    75→fi\n    76→\n    77→# Check per-file coverage floor (80% minimum)\n    78→if [ -x \"$HARNESS_CLI\" ]; then\n    79→  PER_FILE_RESULT=$(\"$HARNESS_CLI\" coverage --check-only --min-file 80 --json 2>/dev/null || true)\n    80→  if [ -n \"$PER_FILE_RESULT\" ]; then\n    81→    VIOLATION_COUNT=$(echo \"$PER_FILE_RESULT\" | grep -o '\"violationCount\"[[:space:]]*:[[:space:]]*[0-9]*' | grep -o '[0-9]*$' || echo \"0\")\n    82→    if [ \"$VIOLATION_COUNT\" -gt 0 ]; then\n    83→      echo \"{\\\"decision\\\": \\\"block\\\", \\\"reason\\\": \\\"${VIOLATION_COUNT} file(s) below 80% statement coverage.\\\\n\\\\n-> Run: codeharness coverage --min-file 80\\\\n-> Fix uncovered files before committing.\\\"}\"\n    84→      exit 2\n    85→    fi\n    86→  fi\n    87→fi\n    88→\n    89→# Check observability coverage gate (uses cached state — no Semgrep re-run)\n    90→if [ -x \"$HARNESS_CLI\" ]; then\n    91→  OBS_RESULT=$(\"$HARNESS_CLI\" observability-gate --json 2>/dev/null || true)\n    92→  if [ -n \"$OBS_RESULT\" ]; then\n    93→    OBS_PASSED=$(echo \"$OBS_RESULT\" | grep -o '\"passed\"[[:space:]]*:[[:space:]]*[a-z]*' | grep -o '[a-z]*$' || echo \"true\")\n    94→    if [ \"$OBS_PASSED\" = \"false\" ]; then\n    95→      OBS_STATIC_CURRENT=$(echo \"$OBS_RESULT\" | grep -o '\"current\"[[:space:]]*:[[:space:]]*[0-9.]*' | head -1 | grep -o '[0-9.]*$' || echo \"?\")\n    96→      OBS_STATIC_TARGET=$(echo \"$OBS_RESULT\" | grep -o '\"target\"[[:space:]]*:[[:space:]]*[0-9.]*' | head -1 | grep -o '[0-9.]*$' || echo \"?\")\n    97→      # Extract gap details (top 5)\n    98→      OBS_GAPS=\"\"\n    99→      GAP_COUNT=$(echo \"$OBS_RESULT\" | grep -o '\"file\"' | wc -l | tr -d ' ' || echo \"0\")\n   100→      if [ \"$GAP_COUNT\" -gt 0 ]; then\n   101→        OBS_GAPS=\"\\\\n\\\\nGaps found (${GAP_COUNT} total) — run: codeharness observability-gate\"\n   102→      fi\n   103→      echo \"{\\\"decision\\\": \\\"block\\\", \\\"reason\\\": \\\"Observability coverage below target: ${OBS_STATIC_CURRENT}% / ${OBS_STATIC_TARGET}% required.${OBS_GAPS}\\\\n\\\\n-> Add logging to flagged functions.\\\\n-> See: patches/observability/ for rule definitions.\\\"}\"\n   104→      exit 2\n   105→    fi\n   106→  fi\n   107→  # If OBS_RESULT is empty or command failed, fail open (allow commit)\n   108→fi\n   109→\n   110→echo '{\"decision\": \"allow\"}'\n   111→exit 0\n   112→"}]},"parent_tool_use_id":null,"session_id":"3302fb5a-267f-479c-8444-7f3205e5b9bb","uuid":"4b9a6ba4-1ec8-44ae-8ffc-26f70dc6652c","timestamp":"2026-03-21T10:33:31.158Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ivintik/dev/personal/codeharness/hooks/pre-commit-gate.sh","content":"#!/bin/bash\n# codeharness: PreToolUse hook for Bash tool\n# Blocks git commit if quality gates haven't passed.\n# Must complete within 500ms (NFR1).\n# Canonical pattern: exit 0 = allow, exit 2 = intentional block, never exit 1.\n# Always output valid JSON. Fail open on errors.\n\n# Error trap: fail open on script errors — always produce valid JSON\ntrap 'echo \"{\\\"decision\\\": \\\"allow\\\"}\"; exit 0' ERR\n\nSTATE_FILE=\".claude/codeharness.local.md\"\nHARNESS_CLI=\"${CLAUDE_PLUGIN_ROOT}/bin/codeharness\"\n\n# Read the hook input from stdin\nHOOK_INPUT=$(cat)\n\n# Only intercept git commit commands\nCOMMAND=$(echo \"$HOOK_INPUT\" | grep -o '\"command\"[[:space:]]*:[[:space:]]*\"[^\"]*\"' | head -1 | sed 's/.*\"command\"[[:space:]]*:[[:space:]]*\"//' | sed 's/\"$//' || true)\n\n# Check if this is a git commit command\ncase \"$COMMAND\" in\n  *\"git commit\"*|*\"git -c\"*\"commit\"*)\n    ;;\n  *)\n    # Not a commit command, allow it\n    exit 0\n    ;;\nesac\n\n# If harness not initialized, allow (fail open)\nif [ ! -f \"$STATE_FILE\" ]; then\n  echo \"[WARN] State file not found — allowing commit\" >&2\n  echo '{\"decision\": \"allow\"}'\n  exit 0\nfi\n\n# Read state values using get_state helper\nget_state() {\n  local key=\"$1\"\n  local value\n  value=$(sed -n '/^---$/,/^---$/p' \"$STATE_FILE\" | grep \"^  ${key}:\" | sed \"s/^  ${key}: *//\" || true)\n  # Trim whitespace and quotes\n  value=$(echo \"$value\" | tr -d '\"' | tr -d \"'\" | xargs 2>/dev/null || echo \"$value\")\n  echo \"$value\"\n}\n\nTESTS_PASSED=$(get_state \"tests_passed\")\nCOVERAGE_MET=$(get_state \"coverage_met\")\nVERIFICATION_RUN=$(get_state \"verification_run\")\n\n# Build failure report\nFAILURES=\"\"\nFAIL_COUNT=0\n\nif [ \"$TESTS_PASSED\" != \"true\" ]; then\n  FAILURES=\"${FAILURES}\\\\n  tests_passed: ${TESTS_PASSED:-false}\"\n  FAIL_COUNT=$((FAIL_COUNT + 1))\nfi\n\nif [ \"$COVERAGE_MET\" != \"true\" ]; then\n  FAILURES=\"${FAILURES}\\\\n  coverage_met: ${COVERAGE_MET:-false}\"\n  FAIL_COUNT=$((FAIL_COUNT + 1))\nfi\n\nif [ \"$VERIFICATION_RUN\" != \"true\" ]; then\n  FAILURES=\"${FAILURES}\\\\n  verification_run: ${VERIFICATION_RUN:-false}\"\n  FAIL_COUNT=$((FAIL_COUNT + 1))\nfi\n\nif [ \"$FAIL_COUNT\" -gt 0 ]; then\n  # Build status line for all flags (show which passed and which failed)\n  STATUS_LINE=\"\\\\n  tests_passed: ${TESTS_PASSED:-false}\\\\n  coverage_met: ${COVERAGE_MET:-false}\\\\n  verification_run: ${VERIFICATION_RUN:-false}\"\n  echo \"{\\\"decision\\\": \\\"block\\\", \\\"reason\\\": \\\"Quality gates not met.${STATUS_LINE}\\\\n\\\\n-> Run tests before committing.\\\"}\"\n  exit 2\nfi\n\n# Check per-file coverage floor (80% minimum)\nif [ -x \"$HARNESS_CLI\" ]; then\n  PER_FILE_RESULT=$(\"$HARNESS_CLI\" coverage --check-only --min-file 80 --json 2>/dev/null || true)\n  if [ -n \"$PER_FILE_RESULT\" ]; then\n    VIOLATION_COUNT=$(echo \"$PER_FILE_RESULT\" | grep -o '\"violationCount\"[[:space:]]*:[[:space:]]*[0-9]*' | grep -o '[0-9]*$' || echo \"0\")\n    if [ \"$VIOLATION_COUNT\" -gt 0 ]; then\n      echo \"{\\\"decision\\\": \\\"block\\\", \\\"reason\\\": \\\"${VIOLATION_COUNT} file(s) below 80% statement coverage.\\\\n\\\\n-> Run: codeharness coverage --min-file 80\\\\n-> Fix uncovered files before committing.\\\"}\"\n      exit 2\n    fi\n  fi\nfi\n\n# Check observability coverage gate (uses cached state — no Semgrep re-run)\nif [ -x \"$HARNESS_CLI\" ]; then\n  OBS_RESULT=$(\"$HARNESS_CLI\" observability-gate --json 2>/dev/null || true)\n  if [ -n \"$OBS_RESULT\" ]; then\n    OBS_PASSED=$(echo \"$OBS_RESULT\" | grep -o '\"passed\"[[:space:]]*:[[:space:]]*[a-z]*' | grep -o '[a-z]*$' || echo \"true\")\n    if [ \"$OBS_PASSED\" = \"false\" ]; then\n      OBS_STATIC_CURRENT=$(echo \"$OBS_RESULT\" | grep -o '\"current\"[[:space:]]*:[[:space:]]*[0-9.]*' | head -1 | grep -o '[0-9.]*$' || echo \"?\")\n      OBS_STATIC_TARGET=$(echo \"$OBS_RESULT\" | grep -o '\"target\"[[:space:]]*:[[:space:]]*[0-9.]*' | head -1 | grep -o '[0-9.]*$' || echo \"?\")\n      # Extract gap details (top 5)\n      OBS_GAPS=\"\"\n      GAP_COUNT=$(echo \"$OBS_RESULT\" | grep -o '\"file\"' | wc -l | tr -d ' ' || echo \"0\")\n      if [ \"$GAP_COUNT\" -gt 0 ]; then\n        OBS_GAPS=\"\\\\n\\\\nGaps found (${GAP_COUNT} total) — run: codeharness observability-gate\"\n      fi\n      echo \"{\\\"decision\\\": \\\"block\\\", \\\"reason\\\": \\\"Observability coverage below target: ${OBS_STATIC_CURRENT}% / ${OBS_STATIC_TARGET}% required.${OBS_GAPS}\\\\n\\\\n-> Add logging to flagged functions.\\\\n-> See: patches/observability/ for rule definitions.\\\"}\"\n      exit 2\n    fi\n  fi\n  # If OBS_RESULT is empty or command failed, fail open (allow commit)\nfi\n\necho '{\"decision\": \"allow\"}'\nexit 0\n","numLines":112,"startLine":1,"totalLines":112}}}
