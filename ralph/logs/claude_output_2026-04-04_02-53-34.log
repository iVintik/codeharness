{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HYxrsSFXgiSfjJaba9kypp","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\t\n3\timport {\n4\t  checkEpicCompletion,\n5\t  getEpicStories,\n6\t  transitionEpicState,\n7\t  EpicCompletionError,\n8\t  VALID_TRANSITIONS,\n9\t  type EpicLifecycleStatus,\n10\t} from '../epic-completion.js';\n11\t\n12\timport {\n13\t  buildSprintState,\n14\t  buildStoryEntry,\n15\t  buildEpicState,\n16\t} from './fixtures/state-builders.js';\n17\t\n18\tdescribe('epic-completion', () => {\n19\t  // --- EpicLifecycleStatus type ---\n20\t\n21\t  describe('EpicLifecycleStatus', () => {\n22\t    it('includes all six values', () => {\n23\t      const allStatuses: EpicLifecycleStatus[] = [\n24\t        'in-progress',\n25\t        'completing',\n26\t        'merging',\n27\t        'validating',\n28\t        'done',\n29\t        'failed',\n30\t      ];\n31\t      // Compile-time check: if any status is missing from the type, this won't compile.\n32\t      // Runtime check: we verify the array has exactly 6 entries.\n33\t      expect(allStatuses).toHaveLength(6);\n34\t    });\n35\t  });\n36\t\n37\t  // --- VALID_TRANSITIONS ---\n38\t\n39\t  describe('VALID_TRANSITIONS', () => {\n40\t    it('encodes the correct state machine', () => {\n41\t      expect(VALID_TRANSITIONS).toEqual({\n42\t        'in-progress': ['completing'],\n43\t        'completing': ['merging', 'failed'],\n44\t        'merging': ['validating', 'failed'],\n45\t        'validating': ['done', 'failed'],\n46\t      });\n47\t    });\n48\t\n49\t    it('does not allow transitions from done or failed', () => {\n50\t      expect(VALID_TRANSITIONS['done']).toBeUndefined();\n51\t      expect(VALID_TRANSITIONS['failed']).toBeUndefined();\n52\t    });\n53\t  });\n54\t\n55\t  // --- getEpicStories ---\n56\t\n57\t  describe('getEpicStories', () => {\n58\t    it('filters correctly by epic ID prefix', () => {\n59\t      const state = buildSprintState({\n60\t        stories: {\n61\t          '19-1-foo': buildStoryEntry({ status: 'done' }),\n62\t          '19-2-bar': buildStoryEntry({ status: 'in-progress' }),\n63\t          '20-1-baz': buildStoryEntry({ status: 'backlog' }),\n64\t        },\n65\t      });\n66\t\n67\t      const result = getEpicStories(state, '19');\n68\t      expect(result).toEqual(['19-1-foo', '19-2-bar']);\n69\t    });\n70\t\n71\t    it('does not include stories from other epics', () => {\n72\t      const state = buildSprintState({\n73\t        stories: {\n74\t          '19-1-foo': buildStoryEntry(),\n75\t          '20-1-baz': buildStoryEntry(),\n76\t          '1-1-qux': buildStoryEntry(),\n77\t        },\n78\t      });\n79\t\n80\t      const result = getEpicStories(state, '19');\n81\t      expect(result).not.toContain('20-1-baz');\n82\t      expect(result).not.toContain('1-1-qux');\n83\t    });\n84\t\n85\t    it('does not match epic 1 against story 19-1-foo', () => {\n86\t      const state = buildSprintState({\n87\t        stories: {\n88\t          '19-1-foo': buildStoryEntry(),\n89\t        },\n90\t      });\n91\t\n92\t      expect(getEpicStories(state, '1')).toEqual([]);\n93\t    });\n94\t\n95\t    it('returns empty array when no stories exist', () => {\n96\t      const state = buildSprintState({ stories: {} });\n97\t      expect(getEpicStories(state, '19')).toEqual([]);\n98\t    });\n99\t\n100\t    it('skips story keys with no dash', () => {\n101\t      const state = buildSprintState({\n102\t        stories: {\n103\t          'orphan': buildStoryEntry(),\n104\t          '19-1-foo': buildStoryEntry(),\n105\t        },\n106\t      });\n107\t\n108\t      expect(getEpicStories(state, '19')).toEqual(['19-1-foo']);\n109\t    });\n110\t  });\n111\t\n112\t  // --- checkEpicCompletion ---\n113\t\n114\t  describe('checkEpicCompletion', () => {\n115\t    it('returns true when all stories are done', () => {\n116\t      const state = buildSprintState({\n117\t        epics: { 'epic-19': buildEpicState({ storiesTotal: 2 }) },\n118\t        stories: {\n119\t          '19-1-foo': buildStoryEntry({ status: 'done' }),\n120\t          '19-2-bar': buildStoryEntry({ status: 'done' }),\n121\t        },\n122\t      });\n123\t\n124\t      expect(checkEpicCompletion(state, '19')).toBe(true);\n125\t    });\n126\t\n127\t    it('returns false when any story is not done', () => {\n128\t      const state = buildSprintState({\n129\t        epics: { 'epic-19': buildEpicState({ storiesTotal: 2 }) },\n130\t        stories: {\n131\t          '19-1-foo': buildStoryEntry({ status: 'done' }),\n132\t          '19-2-bar': buildStoryEntry({ status: 'in-progress' }),\n133\t        },\n134\t      });\n135\t\n136\t      expect(checkEpicCompletion(state, '19')).toBe(false);\n137\t    });\n138\t\n139\t    it('returns false for epic with zero stories', () => {\n140\t      const state = buildSprintState({\n141\t        epics: { 'epic-19': buildEpicState({ storiesTotal: 0 }) },\n142\t        stories: {},\n143\t      });\n144\t\n145\t      expect(checkEpicCompletion(state, '19')).toBe(false);\n146\t    });\n147\t\n148\t    it('throws EpicCompletionError for non-existent epic', () => {\n149\t      const state = buildSprintState({ epics: {} });\n150\t\n151\t      expect(() => checkEpicCompletion(state, '99')).toThrow(EpicCompletionError);\n152\t      expect(() => checkEpicCompletion(state, '99')).toThrow('Epic epic-99 not found in state');\n153\t    });\n154\t  });\n155\t\n156\t  // --- transitionEpicState ---\n157\t\n158\t  describe('transitionEpicState', () => {\n159\t    it('returns updated state with new status', () => {\n160\t      const state = buildSprintState({\n161\t        epics: { 'epic-19': buildEpicState({ status: 'in-progress', storiesTotal: 2 }) },\n162\t        stories: {\n163\t          '19-1-foo': buildStoryEntry({ status: 'done' }),\n164\t          '19-2-bar': buildStoryEntry({ status: 'done' }),\n165\t        },\n166\t      });\n167\t\n168\t      const result = transitionEpicState(state, '19', 'completing');\n169\t      expect(result.epics['epic-19'].status).toBe('completing');\n170\t    });\n171\t\n172\t    it('updates storiesDone on completing transition', () => {\n173\t      const state = buildSprintState({\n174\t        epics: { 'epic-19': buildEpicState({ status: 'in-progress', storiesTotal: 3, storiesDone: 0 }) },\n175\t        stories: {\n176\t          '19-1-foo': buildStoryEntry({ status: 'done' }),\n177\t          '19-2-bar': buildStoryEntry({ status: 'done' }),\n178\t          '19-3-baz': buildStoryEntry({ status: 'in-progress' }),\n179\t        },\n180\t      });\n181\t\n182\t      const result = transitionEpicState(state, '19', 'completing');\n183\t      expect(result.epics['epic-19'].storiesDone).toBe(2);\n184\t    });\n185\t\n186\t    it('does not update storiesDone on non-completing transitions', () => {\n187\t      const state = buildSprintState({\n188\t        epics: { 'epic-19': buildEpicState({ status: 'completing', storiesTotal: 2, storiesDone: 2 }) },\n189\t        stories: {\n190\t          '19-1-foo': buildStoryEntry({ status: 'done' }),\n191\t          '19-2-bar': buildStoryEntry({ status: 'done' }),\n192\t        },\n193\t      });\n194\t\n195\t      const result = transitionEpicState(state, '19', 'merging');\n196\t      expect(result.epics['epic-19'].storiesDone).toBe(2);\n197\t    });\n198\t\n199\t    it('throws on invalid transition', () => {\n200\t      const state = buildSprintState({\n201\t        epics: { 'epic-19': buildEpicState({ status: 'done', storiesTotal: 2 }) },\n202\t      });\n203\t\n204\t      expect(() => transitionEpicState(state, '19', 'in-progress')).toThrow(EpicCompletionError);\n205\t      expect(() => transitionEpicState(state, '19', 'in-progress')).toThrow(\n206\t        'Invalid transition: done → in-progress',\n207\t      );\n208\t    });\n209\t\n210\t    it('throws for non-existent epic', () => {\n211\t      const state = buildSprintState({ epics: {} });\n212\t\n213\t      expect(() => transitionEpicState(state, '99', 'completing')).toThrow(EpicCompletionError);\n214\t      expect(() => transitionEpicState(state, '99', 'completing')).toThrow(\n215\t        'Epic epic-99 not found in state',\n216\t      );\n217\t    });\n218\t\n219\t    it('does not mutate the original state', () => {\n220\t      const state = buildSprintState({\n221\t        epics: { 'epic-19': buildEpicState({ status: 'in-progress', storiesTotal: 1 }) },\n222\t        stories: {\n223\t          '19-1-foo': buildStoryEntry({ status: 'done' }),\n224\t        },\n225\t      });\n226\t\n227\t      const result = transitionEpicState(state, '19', 'completing');\n228\t      expect(state.epics['epic-19'].status).toBe('in-progress');\n229\t      expect(result.epics['epic-19'].status).toBe('completing');\n230\t      expect(state).not.toBe(result);\n231\t    });\n232\t\n233\t    it('allows completing → failed transition', () => {\n234\t      const state = buildSprintState({\n235\t        epics: { 'epic-19': buildEpicState({ status: 'completing' }) },\n236\t      });\n237\t\n238\t      const result = transitionEpicState(state, '19', 'failed');\n239\t      expect(result.epics['epic-19'].status).toBe('failed');\n240\t    });\n241\t\n242\t    it('allows merging → failed transition', () => {\n243\t      const state = buildSprintState({\n244\t        epics: { 'epic-19': buildEpicState({ status: 'merging' }) },\n245\t      });\n246\t\n247\t      const result = transitionEpicState(state, '19', 'failed');\n248\t      expect(result.epics['epic-19'].status).toBe('failed');\n249\t    });\n250\t\n251\t    it('allows validating → failed transition', () => {\n252\t      const state = buildSprintState({\n253\t        epics: { 'epic-19': buildEpicState({ status: 'validating' }) },\n254\t      });\n255\t\n256\t      const result = transitionEpicState(state, '19', 'failed');\n257\t      expect(result.epics['epic-19'].status).toBe('failed');\n258\t    });\n259\t  });\n260\t\n261\t  // --- Exports ---\n262\t\n263\t  describe('exports', () => {\n264\t    it('exports checkEpicCompletion, getEpicStories, transitionEpicState', () => {\n265\t      expect(typeof checkEpicCompletion).toBe('function');\n266\t      expect(typeof getEpicStories).toBe('function');\n267\t      expect(typeof transitionEpicState).toBe('function');\n268\t    });\n269\t\n270\t    it('exports EpicCompletionError class', () => {\n271\t      const err = new EpicCompletionError('test');\n272\t      expect(err).toBeInstanceOf(Error);\n273\t      expect(err.name).toBe('EpicCompletionError');\n274\t    });\n275\t\n276\t    it('exports VALID_TRANSITIONS', () => {\n277\t      expect(typeof VALID_TRANSITIONS).toBe('object');\n278\t    });\n279\t  });\n280\t});\n281\t"}]},"parent_tool_use_id":"toolu_01KxDszVE1hewisgsfsHW1D6","session_id":"cb820906-0735-4f53-a851-3960824caad6","uuid":"2318e803-dd3b-4066-aad2-f6dfee9f9bc5","timestamp":"2026-04-03T22:59:49.502Z"}
