{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0139iNV8hLB4v97rrSJLXts3","type":"tool_result","content":"     1→import { Command } from 'commander';\n     2→import { registerInitCommand } from './commands/init.js';\n     3→import { registerBridgeCommand } from './commands/bridge.js';\n     4→import { registerRunCommand } from './commands/run.js';\n     5→import { registerVerifyCommand } from './commands/verify.js';\n     6→import { registerStatusCommand } from './commands/status.js';\n     7→import { registerOnboardCommand } from './commands/onboard.js';\n     8→import { registerTeardownCommand } from './commands/teardown.js';\n     9→import { registerStateCommand } from './commands/state.js';\n    10→import { registerSyncCommand } from './commands/sync.js';\n    11→import { registerCoverageCommand } from './commands/coverage.js';\n    12→import { registerDocHealthCommand } from './commands/doc-health.js';\n    13→import { registerStackCommand } from './commands/stack.js';\n    14→import { registerQueryCommand } from './commands/query.js';\n    15→import { registerRetroImportCommand } from './commands/retro-import.js';\n    16→import { registerGithubImportCommand } from './commands/github-import.js';\n    17→import { registerVerifyEnvCommand } from './commands/verify-env.js';\n    18→import { registerRetryCommand } from './commands/retry.js';\n    19→import { registerTimeoutReportCommand } from './commands/timeout-report.js';\n    20→import { registerValidateStateCommand } from './commands/validate-state.js';\n    21→import { registerValidateCommand } from './commands/validate.js';\n    22→import { registerProgressCommand } from './commands/progress.js';\n    23→import { registerObservabilityGateCommand } from './commands/observability-gate.js';\n    24→\n    25→declare const __PKG_VERSION__: string;\n    26→const VERSION = typeof __PKG_VERSION__ !== 'undefined' ? __PKG_VERSION__ : '0.0.0-dev';\n    27→\n    28→export function createProgram(): Command {\n    29→  const program = new Command();\n    30→\n    31→  program\n    32→    .name('codeharness')\n    33→    .description('Makes autonomous coding agents produce software that actually works')\n    34→    .version(VERSION)\n    35→    .option('--json', 'Output in machine-readable JSON format');\n    36→\n    37→  registerInitCommand(program);\n    38→  registerBridgeCommand(program);\n    39→  registerRunCommand(program);\n    40→  registerVerifyCommand(program);\n    41→  registerStatusCommand(program);\n    42→  registerOnboardCommand(program);\n    43→  registerTeardownCommand(program);\n    44→  registerStateCommand(program);\n    45→  registerSyncCommand(program);\n    46→  registerCoverageCommand(program);\n    47→  registerDocHealthCommand(program);\n    48→  registerStackCommand(program);\n    49→  registerQueryCommand(program);\n    50→  registerRetroImportCommand(program);\n    51→  registerGithubImportCommand(program);\n    52→  registerVerifyEnvCommand(program);\n    53→  registerRetryCommand(program);\n    54→  registerTimeoutReportCommand(program);\n    55→  registerValidateStateCommand(program);\n    56→  registerValidateCommand(program);\n    57→  registerProgressCommand(program);\n    58→  registerObservabilityGateCommand(program);\n    59→\n    60→  return program;\n    61→}\n    62→\n    63→// Only parse when running as CLI entry point, not when imported in tests\n    64→if (!process.env['VITEST']) {\n    65→  const program = createProgram();\n    66→  program.parse(process.argv);\n    67→}\n    68→"}]},"parent_tool_use_id":"toolu_01L7x1Zkv5Yv1DsfgSndzqDQ","session_id":"f7a66acd-0cc1-40de-a592-d59e75273c0b","uuid":"f9e8a17c-fa71-4624-89d2-dc9659c8162e","timestamp":"2026-03-20T06:00:18.400Z"}
