   expect(dispatchCount).toBe(4);\n1517\t\n1518\t    // Verify circuit breaker was set via evaluateProgress, not mock mutation\n1519\t    expect(lastWrittenState).not.toBeNull();\n1520\t    expect(lastWrittenState!.circuit_breaker.triggered).toBe(true);\n1521\t    expect(lastWrittenState!.circuit_breaker.reason).toBe('score-stagnation');\n1522\t    expect(lastWrittenState!.circuit_breaker.score_history).toEqual([1, 1]);\n1523\t    expect(lastWrittenState!.phase).toBe('circuit-breaker');\n1524\t  });\n1525\t\n1526\t  it('injects findings into retry prompt for failed stories (AC #5)', async () => {\n1527\t    const dispatches: string[] = [];\n1528\t    let callCount = 0;\n1529\t\n1530\t    mockDriverDispatch.mockImplementation((opts: { prompt: string }) => {\n1531\t      callCount++;\n1532\t      dispatches.push(opts.prompt);\n1533\t\n1534\t      if (opts.prompt.includes('Execute task')) {\n1535\t        // First verify: fail, second verify: pass\n1536\t        if (callCount <= 2) {\n1537\t          return makeDriverStream(makeFailVerdict(), 'sess-v');\n1538\t        }\n1539\t        return makeDriverStream(makePassVerdict(), 'sess-v');\n1540\t      }\n1541\t      return makeDriverStream('ok', 'sess-r');\n1542\t    });\n1543\t\n1544\t    mockParse.mockReturnValue({\n1545\t      development_status: { '3-1-foo': 'ready-for-dev' },\n1546\t    });\n1547\t\n1548\t    const config = makeConfig({\n1549\t      workflow: {\n1550\t        tasks: {\n1551\t          retry: makeTask({ scope: 'per-story' }),\n1552\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n1553\t        },\n1554\t        flow: [{ loop: ['retry', 'verify'] }],\n1555\t      },\n1556\t    });\n1557\t\n1558\t    await executeWorkflow(config);\n1559\t\n1560\t    // Second retry prompt (iteration 2) should contain findings\n1561\t    const secondRetryPrompt = dispatches[2]; // [0]=retry, [1]=verify, [2]=retry(with findings)\n1562\t    expect(secondRetryPrompt).toContain('Retry story 3-1-foo