ured yet -->',\n   274→      '',\n   275→      '## AC 3: PENDING',\n   276→      '',\n   277→      '> Third AC',\n   278→      '',\n   279→      '<!-- No evidence captured yet -->',\n   280→    ].join('\\n'));\n   281→\n   282→    const result = validateProofQuality(path);\n   283→    expect(result).toMatchObject({ verified: 0, pending: 3, escalated: 0, total: 3, passed: false });\n   284→  });\n   285→\n   286→  it('returns all verified for fully verified proof (all showboat exec blocks)', () => {\n   287→    const path = join(testDir, 'proof.md');\n   288→    writeFileSync(path, [\n   289→      '# Proof: test-story',\n   290→      '',\n   291→      '## AC 1: PASS',\n   292→      '',\n   293→      '> First AC',\n   294→      '',\n   295→      '<!-- showboat exec: codeharness verify --story test -->',\n   296→      '```',\n   297→      '[OK] verified',\n   298→      '```',\n   299→      '<!-- /showboat exec -->',\n   300→      '',\n   301→      '## AC 2: PASS',\n   302→      '',\n   303→      '> Second AC',\n   304→      '',\n   305→      '<!-- showboat exec: cat file.txt -->',\n   306→      '```',\n   307→      'content',\n   308→      '```',\n   309→      '<!-- /showboat exec -->',\n   310→    ].join('\\n'));\n   311→\n   312→    const result = validateProofQuality(path);\n   313→    expect(result).toMatchObject({ verified: 2, pending: 0, escalated: 0, total: 2, passed: true });\n   314→  });\n   315→\n   316→  it('returns passed=false for mixed proof (some verified, some PENDING)', () => {\n   317→    const path = join(testDir, 'proof.md');\n   318→    writeFileSync(path, [\n   319→      '# Proof: test-story',\n   320→      '',\n   321→      '## AC 1: PASS',\n   322→      '',\n   323→      '> First AC',\n   324→      '',\n   325→      '<!-- showboat exec: codeharness verify -->',\n   326→      '```',\n   327→      'ok',\n   328→      '```',\n   329→      '<!-- /showboat exec -->',\n   330→      '',\n   331→      '## AC 2: PENDING',\n   332→      '',\n   333→      '> Second AC',\n   334→      '',\n   335→      '<!-- No evidence captured yet -->',\n   336→    ].join('\\n'));\n   337→\n   338→    const result = validateProofQuality(path);\n   339→    expect(result).toMatchObject({ verified: 1, pending: 1, escalated: 0, total: 2, passed: false });\n   340→  });\n   341→\n   342→  it('considers showboat image markers as verified evidence', () => {\n   343→    const path = join(testDir, 'proof.md');\n   344→    writeFileSync(path, [\n   345→      '# Proof: test-story',\n   346→      '',\n   347→      '## AC 1: PASS',\n   348→      '',\n   349→      '> First AC',\n   350→      '',\n   351→      '<!-- showboat image: screenshots/test.png -->',\n   352→    ].join('\\n'));\n   353→\n   354→    const result = validateProofQuality(path);\n   355→    expect(result).toMatchObject({ verified: 1, pending: 0, escalated: 0, total: 1, passed: true });\n   356→  });\n   357→\n   358→  it('returns total=0 and passed=false for file with no AC sections', () => {\n   359→    const path = join(testDir, 'proof.md');\n   360→    writeFileSync(path, '# Proof: test-story\\n\\nNo AC sections here.');\n   361→\n   362→    const result = validateProofQuality(path);\n   363→    expect(result).toMatchObject({ verified: 0, pending: 0, escalated: 0, total: 0, passed: false });\n   364→  });\n   365→\n   366→  it('recognises showboat native format (bash + output code blocks) as evidence', () => {\n   367→    const path = join(testDir, 'proof.md');\n   368→    writeFileSync(path, [\n   369→      '## AC 1: Evidence via showboat exec',\n   370→      '',\n   371→      '> AC description',\n   372→      '',\n   373→      '```bash',\n   374→      'node dist/index.js verify --story test',\n   375→      '```',\n   376→      '',\n   377→      '```output',\n   378→      '[FAIL] Proof quality check failed',\n   379→      '```',\n   380→      '',\n   381→      '## AC 2: Also showboat native',\n   382→      '',\n   383→      '```shell',\n   384→      'cat file.txt',\n   385→      '```',\n   386→      '',\n   387→      '```output',\n   388→      'contents here',\n   389→      '```',\n   390→    ].join('\\n'));\n   391→\n   392→    const result = validateProofQuality(path);\n   393→    expect(result).toMatchObject({ verified: 2, pending: 0, escalated: 0, total: 2, blackBoxPass: false, passed: false });\n   394→  });\n   395→\n   396→  it('counts [FAIL] verdict outside code blocks as pending (not verified)', () => {\n   397→    const path = join(testDir, 'proof.md');\n   398→    writeFileSync(path, [\n   399→      '## AC 1: Verified',\n   400→      '',\n   401→      '> First AC',\n   402→      '',\n   403→      '<!-- showboat exec: codeharness verify -->',\n   404→      '```',\n   405→      'ok',\n   406→      '```',\n   407→      '<!-- /showboat exec -->',\n   408→      '',\n   409→      '## AC 2: Failed',\n   410→      '',\n   411→      '> Second AC',\n   412→      '',\n   413→      '[FAIL] Command output did not match expected value',\n   414→      '',\n   415→    ].join('\\n'));\n   416→\n   417→    const result = validateProofQuality(path);\n   418→    expect(result).toMatchObject({ verified: 1, pending: 1, escalated: 0, total: 2, passed: false });\n   419→  });\n   420→\n   421→  it('does not treat [FAIL] inside code blocks as a verdict', () => {\n   422→    const path = join(testDir, 'proof.md');\n   423→    writeFileSync(path, [\n   424→      '## AC 1: Evidence with FAIL in output',\n   425→      '',\n   426→      '> AC description',\n   427→      '',\n   428→      '```bash',\n   429→      'docker exec test node verify.js',\n   430→      '```',\n   431→      '',\n   432→      '```output',\n   433→      '[FAIL] Some check failed but this is command output not a verdict',\n   434→      '```',\n   435→      '',\n   436→    ].join('\\n'));\n   437→\n   438→    const result = validateProofQuality(path);\n   439→    expect(result).toMatchObject({ verified: 1, pending: 0, escalated: 0, total: 1 });\n   440→  });\n   441→\n   442→  it('does not treat [FAIL] inside inline code backticks as a verdict', () => {\n   443→    const path = join(testDir, 'proof.md');\n   444→    writeFileSync(path, [\n   445→      '## AC 1: Expected failure output',\n   446→      '',\n   447→      '> AC description',\n   448→      '',\n   449→      '```bash',\n   450→      'docker exec test codeharness status --check-docker',\n   451→      '```',\n   452→      '',\n   453→      '```output',\n   454→      '[FAIL] VictoriaMetrics stack: not running',\n   455→      '```',\n   456→      '',\n   457→      'The command correctly reports `[FAIL] VictoriaMetrics stack: not running`.',\n   458→      '',\n   459→      '**Verdict:** PASS',\n   460→      '',\n   461→    ].join('\\n'));\n   462→\n   463→    const result = validateProofQuality(path);\n   464→    expect(result).toMatchObject({ verified: 1, pending: 0, escalated: 0, total: 1 });\n   465→  });\n   466→\n   467→  it('counts [ESCALATE] sections as escalated (not pending)', () => {\n   468→    const path = join(testDir, 'proof.md');\n   469→    writeFileSync(path, [\n   470→      '# Proof: test-story',\n   471→      '',\n   472→      '## AC 1: PASS',\n   473→      '',\n   474→      '> First AC',\n   475→      '',\n   476→      '<!-- showboat exec: codeharness verify -->',\n   477→      '```',\n   478→      'ok',\n   479→      '```',\n   480→      '<!-- /showboat exec -->',\n   481→      '',\n   482→      '## AC 2: ESCALATE',\n   483→      '',\n   484→      '> Second AC — requires integration test',\n   485→      '',\n   486→      '[ESCALATE] Requires integration test — cannot verify in current session',\n   487→      '',\n   488→    ].join('\\n'));\n   489→\n   490→    const result = validateProofQuality(path);\n   491→    expect(result).toMatchObject({ verified: 1, pending: 0, escalated: 1, total: 2, passed: true });\n   492→  });\n   493→\n   494→  it('returns passed=true for mixed verified/escalated ACs with no pending', () => {\n   495→    const path = join(testDir, 'proo