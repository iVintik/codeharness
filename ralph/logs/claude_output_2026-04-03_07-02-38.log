e({\n167\t      tasks: {\n168\t        implement: { agent: 'dev', scope: 'per-story', session: 'fresh', source_access: true },\n169\t      },\n170\t      flow: ['implement'],\n171\t    });\n172\t    resolveAgentMock.mockReset();\n173\t    resolveAgentMock.mockReturnValue({\n174\t      name: 'dev',\n175\t      role: { title: 'Developer', purpose: 'Implement code' },\n176\t      persona: { identity: 'A developer', communication_style: 'direct', principles: [] },\n177\t    });\n178\t    compileSubagentMock.mockReset();\n179\t    compileSubagentMock.mockReturnValue({\n180\t      name: 'dev',\n181\t      model: 'claude-sonnet-4-20250514',\n182\t      instructions: 'You are a developer',\n183\t      disallowedTools: [],\n184\t      bare: true,\n185\t    });\n186\t    executeWorkflowMock.mockReset();\n187\t    executeWorkflowMock.mockResolvedValue({\n188\t      success: true,\n189\t      tasksCompleted: 3,\n190\t      storiesProcessed: 1,\n191\t      errors: [],\n192\t      durationMs: 60000,\n193\t    });\n194\t    readWorkflowStateMock.mockReset();\n195\t    readWorkflowStateMock.mockReturnValue({\n196\t      workflow_name: '',\n197\t      started: '',\n198\t      iteration: 0,\n199\t      phase: 'idle',\n200\t      tasks_completed: [],\n201\t      evaluator_scores: [],\n202\t      circuit_breaker: { triggered: false, reason: null, score_history: [] },\n203\t      trace_ids: [],\n204\t    });\n205\t    writeWorkflowStateMock.mockReset();\n206\t    process.exitCode = undefined;\n207\t  });\n208\t\n209\t  afterEach(() => {\n210\t    rmSync(tmpDir, { recursive: true, force: true });\n211\t    vi.restoreAllMocks();\n212\t    process.exitCode = undefined;\n213\t  });\n214\t\n215\t  function mockPaths(overrides: Record<string, boolean>) {\n216\t    existsSyncMock.mockImplementation((p: unknown) => {\n217\t      const path = String(p);\n218\t      for (const [pattern, value] of Object.entries(overrides)) {\n219\t        if (path.includes(pattern)) return value;\n220\t      }\n221\t      return realExistsSync(path);\n222\t    });\n223\t  }\n224\t\n225\t  async function runCommand(args: string[] = []) {\n226\t    const { registerRunCommand } = await import('../run.js');\n227\t    const program = new Command();\n228\t    program.exitOverride();\n229\t    program.option('--json', 'JSON output');\n230\t    registerRunCommand(program);\n231\t    await program.parseAsync(['node', 'codeharness', 'run', ...args]);\n232\t  }\n233\t\n234\t  describe('resolvePluginDir', () => {\n235\t    it('returns cwd/.claude', () => {\n236\t      expect(resolvePluginDir()).toBe(join(process.cwd(), '.claude'));\n237\t    });\n238\t  });\n239\t\n240\t  describe('countStories (re-export)', () => {\n241\t    it('re-exports countStories from run-helpers.ts', () => {\n242\t      const counts = countStories({ '1-1-story': 'done', '1-2-story': 'backlog' });\n243\t      expect(counts.total).toBe(2);\n244\t      expect(counts.done).toBe(1);\n245\t    });\n246\t  });\n247\t\n248\t  describe('action handler', () => {\n249\t    it('fails when plugin directory not found', async () => {\n250\t      mockPaths({ '.claude': false });\n251\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n252\t\n253\t      await runCommand();\n254\t\n255\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Plugin directory not found'));\n256\t      expect(process.exitCode).toBe(1);\n257\t    });\n258\t\n259\t    it('fails when Docker is unavailable', async () => {\n260\t      mockPaths({ '.claude': true });\n261\t      isDockerAvailableMock.mockReturnValue(false);\n262\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n263\t\n264\t      await runCommand();\n265\t\n266\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Docker not available'));\n267\t      expect(process.exitCode).toBe(1);\n268\t    });\n269\t\n270\t    it('fails when no stories found in sprint state', async () => {\n271\t      mockPaths({ '.claude': true });\n272\t      readSprintStatusMock.mockReturnValue({});\n273\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n274\t\n275\t      await runCommand();\n276\t\n277\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('No stories found'));\n278\t      expect(process.exitCode).toBe(1);\n279\t    });\n280\t\n281\t    it('fails when no stories are ready for execution (AC #9)', async () => {\n282\t      mockPaths({ '.claude': true });\n283\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'done', '1-2-story': 'done' });\n284\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n285\t\n286\t      await runCommand();\n287\t\n288\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('No stories ready for execution'));\n289\t      expect(process.exitCode).toBe(1);\n290\t    });\n291\t\n292\t    it('calls executeWorkflow on success path (AC #1, #2)', async () => {\n293\t      mockPaths({ '.claude': true });\n294\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n295\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n296\t\n297\t      await runCommand();\n298\t\n299\t      expect(resolveWorkflowMock).toHaveBeenCalled();\n300\t      expect(resolveAgentMock).toHaveBeenCalled();\n301\t      expect(executeWorkflowMock).toHaveBeenCalled();\n302\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Workflow completed'));\n303\t      expect(process.exitCode).toBeUndefined();\n304\t    });\n305\t\n306\t    it('constructs EngineConfig correctly from CLI options (AC #4)', async () => {\n307\t      mockPaths({ '.claude': true });\n308\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n309\t      vi.spyOn(console, 'log').mockImplementation(() => {});\n310\t\n311\t      await runCommand(['--max-iterations', '10']);\n312\t\n313\t      expect(executeWorkflowMock).toHaveBeenCalled();\n314\t      const config = executeWorkflowMock.mock.calls[0][0];\n315\t      expect(config.maxIterations).toBe(10);\n316\t      expect(config.runId).toMatch(/^run-\\d+$/);\n317\t      expect(config.workflow).toBeDefined();\n318\t      expect(config.agents).toBeDefined();\n319\t      expect(config.sprintStatusPath).toContain('sprint-status.yaml');\n320\t    });\n321\t\n322\t    it('exits 1 on workflow failure (AC #2)', async () => {\n323\t      mockPaths({ '.claude': true });\n324\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n325\t      executeWorkflowMock.mockResolvedValue({\n326\t        success: false,\n327\t        tasksCompleted: 1,\n328\t        storiesProcessed: 1,\n329\t        errors: [{ taskName: 'implement', storyKey: '1-1-story', code: 'UNKNOWN', message: 'dispatch failed' }],\n330\t        durationMs: 5000,\n331\t      });\n332\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n333\t\n334\t      await runCommand();\n335\t\n336\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Workflow failed'));\n337\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('dispatch failed'));\n338\t      expect(process.exitCode).toBe(1);\n339\t    });\n340\t\n341\t    it('exits 1 when executeWorkflow throws', async () => {\n342\t      mockPaths({ '.claude': true });\n343\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n344\t      executeWorkflowMock.mockRejectedValue(new Error('engine crashed'));\n345\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n346\t\n347\t      await runCommand();\n348\t\n349\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Workflow engine error'));\n350\t      expect(process.exitCode).toBe(1);\n351\t    });\n352\t\n353\t    it('exits 1 when workflow resolution fails', async () => {\n354\t      mockPaths({ '.claude': true });\n355\t      readSprintStatusMock.mockRet