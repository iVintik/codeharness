{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0172ZADbGbWbr88ZZfPQk2Uk","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { verifyPromptTemplate, projectTypeGuidance } from '../../../templates/verify-prompt.js';\n     3→import type { PromptProjectType } from '../../../templates/verify-prompt.js';\n     4→\n     5→describe('verifyPromptTemplate', () => {\n     6→  const baseConfig = {\n     7→    storyKey: '13-3-black-box-verifier-agent',\n     8→    storyContent: '# Story 13.3\\n\\n## Acceptance Criteria\\n\\n1. AC one\\n2. AC two',\n     9→  };\n    10→\n    11→  it('includes story acceptance criteria from storyContent', () => {\n    12→    const prompt = verifyPromptTemplate(baseConfig);\n    13→    expect(prompt).toContain('# Story 13.3');\n    14→    expect(prompt).toContain('AC one');\n    15→    expect(prompt).toContain('AC two');\n    16→  });\n    17→\n    18→  it('includes default container name (codeharness-verify)', () => {\n    19→    const prompt = verifyPromptTemplate(baseConfig);\n    20→    expect(prompt).toContain('codeharness-verify');\n    21→    expect(prompt).toContain('docker exec codeharness-verify');\n    22→  });\n    23→\n    24→  it('uses custom container name when provided', () => {\n    25→    const prompt = verifyPromptTemplate({\n    26→      ...baseConfig,\n    27→      containerName: 'my-custom-container',\n    28→    });\n    29→    expect(prompt).toContain('docker exec my-custom-container');\n    30→    expect(prompt).toContain('Container name: `my-custom-container`');\n    31→  });\n    32→\n    33→  it('includes default observability endpoints', () => {\n    34→    const prompt = verifyPromptTemplate(baseConfig);\n    35→    expect(prompt).toContain('localhost:9428');\n    36→    expect(prompt).toContain('localhost:8428');\n    37→    expect(prompt).toContain('localhost:16686');\n    38→  });\n    39→\n    40→  it('uses custom observability endpoints when provided', () => {\n    41→    const prompt = verifyPromptTemplate({\n    42→      ...baseConfig,\n    43→      observabilityEndpoints: {\n    44→        victoriaLogs: 'http://custom-logs:9999',\n    45→        victoriaMetrics: 'http://custom-metrics:8888',\n    46→        victoriaTraces: 'http://custom-traces:7777',\n    47→      },\n    48→    });\n    49→    expect(prompt).toContain('http://custom-logs:9999');\n    50→    expect(prompt).toContain('http://custom-metrics:8888');\n    51→    expect(prompt).toContain('http://custom-traces:7777');\n    52→  });\n    53→\n    54→  it('includes README.md reading instruction', () => {\n    55→    const prompt = verifyPromptTemplate(baseConfig);\n    56→    expect(prompt).toContain('README.md');\n    57→    expect(prompt).toMatch(/[Rr]ead.*README\\.md/);\n    58→  });\n    59→\n    60→  it('includes docker exec usage instructions', () => {\n    61→    const prompt = verifyPromptTemplate(baseConfig);\n    62→    expect(prompt).toContain('ALL commands MUST use `docker exec');\n    63→    expect(prompt).toContain('ALL CLI commands MUST run via');\n    64→  });\n    65→\n    66→  it('includes proof output path', () => {\n    67→    const prompt = verifyPromptTemplate(baseConfig);\n    68→    expect(prompt).toContain(`verification/${baseConfig.storyKey}-proof.md`);\n    69→  });\n    70→\n    71→  it('instructs verifier to report REAL failures', () => {\n    72→    const prompt = verifyPromptTemplate(baseConfig);\n    73→    expect(prompt).toContain('REAL failure');\n    74→    expect(prompt).toMatch(/[Dd]o NOT fabricate/);\n    75→  });\n    76→\n    77→  it('explains no source code is available', () => {\n    78→    const prompt = verifyPromptTemplate(baseConfig);\n    79→    expect(prompt).toContain('NO source code');\n    80→    expect(prompt).toContain('src/');\n    81→    expect(prompt).toContain('does not exist');\n    82→  });\n    83→\n    84→  it('includes observability curl examples', () => {\n    85→    const prompt = verifyPromptTemplate(baseConfig);\n    86→    expect(prompt).toContain('curl');\n    87→    expect(prompt).toContain('logsql/query');\n    88→    expect(prompt).toContain('api/v1/query');\n    89→    expect(prompt).toContain('api/traces');\n    90→  });\n    91→\n    92→  it('includes [ESCALATE] instruction', () => {\n    93→    const prompt = verifyPromptTemplate(baseConfig);\n    94→    expect(prompt).toContain('[ESCALATE]');\n    95→  });\n    96→\n    97→  it('instructs verifier that claude CLI is available in container', () => {\n    98→    const prompt = verifyPromptTemplate(baseConfig);\n    99→    expect(prompt).toContain('claude');\n   100→    expect(prompt).toContain('claude --print');\n   101→    expect(prompt).toContain('ANTHROPIC_API_KEY');\n   102→  });\n   103→\n   104→  it('includes nested --allowedTools instruction for Docker exec scenarios', () => {\n   105→    const prompt = verifyPromptTemplate(baseConfig);\n   106→    expect(prompt).toContain('--allowedTools Bash Read Write Glob Grep Edit');\n   107→    expect(prompt).toContain('nested session');\n   108→  });\n   109→\n   110→  it('instructs verifier to escalate narrowly, not blanket-escalate', () => {\n   111→    const prompt = verifyPromptTemplate(baseConfig);\n   112→    expect(prompt).toContain('escalate narrowly');\n   113→    expect(prompt).toContain('genuinely impossible to automate');\n   114→  });\n   115→\n   116→  // ─── Observability check instructions (Story 2.1) ─────────────────────\n   117→\n   118→  it('includes observability check instructions after docker exec', () => {\n   119→    const prompt = verifyPromptTemplate(baseConfig);\n   120→    expect(prompt).toContain('Observability Check');\n   121→    expect(prompt).toContain('[OBSERVABILITY GAP]');\n   122→    expect(prompt).toContain('last 30 seconds');\n   123→  });\n   124→\n   125→  it('includes observability query template with VictoriaLogs endpoint', () => {\n   126→    const prompt = verifyPromptTemplate(baseConfig);\n   127→    expect(prompt).toContain(\n   128→      \"curl 'http://localhost:9428/select/logsql/query?query=_stream_id:*&start=-30s&limit=100'\",\n   129→    );\n   130→  });\n   131→\n   132→  it('uses custom VictoriaLogs endpoint in observability query template', () => {\n   133→    const prompt = verifyPromptTemplate({\n   134→      ...baseConfig,\n   135→      observabilityEndpoints: {\n   136→        victoriaLogs: 'http://custom-logs:9999',\n   137→      },\n   138→    });\n   139→    expect(prompt).toContain(\n   140→      \"curl 'http://custom-logs:9999/select/logsql/query?query=_stream_id:*&start=-30s&limit=100'\",\n   141→    );\n   142→  });\n   143→\n   144→  it('merges partial observability endpoint overrides with defaults', () => {\n   145→    const prompt = verifyPromptTemplate({\n   146→      ...baseConfig,\n   147→      observabilityEndpoints: {\n   148→        victoriaLogs: 'http://custom-logs:9999',\n   149→        // victoriaMetrics and victoriaTraces should use defaults\n   150→      },\n   151→    });\n   152→    expect(prompt).toContain('http://custom-logs:9999');\n   153→    expect(prompt).toContain('localhost:8428'); // default\n   154→    expect(prompt).toContain('localhost:16686'); // default\n   155→  });\n   156→\n   157→  // ─── Project-type-specific guidance (AC #5) ──────────────────────────────\n   158→\n   159→  it('includes Node.js CLI guidance for nodejs project type', () => {\n   160→    const prompt = verifyPromptTemplate({ ...baseConfig, projectType: 'nodejs' });\n   161→    expect(prompt).toContain('Node.js CLI');\n   162→    expect(prompt).toContain('docker exec');\n   163→    expect(prompt).toContain('stdout/stderr');\n   164→  });\n   165→\n   166→  it('includes Python CLI guidance for python project type', () => {\n   167→    const prompt = verifyPromptTemplate({ ...baseConfig, projectType: 'python' });\n   168→    expect(prompt).toContain('Python CLI');\n   169→    expect(prompt).toContain('docker exec');\n   170→  });\n   171→\n   172→  it('includes plugin guidance for plugin project type', () => {\n   173→    const prompt = verifyPromptTemplate({ ...baseConfig, projectType: 'plugin' });\n   174→    expect(prompt).toContain('Claude Code Plugin');\n   175→    expect(prompt).toContain('claude --print');\n   176→    expect(prompt).toContain('slash commands');\n   177→  });\n   178→\n   179→  it('includes generic guidance for generic project type', () => {\n   180→    const prompt = verifyPromptTemplate({ ...baseConfig, projectType: 'generic' });\n   181→    expect(prompt).toContain('Unknown / Generic');\n   182→    expect(prompt).toContain('Adapt');\n   183→    expect(prompt).toContain('do not refuse verification');\n   184→  });\n   185→\n   186→  it('defaults to nodejs when no projectType provided', () => {\n   187→    const prompt = verifyPromptTemplate(baseConfig);\n   188→    expect(prompt).toContain('Node.js CLI');\n   189→  });\n   190→\n   191→  it('never says project type is not supported', () => {\n   192→    const projectTypes: PromptProjectType[] = ['nodejs', 'python', 'plugin', 'generic'];\n   193→    for (const pt of projectTypes) {\n   194→      const prompt = verifyPromptTemplate({ ...baseConfig, projectType: pt });\n   195→      expect(prompt).not.toContain(\"isn't supported\");\n   196→      expect(prompt).not.toContain('not supported');\n   197→      expect(prompt).not.toContain('Unsupported');\n   198→    }\n   199→  });\n   200→});\n   201→\n   202→// ─── projectTypeGuidance ──────────────────────────────────────────────────\n   203→\n   204→describe('projectTypeGuidance', () => {\n   205→  const container = 'test-container';\n   206→\n   207→  it('returns docker exec guidance for nodejs', () => {\n   208→    const guidance = projectTypeGuidance('nodejs', container);\n   209→    expect(guidance).toContain('Node.js CLI');\n   210→    expect(guidance).toContain(`docker exec ${container}`);\n   211→    expect(guidance).toContain('installed globally');\n   212→ 