test-provable');\n    43→    expect(section).toContain('runtime-provable');\n    44→    expect(section).toContain('environment-provable');\n    45→    expect(section).toContain('escalate');\n    46→  });\n    47→});\n    48→\n    49→// ─── AC2: Decision tree with criteria and 4 concrete examples ────────────────\n    50→\n    51→describe('AC2: decision tree with criteria and examples', () => {\n    52→  it('contains a Tier Decision Tree section', () => {\n    53→    expect(instructions).toContain('Tier Decision Tree');\n    54→  });\n    55→\n    56→  it('includes at least 4 concrete examples (one per tier)', () => {\n    57→    const start = instructions.indexOf('VERIFICATION TIER TAGGING');\n    58→    const end = instructions.indexOf('<!-- Developer context section');\n    59→    const section = instructions.slice(start, end);\n    60→    // In XML, the comment tags are escaped as &lt;!-- and --&gt;\n    61→    expect(section).toContain('verification: test-provable');\n    62→    expect(section).toContain('verification: runtime-provable');\n    63→    expect(section).toContain('verification: environment-provable');\n    64→    expect(section).toContain('verification: escalate');\n    65→  });\n    66→});\n    67→\n    68→// ─── AC3: Tag format is <!-- verification: {tier} --> ────────────────────────\n    69→\n    70→describe('AC3: correct tag format', () => {\n    71→  it('specifies the tag format <!-- verification: {tier} --> (XML-escaped)', () => {\n    72→    // In XML content, angle brackets are escaped: &lt;!-- verification: {tier} --&gt;\n    73→    expect(instructions).toContain('verification: {tier}');\n    74→    expect(instructions).toContain('&lt;!-- verification: {tier} --&gt;');\n    75→  });\n    76→});\n    77→\n    78→// ─── AC4: No references to old tier names ────────────────────────────────────\n    79→\n    80→describe('AC4: no old tier names in instructions.xml', () => {\n    81→  it('does NOT reference cli-verifiable as a valid tier name', 