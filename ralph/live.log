{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Mie53pnhxms83sJcG7wMeM","type":"tool_result","content":"     1→import { existsSync, readFileSync } from 'node:fs';\n     2→import { join } from 'node:path';\n     3→import { warn } from './output.js';\n     4→\n     5→export type AppType = 'server' | 'cli' | 'web' | 'agent' | 'generic';\n     6→\n     7→export function detectStack(dir: string = process.cwd()): string | null {\n     8→  if (existsSync(join(dir, 'package.json'))) return 'nodejs';\n     9→  if (existsSync(join(dir, 'requirements.txt'))) return 'python';\n    10→  if (existsSync(join(dir, 'pyproject.toml'))) return 'python';\n    11→  if (existsSync(join(dir, 'setup.py'))) return 'python';\n    12→  if (existsSync(join(dir, 'Cargo.toml'))) return 'rust';\n    13→  warn('No recognized stack detected');\n    14→  return null;\n    15→}\n    16→\n    17→const AGENT_DEPS_NODE = ['anthropic', '@anthropic-ai/sdk', 'openai', 'langchain', '@langchain/core', 'llamaindex'];\n    18→const AGENT_DEPS_PYTHON = ['anthropic', 'openai', 'langchain', 'llama-index', 'traceloop-sdk'];\n    19→const WEB_FRAMEWORK_DEPS = ['react', 'vue', 'svelte', 'angular', '@angular/core', 'next', 'nuxt', 'vite', 'webpack'];\n    20→const PYTHON_WEB_FRAMEWORKS = ['flask', 'django', 'fastapi', 'streamlit'];\n    21→const RUST_WEB_FRAMEWORKS = ['actix-web', 'axum', 'rocket', 'tide', 'warp'];\n    22→const RUST_AGENT_DEPS = ['async-openai', 'anthropic', 'llm-chain'];\n    23→\n    24→function readJsonSafe(path: string): Record<string, unknown> | null {\n    25→  try {\n    26→    if (!existsSync(path)) return null;\n    27→    return JSON.parse(readFileSync(path, 'utf-8')) as Record<string, unknown>;\n    28→  } catch {\n    29→    return null;\n    30→  }\n    31→}\n    32→\n    33→function readTextSafe(path: string): string | null {\n    34→  try {\n    35→    if (!existsSync(path)) return null;\n    36→    return readFileSync(path, 'utf-8');\n    37→  } catch {\n    38→    return null;\n    39→  }\n    40→}\n    41→\n    42→function getNodeDeps(pkg: Record<string, unknown>): Set<string> {\n    43→  const deps = new Set<string>();\n    44→  for (const field of ['dependencies', 'devDependencies']) {\n    45→    const section = pkg[field] as Record<string, string> | undefined;\n    46→    if (section && typeof section === 'object') {\n    47→      for (const key of Object.keys(section)) {\n    48→        deps.add(key);\n    49→      }\n    50→    }\n    51→  }\n    52→  return deps;\n    53→}\n    54→\n    55→function hasPythonDep(content: string, dep: string): boolean {\n    56→  // Match dep name as a standalone package, not as a substring of another package.\n    57→  // Handles requirements.txt lines like \"openai>=1.0\", pyproject.toml entries like '\"openai\"',\n    58→  // and extras like \"openai[all]\". Uses word boundary or common delimiters to avoid\n    59→  // matching \"not-openai\" or \"myopenai\".\n    60→  const escaped = dep.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n    61→  const pattern = new RegExp(`(?:^|[\\\\s\"',])${escaped}(?:[\\\\[>=<~!;\\\\s\"',]|$)`, 'm');\n    62→  return pattern.test(content);\n    63→}\n    64→\n    65→/**\n    66→ * Extract the [dependencies] section from Cargo.toml content.\n    67→ * Stops at the next section header (e.g., [dev-dependencies], [build-dependencies]).\n    68→ * Returns empty string if no [dependencies] section found.\n    69→ */\n    70→function getCargoDepsSection(content: string): string {\n    71→  const match = content.match(/^\\[dependencies\\]\\s*$/m);\n    72→  if (!match || match.index === undefined) return '';\n    73→  const start = match.index + match[0].length;\n    74→  // Find next section header\n    75→  const nextSection = content.slice(start).search(/^\\[/m);\n    76→  return nextSection === -1 ? content.slice(start) : content.slice(start, start + nextSection);\n    77→}\n    78→\n    79→/**\n    80→ * Check if a Cargo.toml [dependencies] section contains a specific crate.\n    81→ * Uses word-boundary matching to avoid substring false positives\n    82→ * (e.g., \"anthropic-sdk\" should not match \"anthropic\").\n    83→ */\n    84→function hasCargoDep(depsSection: string, dep: string): boolean {\n    85→  const escaped = dep.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n    86→  const pattern = new RegExp(`(?:^|\\\\s)${escaped}(?:\\\\s*=|\\\\s*\\\\{)`, 'm');\n    87→  return pattern.test(depsSection);\n    88→}\n    89→\n    90→function getPythonDepsContent(dir: string): string {\n    91→  const files = ['requirements.txt', 'pyproject.toml', 'setup.py'];\n    92→  const parts: string[] = [];\n    93→  for (const file of files) {\n    94→    const content = readTextSafe(join(dir, file));\n    95→    if (content) parts.push(content);\n    96→  }\n    97→  return parts.join('\\n');\n    98→}\n    99→\n   100→export function detectAppType(dir: string, stack: string | null): AppType {\n   101→  if (stack === 'nodejs') {\n   102→    const pkg = readJsonSafe(join(dir, 'package.json'));\n   103→    if (!pkg) return 'generic';\n   104→\n   105→    const deps = getNodeDeps(pkg);\n   106→\n   107→    // Priority 1: Agent detection\n   108→    if (AGENT_DEPS_NODE.some(d => deps.has(d))) {\n   109→      return 'agent';\n   110→    }\n   111→\n   112→    // Priority 2: Web detection\n   113→    if (WEB_FRAMEWORK_DEPS.some(d => deps.has(d))) {\n   114→      return 'web';\n   115→    }\n   116→    if (\n   117→      existsSync(join(dir, 'index.html')) ||\n   118→      existsSync(join(dir, 'public', 'index.html')) ||\n   119→      existsSync(join(dir, 'src', 'index.html'))\n   120→    ) {\n   121→      return 'web';\n   122→    }\n   123→\n   124→    // Priority 3: CLI detection\n   125→    const bin = pkg['bin'];\n   126→    const scripts = pkg['scripts'] as Record<string, string> | undefined;\n   127→    const hasStart = scripts?.['start'] !== undefined;\n   128→    if (bin && !hasStart) {\n   129→      return 'cli';\n   130→    }\n   131→\n   132→    // Priority 4: Server detection\n   133→    if (hasStart) {\n   134→      return 'server';\n   135→    }\n   136→\n   137→    return 'generic';\n   138→  }\n   139→\n   140→  if (stack === 'python') {\n   141→    const content = getPythonDepsContent(dir);\n   142→\n   143→    // Priority 1: Agent detection\n   144→    if (AGENT_DEPS_PYTHON.some(d => hasPythonDep(content, d))) {\n   145→      return 'agent';\n   146→    }\n   147→\n   148→    // Priority 2: Web detection (framework + templates/static dirs)\n   149→    const hasWebFramework = PYTHON_WEB_FRAMEWORKS.some(d => hasPythonDep(content, d));\n   150→    if (hasWebFramework) {\n   151→      const hasTemplates = existsSync(join(dir, 'templates'));\n   152→      const hasStatic = existsSync(join(dir, 'static'));\n   153→      if (hasTemplates || hasStatic) {\n   154→        return 'web';\n   155→      }\n   156→      // Bare Flask/Django/FastAPI without templates => server\n   157→      return 'server';\n   158→    }\n   159→\n   160→    // Priority 4: Server detection (has main entry point)\n   161→    if (\n   162→      existsSync(join(dir, 'app.py')) ||\n   163→      existsSync(join(dir, 'main.py')) ||\n   164→      existsSync(join(dir, 'manage.py'))\n   165→    ) {\n   166→      return 'server';\n   167→    }\n   168→\n   169→    return 'generic';\n   170→  }\n   171→\n   172→  if (stack === 'rust') {\n   173→    const cargoContent = readTextSafe(join(dir, 'Cargo.toml'));\n   174→    if (!cargoContent) return 'generic';\n   175→\n   176→    const depsSection = getCargoDepsSection(cargoContent);\n   177→\n   178→    // Priority 1: Agent detection (only in [dependencies], not [dev-dependencies])\n   179→    if (RUST_AGENT_DEPS.some(d => hasCargoDep(depsSection, d))) {\n   180→      return 'agent';\n   181→    }\n   182→\n   183→    // Priority 2: Server detection (web framework in [dependencies])\n   184→    if (RUST_WEB_FRAMEWORKS.some(d => hasCargoDep(depsSection, d))) {\n   185→      return 'server';\n   186→    }\n   187→\n   188→    // Priority 3: CLI detection ([[bin]] section present)\n   189→    if (/^\\[\\[bin\\]\\]\\s*$/m.test(cargoContent)) {\n   190→      return 'cli';\n   191→    }\n   192→\n   193→    // Priority 4: Library detection ([lib] section present, no [[bin]])\n   194→    if (/^\\[lib\\]\\s*$/m.test(cargoContent)) {\n   195→      return 'generic';\n   196→    }\n   197→\n   198→    return 'generic';\n   199→  }\n   200→\n   201→  return 'generic';\n   202→}\n   203→"}]},"parent_tool_use_id":"toolu_01CGkWizVB7CtGCqwFm5rfNr","session_id":"6b184f1a-3a3f-4307-8da0-d8cf52066851","uuid":"0e54451a-6bec-428c-be30-2e561f5bef89","timestamp":"2026-03-23T05:23:16.150Z"}
