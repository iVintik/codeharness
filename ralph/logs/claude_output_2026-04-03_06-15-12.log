{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013qcWK6Gb6ZV6bCXsA16myM","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n2\timport { mkdtempSync, rmSync, mkdirSync, writeFileSync } from 'node:fs';\n3\timport { tmpdir } from 'node:os';\n4\timport { join } from 'node:path';\n5\timport { Command } from 'commander';\n6\t\n7\t// Mock output module\n8\tvi.mock('../../lib/output.js', () => ({\n9\t  ok: vi.fn(),\n10\t  fail: vi.fn(),\n11\t  info: vi.fn(),\n12\t  warn: vi.fn(),\n13\t  jsonOutput: vi.fn(),\n14\t}));\n15\t\n16\t// Mock github module\n17\tvi.mock('../../lib/github.js', () => ({\n18\t  isGhAvailable: vi.fn(),\n19\t  findExistingGhIssue: vi.fn(),\n20\t  ghIssueCreate: vi.fn(),\n21\t  ensureLabels: vi.fn(),\n22\t  getRepoFromRemote: vi.fn(),\n23\t}));\n24\t\n25\t// Mock state module\n26\tvi.mock('../../lib/state.js', () => ({\n27\t  readState: vi.fn(),\n28\t  StateFileNotFoundError: class StateFileNotFoundError extends Error {\n29\t    constructor() {\n30\t      super('No state file found');\n31\t      this.name = 'StateFileNotFoundError';\n32\t    }\n33\t  },\n34\t}));\n35\t\n36\timport { registerRetroImportCommand } from '../retro-import.js';\n37\timport { ok, fail, info, warn, jsonOutput } from '../../lib/output.js';\n38\timport { isGhAvailable, findExistingGhIssue, ghIssueCreate, ensureLabels, getRepoFromRemote } from '../../lib/github.js';\n39\timport { readState, StateFileNotFoundError } from '../../lib/state.js';\n40\t\n41\tconst mockIsGhAvailable = vi.mocked(isGhAvailable);\n42\tconst mockFindExistingGhIssue = vi.mocked(findExistingGhIssue);\n43\tconst mockGhIssueCreate = vi.mocked(ghIssueCreate);\n44\tconst mockEnsureLabels = vi.mocked(ensureLabels);\n45\tconst mockGetRepoFromRemote = vi.mocked(getRepoFromRemote);\n46\tconst mockReadState = vi.mocked(readState);\n47\t\n48\tlet testDir: string;\n49\tlet originalCwd: string;\n50\t\n51\tconst RETRO_CONTENT = `\n52\t# Epic 9 Retrospective\n53\t\n54\t## Epic 8 Retro Action Item Status\n55\t\n56\t| # | Action | Status | Notes |\n57\t|---|--------|--------|-------|\n58\t| A1 | Cover run.ts action handler (lines 110-276) | Not done | Permanent technical debt. |\n59\t| A2 | Fix harness initialization bug | Not done | Needs attention. |\n60\t| A3 | Raise overall branch coverage | Regressed | Dropped below target. |\n61\t\n62\t**Summary:** 0 of 3 resolved.\n63\t`;\n64\t\n65\tbeforeEach(() => {\n66\t  vi.clearAllMocks();\n67\t  testDir = mkdtempSync(join(tmpdir(), 'ch-retro-import-test-'));\n68\t  originalCwd = process.cwd();\n69\t  process.chdir(testDir);\n70\t  process.exitCode = undefined;\n71\t  // Default: no state file (skips GitHub phase)\n72\t  mockReadState.mockImplementation(() => {\n73\t    throw new StateFileNotFoundError();\n74\t  });\n75\t});\n76\t\n77\tafterEach(() => {\n78\t  process.chdir(originalCwd);\n79\t  process.exitCode = undefined;\n80\t  rmSync(testDir, { recursive: true, force: true });\n81\t});\n82\t\n83\tfunction createRetroFile(epicNum: number, content?: string): void {\n84\t  const storyDir = join(testDir, '_bmad-output', 'implementation-artifacts');\n85\t  mkdirSync(storyDir, { recursive: true });\n86\t  writeFileSync(\n87\t    join(storyDir, `epic-${epicNum}-retrospective.md`),\n88\t    content ?? RETRO_CONTENT,\n89\t  );\n90\t}\n91\t\n92\tasync function runRetroImport(args: string[]): Promise<void> {\n93\t  const program = new Command();\n94\t  program.exitOverride();\n95\t  program.option('--json', 'JSON output');\n96\t  registerRetroImportCommand(program);\n97\t  try {\n98\t    await program.parseAsync(['node', 'test', 'retro-import', ...args]);\n99\t  } catch {\n100\t    // Commander throws on exitOverride — ignore\n101\t  }\n102\t}\n103\t\n104\tdescribe('retro-import command', () => {\n105\t  it('parses action items from retro file', async () => {\n106\t    createRetroFile(9);\n107\t\n108\t    await runRetroImport(['--epic', '9']);\n109\t\n110\t    // Should parse 3 items and report them\n111\t    expect(vi.mocked(info)).toHaveBeenCalledTimes(4); // 3 items + 1 skip-github message\n112\t  });\n113\t\n114\t  it('fails with invalid epic number', async () => {\n115\t    await runRetroImport(['--epic', 'abc']);\n116\t\n117\t    expect(vi.mocked(fail)).toHaveBeenCalledWith(\n118\t      expect.stringContaining('Invalid epic number'),\n119\t      expect.any(Object),\n120\t    );\n121\t    expect(process.exitCode).toBe(1);\n122\t  });\n123\t\n124\t  it('fails when retro file does not exist', async () => {\n125\t    await runRetroImport(['--epic', '99']);\n126\t\n127\t    expect(vi.mocked(fail)).toHaveBeenCalledWith(\n128\t      expect.stringContaining('Retro file not found'),\n129\t      expect.any(Object),\n130\t    );\n131\t    expect(process.exitCode).toBe(1);\n132\t  });\n133\t\n134\t  it('handles empty retro file with no action items', async () => {\n135\t    createRetroFile(5, '# Epic 5 Retrospective\\n\\nNo action items.');\n136\t\n137\t    await runRetroImport(['--epic', '5']);\n138\t\n139\t    expect(vi.mocked(info)).toHaveBeenCalledWith('No action items found in retro file');\n140\t  });\n141\t\n142\t  it('outputs JSON when --json is set', async () => {\n143\t    createRetroFile(9);\n144\t\n145\t    await runRetroImport(['--epic', '9', '--json']);\n146\t\n147\t    expect(vi.mocked(jsonOutput)).toHaveBeenCalledTimes(1);\n148\t    const jsonCall = vi.mocked(jsonOutput).mock.calls[0][0];\n149\t    expect(jsonCall).toHaveProperty('imported', 0);\n150\t    expect(jsonCall).toHaveProperty('skipped', 0);\n151\t    expect(jsonCall).toHaveProperty('issues');\n152\t    const issues = jsonCall['issues'] as unknown[];\n153\t    expect(issues).toHaveLength(3);\n154\t  });\n155\t\n156\t  it('skips GitHub phase when no state file exists', async () => {\n157\t    createRetroFile(9);\n158\t\n159\t    await runRetroImport(['--epic', '9']);\n160\t\n161\t    expect(vi.mocked(info)).toHaveBeenCalledWith('No state file found — skipping GitHub issues');\n162\t  });\n163\t\n164\t  describe('GitHub issue creation', () => {\n165\t    it('creates GitHub issues when state has retro_issue_targets', async () => {\n166\t      createRetroFile(9);\n167\t      mockReadState.mockReturnValue({\n168\t        retro_issue_targets: [{ repo: 'auto', labels: ['retro'] }],\n169\t      } as any);\n170\t      mockIsGhAvailable.mockReturnValue(true);\n171\t      mockGetRepoFromRemote.mockReturnValue('owner/repo');\n172\t      mockFindExistingGhIssue.mockReturnValue(undefined);\n173\t      mockGhIssueCreate.mockReturnValue({ number: 1, url: 'https://github.com/owner/repo/issues/1' });\n174\t\n175\t      await runRetroImport(['--epic', '9']);\n176\t\n177\t      expect(mockGhIssueCreate).toHaveBeenCalled();\n178\t    });\n179\t\n180\t    it('skips GitHub when gh CLI not available', async () => {\n181\t      createRetroFile(9);\n182\t      mockReadState.mockReturnValue({\n183\t        retro_issue_targets: [{ repo: 'auto', labels: ['retro'] }],\n184\t      } as any);\n185\t      mockIsGhAvailable.mockReturnValue(false);\n186\t\n187\t      await runRetroImport(['--epic', '9']);\n188\t\n189\t      expect(vi.mocked(warn)).toHaveBeenCalledWith('gh CLI not available — skipping GitHub issue creation');\n190\t    });\n191\t\n192\t    it('skips GitHub when no retro_issue_targets configured', async () => {\n193\t      createRetroFile(9);\n194\t      mockReadState.mockReturnValue({} as any);\n195\t      mockIsGhAvailable.mockReturnValue(true);\n196\t\n197\t      await runRetroImport(['--epic', '9']);\n198\t\n199\t      expect(vi.mocked(info)).toHaveBeenCalledWith('No retro_issue_targets configured — skipping GitHub issues');\n200\t    });\n201\t\n202\t    it('skips duplicate issues found on GitHub', async () => {\n203\t      createRetroFile(9);\n204\t      mockReadState.mockReturnValue({\n205\t        retro_issue_targets: [{ repo: 'auto', labels: ['retro'] }],\n206\t      } as any);\n207\t      mockIsGhAvailable.mockReturnValue(true);