{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018bSNfEw6MndRBxMMekckZQ","type":"tool_result","content":"     1→/**\n     2→ * CLI command: `codeharness onboard`\n     3→ *\n     4→ * Alias for `codeharness audit` (FR16).\n     5→ * The old onboard command (scan/coverage/audit/epic pipeline) has been\n     6→ * replaced by the audit coordinator. This thin alias ensures backward\n     7→ * compatibility for existing scripts and documentation.\n     8→ */\n     9→\n    10→import { Command } from 'commander';\n    11→import { warn } from '../lib/output.js';\n    12→import { executeAudit } from './audit-action.js';\n    13→\n    14→export function registerOnboardCommand(program: Command): void {\n    15→  const onboard = program\n    16→    .command('onboard')\n    17→    .description('Alias for audit \\u2014 check all compliance dimensions')\n    18→    .option('--json', 'Output in machine-readable JSON format')\n    19→    .option('--fix', 'Generate fix stories for every gap found')\n    20→    .action(async (opts, cmd) => {\n    21→      const globalOpts = cmd.optsWithGlobals();\n    22→      const isJson = opts.json === true || globalOpts.json === true;\n    23→      const isFix = opts.fix === true;\n    24→\n    25→      await executeAudit({ isJson, isFix });\n    26→    });\n    27→\n    28→  // Deprecated legacy subcommand: `onboard scan`\n    29→  onboard\n    30→    .command('scan')\n    31→    .description('(deprecated) Use \"codeharness audit\" instead')\n    32→    .action(async (_, cmd) => {\n    33→      const globalOpts = cmd.optsWithGlobals();\n    34→      const isJson = globalOpts.json === true;\n    35→\n    36→      warn(\"'onboard scan' is deprecated \\u2014 use 'codeharness audit' instead\");\n    37→\n    38→      await executeAudit({ isJson, isFix: false });\n    39→    });\n    40→}\n    41→"}]},"parent_tool_use_id":"toolu_01FVdVXwr4A1SuLMz7rmo6Vd","session_id":"02b06ad8-9233-430d-bd8e-764032ea190c","uuid":"ab932839-addd-4092-b977-32dec0632f8e","timestamp":"2026-03-21T11:45:01.632Z"}
