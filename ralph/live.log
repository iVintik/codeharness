ive/workflow.yaml\"\n    32→      data: \"{project-root}/_bmad/_config/agent-manifest.csv\"\n    33→      description: \"[ER] Epic Retrospective: Party Mode review of all work completed across an epic.\"\n    34→\n    35→    - trigger: CC or fuzzy match on correct-course\n    36→      workflow: \"{project-root}/_bmad/bmm/workflows/4-implementation/correct-course/workflow.yaml\"\n    37→      description: \"[CC] Course Correction: Use this so we can determine how to proceed if major need for change is discovered mid implementation\"\n    38→"}]},"parent_tool_use_id":"toolu_017HTAduJyEY5nnXzS9Qtj1F","session_id":"eb26302c-c52a-41c7-9204-5eb8c12a854c","uuid":"9effd235-c2fa-4215-95a1-ad53f6e6a1a1","timestamp":"2026-03-21T11:36:08.288Z"}
