{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015S5YyXtkXM67Nch2eTyXYi","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→\n     3→vi.mock('../../../lib/deps.js', () => ({\n     4→  installAllDependencies: vi.fn(() => [\n     5→    { name: 'showboat', displayName: 'Showboat', status: 'already-installed', version: '0.6.1' },\n     6→  ]),\n     7→  checkInstalled: vi.fn(() => ({ installed: true, version: '1.0.0' })),\n     8→  DEPENDENCY_REGISTRY: [\n     9→    {\n    10→      name: 'showboat',\n    11→      displayName: 'Showboat',\n    12→      installCommands: [{ cmd: 'pip', args: ['install', 'showboat'] }],\n    13→      checkCommand: { cmd: 'showboat', args: ['--version'] },\n    14→      critical: false,\n    15→    },\n    16→  ],\n    17→  CriticalDependencyError: class CriticalDependencyError extends Error {\n    18→    dependencyName: string;\n    19→    reason: string;\n    20→    constructor(dep: string, reason: string) {\n    21→      super(`Critical dependency '${dep}' failed to install: ${reason}`);\n    22→      this.name = 'CriticalDependencyError';\n    23→      this.dependencyName = dep;\n    24→      this.reason = reason;\n    25→    }\n    26→  },\n    27→}));\n    28→\n    29→import { installAllDependencies, CriticalDependencyError, checkInstalled } from '../../../lib/deps.js';\n    30→import { installDeps, verifyDeps } from '../deps-install.js';\n    31→\n    32→const mockInstallAll = vi.mocked(installAllDependencies);\n    33→const mockCheckInstalled = vi.mocked(checkInstalled);\n    34→\n    35→beforeEach(() => {\n    36→  vi.restoreAllMocks();\n    37→  vi.spyOn(console, 'log').mockImplementation(() => {});\n    38→  mockInstallAll.mockReturnValue([\n    39→    { name: 'showboat', displayName: 'Showboat', status: 'already-installed', version: '0.6.1' },\n    40→  ]);\n    41→  mockCheckInstalled.mockReturnValue({ installed: true, version: '1.0.0' });\n    42→});\n    43→\n    44→describe('installDeps', () => {\n    45→  it('returns ok with dependency results on success', () => {\n    46→    const result = installDeps({ isJson: false });\n    47→    expect(result.success).toBe(true);\n    48→    if (result.success) {\n    49→      expect(result.data).toHaveLength(1);\n    50→      expect(result.data[0].name).toBe('showboat');\n    51→    }\n    52→  });\n    53→\n    54→  it('passes json flag to installAllDependencies', () => {\n    55→    installDeps({ isJson: true });\n    56→    expect(mockInstallAll).toHaveBeenCalledWith({ json: true });\n    57→  });\n    58→\n    59→  it('returns fail for CriticalDependencyError', () => {\n    60→    mockInstallAll.mockImplementation(() => {\n    61→      throw new CriticalDependencyError('git', 'not found');\n    62→    });\n    63→    const result = installDeps({ isJson: false });\n    64→    expect(result.success).toBe(false);\n    65→    if (!result.success) {\n    66→      expect(result.error).toContain('git');\n    67→    }\n    68→  });\n    69→\n    70→  it('catches non-CriticalDependencyError and returns fail', () => {\n    71→    mockInstallAll.mockImplementation(() => {\n    72→      throw new TypeError('unexpected');\n    73→    });\n    74→    const result = installDeps({ isJson: false });\n    75→    expect(result.success).toBe(false);\n    76→    if (!result.success) {\n    77→      expect(result.error).toContain('unexpected');\n    78→    }\n    79→  });\n    80→});\n    81→\n    82→describe('verifyDeps', () => {\n    83→  it('returns dependency results for each registered dep', () => {\n    84→    const results = verifyDeps(false);\n    85→    expect(results).toHaveLength(1);\n    86→    expect(results[0].status).toBe('already-installed');\n    87→  });\n    88→\n    89→  it('reports failed status when dep not installed', () => {\n    90→    mockCheckInstalled.mockReturnValue({ installed: false, version: null });\n    91→    const results = verifyDeps(false);\n    92→    expect(results[0].status).toBe('failed');\n    93→  });\n    94→\n    95→  it('suppresses console output in json mode', () => {\n    96→    const spy = vi.spyOn(console, 'log');\n    97→    verifyDeps(true);\n    98→    expect(spy).not.toHaveBeenCalled();\n    99→  });\n   100→});\n   101→"}]},"parent_tool_use_id":"toolu_012NCb8jmuC161JN1KxhvDkE","session_id":"b2eefe49-15c3-4418-957c-7920103cee96","uuid":"6fecb157-c28b-48e2-b64d-489a4c7f3e53","timestamp":"2026-03-23T06:23:42.092Z"}
