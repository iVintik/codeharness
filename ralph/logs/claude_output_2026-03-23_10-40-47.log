{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016UaxA8DThSbKHvq2gJoszX","type":"tool_result","content":"     1→/**\n     2→ * Dockerfile template generator — creates stack-appropriate Dockerfiles for user projects.\n     3→ * Returns Result<DockerfileTemplateResult> following the project's Result<T> pattern.\n     4→ *\n     5→ * FR22 (Dockerfile template based on project type).\n     6→ */\n     7→\n     8→import { existsSync, writeFileSync } from 'node:fs';\n     9→import { join } from 'node:path';\n    10→import { ok, fail } from '../../types/result.js';\n    11→import type { Result } from '../../types/result.js';\n    12→\n    13→/** Result returned by generateDockerfileTemplate */\n    14→export interface DockerfileTemplateResult {\n    15→  readonly path: string;\n    16→  readonly stack: string;\n    17→}\n    18→\n    19→// ─── Template content generators ────────────────────────────────────────────\n    20→\n    21→function nodejsTemplate(): string {\n    22→  return `# Base image — pinned version for reproducibility\n    23→FROM node:22-slim\n    24→\n    25→ARG TARBALL=package.tgz\n    26→\n    27→# System utilities for verification\n    28→RUN apt-get update && apt-get install -y --no-install-recommends curl jq && rm -rf /var/lib/apt/lists/*\n    29→\n    30→# Install project from tarball (black-box: no source code)\n    31→COPY \\${TARBALL} /tmp/\\${TARBALL}\n    32→RUN npm install -g /tmp/\\${TARBALL} && rm /tmp/\\${TARBALL}\n    33→\n    34→# Run as non-root user\n    35→USER node\n    36→\n    37→WORKDIR /workspace\n    38→`;\n    39→}\n    40→\n    41→function pythonTemplate(): string {\n    42→  return `# Base image — pinned version for reproducibility\n    43→FROM python:3.12-slim\n    44→\n    45→# System utilities for verification\n    46→RUN apt-get update && apt-get install -y --no-install-recommends curl jq && rm -rf /var/lib/apt/lists/*\n    47→\n    48→# Install project from wheel or sdist\n    49→COPY dist/ /tmp/dist/\n    50→RUN pip install /tmp/dist/*.whl && rm -rf /tmp/dist/ && pip cache purge\n    51→\n    52→# Run as non-root user\n    53→USER nobody\n    54→\n    55→WORKDIR /workspace\n    56→`;\n    57→}\n    58→\n    59→function genericTemplate(): string {\n    60→  return `# Base image — pinned version for reproducibility\n    61→FROM node:22-slim\n    62→\n    63→# System utilities for verification\n    64→RUN apt-get update && apt-get install -y --no-install-recommends bash curl jq git && rm -rf /var/lib/apt/lists/*\n    65→\n    66→# Install project binary (update this for your project)\n    67→RUN npm install -g placeholder && npm cache clean --force\n    68→\n    69→# Run as non-root user\n    70→USER node\n    71→\n    72→WORKDIR /workspace\n    73→`;\n    74→}\n    75→\n    76→// ─── Main generator ─────────────────────────────────────────────────────────\n    77→\n    78→/**\n    79→ * Generate a Dockerfile template based on detected stack type.\n    80→ * Returns fail() if a Dockerfile already exists — caller handles messaging.\n    81→ */\n    82→export function generateDockerfileTemplate(\n    83→  projectDir: string,\n    84→  stack: string | null,\n    85→): Result<DockerfileTemplateResult> {\n    86→  if (!projectDir) {\n    87→    return fail('projectDir is required');\n    88→  }\n    89→\n    90→  const dockerfilePath = join(projectDir, 'Dockerfile');\n    91→\n    92→  if (existsSync(dockerfilePath)) {\n    93→    return fail('Dockerfile already exists');\n    94→  }\n    95→\n    96→  let content: string;\n    97→  let resolvedStack: string;\n    98→\n    99→  if (stack === 'nodejs') {\n   100→    content = nodejsTemplate();\n   101→    resolvedStack = 'nodejs';\n   102→  } else if (stack === 'python') {\n   103→    content = pythonTemplate();\n   104→    resolvedStack = 'python';\n   105→  } else {\n   106→    content = genericTemplate();\n   107→    resolvedStack = 'generic';\n   108→  }\n   109→\n   110→  try {\n   111→    writeFileSync(dockerfilePath, content, 'utf-8');\n   112→  } catch (err) {\n   113→    const message = err instanceof Error ? err.message : String(err);\n   114→    return fail(`Failed to write Dockerfile: ${message}`);\n   115→  }\n   116→\n   117→  return ok({ path: dockerfilePath, stack: resolvedStack });\n   118→}\n   119→"}]},"parent_tool_use_id":"toolu_012HPL1qucK3HTi3z4CmV3pn","session_id":"daf25720-e009-4a3c-8a3c-df9d68d99484","uuid":"5e28ab8a-4d96-4076-ae71-1fb01565a7db","timestamp":"2026-03-23T06:46:04.665Z"}
