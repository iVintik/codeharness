{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019jaeGSKSqQKW4vA5uSUgAm","type":"tool_result","content":"   182в†’});\n   183в†’\n   184в†’describe('updateStoryStatus', () => {\n   185в†’  it('creates file if missing and updates story', () => {\n   186в†’    const result = updateStoryStatus('story-1', 'in-progress');\n   187в†’    expect(result.success).toBe(true);\n   188в†’    expect(existsSync(stateFile())).toBe(true);\n   189в†’\n   190в†’    const state = JSON.parse(readFileSync(stateFile(), 'utf-8')) as SprintState;\n   191в†’    expect(state.stories['story-1'].status).toBe('in-progress');\n   192в†’    expect(state.stories['story-1'].attempts).toBe(1);\n   193в†’    expect(state.sprint.inProgress).toBe('story-1');\n   194в†’  });\n   195в†’\n   196в†’  it('updates existing story preserving other stories', () => {\n   197в†’    updateStoryStatus('story-1', 'in-progress');\n   198в†’    updateStoryStatus('story-2', 'done');\n   199в†’\n   200в†’    const state = JSON.parse(readFileSync(stateFile(), 'utf-8')) as SprintState;\n   201в†’    expect(state.stories['story-1']).toBeDefined();\n   202в†’    expect(state.stories['story-2'].status).toBe('done');\n   203в†’    expect(state.sprint.done).toBe(1);\n   204в†’    expect(state.sprint.total).toBe(2);\n   205в†’  });\n   206в†’\n   207в†’  it('attaches error detail when provided', () => {\n   208в†’    updateStoryStatus('story-1', 'failed', { error: 'build broke' });\n   209в†’\n   210в†’    const state = JSON.parse(readFileSync(stateFile(), 'utf-8')) as SprintState;\n   211в†’    expect(state.stories['story-1'].lastError).toBe('build broke');\n   212в†’    expect(state.stories['story-1'].status).toBe('failed');\n   213в†’    expect(state.sprint.failed).toBe(1);\n   214в†’  });\n   215в†’\n   216в†’  it('attaches proofPath when provided', () => {\n   217в†’    updateStoryStatus('story-1', 'done', {\n   218в†’      proofPath: 'docs/proof.md',\n   219в†’    });\n   220в†’\n   221в†’    const state = JSON.parse(readFileSync(stateFile(), 'utf-8')) as SprintState;\n   222в†’    expect(state.stories['story-1'].proofPath).toBe('docs/proof.md');\n   223в†’  });\n   224в†’\n   225в†’  it('increments attempts only on in-progress transition', () => {\n   226в†’    updateStoryStatus('story-1', 'in-progress');\n   227в†’    updateStoryStatus('story-1', 'failed', { error: 'oops' });\n   228в†’    updateStoryStatus('story-1', 'in-progress');\n   229в†’\n   230в†’    const state = JSON.parse(readFileSync(stateFile(), 'utf-8')) as SprintState;\n   231в†’    expect(state.stories['story-1'].attempts).toBe(2);\n   232в†’  });\n   233в†’\n   234в†’  it('uses atomic write (tmp then rename)', () => {\n   235в†’    updateStoryStatus('story-1', 'done');\n   236в†’    expect(existsSync(tmpFile())).toBe(false);\n   237в†’    expect(existsSync(stateFile())).toBe(true);\n   238в†’  });\n   239в†’\n   240в†’  it('round-trips state correctly (write then read)', () => {\n   241в†’    updateStoryStatus('roundtrip', 'verifying');\n   242в†’\n   243в†’    const result = getSprintState();\n   244в†’    expect(result.success).toBe(true);\n   245в†’    if (result.success) {\n   246в†’      expect(result.data.stories['roundtrip'].status).toBe('verifying');\n   247в†’    }\n   248в†’  });\n   249в†’});\n   250в†’\n   251в†’describe('lastAttempt semantics and error paths', () => {\n   252в†’  it('sets lastAttempt only on in-progress transitions', () => {\n   253в†’    updateStoryStatus('story-1', 'in-progress');\n   254в†’    const state1 = JSON.parse(readFileSync(stateFile(), 'utf-8')) as SprintState;\n   255в†’    const firstAttemptTime = state1.stories['story-1'].lastAttempt;\n   256в†’    expect(firstAttemptTime).not.toBeNull();\n   257в†’    updateStoryStatus('story-1', 'done');\n   258в†’    const state2 = JSON.parse(readFileSync(stateFile(), 'utf-8')) as SprintState;\n   259в†’    expect(state2.stories['story-1'].lastAttempt).toBe(firstAttemptTime);\n   260в†’  });\n   261в†’\n   262в†’  it('writeStateAtomic returns fail on serialization error', () => {\n   263в†’    const poison = {\n   264в†’      ...defaultState(),\n   265в†’      toJSON() { throw new Error('Serialization error'); },\n   266в†’    } as unknown as SprintState;\n   267в†’    const result = writeStateAtomic(poison);\n   268в†’    expect(result.success).toBe(false);\n   269в†’    if (!result.success) {\n   270в†’      expect(result.error).toContain('Failed to write sprint state');\n   271в†’    }\n   272в†’  });\n   273в†’\n   274в†’  it('computeSprintCounts counts all status types', async () => {\n   275в†’    const { computeSprintCounts } = await import('../state.js');\n   276в†’    const mk = (s: string) => ({ status: s as 'done', attempts: 0, lastAttempt: null, lastError: null, proofPath: null, acResults: null });\n   277в†’    const counts = computeSprintCounts({ a: mk('done'), b: mk('failed'), c: mk('blocked'), d: mk('in-progress'), e: mk('backlog') });\n   278в†’    expect(counts).toEqual({ total: 5, done: 1, failed: 1, blocked: 1, inProgress: 'd' });\n   279в†’  });\n   280в†’});\n   281в†’\n   282в†’describe('concurrent writes', () => {\n   283в†’  it('both writes produce valid JSON', () => {\n   284в†’    updateStoryStatus('concurrent-1', 'in-progress');\n   285в†’    updateStoryStatus('concurrent-2', 'done');\n   286в†’\n   287в†’    const raw = readFileSync(stateFile(), 'utf-8');\n   288в†’    expect(() => JSON.parse(raw)).not.toThrow();\n   289в†’\n   290в†’    const state = JSON.parse(raw) as SprintState;\n   291в†’    expect(state.stories['concurrent-1']).toBeDefined();\n   292в†’    expect(state.stories['concurrent-2']).toBeDefined();\n   293в†’    expect(state.stories['concurrent-2'].status).toBe('done');\n   294в†’  });\n   295в†’});\n   296в†’"}]},"parent_tool_use_id":null,"session_id":"2a44c687-0795-47af-a7f4-46576056f827","uuid":"86257dee-4b2b-4402-a817-01254ef5cd8c","timestamp":"2026-03-27T15:11:27.428Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ivintik/dev/personal/codeharness/src/modules/sprint/__tests__/state.test.ts","content":"});\n\ndescribe('updateStoryStatus', () => {\n  it('creates file if missing and updates story', () => {\n    const result = updateStoryStatus('story-1', 'in-progress');\n    expect(result.success).toBe(true);\n    expect(existsSync(stateFile())).toBe(true);\n\n    const state = JSON.parse(readFileSync(stateFile(), 'utf-8')) as SprintState;\n    expect(state.stories['story-1'].status).toBe('in-progress');\n    expect(state.stories['story-1'].attempts).toBe(1);\n    expect(state.sprint.inProgress).toBe('story-1');\n  });\n\n  it('updates existing story preserving other stories', () => {\n    updateStoryStatus('story-1', 'in-progress');\n    updateStoryStatus('story-2', 'done');\n\n    const state = JSON.parse(readFileSync(stateFile(), 'utf-8')) as SprintState;\n    expect(state.stories['story-1']).toBeDefined();\n    expect(state.stories['story-2'].status).toBe('done');\n    expect(state.sprint.done).toBe(1);\n    expect(state.sprint.total).toBe(2);\n  });\n\n  it('attaches error detail when provided', () => {\n    updateStoryStatus('story-1', 'failed', { error: 'build broke' });\n\n    const state = JSON.parse(readFileSync(stateFile(), 'utf-8')) as SprintState;\n    expect(state.stories['story-1'].lastError).toBe('build broke');\n    expect(state.stories['story-1'].status).toBe('failed');\n    expect(state.sprint.failed).toBe(1);\n  });\n\n  it('attaches proofPath when provided', () => {\n    updateStoryStatus('story-1', 'done', {\n      proofPath: 'docs/proof.md',\n    });\n\n    const state = JSON.parse(readFileSync(stateFile(), 'utf-8')) as SprintState;\n    expect(state.stories['story-1'].proofPath).toBe('docs/proof.md');\n  });\n\n  it('increments attempts only on in-progress transition', () => {\n    updateStoryStatus('story-1', 'in-progress');\n    updateStoryStatus('story-1', 'failed', { error: 'oops' });\n    updateStoryStatus('story-1', 'in-progress');\n\n    const state = JSON.parse(readFileSync(stateFile(), 'utf-8')) as SprintState;\n    expect(state.stories['story-1'].attempts).toBe(2);\n  });\n\n  it('uses atomic write (tmp then rename)', () => {\n    updateStoryStatus('story-1', 'done');\n    expect(existsSync(tmpFile())).toBe(false);\n    expect(existsSync(stateFile())).toBe(true);\n  });\n\n  it('round-trips state correctly (write then read)', () => {\n    updateStoryStatus('roundtrip', 'verifying');\n\n    const result = getSprintState();\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.stories['roundtrip'].status).toBe('verifying');\n    }\n  });\n});\n\ndescribe('lastAttempt semantics and error paths', () => {\n  it('sets lastAttempt only on in-progress transitions', () => {\n    updateStoryStatus('story-1', 'in-progress');\n    const state1 = JSON.parse(readFileSync(stateFile(), 'utf-8')) as SprintState;\n    const firstAttemptTime = state1.stories['story-1'].lastAttempt;\n    expect(firstAttemptTime).not.toBeNull();\n    updateStoryStatus('story-1', 'done');\n    const state2 = JSON.parse(readFileSync(stateFile(), 'utf-8')) as SprintState;\n    expect(state2.stories['story-1'].lastAttempt).toBe(firstAttemptTime);\n  });\n\n  it('writeStateAtomic returns fail on serialization error', () => {\n    const poison = {\n      ...defaultState(),\n      toJSON() { throw new Error('Serialization error'); },\n    } as unknown as SprintState;\n    const result = writeStateAtomic(poison);\n    expect(result.success).toBe(false);\n    if (!result.success) {\n      expect(result.error).toContain('Failed to write sprint state');\n    }\n  });\n\n  it('computeSprintCounts counts all status types', async () => {\n    const { computeSprintCounts } = await import('../state.js');\n    const mk = (s: string) => ({ status: s as 'done', attempts: 0, lastAttempt: null, lastError: null, proofPath: null, acResults: null });\n    const counts = computeSprintCounts({ a: mk('done'), b: mk('failed'), c: mk('blocked'), d: mk('in-progress'), e: mk('backlog') });\n    expect(counts).toEqual({ total: 5, done: 1, failed: 1, blocked: 1, inProgress: 'd' });\n  });\n});\n\ndescribe('concurrent writes', () => {\n  it('both writes produce valid JSON', () => {\n    updateStoryStatus('concurrent-1', 'in-progress');\n    updateStoryStatus('concurrent-2', 'done');\n\n    const raw = readFileSync(stateFile(), 'utf-8');\n    expect(() => JSON.parse(raw)).not.toThrow();\n\n    const state = JSON.parse(raw) as SprintState;\n    expect(state.stories['concurrent-1']).toBeDefined();\n    expect(state.stories['concurrent-2']).toBeDefined();\n    expect(state.stories['concurrent-2'].status).toBe('done');\n  });\n});\n","numLines":115,"startLine":182,"totalLines":296}}}
