{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SBRoaLSko4TvSsfVVGreMx","type":"tool_result","content":"399\t\n400\t  // 10. If the driver reported an error in the result event, throw DispatchError\n401\t  if (errorEvent) {\n402\t    // Map ErrorCategory to DispatchErrorCode\n403\t    const categoryToCode: Record<string, string> = {\n404\t      RATE_LIMIT: 'RATE_LIMIT',\n405\t      NETWORK: 'NETWORK',\n406\t      SDK_INIT: 'SDK_INIT',\n407\t      AUTH: 'UNKNOWN',\n408\t      TIMEOUT: 'UNKNOWN',\n409\t      UNKNOWN: 'UNKNOWN',\n410\t    };\n411\t    const code = categoryToCode[errorEvent.errorCategory ?? 'UNKNOWN'] ?? 'UNKNOWN';\n412\t    throw new DispatchError(\n413\t      errorEvent.error,\n414\t      code as DispatchErrorCode,\n415\t      definition.name,\n416\t      errorEvent,\n417\t    );\n418\t  }\n419\t\n420\t  // 11. Record session ID (if dispatch returned one)\n421\t  let updatedState = state;\n422\t  if (resultSessionId) {\n423\t    updatedState = recordSessionId(sessionKey, resultSessionId, updatedState);\n424\t  } else {\n425\t    // Append checkpoint manually when no session ID is returned\n426\t    const checkpoint: TaskCheckpoint = {\n427\t      task_name: taskName,\n428\t      story_key: storyKey,\n429\t      completed_at: new Date().toISOString(),\n430\t    };\n431\t    updatedState = {\n432\t      ...updatedState,\n433\t      tasks_completed: [...updatedState.tasks_completed, checkpoint],\n434\t    };\n435\t  }\n436\t\n437\t  // 12. Record trace ID\n438\t  updatedState = recordTraceId(traceId, updatedState);\n439\t\n440\t  // 12b. Construct and write output contract (Task 1)\n441\t  const durationMs = Date.now() - startMs;\n442\t  let contract: OutputContract | null = null;\n443\t  try {\n444\t    contract = {\n445\t      version: 1,\n446\t      taskName,\n447\t      storyId: storyKey,\n448\t      driver: driverName,\n449\t      model,\n450\t      timestamp: new Date().toISOString(),\n451\t      cost_usd: cost > 0 ? cost : null,\n452\t      duration_ms: durationMs,\n453\t      changedFiles,\n454\t      testResults: null,\n455\t      output,\n456\t      acceptanceCriteria: [],\n457\t    };\n458\t    writeOutputContract(contract, join(projectDir, '.codeharness', 'contracts'));\n459\t  } catch (err: unknown) {\n460\t    const message = err instanceof Error ? err.message : String(err);\n461\t    warn(`workflow-engine: failed to write output contract for ${taskName}/${storyKey}: ${message}`);\n462\t    contract = null;\n463\t  }\n464\t\n465\t  // 13. Write state to disk\n466\t  writeWorkflowState(updatedState, projectDir);\n467\t\n468\t  return { updatedState, output, contract };\n469\t}\n470\t\n471\t// --- Retry Prompt Construction (Task 3) ---\n472\t\n473\t/**\n474\t * Build a retry prompt with evaluator findings injected.\n475\t * Includes only failed/unknown findings.\n476\t */\n477\texport function buildRetryPrompt(storyKey: string, findings: EvaluatorVerdict['findings']): string {\n478\t  const failedFindings = findings.filter(\n479\t    (f) => f.status === 'fail' || f.status === 'unknown',\n480\t  );\n481\t\n482\t  if (failedFindings.length === 0) {\n483\t    return `Implement story ${storyKey}`;\n484\t  }\n485\t\n486\t  const formattedFindings = failedFindings\n487\t    .map((f) => {\n488\t      const status = f.status.toUpperCase();\n489\t      let entry = `AC #${f.ac} (${status}): ${f.description}`;\n490\t      if (f.evidence?.reasoning) {\n491\t        entry += `\\n  Evidence: ${f.evidence.reasoning}`;\n492\t      }\n493\t      return entry;\n494\t    })\n495\t    .join('\\n\\n');\n496\t\n497\t  return `Retry story ${storyKey}. Previous evaluator findings:\\n\\n${formattedFindings}\\n\\nFocus on fixing the failed criteria above.`;\n498\t}\n499\t\n500\t// --- All-UNKNOWN Verdict Builder ---\n501\t\n502\t/**\n503\t * Build an all-UNKNOWN EvaluatorVerdict as fallback when the evaluator\n504\t * fails to produce valid JSON after retry.\n505\t */\n506\texport function buildAllUnknownVerdict(\n507\t  workItems: WorkItem[],\n508\t  reasoning: string,\n509\t): EvaluatorVerdict {\n510\t  const findings = workItems.map((_, index) => ({\n511\t    ac: index + 1,\n512\t    description: `AC #${index + 1}`,\n513\t    status: 'unknown' as const,\n514\t    evidence: {\n515\t      commands_run: [] as string[],\n516\t      output_observed: '',\n517\t      reasoning,\n518\t    },\n519\t  }));\n520\t\n521\t  return {\n522\t    verdict: 'fail',\n523\t    score: {\n524\t      passed: 0,\n525\t      failed: 0,\n526\t      unknown: findings.length,\n527\t      total: findings.length,\n528\t    },\n529\t    findings,\n530\t  };\n531\t}\n532\t\n533\t// --- Failed Story Filtering (Task 4) ---\n534\t\n535\t/**\n536\t * Determine which work items failed based on evaluator findings.\n537\t * If verdict is null (parse failure), returns all items (conservative fallback).\n538\t */\n539\texport function getFailedItems(\n540\t  verdict: EvaluatorVerdict | null,\n541\t  allItems: WorkItem[],\n542\t): WorkItem[] {\n543\t  if (!verdict) return allItems;\n544\t\n545\t  // If verdict passed, no items need retry\n546\t  if (verdict.verdict === 'pass') return [];\n547\t\n548\t  // All items are retried on failure — per-story filtering based on individual\n549\t  // story results is not possible with the current verdict shape (verdict is per-run).\n550\t  // The findings track ACs, not stories. Conservative: retry all on failure.\n551\t  return allItems;\n552\t}\n553\t\n554\t// --- Loop Block Execution (Task 5) ---\n555\t\n556\t/**\n557\t * Result of loop block execution.\n558\t */\n559\tinterface LoopBlockResult {\n560\t  state: WorkflowState;\n561\t  errors: EngineError[];\n562\t  tasksCompleted: number;\n563\t  halted: boolean;\n564\t  lastContract: OutputContract | null;\n565\t}\n566\t\n567\t/**\n568\t * Execute a loop block: iterate tasks until pass, max iterations, or circuit breaker.\n569\t */\n570\texport async function executeLoopBlock(\n571\t  loopBlock: LoopBlock,\n572\t  state: WorkflowState,\n573\t  config: EngineConfig,\n574\t  workItems: WorkItem[],\n575\t  initialContract?: OutputContract | null,\n576\t): Promise<LoopBlockResult> {\n577\t  const projectDir = config.projectDir ?? process.cwd();\n578\t  const maxIterations = config.maxIterations ?? DEFAULT_MAX_ITERATIONS;\n579\t  const errors: EngineError[] = [];\n580\t  let tasksCompleted = 0;\n581\t  let currentState = state;\n582\t  let lastVerdict: EvaluatorVerdict | null = null;\n583\t  let lastOutputContract: OutputContract | null = initialContract ?? null;\n584\t\n585\t  // Handle empty loop block\n586\t  if (loopBlock.loop.length === 0) {\n587\t    return { state: currentState, errors, tasksCompleted, halted: false, lastContract: lastOutputContract };\n588\t  }\n589\t\n590\t  while (true) {\n591\t    // 1. Determine whether to increment iteration or resume a partial one.\n592\t    //    On fresh start (iteration === 0), always increment.\n593\t    //    On resume (iteration > 0), check if the current iteration is fully done.\n594\t    const nextIteration = currentState.iteration + 1;\n595\t    const allCurrentIterationDone = currentState.iteration > 0 && loopBlock.loop.every((tn) => {\n596\t      const t = config.workflow.tasks[tn];\n597\t      if (!t) return true; // missing task = skip = \"done\"\n598\t      if (t.scope === 'per-story') {"}]},"parent_tool_use_id":"toolu_01SkXPMmo5ukZsEWidXQjyr7","session_id":"d2473842-56c4-49f2-ab43-68fabe9113bb","uuid":"c33b7f7d-e24a-42f6-823e-1f1af7ec761a","timestamp":"2026-04-03T10:58:12.305Z"}
