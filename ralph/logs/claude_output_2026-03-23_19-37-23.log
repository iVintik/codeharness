\n   736→\n   737→// ─── buildVerifyImage — Rust project (AC #3, #4, #5, #6) ────────────────────\n   738→\n   739→describe('buildVerifyImage — Rust project', () => {\n   740→  it('builds Rust image when detectStack returns rust (AC #4)', () => {\n   741→    mockDetectStack.mockReturnValue('rust' as ReturnType<typeof detectStack>);\n   742→    writeFileSync(join(testDir, 'templates', 'Dockerfile.verify.rust'), 'FROM rust:1.82-slim\\n');\n   743→\n   744→    mockExecFileSync\n   745→      .mockReturnValueOnce(Buffer.from('')) // docker build\n   746→      .mockReturnValueOnce(Buffer.from('150000000')); // docker image inspect (size)\n   747→\n   748→    const result = buildVerifyImage({ projectDir: testDir });\n   749→    expect(result.cached).toBe(false);\n   750→    expect(result.imageTag).toBe('codeharness-verify');\n   751→\n   752→    const buildCall = mockExecFileSync.mock.calls.find(\n   753→      c => (c[1] as string[]).includes('build'),\n   754→    );\n   755→    expect(buildCall).toBeDefined();\n   756→    // Rust build should NOT have --build-arg TARBALL (no tarball for Rust)\n   757→    expect((buildCall![1] as string[])).not.toContain('--build-arg');\n   758→  });\n   759→\n   760→  it('does not throw for Rust projects without dist/ (AC #4)', () => {\n   761→    mockDetectStack.mockReturnValue('rust' as ReturnType<typeof detectStack>);\n   762→    writeFileSync(join(testDir, 'templates', 'Dockerfile.verify.rust'), 'FROM rust:1.82-slim\\n');\n   763→\n   764→    mockExecFileSync\n   765→      .mockReturnValueOnce(Buffer.from('')) // docker build\n   766→      .mockReturnValueOnce(Buffer.from('150000000')); // docker image inspect (size)\n   767→\n   768→    expect(() => buildVerifyImage({ projectDir: testDir })).not.toThrow();\n   769→  });\n   770→\n   771→  it('resolves Dockerfile.verify.rust template for rust variant (AC #5)', () => {\n   772→    writeFileSync(join(testDir, 'templates', 'Dockerfile.verify.rust'), 'FROM rust:1.82-slim\\n');\n   773→   