{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VB64ouqQ6u2rciyvzJWtEq","type":"tool_result","content":"598\toverrides:\n599\t  tasks:\n600\t    implement:\n601\t      session: continue\n602\t`;\n603\t    const filePath = writeYaml('valid.patch.yaml', patchContent);\n604\t    const result = loadWorkflowPatch(filePath);\n605\t    expect(result).not.toBeNull();\n606\t    expect(result!.extends).toBe('embedded://default');\n607\t    expect(result!.overrides).toBeDefined();\n608\t    expect((result!.overrides!.tasks as Record<string, unknown>).implement).toBeDefined();\n609\t  });\n610\t});\n611\t\n612\tdescribe('mergeWorkflowPatch', () => {\n613\t  const base: Record<string, unknown> = {\n614\t    tasks: {\n615\t      implement: { agent: 'dev', scope: 'per-story', session: 'fresh', source_access: true },\n616\t      verify: { agent: 'evaluator', scope: 'per-run', session: 'fresh', source_access: false },\n617\t    },\n618\t    flow: ['implement', 'verify'],\n619\t  };\n620\t\n621\t  it('handles overrides-only patch (deep merge)', () => {\n622\t    const patch: WorkflowPatch = {\n623\t      overrides: {\n624\t        tasks: {\n625\t          implement: { session: 'continue', max_budget_usd: 5.0 },\n626\t        },\n627\t      },\n628\t    };\n629\t    const result = mergeWorkflowPatch(base, patch);\n630\t    const tasks = result.tasks as Record<string, Record<string, unknown>>;\n631\t\n632\t    // Deep-merged: implement gets new session and max_budget_usd, keeps agent/scope/source_access\n633\t    expect(tasks.implement.agent).toBe('dev');\n634\t    expect(tasks.implement.scope).toBe('per-story');\n635\t    expect(tasks.implement.session).toBe('continue');\n636\t    expect(tasks.implement.max_budget_usd).toBe(5.0);\n637\t    expect(tasks.implement.source_access).toBe(true);\n638\t\n639\t    // verify unchanged\n640\t    expect(tasks.verify.agent).toBe('evaluator');\n641\t\n642\t    // flow unchanged\n643\t    expect(result.flow).toEqual(['implement', 'verify']);\n644\t  });\n645\t\n646\t  it('handles replace-only patch (full replacement)', () => {\n647\t    const patch: WorkflowPatch = {\n648\t      replace: {\n649\t        flow: ['implement'],\n650\t      },\n651\t    };\n652\t    const result = mergeWorkflowPatch(base, patch);\n653\t\n654\t    // flow fully replaced\n655\t    expect(result.flow).toEqual(['implement']);\n656\t\n657\t    // tasks unchanged\n658\t    const tasks = result.tasks as Record<string, Record<string, unknown>>;\n659\t    expect(tasks.implement.agent).toBe('dev');\n660\t    expect(tasks.verify.agent).toBe('evaluator');\n661\t  });\n662\t\n663\t  it('handles patch with both overrides and replace', () => {\n664\t    const patch: WorkflowPatch = {\n665\t      overrides: {\n666\t        tasks: {\n667\t          implement: { session: 'continue' },\n668\t        },\n669\t      },\n670\t      replace: {\n671\t        flow: ['implement'],\n672\t      },\n673\t    };\n674\t    const result = mergeWorkflowPatch(base, patch);\n675\t    const tasks = result.tasks as Record<string, Record<string, unknown>>;\n676\t\n677\t    // overrides applied\n678\t    expect(tasks.implement.session).toBe('continue');\n679\t    expect(tasks.implement.agent).toBe('dev');\n680\t\n681\t    // replace applied after overrides\n682\t    expect(result.flow).toEqual(['implement']);\n683\t  });\n684\t\n685\t  it('replace overwrites even if overrides also touched the same key', () => {\n686\t    const patch: WorkflowPatch = {\n687\t      overrides: {\n688\t        flow: ['implement', 'verify', 'extra'],\n689\t      },\n690\t      replace: {\n691\t        flow: ['only-this'],\n692\t      },\n693\t    };\n694\t    const result = mergeWorkflowPatch(base, patch);\n695\t    // replace wins because it runs after overrides\n696\t    expect(result.flow).toEqual(['only-this']);\n697\t  });\n698\t});\n699\t\n700\tdescribe('resolveWorkflow', () => {\n701\t  it('returns embedded workflow when no patches exist', () => {\n702\t    // Use a cwd with no .codeharness directory\n703\t    const result = resolveWorkflow({ cwd: testDir });\n704\t\n705\t    // Should return the embedded default workflow\n706\t    expect(result.tasks).toBeDefined();\n707\t    expect(result.tasks.implement).toBeDefined();\n708\t    expect(result.tasks.implement.agent).toBe('dev');\n709\t    expect(result.tasks.verify).toBeDefined();\n710\t    expect(result.tasks.verify.agent).toBe('evaluator');\n711\t    expect(result.flow.length).toBeGreaterThan(0);\n712\t  });\n713\t\n714\t  it('deep-merges overrides from project patch onto embedded base', () => {\n715\t    // Create project patch directory\n716\t    const patchDir = join(testDir, '.codeharness', 'workflows');\n717\t    mkdirSync(patchDir, { recursive: true });\n718\t\n719\t    const patchContent = `\n720\textends: embedded://default\n721\toverrides:\n722\t  tasks:\n723\t    implement:\n724\t      session: continue\n725\t      max_budget_usd: 10.0\n726\t`;\n727\t    writeFileSync(join(patchDir, 'default.patch.yaml'), patchContent, 'utf-8');\n728\t\n729\t    const result = resolveWorkflow({ cwd: testDir });\n730\t\n731\t    expect(result.tasks.implement.session).toBe('continue');\n732\t    expect(result.tasks.implement.max_budget_usd).toBe(10.0);\n733\t    // Preserved from base\n734\t    expect(result.tasks.implement.agent).toBe('dev');\n735\t    expect(result.tasks.implement.scope).toBe('per-story');\n736\t    expect(result.tasks.implement.source_access).toBe(true);\n737\t  });\n738\t\n739\t  it('applies replace sections as full replacement (not deep merge)', () => {\n740\t    const patchDir = join(testDir, '.codeharness', 'workflows');\n741\t    mkdirSync(patchDir, { recursive: true });\n742\t\n743\t    const patchContent = `\n744\textends: embedded://default\n745\treplace:\n746\t  flow:\n747\t    - implement\n748\t    - verify\n749\t`;\n750\t    writeFileSync(join(patchDir, 'default.patch.yaml'), patchContent, 'utf-8');\n751\t\n752\t    const result = resolveWorkflow({ cwd: testDir });\n753\t\n754\t    // flow fully replaced — no loop block from embedded default\n755\t    expect(result.flow).toEqual(['implement', 'verify']);\n756\t  });\n757\t\n758\t  it('applies user patch before project patch (ordering)', () => {\n759\t    // Create user-level patch\n760\t    const userPatchDir = join(os.homedir(), '.codeharness', 'workflows');\n761\t    const userPatchPath = join(userPatchDir, 'default.patch.yaml');\n762\t    let userPatchExisted = false;\n763\t    let originalUserPatch: string | undefined;\n764\t\n765\t    try {\n766\t      originalUserPatch = readFileSync(userPatchPath, 'utf-8');\n767\t      userPatchExisted = true;\n768\t    } catch { /* no existing patch */ }\n769\t\n770\t    try {\n771\t      mkdirSync(userPatchDir, { recursive: true });\n772\t      writeFileSync(userPatchPath, `\n773\textends: embedded://default\n774\toverrides:\n775\t  tasks:\n776\t    implement:\n777\t      session: continue\n778\t      max_budget_usd: 3.0\n779\t`, 'utf-8');\n780\t\n781\t      // Create project-level patch that overrides the user patch\n782\t      const projectPatchDir = join(testDir, '.codeharness', 'workflows');\n783\t      mkdirSync(projectPatchDir, { recursive: true });\n784\t      writeFileSync(join(projectPatchDir, 'default.patch.yaml'), `\n785\textends: embedded://default\n786\toverrides:\n787\t  tasks:\n788\t    implement:\n789\t      max_budget_usd: 7.0\n790\t`, 'utf-8');\n791\t\n792\t      const result = resolveWorkflow({ cwd: testDir });\n793\t\n794\t      // User patch: session=continue, max_budget_usd=3.0\n795\t      // Project patch overrides: max_budget_usd=7.0\n796\t      expect(result.tasks.implement.session).toBe('continue');\n797\t      expect(result.tasks.implement.max_budget_usd).toBe(7.0);"}]},"parent_tool_use_id":"toolu_01LQLKYZKtmy4cEq7pgn6KQD","session_id":"90f775a4-0bf0-4884-b410-4d7f1f50684d","uuid":"7ab6a7e7-0dac-488e-85ca-bcf631437d5f","timestamp":"2026-04-03T08:15:04.586Z"}
