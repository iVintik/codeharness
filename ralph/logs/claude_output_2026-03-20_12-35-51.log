{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UzyDtHqhXa2wp3mGuSPyBb","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { formatAuditHuman, formatAuditJson } from '../report.js';\n     3→import type { AuditResult } from '../types.js';\n     4→\n     5→function makeAuditResult(overrides?: Partial<AuditResult>): AuditResult {\n     6→  return {\n     7→    dimensions: {\n     8→      observability: {\n     9→        name: 'observability',\n    10→        status: 'pass',\n    11→        metric: 'static: 0 gaps, runtime: 100%',\n    12→        gaps: [],\n    13→      },\n    14→      testing: {\n    15→        name: 'testing',\n    16→        status: 'pass',\n    17→        metric: '95%',\n    18→        gaps: [],\n    19→      },\n    20→      documentation: {\n    21→        name: 'documentation',\n    22→        status: 'pass',\n    23→        metric: '5 fresh, 0 stale, 0 missing',\n    24→        gaps: [],\n    25→      },\n    26→      verification: {\n    27→        name: 'verification',\n    28→        status: 'pass',\n    29→        metric: '3/3 verified',\n    30→        gaps: [],\n    31→      },\n    32→      infrastructure: {\n    33→        name: 'infrastructure',\n    34→        status: 'pass',\n    35→        metric: 'Dockerfile valid',\n    36→        gaps: [],\n    37→      },\n    38→    },\n    39→    overallStatus: 'pass',\n    40→    gapCount: 0,\n    41→    durationMs: 150,\n    42→    ...overrides,\n    43→  };\n    44→}\n    45→\n    46→describe('formatAuditHuman', () => {\n    47→  it('includes [OK] prefix for passing dimensions', () => {\n    48→    const result = makeAuditResult();\n    49→    const lines = formatAuditHuman(result);\n    50→\n    51→    expect(lines.some(l => l.startsWith('[OK] observability:'))).toBe(true);\n    52→    expect(lines.some(l => l.startsWith('[OK] testing:'))).toBe(true);\n    53→  });\n    54→\n    55→  it('includes [FAIL] prefix for