{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019bcsVAXTy83xTthxuqg4js","type":"tool_result","content":"     1→import { existsSync, readFileSync, readdirSync } from 'node:fs';\n     2→import { join } from 'node:path';\n     3→import { warn } from './output.js';\n     4→\n     5→// Re-export canonical types from stacks/types.ts for backward compatibility.\n     6→// Existing consumers that `import { StackName, AppType } from './stack-detect.js'` continue to work.\n     7→export type { StackName, AppType } from './stacks/types.js';\n     8→\n     9→export interface StackDetection {\n    10→  stack: StackName;\n    11→  dir: string;\n    12→}\n    13→\n    14→/** Directories to skip during subdirectory scanning. */\n    15→const SKIP_DIRS = new Set([\n    16→  'node_modules',\n    17→  '.git',\n    18→  'target',\n    19→  '__pycache__',\n    20→  'dist',\n    21→  'build',\n    22→  'coverage',\n    23→  '.venv',\n    24→  'venv',\n    25→  '.tox',\n    26→  '.mypy_cache',\n    27→  '.cache',\n    28→]);\n    29→\n    30→/** Stack markers in priority order (nodejs > python > rust). */"}]},"parent_tool_use_id":"toolu_016pVTiEDvkXc8fi67pKiZeQ","session_id":"1d547185-a995-481d-9659-9279ed70f717","uuid":"ccef9d75-7a89-478f-88ca-ccb1bcbc2017","timestamp":"2026-03-24T09:36:23.601Z"}
