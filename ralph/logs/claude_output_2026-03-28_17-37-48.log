{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GzScnzbEZ9dXD5Bt2JdCVr","type":"tool_result","content":"     1→/**\n     2→ * Types for the verify module.\n     3→ * Merged from src/lib/verify.ts and src/lib/verify-parser.ts.\n     4→ */\n     5→\n     6→import type { AcResult } from '../../types/state.js';\n     7→\n     8→// ─── Parser Types ────────────────────────────────────────────────────────────\n     9→\n    10→/** @deprecated Use `VerificationTier` instead. Will be removed in a future release. */\n    11→export type Verifiability = 'cli-verifiable' | 'integration-required';\n    12→\n    13→/** The four verification tiers — what evidence is needed to prove ACs work. */\n    14→export type VerificationTier = 'test-provable' | 'runtime-provable' | 'environment-provable' | 'escalate';\n    15→\n    16→/** Tier ordering from lowest to highest. Index = priority. */\n    17→export const TIER_HIERARCHY: readonly VerificationTier[] = [\n    18→  'test-provable',\n    19→  'runtime-provable',\n    20→  'environment-provable',\n    21→  'escalate',\n    22→] as const;\n    23→\n    24→/** Returns the highest tier from an array of tiers. Empty array -> 'test-provable'. */\n    25→export function maxTier(tiers: VerificationTier[]): VerificationTier {\n    26→  if (tiers.length === 0) return 'test-provable';\n    27→  return tiers.reduce((max, t) =>\n    28→    TIER_HIERARCHY.indexOf(t) > TIER_HIERARCHY.indexOf(max) ? t : max\n    29→  );\n    30→}\n    31→\n    32→/** Maps old tag values to new VerificationTier values for backward compat. */\n    33→export const LEGACY_TIER_MAP: Record<string, VerificationTier> = {\n    34→  'cli-verifiable': 'test-provable',\n    35→  'integration-required': 'environment-provable',\n    36→  'unit-testable': 'test-provable',\n    37→  'black-box': 'environment-provable',\n    38→};\n    39→\n    40→/**\n    41→ * Verification strategy — how the verifier should approach proving an AC.\n    42→ *\n    43→ * @deprecated Use `VerificationTier` instead. Will be removed in a future release.\n    44→ *\n    45→ * - docker:    Run in a Docker container (default, safest)\n    46→ * - cli-direct: Run CLI commands in the current subprocess (fallback)\n    47→ * - escalate:   Truly impossible — requires physical hardware, external paid\n    48→ *               service, or human judgement. Last resort only.\n    49→ */\n    50→export type VerificationStrategy = 'docker' | 'cli-direct' | 'escalate';\n    51→\n    52→export interface ParsedAC {\n    53→  readonly id: string;\n    54→  readonly description: string;\n    55→  readonly type: 'ui' | 'api' | 'db' | 'general';\n    56→  /** @deprecated Use `tier` instead. */\n    57→  readonly verifiability: Verifiability;\n    58→  /** @deprecated Use `tier` instead. */\n    59→  readonly strategy: VerificationStrategy;\n    60→  /** The verification tier for this AC. */"}]},"parent_tool_use_id":"toolu_01FnD1p4BzuwR8M458ncZKjU","session_id":"4b69c0d8-c2d9-426d-9413-456ae301bb7e","uuid":"e1d262ae-404c-449e-9ca1-b02b51b56dc6","timestamp":"2026-03-28T14:01:10.444Z"}
