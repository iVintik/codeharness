sed: 1, failed: 0, unknown: 0, total: 1 },\n1251\t      findings: [],\n1252\t    }))).toThrow();\n1253\t  });\n1254\t\n1255\t  it('throws VerdictParseError for invalid verdict value', () => {\n1256\t    expect(() => parseVerdict(JSON.stringify({\n1257\t      verdict: 'maybe',\n1258\t      score: { passed: 1, failed: 0, unknown: 0, total: 1 },\n1259\t      findings: [],\n1260\t    }))).toThrow();\n1261\t  });\n1262\t\n1263\t  it('throws VerdictParseError for missing score field', () => {\n1264\t    expect(() => parseVerdict(JSON.stringify({\n1265\t      verdict: 'pass',\n1266\t      findings: [],\n1267\t    }))).toThrow();\n1268\t  });\n1269\t\n1270\t  it('throws VerdictParseError for missing findings field', () => {\n1271\t    expect(() => parseVerdict(JSON.stringify({\n1272\t      verdict: 'pass',\n1273\t      score: { passed: 1, failed: 0, unknown: 0, total: 1 },\n1274\t    }))).toThrow();\n1275\t  });\n1276\t\n1277\t  it('throws VerdictParseError for non-object input', () => {\n1278\t    expect(() => parseVerdict('\"just a string\"')).toThrow();\n1279\t    expect(() => parseVerdict('42')).toThrow();\n1280\t    expect(() => parseVerdict('null')).toThrow();\n1281\t  });\n1282\t\n1283\t  it('throws VerdictParseError when score fields are not numbers', () => {\n1284\t    expect(() => parseVerdict(JSON.stringify({\n1285\t      verdict: 'pass',\n1286\t      score: { passed: 'one', failed: 0, unknown: 0, total: 1 },\n1287\t      findings: [],\n1288\t    }))).toThrow();\n1289\t  });\n1290\t});\n1291\t\n1292\tdescribe('buildRetryPrompt', () => {\n1293\t  it('builds prompt with failed findings', () => {\n1294\t    const findings: EvaluatorVerdict['findings'] = [\n1295\t      {\n1296\t        ac: 1,\n1297\t        description: 'Unit tests pass',\n1298\t        status: 'fail',\n1299\t        evidence: { commands_run: ['npm test'], output_observed: 'FAIL', reasoning: 'Tests failed' },\n1300\t      },\n1301\t      {\n1302\t        ac: 2,\n1303\t        description: 'Coverage above 80%',\n1304\t        status: 'pass',\n1305\t        evidence: { commands_run: ['npm test'], output_observed: '90%', reasoning: 'Good coverage' },\n1306\t      },\n1307\t      {\n1308\t        ac: 3,\n1309\t        description: 'Lint clean',\n1310\t        status: 'unknown',\n1311\t        evidence: { commands_run: [], output_observed: '', reasoning: 'Could not verify — timeout' },\n1312\t      },\n1313\t    ];\n1314\t\n1315\t    const prompt = buildRetryPrompt('5-1-foo', findings);\n1316\t\n1317\t    expect(prompt).toContain('Retry story 5-1-foo');\n1318\t    expect(prompt).toContain('AC #1 (FAIL): Unit tests pass');\n1319\t    expect(prompt).toContain('Evidence: Tests failed');\n1320\t    expect(prompt).toContain('AC #3 (UNKNOWN): Lint clean');\n1321\t    expect(prompt).not.toContain('AC #2'); // passed — should be excluded\n1322\t    expect(prompt).toContain('Focus on fixing the failed criteria above.');\n1323\t  });\n1324\t\n1325\t  it('returns default prompt when no failed/unknown findings', () => {\n1326\t    const findings: EvaluatorVerdict['findings'] = [\n1327\t      {\n1328\t        ac: 1,\n1329\t        description: 'All good',\n1330\t        status: 'pass',\n1331\t        evidence: { commands_run: [], output_observed: '', reasoning: '' },\n1332\t      },\n1333\t    ];\n1334\t\n1335\t    const prompt = buildRetryPrompt('5-1-foo', findings);\n1336\t    expect(prompt).toBe('Implement story 5-1-foo');\n1337\t  });\n1338\t\n1339\t  it('returns default prompt for empty findings array', () => {\n1340\t    const prompt = buildRetryPrompt('5-1-foo', []);\n1341\t    expect(prompt).toBe('Implement story 5-1-foo');\n1342\t  });\n1343\t});\n1344\t\n1345\tdescribe('getFailedItems', () => {\n1346\t  const items: WorkItem[] = [\n1347\t    { key: '3-1-foo', source: 'sprint' },\n1348\t    { key: '3-2-bar', source: 'sprint' },\n1349\t  ];\n1350\t\n1351\t  it('returns all items when verdict is null', () => {\n1352\t    expect(getFailedItems(null, items)).toEqual(items);\n1353\t  });\n1354\t\n1355\t  it('returns empty array when verdict is pass', () => {\n1356\t    const verdict: EvaluatorVerdict = {\n1357\t      verdict: 'pass',\n1358\t      score: { passed: 2, failed: 0, unknown: 0, total: 2 },\n1359\t      findings: [],\n1360\t    };\n1361\t    expect(getFailedItems(verdict, items)).toEqual([]);\n1362\t  });\n1363\t\n1364\t  it('returns all items when verdict is fail (conservative)', () => {\n1365\t    const verdict: EvaluatorVerdict = {\n1366\t      verdict: 'fail',\n1367\t      score: { passed: 1, failed: 1, unknown: 0, total: 2 },\n1368\t      findings: [],\n1369\t    };\n1370\t    expect(getFailedItems(verdict, items)).toEqual(items);\n1371\t  });\n1372\t});\n1373\t\n1374\tdescribe('loop block execution', () => {\n1375\t  beforeEach(() => {\n1376\t    vi.clearAllMocks();\n1377\t    setupDefaultMocks();\n1378\t  });\n1379\t\n1380\t  function makePassVerdict(): string {\n1381\t    return JSON.stringify({\n1382\t      verdict: 'pass',\n1383\t      score: { passed: 2, failed: 0, unknown: 0, total: 2 },\n1384\t      findings: [],\n1385\t    });\n1386\t  }\n1387\t\n1388\t  function makeFailVerdict(): string {\n1389\t    return JSON.stringify({\n1390\t      verdict: 'fail',\n1391\t      score: { passed: 1, failed: 1, unknown: 0, total: 2 },\n1392\t      findings: [\n1393\t        {\n1394\t          ac: 1,\n1395\t          description: 'Tests pass',\n1396\t          status: 'fail',\n1397\t          evidence: { commands_run: ['npm test'], output_observed: 'FAIL', reasoning: 'Test suite failed' },"}]},"parent_tool_use_id":"toolu_01SkXPMmo5ukZsEWidXQjyr7","session_id":"d2473842-56c4-49f2-ab43-68fabe9113bb","uuid":"e826e461-de60-4cf5-ac45-ad6edc069cc9","timestamp":"2026-04-03T10:58:41.568Z"}
