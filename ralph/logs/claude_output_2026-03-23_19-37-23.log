=> {\n   229→        throw new Error('connection refused');\n   230→      });\n   231→\n   232→      const { stdout, exitCode } = await runCli(['teardown']);\n   233→\n   234→      expect(stdout).toContain('[WARN] Docker stack: failed to stop (connection refused)');\n   235→      expect(stdout).toContain('[OK] Harness teardown complete');\n   236→      expect(exitCode).toBeUndefined();\n   237→    });\n   238→\n   239→    it('--keep-docker preserves legacy compose files', async () => {\n   240→      createInitializedProject({\n   241→        docker: {\n   242→          compose_file: 'docker-compose.harness.yml',\n   243→          stack_running: true,\n   244→          ports: { logs: 9428, metrics: 8428, traces: 14268, otel_grpc: 4317, otel_http: 4318 },\n   245→        },\n   246→      });\n   247→      const composePath = join(testDir, 'docker-compose.harness.yml');\n   248→      const otelPath = join(testDir, 'otel-collector-config.yaml');\n   249→      writeFileSync(composePath, 'version: \"3\"', 'utf-8');\n   250→      writeFileSync(otelPath, 'receivers:', 'utf-8');\n   251→\n   252→      const { stdout } = await runCli(['teardown', '--keep-docker']);\n   253→\n   254→      expect(stdout).toContain('[INFO] Docker stack: kept (--keep-docker)');\n   255→      expect(mockStopStack).not.toHaveBeenCalled();\n   256→      expect(mockIsStackRunning).not.toHaveBeenCalled();\n   257→      expect(existsSync(composePath)).toBe(true);\n   258→      expect(existsSync(otelPath)).toBe(true);\n   259→    });\n   260→\n   261→    it('still removes state file when --keep-docker is set', async () => {\n   262→      createInitializedProject({\n   263→        docker: {\n   264→          compose_file: 'docker-compose.harness.yml',\n   265→          stack_running: true,\n   266→          ports: { logs: 9428, metrics: 8428, traces: 14268, otel_grpc: 4317, otel_http: 4318 },\n   267→        },\n   268→      });\n   269→      const statePath = join(testDir, '.claude', 'codeharness.local.