{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XgE4aFcM9QCXowPoL4Anoo","type":"tool_result","content":"     1→/**\n     2→ * Stack provider registry — stores registered providers and provides\n     3→ * marker-based stack detection (replacing hardcoded checks).\n     4→ */\n     5→\n     6→import { existsSync, readdirSync } from 'node:fs';\n     7→import { join } from 'node:path';\n     8→import type { StackName, StackProvider } from './types.js';\n     9→\n    10→/** Internal registry map. */\n    11→const providers = new Map<StackName, StackProvider>();\n    12→\n    13→/** Directories to skip during subdirectory scanning. */\n    14→const SKIP_DIRS = new Set([\n    15→  'node_modules',\n    16→  '.git',\n    17→  'target',\n    18→  '__pycache__',\n    19→  'dist',\n    20→  'build',\n    21→  'coverage',\n    22→  '.venv',\n    23→  'venv',\n    24→  '.tox',\n    25→  '.mypy_cache',\n    26→  '.cache',\n    27→]);\n    28→\n    29→/**\n    30→ * Priority order for stack detection.\n    31→ * When multiple stacks match at the same directory level, they appear in this order.\n    32→ */\n    33→const STACK_PRIORITY: StackName[] = ['nodejs', 'python', 'rust'];\n    34→\n    35→/** Register a StackProvider. Overwrites any existing provider for the same name. */\n    36→export function registerProvider(provider: StackProvider): void {\n    37→  providers.set(provider.name, provider);\n    38→}\n    39→\n    40→/** Retrieve a registered provider by name, or undefined if not registered. */\n    41→export function getStackProvider(name: StackName): StackProvider | undefined {\n    42→  return providers.get(name);\n    43→}\n    44→\n    45→/** Detection result: stack name + directory where it was found. */\n    46→export interface StackDetection {\n    47→  stack: StackName;\n    48→  dir: string;\n    49→}\n    50→\n    51→/**\n    52→ * Detect all stacks present in a directory using registered provider markers.\n    53→ * Checks root and one level of subdirectories.\n    54→ * Root stacks appear first (in priority order), then subdirectory stacks sorted alphabetically.\n    55→ */\n    56→export function detectStacks(dir: string = process.cwd()): StackDetection[] {\n    57→  const results: StackDetection[] = [];\n    58→\n    59→  // Build ordered list of providers by priority\n    60→  const ordered = getOrderedProviders();\n    61→\n    62→  // Root scan\n    63→  for (const provider of ordered) {\n    64→    if (hasMarker(dir, provider.markers)) {\n    65→      results.push({ stack: provider.name, dir: '.' });\n    66→    }\n    67→  }\n    68→\n    69→  // Subdirectory scan — one level deep\n    70→  let entries: import('node:fs').Dirent[];\n    71→  try {\n    72→    entries = readdirSync(dir, { withFileTypes: true });\n    73→  } catch {\n    74→    entries = [];\n    75→  }\n    76→\n    77→  const subdirs = entries\n    78→    .filter((e) => e.isDirectory() && !SKIP_DIRS.has(e.name))\n    79→    .map((e) => e.name)\n    80→    .sort();\n    81→\n    82→  for (const subdir of subdirs) {\n    83→    const subdirPath = join(dir, subdir);\n    84→    for (const provider of ordered) {\n    85→      if (hasMarker(subdirPath, provider.markers)) {\n    86→        results.push({ stack: provider.name, dir: subdir });\n    87→      }\n    88→    }\n    89→  }\n    90→\n    91→  return results;\n    92→}\n    93→\n    94→/**\n    95→ * Compat wrapper: returns the first detected ROOT stack name, or null.\n    96→ * Only considers root-level markers (dir === '.'), never subdirectory detections.\n    97→ */\n    98→export function detectStack(dir: string = process.cwd()): StackName | null {\n    99→  const stacks = detectStacks(dir);\n   100→  const rootStack = stacks.find((s) => s.dir === '.');\n   101→  return rootStack ? rootStack.stack : null;\n   102→}\n   103→\n   104→/** Check if any of the marker files exist in the given directory. */\n   105→function hasMarker(dir: string, markers: string[]): boolean {\n   106→  return markers.some((marker) => existsSync(join(dir, marker)));\n   107→}\n   108→\n   109→/** Return providers ordered by STACK_PRIORITY, then any extras at the end. */\n   110→function getOrderedProviders(): StackProvider[] {\n   111→  const ordered: StackProvider[] = [];\n   112→  for (const name of STACK_PRIORITY) {\n   113→    const p = providers.get(name);\n   114→    if (p) ordered.push(p);\n   115→  }\n   116→  // Add any providers not in the priority list\n   117→  for (const [name, provider] of providers) {\n   118→    if (!STACK_PRIORITY.includes(name)) {\n   119→      ordered.push(provider);\n   120→    }\n   121→  }\n   122→  return ordered;\n   123→}\n   124→\n   125→/**\n   126→ * Reset the registry (for testing only).\n   127→ * @internal\n   128→ */\n   129→export function _resetRegistry(): void {\n   130→  providers.clear();\n   131→}\n   132→"}]},"parent_tool_use_id":"toolu_01NBw9a8P5guFFtTFy7if2e9","session_id":"31f79ff4-68ea-4b44-861b-4091a0c239f5","uuid":"551b8be6-1350-4094-af0d-b23f130d26c8","timestamp":"2026-03-24T07:46:14.971Z"}
