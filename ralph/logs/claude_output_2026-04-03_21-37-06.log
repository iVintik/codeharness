{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CELVJ8kYZnXdRqdQjdMKvk","type":"tool_result","content":"1\t/**\n2\t * Null Task Handler Registry.\n3\t *\n4\t * Provides a registry pattern for tasks with `agent: null` that execute\n5\t * directly in the engine without LLM dispatch. Handlers are registered at\n6\t * module initialization time. The engine calls `getNullTask(name)` to look\n7\t * up a handler and execute it inline.\n8\t *\n9\t * @see Story 16-2: Engine-Handled Null Tasks\n10\t */\n11\t\n12\timport type { OutputContract } from './agents/types.js';\n13\t\n14\t// --- Interfaces ---\n15\t\n16\t/**\n17\t * Context passed to a null task handler.\n18\t */\n19\texport interface TaskContext {\n20\t  /** Story key (e.g., \"16-2-engine-handled-null-tasks\") or \"__run__\" for per-run. */\n21\t  storyKey: string;\n22\t  /** Task name (e.g., \"telemetry\"). */\n23\t  taskName: string;\n24\t  /** Accumulated cost from previous tasks (USD). */\n25\t  cost: number;\n26\t  /** Elapsed time since workflow start (ms). */\n27\t  durationMs: number;\n28\t  /** Previous task's output contract, or null if first task. */\n29\t  outputContract: OutputContract | null;\n30\t  /** Project root directory. */\n31\t  projectDir: string;\n32\t}\n33\t\n34\t/**\n35\t * Result returned by a null task handler.\n36\t */\n37\texport interface NullTaskResult {\n38\t  /** Whether the handler completed successfully. */\n39\t  success: boolean;\n40\t  /** Optional text output for logging. */\n41\t  output?: string;\n42\t}\n43\t\n44\t/**\n45\t * A null task handler function.\n46\t */\n47\texport type NullTaskHandler = (ctx: TaskContext) => Promise<NullTaskResult>;\n48\t\n49\t// --- Registry ---\n50\t\n51\tconst registry = new Map<string, NullTaskHandler>();\n52\t\n53\t/**\n54\t * Register a null task handler.\n55\t *\n56\t * @param name  The task name to register (must match the task key in workflow YAML).\n57\t * @param handler  The handler function to execute when this task is reached.\n58\t */\n59\texport function registerNullTask(name: string, handler: NullTaskHandler): void {\n60\t  registry.set(name, handler);\n61\t}\n62\t\n63\t/**\n64\t * Look up a registered null task handler.\n65\t *\n66\t * @param name  The task name to look up.\n67\t * @returns The handler function, or `undefined` if no handler is registered.\n68\t */\n69\texport function getNullTask(name: string): NullTaskHandler | undefined {\n70\t  return registry.get(name);\n71\t}\n72\t\n73\t/**\n74\t * List all registered null task handler names.\n75\t * Used for error messages when an unknown null task is encountered.\n76\t */\n77\texport function listNullTasks(): string[] {\n78\t  return [...registry.keys()];\n79\t}\n80\t\n81\t/**\n82\t * Clear all registered handlers. Intended for test cleanup only.\n83\t * Re-registers built-in handlers after clearing.\n84\t */\n85\texport function clearNullTaskRegistry(): void {\n86\t  registry.clear();\n87\t}\n88\t\n89\t// --- Built-in Handlers ---\n90\t\n91\t/**\n92\t * No-op telemetry handler (placeholder — real implementation in story 16-3).\n93\t */\n94\tregisterNullTask('telemetry', async (_ctx: TaskContext): Promise<NullTaskResult> => {\n95\t  return { success: true, output: 'telemetry: no-op placeholder' };\n96\t});\n97\t"}]},"parent_tool_use_id":"toolu_01GYH6ggx8N6jTTqCzjbiH3g","session_id":"3330d992-072a-4898-af8b-5f3f7e12cbac","uuid":"92ae7cad-a100-4865-94cf-c356b3797223","timestamp":"2026-04-03T17:38:30.441Z"}
