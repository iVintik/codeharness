{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FTWzop5WMu4wLfJASqcC3s","type":"tool_result","content":"     1→/**\n     2→ * Story file acceptance criteria parser.\n     3→ * Reads story markdown files and extracts numbered ACs with type classification.\n     4→ */\n     5→\n     6→import { existsSync, readFileSync } from 'node:fs';\n     7→import { warn } from '../../lib/output.js';\n     8→import type { ParsedAC, Verifiability, VerificationStrategy, VerificationTier, ObservabilityGapResult, ObservabilityGapEntry } from './types.js';\n     9→import { LEGACY_TIER_MAP, TIER_HIERARCHY } from './types.js';\n    10→\n    11→// ─── Keywords for Classification ────────────────────────────────────────────\n    12→\n    13→const UI_KEYWORDS = [\n    14→  'agent-browser',\n    15→  'screenshot',\n    16→  'navigate',\n    17→  'click',\n    18→  'form',\n    19→  'ui verification',\n    20→  'ui acceptance',\n    21→];\n    22→\n    23→const API_KEYWORDS = [\n    24→  'http',\n    25→  'api',\n    26→  'endpoint',\n    27→  'curl',\n    28→  'rest',\n    29→  'response bod',\n    30→];\n    31→\n    32→const DB_KEYWORDS = [\n    33→  'database',\n    34→  'db state',\n    35→  'db mcp',\n    36→  'query',\n    37→  'sql',\n    38→  'table',\n    39→];\n    40→\n    41→// ─── Integration Keywords ───────────────────────────────────────────────────\n    42→\n    43→export const INTEGRATION_KEYWORDS = [\n    44→  'external system',\n    45→  'real infrastructure',\n    46→  'manual verification',\n    47→];\n    48→\n    49→// Keywords that indicate true escalation (cannot be automated at all)\n    50→const ESCALATE_KEYWORDS = [\n    51→  'physical hardware',\n    52→  'manual human',\n    53→  'visual inspection by human',\n    54→  'paid external service',\n    55→];\n    56→\n    57→// ─── Verifiability Classification ───────────────────────────────────────────\n    58→\n    59→/**\n    60→ * Classifies whether an AC can be verified in a CLI subprocess or requires\n    61→ * integration testing. Checks description against integration keywords\n    62→ * (case-insensitive). Falls back to 'cli-verifiable'.\n    63→ */\n    64→export function classifyVerifiability(description: string): Verifiability {\n    65→  const lower = description.toLowerCase();\n    66→\n    67→  for (const kw of INTEGRATION_KEYWORDS) {\n    68→    if (lower.includes(kw)) return 'integration-required';\n    69→  }\n    70→\n    71→  return 'cli-verifiable';\n    72→}\n    73→\n    74→// ─── Verification Strategy ─────────────────────────────────────────────────\n    75→\n    76→/**\n    77→ * Determines the best verification strategy for an AC.\n    78→ *\n    79→ * Docker is the DEFAULT — it's the safest approach because it runs in an\n    80→ * isolated container that can't corrupt the host environment.\n    81→ *\n    82→ * cli-direct is the fallback when Docker is unavailable (checked at runtime).\n    83→ * escalate is the last resort for things that truly can't be automated.\n    84→ */\n    85→export function classifyStrategy(description: string): VerificationStrategy {\n    86→  const lower = description.toLowerCase();\n    87→\n    88→  // Check for true escalation first (very rare)\n    89→  for (const kw of ESCALATE_KEYWORDS) {\n    90→    if (lower.includes(kw)) return 'escalate';\n    91→  }\n    92→\n    93→  // Default: Docker for everything\n    94→  return 'docker';\n    95→}\n    96→\n    97→// ─── Verification Tag Parsing ───────────────────────────────────────────────\n    98→\n    99→const VERIFICATION_TAG_PATTERN = /<!--\\s*verification:\\s*(cli-verifiable|integration-required|test-provable|runtime-provable|environment-provable|escalate)\\s*-->/;\n   100→\n   101→/**\n   102→ * Parses a `<!-- verification: ... -->` HTML comment tag from a string.\n   103→ * Accepts both legacy values (cli-verifiable, integration-required) and\n   104→ * new VerificationTier values (test-provable, runtime-provable, etc.).\n   105→ * Returns the tag value if found, or null.\n   106→ */\n   107→export function parseVerificationTag(text: string): Verifiability | VerificationTier | null {\n   108→  const match = VERIFICATION_TAG_PATTERN.exec(text);\n   109→  return match ? (match[1] as Verifiability | VerificationTier) : null;\n   110→}\n   111→\n   112→// ─── Classification ─────────────────────────────────────────────────────────\n   113→\n   114→/**\n   115→ * Classifies an AC description by keywords.\n   116→ * Checks UI, API, DB keywords (case-insensitive). Falls back to 'general'.\n   117→ */\n   118→export function classifyAC(description: string): 'ui' | 'api' | 'db' | 'general' {\n   119→  const lower = description.toLowerCase();\n   120→\n   121→  for (const kw of UI_KEYWORDS) {\n   122→    if (lower.includes(kw)) return 'ui';\n   123→  }\n   124→  for (const kw of API_KEYWORDS) {\n   125→    if (lower.includes(kw)) return 'api';\n   126→  }\n   127→  for (const kw of DB_KEYWORDS) {\n   128→    if (lower.includes(kw)) return 'db';\n   129→  }\n   130→\n   131→  return 'general';\n   132→}\n   133→\n   134→// ─── Parser ─────────────────────────────────────────────────────────────────\n   135→\n   136→/**\n   137→ * Reads a story markdown file and extracts numbered acceptance criteria.\n   138→ * Finds the `## Acceptance Criteria` section, then parses numbered items.\n   139→ *\n   140→ * @throws Error if file not found (with actionable message)\n   141→ * @returns ParsedAC[] — empty array if no AC section found (with warning)\n   142→ */\n   143→export function parseStoryACs(storyFilePath: string): ParsedAC[] {\n   144→  if (!existsSync(storyFilePath)) {\n   145→    throw new Error(\n   146→      `Story file not found: ${storyFilePath}. Ensure the story file exists at the expected path.`,\n   147→    );\n   148→  }\n   149→\n   150→  const content = readFileSync(storyFilePath, 'utf-8');\n   151→  const lines = content.split('\\n');\n   152→\n   153→  // Find the AC section\n   154→  let acSectionStart = -1;\n   155→  for (let i = 0; i < lines.length; i++) {\n   156→    if (/^##\\s+Acceptance\\s+Criteria/i.test(lines[i])) {\n   157→      acSectionStart = i + 1;\n   158→      break;\n   159→    }\n   160→  }\n   161→\n   162→  if (acSectionStart === -1) {\n   163→    warn('No \"## Acceptance Criteria\" section found in story file');\n   164→    return [];\n   165→  }\n   166→\n   167→  // Find section end (next ## heading or end of file)\n   168→  let acSectionEnd = lines.length;\n   169→  for (let i = acSectionStart; i < lines.length; i++) {\n   170→    if (/^##\\s+/.test(lines[i]) && i !== acSectionStart - 1) {\n   171→      acSectionEnd = i;\n   172→      break;\n   173→    }\n   174→  }\n   175→\n   176→  const acSection = lines.slice(acSectionStart, acSectionEnd).join('\\n');\n   177→\n   178→  // Parse numbered ACs\n   179→  const acPattern = /^\\s*(\\d+)\\.\\s+/;\n   180→  const acs: ParsedAC[] = [];\n   181→  const acLines = acSection.split('\\n');\n   182→\n   183→  let currentId: string | null = null;\n   184→  let currentDesc: string[] = [];\n   185→\n   186→  const flushCurrent = (): void => {\n   187→    if (currentId !== null && currentDesc.length > 0) {\n   188→      const description = currentDesc.join(' ').trim();\n   189→      if (description) {\n   190→        const tag = parseVerificationTag(description);\n   191→        const isNewTier = tag !== null && (TIER_HIERARCHY as readonly string[]).includes(tag);\n   192→        const verifiability = isNewTier ? classifyVerifiability(description) : (tag ?? classifyVerifiability(description)) as Verifiability;\n   193→        const strategy = classifyStrategy(description);\n   194→        const tier: VerificationTier = isNewTier\n   195→          ? tag as VerificationTier\n   196→          : (LEGACY_TIER_MAP[verifiability] ?? 'test-provable');\n   197→        acs.push({\n   198→          id: currentId,\n   199→          description,\n   200→          type: classifyAC(description),\n   201→          verifiability,\n   202→          strategy,\n   203→          tier,\n   204→        });\n   205→      } else {\n   206→        warn(`Skipping malformed AC #${currentId}: empty description`);\n   207→      }\n   208→    }\n   209→  };\n   210→\n   211→  for (const line of acLines) {\n   212→    const match = acPattern.exec(line);\n   213→    if (match) {\n   214→      flushCurrent();\n   215→      currentId = match[1];\n   216→      currentDesc = [line.replace(acPattern, '').trim()];\n   217→    } else if (currentId !== null && line.trim()) {\n   218→      currentDesc.push(line.trim());\n   219→    }\n   220→  }\n   221→\n   222→  // Flush last AC\n   223→  flushCurrent();\n   224→\n   225→  return acs;\n   226→}\n   227→\n   228→// ─── Observability Gap Parser ────────────────────────────────────────────\n   229→\n   230→const AC_HEADING_PATTERN = /^##\\s+AC\\s+(\\d+)/i;\n   231→const OBSERVABILITY_GAP_TAG = '[OBSERVABILITY GAP]';\n   232→\n   233→/**\n   234→ * Parses proof content for `[OBSERVABILITY GAP]` tags.\n   235→ * Scans each AC section (delimited by `## AC N:` headings) for the gap tag.\n   236→ *\n   237→ * @param proofContent - Raw markdown content of the proof document\n   238→ * @returns Per-AC gap presence and aggregate counts\n   239→ */\n   240→export function parseObservabilityGaps(proofContent: string): ObservabilityGapResult {\n   241→  const lines = proofContent.split('\\n');\n   242→  const entries: ObservabilityGapEntry[] = [];\n   243→\n   244→  let currentAcId: string | null = null;\n   245→  let currentSectionLines: string[] = [];\n   246→\n   247→  const flushSection = (): void => {\n   248→    if (currentAcId !== null) {\n   249→      const sectionText = currentSectionLines.join('\\n');\n   250→      const hasGap = sectionText.includes(OBSERVABILITY_GAP_TAG);\n   251→      const gapNote = hasGap\n   252→        ? 'No log events detected for this user interaction'\n   253→        : undefined;\n   254→      entries.push({ acId: currentAcId, hasGap, gapNote });\n   255→    }\n   256→  };\n   257→\n   258→  for (const line of lines) {\n   259→    const match = AC_HEADING_PATTERN.exec(line);\n   260→    if (match) {\n   261→      flushSection();\n   262→      currentAcId = match[1];\n   263→      currentSectionLines = [line];\n   264→    } else if (currentAcId !== null) {\n   265→      currentSectionLines.push(line);\n   266→    }\n   267→  }\n   268→\n   269→  // Flush last section\n   270→  flushSection();\n   271→\n   272→  const totalACs = entries.length;\n   273→  const gapCount = entries.filter(e => e.hasGap).length;\n   274→  const coveredCount = totalACs - gapCount;\n   275→\n   276→  return { entries, totalACs, gapCount, coveredCount };\n   277→}\n   278→"}]},"parent_tool_use_id":"toolu_01MjryQZLc2hANKXFHNnX99L","session_id":"6d9d3799-5d0f-4ddf-a676-1dbe6fbfed55","uuid":"a13f262d-fefa-4328-ab56-4003b37b919c","timestamp":"2026-03-27T10:19:55.053Z"}
