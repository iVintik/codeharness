{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0188p7KjadiaXrxJtx9PYgEb","type":"tool_result","content":"1\timport { mkdirSync, copyFileSync, existsSync, rmSync } from 'node:fs';\n2\timport { join, basename } from 'node:path';\n3\timport { warn } from './output.js';\n4\timport type { DispatchOptions } from './agent-dispatch.js';\n5\t\n6\t// --- Interfaces ---\n7\t\n8\t/**\n9\t * Options for creating an isolated workspace.\n10\t */\n11\texport interface IsolationOptions {\n12\t  /** Unique run identifier used in the temp directory name. */\n13\t  runId: string;\n14\t  /** Absolute paths to story files to copy into the workspace. */\n15\t  storyFiles: string[];\n16\t}\n17\t\n18\t/**\n19\t * An isolated workspace with no source code — only story files and a verdict directory.\n20\t */\n21\texport interface IsolatedWorkspace {\n22\t  /** Root directory of the isolated workspace. */\n23\t  dir: string;\n24\t  /** Directory containing copied story files. */\n25\t  storyFilesDir: string;\n26\t  /** Directory where the evaluator writes its verdict. */\n27\t  verdictDir: string;\n28\t  /** Returns DispatchOptions with cwd set to this workspace. */\n29\t  toDispatchOptions(): DispatchOptions;\n30\t  /** Remove the workspace from disk. Idempotent — safe to call multiple times. */\n31\t  cleanup(): Promise<void>;\n32\t}\n33\t\n34\t// --- Helpers ---\n35\t\n36\t/** Sanitize runId to prevent path traversal — allow only alphanumeric, dash, underscore, dot. */\n37\tfunction sanitizeRunId(runId: string): string {\n38\t  // Replace disallowed characters with underscores\n39\t  let sanitized = runId.replace(/[^a-zA-Z0-9._-]/g, '_');\n40\t  // Strip leading dots to prevent \"..\" path traversal\n41\t  sanitized = sanitized.replace(/^\\.+/, '');\n42\t  if (sanitized.length === 0) {\n43\t    throw new Error('Source isolation: runId is empty after sanitization');\n44\t  }\n45\t  return sanitized;\n46\t}\n47\t\n48\t/** Deduplicate a filename within a directory by appending a numeric suffix. */\n49\tfunction deduplicateFilename(dir: string, name: string): string {\n50\t  if (!existsSync(join(dir, name))) {\n51\t    return name;\n52\t  }\n53\t  const dotIdx = name.lastIndexOf('.');\n54\t  const stem = dotIdx > 0 ? name.slice(0, dotIdx) : name;\n55\t  const ext = dotIdx > 0 ? name.slice(dotIdx) : '';\n56\t  let counter = 1;\n57\t  let candidate: string;\n58\t  do {\n59\t    candidate = `${stem}-${counter}${ext}`;\n60\t    counter++;\n61\t  } while (existsSync(join(dir, candidate)));\n62\t  return candidate;\n63\t}\n64\t\n65\t// --- Implementation ---\n66\t\n67\t/**\n68\t * Create an isolated workspace at /tmp/codeharness-verify-{runId}/.\n69\t *\n70\t * The workspace contains only:\n71\t *   - story-files/  — copies of the provided story files\n72\t *   - verdict/      — empty directory for evaluator output\n73\t *\n74\t * No source code, node_modules, package.json, or .git is present.\n75\t * Missing story files are skipped with a warning (no throw).\n76\t */\n77\texport async function createIsolatedWorkspace(\n78\t  options: IsolationOptions,\n79\t): Promise<IsolatedWorkspace> {\n80\t  const safeRunId = sanitizeRunId(options.runId);\n81\t  const dir = `/tmp/codeharness-verify-${safeRunId}`;\n82\t  const storyFilesDir = join(dir, 'story-files');\n83\t  const verdictDir = join(dir, 'verdict');\n84\t\n85\t  // If workspace already exists from a previous crashed run, clean it first\n86\t  if (existsSync(dir)) {\n87\t    rmSync(dir, { recursive: true, force: true });\n88\t  }\n89\t\n90\t  // Create directory structure\n91\t  mkdirSync(storyFilesDir, { recursive: true });\n92\t  mkdirSync(verdictDir, { recursive: true });\n93\t\n94\t  // Copy story files, skipping missing ones; deduplicate basenames\n95\t  for (const filePath of options.storyFiles) {\n96\t    if (!existsSync(filePath)) {\n97\t      warn(`Source isolation: story file not found, skipping: ${filePath}`);\n98\t      continue;\n99\t    }\n100\t    const name = deduplicateFilename(storyFilesDir, basename(filePath));\n101\t    const dest = join(storyFilesDir, name);\n102\t    copyFileSync(filePath, dest);\n103\t  }\n104\t\n105\t  const workspace: IsolatedWorkspace = {\n106\t    dir,\n107\t    storyFilesDir,\n108\t    verdictDir,\n109\t\n110\t    toDispatchOptions(): DispatchOptions {\n111\t      return { cwd: dir };\n112\t    },\n113\t\n114\t    async cleanup(): Promise<void> {\n115\t      if (existsSync(dir)) {\n116\t        rmSync(dir, { recursive: true, force: true });\n117\t      }\n118\t    },\n119\t  };\n120\t\n121\t  return workspace;\n122\t}\n123\t"}]},"parent_tool_use_id":"toolu_01WdSxiK3fbCWnfhSGLhUtia","session_id":"02876edc-b40e-4eff-87e1-ceab09778e92","uuid":"a528ad6e-7279-472a-9657-3a2b7e65b5a0","timestamp":"2026-04-02T21:42:36.664Z"}
