{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01L5zAhKUFDMV66wE6ACY1E7","type":"tool_result","content":"     1→/**\n     2→ * README.md template for project documentation.\n     3→ * Architecture Decision 6: All templates are TypeScript string literals.\n     4→ * Architecture Decision 10: Documentation is load-bearing — wrong docs = verification failure.\n     5→ *\n     6→ * Generated by `codeharness init` when README.md does not exist.\n     7→ * Never overwrites an existing README.md.\n     8→ */\n     9→\n    10→export interface ReadmeTemplateConfig {\n    11→  /** Project name (from package.json name or directory basename) */\n    12→  projectName: string;\n    13→  /** Detected stack: 'nodejs', 'python', 'rust', array of stacks, or null */\n    14→  stack: string | string[] | null;\n    15→  /** Output of `codeharness --help` for CLI reference section */\n    16→  cliHelpOutput: string;\n    17→}\n    18→\n    19→/**\n    20→ * Generates README.md content from the template config.\n    21→ */\n    22→export function readmeTemplate(config: ReadmeTemplateConfig): string {\n    23→  const { projectName, stack, cliHelpOutput } = config;\n    24→\n    25→  const installCommand = getInstallCommand(stack);\n    26→  const firstRunCommand = 'codeharness init';\n    27→  const exampleUsage = 'codeharness status';\n    28→\n    29→  const lines: string[] = [\n    30→    `# ${projectName}`,\n    31→    '',\n    32→    '## Quick Start',\n    33→    '',\n    34→    '```bash',\n    35→    `# Install`,\n    36→    installCommand,\n    37→    '',\n    38→    '# Initialize the project',\n    39→    firstRunCommand,\n    40→    '',\n    41→    '# Check project status',\n    42→    exampleUsage,\n    43→    '```',\n    44→    '',\n    45→    '## Installation',\n    46→    '',\n    47→    '```bash',\n    48→    installCommand,\n    49→    '```',\n    50→    '',\n    51→    '## Usage',\n    52→    '',\n    53→    `After installation, initialize ${projectName} in your project directory:`,\n    54→    '',\n    55→    '```bash',\n    56→    'codeharness init',\n    57→    '```',\n    58→    '',\n    59→    'This sets up the harness with stack detection, observability, and documentation scaffolding.',\n    60→    '',\n    61→    '## CLI Reference',\n    62→    '',\n    63→    '```',\n    64→    cliHelpOutput.trimEnd(),\n    65→    '```',\n    66→    '',\n    67→  ];\n    68→\n    69→  return lines.join('\\n');\n    70→}\n    71→\n    72→export function getInstallCommand(stack: string | string[] | null): string {\n    73→  if (Array.isArray(stack)) {\n    74→    const commands = stack.map(s => getSingleInstallCommand(s));\n    75→    // Deduplicate in case multiple stacks share an install command\n    76→    return [...new Set(commands)].join('\\n');\n    77→  }\n    78→  return getSingleInstallCommand(stack);\n    79→}\n    80→\n    81→function getSingleInstallCommand(stack: string | null): string {\n    82→  if (stack === 'python') return 'pip install codeharness';\n    83→  if (stack === 'rust') return 'cargo build';\n    84→  return 'npm install -g codeharness';\n    85→}\n    86→"}]},"parent_tool_use_id":"toolu_017stQocDjYtQWzyiuCXnw1e","session_id":"58ae4f51-bff6-4a66-807a-d4f10c8bdaa3","uuid":"9dbbe532-fda2-4961-9461-2ad7b9ded08a","timestamp":"2026-03-23T15:51:40.790Z"}
