t] = handler;\n   634→        }),\n   635→        pid: 12345,\n   636→        stdin: null,\n   637→        stdout: null,\n   638→        stderr: null,\n   639→      }));\n   640→\n   641→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   642→      mockPaths({ 'ralph.sh': true, '.claude': true, '.flagged_stories': false });\n   643→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   644→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   645→\n   646→      const p = runCommand(['--quiet']);\n   647→      await vi.waitFor(() => expect(spawnMock).toHaveBeenCalled());\n   648→\n   649→      // Verify startRenderer was called with quiet: true\n   650→      expect(startRendererMock).toHaveBeenCalledWith({ quiet: true });\n   651→\n   652→      // Verify spawn was called with stdio: 'ignore'\n   653→      expect(spawnMock).toHaveBeenCalledWith('bash', expect.any(Array), expect.objectContaining({\n   654→        stdio: 'ignore',\n   655→      }));\n   656→\n   657→      quietHandlers['close'](0);\n   658→      await p;\n   659→\n   660→      // No renderer.update calls should have happened (no stdout/stderr)\n   661→      expect(rendererUpdateMock).not.toHaveBeenCalled();\n   662→    });\n   663→  });\n   664→\n   665→  describe('result event extraction (AC #5)', () => {\n   666→    it('result events are parsed and fed to renderer (caller handles data extraction)', async () => {\n   667→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   668→      mockPaths({ 'ralph.sh': true, '.claude': true, '.flagged_stories': false });\n   669→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   670→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   671→\n   672→      const resultEvent = { type: 'result', cost: 0.05, sessionId: 'sess-123' };\n   673→      parseStreamLineMock.mockReturnValueOnce(resultEvent);\n   674→\n   675→      const p = runCommand();\n   676→      await vi.waitFor(() => expect