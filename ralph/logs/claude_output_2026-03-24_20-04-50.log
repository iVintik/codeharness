{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TwmFiuh44mP18eQFRMyYDp","type":"tool_result","content":"     1→/**\n     2→ * E2E Integration Test — Stream-JSON Pipeline\n     3→ *\n     4→ * Story 6-2: Verify Stream-JSON Pipeline End-to-End\n     5→ *\n     6→ * Tests the full data flow: NDJSON lines → createLineProcessor (line splitting) →\n     7→ * parseStreamLine (event parsing) → renderer update (state accumulation).\n     8→ *\n     9→ * Uses a recorded NDJSON fixture (tests/fixtures/sample-stream.ndjson) that\n    10→ * represents a realistic Claude stream-json session.\n    11→ *\n    12→ * IMPORTANT: This test imports createLineProcessor from run-helpers.ts — the\n    13→ * same function used in production (run.ts). No hand-rolled copies.\n    14→ */\n    15→\n    16→import { describe, it, expect, beforeEach } from 'vitest';\n    17→import { readFileSync } from 'node:fs';\n    18→import { join, dirname } from 'node:path';\n    19→import { parseStreamLine } from '../lib/agents/stream-parser.js';\n    20→import type { StreamEvent } from '../lib/agents/stream-parser.js';\n    21→import { createLineProcessor } from '../lib/run-helpers.js';\n    22→import type { StoryMessage } from '../lib/ink-components.js';\n    23→\n    24→// --- Resolve fixture path (project root / tests / fixtures) ---\n    25→\n    26→function projectRoot(): string {\n    27→  // src/__tests__/run-pipeline.test.ts → up two levels to project root\n    28→  return join(dirname(new URL(import.meta.url).pathname), '..', '..');\n    29→}\n    30→\n    31→function readFixture(name: string): string {\n    32→  return readFileSync(join(projectRoot(), 'tests', 'fixtures', name), 'utf-8');\n    33→}\n    34→\n    35→// --- Collected state for test assertions ---\n    36→\n    37→interface CollectedState {\n    38→  events: StreamEvent[];\n    39→  messages: StoryMessage[];\n    40→  iterationCount: number;\n    41→}\n    42→\n    43→function makeTestProcessor(\n    44→  state: CollectedState,\n    45→  opts?: { parseRalph?: boolean },\n    46→): (data: Buffer) => void {\n    47→  return createLineProcessor(\n    48→    {\n    49→      onEvent: (event) => state.events.push(event),\n    50→      onMessage: (msg) => state.messages.push(msg),\n    51→      onIteration: (iteration) => { state.iterationCount = iteration; },\n    52→    },\n    53→    opts,\n    54→  );\n    55→}\n    56→\n    57→// --- AC1: Full pipeline integration test with recorded NDJSON fixture ---\n    58→\n    59→describe('AC1: Full pipeline — fixture through createLineProcessor → parseStreamLine → renderer', () => {\n    60→  let state: CollectedState;\n    61→\n    62→  beforeEach(() => {\n    63→    state = { events: [], messages: [], iterationCount: 0 };\n    64→  });\n    65→\n    66→  it('pipes the full sample-stream.ndjson fixture through the pipeline', () => {\n    67→    const fixture = readFixture('sample-stream.ndjson');\n    68→    const handler = makeTestProcessor(state);\n    69→\n    70→    // Feed the fixture as a single Buffer (simulates reading from stdout)\n    71→    handler(Buffer.from(fixture));\n    72→    // Flush any remaining partial line\n    73→    handler(Buffer.from('\\n'));\n    74→\n    75→    // Verify events were collected\n    76→    expect(state.events.length).toBeGreaterThan(0);\n    77→\n    78→    // The fixture contains: text, tool-start (Read), tool-input, tool-complete,\n    79→    // tool-start (Bash), tool-input, tool-complete, text, result\n    80→    const types = state.events.map(e => e.type);\n    81→    expect(types).toContain('text');\n    82→    expect(types).toContain('tool-start');\n    83→    expect(types).toContain('tool-input');\n    84→    expect(types).toContain('tool-complete');\n    85→    expect(types).toContain('result');\n    86→  });\n    87→\n    88→  it('handles chunk boundaries — fixture split across multiple Buffers', () => {\n    89→    const fixture = readFixture('sample-stream.ndjson');\n    90→    const handler = makeTestProcessor(state);\n    91→\n    92→    // Split into chunks of varying sizes to test partial-line buffering\n    93→    const chunkSizes = [17, 43, 7, 101, 29, 3, 200];\n    94→    let offset = 0;\n    95→    let sizeIndex = 0;\n    96→    while (offset < fixture.length) {\n    97→      const size = chunkSizes[sizeIndex % chunkSizes.length];\n    98→      const chunk = fixture.slice(offset, offset + size);\n    99→      handler(Buffer.from(chunk));\n   100→      offset += size;\n   101→      sizeIndex++;\n   102→    }\n   103→    // Flush trailing partial\n   104→    handler(Buffer.from('\\n'));\n   105→\n   106→    // Must produce the same events regardless of chunk boundaries\n   107→    const singleChunkState: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   108→    const singleHandler = makeTestProcessor(singleChunkState);\n   109→    singleHandler(Buffer.from(fixture));\n   110→    singleHandler(Buffer.from('\\n'));\n   111→\n   112→    expect(state.events).toEqual(singleChunkState.events);\n   113→  });\n   114→});\n   115→\n   116→// --- AC2: Events reach renderer in correct order ---\n   117→\n   118→describe('AC2: Event ordering — tool-start, tool-input, tool-complete, text arrive in order', () => {\n   119→  it('events arrive in the correct sequence from the fixture', () => {\n   120→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   121→    const handler = makeTestProcessor(state);\n   122→    const fixture = readFixture('sample-stream.ndjson');\n   123→    handler(Buffer.from(fixture));\n   124→    handler(Buffer.from('\\n'));\n   125→\n   126→    const types = state.events.map(e => e.type);\n   127→\n   128→    // Expected order from the fixture:\n   129→    // 1. text (\"I'll start by reading...\")\n   130→    // 2. tool-complete (text block stop — index 0)\n   131→    // 3. tool-start (Read, index 1)\n   132→    // 4. tool-input (Read args)\n   133→    // 5. tool-complete (Read block stop)\n   134→    // 6. tool-start (Bash, index 2)\n   135→    // 7. tool-input (Bash args)\n   136→    // 8. tool-complete (Bash block stop)\n   137→    // 9. text (\"All tests pass...\")\n   138→    // 10. tool-complete (text block stop — index 3)\n   139→    // 11. result\n   140→\n   141→    expect(types[0]).toBe('text');\n   142→    expect(types[1]).toBe('tool-complete'); // text block stop\n   143→\n   144→    // Find the Read tool-start\n   145→    const readStartIdx = types.indexOf('tool-start');\n   146→    expect(readStartIdx).toBeGreaterThan(0);\n   147→    expect((state.events[readStartIdx] as { name: string }).name).toBe('Read');\n   148→\n   149→    // tool-input(s) must follow tool-start (Read has 2 input deltas)\n   150→    expect(types[readStartIdx + 1]).toBe('tool-input');\n   151→    expect(types[readStartIdx + 2]).toBe('tool-input');\n   152→    // tool-complete must follow tool-inputs\n   153→    expect(types[readStartIdx + 3]).toBe('tool-complete');\n   154→\n   155→    // Bash tool-start comes after Read tool-complete\n   156→    const bashStartIdx = types.indexOf('tool-start', readStartIdx + 1);\n   157→    expect(bashStartIdx).toBeGreaterThan(readStartIdx + 3);\n   158→    expect((state.events[bashStartIdx] as { name: string }).name).toBe('Bash');\n   159→    expect(types[bashStartIdx + 1]).toBe('tool-input');\n   160→    expect(types[bashStartIdx + 2]).toBe('tool-complete');\n   161→\n   162→    // Second text event comes after Bash tool-complete\n   163→    const secondTextIdx = types.indexOf('text', bashStartIdx);\n   164→    expect(secondTextIdx).toBeGreaterThan(bashStartIdx + 2);\n   165→\n   166→    // Result is the last event\n   167→    expect(types[types.length - 1]).toBe('result');\n   168→  });\n   169→\n   170→  it('tool-start events contain correct tool names and IDs', () => {\n   171→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   172→    const handler = makeTestProcessor(state);\n   173→    handler(Buffer.from(readFixture('sample-stream.ndjson')));\n   174→    handler(Buffer.from('\\n'));\n   175→\n   176→    const toolStarts = state.events.filter(e => e.type === 'tool-start') as Array<{\n   177→      type: 'tool-start'; name: string; id: string;\n   178→    }>;\n   179→    expect(toolStarts).toHaveLength(2);\n   180→    expect(toolStarts[0]).toEqual({ type: 'tool-start', name: 'Read', id: 'toolu_read_001' });\n   181→    expect(toolStarts[1]).toEqual({ type: 'tool-start', name: 'Bash', id: 'toolu_bash_002' });\n   182→  });\n   183→\n   184→  it('tool-input events contain correct partial JSON', () => {\n   185→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   186→    const handler = makeTestProcessor(state);\n   187→    handler(Buffer.from(readFixture('sample-stream.ndjson')));\n   188→    handler(Buffer.from('\\n'));\n   189→\n   190→    const toolInputs = state.events.filter(e => e.type === 'tool-input') as Array<{\n   191→      type: 'tool-input'; partial: string;\n   192→    }>;\n   193→    expect(toolInputs.length).toBeGreaterThanOrEqual(2);\n   194→\n   195→    // Read tool input — split across two deltas\n   196→    expect(toolInputs[0].partial).toBe('{\"file_path\"');\n   197→    expect(toolInputs[1].partial).toBe(':\"/src/index.ts\"}');\n   198→\n   199→    // Bash tool input — single delta\n   200→    expect(toolInputs[2].partial).toBe('{\"command\":\"npm test\"}');\n   201→  });\n   202→\n   203→  it('text events contain correct text content', () => {\n   204→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   205→    const handler = makeTestProcessor(state);\n   206→    handler(Buffer.from(readFixture('sample-stream.ndjson')));\n   207→    handler(Buffer.from('\\n'));\n   208→\n   209→    const textEvents = state.events.filter(e => e.type === 'text') as Array<{\n   210→      type: 'text'; text: string;\n   211→    }>;\n   212→    expect(textEvents.length).toBeGreaterThanOrEqual(2);\n   213→    expect(textEvents[0].text).toBe(\"I'll start by reading the project files.\");\n   214→    expect(textEvents[1].text).toBe('All tests pass. The implementation is complete.');\n   215→  });\n   216→\n   217→  it('result event contains cost and session ID', () => {\n   218→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   219→    const handler = makeTestProcessor(state);\n   220→    handler(Buffer.from(readFixture('sample-stream.ndjson')));\n   221→    handler(Buffer.from('\\n'));\n   222→\n   223→    const results = state.events.filter(e => e.type === 'result') as Array<{\n   224→      type: 'result'; cost: number; sessionId: string;\n   225→    }>;\n   226→    expect(results).toHaveLength(1);\n   227→    expect(results[0]).toEqual({ type: 'result', cost: 0.42, sessionId: 'sess_e2e_test' });\n   228→  });\n   229→});\n   230→\n   231→// --- AC3: Silently ignored event types ---\n   232→\n   233→describe('AC3: Silently ignored events — thinking_delta, hook_started, hook_response, init', () => {\n   234→  it('thinking_delta events produce null (not errors)', () => {\n   235→    const thinkingLine = JSON.stringify({\n   236→      type: 'stream_event',\n   237→      event: {\n   238→        type: 'content_block_delta',\n   239→        index: 0,\n   240→        delta: { type: 'thinking_delta', thinking: 'Let me analyze the codebase structure first.' },\n   241→      },\n   242→    });\n   243→    expect(parseStreamLine(thinkingLine)).toBeNull();\n   244→  });\n   245→\n   246→  it('hook_started events produce null', () => {\n   247→    const hookStarted = JSON.stringify({\n   248→      type: 'system',\n   249→      subtype: 'hook_started',\n   250→      hook: 'pre-tool-use',\n   251→      tool: 'Bash',\n   252→    });\n   253→    expect(parseStreamLine(hookStarted)).toBeNull();\n   254→  });\n   255→\n   256→  it('hook_response events produce null', () => {\n   257→    const hookResponse = JSON.stringify({\n   258→      type: 'system',\n   259→      subtype: 'hook_response',\n   260→      hook: 'pre-tool-use',\n   261→      approved: true,\n   262→    });\n   263→    expect(parseStreamLine(hookResponse)).toBeNull();\n   264→  });\n   265→\n   266→  it('init events produce null', () => {\n   267→    const initLine = JSON.stringify({\n   268→      type: 'system',\n   269→      subtype: 'init',\n   270→      session_id: 'sess_abc',\n   271→      tools: ['Bash', 'Read'],\n   272→    });\n   273→    expect(parseStreamLine(initLine)).toBeNull();\n   274→  });\n   275→\n   276→  it('message_start, message_stop, message_delta produce null', () => {\n   277→    expect(parseStreamLine(JSON.stringify({\n   278→      type: 'stream_event',\n   279→      event: { type: 'message_start', message: { id: 'msg_001' } },\n   280→    }))).toBeNull();\n   281→\n   282→    expect(parseStreamLine(JSON.stringify({\n   283→      type: 'stream_event',\n   284→      event: { type: 'message_stop' },\n   285→    }))).toBeNull();\n   286→\n   287→    expect(parseStreamLine(JSON.stringify({\n   288→      type: 'stream_event',\n   289→      event: { type: 'message_delta', delta: { stop_reason: 'end_turn' } },\n   290→    }))).toBeNull();\n   291→  });\n   292→\n   293→  it('the full fixture produces zero errors despite containing ignored events', () => {\n   294→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   295→    const handler = makeTestProcessor(state);\n   296→    handler(Buffer.from(readFixture('sample-stream.ndjson')));\n   297→    handler(Buffer.from('\\n'));\n   298→\n   299→    // The fixture has 21 lines. Only some produce events.\n   300→    // Ignored lines: init, message_start, content_block_start(text), thinking_delta,\n   301→    // hook_started, hook_response, message_delta, message_stop\n   302→    // All should be silently ignored — no throws, no error events.\n   303→    const eventTypes = new Set(state.events.map(e => e.type));\n   304→    expect(eventTypes).not.toContain('error');\n   305→\n   306→    // Count: the fixture should produce exactly these event types\n   307→    expect(eventTypes).toEqual(new Set(['text', 'tool-start', 'tool-input', 'tool-complete', 'result']));\n   308→  });\n   309→});\n   310→\n   311→// --- AC4: Ralph stderr messages parsed into StoryMessage objects ---\n   312→\n   313→describe('AC4: Ralph stderr — [SUCCESS], [WARN], [LOOP] parsed into StoryMessage objects', () => {\n   314→  it('[SUCCESS] Story key: DONE is parsed into an OK message', () => {\n   315→    const line = '[2026-03-16 10:23:42] [SUCCESS] Story 3-2-stream-parser: DONE — 12/12 ACs verified (18m, $4.20)';\n   316→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   317→    const handler = makeTestProcessor(state, { parseRalph: true });\n   318→    handler(Buffer.from(line + '\\n'));\n   319→\n   320→    expect(state.messages).toHaveLength(1);\n   321→    expect(state.messages[0].type).toBe('ok');\n   322→    expect(state.messages[0].key).toBe('3-2-stream-parser');\n   323→    expect(state.messages[0].message).toContain('DONE');\n   324→  });\n   325→\n   326→  it('[WARN] Story key exceeded retry limit is parsed into a FAIL message', () => {\n   327→    const line = '[2026-03-16 11:00:00] [WARN] Story 4-1-broken-feature exceeded retry limit';\n   328→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   329→    const handler = makeTestProcessor(state, { parseRalph: true });\n   330→    handler(Buffer.from(line + '\\n'));\n   331→\n   332→    expect(state.messages).toHaveLength(1);\n   333→    expect(state.messages[0].type).toBe('fail');\n   334→    expect(state.messages[0].key).toBe('4-1-broken-feature');\n   335→    expect(state.messages[0].message).toContain('exceeded retry limit');\n   336→  });\n   337→\n   338→  it('[WARN] Story key retry N/M is parsed into a WARN message', () => {\n   339→    const line = '[2026-03-16 11:00:00] [WARN] Story 4-1-broken — retry 3/10';\n   340→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   341→    const handler = makeTestProcessor(state, { parseRalph: true });\n   342→    handler(Buffer.from(line + '\\n'));\n   343→\n   344→    expect(state.messages).toHaveLength(1);\n   345→    expect(state.messages[0].type).toBe('warn');\n   346→    expect(state.messages[0].key).toBe('4-1-broken');\n   347→    expect(state.messages[0].message).toBe('retry 3/10');\n   348→  });\n   349→\n   350→  it('[LOOP] iteration N is parsed into an iteration count', () => {\n   351→    const line = '[2026-03-16 11:00:00] [LOOP] iteration 7';\n   352→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   353→    const handler = makeTestProcessor(state, { parseRalph: true });\n   354→    handler(Buffer.from(line + '\\n'));\n   355→\n   356→    expect(state.iterationCount).toBe(7);\n   357→    expect(state.messages).toHaveLength(0); // LOOP is not a StoryMessage\n   358→  });\n   359→\n   360→  it('ralph messages with ANSI color codes are cleaned before parsing', () => {\n   361→    const line = '\\x1b[32m[2026-03-16 10:23:42] [SUCCESS] Story 3-2-parser: DONE\\x1b[0m';\n   362→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   363→    const handler = makeTestProcessor(state, { parseRalph: true });\n   364→    handler(Buffer.from(line + '\\n'));\n   365→\n   366→    expect(state.messages).toHaveLength(1);\n   367→    expect(state.messages[0].type).toBe('ok');\n   368→    expect(state.messages[0].key).toBe('3-2-parser');\n   369→  });\n   370→\n   371→  it('non-ralph lines produce no messages', () => {\n   372→    const line = 'Just some random output that is not a ralph message';\n   373→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   374→    const handler = makeTestProcessor(state, { parseRalph: true });\n   375→    handler(Buffer.from(line + '\\n'));\n   376→\n   377→    expect(state.messages).toHaveLength(0);\n   378→  });\n   379→\n   380→  it('stderr handler parses both NDJSON events AND ralph messages', () => {\n   381→    // Stderr can contain both NDJSON (from tee) and ralph's own log lines\n   382→    const ndjsonLine = JSON.stringify({\n   383→      type: 'stream_event',\n   384→      event: { type: 'content_block_stop' },\n   385→    });\n   386→    const ralphLine = '[2026-03-16 10:23:42] [SUCCESS] Story 5-1-feature: DONE';\n   387→    const combined = ndjsonLine + '\\n' + ralphLine + '\\n';\n   388→\n   389→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   390→    const handler = makeTestProcessor(state, { parseRalph: true });\n   391→    handler(Buffer.from(combined));\n   392→\n   393→    // NDJSON line produces a stream event\n   394→    expect(state.events).toHaveLength(1);\n   395→    expect(state.events[0].type).toBe('tool-complete');\n   396→\n   397→    // Ralph line produces a story message\n   398→    expect(state.messages).toHaveLength(1);\n   399→    expect(state.messages[0].key).toBe('5-1-feature');\n   400→  });\n   401→});\n   402→\n   403→// --- Renderer state accumulation integration ---\n   404→\n   405→describe('Renderer state accumulation — full pipeline to RendererHandle-compatible state', () => {\n   406→  it('accumulates state matching what RendererHandle.update() would produce', () => {\n   407→    const state: CollectedState = { events: [], messages: [], iterationCount: 0 };\n   408→    const handler = makeTestProcessor(state);\n   409→    handler(Buffer.from(readFixture('sample-stream.ndjson')));\n   410→    handler(Buffer.from('\\n'));\n   411→\n   412→    // Simulate what the renderer does: walk events and build renderer state\n   413→    let activeTool: { name: string } | null = null;\n   414→    let activeToolArgs = '';\n   415→    const completedTools: Array<{ name: string; args: string }> = [];\n   416→    let lastThought: string | null = null;\n   417→\n   418→    for (const event of state.events) {\n   419→      switch (event.type) {\n   420→        case 'tool-start':\n   421→          activeTool = { name: event.name };\n   422→          activeToolArgs = '';\n   423→          lastThought = null;\n   424→          break;\n   425→        case 'tool-input':\n   426→          activeToolArgs += event.partial;\n   427→          break;\n   428→        case 'tool-complete':\n   429→          if (activeTool) {\n   430→            completedTools.push({ name: activeTool.name, args: activeToolArgs });\n   431→            activeTool = null;\n   432→            activeToolArgs = '';\n   433→          }\n   434→          break;\n   435→        case 'text':\n   436→          lastThought = event.text;\n   437→          break;\n   438→      }\n   439→    }\n   440→\n   441→    // Verify accumulated state\n   442→    expect(completedTools).toHaveLength(2);\n   443→    expect(completedTools[0]).toEqual({ name: 'Read', args: '{\"file_path\":\"/src/index.ts\"}' });\n   444→    expect(completedTools[1]).toEqual({ name: 'Bash', args: '{\"command\":\"npm test\"}' });\n   445→    expect(activeTool).toBeNull(); // All tools completed\n   446→    expect(lastThought).toBe('All tests pass. The implementation is complete.');\n   447→  });\n   448→});\n   449→"}]},"parent_tool_use_id":"toolu_01RmTRSciNZ4m4Rj6YrMRu8q","session_id":"110312c9-09eb-45d4-bc39-1124b22b5753","uuid":"0e9ac2ba-09a8-4a89-9efd-8440be0a947c","timestamp":"2026-03-24T16:06:32.612Z"}
