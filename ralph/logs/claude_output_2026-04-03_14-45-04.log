{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011dMnNeCKB7Nz3rrgntpT6h","type":"tool_result","content":"200\t      return items;\n201\t    }\n202\t\n203\t    let parsed: unknown;\n204\t    try {\n205\t      parsed = parse(raw);\n206\t    } catch { // IGNORE: malformed issues YAML — warn and return what we have\n207\t      warn(`workflow-engine: invalid YAML in issues.yaml at ${issuesPath}`);\n208\t      return items;\n209\t    }\n210\t\n211\t    if (parsed && typeof parsed === 'object') {\n212\t      const data = parsed as Record<string, unknown>;\n213\t      const issuesList = data.issues as Array<Record<string, unknown>> | undefined;\n214\t\n215\t      if (Array.isArray(issuesList)) {\n216\t        for (const issue of issuesList) {\n217\t          if (issue && typeof issue === 'object') {\n218\t            const status = issue.status as string | undefined;\n219\t            if (status === 'backlog' || status === 'ready-for-dev') {\n220\t              items.push({\n221\t                key: issue.id as string,\n222\t                title: issue.title as string | undefined,\n223\t                source: 'issues',\n224\t              });\n225\t            }\n226\t          }\n227\t        }\n228\t      }\n229\t    }\n230\t  }\n231\t\n232\t  return items;\n233\t}\n234\t\n235\t// --- Single Task Dispatch ---\n236\t\n237\t/**\n238\t * Dispatch a single task for a specific work item (or per-run sentinel).\n239\t *\n240\t * Handles: trace ID generation, session resolution, source isolation,\n241\t * agent dispatch, state checkpointing, and cleanup.\n242\t *\n243\t * Returns the updated workflow state after recording the dispatch.\n244\t */\n245\texport async function dispatchTask(\n246\t  task: ResolvedTask,\n247\t  taskName: string,\n248\t  storyKey: string,\n249\t  definition: SubagentDefinition,\n250\t  state: WorkflowState,\n251\t  config: EngineConfig,\n252\t  customPrompt?: string,\n253\t  previousOutputContract?: OutputContract,\n254\t): Promise<WorkflowState> {\n255\t  const { updatedState } = await dispatchTaskWithResult(\n256\t    task, taskName, storyKey, definition, state, config, customPrompt, previousOutputContract,\n257\t  );\n258\t  return updatedState;\n259\t}\n260\t\n261\t/** Tool names that indicate file write/edit operations across different drivers. */\n262\tconst FILE_WRITE_TOOL_NAMES = new Set([\n263\t  'Write', 'Edit', 'write_to_file', 'edit_file',\n264\t  'write', 'edit', 'WriteFile', 'EditFile',\n265\t]);\n266\t\n267\t// --- Flow Step Type Guard ---\n268\t\n269\tfunction isLoopBlock(step: FlowStep): step is LoopBlock {\n270\t  return typeof step === 'object' && step !== null && 'loop' in step;\n271\t}\n272\t\n273\t// --- Core Dispatch (shared by dispatchTask and loop block execution) ---\n274\t\n275\t/**\n276\t * Dispatch a task and return both the updated state and the raw dispatch output.\n277\t * This is the single implementation of task dispatch logic. Both `dispatchTask()`\n278\t * and loop block execution delegate here.\n279\t */\n280\tasync function dispatchTaskWithResult(\n281\t  task: ResolvedTask,\n282\t  taskName: string,\n283\t  storyKey: string,\n284\t  definition: SubagentDefinition,\n285\t  state: WorkflowState,\n286\t  config: EngineConfig,\n287\t  customPrompt?: string,\n288\t  previousOutputContract?: OutputContract,\n289\t): Promise<{ updatedState: WorkflowState; output: string; contract: OutputContract | null }> {\n290\t  const projectDir = config.projectDir ?? process.cwd();\n291\t\n292\t  // 1. Generate trace ID\n293\t  const traceId = generateTraceId(config.runId, state.iteration, taskName);\n294\t\n295\t  // 2. Format trace prompt — injected into driver via DispatchOpts.appendSystemPrompt\n296\t  const tracePrompt = formatTracePrompt(traceId);\n297\t\n298\t  // 3. Resolve session ID\n299\t  const sessionKey: SessionLookupKey = { taskName, storyKey };\n300\t  const sessionId = resolveSessionId(task.session, sessionKey, state);\n301\t\n302\t  // 4. Resolve driver\n303\t  const driverName = task.driver ?? 'claude-code';\n304\t  const driver = getDriver(driverName);\n305\t\n306\t  // 5. Resolve model via cascade: task → agent → driver\n307\t  const agentAsModelSource = { model: definition.model };\n308\t  const model = resolveModel(task, agentAsModelSource, driver);\n309\t\n310\t  // 6. Determine cwd based on source_access\n311\t  let cwd: string;\n312\t  let workspace: Awaited<ReturnType<typeof createIsolatedWorkspace>> | null = null;\n313\t\n314\t  if (task.source_access === false) {\n315\t    workspace = await createIsolatedWorkspace({ runId: config.runId, storyFiles: [] });\n316\t    cwd = workspace.toDispatchOptions().cwd ?? projectDir;\n317\t  } else {\n318\t    cwd = projectDir;\n319\t  }\n320\t\n321\t  // 7. Construct prompt\n322\t  const basePrompt = customPrompt\n323\t    ?? (storyKey === PER_RUN_SENTINEL\n324\t      ? `Execute task \"${taskName}\" for the current run.`\n325\t      : `Implement story ${storyKey}`);\n326\t\n327\t  // 7b. Inject previous task's output contract context into the prompt (story 13-2)\n328\t  const prompt = buildPromptWithContractContext(basePrompt, previousOutputContract ?? null);\n329\t\n330\t  // 8. Build DispatchOpts for the driver\n331\t  const dispatchOpts: DispatchOpts = {\n332\t    prompt,\n333\t    model,\n334\t    cwd,\n335\t    sourceAccess: task.source_access !== false,\n336\t    ...(sessionId ? { sessionId } : {}),\n337\t    ...(tracePrompt ? { appendSystemPrompt: tracePrompt } : {}),\n338\t    ...(task.plugins ? { plugins: task.plugins } : {}),\n339\t    ...(task.max_budget_usd != null ? { timeout: task.max_budget_usd } : {}),\n340\t  };\n341\t\n342\t  // 9. Dispatch through the driver and consume AsyncIterable<StreamEvent>\n343\t  let output = '';\n344\t  let resultSessionId = '';\n345\t  let cost = 0;\n346\t  let errorEvent: { error: string; errorCategory?: string } | null = null;\n347\t\n348\t  // Track changed files from tool-start/tool-input/tool-complete events (Task 2)\n349\t  const changedFiles: string[] = [];\n350\t  let activeToolName: string | null = null;\n351\t  let activeToolInput = '';\n352\t\n353\t  // Timing measurement (Task 6)\n354\t  const startMs = Date.now();\n355\t\n356\t  try {\n357\t    for await (const event of driver.dispatch(dispatchOpts)) {\n358\t      if (event.type === 'text') {\n359\t        output += event.text;\n360\t      }\n361\t      if (event.type === 'tool-start') {\n362\t        const toolStart = event as ToolStartEvent;\n363\t        activeToolName = toolStart.name;\n364\t        activeToolInput = '';\n365\t      }\n366\t      if (event.type === 'tool-input') {\n367\t        activeToolInput += event.partial;\n368\t      }\n369\t      if (event.type === 'tool-complete') {\n370\t        // Extract file path from Write/Edit tool completions\n371\t        if (activeToolName && FILE_WRITE_TOOL_NAMES.has(activeToolName)) {\n372\t          try {\n373\t            const parsed = JSON.parse(activeToolInput) as Record<string, unknown>;\n374\t            const filePath = (parsed.file_path ?? parsed.path ?? parsed.filePath) as string | undefined;\n375\t            if (filePath && typeof filePath === 'string') {\n376\t              changedFiles.push(filePath);\n377\t            }\n378\t          } catch { // IGNORE: best-effort — tool input may not be valid JSON (partial accumulation)\n379\t          }\n380\t        }\n381\t        activeToolName = null;\n382\t        activeToolInput = '';\n383\t      }\n384\t      if (event.type === 'result') {\n385\t        const resultEvt = event as ResultEvent;\n386\t        resultSessionId = resultEvt.sessionId;\n387\t        cost = resultEvt.cost;\n388\t        if (resultEvt.error) {\n389\t          errorEvent = { error: resultEvt.error, errorCategory: resultEvt.errorCategory };\n390\t        }\n391\t      }\n392\t    }\n393\t  } finally {\n394\t    // Cleanup workspace regardless of dispatch success/failure\n395\t    if (workspace) {\n396\t      await workspace.cleanup();\n397\t    }\n398\t  }\n399\t"}]},"parent_tool_use_id":"toolu_01SkXPMmo5ukZsEWidXQjyr7","session_id":"d2473842-56c4-49f2-ab43-68fabe9113bb","uuid":"447f379f-d8a2-4e61-801a-ac61cd4927f0","timestamp":"2026-04-03T10:58:08.023Z"}
