{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NnYjaLC9K2szUWP4PbBHMR","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→\n     3→vi.mock('node:fs', () => ({\n     4→  existsSync: vi.fn(),\n     5→  readFileSync: vi.fn(),\n     6→}));\n     7→\n     8→import { existsSync, readFileSync } from 'node:fs';\n     9→import { validateDockerfile, loadRules } from '../dockerfile-validator.js';\n    10→\n    11→const mockExistsSync = vi.mocked(existsSync);\n    12→const mockReadFileSync = vi.mocked(readFileSync);\n    13→\n    14→beforeEach(() => {\n    15→  vi.clearAllMocks();\n    16→});\n    17→\n    18→// Helper: build a Dockerfile string that passes all rules\n    19→function goodDockerfile(): string {\n    20→  return [\n    21→    'FROM node:22-slim',\n    22→    'RUN apt-get update && apt-get install -y curl jq && rm -rf /var/lib/apt/lists/*',\n    23→    'RUN npm install -g codeharness',\n    24→    'COPY dist/ /app/dist/',\n    25→    'USER node',\n    26→    'CMD [\"codeharness\"]',\n    27→  ].join('\\n');\n    28→}\n    29→\n    30→// ─── Pinned FROM ────────────────────────────────────────────────────────────\n    31→\n    32→describe('pinned FROM', () => {\n    33→  it('passes for node:22-slim', () => {\n    34→    mockExistsSync.mockReturnValue(true);\n    35→    mockReadFileSync.mockReturnValue(goodDockerfile());\n    36→\n    37→    const r = validateDockerfile('/project');\n    38→    expect(r.success).toBe(true);\n    39→    if (r.success) {\n    40→      const fromGaps = r.data.gaps.filter(g => g.rule === 'pinned-from');\n    41→      expect(fromGaps).toHaveLength(0);\n    42→    }\n    43→  });\n    44→\n    45→  it('fails for node:latest', () => {\n    46→    mockExistsSync.mockReturnValue(true);\n    47→    mockReadFileSync.mockReturnValue(\n    48→      goodDockerfile().replace('FROM node:22-slim', 'FROM node:latest'),\n    49→    );\n    50→\n    51→    const r = validateDockerfile('/project');\n    52→    expect(r.success).toBe(true);\n    53→    if (r.success) {\n    54→      const fromGaps = r.data.gaps.filter(g => g.rule === 'pinned-from');\n    55→      expect(fromGaps.length).toBeGreaterThan(0);\n    56→      expect(fromGaps[0].description).toContain('unpinned base image');\n    57→    }\n    58→  });\n    59→\n    60→  it('fails for node (no tag)', () => {\n    61→    mockExistsSync.mockReturnValue(true);\n    62→    mockReadFileSync.mockReturnValue(\n    63→      goodDockerfile().replace('FROM node:22-slim', 'FROM node'),\n    64→    );\n    65→\n    66→    const r = validateDockerfile('/project');\n    67→    expect(r.success).toBe(true);\n    68→    if (r.success) {\n    69→      const fromGaps = r.data.gaps.filter(g => g.rule === 'pinned-from');\n    70→      expect(fromGaps.length).toBeGreaterThan(0);\n    71→      expect(fromGaps[0].description).toContain('unpinned base image');\n    72→    }\n    73→  });\n    74→});\n    75→\n    76→// ─── Project binary on PATH ─────────────────────────────────────────────────\n    77→\n    78→describe('project binary on PATH', () => {\n    79→  it('passes with npm install -g', () => {\n    80→    mockExistsSync.mockReturnValue(true);\n    81→    mockReadFileSync.mockReturnValue(goodDockerfile());\n    82→\n    83→    const r = validateDockerfile('/project');\n    84→    expect(r.success).toBe(true);\n    85→    if (r.success) {\n    86→      const binGaps = r.data.gaps.filter(g => g.rule === 'binary-on-path');\n    87→      expect(binGaps).toHaveLength(0);\n    88→    }\n    89→  });\n    90→\n    91→  it('passes with pip install', () => {\n    92→    mockExistsSync.mockReturnValue(true);\n    93→    const df = goodDockerfile().replace('RUN npm install -g codeharness', 'RUN pip install myapp');\n    94→    mockReadFileSync.mockReturnValue(df);\n    95→\n    96→    const r = validateDockerfile('/project');\n    97→    expect(r.success).toBe(true);\n    98→    if (r.success) {\n    99→      const binGaps = r.data.gaps.filter(g => g.rule === 'binary-on-path');\n   100→      expect(binGaps).toHaveLength(0);\n   101→    }\n   102→  });\n   103→\n   104→  it('fails when no binary install pattern found', () => {\n   105→    mockExistsSync.mockReturnValue(true);\n   106→    const df = goodDockerfile().replace('RUN npm install -g codeharness', 'RUN echo hello');\n   107→    mockReadFileSync.mockReturnValue(df);\n   108→\n   109→    const r = validateDockerfile('/project');\n   110→    expect(r.success).toBe(true);\n   111→    if (r.success) {\n   112→      const binGaps = r.data.gaps.filter(g => g.rule === 'binary-on-path');\n   113→      expect(binGaps).toHaveLength(1);\n   114→      expect(binGaps[0].description).toContain('project binary not installed');\n   115→    }\n   116→  });\n   117→});\n   118→\n   119→// ─── Verification tools ─────────────────────────────────────────────────────\n   120→\n   121→describe('verification tools', () => {\n   122→  it('passes when curl and jq are installed', () => {\n   123→    mockExistsSync.mockReturnValue(true);\n   124→    mockReadFileSync.mockReturnValue(goodDockerfile());\n   125→\n   126→    const r = validateDockerfile('/project');\n   127→    expect(r.success).toBe(true);\n   128→    if (r.success) {\n   129→      const toolGaps = r.data.gaps.filter(g => g.rule === 'verification-tools');\n   130→      expect(toolGaps).toHaveLength(0);\n   131→    }\n   132→  });\n   133→\n   134→  it('fails when curl is missing', () => {\n   135→    mockExistsSync.mockReturnValue(true);\n   136→    const df = goodDockerfile().replace('curl jq', 'jq');\n   137→    mockReadFileSync.mockReturnValue(df);\n   138→\n   139→    const r = validateDockerfile('/project');\n   140→    expect(r.success).toBe(true);\n   141→    if (r.success) {\n   142→      const toolGaps = r.data.gaps.filter(g => g.rule === 'verification-tools');\n   143→      expect(toolGaps.some(g => g.description.includes('curl'))).toBe(true);\n   144→    }\n   145→  });\n   146→\n   147→  it('fails when jq is missing', () => {\n   148→    mockExistsSync.mockReturnValue(true);\n   149→    const df = goodDockerfile().replace('curl jq', 'curl');\n   150→    mockReadFileSync.mockReturnValue(df);\n   151→\n   152→    const r = validateDockerfile('/project');\n   153→    expect(r.success).toBe(true);\n   154→    if (r.success) {\n   155→      const toolGaps = r.data.gaps.filter(g => g.rule === 'verification-tools');\n   156→      expect(toolGaps.some(g => g.description.includes('jq'))).toBe(true);\n   157→    }\n   158→  });\n   159→});\n   160→\n   161→// ─── No source code COPY ────────────────────────────────────────────────────\n   162→\n   163→describe('no source code COPY', () => {\n   164→  it('passes when no source dirs copied', () => {\n   165→    mockExistsSync.mockReturnValue(true);\n   166→    mockReadFileSync.mockReturnValue(goodDockerfile());\n   167→\n   168→    const r = validateDockerfile('/project');\n   169→    expect(r.success).toBe(true);\n   170→    if (r.success) {\n   171→      const copyGaps = r.data.gaps.filter(g => g.rule === 'no-source-copy');\n   172→      expect(copyGaps).toHaveLength(0);\n   173→    }\n   174→  });\n   175→\n   176→  it('fails for COPY src/', () => {\n   177→    mockExistsSync.mockReturnValue(true);\n   178→    const df = goodDockerfile() + '\\nCOPY src/ /app/src/';\n   179→    mockReadFileSync.mockReturnValue(df);\n   180→\n   181→    const r = validateDockerfile('/project');\n   182→    expect(r.success).toBe(true);\n   183→    if (r.success) {\n   184→      const copyGaps = r.data.gaps.filter(g => g.rule === 'no-source-copy');\n   185→      expect(copyGaps.length).toBeGreaterThan(0);\n   186→      expect(copyGaps[0].description).toContain('source code copied into container');\n   187→    }\n   188→  });\n   189→\n   190→  it('fails for COPY lib/', () => {\n   191→    mockExistsSync.mockReturnValue(true);\n   192→    const df = goodDockerfile() + '\\nCOPY lib/ /app/lib/';\n   193→    mockReadFileSync.mockReturnValue(df);\n   194→\n   195→    const r = validateDockerfile('/project');\n   196→    expect(r.success).toBe(true);\n   197→    if (r.success) {\n   198→      const copyGaps = r.data.gaps.filter(g => g.rule === 'no-source-copy');\n   199→      expect(copyGaps.length).toBeGreaterThan(0);\n   200→    }\n   201→  });\n   202→});\n   203→\n   204→// ─── Non-root USER ──────────────────────────────────────────────────────────\n   205→\n   206→describe('non-root USER', () => {\n   207→  it('passes with USER node', () => {\n   208→    mockExistsSync.mockReturnValue(true);\n   209→    mockReadFileSync.mockReturnValue(goodDockerfile());\n   210→\n   211→    const r = validateDockerfile('/project');\n   212→    expect(r.success).toBe(true);\n   213→    if (r.success) {\n   214→      const userGaps = r.data.gaps.filter(g => g.rule === 'non-root-user');\n   215→      expect(userGaps).toHaveLength(0);\n   216→    }\n   217→  });\n   218→\n   219→  it('fails when no USER instruction', () => {\n   220→    mockExistsSync.mockReturnValue(true);\n   221→    const df = goodDockerfile().replace('USER node\\n', '');\n   222→    mockReadFileSync.mockReturnValue(df);\n   223→\n   224→    const r = validateDockerfile('/project');\n   225→    expect(r.success).toBe(true);\n   226→    if (r.success) {\n   227→      const userGaps = r.data.gaps.filter(g => g.rule === 'non-root-user');\n   228→      expect(userGaps).toHaveLength(1);\n   229→      expect(userGaps[0].description).toContain('no non-root USER instruction found');\n   230→    }\n   231→  });\n   232→\n   233→  it('fails when only USER root', () => {\n   234→    mockExistsSync.mockReturnValue(true);\n   235→    const df = goodDockerfile().replace('USER node', 'USER root');\n   236→    mockReadFileSync.mockReturnValue(df);\n   237→\n   238→    const r = validateDockerfile('/project');\n   239→    expect(r.success).toBe(true);\n   240→    if (r.success) {\n   241→      const userGaps = r.data.gaps.filter(g => g.rule === 'non-root-user');\n   242→      expect(userGaps).toHaveLength(1);\n   243→    }\n   244→  });\n   245→});\n   246→\n   247→// ─── Cache cleanup ──────────────────────────────────────────────────────────\n   248→\n   249→describe('cache cleanup', () => {\n   250→  it('passes with apt cache cleanup', () => {\n   251→    mockExistsSync.mockReturnValue(true);\n   252→    mockReadFileSync.mockReturnValue(goodDockerfile());\n   253→\n   254→    const r = validateDockerfile('/project');\n   255→    expect(r.success).toBe(true);\n   256→    if (r.success) {\n   257→      const cacheGaps = r.data.gaps.filter(g => g.rule === 'cache-cleanup');\n   258→      expect(cacheGaps).toHaveLength(0);\n   259→    }\n   260→  });\n   261→\n   262→  it('passes with npm cache clean', () => {\n   263→    mockExistsSync.mockReturnValue(true);\n   264→    const df = goodDockerfile().replace('rm -rf /var/lib/apt/lists/*', 'npm cache clean --force');\n   265→    mockReadFileSync.mockReturnValue(df);\n   266→\n   267→    const r = validateDockerfile('/project');\n   268→    expect(r.success).toBe(true);\n   269→    if (r.success) {\n   270→      const cacheGaps = r.data.gaps.filter(g => g.rule === 'cache-cleanup');\n   271→      expect(cacheGaps).toHaveLength(0);\n   272→    }\n   273→  });\n   274→\n   275→  it('passes with pip cache purge', () => {\n   276→    mockExistsSync.mockReturnValue(true);\n   277→    const df = goodDockerfile().replace('rm -rf /var/lib/apt/lists/*', 'pip cache purge');\n   278→    mockReadFileSync.mockReturnValue(df);\n   279→\n   280→    const r = validateDockerfile('/project');\n   281→    expect(r.success).toBe(true);\n   282→    if (r.success) {\n   283→      const cacheGaps = r.data.gaps.filter(g => g.rule === 'cache-cleanup');\n   284→      expect(cacheGaps).toHaveLength(0);\n   285→    }\n   286→  });\n   287→\n   288→  it('fails when no cache cleanup', () => {\n   289→    mockExistsSync.mockReturnValue(true);\n   290→    const df =