{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011ydDWyD9bikqp9YLPNRt7f","type":"tool_result","content":"1\t/**\n2\t * Helper functions for the run command.\n3\t *\n4\t * Extracted from run.ts to comply with NFR9 (max 300 lines per file).\n5\t * Contains: elapsed time formatting, sprint status -> story status mapping,\n6\t * and line processing utilities.\n7\t *\n8\t * Ralph-specific functions removed in Story 1.2 — workflow engine pending (Epic 5).\n9\t */\n10\t\n11\timport { StringDecoder } from 'node:string_decoder';\n12\timport { parseStreamLine } from './agents/stream-parser.js';\n13\timport type { StreamEvent } from './agents/stream-parser.js';\n14\timport type { StoryStatusEntry, StoryStatusValue, StoryMessage } from './ink-components.js';\n15\t\n16\t// --- Story Counting ---\n17\t\n18\t/** Story key pattern: digit-digit-name */\n19\tconst STORY_KEY_PATTERN = /^\\d+-\\d+-/;\n20\t\n21\t/**\n22\t * Counts stories by status from sprint-status.yaml.\n23\t */\n24\texport function countStories(statuses: Record<string, string>): {\n25\t  total: number;\n26\t  ready: number;\n27\t  done: number;\n28\t  inProgress: number;\n29\t  // eslint-disable-next-line @typescript-eslint/naming-convention\n30\t  verified: number;\n31\t} {\n32\t  let total = 0;\n33\t  let ready = 0;\n34\t  let done = 0;\n35\t  let inProgress = 0;\n36\t  // eslint-disable-next-line @typescript-eslint/naming-convention\n37\t  let verified = 0;\n38\t\n39\t  for (const [key, status] of Object.entries(statuses)) {\n40\t    if (!STORY_KEY_PATTERN.test(key)) continue;\n41\t    total++;\n42\t    if (status === 'backlog' || status === 'ready-for-dev') ready++;\n43\t    else if (status === 'done') done++;\n44\t    else if (status === 'in-progress' || status === 'review') inProgress++;\n45\t    else if (status === 'verifying') verified++;\n46\t  }\n47\t\n48\t  return { total, ready, done, inProgress, verified };\n49\t}\n50\t\n51\t// --- Elapsed Time Formatting (AC #6) ---\n52\t\n53\t/**\n54\t * Format elapsed milliseconds as \"Xm\" or \"XhYm\".\n55\t * Matches the UX spec format (not the DashboardFormatter \"Xm Ys\" format).\n56\t */\n57\texport function formatElapsed(ms: number): string {\n58\t  const totalMinutes = Math.max(0, Math.floor(ms / 60_000));\n59\t  const hours = Math.floor(totalMinutes / 60);\n60\t  const minutes = totalMinutes % 60;\n61\t  if (hours > 0) {\n62\t    return `${hours}h${minutes}m`;\n63\t  }\n64\t  return `${totalMinutes}m`;\n65\t}\n66\t\n67\t// --- Sprint Status -> Story Status Mapping (AC #7) ---\n68\t\n69\t/**\n70\t * Maps a sprint-status.yaml status value to a StoryStatusValue for the Ink renderer.\n71\t *\n72\t * Mapping:\n73\t *   done -> done\n74\t *   in-progress, review, verifying -> in-progress\n75\t *   backlog, ready-for-dev -> pending\n76\t *   failed -> failed\n77\t *   blocked, exhausted -> blocked\n78\t */\n79\texport function mapSprintStatus(status: string): StoryStatusValue {\n80\t  switch (status) {\n81\t    case 'done':\n82\t      return 'done';\n83\t    case 'in-progress':\n84\t    case 'review':\n85\t    case 'verifying':\n86\t      return 'in-progress';\n87\t    case 'backlog':\n88\t    case 'ready-for-dev':\n89\t      return 'pending';\n90\t    case 'failed':\n91\t      return 'failed';\n92\t    case 'blocked':\n93\t    case 'exhausted':\n94\t      return 'blocked';\n95\t    default:\n96\t      return 'pending';\n97\t  }\n98\t}\n99\t\n100\t/**\n101\t * Converts sprint-status.yaml entries to StoryStatusEntry[] for the Ink renderer.\n102\t * Filters out epic keys, retrospective keys, and optional entries.\n103\t */\n104\texport function mapSprintStatuses(statuses: Record<string, string>): StoryStatusEntry[] {\n105\t  const entries: StoryStatusEntry[] = [];\n106\t  for (const [key, status] of Object.entries(statuses)) {\n107\t    if (!STORY_KEY_PATTERN.test(key)) continue;\n108\t    if (status === 'optional') continue;\n109\t    entries.push({ key, status: mapSprintStatus(status) });\n110\t  }\n111\t  return entries;\n112\t}\n113\t\n114\t// --- Line Processor (extracted from run.ts for testability) ---\n115\t\n116\texport interface LineProcessorCallbacks {\n117\t  onEvent: (event: StreamEvent) => void;\n118\t  onMessage?: (msg: StoryMessage) => void;\n119\t  onIteration?: (iteration: number) => void;\n120\t}\n121\t\n122\t/**\n123\t * Creates a Buffer-to-lines processor that splits on newlines, handles\n124\t * partial-line buffering across chunk boundaries, and feeds complete\n125\t * lines through the stream parser.\n126\t *\n127\t * Ralph message parsing removed in Story 1.2 — workflow engine pending (Epic 5).\n128\t */\n129\texport function createLineProcessor(\n130\t  callbacks: LineProcessorCallbacks,\n131\t): (data: Buffer) => void {\n132\t  let partial = '';\n133\t  const decoder = new StringDecoder('utf8');\n134\t  return (data: Buffer): void => {\n135\t    const text = partial + decoder.write(data);\n136\t    const parts = text.split('\\n');\n137\t    partial = parts.pop() ?? '';\n138\t    for (const line of parts) {\n139\t      if (line.trim().length === 0) continue;\n140\t      const event = parseStreamLine(line);\n141\t      if (event) {\n142\t        callbacks.onEvent(event);\n143\t      }\n144\t    }\n145\t  };\n146\t}\n147\t"}]},"parent_tool_use_id":"toolu_01YVAicDPB2Xe9r2bfCAtkWv","session_id":"1e0d780f-040f-4c10-b8e5-df49ae6fae2c","uuid":"15332406-8015-49b1-8df6-499eab28d462","timestamp":"2026-04-03T20:45:29.997Z"}
