{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011YjstHcqWeXWC4B248MSVL","type":"tool_result","content":"diff --git a/hooks/post-write-check.sh b/hooks/post-write-check.sh\nindex 1dd5fe3..dd83a1d 100755\n--- a/hooks/post-write-check.sh\n+++ b/hooks/post-write-check.sh\n@@ -22,10 +22,26 @@ FILE_PATH=$(echo \"$HOOK_INPUT\" | grep -o '\"file_path\"[[:space:]]*:[[:space:]]*\"[\n # Only prompt for source code files, not config/docs\n case \"$FILE_PATH\" in\n   *.ts|*.js|*.tsx|*.jsx|*.py|*.go|*.rs)\n-    echo '{\"message\": \"New code written. Verify OTLP instrumentation is present.\\n-> Check that new endpoints emit traces and structured logs.\"}'\n     ;;\n   *)\n     # Non-source file, skip\n     exit 0\n     ;;\n esac\n+\n+# Python-specific: check for bare exception swallowing\n+BARE_EXCEPT_WARNING=\"\"\n+if [[ \"$FILE_PATH\" == *.py ]]; then\n+  BARE_EXCEPT_MATCHES=$(grep -n \"except Exception.*pass\" \"$FILE_PATH\" 2>/dev/null || true)\n+  if [ -n \"$BARE_EXCEPT_MATCHES\" ]; then\n+    BARE_EXCEPT_WARNING=\"\\\\n[WARN] Bare 'except Exception: pass' detected in $FILE_PATH\\\\n       Handle the error or add a # IGNORE: comment\"\n+  fi\n+fi\n+\n+# Build message\n+MSG=\"New code written. Verify OTLP instrumentation is present.\\\\n-> Check that new endpoints emit traces and structured logs.\"\n+if [ -n \"$BARE_EXCEPT_WARNING\" ]; then\n+  MSG=\"${MSG}${BARE_EXCEPT_WARNING}\"\n+fi\n+\n+echo \"{\\\"message\\\": \\\"${MSG}\\\"}\"","is_error":false}]},"parent_tool_use_id":"toolu_01RaXV75NMTprbvd4KMPDvjb","session_id":"3fcb2b1c-e710-401b-91ab-b64a3e9a3996","uuid":"dcbc0600-2d63-4c57-b570-bd11d9d03863","timestamp":"2026-03-25T06:59:35.827Z"}
