{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XaHMsrZU3Q3CSWaCFRcyTo","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n     2→import { mkdtempSync, rmSync, mkdirSync, writeFileSync, existsSync, readFileSync } from 'node:fs';\n     3→import { tmpdir } from 'node:os';\n     4→import { join } from 'node:path';\n     5→import { Command } from 'commander';\n     6→\n     7→// Mock stack-path module\n     8→vi.mock('../../lib/stack-path.js', () => ({\n     9→  getStackDir: vi.fn(() => '/mock/.codeharness/stack'),\n    10→  getComposeFilePath: vi.fn(() => '/mock/.codeharness/stack/docker-compose.harness.yml'),\n    11→  getOtelConfigPath: vi.fn(() => '/mock/.codeharness/stack/otel-collector-config.yaml'),\n    12→  ensureStackDir: vi.fn(),\n    13→}));\n    14→\n    15→// Mock docker module\n    16→vi.mock('../../lib/docker.js', () => ({\n    17→  isStackRunning: vi.fn(() => false),\n    18→  stopStack: vi.fn(),\n    19→  stopCollectorOnly: vi.fn(),\n    20→}));\n    21→\n    22→// Mock patch-engine module\n    23→vi.mock('../../lib/patch-engine.js', () => ({\n    24→  removePatch: vi.fn(() => false),\n    25→}));\n    26→\n    27→import { registerTeardownCommand } from '../teardown.js';\n    28→import { writeState, getDefaultState } from '../../lib/state.js';\n    29→import { isStackRunning, stopStack, stopCollectorOnly } from '../../lib/docker.js';\n    30→import { removePatch } from '../../lib/patch-engine.js';\n    31→import { PATCH_TARGETS } from '../../lib/bmad.js';\n    32→\n    33→const mockIsStackRunning = vi.mocked(isStackRunning);\n    34→const mockStopStack = vi.mocked(stopStack);\n    35→const mockStopCollectorOnly = vi.mocked(stopCollectorOnly);\n    36→const mockRemovePatch = vi.mocked(removePatch);\n    37→\n    38→let testDir: string;\n    39→let originalCwd: string;\n    40→\n    41→function createInitializedProject(overrides?: Partial<ReturnType<typeof getDefaultState>>): void {\n    42→  const state = { ...getDefaultState('nodejs'), initialized: true, ...overrides };\n    43→  writeState(state, testDir);\n    44→}\n    45→\n    46→function createCli(): Command {\n    47→  const program = new Command();\n    48→  program.option('--json', 'JSON output');\n    49→  registerTeardownCommand(program);\n    50→  return program;\n    51→}\n    52→\n    53→async function runCli(args: string[]): Promise<{ stdout: string; exitCode: number | undefined }> {\n    54→  const logs: string[] = [];\n    55→  const consoleSpy = vi.spyOn(console, 'log').mockImplementation((...a: unknown[]) => {\n    56→    logs.push(a.map(String).join(' '));\n    57→  });\n    58→  process.exitCode = undefined;\n    59→\n    60→  const program = createCli();\n    61→  await program.parseAsync(['node', 'codeharness', ...args]);\n    62→\n    63→  consoleSpy.mockRestore();\n    64→  return { stdout: logs.join('\\n'), exitCode: process.exitCode };\n    65→}\n    66→\n    67→beforeEach(() => {\n    68→  testDir = mkdtempSync(join(tmpdir(), 'ch-teardown-test-'));\n    69→  originalCwd = process.cwd();\n    70→  process.chdir(testDir);\n    71→  mockIsStackRunning.mockReset();\n    72→  mockIsStackRunning.mockReturnValue(false);\n    73→  mockStopStack.mockReset();\n    74→  mockStopCollectorOnly.mockReset();\n    75→  mockRemovePatch.mockReset();\n    76→  mockRemovePatch.mockReturnValue(false);\n    77→});\n    78→\n    79→afterEach(() => {\n    80→  process.chdir(originalCwd);\n    81→  rmSync(testDir, { recursive: true, force: true });\n    82→  process.exitCode = undefined;\n    83→});\n    84→\n    85→describe('teardown command', () => {\n    86→  describe('state file not found', () => {\n    87→    it('prints error message and sets exit code 1', async () => {\n    88→      const { stdout, exitCode } = await runCli(['teardown']);\n    89→\n    90→      expect(stdout).toContain('[FAIL] Harness not initialized. Nothing to tear down.');\n    91→      expect(exitCode).toBe(1);\n    92→    });\n    93→\n    94→    it('outputs JSON error when --json flag is set', async () => {\n    95→      const { stdout, exitCode } = await runCli(['--json', 'teardown']);\n    96→\n    97→      const parsed = JSON.parse(stdout);\n    98→      expect(parsed.status).toBe('fail');\n    99→      expect(parsed.error).toBe('Harness not initialized. Nothing to tear down.');\n   100→      expect(exitCode).toBe(1);\n   101→    });\n   102→  });\n   103→\n   104→  describe('successful teardown', () => {\n   105→    it('removes state file', async () => {\n   106→      createInitializedProject();\n   107→      const statePath = join(testDir, '.claude', 'codeharness.local.md');\n   108→      expect(existsSync(statePath)).toBe(true);\n   109→\n   110→      await runCli(['teardown']);\n   111→\n   112→      expect(existsSync(statePath)).toBe(false);\n   113→    });\n   114→\n   115→    it('prints success messages', async () => {\n   116→      createInitializedProject();\n   117→\n   118→      const { stdout } = await runCli(['teardown']);\n   119→\n   120→      expect(stdout).toContain('[OK] Removed: .claude/codeharness.local.md');\n   121→      expect(stdout).toContain('[OK] Harness teardown complete');\n   122→    });\n   123→\n   124→    it('prints preserved items', async () => {\n   125→      createInitializedProject();\n   126→\n   127→      const { stdout } = await runCli(['teardown']);\n   128→\n   129→      expect(stdout).toContain('[INFO] Preserved: .beads/ (task history)');\n   130→      expect(stdout).toContain('[INFO] Preserved: _bmad/ (BMAD artifacts, patches removed)');\n   131→      expect(stdout).toContain('[INFO] Preserved: docs/ (documentation)');\n   132→    });\n   133→  });\n   134→\n   135→  describe('shared stack teardown', () => {\n   136→    it('does NOT stop shared stack', async () => {\n   137→      createInitializedProject({\n   138→        docker: {\n   139→          compose_file: '/mock/.codeharness/stack/docker-compose.harne