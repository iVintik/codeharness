 string[] {\n591\t    try {\n592\t      const output = this.execGit('git diff --name-only --diff-filter=U');\n593\t      return output\n594\t        .split('\\n')\n595\t        .map((f) => f.trim())\n596\t        .filter((f) => f.length > 0);\n597\t    } catch { // IGNORE: diff failure means no conflict info available\n598\t      return [];\n599\t    }\n600\t  }\n601\t\n602\t  /**\n603\t   * Abort an in-progress merge or rebase to restore main branch state.\n604\t   */\n605\t  private abortMerge(strategy: MergeStrategy): void {\n606\t    try {\n607\t      if (strategy === 'rebase') {\n608\t        this.execGit('git rebase --abort');\n609\t      } else {\n610\t        this.execGit('git merge --abort');\n611\t      }\n612\t    } catch { // IGNORE: abort may fail if merge already resolved; main state is preserved\n613\t    }\n614\t  }\n615\t\n616\t  /**\n617\t   * Run the test suite and parse results from stdout.\n618\t   * Uses async exec with a 5-minute timeout.\n619\t   */\n620\t  private async runTestSuite(\n621\t    testCommand: string = 'npm test',\n622\t  ): Promise<{ passed: number; failed: number; coverage?: number }> {\n623\t    try {\n624\t      const { stdout } = await execAsync(testCommand, {\n625\t        cwd: this.cwd,\n626\t        timeout: 300_000, // 5 minutes\n627\t      });\n628\t\n629\t      return this.parseTestOutput(stdout);\n630\t    } catch (err: unknown) {\n631\t      // Test command failed (non-zero exit) — parse whatever output we got\n632\t      const stdout = (err as { stdout?: string })?.stdout ?? '';\n633\t      const result = this.parseTestOutput(stdout);\n634\t      // If we couldn't parse anything, report 1 failure\n635\t      if (result.passed === 0 && result.failed === 0) {\n636\t        return { passed: 0, failed: 1 };\n637\t      }\n638\t      return result;\n639\t    }\n640\t  }\n641\t\n642\t  /**\n643\t   * Parse test output to extract pass/fail counts and optional coverage.\n644\t   * Supports common vitest/jest output patterns.\n645\t   */\n646\t  private parseTestOutput(stdout: string): { passed: number; failed: number; coverage?: number } {\n647\t    let passed = 0;\n648\t    let failed = 0;\n649\t    let coverage: number | undefined;\n650\t\n651\t    // Match vitest/jest \"Tests: X passed, Y failed\" or \"X passed\" patterns\n652\t    const passMatch = stdout.match(/(\\d+)\\s+passed/);\n653\t    const failMatch = stdout.match(/(\\d+)\\s+failed/);\n654\t    if (passMatch) passed = parseInt(passMatch[1], 10);\n655\t    if (failMatch) failed = parseInt(failMatch[1], 10);\n656\t\n657\t    // Match coverage percentage patterns like \"All files | 85.5\"\n658\t    const covMatch = stdout.match(/All files[^|]*\\|\\s*([\\d.]+)/);\n659\t    if (covMatch) coverage = parseFloat(covMatch[1]);\n660\t\n661\t    return { passed, failed, ...(coverage !== undefined && { coverage }) };\n662\t  }\n663\t\n664\t  /**\n665\t   * Check if a worktree is orphaned (no active codeharness process).\n666\t   */\n667\t  private isOrphaned(wt: WorktreeInfo): boolean {\n668\t    const laneStatePath = join(wt.path, '.codeharness', 'lane-state.json');\n669\t\n670\t    if (!existsSync(laneStatePath)) {\n671\t      return true;\n672\t    }\n673\t\n674\t    try {\n675\t      const content = readFileSync(laneStatePath, 'utf-8');\n676\t      const state = JSON.parse(content) as { pid?: number };\n677\t\n678\t      if (!state.pid) {\n679\t        return true;\n680\t      }\n681\t\n682\t      // Check if the PID is still running\n683\t      try {\n684\t        process.kill(state.pid, 0);\n685\t        return false; // Process is alive — not orphaned\n686\t      } catch { // IGNORE: ESRCH means process is dead — worktree is orphaned per AC #8\n687\t        return true;\n688\t      }\n689\t    } catch { // IGNORE: unreadable/corrupt lane-state.json means orphaned per AC #8\n690\t      return true;\n691\t    }\n692\t  }\n693\t}\n694\t"}]},"parent_tool_use_id":"toolu_01CHrkgpjhvPg7eJ8iLesM4b","session_id":"22206bba-5847-41b1-b51