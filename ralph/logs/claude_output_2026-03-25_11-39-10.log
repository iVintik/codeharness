"$skey\"\n  1174→                        else\n  1175→                            log_status \"WARN\" \"Story ${skey} — retry ${retry_count}/${MAX_STORY_RETRIES}\"\n  1176→                        fi\n  1177→                        break  # only retry the first actionable story\n  1178→                    done <<< \"$UNCHANGED_STORIES\"\n  1179→                fi\n  1180→\n  1181→                if [[ -n \"$CHANGED_STORIES\" ]]; then\n  1182→                    while IFS= read -r skey; do\n  1183→                        [[ -z \"$skey\" ]] && continue\n  1184→                        # Extract story title from story file if available\n  1185→                        local story_file=\"$project_root/_bmad-output/implementation-artifacts/${skey}.md\"\n  1186→                        local story_title=\"\"\n  1187→                        if [[ -f \"$story_file\" ]]; then\n  1188→                            story_title=$(grep -m1 '^# \\|^## Story' \"$story_file\" 2>/dev/null | sed 's/^#* *//' | head -c 60)\n  1189→                        fi\n  1190→                        local proof_file=\"$project_root/verification/${skey}-proof.md\"\n  1191→                        local proof_info=\"\"\n  1192→                        if [[ -f \"$proof_file\" ]]; then\n  1193→                            proof_info=\" [proof: verification/${skey}-proof.md]\"\n  1194→                        fi\n  1195→                        if [[ -n \"$story_title\" ]]; then\n  1196→                            log_status \"SUCCESS\" \"Story ${skey}: DONE — ${story_title}${proof_info}\"\n  1197→                        else\n  1198→                            log_status \"SUCCESS\" \"Story ${skey}: DONE${proof_info}\"\n  1199→                        fi\n  1200→                    done <<< \"$CHANGED_STORIES\"\n  1201→                fi\n  1202→\n  1203→                sleep 5  # Brief pause between iterations\n  1204→                ;;\n  1205→            2)\n  1206→                # API limit — wait or exit\n  1207→                log_status \"WARN\" \"API usage limit reached. Waiting 60 minutes...\"\n  1208→                update_status \"$loop_count\" \"$(cat \"$CALL_COUNT_FILE\" 2>/dev/null || echo \"0\")\" \"api_limit\" \"paused\"\n  1209→                sleep 3600\n  1210→                ;;\n  1211→            3)\n  1212→                # Circuit breaker\n  1213→                log_status \"ERROR\" \"Circuit breaker opened — halting loop\"\n  1214→                update_status \"$loop_count\" \"$(cat \"$CALL_COUNT_FILE\" 2>/dev/null || echo \"0\")\" \"circuit_breaker\" \"halted\"\n  1215→                break\n  1216→                ;;\n  1217→            4)\n  1218→                # Transient API error — retry after brief pause, don't count against story\n  1219→                consecutive_failures=0  # reset — this isn't the story's fault\n  1220→                log_status \"INFO\" \"Transient API error — retrying in 30s (not counting against story)\"\n  1221→                sleep 30\n  1222→                ;;\n  1223→            *)\n  1224→                # Failure (timeout or crash) — increment retry for the story that was being worked on\n  1225→                consecutive_failures=$((consecutive_failures + 1))\n  1226→\n  1227→                # Increment retry for the first non-done, non-flagged story (the one that caused the timeout)\n  1228→                local after_snap_fail\n  1229→                after_snap_fail=$(snapshot_story_statuses)\n  1230→                while IFS=: read -r fkey fstatus; do\n  1231→                    [[ -z \"$fkey\" ]] && continue\n  1232→                    [[ \"$fstatus\" == \"done\" ]] && continue\n  1233→                    if ! is_story_flagged \"$fkey\"; then\n  1234→                        local fail_retry\n  1235→                        fail_retry=$(increment_story_retry \"$fkey\")\n  1236→                        if [[ $fail_retry -ge $MAX_STORY_RETRIES ]]; then\n  1237→                            log_status \"WARN\" \"Story ${fkey} exceeded retry limit (${fail_retry}) after timeout — flagging\"\n  1238→                            flag_story \"$fkey\"\n  1239→                        else\n  1240→                            log_status \"WARN\" \"Story ${fkey} — timeout retry ${fail_retry}/${MAX_STORY_RETRIES}\"\n  1241→                        fi\n  1242→                        break\n  1243→                    fi\n  1244→                done <<< \"$after_snap_fail\"\n  1245→\n  1246→                if [[ $consecutive_failures -ge $max_consecutive_failures ]]; then\n  1247→                    log_status \"ERROR\" \"$max_consecutive_failures consecutive failures — halting\"\n  1248→                    update_status \"$loop_count\" \"$(cat \"$CALL_COUNT_FILE\" 2>/dev/null || echo \"0\")\" \"consecutive_failures\" \"halted\"\n  1249→                    break\n  1250→                fi\n  1251→\n  1252→                update_status \"$loop_count\" \"$(cat \"$CALL_COUNT_FILE\" 2>/dev/null || echo \"0\")\" \"failed\" \"error\"\n  1253→                log_status \"WARN\" \"Iteration failed ($consecutive_failures/$max_consecutive_failures). Waiting 30s...\"\n  1254→                sleep 30\n  1255→                ;;\n  1256→        esac\n  1257→\n  1258→        # Print progress summary after every iteration\n  1259→        print_progress_summary\n  1260→\n  1261→        # ── Show session issues and retro highlights ──\n  1262→        print_iteration_insights\n  1263→\n  1264→        log_status \"LOOP\" \"=== End Iteration #$loop_count ===\"\n  1265→    done\n  1266→\n  1267→    # Final summary — reads from sprint-status.yaml\n  1268→    local counts\n  1269→    counts=$(get_task_counts)"}]},"parent_tool_use_id":"toolu_016bm8Vm35hrwaxcUECzXhDh","session_id":"7abd6544-c701-4823-9983-ef3c4c76fb5b","uuid":"168bc474-043a-4595-9c0e-24658b6db322","timestamp":"2026-03-25T07:41:42.414Z"}
