{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G5Ay1VM5wXH1mBL6Dq9h7D","type":"tool_result","content":"1\t/**\n2\t * AgentDriver abstraction types.\n3\t *\n4\t * Defines the contract that all agent drivers (Claude Code, Codex, OpenCode)\n5\t * must implement. See architecture-multi-framework.md Decision 1.\n6\t */\n7\t\n8\timport type { Readable } from 'node:stream';\n9\timport type { StreamEvent } from './stream-parser.js';\n10\t\n11\t// --- New Types (Epic 10) ---\n12\t\n13\t/**\n14\t * Health status returned by a driver's healthCheck().\n15\t */\n16\texport interface DriverHealth {\n17\t  readonly available: boolean;\n18\t  readonly authenticated: boolean;\n19\t  readonly version: string | null;\n20\t  readonly error?: string;\n21\t}\n22\t\n23\t/**\n24\t * Capability flags for a driver. Extensible — new boolean fields\n25\t * can be added without breaking existing drivers.\n26\t */\n27\texport interface DriverCapabilities {\n28\t  readonly supportsPlugins: boolean;\n29\t  readonly supportsStreaming: boolean;\n30\t  readonly costReporting: boolean;\n31\t}\n32\t\n33\t/**\n34\t * Error classification categories for driver errors.\n35\t * Drivers must NOT invent new categories.\n36\t *\n37\t * Classification priority:\n38\t * 1. HTTP 429 or \"rate limit\" in message -> RATE_LIMIT\n39\t * 2. ECONNREFUSED, ETIMEDOUT, ENOTFOUND -> NETWORK\n40\t * 3. HTTP 401/403 or \"unauthorized\"/\"forbidden\" -> AUTH\n41\t * 4. Process killed by timeout -> TIMEOUT\n42\t * 5. Everything else -> UNKNOWN\n43\t */\n44\texport type ErrorCategory = 'RATE_LIMIT' | 'NETWORK' | 'AUTH' | 'TIMEOUT' | 'UNKNOWN';\n45\t\n46\t/**\n47\t * Test results summary for an output contract.\n48\t */\n49\texport interface TestResults {\n50\t  readonly passed: number;\n51\t  readonly failed: number;\n52\t  readonly coverage: number | null;\n53\t}\n54\t\n55\t/**\n56\t * Acceptance criteria status entry.\n57\t */\n58\texport interface ACStatus {\n59\t  readonly id: string;\n60\t  readonly description: string;\n61\t  readonly status: string;\n62\t}\n63\t\n64\t/**\n65\t * Structured output contract produced by a dispatch.\n66\t */\n67\texport interface OutputContract {\n68\t  readonly version: number;\n69\t  readonly taskName: string;\n70\t  readonly storyId: string;\n71\t  readonly driver: string;\n72\t  readonly model: string;\n73\t  readonly timestamp: string;\n74\t  readonly cost_usd: number | null;\n75\t  readonly duration_ms: number;\n76\t  readonly changedFiles: readonly string[];\n77\t  readonly testResults: TestResults | null;\n78\t  readonly output: string;\n79\t  readonly acceptanceCriteria: readonly ACStatus[];\n80\t}\n81\t\n82\t/**\n83\t * Options for dispatching a task to a driver.\n84\t */\n85\texport interface DispatchOpts {\n86\t  readonly prompt: string;\n87\t  readonly model: string;\n88\t  readonly cwd: string;\n89\t  readonly sourceAccess: boolean;\n90\t  readonly plugins?: readonly string[];\n91\t  readonly timeout?: number;\n92\t  readonly outputContract?: OutputContract;\n93\t}\n94\t\n95\t/**\n96\t * The core agent driver interface (v2 — Epic 10).\n97\t * Each driver knows how to check health, dispatch tasks, and report cost.\n98\t * `dispatch()` returns `AsyncIterable<StreamEvent>` enabling both in-process\n99\t * (Agent SDK yields) and CLI-wrapped (stdout parsed to events) drivers.\n100\t */\n101\texport interface AgentDriver {\n102\t  readonly name: string;\n103\t  readonly defaultModel: string;\n104\t  readonly capabilities: DriverCapabilities;\n105\t  healthCheck(): Promise<DriverHealth>;\n106\t  dispatch(opts: DispatchOpts): AsyncIterable<StreamEvent>;\n107\t  getLastCost(): number | null;\n108\t}\n109\t\n110\t// --- Deprecated Types (backward compatibility until story 10-3) ---\n111\t\n112\t/**\n113\t * Options for spawning an agent process.\n114\t * @deprecated Use `DispatchOpts` instead. Will be removed after story 10-3.\n115\t */\n116\texport interface SpawnOpts {\n117\t  storyKey: string;\n118\t  prompt: string;\n119\t  workDir: string;\n120\t  timeout: number;\n121\t  env?: Record<string, string>;\n122\t}\n123\t\n124\t/**\n125\t * Abstraction over a running agent process.\n126\t * Wraps Node.js ChildProcess but allows non-process-based drivers\n127\t * (direct API calls, WebSocket connections) to implement the same interface.\n128\t * @deprecated Use `AsyncIterable<StreamEvent>` from `dispatch()` instead. Will be removed after story 10-3.\n129\t */\n130\texport interface AgentProcess {\n131\t  stdout: Readable;\n132\t  stderr: Readable;\n133\t  on(event: 'close', handler: (code: number) => void): void;\n134\t  on(event: 'error', handler: (err: Error) => void): void;\n135\t  kill(signal?: string): void;\n136\t}\n137\t\n138\t/**\n139\t * Discriminated union of events emitted by an agent driver.\n140\t * The `parseOutput()` method converts raw agent output lines into these typed events.\n141\t * @deprecated Use `StreamEvent` from `stream-parser.ts` instead. Will be removed after story 10-3.\n142\t */\n143\texport type AgentEvent =\n144\t  | { type: 'tool-start'; name: string }\n145\t  | { type: 'tool-input'; partial: string }\n146\t  | { type: 'tool-complete'; name?: string; args?: string }\n147\t  | { type: 'text'; text: string }\n148\t  | { type: 'story-complete'; key: string; details: string }\n149\t  | { type: 'story-failed'; key: string; reason: string }\n150\t  | { type: 'iteration'; count: number }\n151\t  | { type: 'retry'; attempt: number; delay: number }\n152\t  | { type: 'result'; cost: number; sessionId: string };\n153\t"}]},"parent_tool_use_id":"toolu_011ACjM7rS7kgs6kygtQ7sim","session_id":"f83470b7-c271-483e-ae93-7fe9bce4b683","uuid":"3ffcd525-5157-4a4a-8e5d-13047b161123","timestamp":"2026-04-03T07:38:06.827Z"}
{"type":"system","subtype":"task_progress","task_id":"a6a88f64732542c7c","tool_use_id":"toolu_011ACjM7rS7kgs6kygtQ7sim","description":"Reading src/lib/agents/drivers/claude-code.ts","usage":{"total_tokens":42993,"tool_uses":17,"duration_ms":31923},"last_tool_name":"Read","uuid":"d499f672-14e9-431c-b85e-3071e8a17d71","session_id":"f83470b7-c271-483e-ae93-7fe9bce4b683"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_011g2YMpC1ueHkcP3PUG2CVe","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Fa689M7GqCyejD9qPoEZ5j","name":"Read","input":{"file_path":"/Users/ivintik/dev/personal/codeharness/src/lib/agents/drivers/claude-code.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":12765,"cache_read_input_tokens":29922,"cache_creation":{"ephemeral_5m_input_tokens":12765,"ephemeral_1h_input_tokens":0},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_011ACjM7rS7kgs6kygtQ7sim","session_id":"f83470b7-c271-483e-ae93-7fe9bce4b683","uuid":"bdb2794d-e834-4504-9f4f-a3bdeb6727f8"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Fa689M7GqCyejD9qPoEZ5j","type":"tool_result","content":"1\t/**\n2\t * Claude Code Driver — in-process driver using the Agent SDK.\n3\t *\n4\t * Unlike CLI-wrapped drivers (Codex, OpenCode), this driver calls the\n5\t * Agent SDK `query()` function directly. No process spawning needed.\n6\t *\n7\t * @see architecture-multi-framework.md — Decision 1: Driver Interface Design\n8\t * @see architecture-multi-framework.md — Decision 2: CLI-Wrapping Strategy (in-process variant)\n9\t */\n10\t\n11\timport { query } from '@anthropic-ai/claude-agent-sdk';\n12\timport type {\n13\t  AgentDriver,\n14\t  DispatchOpts,\n15\t  DriverHealth,\n16\t  DriverCapabilities,\n17\t  ErrorCategory,\n18\t} from '../types.js';\n19\timport type { StreamEvent, ResultEvent } from '../stream-parser.js';\n20\t\n21\t// --- Error Classification ---\n22\t\n23\tconst NETWORK_CODES = new Set([\n24\t  'ECONNREFUSED',\n25\t  'ETIMEDOUT',\n26\t  'ENOTFOUND',\n27\t  'ENETUNREACH',\n28\t  'ECONNRESET',\n29\t  'EPIPE',\n30\t]);\n31\t\n32\t/**\n33\t * Classify an error into a standard ErrorCategory.\n34\t *\n35\t * Priority order:\n36\t * 1. HTTP 429 or \"rate limit\" -> RATE_LIMIT\n37\t * 2. Known network error codes -> NETWORK\n38\t * 3. HTTP 401/403 or \"unauthorized\"/\"forbidden\" -> AUTH\n39\t * 4. Timeout -> TIMEOUT\n40\t * 5. Everything else -> UNKNOWN\n41\t */\n42\tfunction classifyError(err: unknown): ErrorCategory {\n43\t  const message = err instanceof Error ? err.message : String(err);\n44\t  const code = (err as { code?: string })?.code;\n45\t  const status = (err as { status?: number })?.status;\n46\t\n47\t  // Rate limit: HTTP 429 or message containing \"rate limit\"\n48\t  if (status === 429 || /rate.?limit/i.test(message)) {\n49\t    return 'RATE_LIMIT';\n50\t  }\n51\t\n52\t  // Network errors: known error codes\n53\t  if (code && NETWORK_CODES.has(code)) {\n54\t    return 'NETWORK';\n55\t  }\n56\t  if (/fetch|network|dns/i.test(message) && /fail|error|timeout/i.test(message)) {\n57\t    return 'NETWORK';\n58\t  }\n59\t\n60\t  // Auth errors: HTTP 401/403 or auth-related messages\n61\t  if (status === 401 || status === 403 || /unauthorized|forbidden/i.test(message)) {\n62\t    return 'AUTH';\n63\t  }\n64\t\n65\t  // Timeout: AbortError or timeout-related messages\n66\t  if (\n67\t    (err instanceof Error && err.name === 'AbortError') ||\n68\t    /timeout|timed.?out|aborted/i.test(message)\n69\t  ) {\n70\t    return 'TIMEOUT';\n71\t  }\n72\t\n73\t  return 'UNKNOWN';\n74\t}\n75\t\n76\t// --- SDK Message to StreamEvent mapping ---\n77\t\n78\t/**\n79\t * Map an SDK message object to a StreamEvent, or return null if unrecognized.\n80\t */\n81\tfunction mapSdkMessage(message: Record<string, unknown>): StreamEvent | null {\n82\t  const type = message.type as string | undefined;\n83\t\n84\t  if (type === 'stream_event') {\n85\t    const event = message.event as Record<string, unknown> | undefined;\n86\t    if (!event || typeof event !== 'object') return null;\n87\t\n88\t    const eventType = event.type as string | undefined;\n89\t\n90\t    if (eventType === 'content_block_start') {\n91\t      const contentBlock = event.content_block as Record<string, unknown> | undefined;\n92\t      if (contentBlock?.type === 'tool_use') {\n93\t        const name = contentBlock.name;\n94\t        const id = contentBlock.id;\n95\t        if (typeof name === 'string' && typeof id === 'string') {\n96\t          return { type: 'tool-start', name, id };\n97\t        }\n98\t      }\n99\t      return null;\n100\t    }\n101\t\n102\t    if (eventType === 'content_block_delta') {\n103\t      const delta = event.delta as Record<string, unknown> | undefined;\n104\t      if (!delta) return null;\n105\t\n106\t      if (delta.type === 'input_json_delta') {\n107\t        const partialJson = delta.partial_json;\n108\t        if (typeof partialJson === 'string') {\n109\t          return { type: 'tool-input', partial: partialJson };\n110\t        }\n111\t        return null;\n112\t      }\n113\t\n114\t      if (delta.type === 'text_delta') {\n115\t        const text = delta.text;\n116\t        if (typeof text === 'string') {\n117\t          return { type: 'text', text };\n118\t        }\n119\t        return null;\n120\t      }\n121\t\n122\t      return null;\n123\t    }\n124\t\n125\t    if (eventType === 'content_block_stop') {\n126\t      return { type: 'tool-complete' };\n127\t    }\n128\t\n129\t    return null;\n130\t  }\n131\t\n132\t  if (type === 'system') {\n133\t    const subtype = message.subtype as string | undefined;\n134\t    if (subtype === 'api_retry') {\n135\t      const attempt = message.attempt;\n136\t      const delay = message.retry_delay_ms;\n137\t      if (typeof attempt === 'number' && typeof delay === 'number') {\n138\t        return { type: 'retry', attempt, delay };\n139\t      }\n140\t    }\n141\t    return null;\n142\t  }\n143\t\n144\t  // 'result' type is handled separately in dispatch() to capture cost\n145\t  return null;\n146\t}\n147\t\n148\t// --- Driver Implementation ---\n149\t\n150\t/**\n151\t * ClaudeCodeDriver — in-process AgentDriver using the Agent SDK query() API.\n152\t *\n153\t * This driver is always available (in-process dependency). Auth is checked\n154\t * lazily on first API call, not eagerly.\n155\t */\n156\texport class ClaudeCodeDriver implements AgentDriver {\n157\t  readonly name = 'claude-code' as const;\n158\t  readonly defaultModel = 'claude-sonnet-4-20250514' as const;\n159\t  readonly capabilities: DriverCapabilities = {\n160\t    supportsPlugins: true,\n161\t    supportsStreaming: true,\n162\t    costReporting: true,\n163\t  };\n164\t\n165\t  private lastCost: number | null = null;\n166\t\n167\t  async healthCheck(): Promise<DriverHealth> {\n168\t    return { available: true, authenticated: true, version: null };\n169\t  }\n170\t\n171\t  async *dispatch(opts: DispatchOpts): AsyncGenerator<StreamEvent> {\n172\t    this.lastCost = null;\n173\t\n174\t    // Build query options\n175\t    const queryOptions: Record<string, unknown> = {\n176\t      model: opts.model,\n177\t      cwd: opts.cwd,\n178\t      permissionMode: opts.sourceAccess ? 'bypassPermissions' : 'default',\n179\t      ...(opts.sourceAccess ? { allowDangerouslySkipPermissions: true } : {}),\n180\t    };\n181\t\n182\t    // Plugin pass-through\n183\t    if (opts.plugins && opts.plugins.length > 0) {\n184\t      queryOptions.plugins = [...opts.plugins];\n185\t    }\n186\t\n187\t    // Timeout handling via AbortController\n188\t    let abortController: AbortController | undefined;\n189\t    let timeoutId: ReturnType<typeof setTimeout> | undefined;\n190\t\n191\t    if (opts.timeout) {\n192\t      abortController = new AbortController();\n193\t      timeoutId = setTimeout(() => {\n194\t        abortController!.abort();\n195\t      }, opts.timeout);\n196\t    }\n197\t\n198\t    let yieldedResult = false;\n199\t\n200\t    try {\n201\t      const queryGenerator = query({\n202\t        prompt: opts.prompt,\n203\t        options: queryOptions,\n204\t        ...(abortController ? { abortController } : {}),\n205\t      });\n206\t\n207\t      for await (const message of queryGenerator) {\n208\t        const msg = message as Record<string, unknown>;\n209\t\n210\t        // Handle result message specially to capture cost\n211\t        if (msg.type === 'result') {\n212\t          const costUsd = msg.total_cost_usd;\n213\t          const sessionId = msg.session_id;\n214\t\n215\t          if (typeof costUsd === 'number') {\n216\t            this.lastCost = costUsd;\n217\t          }\n218\t\n219\t          const resultEvent: ResultEvent = {\n220\t            type: 'result',\n221\t            cost: typeof costUsd === 'number' ? costUsd : 0,\n222\t            sessionId: typeof sessionId === 'string' ? sessionId : '',\n223\t            cost_usd: typeof costUsd === 'number' ? costUsd : null,\n224\t          };\n225\t          yield resultEvent;\n226\t          yieldedResult = true;\n227\t          continue;\n228\t        }\n229\t\n230\t        // Map other SDK messages to StreamEvents\n231\t        const streamEvent = mapSdkMessage(msg);\n232\t        if (streamEvent) {\n233\t          yield streamEvent;\n234\t        }\n235\t      }\n236\t    } catch (err: unknown) {\n237\t      const category = classifyError(err);\n238\t      const errorMessage = err instanceof Error ? err.message : String(err);\n239\t\n240\t      // If abort was triggered by our timeout, classify as TIMEOUT\n241\t      const finalCategory =\n242\t        abortController?.signal.aborted && category !== 'RATE_LIMIT'\n243\t          ? 'TIMEOUT'\n244\t          : category;\n245\t\n246\t      const resultEvent: ResultEvent = {\n247\t        type: 'result',\n248\t        cost: this.lastCost ?? 0,\n249\t        sessionId: '',\n250\t        cost_usd: this.lastCost,\n251\t      };\n252\t\n253\t      yield {\n254\t        ...resultEvent,\n255\t        error: errorMessage,\n256\t        errorCategory: finalCategory,\n257\t      };\n258\t      yieldedResult = true;\n259\t    } finally {\n260\t      if (timeoutId) {\n261\t        clearTimeout(timeoutId);\n262\t      }\n263\t    }\n264\t\n265\t    // Guarantee a result event is always yielded\n266\t    if (!yieldedResult) {\n267\t      yield {\n268\t        type: 'result',\n269\t        cost: this.lastCost ?? 0,\n270\t        sessionId: '',\n271\t        cost_usd: this.lastCost,\n272\t      } as ResultEvent;\n273\t    }\n274\t  }\n275\t\n276\t  getLastCost(): number | null {\n277\t    return this.lastCost;\n278\t  }\n279\t}\n280\t"}]},"parent_tool_use_id":"toolu_011ACjM7rS7kgs6kygtQ7sim","session_id":"f83470b7-c271-483e-ae93-7fe9bce4b683","uuid":"a38f69cf-6d7a-4209-91f2-793399f086d6","timestamp":"2026-04-03T07:38:11.381Z"}
