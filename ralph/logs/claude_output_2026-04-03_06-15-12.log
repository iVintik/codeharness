{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DDJUAVvm3kX6w5yrEkRPhV","type":"tool_result","content":"1\t/**\n2\t * Parses retrospective markdown files to extract action items\n3\t * and classify them for beads import.\n4\t */\n5\t\n6\texport interface RetroActionItem {\n7\t  /** Item number identifier, e.g., \"A1\", \"A2\" */\n8\t  number: string;\n9\t  /** Action item description */\n10\t  description: string;\n11\t  /** Status from the retro table, e.g., \"Not done\", \"Regressed\" */\n12\t  status: string;\n13\t  /** Notes column from the retro table */\n14\t  notes: string;\n15\t}\n16\t\n17\texport type Classification =\n18\t  | { type: 'harness' }\n19\t  | { type: 'tool'; name: string }\n20\t  | { type: 'project' };\n21\t\n22\tconst KNOWN_TOOLS = ['showboat', 'ralph', 'beads', 'bmad'];\n23\t\n24\t/**\n25\t * Parses action items from a retrospective markdown file.\n26\t * Looks for a table with the format: `| # | Action | Status | Notes |`\n27\t */\n28\texport function parseRetroActionItems(content: string): RetroActionItem[] {\n29\t  const lines = content.split('\\n');\n30\t  const items: RetroActionItem[] = [];\n31\t\n32\t  let inTable = false;\n33\t\n34\t  for (const line of lines) {\n35\t    const trimmed = line.trim();\n36\t\n37\t    // Detect table header row: | # | Action | Status | Notes |\n38\t    if (!inTable && /^\\|\\s*#\\s*\\|\\s*Action\\s*\\|\\s*Status\\s*\\|\\s*Notes\\s*\\|/i.test(trimmed)) {\n39\t      inTable = true;\n40\t      continue;\n41\t    }\n42\t\n43\t    // Skip separator row: |---|--------|--------|-------|\n44\t    if (inTable && /^\\|[\\s\\-|]+\\|$/.test(trimmed)) {\n45\t      continue;\n46\t    }\n47\t\n48\t    // Parse data rows\n49\t    if (inTable && trimmed.startsWith('|')) {\n50\t      const cells = trimmed\n51\t        .split('|')\n52\t        .slice(1, -1) // Remove leading/trailing empty strings from split\n53\t        .map(c => c.trim());\n54\t\n55\t      if (cells.length >= 4) {\n56\t        const number = cells[0];\n57\t        const description = cells[1];\n58\t        const status = cells[2];\n59\t        const notes = cells[3];\n60\t\n61\t        // Only include rows with valid item numbers (e.g., A1, A2)\n62\t        if (/^[A-Za-z]\\d+$/.test(number)) {\n63\t          items.push({ number, description, status, notes });\n64\t        }\n65\t      }\n66\t    }\n67\t\n68\t    // End of table: non-table line after table started\n69\t    if (inTable && !trimmed.startsWith('|') && trimmed !== '') {\n70\t      inTable = false;\n71\t    }\n72\t  }\n73\t\n74\t  return items;\n75\t}\n76\t\n77\t/**\n78\t * Classifies a retro action item based on its description text.\n79\t *\n80\t * Rules (applied in order):\n81\t * 1. Contains \"harness\" or \"codeharness\" (case-insensitive) -> harness\n82\t * 2. Contains known tool name (case-insensitive) -> tool:<name>\n83\t * 3. Everything else -> project\n84\t */\n85\texport function classifyFinding(item: RetroActionItem): Classification {\n86\t  const text = item.description.toLowerCase();\n87\t\n88\t  if (text.includes('harness') || text.includes('codeharness')) {\n89\t    return { type: 'harness' };\n90\t  }\n91\t\n92\t  for (const tool of KNOWN_TOOLS) {\n93\t    if (text.includes(tool)) {\n94\t      return { type: 'tool', name: tool };\n95\t    }\n96\t  }\n97\t\n98\t  return { type: 'project' };\n99\t}\n100\t\n101\t/**\n102\t * Derives priority from retro action item context.\n103\t * - Items marked \"Regressed\" or with urgency indicators -> priority 1\n104\t * - Items marked \"Not done\" with multiple carries -> priority 2\n105\t * - Default -> priority 2\n106\t */\n107\texport function derivePriority(item: RetroActionItem): number {\n108\t  const statusLower = item.status.toLowerCase();\n109\t  const notesLower = item.notes.toLowerCase();\n110\t\n111\t  // Regressed or urgency indicators -> priority 1\n112\t  if (\n113\t    statusLower.includes('regressed') ||\n114\t    notesLower.includes('urgent') ||\n115\t    notesLower.includes('critical')\n116\t  ) {\n117\t    return 1;\n118\t  }\n119\t\n120\t  // Default priority\n121\t  return 2;\n122\t}\n123\t\n124\t// ─── Section-based retro parsing (subsection format) ────────────────────\n125\t\n126\t/** Section classification for action items under ## 6. Action Items */\n127\texport type RetroSection = 'fix-now' | 'fix-soon' | 'backlog';\n128\t\n129\t/** An action item parsed from a retro subsection */\n130\texport interface RetroSectionItem {\n131\t  readonly section: RetroSection;\n132\t  readonly text: string;\n133\t}\n134\t\n135\t/**\n136\t * Classify a subsection header into a RetroSection.\n137\t * Matches case-insensitively and strips parenthetical suffixes.\n138\t * Returns null if the header doesn't match a known section.\n139\t */\n140\tfunction classifyHeader(header: string): RetroSection | null {\n141\t  // Strip leading #+ and trim\n142\t  const text = header.replace(/^#+\\s*/, '').trim();\n143\t  // Strip parenthetical suffix: \"Fix Now (Before Next Session)\" -> \"Fix Now\"\n144\t  const base = text.replace(/\\s*\\(.*\\)\\s*$/, '').trim().toLowerCase();\n145\t  if (base === 'fix now') return 'fix-now';\n146\t  if (base === 'fix soon') return 'fix-soon';\n147\t  if (base === 'backlog') return 'backlog';\n148\t  return null;\n149\t}\n150\t\n151\t/**\n152\t * Parse retro subsection-based action items from the `## 6. Action Items` section.\n153\t * Handles varying header formats (### or ####, with/without parenthetical suffixes).\n154\t * Extracts bullet items (`- ` or numbered `1. `) under each subsection.\n155\t */\n156\texport function parseRetroSections(content: string): RetroSectionItem[] {\n157\t  const lines = content.split('\\n');\n158\t  const items: RetroSectionItem[] = [];\n159\t  let currentSection: RetroSection | null = null;\n160\t  let inActionItems = false;\n161\t\n162\t  for (const line of lines) {\n163\t    const trimmed = line.trim();\n164\t\n165\t    // Detect ## 6. Action Items header (or similar)\n166\t    if (/^#{2}\\s+\\d+\\.\\s*Action\\s*Items/i.test(trimmed)) {\n167\t      inActionItems = true;\n168\t      continue;\n169\t    }\n170\t\n171\t    // If we hit another ## header (not ###/####), stop\n172\t    if (inActionItems && /^#{2}\\s+[^#]/.test(trimmed) && !/Action\\s*Items/i.test(trimmed)) {\n173\t      break;\n174\t    }\n175\t\n176\t    if (!inActionItems) continue;\n177\t\n178\t    // Detect ### or #### subsection headers\n179\t    if (/^#{3,4}\\s+/.test(trimmed)) {\n180\t      const section = classifyHeader(trimmed);\n181\t      currentSection = section;\n182\t      continue;\n183\t    }\n184\t\n185\t    // Extract bullet items under current section\n186\t    if (currentSection !== null) {\n187\t      const bulletMatch = trimmed.match(/^(?:-|\\d+\\.)\\s+(.+)$/);\n188\t      if (bulletMatch) {\n189\t        items.push({ section: currentSection, text: bulletMatch[1].trim() });\n190\t      }\n191\t    }\n192\t  }\n193\t\n194\t  return items;\n195\t}\n196\t\n197\t// ─── Deduplication utilities ────────────────────────────────────────────\n198\t\n199\t/**\n200\t * Normalize text for deduplication: lowercase, remove punctuation, split into words.\n201\t */\n202\texport function normalizeText(text: string): string[] {\n203\t  return text\n204\t    .toLowerCase()\n205\t    .replace(/[^a-z0-9\\s]/g, '')\n206\t    .split(/\\s+/)\n207\t    .filter(w => w.length > 0);\n208\t}\n209\t\n210\t/**\n211\t * Compute word overlap between two normalized word arrays.\n212\t * Returns overlap percentage (0-1) using min(|a|, |b|) as denominator.\n213\t */\n214\texport function wordOverlap(a: string[], b: string[]): number {\n215\t  if (a.length === 0 || b.length === 0) return 0;\n216\t  const setA = new Set(a);\n217\t  const setB = new Set(b);\n218\t  let intersection = 0;\n219\t  for (const w of setA) {\n220\t    if (setB.has(w)) intersection++;\n221\t  }\n222\t  return intersection / Math.min(setA.size, setB.size);\n223\t}\n224\t\n225\t/**\n226\t * Check if a new item is a duplicate of any existing title.\n227\t * Uses word overlap with configurable threshold (default 0.8).\n228\t */\n229\texport function isDuplicate(\n230\t  newItem: string,\n231\t  existingTitles: string[],\n232\t  threshold = 0.8,\n233\t): { duplicate: boolean; matchedTitle?: string } {\n234\t  const newWords = normalizeText(newItem);\n235\t  for (const title of existingTitles) {\n236\t    const titleWords = normalizeText(title);\n237\t    if (wordOverlap(newWords, titleWords) >= threshold) {\n238\t      return { duplicate: true, matchedTitle: title };\n239\t    }\n240\t  }\n241\t  return { duplicate: false };\n242\t}\n243\t"}]},"parent_tool_use_id":"toolu_01U1QxzZy7C659GJM4oxEmEf","session_id":"3f15b50c-2c9b-40fa-9e63-9fad2199af43","uuid":"d25d736d-11c3-4656-96b0-bffa39f14040","timestamp":"2026-04-03T02:27:47.816Z"}
