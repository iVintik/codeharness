-3 trace IDs). */\u001b[39m\n\u001b[31m+   appendSystemPrompt?: string;\u001b[39m\n\u001b[31m+ }\u001b[39m\n\u001b[31m+\u001b[39m\n\u001b[31m+ /**\u001b[39m\n\u001b[31m+  * Result of a successful agent dispatch.\u001b[39m\n\u001b[31m+  */\u001b[39m\n\u001b[31m+ export interface DispatchResult {\u001b[39m\n\u001b[31m+   /** The session ID assigned by the Agent SDK. */\u001b[39m\n\u001b[31m+   sessionId: string;\u001b[39m\n\u001b[31m+   /** Whether the session completed successfully (no errors). */\u001b[39m\n\u001b[31m+   success: boolean;\u001b[39m\n\u001b[31m+   /** Wall-clock duration in milliseconds. */\u001b[39m\n\u001b[31m+   durationMs: number;\u001b[39m\n\u001b[31m+   /** The agent's final text response. */\u001b[39m\n\u001b[31m+   output: string;\u001b[39m\n\u001b[31m+ }\u001b[39m\n\u001b[31m+\u001b[39m\n\u001b[31m+ // --- Error Class ---\u001b[39m\n\u001b[31m+\u001b[39m\n\u001b[31m+ /** Error codes for classifying dispatch failures. */\u001b[39m\n\u001b[31m+ export type DispatchErrorCode = 'RATE_LIMIT' | 'NETWORK' | 'SDK_INIT' | 'UNKNOWN';\u001b[39m\n\u001b[31m+\u001b[39m\n\u001b[31m+ /**\u001b[39m\n\u001b[31m+  * Structured error thrown by dispatchAgent() with a classification code.\u001b[39m\n\u001b[31m+  */\u001b[39m\n\u001b[31m+ export class DispatchError extends Error {\u001b[39m\n\u001b[31m+   public readonly code: DispatchErrorCode;\u001b[39m\n\u001b[31m+   public readonly agentName: string;\u001b[39m\n\u001b[31m+   public readonly cause: unknown;\u001b[39m\n\u001b[31m+\u001b[39m\n\u001b[31m+   constructor(\u001b[39m\n\u001b[31m+     message: string,\u001b[39m\n\u001b[31m+     code: DispatchErrorCode,\u001b[39m\n\u001b[31m+     agentName: string,\u001b[39m\n\u001b[31m+     cause: unknown,\u001b[39m\n\u001b[31m+   ) {\u001b[39m\n\u001b[31m+     super(message);\u001b[39m\n\u001b[31m+     this.name = 'DispatchError';\u001b[39m\n\u001b[31m+     this.code = code;\u001b[39m\n\u001b[31m+     this.agentName = agentName;\u001b[39m\n\u001b[31m+     this.cause 