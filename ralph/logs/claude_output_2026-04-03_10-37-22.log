{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DJPUGRCQK1gxrBfkuxKXMR","type":"tool_result","content":"1\t/**\n2\t * Driver Factory & Registry.\n3\t *\n4\t * Module-singleton registry for AgentDriver instances.\n5\t * Drivers are registered explicitly via registerDriver() — no auto-discovery,\n6\t * no filesystem scanning, no dynamic imports.\n7\t *\n8\t * @see architecture-multi-framework.md — \"Register in factory.ts — never auto-discover\"\n9\t */\n10\t\n11\timport type { AgentDriver } from '../types.js';\n12\t\n13\tconst registry = new Map<string, AgentDriver>();\n14\t\n15\t/**\n16\t * Register an AgentDriver by its `name` property.\n17\t * Throws if a driver with the same name is already registered.\n18\t */\n19\texport function registerDriver(driver: AgentDriver): void {\n20\t  if (!driver || typeof driver.name !== 'string') {\n21\t    throw new Error('registerDriver requires a valid AgentDriver with a string name property.');\n22\t  }\n23\t  if (!driver.name) {\n24\t    throw new Error('Driver name must be a non-empty string.');\n25\t  }\n26\t  if (registry.has(driver.name)) {\n27\t    throw new Error(\n28\t      `Driver '${driver.name}' is already registered. Each driver name must be unique.`,\n29\t    );\n30\t  }\n31\t  registry.set(driver.name, driver);\n32\t}\n33\t\n34\t/**\n35\t * Retrieve a registered AgentDriver by name.\n36\t * Throws with a helpful message listing all registered drivers if not found.\n37\t */\n38\texport function getDriver(name: string): AgentDriver {\n39\t  if (!name || typeof name !== 'string') {\n40\t    throw new Error('getDriver requires a non-empty string name.');\n41\t  }\n42\t  const driver = registry.get(name);\n43\t  if (!driver) {\n44\t    const registered = [...registry.keys()];\n45\t    const list =\n46\t      registered.length > 0 ? registered.join(', ') : '(none)';\n47\t    throw new Error(\n48\t      `Driver '${name}' not found. Registered drivers: ${list}`,\n49\t    );\n50\t  }\n51\t  return driver;\n52\t}\n53\t\n54\t/**\n55\t * List all registered driver names.\n56\t * Returns a copy — mutating the returned array does not affect the registry.\n57\t */\n58\texport function listDrivers(): string[] {\n59\t  return [...registry.keys()];\n60\t}\n61\t\n62\t/**\n63\t * Clear all registered drivers. Exported for test isolation.\n64\t */\n65\texport function resetDrivers(): void {\n66\t  registry.clear();\n67\t}\n68\t"}]},"parent_tool_use_id":"toolu_017Urm7EPd5KhakJiz43kv21","session_id":"61d40628-eabe-45b5-b544-2f5989944a22","uuid":"12e21e99-f905-477e-b847-c63f759e2449","timestamp":"2026-04-03T06:47:08.586Z"}
