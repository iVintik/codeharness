EvaluatorVerdict {\n44\t  verdict: 'pass' | 'fail';\n45\t  score: {\n46\t    passed: number;\n47\t    failed: number;\n48\t    unknown: number;\n49\t    total: number;\n50\t  };\n51\t  findings: Array<{\n52\t    ac: number;\n53\t    description: string;\n54\t    status: 'pass' | 'fail' | 'unknown';\n55\t    evidence: {\n56\t      commands_run: string[];\n57\t      output_observed: string;\n58\t      reasoning: string;\n59\t    };\n60\t  }>;\n61\t  evaluator_trace_id?: string;\n62\t  duration_seconds?: number;\n63\t}\n64\t\n65\t/**\n66\t * Result returned by executeWorkflow().\n67\t */\n68\texport interface EngineResult {\n69\t  /** Whether the workflow completed without errors. */\n70\t  success: boolean;\n71\t  /** Number of task dispatches completed. */\n72\t  tasksCompleted: number;\n73\t  /** Number of work items (stories/issues) processed. */\n74\t  storiesProcessed: number;\n75\t  /** Errors encountered during execution. */\n76\t  errors: EngineError[];\n77\t  /** Wall-clock duration of the entire workflow in milliseconds. */\n78\t  durationMs: number;\n79\t}\n80\t"}]},"parent_tool_use_id":"toolu_011M8ZBuds1zdWKjWaZPai8m","session_id":"452c48b4-eed2-4c96-83e9-8c71df0bbdac","uuid":"29a7a039-47fd-44ff-91a5-629e60f97adc","timestamp":"2026-04-02T23:13:34.219Z"}
