{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SCUtdiNcvn7pb6yX8dztKE","type":"tool_result","content":"1\timport type { SubagentDefinition } from './agent-resolver.js';\n2\timport type { DispatchResult } from './agent-dispatch.js';\n3\timport { dispatchAgent } from './agent-dispatch.js';\n4\timport { createIsolatedWorkspace } from './source-isolation.js';\n5\timport type { IsolatedWorkspace } from './source-isolation.js';\n6\timport { isDockerAvailable } from './docker/index.js';\n7\timport { formatTracePrompt } from './trace-id.js';\n8\t\n9\t// --- Interfaces ---\n10\t\n11\t/**\n12\t * Options for running the blind evaluator.\n13\t */\n14\texport interface EvaluatorOptions {\n15\t  /** Unique run identifier — used in workspace path and tracing. */\n16\t  runId: string;\n17\t  /** Absolute paths to story files containing acceptance criteria. */\n18\t  storyFiles: string[];\n19\t  /** Pre-compiled subagent definition for the evaluator agent. */\n20\t  agentDefinition: SubagentDefinition;\n21\t  /** Timeout in milliseconds for the evaluator dispatch. Default: 300000 (5 minutes). */\n22\t  timeoutMs?: number;\n23\t  /** Optional trace ID for correlation in logs/metrics. */\n24\t  traceId?: string;\n25\t}\n26\t\n27\t/**\n28\t * Result of an evaluator run.\n29\t */\n30\texport interface EvaluatorResult {\n31\t  /** Raw agent output (or synthesized JSON for fallback cases). */\n32\t  output: string;\n33\t  /** Whether the evaluator completed successfully. */\n34\t  success: boolean;\n35\t  /** Wall-clock duration of the evaluator run in milliseconds. */\n36\t  durationMs: number;\n37\t  /** Whether Docker was available at the time of the run. */\n38\t  dockerAvailable: boolean;\n39\t  /** Whether the evaluator timed out. */\n40\t  timedOut: boolean;\n41\t}\n42\t\n43\t// --- Constants ---\n44\t\n45\tconst DEFAULT_TIMEOUT_MS = 300_000; // 5 minutes\n46\t\n47\t/**\n48\t * Build the evaluator dispatch prompt from the compiled agent definition instructions.\n49\t * The compiled SubagentDefinition.instructions already contain the prompt_template\n50\t * from evaluator.yaml (appended by compileSubagentDefinition). This function adds\n51\t * the minimal task-kick context that varies per dispatch — story file location and\n52\t * output directory. The full anti-leniency prompt, evidence requirements, and output\n53\t * format are in the instructions (system prompt), not duplicated here.\n54\t */\n55\tfunction buildEvaluatorPrompt(): string {\n56\t  const parts: string[] = [];\n57\t\n58\t  parts.push('Verify the acceptance criteria for this story.');\n59\t  parts.push('Story files are available in ./story-files/. Read each file to find the ACs.');\n60\t  parts.push('Write your verdict JSON output to ./verdict/verdict.json.');\n61\t\n62\t  return parts.join('\\n');\n63\t}\n64\t\n65\t// --- Helpers ---\n66\t\n67\t/**\n68\t * Build a fallback output JSON string with all ACs scored UNKNOWN.\n69\t */\n70\tfunction buildUnknownOutput(storyFiles: string[], reasoning: string): string {\n71\t  // We don't know how many ACs each story file has, so we produce\n72\t  // a single finding per story file with status unknown.\n73\t  const findings = storyFiles.map((_, index) => ({\n74\t    ac: index + 1,\n75\t    description: `AC #${index + 1}`,\n76\t    status: 'unknown' as const,\n77\t    evidence: {\n78\t      commands_run: [],\n79\t      output_observed: '',\n80\t      reasoning,\n81\t    },\n82\t  }));\n83\t\n84\t  return JSON.stringify({\n85\t    verdict: 'fail',\n86\t    score: {\n87\t      passed: 0,\n88\t      failed: 0,\n89\t      unknown: findings.length,\n90\t      total: findings.length,\n91\t    },\n92\t    findings,\n93\t  });\n94\t}\n95\t\n96\t// --- Main Function ---\n97\t\n98\t/**\n99\t * Run the blind evaluator lifecycle:\n100\t *   1. Check Docker availability\n101\t *   2. Create isolated workspace\n102\t *   3. Dispatch evaluator agent (with timeout)\n103\t *   4. Collect result\n104\t *   5. Cleanup workspace\n105\t *\n106\t * Returns raw output for downstream parsing (story 6-2).\n107\t * Does NOT throw on Docker unavailability or timeout — returns graceful UNKNOWN results.\n108\t */\n109\texport async function runEvaluator(options: EvaluatorOptions): Promise<EvaluatorResult> {\n110\t  const startMs = Date.now();\n111\t  const timeoutMs = options.timeoutMs ?? DEFAULT_TIMEOUT_MS;\n112\t\n113\t  // Step 1: Check Docker availability\n114\t  const dockerAvailable = isDockerAvailable();\n115\t  if (!dockerAvailable) {\n116\t    return {\n117\t      output: buildUnknownOutput(\n118\t        options.storyFiles,\n119\t        'Docker is not available — cannot run verification commands.',\n120\t      ),\n121\t      success: false,\n122\t      durationMs: Date.now() - startMs,\n123\t      dockerAvailable: false,\n124\t      timedOut: false,\n125\t    };\n126\t  }\n127\t\n128\t  // Step 2: Create isolated workspace\n129\t  let workspace: IsolatedWorkspace | undefined;\n130\t  try {\n131\t    workspace = await createIsolatedWorkspace({\n132\t      runId: options.runId,\n133\t      storyFiles: options.storyFiles,\n134\t    });\n135\t\n136\t    // Step 3: Build dispatch options\n137\t    const dispatchOptions = workspace.toDispatchOptions();\n138\t    if (options.traceId) {\n139\t      dispatchOptions.appendSystemPrompt = formatTracePrompt(options.traceId);\n140\t    }\n141\t\n142\t    // Step 4: Race dispatch against timeout\n143\t    const evaluatorPrompt = buildEvaluatorPrompt();\n144\t    const dispatchPromise = dispatchAgent(\n145\t      options.agentDefinition,\n146\t      evaluatorPrompt,\n147\t      dispatchOptions,\n148\t    );\n149\t\n150\t    let timeoutTimer: ReturnType<typeof setTimeout> | undefined;\n151\t    const timeoutPromise = new Promise<never>((_, reject) => {\n152\t      timeoutTimer = setTimeout(() => reject(new Error('Evaluator timeout')), timeoutMs);\n153\t    });\n154\t\n155\t    let result: DispatchResult;\n156\t    try {\n157\t      result = await Promise.race([dispatchPromise, timeoutPromise]);\n158\t    } catch (err: unknown) {\n159\t      const message = err instanceof Error ? err.message : String(err);\n160\t      if (message === 'Evaluator timeout') {\n161\t        return {\n162\t          output: buildUnknownOutput(\n163\t            options.storyFiles,\n164\t            `Evaluator timed out after ${timeoutMs}ms.`,\n165\t          ),\n166\t          success: false,\n167\t          durationMs: Date.now() - startMs,\n168\t          dockerAvailable: true,\n169\t          timedOut: true,\n170\t        };\n171\t      }\n172\t      // Re-throw non-timeout errors\n173\t      throw err;\n174\t    } finally {\n175\t      // Clear the timeout timer to prevent Node.js process from hanging\n176\t      if (timeoutTimer) {\n177\t        clearTimeout(timeoutTimer);\n178\t      }\n179\t    }\n180\t\n181\t    return {\n182\t      output: result.output,\n183\t      success: result.success,\n184\t      durationMs: Date.now() - startMs,\n185\t      dockerAvailable: true,\n186\t      timedOut: false,\n187\t    };\n188\t  } finally {\n189\t    // Step 5: Cleanup workspace (always)\n190\t    if (workspace) {\n191\t      await workspace.cleanup();\n192\t    }\n193\t  }\n194\t}\n195\t"}]},"parent_tool_use_id":"toolu_01Kwq1jWkHGueReqZtY8JQZo","session_id":"0dddd908-79fb-4621-81f1-f9e1a3ee8324","uuid":"dbd098ec-583d-41f2-af5b-688ee0a72ec8","timestamp":"2026-04-03T00:56:45.728Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DC4Lu8TFPRueyP3sokiYr5","type":"tool_result","content":"1\timport { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n2\timport { join } from 'node:path';\n3\timport { parse, stringify } from 'yaml';\n4\timport { warn } from './output.js';\n5\t\n6\t// --- Interfaces ---\n7\t\n8\texport interface TaskCheckpoint {\n9\t  task_name: string;\n10\t  story_key: string;\n11\t  completed_at: string;\n12\t  session_id?: string;\n13\t  /** When present, indicates this checkpoint records a failed dispatch (not a success). */\n14\t  error?: boolean;\n15\t}\n16\t\n17\texport interface EvaluatorScore {\n18\t  iteration: number;\n19\t  passed: number;\n20\t  failed: number;\n21\t  unknown: number;\n22\t  total: number;\n23\t  timestamp: string;\n24\t}\n25\t\n26\texport interface CircuitBreakerState {\n27\t  triggered: boolean;\n28\t  reason: string | null;\n29\t  score_history: number[];\n30\t}\n31\t\n32\texport interface WorkflowState {\n33\t  workflow_name: string;\n34\t  started: string;\n35\t  iteration: number;\n36\t  phase: string;\n37\t  tasks_completed: TaskCheckpoint[];\n38\t  evaluator_scores: EvaluatorScore[];\n39\t  circuit_breaker: CircuitBreakerState;\n40\t  trace_ids?: string[];\n41\t}\n42\t\n43\t// --- Constants ---\n44\t\n45\tconst STATE_DIR = '.codeharness';\n46\tconst STATE_FILE = 'workflow-state.yaml';\n47\t\n48\t// --- Functions ---\n49\t\n50\texport function getDefaultWorkflowState(): WorkflowState {\n51\t  return {\n52\t    workflow_name: '',\n53\t    started: '',\n54\t    iteration: 0,\n55\t    phase: 'idle',\n56\t    tasks_completed: [],\n57\t    evaluator_scores: [],\n58\t    circuit_breaker: {\n59\t      triggered: false,\n60\t      reason: null,\n61\t      score_history: [],\n62\t    },\n63\t    trace_ids: [],\n64\t  };\n65\t}\n66\t\n67\texport function writeWorkflowState(state: WorkflowState, dir?: string): void {\n68\t  const baseDir = dir ?? process.cwd();\n69\t  const stateDir = join(baseDir, STATE_DIR);\n70\t  mkdirSync(stateDir, { recursive: true });\n71\t  const yamlContent = stringify(state, { nullStr: 'null' });\n72\t  writeFileSync(join(stateDir, STATE_FILE), yamlContent, 'utf-8');\n73\t}\n74\t\n75\texport function readWorkflowState(dir?: string): WorkflowState {\n76\t  const baseDir = dir ?? process.cwd();\n77\t  const filePath = join(baseDir, STATE_DIR, STATE_FILE);\n78\t\n79\t  if (!existsSync(filePath)) {\n80\t    return getDefaultWorkflowState();\n81\t  }\n82\t\n83\t  let raw: string;\n84\t  try {\n85\t    raw = readFileSync(filePath, 'utf-8');\n86\t  } catch { // IGNORE: unreadable file (permissions, EISDIR, etc.) — recover with defaults\n87\t    warn('workflow-state.yaml could not be read — returning default state');\n88\t    return getDefaultWorkflowState();\n89\t  }\n90\t\n91\t  let parsed: unknown;\n92\t  try {\n93\t    parsed = parse(raw);\n94\t  } catch { // IGNORE: corrupted YAML — recover with defaults\n95\t    warn('workflow-state.yaml contains invalid YAML — returning default state');\n96\t    return getDefaultWorkflowState();\n97\t  }\n98\t\n99\t  if (!isValidWorkflowState(parsed)) {\n100\t    warn('workflow-state.yaml has invalid shape — returning default state');\n101\t    return getDefaultWorkflowState();\n102\t  }\n103\t\n104\t  return parsed;\n105\t}\n106\t\n107\t// --- Validation ---\n108\t\n109\tfunction isValidWorkflowState(value: unknown): value is WorkflowState {\n110\t  if (!value || typeof value !== 'object') return false;\n111\t  const s = value as Record<string, unknown>;\n112\t\n113\t  if (typeof s.workflow_name !== 'string') return false;\n114\t  if (typeof s.started !== 'string') return false;\n115\t  if (typeof s.iteration !== 'number') return false;\n116\t  if (typeof s.phase !== 'string') return false;\n117\t  if (!Array.isArray(s.tasks_completed)) return false;\n118\t  if (!Array.isArray(s.evaluator_scores)) return false;\n119\t  if (!s.circuit_breaker || typeof s.circuit_breaker !== 'object') return false;\n120\t\n121\t  // Validate trace_ids (optional array of strings)\n122\t  if (s.trace_ids !== undefined) {\n123\t    if (!Array.isArray(s.trace_ids)) return false;\n124\t    for (const id of s.trace_ids) {\n125\t      if (typeof id !== 'string') return false;\n126\t    }\n127\t  }\n128\t\n129\t  // Validate tasks_completed element shapes\n130\t  for (const t of s.tasks_completed) {\n131\t    if (!t || typeof t !== 'object') return false;\n132\t    const tc = t as Record<string, unknown>;\n133\t    if (typeof tc.task_name !== 'string') return false;\n134\t    if (typeof tc.story_key !== 'string') return false;\n135\t    if (typeof tc.completed_at !== 'string') return false;\n136\t    if (tc.session_id !== undefined && typeof tc.session_id !== 'string') return false;\n137\t    if (tc.error !== undefined && typeof tc.error !== 'boolean') return false;\n138\t  }\n139\t\n140\t  // Validate evaluator_scores element shapes\n141\t  for (const e of s.evaluator_scores) {\n142\t    if (!e || typeof e !== 'object') return false;\n143\t    const es = e as Record<string, unknown>;\n144\t    if (typeof es.iteration !== 'number') return false;\n145\t    if (typeof es.passed !== 'number') return false;\n146\t    if (typeof es.failed !== 'number') return false;\n147\t    if (typeof es.unknown !== 'number') return false;\n148\t    if (typeof es.total !== 'number') return false;\n149\t    if (typeof es.timestamp !== 'string') return false;\n150\t  }\n151\t\n152\t  const cb = s.circuit_breaker as Record<string, unknown>;\n153\t  if (typeof cb.triggered !== 'boolean') return false;\n154\t  if (cb.reason !== null && typeof cb.reason !== 'string') return false;\n155\t  if (!Array.isArray(cb.score_history)) return false;\n156\t\n157\t  // Validate score_history elements are numbers\n158\t  for (const score of cb.score_history) {\n159\t    if (typeof score !== 'number') return false;\n160\t  }\n161\t\n162\t  return true;\n163\t}\n164\t"}]},"parent_tool_use_id":"toolu_01Kwq1jWkHGueReqZtY8JQZo","session_id":"0dddd908-79fb-4621-81f1-f9e1a3ee8324","uuid":"9c804950-5510-4f68-942a-a1f875f92458","timestamp":"2026-04-03T00:56:45.730Z"}
