{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01K1i6ZBXqtAHfbCZxNs58Mc","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→\n     3→vi.mock('node:child_process', () => ({\n     4→  execFileSync: vi.fn(),\n     5→}));\n     6→\n     7→import { execFileSync } from 'node:child_process';\n     8→import {\n     9→  checkInstalled,\n    10→  installDependency,\n    11→  installAllDependencies,\n    12→  parseVersion,\n    13→  CriticalDependencyError,\n    14→  DEPENDENCY_REGISTRY,\n    15→} from '../deps.js';\n    16→import type { DependencySpec } from '../deps.js';\n    17→\n    18→const mockExecFileSync = vi.mocked(execFileSync);\n    19→\n    20→beforeEach(() => {\n    21→  vi.restoreAllMocks();\n    22→  // Suppress console output during tests\n    23→  vi.spyOn(console, 'log').mockImplementation(() => {});\n    24→});\n    25→\n    26→describe('parseVersion', () => {\n    27→  it('extracts version from simple output', () => {\n    28→    expect(parseVersion('1.2.3')).toBe('1.2.3');\n    29→  });\n    30→\n    31→  it('extracts version from \"tool v1.2.3\" format', () => {\n    32→    expect(parseVersion('showboat v0.6.1')).toBe('0.6.1');\n    33→  });\n    34→\n    35→  it('extracts version from \"tool version 1.2.3\" format', () => {\n    36→    expect(parseVersion('bd version 2.0.0-beta.1')).toBe('2.0.0-beta.1');\n    37→  });\n    38→\n    39→  it('returns null when no version found', () => {\n    40→    expect(parseVersion('no version here')).toBeNull();\n    41→  });\n    42→\n    43→  it('returns null for empty string', () => {\n    44→    expect(parseVersion('')).toBeNull();\n    45→  });\n    46→});\n    47→\n    48→describe('checkInstalled', () => {\n    49→  const spec: DependencySpec = {\n    50→    name: 'test-tool',\n    51→    displayName: 'TestTool',\n    52→    installCommands: [{ cmd: 'pip', args: ['install', 'test-tool'] }],\n    53→    checkCommand: { cmd: 'test-tool', args: ['--version'] },\n    54→    critical: false,\n    55→  };\n    56→\n    57→  it('returns installed=true with version when command succeeds', () => {\n    58→    mockExecFileSync.mockReturnValue(Buffer.from('test-tool 1.0.0'));\n    59→    const result = checkInstalled(spec);\n    60→    expect(result.installed).toBe(true);\n    61→    expect(result.version).toBe('1.0.0');\n    62→    expect(mockExecFileSync).toHaveBeenCalledWith('test-tool', ['--version'], { stdio: 'pipe', timeout: 15_000 });\n    63→  });\n    64→\n    65→  it('returns installed=false when command fails', () => {\n    66→    mockExecFileSync.mockImplementation(() => {\n    67→      throw new Error('command not found');\n    68→    });\n    69→    const result = checkInstalled(spec);\n    70→    expect(result.installed).toBe(false);\n    71→    expect(result.version).toBeNull();\n    72→  });\n    73→\n    74→  it('returns installed=true with null version when output has no version', () => {\n    75→    mockExecFileSync.mockReturnValue(Buffer.from('some output without version'));\n    76→    const result = checkInstalled(spec);\n    77→    expect(result.installed).toBe(true);\n    78→    expect(result.version).toBeNull();\n    79→  });\n    80→});\n    81→\n    82→describe('installDependency', () => {\n    83→  const nonCriticalSpec: DependencySpec = {\n    84→    name: 'showboat',\n    85→    displayName: 'Showboat',\n    86→    installCommands: [\n    87→      { cmd: 'pip', args: ['install', 'showboat'] },\n    88→      { cmd: 'pipx', args: ['install', 'showboat'] },\n    89→    ],\n    90→    checkCommand: { cmd: 'showboat', args: ['--version'] },\n    91→    critical: false,\n    92→  };\n    93→\n    94→  it('returns already-installed when tool is already present', () => {\n    95→    mockExecFileSync.mockReturnValue(Buffer.from('showboat 0.6.1'));\n    96→    const result = installDependency(nonCriticalSpec);\n    97→    expect(result.status).toBe('already-installed');\n    98→    expect(result.version).toBe('0.6.1');\n    99→  });\n   100→\n   101→  it('installs via primary command and returns installed', () => {\n   102→    let checkCount = 0;\n   103→    mockExecFileSync.mockImplementation((cmd) => {\n   104→      const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   105→      // Version check: first fails, then succeeds\n   106→      if (cmdStr === 'showboat') {\n   107→        checkCount++;\n   108→        if (checkCount === 1) throw new Error('not found');\n   109→        return Buffer.from('showboat 0.6.1');\n   110→      }\n   111→      // Install command succeeds\n   112→      return Buffer.from('');\n   113→    });\n   114→\n   115→    const result = installDependency(nonCriticalSpec);\n   116→    expect(result.status).toBe('installed');\n   117→    expect(result.version).toBe('0.6.1');\n   118→  });\n   119→\n   120→  it('falls back to secondary command when primary fails', () => {\n   121→    let checkCount = 0;\n   122→    mockExecFileSync.mockImplementation((cmd) => {\n   123→      const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   124→      if (cmdStr === 'showboat') {\n   125→        checkCount++;\n   126→        if (checkCount === 1) throw new Error('not found');\n   127→        return Buffer.from('showboat 0.6.1');\n   128→      }\n   129→      if (cmdStr === 'pip') throw new Error('pip not found');\n   130→      // pipx install succeeds\n   131→      return Buffer.from('');\n   132→    });\n   133→\n   134→    const result = installDependency(nonCriticalSpec);\n   135→    expect(result.status).toBe('installed');\n   136→    expect(result.version).toBe('0.6.1');\n   137→  });\n   138→\n   139→  it('returns failed when all install commands fail', () => {\n   140→    mockExecFileSync.mockImplementation(() => {\n   141→      throw new Error('command failed');\n   142→    });\n   143→\n   144→    const result = installDependency(nonCriticalSpec);\n   145→    expect(result.status).toBe('failed');\n 