{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01F4rrZgHPbPCXu8bTtQapcm","type":"tool_result","content":"1\t/**\n2\t * Sprint state types matching architecture decision 2: Unified State Format.\n3\t */\n4\t\n5\t/** All possible story statuses */\n6\texport type StoryStatus =\n7\t  | 'backlog'\n8\t  | 'ready'\n9\t  | 'in-progress'\n10\t  | 'review'\n11\t  | 'verifying'\n12\t  | 'done'\n13\t  | 'failed'\n14\t  | 'blocked';\n15\t\n16\t/** Verdict for a single acceptance criterion check */\n17\texport type AcVerdict = 'pass' | 'fail' | 'escalate' | 'pending';\n18\t\n19\t/** Result of checking one acceptance criterion */\n20\texport interface AcResult {\n21\t  readonly id: string;\n22\t  readonly verdict: AcVerdict;\n23\t}\n24\t\n25\t/** State of an individual story */\n26\texport interface StoryState {\n27\t  readonly status: StoryStatus;\n28\t  readonly attempts: number;\n29\t  readonly lastAttempt: string | null;\n30\t  readonly lastError: string | null;\n31\t  readonly proofPath: string | null;\n32\t  readonly acResults: AcResult[] | null;\n33\t}\n34\t\n35\t/** Source of an action item */\n36\texport type ActionItemSource = 'verification' | 'retro' | 'manual';\n37\t\n38\t/** An action item tracked across sprints */\n39\texport interface ActionItem {\n40\t  readonly id: string;\n41\t  readonly story: string;\n42\t  readonly description: string;\n43\t  readonly source: ActionItemSource;\n44\t  readonly resolved: boolean;\n45\t}\n46\t\n47\t/** State of an epic within the sprint */\n48\texport interface EpicState {\n49\t  readonly status: string;\n50\t  readonly storiesTotal: number;\n51\t  readonly storiesDone: number;\n52\t}\n53\t\n54\t/** Session runtime state */\n55\texport interface SessionState {\n56\t  readonly active: boolean;\n57\t  readonly startedAt: string | null;\n58\t  readonly iteration: number;\n59\t  readonly elapsedSeconds: number;\n60\t}"}]},"parent_tool_use_id":"toolu_01KrDuJXvL9iMGiH4fKqNTEw","session_id":"1e0d780f-040f-4c10-b8e5-df49ae6fae2c","uuid":"4e063541-f25d-4025-ab81-4cd147504c5f","timestamp":"2026-04-03T20:57:47.463Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016yBE7BjKMkzm8K2nj6VDVm","type":"tool_result","content":"1\timport type { ResolvedTask, FlowStep, LoopBlock } from './workflow-parser.js';\n2\t\n3\t// --- Interfaces ---\n4\t\n5\texport interface ExecutionConfig {\n6\t  max_parallel: number;\n7\t  isolation: 'worktree' | 'none';\n8\t  merge_strategy: 'rebase' | 'merge-commit';\n9\t  epic_strategy: 'parallel' | 'sequential';\n10\t  story_strategy: 'sequential' | 'parallel';\n11\t}\n12\t\n13\texport interface HierarchicalFlow {\n14\t  execution: ExecutionConfig;\n15\t  storyFlow: FlowStep[];\n16\t  epicFlow: FlowStep[];\n17\t  tasks: Record<string, ResolvedTask>;\n18\t}\n19\t\n20\t// --- Constants ---\n21\t\n22\t/** Built-in epic flow task names that do not need entries in `tasks:`. */\n23\texport const BUILTIN_EPIC_FLOW_TASKS = new Set(['merge', 'validate']);\n24\t\n25\t/** Default execution configuration values. */\n26\texport const EXECUTION_DEFAULTS: ExecutionConfig = {\n27\t  max_parallel: 1,\n28\t  isolation: 'none',\n29\t  merge_strategy: 'merge-commit',\n30\t  epic_strategy: 'sequential',\n31\t  story_strategy: 'sequential',\n32\t};\n33\t\n34\t/** Valid enum values for execution config fields. */\n35\tconst VALID_ISOLATION = new Set<string>(['worktree', 'none']);\n36\tconst VALID_MERGE_STRATEGY = new Set<string>(['rebase', 'merge-commit']);\n37\tconst VALID_EPIC_STRATEGY = new Set<string>(['parallel', 'sequential']);\n38\tconst VALID_STORY_STRATEGY = new Set<string>(['sequential', 'parallel']);\n39\t\n40\t// --- Resolution ---\n41\t\n42\t/**\n43\t * Resolve a parsed workflow YAML object into a HierarchicalFlow.\n44\t *\n45\t * Handles three cases:\n46\t * 1. Legacy: only `flow` present → normalized to `storyFlow`\n47\t * 2. Hierarchical: `story_flow` (and optionally `epic_flow`, `execution`) present\n48\t * 3. Conflict: both `flow` and `story_flow` → rejected with error\n49\t *\n50\t * This is a pure parsing/normalization function with no side effects."}]},"parent_tool_use_id":"toolu_01KrDuJXvL9iMGiH4fKqNTEw","session_id":"1e0d780f-040f-4c10-b8e5-df49ae6fae2c","uuid":"db4cb2e7-1311-4073-a108-7388a9b9de35","timestamp":"2026-04-03T20:57:47.465Z"}
