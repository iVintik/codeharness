{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CyUTEvwBHAwLqQPxCktgHC","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { render } from 'ink-testing-library';\n3\timport React from 'react';\n4\timport { ActiveTool, CompletedTool, DriverCostSummary } from '../ink-activity-components.js';\n5\timport type { CompletedToolEntry } from '../ink-components.js';\n6\t\n7\t// --- ActiveTool tests ---\n8\t\n9\tdescribe('ActiveTool component', () => {\n10\t  it('renders driver name when provided', () => {\n11\t    const { lastFrame } = render(<ActiveTool name=\"Bash\" driverName=\"claude-code\" />);\n12\t    const frame = lastFrame()!;\n13\t    expect(frame).toContain('Bash');\n14\t    expect(frame).toContain('(claude-code)');\n15\t  });\n16\t\n17\t  it('renders without driver name (backward compat)', () => {\n18\t    const { lastFrame } = render(<ActiveTool name=\"Bash\" />);\n19\t    const frame = lastFrame()!;\n20\t    expect(frame).toContain('Bash');\n21\t    expect(frame).not.toContain('(');\n22\t  });\n23\t\n24\t  it('renders without driver name when null', () => {\n25\t    const { lastFrame } = render(<ActiveTool name=\"Read\" driverName={null} />);\n26\t    const frame = lastFrame()!;\n27\t    expect(frame).toContain('Read');\n28\t    expect(frame).not.toContain('(');\n29\t  });\n30\t});"}]},"parent_tool_use_id":"toolu_018yuUCTksy6z1zXKFgN7iGd","session_id":"0c112080-0896-4e32-96a0-f82adec16922","uuid":"9830d3b2-52ea-4d13-955e-d4a819f21ce6","timestamp":"2026-04-04T02:19:30.324Z"}
