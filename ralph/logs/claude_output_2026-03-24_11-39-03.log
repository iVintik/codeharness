{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019ZA54RZZsPVD4tdCTyY6F4","type":"tool_result","content":"     1→/**\n     2→ * Stack provider registry — stores registered providers and provides\n     3→ * marker-based stack detection (replacing hardcoded checks).\n     4→ */\n     5→\n     6→import { existsSync, readdirSync } from 'node:fs';\n     7→import { join } from 'node:path';\n     8→import type { StackName, StackProvider } from './types.js';\n     9→\n    10→/** Internal registry map. */\n    11→const providers = new Map<StackName, StackProvider>();\n    12→\n    13→/** Directories to skip during subdirectory scanning. */\n    14→const SKIP_DIRS = new Set([\n    15→  'node_modules',\n    16→  '.git',\n    17→  'target',\n    18→  '__pycache__',\n    19→  'dist',\n    20→  'build',\n    21→  'coverage',\n    22→  '.venv',\n    23→  'venv',\n    24→  '.tox',\n    25→  '.mypy_cache',\n    26→  '.cache',\n    27→]);\n    28→\n    29→/**\n    30→ * Priority order for stack detection.\n    31→ * When multiple stacks match at the same directory level, they appear in this order.\n    32→ */\n    33→const STACK_PRIORITY: StackName[] = ['nodejs', 'python', 'rust'];\n    34→\n    35→/** Register a StackProvider. Overwrites any existing provider for the same name. */\n    36→export function registerProvider(provider: StackProvider): void {\n    37→  providers.set(provider.name, provider);\n    38→}\n    39→\n    40→/** Retrieve a registered provider by name, or undefined if not registered. */\n    41→export function getStackProvider(name: StackName): StackProvider | undefined {\n    42→  return providers.get(name);\n    43→}\n    44→\n    45→/** Detection result: stack name + directory where it was found. */\n    46→export interface StackDetection {\n    47→  stack: StackName;\n    48→  dir: string;\n    49→}\n    50→\n    51→/**\n    52→ * Detect all stacks present in a directory using registered provider markers.\n    53→ * Checks root and one level of subdirectories.\n    54→ * Root stacks appear first (in priority order), then subdirectory stacks sorted alphabetically.\n    55→ */\n    56→export function detectStacks(dir: string = process.cwd()): StackDetection[] {\n    57→  const results: StackDetection[] = [];\n    58→\n    59→  // Build ordered list of providers by priority\n    60→  const ordered = getOrderedProviders();\n    61→\n    62→  // Root scan\n    63→  for (const provider of ordered) {\n    64→    if (hasMarker(dir, provider.markers)) {\n    65→      results.push({ stack: provider.name, dir: '.' });\n    66→    }\n    67→  }\n    68→\n    69→  // Subdirectory scan — one level deep\n    70→  let entries: import('node:fs').Dirent[];\n    71→  try {\n    72→    entries = readdirSync(dir, { withFileTypes: true });\n    73→  } catch (_err: unknown) {\n    74→    // Non-existent or unreadable directory — treat as empty (no subdirectories to scan)\n    75→    entries = [];\n    76→  }\n    77→\n    78→  const subdirs = entries\n    79→    .filter((e) => e.isDirectory() && !SKIP_DIRS.has(e.name))\n    80→    .map((e) => e.name)\n    81→    .sort();\n    82→\n    83→  for (const subdir of subdirs) {\n    84→    const subdirPath = join(dir, subdir);\n    85→    for (const provider of ordered) {\n    86→      if (hasMarker(subdirPath, provider.markers)) {\n    87→        results.push({ stack: provider.name, dir: subdir });\n    88→      }\n    89→    }\n    90→  }\n    91→\n    92→  return results;\n    93→}\n    94→\n    95→/**\n    96→ * Compat wrapper: returns the first detected ROOT stack name, or null.\n    97→ * Only considers root-level markers (dir === '.'), never subdirectory detections.\n    98→ */\n    99→export function detectStack(dir: string = process.cwd()): StackName | null {\n   100→  const stacks = detectStacks(dir);\n   101→  const rootStack = stacks.find((s) => s.dir === '.');\n   102→  return rootStack ? rootStack.stack : null;\n   103→}\n   104→\n   105→/** Check if any of the marker files exist in the given directory. */\n   106→function hasMarker(dir: string, markers: string[]): boolean {\n   107→  return markers.some((marker) => existsSync(join(dir, marker)));\n   108→}\n   109→\n   110→/** Return providers ordered by STACK_PRIORITY, then any extras at the end. */\n   111→function getOrderedProviders(): StackProvider[] {\n   112→  const ordered: StackProvider[] = [];\n   113→  for (const name of STACK_PRIORITY) {\n   114→    const p = providers.get(name);\n   115→    if (p) ordered.push(p);\n   116→  }\n   117→  // Add any providers not in the priority list\n   118→  for (const [name, provider] of providers) {\n   119→    if (!STACK_PRIORITY.includes(name)) {\n   120→      ordered.push(provider);\n   121→    }\n   122→  }\n   123→  return ordered;\n   124→}\n   125→\n   126→/**\n   127→ * Reset the registry (for testing only).\n   128→ * @internal\n   129→ */\n   130→export function _resetRegistry(): void {\n   131→  providers.clear();\n   132→}\n   133→"}]},"parent_tool_use_id":null,"session_id":"31f79ff4-68ea-4b44-861b-4091a0c239f5","uuid":"15610f0b-7964-4d38-acaa-25716ae8128c","timestamp":"2026-03-24T07:50:06.346Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ivintik/dev/personal/codeharness/src/lib/stacks/registry.ts","content":"/**\n * Stack provider registry — stores registered providers and provides\n * marker-based stack detection (replacing hardcoded checks).\n */\n\nimport { existsSync, readdirSync } from 'node:fs';\nimport { join } from 'node:path';\nimport type { StackName, StackProvider } from './types.js';\n\n/** Internal registry map. */\nconst providers = new Map<StackName, StackProvider>();\n\n/** Directories to skip during subdirectory scanning. */\nconst SKIP_DIRS = new Set([\n  'node_modules',\n  '.git',\n  'target',\n  '__pycache__',\n  'dist',\n  'build',\n  'coverage',\n  '.venv',\n  'venv',\n  '.tox',\n  '.mypy_cache',\n  '.cache',\n]);\n\n/**\n * Priority order for stack detection.\n * When multiple stacks match at the same directory level, they appear in this order.\n */\nconst STACK_PRIORITY: StackName[] = ['nodejs', 'python', 'rust'];\n\n/** Register a StackProvider. Overwrites any existing provider for the same name. */\nexport function registerProvider(provider: StackProvider): void {\n  providers.set(provider.name, provider);\n}\n\n/** Retrieve a registered provider by name, or undefined if not registered. */\nexport function getStackProvider(name: StackName): StackProvider | undefined {\n  return providers.get(name);\n}\n\n/** Detection result: stack name + directory where it was found. */\nexport interface StackDetection {\n  stack: StackName;\n  dir: string;\n}\n\n/**\n * Detect all stacks present in a directory using registered provider markers.\n * Checks root and one level of subdirectories.\n * Root stacks appear first (in priority order), then subdirectory stacks sorted alphabetically.\n */\nexport function detectStacks(dir: string = process.cwd()): StackDetection[] {\n  const results: StackDetection[] = [];\n\n  // Build ordered list of providers by priority\n  const ordered = getOrderedProviders();\n\n  // Root scan\n  for (const provider of ordered) {\n    if (hasMarker(dir, provider.markers)) {\n      results.push({ stack: provider.name, dir: '.' });\n    }\n  }\n\n  // Subdirectory scan — one level deep\n  let entries: import('node:fs').Dirent[];\n  try {\n    entries = readdirSync(dir, { withFileTypes: true });\n  } catch (_err: unknown) {\n    // Non-existent or unreadable directory — treat as empty (no subdirectories to scan)\n    entries = [];\n  }\n\n  const subdirs = entries\n    .filter((e) => e.isDirectory() && !SKIP_DIRS.has(e.name))\n    .map((e) => e.name)\n    .sort();\n\n  for (const subdir of subdirs) {\n    const subdirPath = join(dir, subdir);\n    for (const provider of ordered) {\n      if (hasMarker(subdirPath, provider.markers)) {\n        results.push({ stack: provider.name, dir: subdir });\n      }\n    }\n  }\n\n  return results;\n}\n\n/**\n * Compat wrapper: returns the first detected ROOT stack name, or null.\n * Only considers root-level markers (dir === '.'), never subdirectory detections.\n */\nexport function detectStack(dir: string = process.cwd()): StackName | null {\n  const stacks = detectStacks(dir);\n  const rootStack = stacks.find((s) => s.dir === '.');\n  return rootStack ? rootStack.stack : null;\n}\n\n/** Check if any of the marker files exist in the given directory. */\nfunction hasMarker(dir: string, markers: string[]): boolean {\n  return markers.some((marker) => existsSync(join(dir, marker)));\n}\n\n/** Return providers ordered by STACK_PRIORITY, then any extras at the end. */\nfunction getOrderedProviders(): StackProvider[] {\n  const ordered: StackProvider[] = [];\n  for (const name of STACK_PRIORITY) {\n    const p = providers.get(name);\n    if (p) ordered.push(p);\n  }\n  // Add any providers not in the priority list\n  for (const [name, provider] of providers) {\n    if (!STACK_PRIORITY.includes(name)) {\n      ordered.push(provider);\n    }\n  }\n  return ordered;\n}\n\n/**\n * Reset the registry (for testing only).\n * @internal\n */\nexport function _resetRegistry(): void {\n  providers.clear();\n}\n","numLines":133,"startLine":1,"totalLines":133}}}
