{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VPnh811D4urd6ZjDXwFmER","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { resolveModel } from '../model-resolver.js';\n3\timport { resolveModel as barrelResolveModel } from '../index.js';\n4\t\n5\tdescribe('agents/model-resolver — resolveModel()', () => {\n6\t  const driver = { defaultModel: 'claude-haiku-3-20250514' };\n7\t\n8\t  // --- 3-level cascade ---\n9\t\n10\t  describe('cascade priority', () => {\n11\t    it('task model takes highest priority (AC #2)', () => {\n12\t      const result = resolveModel(\n13\t        { model: 'claude-opus-4-20250514' },\n14\t        { model: 'claude-sonnet-4-20250514' },\n15\t        { defaultModel: 'claude-haiku-3-20250514' },\n16\t      );\n17\t      expect(result).toBe('claude-opus-4-20250514');\n18\t    });\n19\t\n20\t    it('agent model used when task has no model (AC #3)', () => {\n21\t      const result = resolveModel(\n22\t        {},\n23\t        { model: 'claude-sonnet-4-20250514' },\n24\t        { defaultModel: 'claude-haiku-3-20250514' },\n25\t      );\n26\t      expect(result).toBe('claude-sonnet-4-20250514');\n27\t    });\n28\t\n29\t    it('driver default used when neither task nor agent specify one (AC #4)', () => {\n30\t      const result = resolveModel(\n31\t        {},\n32\t        {},\n33\t        { defaultModel: 'claude-sonnet-4-20250514' },\n34\t      );\n35\t      expect(result).toBe('claude-sonnet-4-20250514');\n36\t    });\n37\t  });\n38\t\n39\t  // --- undefined fields ---\n40\t\n41\t  describe('undefined fields fall through correctly', () => {\n42\t    it('task.model undefined, agent.model undefined → driver default (AC #5)', () => {\n43\t      const result = resolveModel(\n44\t        { model: undefined },\n45\t        { model: undefined },\n46\t        { defaultModel: 'codex-mini' },\n47\t      );\n48\t      expect(result).toBe('codex-mini');\n49\t    });\n50\t\n51\t    it('task.model undefined falls to agent', () => {\n52\t      const result = resolveModel(\n53\t        { model: undefined },\n54\t        { model: 'claude-sonnet-4-20250514' },\n55\t        driver,\n56\t      );\n57\t      expect(result).toBe('claude-sonnet-4-20250514');\n58\t    });\n59\t  });\n60\t\n61\t  // --- null fields ---\n62\t\n63\t  describe('null fields fall through correctly', () => {\n64\t    it('task.model null falls to agent', () => {\n65\t      const result = resolveModel(\n66\t        { model: null },\n67\t        { model: 'claude-sonnet-4-20250514' },\n68\t        driver,\n69\t      );\n70\t      expect(result).toBe('claude-sonnet-4-20250514');\n71\t    });\n72\t\n73\t    it('task.model null and agent.model null falls to driver', () => {\n74\t      const result = resolveModel(\n75\t        { model: null },\n76\t        { model: null },\n77\t        driver,\n78\t      );\n79\t      expect(result).toBe('claude-haiku-3-20250514');\n80\t    });\n81\t  });\n82\t\n83\t  // --- empty string treated as unset ---\n84\t\n85\t  describe('empty string treated as unset', () => {\n86\t    it('empty string at task level falls to agent (AC #6)', () => {\n87\t      const result = resolveModel(\n88\t        { model: '' },\n89\t        { model: 'claude-sonnet-4-20250514' },\n90\t        driver,\n91\t      );\n92\t      expect(result).toBe('claude-sonnet-4-20250514');\n93\t    });\n94\t\n95\t    it('empty string at agent level falls to driver', () => {\n96\t      const result = resolveModel(\n97\t        {},\n98\t        { model: '' },\n99\t        driver,\n100\t      );\n101\t      expect(result).toBe('claude-haiku-3-20250514');\n102\t    });\n103\t\n104\t    it('empty strings at both task and agent levels fall to driver', () => {\n105\t      const result = resolveModel(\n106\t        { model: '' },\n107\t        { model: '' },\n108\t        driver,\n109\t      );\n110\t      expect(result).toBe('claude-haiku-3-20250514');\n111\t    });\n112\t  });\n113\t\n114\t  // --- driver default empty string throws ---\n115\t\n116\t  describe('driver default validation (AC #7)', () => {\n117\t    it('throws when driver.defaultModel is empty string', () => {\n118\t      expect(() => resolveModel({}, {}, { defaultModel: '' })).toThrow(\n119\t        'Driver has no default model',\n120\t      );\n121\t    });\n122\t\n123\t    it('error message is descriptive', () => {\n124\t      expect(() => resolveModel({}, {}, { defaultModel: '' })).toThrow(\n125\t        /driver\\.defaultModel must be a non-empty string/,\n126\t      );\n127\t    });\n128\t\n129\t    it('does NOT throw when task or agent provide a model (even with empty driver)', () => {\n130\t      // The function throws before checking task/agent because driver validation\n131\t      // comes first — this is the only case where resolveModel throws (AC #7).\n132\t      expect(() =>\n133\t        resolveModel({ model: 'x' }, {}, { defaultModel: '' }),\n134\t      ).toThrow('Driver has no default model');\n135\t    });\n136\t  });\n137\t\n138\t  // --- return type ---\n139\t\n140\t  describe('return type', () => {\n141\t    it('always returns a string', () => {\n142\t      const r1 = resolveModel({ model: 'a' }, {}, driver);\n143\t      const r2 = resolveModel({}, { model: 'b' }, driver);\n144\t      const r3 = resolveModel({}, {}, driver);\n145\t      expect(typeof r1).toBe('string');\n146\t      expect(typeof r2).toBe('string');\n147\t      expect(typeof r3).toBe('string');\n148\t    });\n149\t  });\n150\t\n151\t  // --- barrel re-export (AC #8) ---\n152\t\n153\t  describe('barrel re-export', () => {\n154\t    it('resolveModel is re-exported from agents/index.ts', () => {\n155\t      expect(barrelResolveModel).toBe(resolveModel);\n156\t    });\n157\t\n158\t    it('barrel re-export works correctly', () => {\n159\t      const result = barrelResolveModel(\n160\t        { model: 'opus' },\n161\t        { model: 'sonnet' },\n162\t        { defaultModel: 'haiku' },\n163\t      );\n164\t      expect(result).toBe('opus');\n165\t    });\n166\t  });\n167\t});\n168\t"}]},"parent_tool_use_id":"toolu_01LRGwVdnBi8B25YdHRso3f2","session_id":"2c102368-34ec-49f5-8d34-59f136ae42aa","uuid":"d024e6f2-d24e-45a7-93fe-ff45c09d009a","timestamp":"2026-04-03T07:25:18.707Z"}
