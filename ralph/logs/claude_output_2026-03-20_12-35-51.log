{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Myktoeo4eWJTyprHSi9uHT","type":"tool_result","content":"     1→/**\n     2→ * Documentation health scanner.\n     3→ * Checks freshness of AGENTS.md, exec-plans, generated docs.\n     4→ * Manages exec-plan lifecycle (create / complete).\n     5→ *\n     6→ * FR58 (stale doc scanning), FR59 (exec-plan management),\n     7→ * FR60 (doc freshness enforcement).\n     8→ */\n     9→\n    10→import { execSync } from 'node:child_process';\n    11→import {\n    12→  existsSync,\n    13→  mkdirSync,\n    14→  readFileSync,\n    15→  readdirSync,\n    16→  statSync,\n    17→  unlinkSync,\n    18→  writeFileSync,\n    19→} from 'node:fs';\n    20→import { join, relative } from 'node:path';\n    21→import { ok, fail as failFmt, info as infoFmt } from './output.js';\n    22→\n    23→// ─── Types ──────────────────────────────────────────────────────────────────\n    24→\n    25→export interface DocHealthResult {\n    26→  path: string;\n    27→  grade: 'fresh' | 'stale' | 'missing';\n    28→  lastModified: Date | null;\n    29→  codeLastModified: Date | null;\n    30→  reason: string;\n    31→}\n    32→\n    33→export interface DocHealthReport {\n    34→  documents: DocHealthResult[];\n    35→  summary: { fresh: number; stale: number; missing: number; total: number };\n    36→  passed: boolean;\n    37→  scanDurationMs: number;\n    38→}\n    39→\n    40→// ─── Constants ──────────────────────────────────────────────────────────────\n    41→\n    42→const DO_NOT_EDIT_HEADER = '<!-- DO NOT EDIT MANUALLY';\n    43→const SOURCE_EXTENSIONS = new Set(['.ts', '.js', '.py']);\n    44→const DEFAULT_MODULE_THRESHOLD = 3;\n    45→\n    46→// ─── Module Detection (Task 1.5) ────────────────────────────────────────────\n    47→\n    48→/**\n    49→ * Finds directories that qualify as modules.\n    50→ * A directory is a module if it contains at least `threshold` source files\n    51→ * (.ts, .js, .py — excluding test files and node_modules).\n    52→ * Returns array of relative paths from `dir`.\n    53→ */\n    54→export function findModules(dir: string, threshold?: number): string[] {\n    55→  const limit = threshold ?? DEFAULT_MODULE_THRESHOLD;\n    56→  const root = dir;\n    57→  const modules: string[] = [];\n    58→\n    59→  function walk(current: string): void {\n    60→    let entries: string[];\n    61→    try {\n    62→      entries = readdirSync(current);\n    63→    } catch {\n    64→      return;\n    65→    }\n    66→\n    67→    // Skip node_modules, .git, hidden directories, and build output directories\n    68→    const dirName = current.split('/').pop() ?? '';\n    69→    if (\n    70→      dirName === 'node_modules' ||\n    71→      dirName === '.git' ||\n    72→      dirName === 'dist' ||\n    73→      dirName === 'coverage' ||\n    74→      (dirName.startsWith('.') && current !== root)\n    75→    ) {\n    76→      return;\n    77→    }\n    78→\n    79→    let sourceCount = 0;\n    80→    const subdirs: string[] = [];\n    81→\n    82→    for (const entry of entries) {\n    83→      const fullPath = join(current, entry);\n    84→      let stat;\n    85→      try {\n    86→        stat = statSync(fullPath);\n    87→      } catch {\n    88→        continue;\n    89→      }\n    90→\n    91→      if (stat.isDirectory()) {\n    92→        subdirs.push(fullPath);\n    93→      } else if (stat.isFile()) {\n    94→        const ext = getExtension(entry);\n    95→        if (SOURCE_EXTENSIONS.has(ext) && !isTestFile(entry)) {\n    96→          sourceCount++;\n    97→        }\n    98→      }\n    99→    }\n   100→\n   101→    if (sourceCount >= limit) {\n   102→      const rel = relative(root, current);\n   103→      // Skip root directory (empty string) — it's not a meaningful module path\n   104→      if (rel !== '') {\n   105→        modules.push(rel);\n   106→      }\n   107→    }\n   108→\n   109→    for (const subdir of subdirs) {\n   110→      walk(subdir);\n   111→    }\n   112→  }\n   113→\n   114→  walk(root);\n   115→  return modules;\n   116→}\n   117→\n   118→function getExtension(filename: string): string {\n   119→  const dot = filename.lastIndexOf('.');\n   120→  return dot >= 0 ? filename.slice(dot) : '';\n   121→}\n   122→\n   123→function isTestFile(filename: string): boolean {\n   124→  return (\n   125→    filename.includes('.test.') ||\n   126→    filename.includes('.spec.') ||\n   127→    filename.includes('__tests__') ||\n   128→    filename.startsWith('test_')\n   129→  );\n   130→}\n   131→\n   132→// ─── Freshness Checking (Task 1.4) ─────────────────────────────────────────\n   133→\n   134→/**\n   135→ * Compares the last modification time of `docPath` against the newest file\n   136→ * modification time in `codeDir`. If any source file in codeDir is newer\n   137→ * than the document, the document is stale.\n   138→ */\n   139→export function isDocStale(docPath: string, codeDir: string): boolean {\n   140→  if (!existsSync(docPath)) return true;\n   141→  if (!existsSync(codeDir)) return false;\n   142→\n   143→  const docMtime = statSync(docPath).mtime;\n   144→  const newestCode = getNewestSourceMtime(codeDir);\n   145→\n   146→  if (newestCode === null) return false;\n   147→  return newestCode.getTime() > docMtime.getTime();\n   148→}\n   149→\n   150→function getNewestSourceMtime(dir: string): Date | null {\n   151→  let newest: Date | null = null;\n   152→\n   153→  function walk(current: string): void {\n   154→    let entries: string[];\n   155→    try {\n   156→      entries = readdirSync(current);\n   157→    } catch {\n   158→      return;\n   159→    }\n   160→\n   161→    const dirName = current.split('/').pop() ?? '';\n   162→    if (dirName === 'node_modules' || dirName === '.git') return;\n   163→\n   164→    for (const entry of entries) {\n   165→      const fullPath = join(current, entry);\n   166→      let stat;\n   167→      try {\n   168→        stat = statSync(fullPath);\n   169→      } catch {\n   170→        continue;\n   171→      }\n   172→\n   173→      if (stat.isDirectory()) {\n   174→        // Skip __tests__ directories\n   175→        if (entry !== '__tests__') {\n   176→          walk(fullPath);\n   177→        }\n   178→      } else if (stat.isFile()) {\n   179→        const ext = getExtension(entry);\n   180→        if (SOURCE_EXTENSIONS.has(ext) && !isTestFile(entry)) {\n   181→          if (newest === null || stat.mtime.getTime() > newest.getTime()) {\n   182→            newest = stat.mtime;\n   183→          }\n   184→        }\n   185→      }\n   186→    }\n   187→  }\n   188→\n   189→  walk(dir);\n   190→  return newest;\n   191→}\n   192→\n   193→// ─── AGENTS.md Content Completeness (Story 12.2) ────────────────────────────\n   194→\n   195→/**\n   196→ * Lists all source files (.ts, .js, .py — excluding tests) in a module directory.\n   197→ * Returns filenames only (not full paths).\n   198→ */\n   199→export function getSourceFilesInModule(modulePath: string): string[] {\n   200→  const files: string[] = [];\n   201→\n   202→  function walk(current: string): void {\n   203→    let entries: string[];\n   204→    try {\n   205→      entries = readdirSync(current);\n   206→    } catch {\n   207→      return;\n   208→    }\n   209→\n   210→    const dirName = current.split('/').pop() ?? '';\n   211→    if (\n   212→      dirName === 'node_modules' ||\n   213→      dirName === '.git' ||\n   214→      dirName === '__tests__' ||\n   215→      dirName === 'dist' ||\n   216→      dirName === 'coverage' ||\n   217→      (dirName.startsWith('.') && current !== modulePath)\n   218→    ) return;\n   219→\n   220→    for (const entry of entries) {\n   221→      const fullPath = join(current, entry);\n   222→      let stat;\n   223→      try {\n   224→        stat = statSync(fullPath);\n   225→      } catch {\n   226→        continue;\n   227→      }\n   228→\n   229→      if (stat.isDirectory()) {\n   230→        walk(fullPath);\n   231→      } else if (stat.isFile()) {\n   232→        const ext = getExtension(entry);\n   233→        if (SOURCE_EXTENSIONS.has(ext) && !isTestFile(entry)) {\n   234→          files.push(entry);\n   235→        }\n   236→      }\n   237→    }\n   238→  }\n   239→\n   240→  walk(modulePath);\n   241→  return files;\n   242→}\n   243→\n   244→/**\n   245→ * Parses AGENTS.md and extracts all filenames mentioned in the document.\n   246→ * Looks for filenames in code blocks, inline code, bullet lists, and tables.\n   247→ */\n   248→export function getMentionedFilesInAgentsMd(agentsPath: string): string[] {\n   249→  if (!existsSync(agentsPath)) return [];\n   250→\n   251→  const content = readFileSync(agentsPath, 'utf-8');\n   252→  const mentioned = new Set<string>();\n   253→\n   254→  // Match filenames with source extensions in various contexts:\n   255→  // - inline code: `filename.ts`\n   256→  // - code blocks, bullet items, table cells, plain text\n   257→  // Pattern: word characters, hyphens, dots forming a filename with a known extension\n   258→  const filenamePattern = /[\\w./-]*[\\w-]+\\.(?:ts|js|py)\\b/g;\n   259→  let match;\n   260→  while ((match = filenamePattern.exec(content)) !== null) {\n   261→    // Extract just the filename (last segment of any path)\n   262→    const fullMatch = match[0];\n   263→    const basename = fullMatch.split('/').pop()!;\n   264→    // Skip test files\n   265→    if (!isTestFile(basename)) {\n   266→      mentioned.add(basename);\n   267→    }\n   268→  }\n   269→\n   270→  return Array.from(mentioned);\n   271→}\n   272→\n   273→/**\n   274→ * Compares source files in a module against files mentioned in AGENTS.md.\n   275→ * Returns completeness status and list of missing files.\n   276→ */\n   277→export function checkAgentsMdCompleteness(\n   278→  agentsPath: string,\n   279→  modulePath: string,\n   280→): { complete: boolean; missing: string[] } {\n   281→  const sourceFiles = getSourceFilesInModule(modulePath);\n   282→  const mentionedFiles = new Set(getMentionedFilesInAgentsMd(agentsPath));\n   283→\n   284→  const missing = sourceFiles.filter(f => !mentionedFiles.has(f));\n   285→\n   286→  return {\n   287→    complete: missing.length === 0,\n   288→    missing,\n   289→  };\n   290→}\n   291→\n   292→// ─── AGENTS.md Checking (Task 1.6) ─────────────────────────────────────────\n   293→\n   294→/**\n   295→ * Checks if a module has a corresponding AGENTS.md and whether it's fresh.\n   296→ * Uses content completeness (are all source files mentioned?) instead of mtime.\n   297→ */\n   298→export function checkAgentsMdForModule(\n   299→  modulePath: string,\n   300→  dir?: string,\n   301→): DocHealthResult {\n   302→  const root = dir ?? process.cwd();\n   303→  const fullModulePath = join(root, modulePath);\n   304→\n   305→  // Check for module-level AGENTS.md first, then root AGENTS.md\n   306→  let agentsPath = join(fullModulePath, 'AGENTS.md');\n   307→  if (!existsSync(agentsPath)) {\n   308→    // Fall back to root AGENTS.md if the module is top-level source\n   309→    agentsPath = join(root, 'AGENTS.md');\n   310→  }\n   311→\n   312→  if (!existsSync(agentsPath)) {\n   313→    return {\n   314→      path: relative(root, agentsPath),\n   315→      grade: 'missing',\n   316→      lastModified: null,\n   317→      codeLastModified: getNewestSourceMtime(fullModulePath),\n   318→      reason: `No AGENTS.md found for module: ${modulePath}`,\n   319→    };\n   320→  }\n   321→\n   322→  const docMtime = statSync(agentsPath).mtime;\n   323→  const codeMtime = getNewestSourceMtime(fullModulePath);\n   324→\n   325→  // Use content completeness check instead of mtime comparison\n   326→  const { complete, missing } = checkAgentsMdCompleteness(agentsPath, fullModulePath);\n   327→\n   328→  if (!complete) {\n   329→    const missingList = missing.join(', ');\n   330→    return {\n   331→      path: relative(root, agentsPath),\n   332→      grade: 'stale',\n   333→      lastModified: docMtime,\n   334→      codeLastModified: codeMtime,\n   335→      reason: `AGENTS.md stale for module: ${modulePath} — missing: ${missingList}`,\n   336→    };\n   337→  }\n   338→\n   339→  return {\n   340→    path: relative(root, agentsPath),\n   341→    grade: 'fresh',\n   342→    lastModified: docMtime,\n   343→    codeLastModified: codeMtime,\n   344→    reason: 'Up to date',\n   345→  };\n   346→}\n   347→\n   348→// ─── DO NOT EDIT Header Check (Task 1.7) ────────────────────────────────────\n   349→\n   350→/**\n   351→ * Reads the file and checks if it starts with a `DO NOT EDIT MANUALLY` header.\n   352→ */\n   353→export function checkDoNotEditHeaders(docPath: string): boolean {\n   354→  if (!existsSync(docPath)) return false;\n   355→\n   356→  try {\n   357→    const content = readFileSync(docPath, 'utf-8');\n   358→    if (content.length === 0) return false;\n   359→    return content.trimStart().startsWith(DO_NOT_EDIT_HEADER);\n   360→  } catch {\n   361→    return false;\n   362→  }\n   363→}\n   364→\n   365→// ─── Full Scan (Task 1.3) ───────────────────────────────────────────────────\n   366→\n   367→/**\n   368→ * Main scan function. Scans AGENTS.md files, docs/index.md,\n   369→ * active exec-plans, and generated docs for DO NOT EDIT headers.\n   370→ */\n   371→export function scanDocHealth(dir?: string): DocHealthReport {\n   372→  const start = Date.now();\n   373→  const root = dir ?? process.cwd();\n   374→  const documents: DocHealthResult[] = [];\n   375→\n   376→  // Compute modules once for reuse\n   377→  const modules = findModules(root);\n   378→\n   379→  // 1. Root AGENTS.md — use content completeness check\n   380→  const rootAgentsPath = join(root, 'AGENTS.md');\n   381→  if (existsSync(rootAgentsPath)) {\n   382→    if (modules.length > 0) {\n   383→      const docMtime = statSync(rootAgentsPath).mtime;\n   384→\n   385→      // Collect all source files across all modules and check completeness\n   386→      let allMissing: string[] = [];\n   387→      let staleModule = '';\n   388→      let newestCode: Date | null = null;\n   389→\n   390→      for (const mod of modules) {\n   391→        const fullModPath = join(root, mod);\n   392→        // Only check root AGENTS.md for modules that don't have their own AGENTS.md\n   393→        const modAgentsPath = join(fullModPath, 'AGENTS.md');\n   394→        if (existsSync(modAgentsPath)) continue;\n   395→\n   396→        const { missing } = checkAgentsMdCompleteness(rootAgentsPath, fullModPath);\n   397→        if (missing.length > 0 && staleModule === '') {\n   398→          staleModule = mod;\n   399→          allMissing = missing;\n   400→        }\n   401→\n   402→        const modMtime = getNewestSourceMtime(fullModPath);\n   403→        if (modMtime !== null && (newestCode === null || modMtime.getTime() > newestCode.getTime())) {\n   404→          newestCode = modMtime;\n   405→        }\n   406→      }\n   407→\n   408→      if (allMissing.length > 0) {\n   409→        documents.push({\n   410→          path: 'AGENTS.md',\n   411→          grade: 'stale',\n   412→          lastModified: docMtime,\n   413→          codeLastModified: newestCode,\n   414→          reason: `AGENTS.md stale for module: ${staleModule} — missing: ${allMissing.join(', ')}`,\n   415→        });\n   416→      } else {\n   417→        documents.push({\n   418→          path: 'AGENTS.md',\n   419→          grade: 'fresh',\n   420→          lastModified: docMtime,\n   421→          codeLastModified: newestCode,\n   422→          reason: 'Up to date',\n   423→        });\n   424→      }\n   425→    } else {\n   426→      documents.push({\n   427→        path: 'AGENTS.md',\n   428→        grade: 'fresh',\n   429→        lastModified: statSync(rootAgentsPath).mtime,\n   430→        codeLastModified: null,\n   431→        reason: 'No modules found to compare',\n   432→      });\n   433→    }\n   434→\n   435→    // NFR24: AGENTS.md line count check (warning only)\n   436→    checkAgentsMdLineCount(rootAgentsPath, 'AGENTS.md', documents);\n   437→  } else {\n   438→    documents.push({\n   439→      path: 'AGENTS.md',\n   440→      grade: 'missing',\n   441→      lastModified: null,\n   442→      codeLastModified: null,\n   443→      reason: 'Root AGENTS.md not found',\n   444→    });\n   445→  }\n   446→\n   447→  // 2. Per-module AGENTS.md files\n   448→  for (const mod of modules) {\n   449→    const modAgentsPath = join(root, mod, 'AGENTS.md');\n   450→    if (existsSync(modAgentsPath)) {\n   451→      const result = checkAgentsMdForModule(mod, root);\n   452→      // Avoid duplicating root AGENTS.md\n   453→      if (result.path !== 'AGENTS.md') {\n   454→        documents.push(result);\n   455→        checkAgentsMdLineCount(modAgentsPath, result.path, documents);\n   456→      }\n   457→    }\n   458→  }\n   459→\n   460→  // 3. docs/index.md\n   461→  const indexPath = join(root, 'docs', 'index.md');\n   462→  if (existsSync(indexPath)) {\n   463→    const content = readFileSync(indexPath, 'utf-8');\n   464→    // NFR25: check that index only uses relative paths, not copied content\n   465→    const hasAbsolutePaths = /https?:\\/\\/|file:\\/\\//i.test(content);\n   466→    documents.push({\n   467→      path: 'docs/index.md',\n   468→      grade: 'fresh',\n   469→      lastModified: statSync(indexPath).mtime,\n   470→      codeLastModified: null,\n   471→      reason: hasAbsolutePaths\n   472→        ? 'Contains absolute URLs (may violate NFR25)'\n   473→        : 'Uses relative paths',\n   474→    });\n   475→  }\n   476→\n   477→  // 4. Active exec-plans\n   478→  const activeDir = join(root, 'docs', 'exec-plans', 'active');\n   479→  if (existsSync(activeDir)) {\n   480→    const files = readdirSync(activeDir).filter(f => f.endsWith('.md'));\n   481→    for (const file of files) {\n   482→      const filePath = join(activeDir, file);\n   483→      documents.push({\n   484→        path: `docs/exec-plans/active/${file}`,\n   485→        grade: 'fresh',\n   486→        lastModified: statSync(filePath).mtime,\n   487→        codeLastModified: null,\n   488→        reason: 'Active exec-plan',\n   489→      });\n   490→    }\n   491→  }\n   492→\n   493→  // 5. docs/quality/ and docs/generated/ — check DO NOT EDIT headers (NFR26)\n   494→  for (const subdir of ['quality', 'generated']) {\n   495→    const dirPath = join(root, 'docs', subdir);\n   496→    if (!existsSync(dirPath)) continue;\n   497→\n   498→    const files = readdirSync(dirPath).filter(f => !f.startsWith('.'));\n   499→    for (const file of files) {\n   500→      const filePath = join(dirPath, file);\n   501→      let stat;\n   502→      try {\n   503→        stat = statSync(filePath);\n   504→      } catch {\n   505→        continue;\n   506→      }\n   507→      if (!stat.isFile()) continue;\n   508→\n   509→      const hasHeader = checkDoNotEditHeaders(filePath);\n   510→      documents.push({\n   511→        path: `docs/${subdir}/${file}`,\n   512→        grade: hasHeader ? 'fresh' : 'stale',\n   513→        lastModified: stat.mtime,\n   514→        codeLastModified: null,\n   515→        reason: hasHeader\n   516→          ? 'Has DO NOT EDIT MANUALLY header'\n   517→          : 'Missing DO NOT EDIT MANUALLY header (NFR26)',\n   518→      });\n   519→    }\n   520→  }\n   521→\n   522→  const summary = {\n   523→    fresh: documents.filter(d => d.grade === 'fresh').length,\n   524→    stale: documents.filter(d => d.grade === 'stale').length,\n   525→    missing: documents.filter(d => d.grade === 'missing').length,\n   526→    total: documents.length,\n   527→  };\n   528→\n   529→  return {\n   530→    documents,\n   531→    summary,\n   532→    passed: summary.stale === 0 && summary.missing === 0,\n   533→    scanDurationMs: Date.now() - start,\n   534→  };\n   535→}\n   536→\n   537→function checkAgentsMdLineCount(\n   538→  filePath: string,\n   539→  docPath: string,\n   540→  documents: DocHealthResult[],\n   541→): void {\n   542→  try {\n   543→    const content = readFileSync(filePath, 'utf-8');\n   544→    const lineCount = content.split('\\n').length;\n   545→    if (lineCount > 100) {\n   546→      // NFR24 warning — push a separate warning result\n   547→      // This is a warning, not a failure, so we don't change the grade\n   548→      documents.push({\n   549→        path: docPath,\n   550→        grade: 'fresh', // warnings don't affect pass/fail\n   551→        lastModified: statSync(filePath).mtime,\n   552→        codeLastModified: null,\n   553→        reason: `AGENTS.md exceeds 100 lines (${lineCount} lines) — consider splitting`,\n   554→      });\n   555→    }\n   556→  } catch {\n   557→    // Ignore read errors\n   558→  }\n   559→}\n   560→\n   561→// ─── Story-Specific Freshness (Task 2) ──────────────────────────────────────\n   562→\n   563→/**\n   564→ * Given a story ID, determines which modules were changed and checks\n   565→ * AGENTS.md freshness for those specific modules.\n   566→ */\n   567→export function checkStoryDocFreshness(\n   568→  storyId: string,\n   569→  dir?: string,\n   570→): DocHealthReport {\n   571→  const start = Date.now();\n   572→  const root = dir ?? process.cwd();\n   573→  const documents: DocHealthResult[] = [];\n   574→\n   575→  // Try git-based detection first\n   576→  const changedFiles = getRecentlyChangedFiles(root);\n   577→  const allModules = findModules(root);\n   578→\n   579→  let modulesToCheck: string[];\n   580→\n   581→  if (changedFiles.length > 0) {\n   582→    // Map changed files to their parent module directories\n   583→    const changedModules = new Set<string>();\n   584→    for (const file of changedFiles) {\n   585→      for (const mod of allModules) {\n   586→        if (file.startsWith(mod + '/') || file.startsWith(mod + '\\\\')) {\n   587→          changedModules.add(mod);\n   588→        }\n   589→      }\n   590→    }\n   591→    modulesToCheck = Array.from(changedModules);\n   592→  } else {\n   593→    // Fall back to full scan\n   594→    modulesToCheck = allModules;\n   595→  }\n   596→\n   597→  // Check AGENTS.md for each relevant module\n   598→  for (const mod of modulesToCheck) {\n   599→    const result = checkAgentsMdForModule(mod, root);\n   600→    documents.push(result);\n   601→\n   602→    // NFR24 line count warning — check the actual AGENTS.md path used\n   603→    const moduleAgentsPath = join(root, mod, 'AGENTS.md');\n   604→    const actualAgentsPath = existsSync(moduleAgentsPath)\n   605→      ? moduleAgentsPath\n   606→      : join(root, 'AGENTS.md');\n   607→    if (existsSync(actualAgentsPath)) {\n   608→      checkAgentsMdLineCount(actualAgentsPath, result.path, documents);\n   609→    }\n   610→  }\n   611→\n   612→  // If no modules to check, report root AGENTS.md\n   613→  if (modulesToCheck.length === 0) {\n   614→    const rootAgentsPath = join(root, 'AGENTS.md');\n   615→    if (existsSync(rootAgentsPath)) {\n   616→      documents.push({\n   617→        path: 'AGENTS.md',\n   618→        grade: 'fresh',\n   619→        lastModified: statSync(rootAgentsPath).mtime,\n   620→        codeLastModified: null,\n   621→        reason: 'No changed modules detected',\n   622→      });\n   623→    }\n   624→  }\n   625→\n   626→  const summary = {\n   627→    fresh: documents.filter(d => d.grade === 'fresh').length,\n   628→    stale: documents.filter(d => d.grade === 'stale').length,\n   629→    missing: documents.filter(d => d.grade === 'missing').length,\n   630→    total: documents.length,\n   631→  };\n   632→\n   633→  return {\n   634→    documents,\n   635→    summary,\n   636→    passed: summary.stale === 0 && summary.missing === 0,\n   637→    scanDurationMs: Date.now() - start,\n   638→  };\n   639→}\n   640→\n   641→function getRecentlyChangedFiles(dir: string): string[] {\n   642→  try {\n   643→    const output = execSync('git diff --name-only HEAD~5', {\n   644→      cwd: dir,\n   645→      encoding: 'utf-8',\n   646→      stdio: ['pipe', 'pipe', 'pipe'],\n   647→      timeout: 10_000,\n   648→    });\n   649→    return output\n   650→      .trim()\n   651→      .split('\\n')\n   652→      .filter(line => line.length > 0);\n   653→  } catch {\n   654→    return [];\n   655→  }\n   656→}\n   657→\n   658→// ─── Exec-Plan Lifecycle (Task 3) ───────────────────────────────────────────\n   659→\n   660→/**\n   661→ * Generates an exec-plan from story file content.\n   662→ * Creates docs/exec-plans/active/<storyId>.md.\n   663→ */\n   664→export function createExecPlan(storyId: string, dir?: string): string {\n   665→  const root = dir ?? process.cwd();\n   666→  const activeDir = join(root, 'docs', 'exec-plans', 'active');\n   667→  mkdirSync(activeDir, { recursive: true });\n   668→\n   669→  const execPlanPath = join(activeDir, `${storyId}.md`);\n   670→\n   671→  // Try to extract content from story file\n   672→  const storyDir = join(root, '_bmad-output', 'implementation-artifacts');\n   673→  const storyPath = join(storyDir, `${storyId}.md`);\n   674→\n   675→  let storyTitle = storyId;\n   676→  let acSection = '';\n   677→  let taskSection = '';\n   678→\n   679→  if (existsSync(storyPath)) {\n   680→    const content = readFileSync(storyPath, 'utf-8');\n   681→\n   682→    // Extract title\n   683→    const titleMatch = /^#\\s+(.+)$/m.exec(content);\n   684→    if (titleMatch) {\n   685→      storyTitle = titleMatch[1];\n   686→    }\n   687→\n   688→    // Extract acceptance criteria section\n   689→    const acMatch = /## Acceptance Criteria\\n([\\s\\S]*?)(?=\\n## |\\n<!-- |$)/i.exec(content);\n   690→    if (acMatch) {\n   691→      acSection = acMatch[1].trim();\n   692→    }\n   693→\n   694→    // Extract tasks section\n   695→    const taskMatch = /## Tasks \\/ Subtasks\\n([\\s\\S]*?)(?=\\n## |\\n<!-- |$)/i.exec(content);\n   696→    if (taskMatch) {\n   697→      taskSection = taskMatch[1].trim();\n   698→    }\n   699→  }\n   700→\n   701→  const timestamp = new Date().toISOString();\n   702→  const execPlanContent = [\n   703→    '<!-- DO NOT EDIT MANUALLY — managed by codeharness -->',\n   704→    `# Exec Plan: ${storyId}`,\n   705→    '',\n   706→    'Status: active',\n   707→    `Created: ${timestamp}`,\n   708→    '',\n   709→    '## Acceptance Criteria',\n   710→    '',\n   711→    acSection || '_No acceptance criteria extracted_',\n   712→    '',\n   713→    '## Task Checklist',\n   714→    '',\n   715→    taskSection || '_No tasks extracted_',\n   716→    '',\n   717→  ].join('\\n');\n   718→\n   719→  writeFileSync(execPlanPath, execPlanContent, 'utf-8');\n   720→  return execPlanPath;\n   721→}\n   722→\n   723→/**\n   724→ * Moves an active exec-plan to completed.\n   725→ * Updates Status header and adds completion timestamp.\n   726→ */\n   727→export function completeExecPlan(storyId: string, dir?: string): string | null {\n   728→  const root = dir ?? process.cwd();\n   729→  const activePath = join(root, 'docs', 'exec-plans', 'active', `${storyId}.md`);\n   730→\n   731→  if (!existsSync(activePath)) {\n   732→    return null;\n   733→  }\n   734→\n   735→  let content = readFileSync(activePath, 'utf-8');\n   736→\n   737→  // Update status\n   738→  content = content.replace(/^Status:\\s*active$/m, 'Status: completed');\n   739→\n   740→  // Add completion timestamp after Created line\n   741→  const timestamp = new Date().toISOString();\n   742→  content = content.replace(\n   743→    /^(Created:\\s*.+)$/m,\n   744→    `$1\\nCompleted: ${timestamp}`,\n   745→  );\n   746→\n   747→  // Create completed directory and write\n   748→  const completedDir = join(root, 'docs', 'exec-plans', 'completed');\n   749→  mkdirSync(completedDir, { recursive: true });\n   750→\n   751→  const completedPath = join(completedDir, `${storyId}.md`);\n   752→  writeFileSync(completedPath, content, 'utf-8');\n   753→\n   754→  // Remove from active\n   755→  try {\n   756→    unlinkSync(activePath);\n   757→  } catch {\n   758→    // Best-effort removal\n   759→  }\n   760→\n   761→  return completedPath;\n   762→}\n   763→\n   764→/**\n   765→ * Checks whether an exec-plan exists for the story and its current location.\n   766→ */\n   767→export function getExecPlanStatus(\n   768→  storyId: string,\n   769→  dir?: string,\n   770→): 'active' | 'completed' | 'missing' {\n   771→  const root = dir ?? process.cwd();\n   772→\n   773→  if (existsSync(join(root, 'docs', 'exec-plans', 'active', `${storyId}.md`))) {\n   774→    return 'active';\n   775→  }\n   776→  if (existsSync(join(root, 'docs', 'exec-plans', 'completed', `${storyId}.md`))) {\n   777→    return 'completed';\n   778→  }\n   779→  return 'missing';\n   780→}\n   781→\n   782→// ─── Output Formatting (Task 1.8) ───────────────────────────────────────────\n   783→\n   784→/**\n   785→ * Returns array of output lines using ok(), fail(), info() format.\n   786→ */\n   787→export function formatDocHealthOutput(report: DocHealthReport): string[] {\n   788→  const lines: string[] = [];\n   789→\n   790→  for (const doc of report.documents) {\n   791→    switch (doc.grade) {\n   792→      case 'fresh':\n   793→        lines.push(`[OK] ${doc.path}: fresh`);\n   794→        break;\n   795→      case 'stale':\n   796→        lines.push(`[FAIL] ${doc.reason}`);\n   797→        break;\n   798→      case 'missing':\n   799→        lines.push(`[FAIL] ${doc.reason}`);\n   800→        break;\n   801→    }\n   802→  }\n   803→\n   804→  lines.push(\n   805→    `[INFO] Doc health: ${report.summary.fresh} fresh, ${report.summary.stale} stale, ${report.summary.missing} missing`,\n   806→  );\n   807→\n   808→  return lines;\n   809→}\n   810→\n   811→/**\n   812→ * Prints the doc health report using output utilities.\n   813→ */\n   814→export function printDocHealthOutput(report: DocHealthReport): void {\n   815→  for (const doc of report.documents) {\n   816→    switch (doc.grade) {\n   817→      case 'fresh':\n   818→        ok(`${doc.path}: fresh`);\n   819→        break;\n   820→      case 'stale':\n   821→        failFmt(doc.reason);\n   822→        break;\n   823→      case 'missing':\n   824→        failFmt(doc.reason);\n   825→        break;\n   826→    }\n   827→  }\n   828→\n   829→  infoFmt(\n   830→    `Doc health: ${report.summary.fresh} fresh, ${report.summary.stale} stale, ${report.summary.missing} missing`,\n   831→  );\n   832→}\n   833→"}]},"parent_tool_use_id":"toolu_01AdMUjsSRd2zQjpuDrBr3HX","session_id":"e1f3df9b-d919-466e-880e-1001c8652ee8","uuid":"ae1cd841-effe-4654-96ac-46be1b4bf36e","timestamp":"2026-03-20T08:40:40.750Z"}
