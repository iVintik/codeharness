{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01C2XB5n4RsTG4iJSPNQZ3Rs","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { validateAgentSchema, validateWorkflowSchema } from '../schema-validate.js';\n3\t\n4\t// --- Helpers ---\n5\t\n6\tfunction minimalValidAgent() {\n7\t  return {\n8\t    name: 'evaluator',\n9\t    role: {\n10\t      title: 'Adversarial QA Evaluator',\n11\t      purpose: 'Exercise the built artifact and determine if it actually works',\n12\t    },\n13\t    persona: {\n14\t      identity: 'Senior QA who trusts nothing without evidence',\n15\t      communication_style: 'Blunt, evidence-first',\n16\t      principles: [\n17\t        'Never give the benefit of the doubt',\n18\t        'Every PASS requires evidence',\n19\t      ],\n20\t    },\n21\t  };\n22\t}\n23\t\n24\tfunction agentWithPersonality() {\n25\t  return {\n26\t    ...minimalValidAgent(),\n27\t    personality: {\n28\t      traits: {\n29\t        rigor: 0.98,\n30\t        directness: 0.95,\n31\t        warmth: 0.2,\n32\t      },\n33\t    },\n34\t  };\n35\t}\n36\t\n37\tfunction agentWithDisallowedTools() {\n38\t  return {\n39\t    ...minimalValidAgent(),\n40\t    disallowedTools: ['Edit', 'Write'],\n41\t  };\n42\t}\n43\t\n44\t// --- Tests ---\n45\t\n46\tdescribe('validateAgentSchema', () => {\n47\t  describe('valid agents', () => {\n48\t    it('accepts a minimal valid agent with all required fields (AC #1, #2)', () => {\n49\t      const result = validateAgentSchema(minimalValidAgent());\n50\t      expect(result.valid).toBe(true);\n51\t      expect(result.errors).toEqual([]);\n52\t    });\n53\t\n54\t    it('accepts agent with optional personality.traits in 0-1 range (AC #5)', () => {\n55\t      const result = validateAgentSchema(agentWithPersonality());\n56\t      expect(result.valid).toBe(true);\n57\t      expect(result.errors).toEqual([]);\n58\t    });\n59\t\n60\t    it('accepts agent with valid disallowedTools array', () => {\n61\t      const result = validateAgentSchema(agentWithDisallowedTools());\n62\t      expect(result.valid).toBe(true);\n63\t      expect(result.errors).toEqual([]);\n64\t    });\n65\t\n66\t    it('accepts agent with all optional fields present', () => {\n67\t      const agent = {\n68\t        ...minimalValidAgent(),\n69\t        personality: {\n70\t          traits: {\n71\t            rigor: 0.98,\n72\t            warmth: 0.2,\n73\t          },\n74\t        },\n75\t        disallowedTools: ['Edit', 'Write'],\n76\t      };\n77\t      const result = validateAgentSchema(agent);\n78\t      expect(result.valid).toBe(true);\n79\t      expect(result.errors).toEqual([]);\n80\t    });\n81\t\n82\t    it('accepts personality with empty traits object', () => {\n83\t      const agent = {\n84\t        ...minimalValidAgent(),\n85\t        personality: { traits: {} },\n86\t      };\n87\t      const result = validateAgentSchema(agent);\n88\t      expect(result.valid).toBe(true);\n89\t    });\n90\t\n91\t    it('accepts empty disallowedTools array', () => {\n92\t      const agent = {\n93\t        ...minimalValidAgent(),\n94\t        disallowedTools: [],\n95\t      };\n96\t      const result = validateAgentSchema(agent);\n97\t      expect(result.valid).toBe(true);\n98\t    });\n99\t\n100\t    it('accepts trait values at boundaries (0 and 1)', () => {\n101\t      const agent = {\n102\t        ...minimalValidAgent(),\n103\t        personality: {\n104\t          traits: {\n105\t            minimum: 0,\n106\t            maximum: 1,\n107\t          },\n108\t        },\n109\t      };\n110\t      const result = validateAgentSchema(agent);\n111\t      expect(result.valid).toBe(true);\n112\t    });\n113\t  });\n114\t\n115\t  describe('missing required fields', () => {\n116\t    it('rejects missing name field (AC #3)', () => {\n117\t      const { name: _, ...agent } = minimalValidAgent();\n118\t      const result = validateAgentSchema(agent);\n119\t      expect(result.valid).toBe(false);\n120\t      expect(result.errors.some((e) => e.keyword === 'required' && e.message.includes('name'))).toBe(true);\n121\t    });\n122\t\n123\t    it('rejects missing role field (AC #3)', () => {\n124\t      const { role: _, ...agent } = minimalValidAgent();\n125\t      const result = validateAgentSchema(agent);\n126\t      expect(result.valid).toBe(false);\n127\t      expect(result.errors.some((e) => e.keyword === 'required' && e.message.includes('role'))).toBe(true);\n128\t    });\n129\t\n130\t    it('rejects missing persona field (AC #3)', () => {\n131\t      const { persona: _, ...agent } = minimalValidAgent();\n132\t      const result = validateAgentSchema(agent);\n133\t      expect(result.valid).toBe(false);\n134\t      expect(result.errors.some((e) => e.keyword === 'required' && e.message.includes('persona'))).toBe(true);\n135\t    });\n136\t\n137\t    it('rejects missing role.title', () => {\n138\t      const agent = minimalValidAgent();\n139\t      delete (agent.role as Record<string, unknown>).title;\n140\t      const result = validateAgentSchema(agent);\n141\t      expect(result.valid).toBe(false);\n142\t      expect(result.errors.some((e) => e.keyword === 'required' && e.path === '/role')).toBe(true);\n143\t    });\n144\t\n145\t    it('rejects missing role.purpose', () => {\n146\t      const agent = minimalValidAgent();\n147\t      delete (agent.role as Record<string, unknown>).purpose;\n148\t      const result = validateAgentSchema(agent);\n149\t      expect(result.valid).toBe(false);\n150\t      expect(result.errors.some((e) => e.keyword === 'required' && e.path === '/role')).toBe(true);\n151\t    });\n152\t\n153\t    it('rejects missing persona.identity', () => {\n154\t      const agent = minimalValidAgent();\n155\t      delete (agent.persona as Record<string, unknown>).identity;\n156\t      const result = validateAgentSchema(agent);\n157\t      expect(result.valid).toBe(false);\n158\t      expect(result.errors.some((e) => e.keyword === 'required' && e.path === '/persona')).toBe(true);\n159\t    });\n160\t\n161\t    it('rejects missing persona.communication_style', () => {\n162\t      const agent = minimalValidAgent();\n163\t      delete (agent.persona as Record<string, unknown>).communication_style;\n164\t      const result = validateAgentSchema(agent);\n165\t      expect(result.valid).toBe(false);\n166\t      expect(result.errors.some((e) => e.keyword === 'required' && e.path === '/persona')).toBe(true);\n167\t    });\n168\t\n169\t    it('rejects missing persona.principles', () => {\n170\t      const agent = minimalValidAgent();\n171\t      delete (agent.persona as Record<string, unknown>).principles;\n172\t      const result = validateAgentSchema(agent);\n173\t      expect(result.valid).toBe(false);\n174\t      expect(result.errors.some((e) => e.keyword === 'required' && e.path === '/persona')).toBe(true);\n175\t    });\n176\t  });\n177\t\n178\t  describe('personality trait validation', () => {\n179\t    it('rejects trait value above 1 (AC #4)', () => {\n180\t      const agent = {\n181\t        ...minimalValidAgent(),\n182\t        personality: {\n183\t          traits: {\n184\t            rigor: 1.5,\n185\t          },\n186\t        },\n187\t      };\n188\t      const result = validateAgentSchema(agent);\n189\t      expect(result.valid).toBe(false);\n190\t      expect(result.errors.some((e) => e.keyword === 'maximum' && e.path.includes('rigor'))).toBe(true);\n191\t    });\n192\t\n193\t    it('rejects trait value below 0 (AC #4)', () => {\n194\t      const agent = {\n195\t        ...minimalValidAgent(),\n196\t        personality: {\n197\t          traits: {\n198\t            warmth: -0.1,\n199\t          },\n200\t        },\n201\t      };\n202\t      const result = validateAgentSchema(agent);\n203\t      expect(result.valid).toBe(false);\n204\t      expect(result.errors.some((e) => e.keyword === 'minimum' && e.path.includes('warmth'))).toBe(true);\n205\t    });\n206\t\n207\t    it('rejects non-number trait value', () => {\n208\t      const agent = {\n209\t        ...minimalValidAgent(),\n210\t        personality: {\n211\t          traits: {\n212\t            rigor: 'high',\n213\t          },\n214\t        },\n215\t      };\n216\t      const result = validateAgentSchema(agent);\n217\t      expect(result.valid).toBe(false);\n218\t      expect(result.errors.some((e) => e.keyword === 'type')).toBe(true);\n219\t    });\n220\t  });\n221\t\n222\t  describe('additional properties', () => {\n223\t    it('rejects unknown top-level property', () => {\n224\t      const agent = {\n225\t        ...minimalValidAgent(),\n226\t        unknownField: 'unexpected',\n227\t      };\n228\t      const result = validateAgentSchema(agent);\n229\t      expect(result.valid).toBe(false);\n230\t      expect(result.errors.some((e) => e.keyword === 'additionalProperties')).toBe(true);\n231\t    });\n232\t\n233\t    it('rejects unknown property in role', () => {\n234\t      const agent = minimalValidAgent();\n235\t      (agent.role as Record<string, unknown>).extra = 'nope';\n236\t      const result = validateAgentSchema(agent);\n237\t      expect(result.valid).toBe(false);\n238\t      expect(result.errors.some((e) => e.keyword === 'additionalProperties')).toBe(true);\n239\t    });\n240\t\n241\t    it('rejects unknown property in persona', () => {\n242\t      const agent = minimalValidAgent();\n243\t      (agent.persona as Record<string, unknown>).extra = 'nope';\n244\t      const result = validateAgentSchema(agent);\n245\t      expect(result.valid).toBe(false);\n246\t      expect(result.errors.some((e) => e.keyword === 'additionalProperties')).toBe(true);\n247\t    });\n248\t\n249\t    it('rejects unknown property in personality', () => {\n250\t      const agent = {\n251\t        ...minimalValidAgent(),\n252\t        personality: {\n253\t          traits: { rigor: 0.9 },\n254\t          extra: 'nope',\n255\t        },\n256\t      };\n257\t      const result = validateAgentSchema(agent);\n258\t      expect(