{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01U2uuwYJ1Hjf5cQAwogtEQv","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n     2→import type { SprintState, StoryState } from '../../../types/state.js';\n     3→\n     4→// ─── Mocks ───────────────────────────────────────────────────────────────────\n     5→\n     6→// Mock sprint module (public API)\n     7→const mockGetSprintState = vi.fn();\n     8→const mockWriteStateAtomic = vi.fn();\n     9→const mockComputeSprintCounts = vi.fn();\n    10→\n    11→vi.mock('../../sprint/index.js', () => ({\n    12→  getSprintState: (...args: unknown[]) => mockGetSprintState(...args),\n    13→  writeStateAtomic: (...args: unknown[]) => mockWriteStateAtomic(...args),\n    14→  computeSprintCounts: (...args: unknown[]) => mockComputeSprintCounts(...args),\n    15→}));\n    16→\n    17→// Mock dev module\n    18→const mockDevelopStory = vi.fn();\n    19→vi.mock('../../dev/index.js', () => ({\n    20→  developStory: (...args: unknown[]) => mockDevelopStory(...args),\n    21→}));\n    22→\n    23→// Mock child_process\n    24→const mockExecSync = vi.fn();\n    25→vi.mock('node:child_process', () => ({\n    26→  execSync: (...args: unknown[]) => mockExecSync(...args),\n    27→}));\n    28→\n    29→// Mock fs\n    30→const mockWriteFileSync = vi.fn();\n    31→const mockMkdirSync = vi.fn();\n    32→vi.mock('node:fs', () => ({\n    33→  writeFileSync: (...args: unknown[]) => mockWriteFileSync(...args),\n    34→  mkdirSync: (...args: unknown[]) => mockMkdirSync(...args),\n    35→}));\n    36→\n    37→// Import after mocks\n    38→import {\n    39→  createValidationSprint,\n    40→  executeValidationAC,\n    41→  createFixStory,\n    42→  processValidationResult,\n    43→} from '../validation-runner.js';\n    44→import {\n    45→  getValidationProgress,\n    46→  runValidationCycle,\n    47→} from '../validation-orchestrator.js';\n    48→import { VALIDATION_ACS } from '../validation-acs.js';\n    49→import type { ValidationAC } from '../validation-ac-types.js';\n    50→import type { ValidationACResult } from '../validation-runner-types.js';\n    51→\n    52→// ─── Helpers ─────────────────────────────────────────────────────────────────\n    53→\n    54→function emptyState(): SprintState {\n    55→  return {\n    56→    version: 2,\n    57→    sprint: { total: 0, done: 0, failed: 0, blocked: 0, inProgress: null },\n    58→    stories: {},\n    59→    retries: {},\n    60→    flagged: [],\n    61→    epics: {},\n    62→    session: { active: false, startedAt: null, iteration: 0, elapsedSeconds: 0 },\n    63→    observability: { statementCoverage: null, branchCoverage: null, functionCoverage: null, lineCoverage: null },\n    64→    run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n    65→    actionItems: [],\n    66→  };\n    67→}\n    68→\n    69→function defaultStory(overrides?: Partial<StoryState>): StoryState {\n    70→  return {\n    71→    status: 'backlog',\n    72→    attempts: 0,\n    73→    lastAttempt: null,\n    74→    lastError: null,\n    75→    proofPath: null,\n    76→    acResults: null,\n    77→    ...overrides,\n    78→  };\n    79→}\n    80→\n    81→function cliAC(id: number): ValidationAC {\n    82→  return {\n    83→    id,\n    84→    frRef: `FR${id}`,\n    85→    description: `Test AC ${id}`,\n    86→    verificationMethod: 'cli',\n    87→    command: `echo \"AC ${id} ok\"`,\n    88→    category: 'FR',\n    89→  };\n    90→}\n    91→\n    92→function integrationAC(id: number): ValidationAC {\n    93→  return {\n    94→    id,\n    95→    frRef: `FR${id}`,\n    96→    description: `Test AC ${id}`,\n    97→    verificationMethod: 'integration',\n    98→    category: 'FR',\n    99→  };\n   100→}\n   101→\n   102→beforeEach(() => {\n   103→  vi.resetAllMocks();\n   104→  mockComputeSprintCounts.mockReturnValue({\n   105→    total: 0, done: 0, failed: 0, blocked: 0, inProgress: null,\n   106→  });\n   107→  mockWriteStateAtomic.mockReturnValue({ success: true, data: undefined });\n   108→  mockDevelopStory.mockReturnValue({ success: true, data: { storyKey: 'test', status: 'done' } });\n   109→  mockMkdirSync.mockReturnValue(undefined);\n   110→  mockWriteFileSync.mockReturnValue(undefined);\n   111→});\n   112→\n   113→// ─── Task 1: createValidationSprint ──────────────────────────────────────────\n   114→\n   115→describe('createValidationSprint', () => {\n   116→  it('creates 79 story entries with correct initial state', () => {\n   117→    const state = emptyState();\n   118→    mockGetSprintState.mockReturnValue({ success: true, data: state });\n   119→\n   120→    const result = createValidationSprint();\n   121→\n   122→    expect(result.success).toBe(true);\n   123→    if (!result.success) return;\n   124→    expect(result.data.acsAdded).toBe(79);\n   125→    expect(result.data.existingPreserved).toBe(0);\n   126→\n   127→    // Verify writeStateAtomic was called with 79 val- entries\n   128→    const writtenState = mockWriteStateAtomic.mock.calls[0][0] as SprintState;\n   129→    const valKeys = Object.keys(writtenState.stories).filter(k => k.startsWith('val-'));\n   130→    expect(valKeys).toHaveLength(79);\n   131→\n   132→    // Each entry has correct initial state\n   133→    for (const key of valKeys) {\n   134→      const story = writtenState.stories[key];\n   135→      expect(story.status).toBe('backlog');\n   136→      expect(story.attempts).toBe(0);\n   137→      expect(story.lastAttempt).toBeNull();\n   138→      expect(story.lastError).toBeNull();\n   139→    }\n   140→  });\n   141→\n   142→  it('preserves existing non-validation stories in sprint-state.json', () => {\n   143→    const state = emptyState();\n   144→    state.stories['1-1-user-auth'] = defaultStory({ status: 'in-progress' });\n   145→    state.stories['2-1-data-model'] = defaultStory({ status: 'done' });\n   146→    // Treat stories as mutable for test setup\n   147→    (state as { stories: Record<string, StoryState> }).stories = {\n   148→      '1-1-user-auth': defaultStory({ status: 'in-progress' }),\n   149→      '2-1-data-model': defaultStory({ status: 'done' }),\n   150→    };\n   151→    mockGetSprintState.mockReturnValue({ success: true, data: state });\n   152→\n   153→    const result = createValidationSprint();\n   154→\n   155→    expect(result.success).toBe(true);\n   156→    if (!result.success) return;\n   157→    expect(result.data.existingPreserved).toBe(2);\n   158→    expect(result.data.acsAdded).toBe(79);\n   159→\n   160→    const writtenState = mockWriteStateAtomic.mock.calls[0][0] as SprintState;\n   161→    expect(writtenState.stories['1-1-user-auth']).toBeDefined();\n   162→    expect(writtenState.stories['1-1-user-auth'].status).toBe('in-progress');\n   163→    expect(writtenState.stories['2-1-data-model']).toBeDefined();\n   164→    expect(writtenState.stories['2-1-data-model'].status).toBe('done');\n   165→  });\n   166→\n   167→  it('does not overwrite existing validation entries', () => {\n   168→    const state = emptyState();\n   169→    (state as { stories: Record<string, StoryState> }).stories = {\n   170→      'val-1': defaultStory({ status: 'done', attempts: 3 }),\n   171→    };\n   172→    mockGetSprintState.mockReturnValue({ success: true, data: state });\n   173→\n   174→    const result = createValidationSprint();\n   175→\n   176→    expect(result.success).toBe(true);\n   177→    if (!result.success) return;\n   178→    expect(result.data.acsAdded).toBe(78); // 79 - 1 existing\n   179→\n   180→    const writtenState = mockWriteStateAtomic.mock.calls[0][0] as SprintState;\n   181→    expect(writtenState.stories['val-1'].status).toBe('done');\n   182→    expect(writtenState.stories['val-1'].attempts).toBe(3);\n   183→  });\n   184→\n   185→  it('returns fail when getSprintState fails', () => {\n   186→    mockGetSprintState.mockReturnValue({ success: false, error: 'disk error' });\n   187→\n   188→    const result = createValidationSprint();\n   189→    expect(result.success).toBe(false);\n   190→    if (result.success) return;\n   191→    expect(result.error).toBe('disk error');\n   192→  });\n   193→\n   194→  it('returns fail when writeStateAtomic fails', () => {\n   195→    mockGetSprintState.mockReturnValue({ success: true, data: emptyState() });\n   196→    mockWriteStateAtomic.mockReturnValue({ success: false, error: 'write failed' });\n   197→\n   198→    const result = createValidationSprint();\n   199→    expect(result.success).toBe(false);\n   200→    if (result.success) return;\n   201→    expect(result.error).toBe('write failed');\n   202→  });\n   203→});\n   204→\n   205→// ─── Task 2: executeValidationAC ─────────────────────────────────────────────\n   206→\n   207→describe('executeValidationAC', () => {\n   208→  it('CLI AC with passing command returns pass', () => {\n   209→    const ac = cliAC(1);\n   210→    mockExecSync.mockReturnValue('all good');\n   211→\n   212→    const result = executeValidationAC(ac);\n   213→\n   214→    expect(result.success).toBe(true);\n   215→    if (!result.success) return;\n   216→    expect(result.data.acId).toBe(1);\n   217→    expect(result.data.verdict).toBe('pass');\n   218→    expect(result.data.output).toBe('all good');\n   219→    expect(result.data.durationMs).toBeGreaterThanOrEqual(0);\n   220→  });\n   221→\n   222→  it('CLI AC with failing command returns fail with captured output', () => {\n   223→    const ac = cliAC(2);\n   224→    const execError = new Error('Command failed');\n   225→    (execError as unknown as Record<string, unknown>).stdout = 'partial output';\n   226→    (execError as unknown as Record<string, unknown>).stderr = 'error details';\n   227→    mockExecSync.mockImplementation(() => { throw execError; });\n   228→\n   229→    const result = executeValidationAC(ac);\n   230→\n   231→    expect(result.success).toBe(true);\n   232→    if (!result.success) return;\n   233→    expect(result.data.acId).toBe(2);\n   234→    expect(result.data.verdict).toBe('fail');\n   235→    expect(result.data.output).toContain('partial output');\n   236→    expect(result.data.output).toContain('error details');\n   237→  });\n   238→\n   239→  it('integration AC returns blocked with reason', () => {\n   240→    const ac = integrationAC(5);\n   241→\n   242→    const result = executeValidationAC(ac);\n   243→\n   244→    expect(result.success).toBe(true);\n   245→    if (!result.success) return;\n   246→    expect(result.data.acId).toBe(5);\n   247→    expect(result.data.verdict).toBe('blocked');\n   248→    expect(result.data.reason).toBe('integration-required');\n   249→    expect(result.data.durationMs).toBe(0);\n   250→    expect(result.data.output).toBe('');\n   251→  });\n   252→\n   253→  it('CLI AC without command returns blocked', () => {\n   254→    const ac: ValidationAC = {\n   255→      id: 99,\n   256→      frRef: 'FR99',\n   257→      description: 'No command AC',\n   258→      verificationMethod: 'cli',\n   259→      category: 'FR',\n   260→    };\n   261→\n   262→    const result = executeValidationAC(ac);\n   263→\n   264→    expect(result.success).toBe(true);\n   265→    if (!result.success) return;\n   266→    expect(result.data.verdict).toBe('blocked');\n   267→    expect(result.data.reason).toBe('no-command');\n   268→  });\n   269→\n   270→  it('passes timeout option to execSync', () => {\n   271→    const ac = cliAC(1);\n   272→    mockExecSync.mockReturnValue('ok');\n   273→\n   274→    executeValidationAC(ac);\n   275→\n   276→    expect(mockExecSync).toHaveBeenCalledWith(\n   277→      ac.command,\n   278→      expect.objectContaining({ timeout: 30_000 }),\n   279→    );\n   280→  });\n   281→});\n   282→\n   283→// ─── Task 3: createFixStory ──────────────────────────────────────────────────\n   284→\n   285→describe('createFixStory', () => {\n   286→  it('generates valid markdown with AC details', () => {\n   287→    const ac = cliAC(42);\n   288→    const error = 'Expected file not found';\n   289→\n   290→    const result = createFixStory(ac, error);\n   291→\n   292→    expect(result.success).toBe(true);\n   293→    if (!result.success) return;\n   294→    expect(result.data).toBe('val-fix-42');\n   295→\n   296→    // Verify file was written\n   297→    expect(mockMkdirSync).toHaveBeenCalled();\n   298→    expect(mockWriteFileSync).toHaveBeenCalledTimes(1);\n   299→\n   300→    const writtenContent = mockWriteFileSync.mock.calls[0][1] as string;\n   301→    expect(writtenContent).toContain('# Fix: Validation AC 42');\n   302→    expect(writtenContent).toContain('FR42');\n   303→    expect(writtenContent).toContain('Expected file not found');\n   304→    expect(writtenContent).toContain(ac.description);\n   305→    expect(writtenContent).toContain('Status: ready-for-dev');\n   306→  });\n   307→\n   308→  it('includes command in story when AC has one', () => {\n   309→    const ac = cliAC(10);\n   310→    const result = createFixStory(ac, 'fail');\n   311→\n   312→    expect(result.success).toBe(true);\n   313→    const writtenContent = mockWriteFileSync.mock.calls[0][1] as string;\n   314→    expect(writtenContent).toContain('`echo \"AC 10 ok\"`');\n   315→  });\n   316→\n   317→  it('omits command line when AC has no command', () => {\n   318→    const ac = integrationAC(20);\n   319→    const result = createFixStory(ac, 'missing service');\n   320→\n   321→    expect(result.success).toBe(true);\n   322→    const writtenContent = mockWriteFileSync.mock.calls[0][1] as string;\n   323→    expect(writtenContent).not.toContain('**Command:**');\n   324→    expect(writtenContent).toContain('missing service');\n   325→  });\n   326→\n   327→  it('returns fail on write error', () => {\n   328→    const ac = cliAC(1);\n   329→    mockMkdirSync.mockImplementation(() => { throw new Error('Permission denied'); });\n   330→\n   331→    const result = createFixStory(ac, 'err');\n   332→    expect(result.success).toBe(false);\n   333→    if (result.success) return;\n   334→    expect(result.error).toContain('Permission denied');\n   335→  });\n   336→});\n   337→\n   338→// ─── Task 4: processValidationResult ─────────────────────────────────────────\n   339→\n   340→describe('processValidationResult', () => {\n   341→  it('marks story done on pass', () => {\n   342→    const state = emptyState();\n   343→    (state as { stories: Record<string, StoryState> }).stories = {\n   344→      'val-1': defaultStory({ status: 'backlog', attempts: 0 }),\n   345→    };\n   346→    mockGetSprintState.mockReturnValue({ success: true, data: state });\n   347→\n   348→    const acResult: ValidationACResult = {\n   349→      acId: 1, verdict: 'pass', output: 'ok', durationMs: 100,\n   350→    };\n   351→\n   352→    const result = processValidationResult(1, acResult);\n   353→    expect(result.success).toBe(true);\n   354→\n   355→    const writtenState = mockWriteStateAtomic.mock.calls[0][0] as SprintState;\n   356→    expect(writtenState.stories['val-1'].status).toBe('done');\n   357→    expect(writtenState.stories['val-1'].attempts).toBe(1);\n   358→    expect(writtenState.stories['val-1'].lastError).toBeNull();\n   359→  });\n   360→\n   361→  it('marks story failed on fail with error', () => {\n   362→    const state = emptyState();\n   363→    (state as { stories: Record<string, StoryState> }).stories = {\n   364→      'val-5': defaultStory({ status: 'backlog', attempts: 0 }),\n   365→    };\n   366→    mockGetSprintState.mockReturnValue({ success: true, data: state });\n   367→\n   368→    const acResult: ValidationACResult = {\n   369→      acId: 5, verdict: 'fail', output: 'not found', durationMs: 50,\n   370→    };\n   371→\n   372→    const result = processValidationResult(5, acResult);\n   373→    expect(result.success).toBe(true);\n   374→\n   375→    const writtenState = mockWriteStateAtomic.mock.calls[0][0] as SprintState;\n   376→    expect(writtenState.stories['val-5'].status).toBe('failed');\n   377→    expect(writtenState.stories['val-5'].lastError).toBe('not found');\n   378→  });\n   379→\n   380→  it('marks blocked after 10 consecutive failures (retry-exhausted)', () => {\n   381→    const state = emptyState();\n   382→    (state as { stories: Record<string, StoryState> }).stories = {\n   383→      'val-3': defaultStory({ status: 'failed', attempts: 9 }),\n   384→    };\n   385→    mockGetSprintState.mockReturnValue({ success: true, data: state });\n   386→\n   387→    const acResult: ValidationACResult = {\n   388→      acId: 3, verdict: 'fail', output: 'still broken', durationMs: 10,\n   389→    };\n   390→\n   391→    const result = processValidationResult(3, acResult);\n   392→    expect(result.success).toBe(true);\n   393→\n   394→    const writtenState = mockWriteStateAtomic.mock.calls[0][0] as SprintState;\n   395→    expect(writtenState.stories['val-3'].status).toBe('blocked');\n   396→    expect(writtenState.stories['val-3'].lastError).toBe('retry-exhausted');\n   397→    expect(writtenState.stories['val-3'].attempts).toBe(10);\n   398→  });\n   399→\n   400→  it('marks blocked when verdict is blocked', () => {\n   401→    const state = emptyState();\n   402→    (state as { stories: Record<string, StoryState> }).stories = {\n   403→      'val-7': defaultStory(),\n   404→    };\n   405→    mockGetSprintState.mockReturnValue({ success: true, data: state });\n   406→\n   407→    const acResult: ValidationACResult = {\n   408→      acId: 7, verdict: 'blocked', output: '', durationMs: 0, reason: 'integration-required',\n   409→    };\n   410→\n   411→    const result = processValidationResult(7, acResult);\n   412→    expect(result.success).toBe(true);\n   413→\n   414→    const writtenState = mockWriteStateAtomic.mock.calls[0][0] as SprintState;\n   415→    expect(writtenState.stories['val-7'].status).toBe('blocked');\n   416→    expect(writtenState.stories['val-7'].lastError).toBe('integration-required');\n   417→  });\n   418→\n   419→  it('returns fail when story not found', () => {\n   420→    mockGetSprintState.mockReturnValue({ success: true, data: emptyState() });\n   421→\n   422→    const acResult: ValidationACResult = {\n   423→      acId: 999, verdict: 'pass', output: '', durationMs: 0,\n   424→    };\n   425→\n   426→    const result = processValidationResult(999, acResult);\n   427→    expect(result.success).toBe(false);\n   428→    if (result.success) return;\n   429→    expect(result.error).toContain('val-999');\n   430→  });\n   431→\n   432→  it('returns fail when getSprintState fails', () => {\n   433→    mockGetSprintState.mockReturnValue({ success: false, error: 'state corrupted' });\n   434→\n   435→    const acResult: ValidationACResult = {\n   436→      acId: 1, verdict: 'pass', output: '', durationMs: 0,\n   437→    };\n   438→\n   439→    const result = processValidationResult(1, acResult);\n   440→    expect(result.success).toBe(false);\n   441→    if (result.success) return;\n   442→    expect(result.error).toBe('state corrupted');\n   443→  });\n   444→\n   445→  it('uses fallback message when fail output is empty', () => {\n   446→    const state = emptyState();\n   447→    (state as { stories: Record<string, StoryState> }).stories = {\n   448→      'val-10': defaultStory({ status: 'backlog', attempts: 0 }),\n   449→    };\n   450→    mockGetSprintState.mockReturnValue({ success: true, data: state });\n   451→\n   452→    const acResult: ValidationACResult = {\n   453→      acId: 10, verdict: 'fail', output: '', durationMs: 50,\n   454→    };\n   455→\n   456→    const result = processValidationResult(10, acResult);\n   457→    expect(result.success).toBe(true);\n   458→\n   459→    const writtenState = mockWriteStateAtomic.mock.calls[0][0] as SprintState;\n   460→    expect(writtenState.stories['val-10'].lastError).toBe('validation failed');\n   461→  });\n   462→});\n   463→\n   464→// ─── Task 4: getValidationProgress ───────────────────────────────────────────\n   465→\n   466→describe('getValidationProgress', () => {\n   467→  it('returns correct counts for mixed statuses', () => {\n   468→    const state = emptyState();\n   469→    (state as { stories: Record<string, StoryState> }).stories = {\n   470→      'val-1': defaultStory({ status: 'done' }),\n   471→      'val-2': defaultStory({ status: 'done' }),\n   472→      'val-3': defaultStory({ status: 'failed', attempts: 3 }),\n   473→      'val-4': defaultStory({ status: 'blocked' }),\n   474→      'val-5': defaultStory({ status: 'backlog' }),\n   475→      'val-6': defaultStory({ status: 'backlog' }),\n   476→      'val-7': defaultStory({ status: 'backlog' }),\n   477→    };\n   478→    mockGetSprintState.mockReturnValue({ success: true, data: state });\n   479→\n   480→    const result = getValidationProgress();\n   481→    expect(result.success).toBe(true);\n   482→    if (!result.success) return;\n   483→\n   484→    // Only counts ACs that exist in VALIDATION_ACS registry\n   485→    // val-1 through val-7 map to AC IDs 1-7 which exist in the 79-AC registry\n   486→    expect(result.data.passed).toBe(2);\n   487→    expect(result.data.failed).toBe(1);\n   488→    expect(result.data.blocked).toBe(1);\n   489→    expect(result.data.remaining).toBe(3);\n   490→    expect(result.data.total).toBe(7);\n   491→  });\n   492→\n   493→  it('returns per-AC status with attempts and lastError', () => {\n   494→    const state = emptyState();\n   495→    (state as { stories: Record<string, StoryState> }).stories = {\n   496→      'val-1': defaultStory({ status: 'done', attempts: 1, lastError: null }),\n   497→      'val-2': defaultStory({ status: 'failed', attempts: 5, lastError: 'exit code 1' }),\n   498→    };\n   499→    mockGetSprintState.mockReturnValue({ success: true, data: state });\n   500→\n   501→    const result = getValidationProgress();\n   502→    expect(result.success).toBe(true);\n   503→    if (!result.success) return;\n   504→\n   505→    const ac1 = result.data.perAC.find(a => a.acId === 1);\n   506→    expect(ac1).toBeDefined();\n   507→    expect(ac1!.status).toBe('done');\n   508→    expect(ac1!.attempts).toBe(1);\n   509→    expect(ac1!.lastError).toBeNull();\n   510→\n   511→    const ac2 = result.data.perAC.find(a => a.acId === 2);\n   512→    expect(ac2).toBeDefined();\n   513→    expect(ac2!.status).toBe('failed');\n   514→    expect(ac2!.attempts).toBe(5);\n   515→    expect(ac2!.lastError).toBe('exit code 1');\n   516→  });\n   517→\n   518→  it('returns fail when state read fails', () => {\n   519→    mockGetSprintState.mockReturnValue({ success: false, error: 'no file' });\n   520→\n   521→    const result = getValidationProgress();\n   522→    expect(result.success).toBe(false);\n   523→  });\n   524→});\n   525→\n   526→// ─── Task 5: runValidationCycle ──────────────────────────────────────────────\n   527→\n   528→describe('runValidationCycle', () => {\n   529→  it('routes failures to dev module via fix story', () => {\n   530→    // Find a CLI-verifiable AC from the real registry\n   531→    const targetAC = VALIDATION_ACS.find(ac => ac.verificationMethod === 'cli')!;\n   532→    const state = emptyState();\n   533→    // Set all ACs as done except our target\n   534→    for (let i = 1; i <= 79; i++) {\n   535→      (state as { stories: Record<string, StoryState> }).stories[`val-${i}`] = defaultStory({ status: 'done' });\n   536→    }\n   537→    (state as { stories: Record<string, StoryState> }).stories[`val-${targetAC.id}`] = defaultStory({ status: 'backlog' });\n   538→\n   539→    // Both getSprintState calls return the same state\n   540→    mockGetSprintState.mockReturnValue({ success: true, data: state });\n   541→\n   542→    // The AC command fails\n   543→    mockExecSync.mockImplementation(() => {\n   544→      const err = new Error('fail');\n   545→      (err as unknown as Record<string, unknown>).stderr = 'error output';\n   546→      throw err;\n   547→    });\n   548→\n   549→    const result = runValidationCycle();\n   550→    expect(result.success).toBe(true);\n   551→    if (!result.success) return;\n   552→\n   553→    expect(result.data.action).toBe('failed-routed-to-dev');\n   554→    expect(result.data.fixStoryKey).toMatch(/^val-fix-/);\n   555→    expect(mockDevelopStory).toHaveBeenCalled();\n   556→  });\n   557→\n   558→  it('returns no-actionable-ac when all are done or blocked', () => {\n   559→    const state = emptyState();\n   560→    (state as { stories: Record<string, StoryState> }).stories = {\n   561→      'val-1': defaultStory({ status: 'done' }),\n   562→      'val-2': defaultStory({ status: 'blocked' }),\n   563→    };\n   564→    // Add remaining ACs as done\n   565→    for (let i = 3; i <= 79; i++) {\n   566→      (state as { stories: Record<string, StoryState> }).stories[`val-${i}`] = defaultStory({ status: 'done' });\n   567→    }\n   568→    mockGetSprintState.mockReturnValue({ success: true, data: state });\n   569→\n   570→    const result = runValidationCycle();\n   571→    expect(result.success).toBe(true);\n   572→    if (!result.success) return;\n   573→    expect(result.data.action).toBe('no-actionable-ac');\n   574→  });\n   575→\n   576→  it('prefers failed ACs over backlog ACs (re-validation)', () => {\n   577→    // Find two CLI-verifiable ACs\n   578→    const cliACs = VALIDATION_ACS.filter(ac => ac.verificationMethod === 'cli');\n   579→    const backlogAC = cliACs[0];\n   580→    const failedAC = cliACs[1];\n   581→\n   582→    const state = emptyState();\n   583→    // Fill all with done\n   584→    for (let i = 1; i <= 79; i++) {\n   585→      (state as { stories: Record<string, StoryState> }).stories[`val-${i}`] = defaultStory({ status: 'done' });\n   586→    }\n   587→    // Set backlog and failed\n   588→    (state as { stories: Record<string, StoryState> }).sto