: \"^4.1.0\",\n55\t    \"eslint\": \"^10.1.0\",\n56\t    \"ink-testing-library\": \"^4.0.0\",\n57\t    \"tsup\": \"^8.5.1\",\n58\t    \"typescript\": \"^5.9.3\",\n59\t    \"typescript-eslint\": \"^8.57.2\",\n60\t    \"vitest\": \"^4.1.0\"\n61\t  }\n62\t}\n63\t"}]},"parent_tool_use_id":"toolu_01VGSj6rHvizz2esfbdaxjc5","session_id":"655665ef-6468-4ba6-a46a-b395b1530cdd","uuid":"48f443aa-6291-482c-affe-0874eeb937b3","timestamp":"2026-04-02T11:49:40.292Z"}
