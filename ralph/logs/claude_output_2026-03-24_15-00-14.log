{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QgUck58mb4i8Siw225caey","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';\n     2→import {\n     3→  readFileSync,\n     4→  writeFileSync,\n     5→  existsSync,\n     6→  mkdtempSync,\n     7→  rmSync,\n     8→} from 'node:fs';\n     9→import { tmpdir } from 'node:os';\n    10→import { join } from 'node:path';\n    11→import type { SprintState } from '../../../types/state.js';\n    12→\n    13→// Mock migration so tests are isolated from real project files\n    14→vi.mock('../migration.js', () => ({\n    15→  migrateFromOldFormat: vi.fn(() => ({\n    16→    success: false,\n    17→    error: 'No old format files found for migration',\n    18→  })),\n    19→  migrateV1ToV2: vi.fn((v1: Record<string, unknown>) => {\n    20→    const defaultRun = { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null };\n    21→    return {\n    22→      ...v1,\n    23→      version: 2,\n    24→      retries: {},\n    25→      flagged: [],\n    26→      epics: {},\n    27→      session: { active: false, startedAt: null, iteration: 0, elapsedSeconds: 0 },\n    28→      observability: { statementCoverage: null, branchCoverage: null, functionCoverage: null, lineCoverage: null },\n    29→      run: { ...defaultRun, ...(v1.run as Record<string, unknown>) },\n    30→    };\n    31→  }),\n    32→}));\n    33→\n    34→// Import after mock setup\n    35→const {\n    36→  updateRunProgress,\n    37→  clearRunProgress,\n    38→  getSprintState,\n    39→  writeStateAtomic,\n    40→  defaultState,\n    41→} = await import('../state.js');\n    42→\n    43→let testDir: string;\n    44→let originalCwd: string;\n    45→\n    46→beforeEach(() => {\n    47→  testDir = mkdtempSync(join(tmpdir(), 'ch-run-progress-'));\n    48→  originalCwd = process.cwd();\n    49→  process.chdir(testDir);\n    50→});\n    51→\n    52→afterEach(() => {\n    53→  process.chdir(originalCwd);\n    54→  rmSync(testDir, { recursive: true, force: true });\n    55→});\n    56→\n    57→function stateFile(): string {\n    58→  return join(process.cwd(), 'sprint-state.json');\n    59→}\n    60→\n    61→function tmpFile(): string {\n    62→  return join(process.cwd(), '.sprint-state.json.tmp');\n    63→}\n    64→\n    65→describe('updateRunProgress', () => {\n    66→  it('sets all progress fields on existing state', () => {\n    67→    writeStateAtomic(defaultState());\n    68→\n    69→    const result = updateRunProgress({\n    70→      currentStory: '1-2-user-auth',\n    71→      currentPhase: 'dev',\n    72→      lastAction: 'Starting development',\n    73→      acProgress: '0/7',\n    74→    });\n    75→\n    76→    expect(result.success).toBe(true);\n    77→\n    78→    const stateResult = getSprintState();\n    79→    expect(stateResult.success).toBe(true);\n    80→    if (stateResult.success) {\n    81→      expect(stateResult.data.run.currentStory).toBe('1-2-user-auth');\n    82→      expect(stateResult.data.run.currentPhase).toBe('dev');\n    83→      expect(stateResult.data.run.lastAction).toBe('Starting development');\n    84→      expect(stateResult.data.run.acProgress).toBe('0/7');\n    85→    }\n    86→  });\n    87→\n    88→  it('partial update only changes specified fields', () => {\n    89→    const state = defaultState();\n    90→    const stateWithProgress: SprintState = {\n    91→      ...state,\n    92→      run: {\n    93→        ...state.run,\n    94→        currentStory: '1-2-user-auth',\n    95→        currentPhase: 'dev',\n    96→        lastAction: 'Starting development',\n    97→        acProgress: null,\n    98→      },\n    99→    };\n   100→    writeStateAtomic(stateWithProgress);\n   101→\n   102→    const result = updateRunProgress({\n   103→      currentPhase: 'verify',\n   104→    });\n   105→\n   106→    expect(result.success).toBe(true);\n   107→\n   108→    const stateResult = getSprintState();\n   109→    expect(stateResult.success).toBe(true);\n   110→    if (stateResult.success) {\n   111→      expect(stateResult.data.run.currentStory).toBe('1-2-user-auth');\n   112→      expect(stateResult.data.run.currentPhase).toBe('verify');\n   113→      expect(stateResult.data.run.lastAction).toBe('Starting development');\n   114→      expect(stateResult.data.run.acProgress).toBeNull();\n   115→    }\n   116→  });\n   117→\n   118→  it('updates only acProgress without clearing other fields', () => {\n   119→    const state = defaultState();\n   120→    const stateWithProgress: SprintState = {\n   121→      ...state,\n   122→      run: {\n   123→        ...state.run,\n   124→        currentStory: '1-2-user-auth',\n   125→        currentPhase: 'verify',\n   126→        lastAction: 'Running verification',\n   127→        acProgress: '2/7',\n   128→      },\n   129→    };\n   130→    writeStateAtomic(stateWithProgress);\n   131→\n   132→    const result = updateRunProgress({ acProgress: '5/7' });\n   133→\n   134→    expect(result.success).toBe(true);\n   135→\n   136→    const stateResult = getSprintState();\n   137→    expect(stateResult.success).toBe(true);\n   138→    if (stateResult.success) {\n   139→      expect(stateResult.data.run.currentStory).toBe('1-2-user-auth');\n   140→      expect(stateResult.data.run.currentPhase).toBe('verify');\n   141→      expect(stateResult.data.run.lastAction).toBe('Running verification');\n   142→      expect(stateResult.data.run.acProgress).toBe('5/7');\n   143→    }\n   144→  });\n   145→\n   146→  it('can set a field to null explicitly', () => {\n   147→    const state = defaultState();\n   148→    const stateWithProgress: SprintState = {\n   149→      ...state,\n   150→      run: {\n   151→        ...state.run,\n   152→        currentStory: '1-2-user-auth',\n   153→        currentPhase: 'dev',\n   154→        lastAction: 'Working',\n   155→        acProgress: '3/7',\n   156→      },\n   157→    };\n   158→    writeStateAtomic(stateWithProgress);\n   159→\n   160→    const result = updateRunProgress({ acProgress: null });\n   161→\n   162→    expect(result.success).toBe(true);\n   163→\n   164→    const stateResult = getSprintState();\n   165→    expect(stateResult.success).toBe(true);\n   166→    if (stateResult.success) {\n   167→      expect(stateResult.data.run.acProgress).toBeNull();\n   168→      expect(stateResult.data.run.currentStory).toBe('1-2-user-auth');\n   169→    }\n   170→  });\n   171→\n   172→  it('preserves non-progress run fields (active, iteration, etc.)', () => {\n   173→    const state = defaultState();\n   174→    const stateWithRun: SprintState = {\n   175→      ...state,\n   176→      run: {\n   177→        ...state.run,\n   178→        active: true,\n   179→        startedAt: '2026-03-19T10:00:00Z',\n   180→        iteration: 3,\n   181→        cost: 1.5,\n   182→        completed: ['story-a'],\n   183→        failed: ['story-b'],\n   184→      },\n   185→    };\n   186→    writeStateAtomic(stateWithRun);\n   187→\n   188→    const result = updateRunProgress({\n   189→      currentStory: '1-3-new-story',\n   190→      currentPhase: 'create',\n   191→    });\n   192→\n   193→    expect(result.success).toBe(true);\n   194→\n   195→    const stateResult = getSprintState();\n   196→    expect(stateResult.success).toBe(true);\n   197→    if (stateResult.success) {\n   198→      expect(stateResult.data.run.active).toBe(true);\n   199→      expect(stateResult.data.run.startedAt).toBe('2026-03-19T10:00:00Z');\n   200→      expect(stateResult.data.run.iteration).toBe(3);\n   201→      expect(stateResult.data.run.cost).toBe(1.5);\n   202→      expect(stateResult.data.run.completed).toEqual(['story-a']);\n   203→      expect(stateResult.data.run.failed).toEqual(['story-b']);\n   204→      expect(stateResult.data.run.currentStory).toBe('1-3-new-story');\n   205→      expect(stateResult.data.run.currentPhase).toBe('create');\n   206→    }\n   207→  });\n   208→\n   209→  it('creates state file if none exists', () => {\n   210→    const result = updateRunProgress({\n   211→      currentStory: 'new-story',\n   212→      currentPhase: 'dev',\n   213→    });\n   214→\n   215→    expect(result.success).toBe(true);\n   216→    expect(existsSync(stateFile())).toBe(true);\n   217→\n   218→    const stateResult = getSprintState();\n   219→    expect(stateResult.success).toBe(true);\n   220→    if (stateResult.success) {\n   221→      expect(stateResult.data.run.currentStory).toBe('new-story');\n   222→    }\n   223→  });\n   224→\n   225→  it('uses atomic write (no tmp file remains)', () => {\n   226→    writeStateAtomic(defaultState());\n   227→\n   228→    updateRunProgress({ currentStory: 'test', currentPhase: 'dev' });\n   229→\n   230→    expect(existsSync(tmpFile())).toBe(false);\n   231→    expect(existsSync(stateFile())).toBe(true);\n   232→  });\n   233→\n   234→  it('returns fail on read error', () => {\n   235→    writeFileSync(stateFile(), '{invalid json', 'utf-8');\n   236→\n   237→    const result = updateRunProgress({ currentStory: 'test' });\n   238→\n   239→    expect(result.success).toBe(false);\n   240→    if (!result.success) {\n   241→      expect(result.error).toContain('Failed to read sprint state');\n   242→    }\n   243→  });\n   244→\n   245→  it('empty update (no fields specified) writes state unchanged', () => {\n   246→    const state = defaultState();\n   247→    const stateWithProgress: SprintState = {\n   248→      ...state,\n   249→      run: {\n   250→        ...state.run,\n   251→        currentStory: 'keep-me',\n   252→        currentPhase: 'dev',\n   253→      },\n   254→    };\n   255→    writeStateAtomic(stateWithProgress);\n   256→\n   257→    const result = updateRunProgress({});\n   258→\n   259→    expect(result.success).toBe(true);\n   260→\n   261→    const stateResult = getSprintState();\n   262→    expect(stateResult.success).toBe(true);\n   263→    if (stateResult.success) {\n   264→      expect(stateResult.data.run.currentStory).toBe('keep-me');\n   265→      expect(stateResult.data.run.currentPhase).toBe('dev');\n   266→    }\n   267→  });\n   268→});\n   269→\n   270→describe('clearRunProgress', () => {\n   271→  it('resets all live fields to null', () => {\n   272→    const state = defaultState();\n   273→    const stateWithProgress: SprintState = {\n   274→      ...state,\n   275→      run: {\n   276→        ...state.run,\n   277→        currentStory: '1-2-user-auth',\n   278→        currentPhase: 'verify',\n   279→        lastAction: 'Checking AC 5',\n   280→        acProgress: '4/7',\n   281→      },\n   282→    };\n   283→    writeStateAtomic(stateWithProgress);\n   284→\n   285→    const result = clearRunProgress();\n   286→\n   287→    expect(result.success).toBe(true);\n   288→\n   289→    const stateResult = getSprintState();\n   290→    expect(stateResult.success).toBe(true);\n   291→    if (stateResult.success) {\n   292→      expect(stateResult.data.run.currentStory).toBeNull();\n   293→      expect(stateResult.data.run.currentPhase).toBeNull();\n   294→      expect(stateResult.data.run.lastAction).toBeNull();\n   295→      expect(stateResult.data.run.acProgress).toBeNull();\n   296→    }\n   297→  });\n   298→\n   299→  it('preserves non-progress run fields', () => {\n   300→    const state = defaultState();\n   301→    const stateWithRun: SprintState = {\n   302→      ...state,\n   303→      run: {\n   304→        ...state.run,\n   305→        active: true,\n   306→        startedAt: '2026-03-19T10:00:00Z',\n   307→        iteration: 5,\n   308→        cost: 2.0,\n   309→        completed: ['story-x'],\n   310→        failed: ['story-y'],\n   311→        currentStory: 'to-clear',\n   312→        currentPhase: 'dev',\n   313→        lastAction: 'to-clear',\n   314→        acProgress: '1/3',\n   315→      },\n   316→    };\n   317→    writeStateAtomic(stateWithRun