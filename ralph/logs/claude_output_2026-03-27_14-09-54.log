{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01U3eGV4yAimBPY7HGhAmckN","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n     2→import { mkdtempSync, rmSync, writeFileSync, mkdirSync } from 'node:fs';\n     3→import { tmpdir } from 'node:os';\n     4→import { join } from 'node:path';\n     5→import { parseStoryACs, classifyAC, classifyVerifiability, classifyStrategy, parseVerificationTag, INTEGRATION_KEYWORDS } from '../parser.js';\n     6→\n     7→// Mock output.ts to suppress warnings during tests\n     8→vi.mock('../../../lib/output.js', () => ({\n     9→  ok: vi.fn(),\n    10→  fail: vi.fn(),\n    11→  warn: vi.fn(),\n    12→  info: vi.fn(),\n    13→  jsonOutput: vi.fn(),\n    14→}));\n    15→\n    16→let testDir: string;\n    17→\n    18→beforeEach(() => {\n    19→  vi.restoreAllMocks();\n    20→  testDir = mkdtempSync(join(tmpdir(), 'ch-verify-parser-test-'));\n    21→});\n    22→\n    23→afterEach(() => {\n    24→  rmSync(testDir, { recursive: true, force: true });\n    25→});\n    26→\n    27→function writeStoryFile(filename: string, content: string): string {\n    28→  const filePath = join(testDir, filename);\n    29→  writeFileSync(filePath, content, 'utf-8');\n    30→  return filePath;\n    31→}\n    32→\n    33→// ─── classifyAC ─────────────────────────────────────────────────────────────\n    34→\n    35→describe('classifyAC', () => {\n    36→  it('classifies UI keywords', () => {\n    37→    expect(classifyAC('use agent-browser to navigate')).toBe('ui');\n    38→    expect(classifyAC('take a screenshot of the page')).toBe('ui');\n    39→    expect(classifyAC('click on the submit button')).toBe('ui');\n    40→    expect(classifyAC('fill the form with data')).toBe('ui');\n    41→    expect(classifyAC('navigate to the home page')).toBe('ui');\n    42→  });\n    43→\n    44→  it('classifies API keywords', () => {\n    45→    expect(classifyAC('make HTTP calls to the endpoint')).toBe('api');\n    46→    expect(classifyAC('use curl to test the API')).toBe('api');\n    47→    expect(classifyAC('verify REST response body')).toBe('api');\n    48→    expect(classifyAC('check the API endpoint status')).toBe('api');\n    49→  });\n    50→\n    51→  it('classifies DB keywords', () => {\n    52→    expect(classifyAC('check database state after insert')).toBe('db');\n    53→    expect(classifyAC('verify DB state via query')).toBe('db');\n    54→    expect(classifyAC('use Database MCP to query')).toBe('db');\n    55→    expect(classifyAC('run SQL to verify')).toBe('db');\n    56→    expect(classifyAC('check the table contents')).toBe('db');\n    57→  });\n    58→\n    59→  it('classifies general when no keywords match', () => {\n    60→    expect(classifyAC('verify the output is correct')).toBe('general');\n    61→    expect(classifyAC('check that the file exists')).toBe('general');\n    62→    expect(classifyAC('ensure the config is valid')).toBe('general');\n    63→  });\n    64→\n    65→  it('is case insensitive', () => {\n    66→    expect(classifyAC('Use AGENT-BROWSER to test')).toBe('ui');\n    67→    expect(classifyAC('Make HTTP calls')).toBe('api');\n    68→    expect(classifyAC('Check DATABASE state')).toBe('db');\n    69→  });\n    70→\n    71→  it('returns first matching type when multiple keywords present', () => {\n    72→    // UI keywords are checked first\n    73→    expect(classifyAC('use agent-browser to call API endpoint')).toBe('ui');\n    74→  });\n    75→});\n    76→\n    77→// ─── parseStoryACs ──────────────────────────────────────────────────────────\n    78→\n    79→describe('parseStoryACs', () => {\n    80→  it('extracts numbered ACs from a standard story file', () => {\n    81→    const filePath = writeStoryFile('story.md', `# Story 4.1: Test Story\n    82→\n    83→Status: ready-for-dev\n    84→\n    85→## Story\n    86→\n    87→As a developer...\n    88→\n    89→## Acceptance Criteria\n    90→\n    91→1. **Given** a developer runs the command, **When** tests pass, **Then** output is shown.\n    92→\n    93→2. **Given** a user opens the app, **When** they click submit, **Then** the form is saved.\n    94→\n    95→## Tasks / Subtasks\n    96→\n    97→- [ ] Task 1: Do something\n    98→`);\n    99→\n   100→    const acs = parseStoryACs(filePath);\n   101→    expect(acs).toHaveLength(2);\n   102→    expect(acs[0].id).toBe('1');\n   103→    expect(acs[0].description).toContain('developer runs the command');\n   104→    expect(acs[0].type).toBe('general');\n   105→    expect(acs[0].verifiability).toBe('cli-verifiable');\n   106→    expect(acs[0].tier).toBe('test-provable');\n   107→    expect(acs[1].id).toBe('2');\n   108→    expect(acs[1].description).toContain('click submit');\n   109→    expect(acs[1].type).toBe('ui');\n   110→    expect(acs[1].verifiability).toBe('cli-verifiable');\n   111→    expect(acs[1].tier).toBe('test-provable');\n   112→  });\n   113→\n   114→  it('handles multi-line ACs', () => {\n   115→    const filePath = writeStoryFile('story.md', `# Story 1.1: Multi\n   116→\n   117→## Acceptance Criteria\n   118→\n   119→1. **Given** a developer runs the verify command,\n   120→   **When** the verification pipeline starts,\n   121→   **Then** preconditions are checked.\n   122→\n   123→## Tasks\n   124→`);\n   125→\n   126→    const acs = parseStoryACs(filePath);\n   127→    expect(acs).toHaveLength(1);\n   128→    expect(acs[0].description).toContain('developer runs the verify command');\n   129→    expect(acs[0].description).toContain('preconditions are checked');\n   130→  });\n   131→\n   132→  it('classifies ACs by type from content', () => {\n   133→    const filePath = writeStoryFile('story.md', `# Story 1.1: Types\n   134→\n   135→## Acceptance Criteria\n   136→\n   137→1. **Given** agent-browser is used, **Then** screenshots are captured.\n   138→\n   139→2. **Given** HTTP calls are made to the API endpoint, **Then** response bodies are inspected.\n   140→\n   141→3. **Given** Database MCP is used for read-only queries, **Then** results are captured.\n   142→\n   143→4. **Given** verification steps complete, **Then** a proof document is created.\n   144→\n   145→## Tasks\n   146→`);\n   147→\n   148→    const acs = parseStoryACs(filePath);\n   149→    expect(acs).toHaveLength(4);\n   150→    expect(acs[0].type).toBe('ui');\n   151→    expect(acs[1].type).toBe('api');\n   152→    expect(acs[2].type).toBe('db');\n   153→    expect(acs[3].type).toBe('general');\n   154→  });\n   155→\n   156→  it('throws with actionable message when file not found', () => {\n   157→    expect(() => parseStoryACs('/nonexistent/path/story.md')).toThrow(\n   158→      'Story file not found: /nonexistent/path/story.md',\n   159→    );\n   160→  });\n   161→\n   162→  it('returns empty array when no AC section exists', () => {\n   163→    const filePath = writeStoryFile('story.md', `# Story 1.1: No ACs\n   164→\n   165→## Story\n   166→\n   167→As a developer...\n   168→\n   169→## Tasks\n   170→\n   171→- [ ] Do something\n   172→`);\n   173→\n   174→    const acs = parseStoryACs(filePath);\n   175→    expect(acs).toEqual([]);\n   176→  });\n   177→\n   178→  it('handles malformed ACs — skips empty descriptions', () => {\n   179→    const filePath = writeStoryFile('story.md', `# Story 1.1: Malformed\n   180→\n   181→## Acceptance Criteria\n   182→\n   183→1. **Given** a valid AC, **Then** it works.\n   184→\n   185→2.\n   186→\n   187→3. **Given** another valid AC, **Then** it also works.\n   188→\n   189→## Tasks\n   190→`);\n   191→\n   192→    const acs = parseStoryACs(filePath);\n   193→    // AC #2 has empty description and should be skipped\n   194→    expect(acs).toHaveLength(2);\n   195→    expect(acs[0].id).toBe('1');\n   196→    expect(acs[1].id).toBe('3');\n   197→  });\n   198→\n   199→  it('handles AC section at end of file (no following section)', () => {\n   200→    const filePath = writeStoryFile('story.md', `# Story 1.1: EOF\n   201→\n   202→## Acceptance Criteria\n   203→\n   204→1. **Given** it is the last section, **Then** it should still parse.\n   205→`);\n   206→\n   207→    const acs = parseStoryACs(filePath);\n   208→    expect(acs).toHaveLength(1);\n   209→    expect(acs[0].description).toContain('last section');\n   210→    expect(acs[0].verifiability).toBe('cli-verifiable');\n   211→  });\n   212→\n   213→  it('reads verification tag from AC line and sets verifiability accordingly', () => {\n   214→    const filePath = writeStoryFile('story.md', `# Story 12.3: Tags\n   215→\n   216→## Acceptance Criteria\n   217→\n   218→1. **Given** a CLI command, **Then** output is shown. <!-- verification: cli-verifiable -->\n   219→\n   220→2. **Given** sprint planning surfaces retro items, **Then** items appear. <!-- verification: integration-required -->\n   221→\n   222→## Tasks\n   223→`);\n   224→\n   225→    const acs = parseStoryACs(filePath);\n   226→    expect(acs).toHaveLength(2);\n   227→    expect(acs[0].verifiability).toBe('cli-verifiable');\n   228→    expect(acs[0].tier).toBe('test-provable');\n   229→    expect(acs[1].verifiability).toBe('integration-required');\n   230→    expect(acs[1].tier).toBe('environment-provable');\n   231→  });\n   232→\n   233→  it('falls back to heuristic classification when no verification tag is present', () => {\n   234→    const filePath = writeStoryFile('story.md', `# Story 12.3: Heuristic\n   235→\n   236→## Acceptance Criteria\n   237→\n   238→1. **Given** a CLI command, **Then** output is correct.\n   239→\n   240→2. **Given** an external system connection, **Then** data syncs.\n   241→\n   242→3. **Given** manual verification is needed, **Then** flag for human review.\n   243→\n   244→## Tasks\n   245→`);\n   246→\n   247→    const acs = parseStoryACs(filePath);\n   248→    expect(acs).toHaveLength(3);\n   249→    expect(acs[0].verifiability).toBe('cli-verifiable');\n   250→    expect(acs[0].tier).toBe('test-provable');\n   251→    expect(acs[1].verifiability).toBe('integration-required');\n   252→    expect(acs[1].tier).toBe('environment-provable');\n   253→    expect(acs[2].verifiability).toBe('integration-required');\n   254→    expect(acs[2].tier).toBe('environment-provable');\n   255→  });\n   256→\n   257→  it('verification tag overrides heuristic classification', () => {\n   258→    const filePath = writeStoryFile('story.md', `# Story 12.3: Override\n   259→\n   260→## Acceptance Criteria\n   261→\n   262→1. **Given** an external system is connected, **Then** output is correct. <!-- verification: cli-verifiable -->\n   263→\n   264→## Tasks\n   265→`);\n   266→\n   267→    const acs = parseStoryACs(filePath);\n   268→    expect(acs).toHaveLength(1);\n   269→    // \"external system\" would heuristically classify as integration-required,\n   270→    // but the explicit tag overrides it to cli-verifiable\n   271→    expect(acs[0].verifiability).toBe('cli-verifiable');\n   272→    expect(acs[0].tier).toBe('test-provable');\n   273→  });\n   274→\n   275→  it('populates tier field correctly for integration-required ACs', () => {\n   276→    const filePath = writeStoryFile('story.md', `# Story 16.1: Tier test\n   277→\n   278→## Acceptance Criteria\n   279→\n   280→1. **Given** an external system is used, **Then** it is verified.\n   281→\n   282→## Tasks\n   283→`);\n   284→\n   285→    const acs = parseStoryACs(filePath);\n   286→    expect(acs).toHaveLength(1);\n   287→    expect(acs[0].verifiability).toBe('integration-required');\n   288→    expect(acs[0].tier).toBe('environment-provable');\n   289→  });\n   290→\n   291→  it('defaults tier to test-provable for cli-verifiable ACs', () => {\n   292→    const filePath = writeStoryFile('story.md', `# Story 16.1: Default tier\n   293→\n   294→## Acceptance Criteria\n   295→\n   296→1. **Given** a simple check, **Then** it passes.\n   297→\n   298→## Tasks\n   299→`);\n   300→\n   301→    const acs = parseStoryACs(filePath);\n   302→    expect(acs).toHaveLength(1);\n   303→    expect(acs[0].verifiability).toBe('cli-verifiable');\n   304→    expect(acs[0].tier).toBe('test-provable');\n   305→  });\n   306→\n   307→  it('parses new verification tier tags from story AC lines', () => {\n   308→    const filePath = writeStoryFile('story.md', `# Story 16.1: New tags\n   309→\n   310→## Acceptance Criteria\n   311→\n   312→1. **Given** a test-provable AC, **Then** it works. <!-- verification: test-provable -->\n   313→\n   314→2. **Given** a runtime-provable AC, **Then** it works. <!-- verification: runtime-provable -->\n   315→\n   316→3. **Given** an environment-provable AC, **Then** it works. <!-- verification: environment-provable -->\n   317→\n   318→4. **Given** an escalate AC, **Then** it works. <!-- verification: escalate -->\n   319→\n   320→## Tasks\n   321→`);\n   322→\n   323→    const acs = parseStoryACs(filePath);\n   324→    expect(acs).toHaveLength(4);\n   325→    expect(acs[0].tier).toBe('test-provable');\n   326→    expect(acs[1].tier).toBe('runtime-provable');\n   327→    expect(acs[2].tier).toBe('environment-provable');\n   328→    expect(acs[3].tier).toBe('escalate');\n   329→  });\n   330→});\n   331→\n   332→// ─── classifyVerifiability ───────────────────────────────────────────────────\n   333→\n   334→describe('classifyVerifiability', () => {\n   335→  it('returns integration-required for descriptions mentioning integration keywords', () => {\n   336→    expect(classifyVerifiability('connects to external system')).toBe('integration-required');\n   337→    expect(classifyVerifiability('uses real infrastructure for testing')).toBe('integration-required');\n   338→    expect(classifyVerifiability('requires manual verification')).toBe('integration-required');\n   339→  });\n   340→\n   341→  it('returns cli-verifiable for descriptions that were previously over-classified', () => {\n   342→    expect(classifyVerifiability('sprint planning surfaces retro action items')).toBe('cli-veri