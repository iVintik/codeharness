{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AG9PkDE8c5kJeMbWze42fR","type":"tool_result","content":"1\t/**\n2\t * Cross-Worktree Validator.\n3\t *\n4\t * Encapsulates the test-run-after-merge logic extracted from\n5\t * worktree-manager.ts and merge-agent.ts. Both modules delegate\n6\t * to validateMerge() instead of maintaining their own runTestSuite\n7\t * and parseTestOutput implementations.\n8\t *\n9\t * @see Story 18-3: Cross-Worktree Test Validation\n10\t */\n11\t\n12\timport { exec } from 'node:child_process';\n13\timport { appendFileSync, mkdirSync } from 'node:fs';\n14\timport { join } from 'node:path';\n15\timport { promisify } from 'node:util';\n16\t\n17\timport type { TelemetryEntry } from './telemetry-writer.js';\n18\t\n19\tconst execAsync = promisify(exec);\n20\t\n21\t/** 10 MB — generous buffer for verbose test + coverage output. */\n22\tconst MAX_BUFFER = 10 * 1024 * 1024;\n23\t\n24\t// --- Interfaces ---\n25\t\n26\t/**\n27\t * Options for running post-merge test validation.\n28\t */\n29\texport interface ValidateMergeOptions {\n30\t  /** Command to run for test validation. */\n31\t  readonly testCommand: string;\n32\t  /** Working directory to run the test command in. */\n33\t  readonly cwd: string;\n34\t  /** Epic identifier for telemetry. */\n35\t  readonly epicId: string;\n36\t  /** Optional story key override for telemetry (defaults to `merge-{epicId}`). */\n37\t  readonly storyKey?: string;\n38\t  /** Whether to write a telemetry entry after the test suite completes. */\n39\t  readonly writeTelemetry: boolean;\n40\t}\n41\t\n42\t/**\n43\t * Result of a post-merge test validation.\n44\t */\n45\texport interface ValidationResult {\n46\t  /** Whether all tests passed (passed > 0 and failed === 0). */\n47\t  readonly valid: boolean;\n48\t  /** Parsed test results: pass/fail counts and coverage (null if not reported). */\n49\t  readonly testResults: { passed: number; failed: number; coverage: number | null };\n50\t  /** Raw test command stdout+stderr for retry context. */\n51\t  readonly output: string;\n52\t  /** Wall-clock duration of the test run in milliseconds. */\n53\t  readonly durationMs: number;\n54\t}\n55\t\n56\t// --- Constants ---\n57\t\n58\tconst TELEMETRY_DIR = '.codeharness';\n59\tconst TELEMETRY_FILE = 'telemetry.jsonl';\n60\tconst TEST_TIMEOUT_MS = 300_000; // 5 minutes\n61\t\n62\t// --- Test Output Parsing ---\n63\t\n64\t/**\n65\t * Parse test output to extract pass/fail counts and optional coverage.\n66\t * Supports vitest/jest output patterns.\n67\t */\n68\texport function parseTestOutput(stdout: string): { passed: number; failed: number; coverage: number | null } {\n69\t  let passed = 0;\n70\t  let failed = 0;\n71\t  let coverage: number | null = null;\n72\t\n73\t  const passMatch = stdout.match(/(\\d+)\\s+passed/);\n74\t  const failMatch = stdout.match(/(\\d+)\\s+failed/);\n75\t  if (passMatch) passed = parseInt(passMatch[1], 10);\n76\t  if (failMatch) failed = parseInt(failMatch[1], 10);\n77\t\n78\t  const covMatch = stdout.match(/All files[^|]*\\|\\s*([\\d.]+)/);\n79\t  if (covMatch) coverage = parseFloat(covMatch[1]);\n80\t\n81\t  return { passed, failed, coverage };\n82\t}\n83\t\n84\t// --- Telemetry ---\n85\t\n86\t/**\n87\t * Write a merge validation telemetry entry to the NDJSON telemetry file.\n88\t * Failures are silently caught — telemetry must never break validation.\n89\t *\n90\t * Exported so callers (e.g., merge-agent) can defer telemetry writes\n91\t * until they know whether the validation is final (success or last attempt).\n92\t */\n93\texport function writeMergeTelemetry(opts: ValidateMergeOptions, result: ValidationResult): void {\n94\t  try {\n95\t    const entry: TelemetryEntry = {\n96\t      version: 1,\n97\t      timestamp: new Date().toISOString(),\n98\t      storyKey: opts.storyKey ?? `merge-${opts.epicId}`,\n99\t      epicId: opts.epicId,\n100\t      duration_ms: result.durationMs,\n101\t      cost_usd: null,\n102\t      attempts: null,\n103\t      acResults: null,\n104\t      filesChanged: [],\n105\t      testResults: result.testResults,\n106\t      errors: result.valid ? [] : ['Test suite failed after merge'],\n107\t    };\n108\t\n109\t    const dir = join(opts.cwd, TELEMETRY_DIR);\n110\t    mkdirSync(dir, { recursive: true });\n111\t    appendFileSync(join(dir, TELEMETRY_FILE), JSON.stringify(entry) + '\\n');\n112\t  } catch { // IGNORE: telemetry write failure must not break validation\n113\t  }\n114\t}\n115\t\n116\t// --- Main Entry Point ---\n117\t\n118\t/**\n119\t * Run test validation after a merge and optionally write telemetry.\n120\t *\n121\t * Executes the configured test command, parses the output for\n122\t * pass/fail/coverage, and returns a ValidationResult. When\n123\t * writeTelemetry is true, appends an NDJSON entry to the\n124\t * telemetry file.\n125\t *\n126\t * @param opts  Validation options including test command and cwd.\n127\t * @returns Validation result with test results and raw output.\n128\t */\n129\texport async function validateMerge(opts: ValidateMergeOptions): Promise<ValidationResult> {\n130\t  const start = Date.now();\n131\t\n132\t  try {\n133\t    const { stdout, stderr } = await execAsync(opts.testCommand, {\n134\t      cwd: opts.cwd,\n135\t      timeout: TEST_TIMEOUT_MS,\n136\t      maxBuffer: MAX_BUFFER,\n137\t    });\n138\t\n139\t    const combined = stdout + (stderr ? '\\n' + stderr : '');\n140\t    const testResults = parseTestOutput(combined);\n141\t    const result: ValidationResult = {\n142\t      valid: testResults.failed === 0 && testResults.passed > 0,\n143\t      testResults,\n144\t      output: combined,\n145\t      durationMs: Date.now() - start,\n146\t    };\n147\t\n148\t    if (opts.writeTelemetry) {\n149\t      writeMergeTelemetry(opts, result);\n150\t    }\n151\t\n152\t    return result;\n153\t  } catch (err: unknown) {\n154\t    const stdout = (err as { stdout?: string })?.stdout ?? '';\n155\t    const stderr = (err as { stderr?: string })?.stderr ?? '';\n156\t    const combined = stdout + (stderr ? '\\n' + stderr : '');\n157\t    const testResults = parseTestOutput(combined);\n158\t\n159\t    // If we couldn't parse anything, report 1 failure\n160\t    if (testResults.passed === 0 && testResults.failed === 0) {\n161\t      const result: ValidationResult = {\n162\t        valid: false,\n163\t        testResults: { passed: 0, failed: 1, coverage: null },\n164\t        output: combined || 'Test command failed with no output',\n165\t        durationMs: Date.now() - start,\n166\t      };\n167\t\n168\t      if (opts.writeTelemetry) {\n169\t        writeMergeTelemetry(opts, result);\n170\t      }\n171\t\n172\t      return result;\n173\t    }\n174\t\n175\t    const result: ValidationResult = {\n176\t      valid: false,\n177\t      testResults,\n178\t      output: combined,\n179\t      durationMs: Date.now() - start,\n180\t    };\n181\t\n182\t    if (opts.writeTelemetry) {\n183\t      writeMergeTelemetry(opts, result);\n184\t    }\n185\t\n186\t    return result;\n187\t  }\n188\t}\n189\t"}]},"parent_tool_use_id":"toolu_01F81mjQ26vaP2cNozxfQdMu","session_id":"463e753d-ff5b-4757-9453-b6d867bfb166","uuid":"61dfd58d-79b6-4be2-a92c-914ae3546c50","timestamp":"2026-04-03T22:39:26.659Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SVAHHn488hJpKVRK53vp4k","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach } from 'vitest';\n2\t\n3\t// Create controllable mocks — must use vi.hoisted so they're available in vi.mock factories\n4\tconst { mockExecAsync, mockAppendFileSync, mockMkdirSync } = vi.hoisted(() => ({\n5\t  mockExecAsync: vi.fn(),\n6\t  mockAppendFileSync: vi.fn(),\n7\t  mockMkdirSync: vi.fn(),\n8\t}));\n9\t\n10\t// Mock node:child_process\n11\tvi.mock('node:child_process', () => ({\n12\t  exec: vi.fn(),\n13\t}));\n14\t\n15\t// Mock node:util to return our controllable mockExecAsync\n16\tvi.mock('node:util', () => ({\n17\t  promisify: () => mockExecAsync,\n18\t}));\n19\t\n20\t// Mock node:fs\n21\tvi.mock('node:fs', () => ({\n22\t  appendFileSync: mockAppendFileSync,\n23\t  mkdirSync: mockMkdirSync,\n24\t}));\n25\t\n26\timport {\n27\t  validateMerge,\n28\t  parseTestOutput,\n29\t  writeMergeTelemetry,\n30\t  type ValidateMergeOptions,\n31\t  type ValidationResult,\n32\t} from '../cross-worktree-validator.js';\n33\t\n34\tdescribe('cross-worktree-validator', () => {\n35\t  beforeEach(() => {\n36\t    vi.clearAllMocks();\n37\t  });\n38\t\n39\t  // --- Interface Shape Tests (AC #7, #8) ---\n40\t\n41\t  describe('ValidateMergeOptions interface shape (AC #8)', () => {\n42\t    it('has all required fields', () => {\n43\t      const opts: ValidateMergeOptions = {\n44\t        testCommand: 'npm test',\n45\t        cwd: '/repo',\n46\t        epicId: '18',\n47\t        writeTelemetry: true,\n48\t      };\n49\t      expect(opts).toHaveProperty('testCommand');\n50\t      expect(opts).toHaveProperty('cwd');\n51\t      expect(opts).toHaveProperty('epicId');\n52\t      expect(opts).toHaveProperty('writeTelemetry');\n53\t    });\n54\t\n55\t    it('accepts optional storyKey', () => {\n56\t      const opts: ValidateMergeOptions = {\n57\t        testCommand: 'npm test',\n58\t        cwd: '/repo',\n59\t        epicId: '18',\n60\t        storyKey: 'merge-18-custom',\n61\t        writeTelemetry: false,\n62\t      };\n63\t      expect(opts.storyKey).toBe('merge-18-custom');\n64\t    });\n65\t  });\n66\t\n67\t  describe('ValidationResult interface shape (AC #7)', () => {\n68\t    it('has all required fields', () => {\n69\t      const result: ValidationResult = {\n70\t        valid: true,\n71\t        testResults: { passed: 10, failed: 0, coverage: 95.5 },\n72\t        output: '10 passed',\n73\t        durationMs: 1234,\n74\t      };\n75\t      expect(result).toHaveProperty('valid');\n76\t      expect(result).toHaveProperty('testResults');\n77\t      expect(result).toHaveProperty('output');\n78\t      expect(result).toHaveProperty('durationMs');\n79\t    });\n80\t\n81\t    it('testResults includes passed, failed, and optional coverage', () => {\n82\t      const withCov: ValidationResult = {\n83\t        valid: true,\n84\t        testResults: { passed: 5, failed: 0, coverage: 88.2 },\n85\t        output: '',\n86\t        durationMs: 100,\n87\t      };\n88\t      expect(withCov.testResults.passed).toBe(5);\n89\t      expect(withCov.testResults.failed).toBe(0);\n90\t      expect(withCov.testResults.coverage).toBe(88.2);\n91\t\n92\t      const withoutCov: ValidationResult = {\n93\t        valid: false,\n94\t        testResults: { passed: 3, failed: 2, coverage: null },\n95\t        output: '',\n96\t        durationMs: 200,\n97\t      };\n98\t      expect(withoutCov.testResults.coverage).toBeNull();\n99\t    });\n100\t  });\n101\t\n102\t  // --- parseTestOutput Tests ---\n103\t\n104\t  describe('parseTestOutput (AC #1)', () => {\n105\t    it('parses passed and failed counts', () => {\n106\t      const result = parseTestOutput('10 passed\\n2 failed');\n107\t      expect(result.passed).toBe(10);\n108\t      expect(result.failed).toBe(2);\n109\t    });\n110\t\n111\t    it('parses passed only', () => {\n112\t      const result = parseTestOutput('5 passed');\n113\t      expect(result.passed).toBe(5);\n114\t      expect(result.failed).toBe(0);\n115\t    });\n116\t\n117\t    it('parses coverage from \"All files\" pattern', () => {\n118\t      const result = parseTestOutput('10 passed\\n0 failed\\nAll files | 95.5');\n119\t      expect(result.coverage).toBe(95.5);\n120\t    });\n121\t\n122\t    it('returns 0/0 for unparseable output', () => {\n123\t      const result = parseTestOutput('Build completed successfully.');\n124\t      expect(result.passed).toBe(0);\n125\t      expect(result.failed).toBe(0);\n126\t      expect(result.coverage).toBeNull();\n127\t    });\n128\t\n129\t    it('handles empty string', () => {\n130\t      const result = parseTestOutput('');\n131\t      expect(result.passed).toBe(0);\n132\t      expect(result.failed).toBe(0);\n133\t    });\n134\t  });\n135\t\n136\t  // --- validateMerge Tests ---\n137\t\n138\t  describe('validateMerge — success path (AC #1)', () => {\n139\t    it('returns valid: true when tests pass', async () => {\n140\t      mockExecAsync.mockResolvedValue({ stdout: '10 passed\\n0 failed' });\n141\t\n142\t      const result = await validateMerge({\n143\t        testCommand: 'npm test',\n144\t        cwd: '/repo',\n145\t        epicId: '18',\n146\t        writeTelemetry: false,\n147\t      });\n148\t\n149\t      expect(result.valid).toBe(true);\n150\t      expect(result.testResults).toEqual({ passed: 10, failed: 0, coverage: null });\n151\t      expect(result.output).toBe('10 passed\\n0 failed');\n152\t      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n153\t    });\n154\t\n155\t    it('includes coverage in test results when available', async () => {\n156\t      mockExecAsync.mockResolvedValue({ stdout: '10 passed\\nAll files | 95.5' });\n157\t\n158\t      const result = await validateMerge({\n159\t        testCommand: 'npm test',\n160\t        cwd: '/repo',\n161\t        epicId: '18',\n162\t        writeTelemetry: false,\n163\t      });\n164\t\n165\t      expect(result.valid).toBe(true);\n166\t      expect(result.testResults.coverage).toBe(95.5);\n167\t    });\n168\t  });\n169\t\n170\t  describe('validateMerge — failure path (AC #2)', () => {\n171\t    it('returns valid: false when tests fail', async () => {\n172\t      mockExecAsync.mockResolvedValue({ stdout: '5 passed\\n3 failed' });\n173\t\n174\t      const result = await validateMerge({\n175\t        testCommand: 'npm test',\n176\t        cwd: '/repo',\n177\t        epicId: '18',\n178\t        writeTelemetry: false,\n179\t      });\n180\t\n181\t      expect(result.valid).toBe(false);\n182\t      expect(result.testResults).toEqual({ passed: 5, failed: 3, coverage: null });\n183\t      expect(result.output).toBe('5 passed\\n3 failed');\n184\t    });\n185\t\n186\t    it('returns valid: false when test command exits non-zero with parseable output', async () => {\n187\t      const err = new Error('Command failed') as Error & { stdout: string };\n188\t      err.stdout = '3 passed\\n2 failed\\nError: some test error';\n189\t      mockExecAsync.mockRejectedValue(err);\n190\t\n191\t      const result = await validateMerge({\n192\t        testCommand: 'npm test',\n193\t        cwd: '/repo',\n194\t        epicId: '18',\n195\t        writeTelemetry: false,\n196\t      });\n197\t\n198\t      expect(result.valid).toBe(false);\n199\t      expect(result.testResults).toEqual({ passed: 3, failed: 2, coverage: null });\n200\t      expect(result.output).toContain('3 passed');\n201\t    });\n202\t\n203\t    it('returns failed: 1 when test command exits with no parseable output', async () => {\n204\t      const err = new Error('Command failed') as Error & { stdout: string };\n205\t      err.stdout = '';\n206\t      mockExecAsync.mockRejectedValue(err);\n207\t\n208\t      const result = await validateMerge({\n209\t        testCommand: 'npm test',\n210\t        cwd: '/repo',\n211\t        epicId: '18',\n212\t        writeTelemetry: false,\n213\t      });\n214\t\n215\t      expect(result.valid).toBe(false);\n216\t      expect(result.testResults).toEqual({ passed: 0, failed: 1, coverage: null });\n217\t      expect(result.output).toBe('Test command failed with no output');\n218\t    });\n219\t\n220\t    it('handles error with no stdout property', async () => {\n221\t      mockExecAsync.mockRejectedValue(new Error('SIGTERM'));\n222\t\n223\t      const result = await validateMerge({\n224\t        testCommand: 'npm test',\n225\t        cwd: '/repo',\n226\t        epicId: '18',\n227\t        writeTelemetry: false,\n228\t      });\n229\t\n230\t      expect(result.valid).toBe(false);\n231\t      expect(result.testResults).toEqual({ passed: 0, failed: 1, coverage: null });\n232\t    });\n233\t\n234\t    it('treats 0 passed 0 failed as failure (edge case)', async () => {\n235\t      mockExecAsync.mockResolvedValue({ stdout: 'Build completed successfully.' });\n236\t\n237\t      const result = await validateMerge({\n238\t        testCommand: 'npm test',\n239\t        cwd: '/repo',\n240\t        epicId: '18',\n241\t        writeTelemetry: false,\n242\t      });\n243\t\n244\t      // 0 passed && 0 failed => valid = false (passed must be > 0)\n245\t      expect(result.valid).toBe(false);\n246\t    });\n247\t  });\n248\t\n249\t  describe('validateMerge — timeout (AC #5)', () => {\n250\t    it('respects 5-minute timeout', async () => {\n251\t      mockExecAsync.mockResolvedValue({ stdout: '5 passed' });\n252\t\n253\t      await validateMerge({\n254\t        testCommand: 'npm test',\n255\t        cwd: '/repo',\n256\t        epicId: '18',\n257\t        writeTelemetry: false,\n258\t      });\n259\t\n260\t      expect(mockExecAsync).toHaveBeenCalledWith('npm test', {\n261\t        cwd: '/repo',\n262\t        timeout: 300_000,\n263\t        maxBuffer: 10 * 1024 * 1024,\n264\t      });\n265\t    });\n266\t\n267\t    it('handles timeout error as failure', async () => {\n268\t      const err = new Error('Process timed out') as Error & { stdout: string };\n269\t      err.stdout = '';\n270\t      mockExecAsync.mockRejectedValue(err);\n271\t\n272\t      const result = await validateMerge({\n273\t        testCommand: 'npm test',\n274\t        cwd: '/repo',\n275\t        epicId: '18',\n276\t        writeTelemetry: false,\n277\t      });\n278\t\n279\t      expect(result.valid).toBe(false);\n280\t      expect(result.testResults).toEqual({ passed: 0, failed: 1, coverage: null });\n281\t    });\n282\t  });\n283\t\n284\t  // --- Telemetry Tests (AC #4, #9) ---\n285\t\n286\t  describe('validateMerge — telemetry integration (AC #4, #9)', () => {\n287\t    it('writes telemetry when writeTelemetry is true', async () => {\n288\t      mockExecAsync.mockResolvedValue({ stdout: '10 passed\\n0 failed' });\n289\t\n290\t      await validateMerge({\n291\t        testCommand: 'npm test',\n292\t        cwd: '/repo',\n293\t        epicId: '18',\n294\t        writeTelemetry: true,\n295\t      });\n296\t\n297\t      expect(mockMkdirSync).toHaveBeenCalledWith('/repo/.codeharness', { recursive: true });\n298\t      expect(mockAppendFileSync).toHaveBeenCalledOnce();\n299\t      const written = mockAppendFileSync.mock.calls[0][1] as string;\n300\t      const entry = JSON.parse(written.trim());\n301\t      expect(entry.version).toBe(1);\n302\t      expect(entry.storyKey).toBe('merge-18');\n303\t      expect(entry.epicId).toBe('18');\n304\t      expect(entry.testResults.passed).toBe(10);\n305\t      expect(entry.testResults.failed).toBe(0);\n306\t      expect(entry.errors).toEqual([]);\n307\t    });\n308\t\n309\t    it('skips telemetry when writeTelemetry is false', async () => {\n310\t      mockExecAsync.mockResolvedValue({ stdout: '10 passed' });\n311\t\n312\t      await validateMerge({\n313\t        testCommand: 'npm test',\n314\t        cwd: '/repo',\n315\t        epicId: '18',\n316\t        writeTelemetry: false,\n317\t      });\n318\t\n319\t      expect(mockAppendFileSync).not.toHaveBeenCalled();\n320\t    });\n321\t\n322\t    it('writes telemetry on failure with error message', async () => {\n323\t      mockExecAsync.mockResolvedValue({ stdout: '5 passed\\n2 failed' });\n324\t\n325\t      await validateMerge({\n326\t        testCommand: 'npm test',\n327\t        cwd: '/repo',\n328\t        epicId: '18',\n329\t        writeTelemetry: true,\n330\t      });\n331\t\n332\t      expect(mockAppendFileSync).toHaveBeenCalledOnce();\n333\t      const written = mockAppendFileSync.mock.calls[0][1] as string;\n334\t      const entry = JSON.parse(written.trim());\n335\t      expect(entry.errors).toEqual(['Test suite failed after merge']);\n336\t      expect(entry.testResults.failed).toBe(2);\n337\t    });\n338\t\n339\t    it('telemetry entry has storyKey: merge-{epicId} format (AC #9)', async () => {\n340\t      mockExecAsync.mockResolvedValue({ stdout: '5 passed' });\n341\t\n342\t      await validateMerge({\n343\t        testCommand: 'npm test',\n344\t        cwd: '/repo',\n345\t        epicId: '42',\n346\t        writeTelemetry: true,\n347\t      });\n348\t\n349\t      const written = mockAppendFileSync.mock.calls[0][1] as string;\n350\t      const entry = JSON.parse(written.trim());\n351\t      expect(entry.storyKey).toBe('merge-42');\n352\t    });\n353\t\n354\t    it('uses custom storyKey when provided (AC #9)', async () => {\n355\t      mockExecAsync.mockResolvedValue({ stdout: '5 passed' });\n356\t\n357\t      await validateMerge({\n358\t        testCommand: 'npm test',\n359\t        cwd: '/repo',\n360\t        epicId: '42',\n361\t        storyKey: 'custom-key',\n362\t        writeTelemetry: true,\n363\t      });\n364\t\n365\t      const written = mockAppendFileSync.mock.calls[0][1] as string;\n366\t      const entry = JSON.parse(written.trim());\n367\t      expect(entry.storyKey).toBe('custom-key');\n368\t    });\n369\t\n370\t    it('telemetry entry includes duration_ms and timestamp', async () => {\n371\t      mockExecAsync.mockResolvedValue({ stdout: '5 passed' });\n372\t\n373\t      await validateMerge({\n374\t        testCommand: 'npm test',\n375\t        cwd: '/repo',\n376\t        epicId: '18',\n377\t        writeTelemetry: true,\n378\t      });\n379\t\n380\t      const written = mockAppendFileSync.mock.calls[0][1] as string;\n381\t      const entry = JSON.parse(written.trim());\n382\t      expect(typeof entry.duration_ms).toBe('number');\n383\t      expect(entry.duration_ms).toBeGreaterThanOrEqual(0);\n384\t      expect(typeof entry.timestamp).toBe('string');\n385\t      expect(entry.cost_usd).toBeNull();\n386\t      expect(entry.attempts).toBeNull();\n387\t      expect(entry.acResults).toBeNull();\n388\t      expect(entry.filesChanged).toEqual([]);\n389\t    });\n390\t\n391\t    it('telemetry write failure does not break validation', async () => {\n392\t      mockExecAsync.mockResolvedValue({ stdout: '10 passed\\n0 failed' });\n393\t      mockAppendFileSync.mockImplementation(() => {\n394\t        throw new Error('ENOSPC: no space left on device');\n395\t      });\n396\t\n397\t      const result = await validateMerge({\n398\t        testCommand: 'npm test',\n399\t        cwd: '/repo',\n400\t        epicId: '18',\n401\t        writeTelemetry: true,\n402\t      });\n403\t\n404\t      // Validation should still succeed despite telemetry failure\n405\t      expect(result.valid).toBe(true);\n406\t      expect(result.testResults).toEqual({ passed: 10, failed: 0, coverage: null });\n407\t    });\n408\t\n409\t    it('writes telemetry on test command error when writeTelemetry is true', async () => {\n410\t      const err = new Error('Command failed') as Error & { stdout: string };\n411\t      err.stdout = '2 passed\\n3 failed';\n412\t      mockExecAsync.mockRejectedValue(err);\n413\t\n414\t      await validateMerge({\n415\t        testCommand: 'npm test',\n416\t        cwd: '/repo',\n417\t        epicId: '18',\n418\t        writeTelemetry: true,\n419\t      });\n420\t\n421\t      expect(mockAppendFileSync).toHaveBeenCalledOnce();\n422\t      const written = mockAppendFileSync.mock.calls[0][1] as string;\n423\t      const entry = J