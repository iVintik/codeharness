ide TOML comments | Yes — used line-anchored regexes |"}]},"parent_tool_use_id":"toolu_01FKpCJs7D5YnrbAmEFWyYA2","session_id":"9d3ab825-6dfa-42d3-92d1-28b7bc09852d","uuid":"cd038d3e-005c-4021-9897-47d47b2d64a3","timestamp":"2026-03-23T08:55:21.348Z"}
