{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01P38cF59mUT7RhHSnJQiWyt","type":"tool_result","content":"     1→import { Command } from 'commander';\n     2→import { existsSync, unlinkSync, readFileSync, writeFileSync, rmSync } from 'node:fs';\n     3→import { join } from 'node:path';\n     4→import { ok, fail, info, warn, jsonOutput } from '../lib/output.js';\n     5→import { readState, getStatePath, StateFileNotFoundError } from '../lib/state.js';\n     6→import { getStackDir } from '../lib/stack-path.js';\n     7→import { PATCH_TARGETS } from '../lib/bmad.js';\n     8→import { removePatch } from '../lib/patch-engine.js';\n     9→import { NODE_REQUIRE_FLAG } from '../lib/otlp.js';\n    10→import type { HarnessState } from '../lib/state.js';\n    11→\n    12→export interface TeardownResult {\n    13→  status: 'ok' | 'fail';\n    14→  removed: string[];\n    15→  preserved: string[];\n    16→  docker: { stopped: boolean; kept: boolean };\n    17→  patches_removed: number;\n    18→  otlp_cleaned: boolean;\n    19→  error?: string;\n    20→}\n    21→\n    22→function buildDefaultResult(): TeardownResult {\n    23→  return {\n    24→    status: 'ok',\n    25→    removed: [],\n    26→    preserved: [],\n    27→    docker: { stopped: false, kept: false },\n    28→    patches_removed: 0,\n    29→    otlp_cleaned: false,\n    30→  };\n    31→}\n    32→\n    33→export function registerTeardownCommand(program: Command): void {\n    34→  program\n    35→    .command('teardown')\n    36→    .description('Remove harness from a project')\n    37→    .option('--keep-docker', 'Leave Docker stack running and preserve compose files')\n    38→    .option('--keep-beads', 'Preserve beads data (this is the default)')\n    39→    .action(async (options: { keepDocker?: boolean; keepBeads?: boolean }, cmd: Command) => {\n    40→      const globalOpts = cmd.optsWithGlobals() as { json?: boolean };\n    41→      const isJson = globalOpts.json === true;\n    42→      const projectDir = process.cwd();\n    43→\n    44→      const result = buildDefaultResult();\n    45→\n    46→      // --- Read state (hard gate) ---\n    47→      let state: HarnessState;\n    48→      try {\n    49→        state = readState(projectDir);\n    50→      } catch (err) {\n    51→        if (err instanceof StateFileNotFoundError) {\n    52→          result.status = 'fail';\n    53→          result.error = 'Harness not initialized. Nothing to tear down.';\n    54→          if (isJson) {\n    55→            jsonOutput(result as unknown as Record<string, unknown>);\n    56→          } else {\n    57→            fail('Harness not initialized. Nothing to tear down.');\n    58→          }\n    59→          process.exitCode = 1;\n    60→          return;\n    61→        }\n    62→        throw err;\n    63→      }\n    64→\n    65→      // --- Docker teardown (mode-aware) ---\n    66→      const otlpMode = state.otlp?.mode ?? 'local-shared';\n    67→      const composeFile = state.docker?.compose_file ?? '';\n    68→      const stackDir = getStackDir();\n    69→      const isSharedStack = composeFile !== '' && composeFile.startsWith(stackDir);\n    70→      const isLegacyStack = composeFile !== '' && !isSharedStack;\n    71→\n    72→      if (otlpMode === 'remote-direct') {\n    73→        // Remote-direct: no Docker containers to stop\n    74→        if (!isJson) {\n    75→          info('Docker: none (remote OTLP mode)');\n    76→        }\n    77→      } else if (otlpMode === 'remote-routed') {\n    78→        // Remote-routed: stop collector-only container\n    79→        if (!options.keepDocker) {\n    80→          try {\n    81→            const { stopCollectorOnly } = await import('../lib/docker.js');\n    82→            stopCollectorOnly();\n    83→            result.docker.stopped = true;\n    84→            if (!isJson) {\n    85→              ok('OTel Collector: stopped');\n    86→            }\n    87→          } catch (err) {\n    88→            const message = err instanceof Error ? err.message : String(err);\n    89→            if (!isJson) {\n    90→              warn(`OTel Collector: failed to stop (${message})`);\n    91→            }\n    92→          }\n    93→        } else {\n    94→          result.docker.kept = true;\n    95→          if (!isJson) {\n    96→            info('OTel Collector: kept (--keep-docker)');\n    97→          }\n    98→        }\n    99→      } else if (options.keepDocker) {\n   100→        result.docker.kept = true;\n   101→        if (!isJson) {\n   102→          if (isSharedStack) {\n   103→            info('Docker stack: shared (not managed per-project)');\n   104→          } else {\n   105→            info('Docker stack: kept (--keep-docker)');\n   106→          }\n   107→        }\n   108→      } else if (isSharedStack) {\n   109→        // Shared stack: never stop, just inform\n   110→        if (!isJson) {\n   111→          info('Shared stack: kept running (other projects may use it)');\n   112→        }\n   113→      } else if (isLegacyStack) {\n   114→        // Legacy per-project stack — stop and clean up\n   115→        const { isStackRunning, stopStack } = await import('../lib/docker.js');\n   116→        let stackRunning = false;\n   117→        try {\n   118→          stackRunning = isStackRunning(composeFile);\n   119→        } catch {\n   120→          stackRunning = false;\n   121→        }\n   122→\n   123→        if (stackRunning) {\n   124→          try {\n   125→            stopStack(composeFile);\n   126→            result.docker.stopped = true;\n   127→            if (!isJson) {\n   128→              ok('Docker stack: stopped');\n   129→            }\n   130→          } catch (err) {\n   131→            const message = err instanceof Error ? err.message : String(err);\n   132→            if (!isJson) {\n   133→              warn(`Docker stack: failed to stop (${message})`);\n   134→            }\n   135→          }\n   136→        } else {\n   137→          if (!isJson) {\n   138→            info('Docker stack: not running, skipping');\n   139→          }\n   140→        }\n   141→\n   142→        // Remove per-project docker-compose file\n   143→        const composeFilePath = join(projectDir, composeFile);\n   144→        if (existsSync(composeFilePath)) {\n   145→          unlinkSync(composeFilePath);\n   146→          result.removed.push(composeFile);\n   147→          if (!isJson) {\n   148→            ok(`Removed: ${composeFile}`);\n   149→          }\n   150→        }\n   151→\n   152→        // Remove per-project otel config\n   153→        const otelConfigPath = join(projectDir, 'otel-collector-config.yaml');\n   154→        if (existsSync(otelConfigPath)) {\n   155→          unlinkSync(otelConfigPath);\n   156→          result.removed.push('otel-collector-config.yaml');\n   157→          if (!isJson) {\n   158→            ok(`Removed: otel-collector-config.yaml`);\n   159→          }\n   160→        }\n   161→      }\n   162→\n   163→      // --- Task 3: Remove BMAD patches ---\n   164→      let patchesRemoved = 0;\n   165→      for (const [patchName, relativePath] of Object.entries(PATCH_TARGETS)) {\n   166→        const filePath = join(projectDir, '_bmad', relativePath);\n   167→        if (!existsSync(filePath)) {\n   168→          continue;\n   169→        }\n   170→        try {\n   171→          const removed = removePatch(filePath, patchName);\n   172→          if (removed) {\n   173→            patchesRemoved++;\n   174→          }\n   175→        } catch {\n   176→          // Skip silently on error\n   177→        }\n   178→      }\n   179→      result.patches_removed = patchesRemoved;\n   180→\n   181→      if (!isJson) {\n   182→        if (patchesRemoved > 0) {\n   183→          ok(`BMAD patches: removed ${patchesRemoved} patches`);\n   184→        } else {\n   185→          info('BMAD patches: none found');\n   186→        }\n   187→      }\n   188→\n   189→      // --- Task 4: Remove OTLP instrumentation ---\n   190→      if (state.otlp?.enabled && state.stack === 'nodejs') {\n   191→        const pkgPath = join(projectDir, 'package.json');\n   192→        if (existsSync(pkgPath)) {\n   193→          try {\n   194→            const raw = readFileSync(pkgPath, 'utf-8');\n   195→            const pkg = JSON.parse(raw) as Record<string, unknown>;\n   196→            const scripts = pkg['scripts'] as Record<string, string> | undefined;\n   197→\n   198→            if (scripts) {\n   199→              const keysToRemove: string[] = [];\n   200→              for (const [key, value] of Object.entries(scripts)) {\n   201→                if (key.endsWith(':instrumented') && value.includes(NODE_REQUIRE_FLAG)) {\n   202→                  keysToRemove.push(key);\n   203→                }\n   204→              }\n   205→\n   206→              if (keysToRemove.length > 0) {\n   207→                for (const key of keysToRemove) {\n   208→                  delete scripts[key];\n   209→                }\n   210→                writeFileSync(pkgPath, JSON.stringify(pkg, null, 2) + '\\n', 'utf-8');\n   211→                result.otlp_cleaned = true;\n   212→                if (!isJson) {\n   213→                  ok('OTLP: removed instrumented scripts from package.json');\n   214→                }\n   215→              } else {\n   216→                if (!isJson) {\n   217→                  info('OTLP: no instrumented scripts found');\n   218→                }\n   219→              }\n   220→            } else {\n   221→              if (!isJson) {\n   222→                info('OTLP: no instrumented scripts found');\n   223→              }\n   224→            }\n   225→          } catch {\n   226→            if (!isJson) {\n   227→              info('OTLP: no instrumented scripts found');\n   228→            }\n   229→          }\n   230→        } else {\n   231→          if (!isJson) {\n   232→            info('OTLP: no instrumented scripts found');\n   233→          }\n   234→        }\n   235→      }\n   236→\n   237→      // --- Remove .harness/ cache directory ---\n   238→      const harnessDir = join(projectDir, '.harness');\n   239→      if (existsSync(harnessDir)) {\n   240→        rmSync(harnessDir, { recursive: true, force: true });\n   241→        result.removed.push('.harness/');\n   242→        if (!isJson) {\n   243→          ok('Removed: .harness/');\n   244→        }\n   245→      }\n   246→\n   247→      // --- Task 5: Remove state file (LAST) ---\n   248→      const statePath = getStatePath(projectDir);\n   249→      if (existsSync(statePath)) {\n   250→        unlinkSync(statePath);\n   251→        result.removed.push('.claude/codeharness.local.md');\n   252→        if (!isJson) {\n   253→          ok('Removed: .claude/codeharness.local.md');\n   254→        }\n   255→      }\n   256→\n   257→      // --- Task 6: Summary ---\n   258→      result.preserved.push('.beads/ (task history)');\n   259→      result.preserved.push('_bmad/ (BMAD artifacts, patches removed)');\n   260→      result.preserved.push('docs/ (documentation)');\n   261→\n   262→      if (isJson) {\n   263→        jsonOutput(result as unknown as Record<string, unknown>);\n   264→      } else {\n   265→        ok('Harness teardown complete');\n   266→        info('Preserved: .beads/ (task history)');\n   267→        info('Preserved: _bmad/ (BMAD artifacts, patches removed)');\n   268→        info('Preserved: docs/ (documentation)');\n   269→      }\n   270→    });\n   271→}\n   272→"}]},"parent_tool_use_id":"toolu_01CVfsuk3fYkb5FT4qRVJXrF","session_id":"58ae4f51-bff6-4a66-807a-d4f10c8bdaa3","uuid":"5fb50bfc-ff36-41a0-adc0-44604bfe623a","timestamp":"2026-03-23T15:42:18.626Z"}
