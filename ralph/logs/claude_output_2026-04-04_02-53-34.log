{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Hqt85nRDMK1aWWDQMMjKLD","type":"tool_result","content":"1\t/**\n2\t * Epic Completion Detection.\n3\t *\n4\t * Pure logic module that detects when all stories in an epic reach\n5\t * \"done\" status and provides a state machine for epic lifecycle\n6\t * transitions: in-progress → completing → merging → validating → done.\n7\t *\n8\t * @see Story 19-1: Epic Completion Detection\n9\t */\n10\t\n11\timport type { SprintState } from '../types/state.js';\n12\t\n13\t// --- Types ---\n14\t\n15\t/**\n16\t * All possible epic lifecycle statuses.\n17\t * Narrows the broad `string` type from EpicState.status.\n18\t */\n19\texport type EpicLifecycleStatus =\n20\t  | 'in-progress'\n21\t  | 'completing'\n22\t  | 'merging'\n23\t  | 'validating'\n24\t  | 'done'\n25\t  | 'failed';\n26\t\n27\t// --- Error ---\n28\t\n29\t/**\n30\t * Error thrown for invalid epic operations:\n31\t * - Epic not found in state\n32\t * - Invalid state transition\n33\t */\n34\texport class EpicCompletionError extends Error {\n35\t  constructor(message: string) {\n36\t    super(message);\n37\t    this.name = 'EpicCompletionError';\n38\t  }\n39\t}\n40\t\n41\t// --- State Machine ---\n42\t\n43\t/**\n44\t * Valid epic state transitions.\n45\t *\n46\t * Happy path: in-progress → completing → merging → validating → done\n47\t * Failure:    completing|merging|validating → failed\n48\t */\n49\t/**\n50\t * Statuses that have outgoing transitions in the state machine.\n51\t * Terminal statuses (done, failed) have no outgoing transitions.\n52\t */\n53\ttype TransitionableStatus = Exclude<EpicLifecycleStatus, 'done' | 'failed'>;\n54\t\n55\texport const VALID_TRANSITIONS: Record<TransitionableStatus, EpicLifecycleStatus[]> = {\n56\t  'in-progress': ['completing'],\n57\t  'completing': ['merging', 'failed'],\n58\t  'merging': ['validating', 'failed'],\n59\t  'validating': ['done', 'failed'],\n60\t};\n61\t\n62\t// --- Functions ---\n63\t\n64\t/**\n65\t * Get all story keys belonging to a given epic.\n66\t *\n67\t * Stories are matched by the numeric prefix before the first dash.\n68\t * E.g., epicId \"19\" matches \"19-1-foo\" and \"19-2-bar\" but not \"1-9-baz\".\n69\t */\n70\texport function getEpicStories(state: SprintState, epicId: string): string[] {\n71\t  return Object.keys(state.stories).filter((key) => {\n72\t    const dash = key.indexOf('-');\n73\t    if (dash === -1) return false;\n74\t    return key.slice(0, dash) === epicId;\n75\t  }).sort();\n76\t}\n77\t\n78\t/**\n79\t * Check whether all stories in an epic have status \"done\".\n80\t *\n81\t * Returns false for epics with zero stories (never considered complete).\n82\t * Throws EpicCompletionError if the epic does not exist in state.\n83\t */\n84\texport function checkEpicCompletion(state: SprintState, epicId: string): boolean {\n85\t  if (!state.epics[`epic-${epicId}`]) {\n86\t    throw new EpicCompletionError(`Epic epic-${epicId} not found in state`);\n87\t  }\n88\t  const stories = getEpicStories(state, epicId);\n89\t  if (stories.length === 0) return false;\n90\t  return stories.every((key) => state.stories[key]?.status === 'done');\n91\t}\n92\t\n93\t/**\n94\t * Transition an epic to a new lifecycle status (immutable).\n95\t *\n96\t * Validates that:\n97\t * 1. The epic exists in state\n98\t * 2. The transition is allowed by the state machine\n99\t *\n100\t * When transitioning to \"completing\", updates storiesDone to the\n101\t * count of stories with status \"done\".\n102\t *\n103\t * Returns a new SprintState — does not mutate the input.\n104\t */\n105\texport function transitionEpicState(\n106\t  state: SprintState,\n107\t  epicId: string,\n108\t  targetStatus: EpicLifecycleStatus,\n109\t): SprintState {\n110\t  const epicKey = `epic-${epicId}`;\n111\t  const epic = state.epics[epicKey];\n112\t  if (!epic) throw new EpicCompletionError(`Epic ${epicKey} not found in state`);\n113\t\n114\t  const currentStatus = epic.status as EpicLifecycleStatus;\n115\t  const allowed = VALID_TRANSITIONS[currentStatus as TransitionableStatus];\n116\t  if (!allowed?.includes(targetStatus)) {\n117\t    throw new EpicCompletionError(\n118\t      `Invalid transition: ${currentStatus} → ${targetStatus}`,\n119\t    );\n120\t  }\n121\t\n122\t  const storiesDone = targetStatus === 'completing'\n123\t    ? getEpicStories(state, epicId).filter((k) => state.stories[k]?.status === 'done').length\n124\t    : epic.storiesDone;\n125\t\n126\t  return {\n127\t    ...state,\n128\t    epics: {\n129\t      ...state.epics,\n130\t      [epicKey]: { ...epic, status: targetStatus, storiesDone },\n131\t    },\n132\t  };\n133\t}\n134\t"}]},"parent_tool_use_id":"toolu_01KxDszVE1hewisgsfsHW1D6","session_id":"cb820906-0735-4f53-a851-3960824caad6","uuid":"da2eb772-f25a-4d45-adb3-4abf9c9bbe82","timestamp":"2026-04-03T23:01:56.368Z"}
