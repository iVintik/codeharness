{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016AZjAJVVot4fCSkEfD1H2Y","type":"tool_result","content":"     1→/**\n     2→ * Parses retrospective markdown files to extract action items\n     3→ * and classify them for beads import.\n     4→ */\n     5→\n     6→export interface RetroActionItem {\n     7→  /** Item number identifier, e.g., \"A1\", \"A2\" */\n     8→  number: string;\n     9→  /** Action item description */\n    10→  description: string;\n    11→  /** Status from the retro table, e.g., \"Not done\", \"Regressed\" */\n    12→  status: string;\n    13→  /** Notes column from the retro table */\n    14→  notes: string;\n    15→}\n    16→\n    17→export type Classification =\n    18→  | { type: 'harness' }\n    19→  | { type: 'tool'; name: string }\n    20→  | { type: 'project' };\n    21→\n    22→const KNOWN_TOOLS = ['showboat', 'ralph', 'beads', 'bmad'];\n    23→\n    24→/**\n    25→ * Parses action items from a retrospective markdown file.\n    26→ * Looks for a table with the format: `| # | Action | Status | Notes |`\n    27→ */\n    28→export function parseRetroActionItems(content: string): RetroActionItem[] {\n    29→  const lines = content.split('\\n');\n    30→  const items: RetroActionItem[] = [];\n    31→\n    32→  let inTable = false;\n    33→\n    34→  for (const line of lines) {\n    35→    const trimmed = line.trim();\n    36→\n    37→    // Detect table header row: | # | Action | Status | Notes |\n    38→    if (!inTable && /^\\|\\s*#\\s*\\|\\s*Action\\s*\\|\\s*Status\\s*\\|\\s*Notes\\s*\\|/i.test(trimmed)) {\n    39→      inTable = true;\n    40→      continue;\n    41→    }\n    42→\n    43→    // Skip separator row: |---|--------|--------|-------|\n    44→    if (inTable && /^\\|[\\s\\-|]+\\|$/.test(trimmed)) {\n    45→      continue;\n    46→    }\n    47→\n    48→    // Parse data rows\n    49→    if (inTable && trimmed.startsWith('|')) {\n    50→      const cells = trimmed\n    51→        .split('|')\n    52→        .slice(1, -1) // Remove leading/trailing empty strings from split\n    53→        .map(c => c.trim());\n    54→\n    55→      if (cells.length >= 4) {\n    56→        const number = cells[0];\n    57→        const description = cells[1];\n    58→        const status = cells[2];\n    59→        const notes = cells[3];\n    60→\n    61→        // Only include rows with valid item numbers (e.g., A1, A2)\n    62→        if (/^[A-Za-z]\\d+$/.test(number)) {\n    63→          items.push({ number, description, status, notes });\n    64→        }\n    65→      }\n    66→    }\n    67→\n    68→    // End of table: non-table line after table started\n    69→    if (inTable && !trimmed.startsWith('|') && trimmed !== '') {\n    70→      inTable = false;\n    71→    }\n    72→  }\n    73→\n    74→  return items;\n    75→}\n    76→\n    77→/**\n    78→ * Classifies a retro action item based on its description text.\n    79→ *\n    80→ * Rules (applied in order):\n    81→ * 1. Contains \"harness\" or \"codeharness\" (case-insensitive) -> harness\n    82→ * 2. Contains known tool name (case-insensitive) -> tool:<name>\n    83→ * 3. Everything else -> project\n    84→ */\n    85→export function classifyFinding(item: RetroActionItem): Classification {\n    86→  const text = item.description.toLowerCase();\n    87→\n    88→  if (text.includes('harness') || text.includes('codeharness')) {\n    89→    return { type: 'harness' };\n    90→  }\n    91→\n    92→  for (const tool of KNOWN_TOOLS) {\n    93→    if (text.includes(tool)) {\n    94→      return { type: 'tool', name: tool };\n    95→    }\n    96→  }\n    97→\n    98→  return { type: 'project' };\n    99→}\n   100→\n   101→/**\n   102→ * Derives priority from retro action item context.\n   103→ * - Items marked \"Regressed\" or with urgency indicators -> priority 1\n   104→ * - Items marked \"Not done\" with multiple carries -> priority 2\n   105→ * - Default -> priority 2\n   106→ */\n   107→export function derivePriority(item: RetroActionItem): number {\n   108→  const statusLower = item.status.toLowerCase();\n   109→  const notesLower = item.notes.toLowerCase();\n   110→\n   111→  // Regressed or urgency indicators -> priority 1\n   112→  if (\n   113→    statusLower.includes('regressed') ||\n   114→    notesLower.includes('urgent') ||\n   115→    notesLower.includes('critical')\n   116→  ) {\n   117→    return 1;\n   118→  }\n   119→\n   120→  // Default priority\n   121→  return 2;\n   122→}\n   123→\n   124→// ─── Section-based retro parsing (subsection format) ────────────────────\n   125→\n   126→/** Section classification for action items under ## 6. Action Items */\n   127→export type RetroSection = 'fix-now' | 'fix-soon' | 'backlog';\n   128→\n   129→/** An action item parsed from a retro subsection */\n   130→export interface RetroSectionItem {\n   131→  readonly section: RetroSection;\n   132→  readonly text: string;\n   133→}\n   134→\n   135→/**\n   136→ * Classify a subsection header into a RetroSection.\n   137→ * Matches case-insensitively and strips parenthetical suffixes.\n   138→ * Returns null if the header doesn't match a known section.\n   139→ */\n   140→function classifyHeader(header: string): RetroSection | null {\n   141→  // Strip leading #+ and trim\n   142→  const text = header.replace(/^#+\\s*/, '').trim();\n   143→  // Strip parenthetical suffix: \"Fix Now (Before Next Session)\" -> \"Fix Now\"\n   144→  const base = text.replace(/\\s*\\(.*\\)\\s*$/, '').trim().toLowerCase();\n   145→  if (base === 'fix now') return 'fix-now';\n   146→  if (base === 'fix soon') return 'fix-soon';\n   147→  if (base === 'backlog') return 'backlog';\n   148→  return null;\n   149→}\n   150→\n   151→/**\n   152→ * Parse retro subsection-based action items from the `## 6. Action Items` section.\n   153→ * Handles varying header formats (### or ####, with/without parenthetical suffixes).\n   154→ * Extracts bullet items (`- ` or numbered `1. `) under each subsection.\n   155→ */\n   156→export function parseRetroSections(content: string): RetroSectionItem[] {\n   157→  const lines = content.split('\\n');\n   158→  const items: RetroSectionItem[] = [];\n   159→  let currentSection: RetroSection | null = null;\n   160→  let inActionItems = false;\n   161→\n   162→  for (const line of lines) {\n   163→    const trimmed = line.trim();\n   164→\n   165→    // Detect ## 6. Action Items header (or similar)\n   166→    if (/^#{2}\\s+\\d+\\.\\s*Action\\s*Items/i.test(trimmed)) {\n   167→      inActionItems = true;\n   168→      continue;\n   169→    }\n   170→\n   171→    // If we hit another ## header (not ###/####), stop\n   172→    if (inActionItems && /^#{2}\\s+[^#]/.test(trimmed) && !/Action\\s*Items/i.test(trimmed)) {\n   173→      break;\n   174→    }\n   175→\n   176→    if (!inActionItems) continue;\n   177→\n   178→    // Detect ### or #### subsection headers\n   179→    if (/^#{3,4}\\s+/.test(trimmed)) {\n   180→      const section = classifyHeader(trimmed);\n   181→      currentSection = section;\n   182→      continue;\n   183→    }\n   184→\n   185→    // Extract bullet items under current section\n   186→    if (currentSection !== null) {\n   187→      const bulletMatch = trimmed.match(/^(?:-|\\d+\\.)\\s+(.+)$/);\n   188→      if (bulletMatch) {\n   189→        items.push({ section: currentSection, text: bulletMatch[1].trim() });\n   190→      }\n   191→    }\n   192→  }\n   193→\n   194→  return items;\n   195→}\n   196→\n   197→// ─── Deduplication utilities ────────────────────────────────────────────\n   198→\n   199→/**\n   200→ * Normalize text for deduplication: lowercase, remove punctuation, split into words.\n   201→ */\n   202→export function normalizeText(text: string): string[] {\n   203→  return text\n   204→    .toLowerCase()\n   205→    .replace(/[^a-z0-9\\s]/g, '')\n   206→    .split(/\\s+/)\n   207→    .filter(w => w.length > 0);\n   208→}\n   209→\n   210→/**\n   211→ * Compute word overlap between two normalized word arrays.\n   212→ * Returns overlap percentage (0-1) using min(|a|, |b|) as denominator.\n   213→ */\n   214→export function wordOverlap(a: string[], b: string[]): number {\n   215→  if (a.length === 0 || b.length === 0) return 0;\n   216→  const setB = new Set(b);\n   217→  const intersection = a.filter(w => setB.has(w)).length;\n   218→  return intersection / Math.min(a.length, b.length);\n   219→}\n   220→\n   221→/**\n   222→ * Check if a new item is a duplicate of any existing title.\n   223→ * Uses word overlap with configurable threshold (default 0.8).\n   224→ */\n   225→export function isDuplicate(\n   226→  newItem: string,\n   227→  existingTitles: string[],\n   228→  threshold = 0.8,\n   229→): { duplicate: boolean; matchedTitle?: string } {\n   230→  const newWords = normalizeText(newItem);\n   231→  for (const title of existingTitles) {\n   232→    const titleWords = normalizeText(title);\n   233→    if (wordOverlap(newWords, titleWords) >= threshold) {\n   234→      return { duplicate: true, matchedTitle: title };\n   235→    }\n   236→  }\n   237→  return { duplicate: false };\n   238→}\n   239→"}]},"parent_tool_use_id":"toolu_01QdekhbhdCn1yMfA8HwX61q","session_id":"84a01a9c-e466-45b4-91ef-8201b3712d8d","uuid":"888ad23d-bd93-448f-a2d3-6fc52765c18b","timestamp":"2026-03-24T21:56:57.286Z"}
