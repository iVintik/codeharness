{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xqg7sRBX8q8t8iUFX22rwJ","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { validateWorkflowSchema, validateAgainstSchema } from '../schema-validate.js';\n3\t\n4\t// --- Helpers ---\n5\t\n6\tfunction minimalValidWorkflow() {\n7\t  return {\n8\t    tasks: {\n9\t      implement: {\n10\t        agent: 'dev',\n11\t      },\n12\t    },\n13\t    flow: ['implement'],\n14\t  };\n15\t}\n16\t\n17\tfunction fullValidWorkflow() {\n18\t  return {\n19\t    tasks: {\n20\t      implement: {\n21\t        agent: 'dev',\n22\t        scope: 'per-story',\n23\t        session: 'fresh',\n24\t        source_access: true,\n25\t        prompt_template: 'Implement story {{story_key}}',\n26\t        input_contract: { type: 'object' },\n27\t        output_contract: { type: 'object' },\n28\t        max_budget_usd: 5.0,\n29\t      },\n30\t      verify: {\n31\t        agent: 'evaluator',\n32\t        scope: 'per-run',\n33\t        session: 'continue',\n34\t        source_access: false,\n35\t      },\n36\t      retry: {\n37\t        agent: 'dev',\n38\t        scope: 'per-story',\n39\t        session: 'fresh',\n40\t        source_access: true,\n41\t        prompt_template: 'Fix failures: {{findings}}',\n42\t      },\n43\t    },\n44\t    flow: ['implement', 'verify', { loop: ['retry', 'verify'] }],\n45\t  };\n46\t}\n47\t\n48\t// --- Tests ---\n49\t\n50\tdescribe('validateWorkflowSchema', () => {\n51\t  describe('valid workflows', () => {\n52\t    it('accepts a minimal valid workflow (AC #1)', () => {\n53\t      const result = validateWorkflowSchema(minimalValidWorkflow());\n54\t      expect(result.valid).toBe(true);\n55\t      expect(result.errors).toEqual([]);\n56\t    });\n57\t\n58\t    it('accepts a full workflow with all optional fields (AC #9)', () => {\n59\t      const result = validateWorkflowSchema(fullValidWorkflow());\n60\t      expect(result.valid).toBe(true);"}]},"parent_t