tectAppType(testDir, 'python')).toBe('agent');\n   332→  });\n   333→\n   334→  it('returns \"agent\" for Python project with traceloop-sdk', () => {\n   335→    writeFileSync(join(testDir, 'requirements.txt'), 'traceloop-sdk>=0.5.0');\n   336→    expect(detectAppType(testDir, 'python')).toBe('agent');\n   337→  });\n   338→\n   339→  // --- Agent takes priority over web/cli ---\n   340→  it('agent takes priority over web when both signals present', () => {\n   341→    writeFileSync(\n   342→      join(testDir, 'package.json'),\n   343→      JSON.stringify({\n   344→        name: 'ai-dashboard',\n   345→        dependencies: { react: '^18.0.0', openai: '^4.0.0' },\n   346→      }),\n   347→    );\n   348→    expect(detectAppType(testDir, 'nodejs')).toBe('agent');\n   349→  });\n   350→\n   351→  it('agent takes priority over cli when both signals present', () => {\n   352→    writeFileSync(\n   353→      join(testDir, 'package.json'),\n   354→      JSON.stringify({\n   355→        name: 'ai-cli',\n   356→        bin: { 'ai-cli': './dist/cli.js' },\n   357→        dependencies: { anthropic: '^0.20.0' },\n   358→      }),\n   359→    );\n   360→    expect(detectAppType(testDir, 'nodejs')).toBe('agent');\n   361→  });\n   362→\n   363→  // --- Server detection ---\n   364→  it('returns \"server\" for Node.js project with start script and no framework deps', () => {\n   365→    writeFileSync(\n   366→      join(testDir, 'package.json'),\n   367→      JSON.stringify({ name: 'my-server', scripts: { start: 'node server.js' } }),\n   368→    );\n   369→    expect(detectAppType(testDir, 'nodejs')).toBe('server');\n   370→  });\n   371→\n   372→  it('returns \"server\" for Python project with flask but no templates dir', () => {\n   373→    writeFileSync(join(testDir, 'requirements.txt'), 'flask>=2.0');\n   374→    expect(detectAppType(testDir, 'python')).toBe('server');\n   375→  });\n   376→\n   377→  it('returns \"server\" for Python project with app.py entry point', () =>