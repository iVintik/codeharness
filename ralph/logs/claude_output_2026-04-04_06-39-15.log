{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01D1eese4KcFU4FCjwLtK5sK","type":"tool_result","content":"1\t/**\n2\t * Lane — Ink component that renders a single epic lane's status display.\n3\t *\n4\t * Shows epic title, current story + phase, story progress bar,\n5\t * and driver name + cost/time. Pure presentational component.\n6\t *\n7\t * @see Story 20.1: Lane Container & Lane Components\n8\t */\n9\t\n10\timport React from 'react';\n11\timport { Text, Box } from 'ink';\n12\t\n13\t// --- Types ---\n14\t\n15\texport type StoryProgressStatus = 'done' | 'in-progress' | 'pending';\n16\t\n17\texport interface StoryProgressEntry {\n18\t  key: string;\n19\t  status: StoryProgressStatus;\n20\t}\n21\t\n22\texport interface LaneProps {\n23\t  /** Epic identifier (e.g., \"10\"). */\n24\t  epicId: string;\n25\t  /** Human-readable epic title (e.g., \"Driver Interface\"). */\n26\t  epicTitle: string;\n27\t  /** Current story key (e.g., \"10-3\"). */\n28\t  currentStory: string | null;\n29\t  /** Current phase (e.g., \"dev\", \"verify\"). */\n30\t  phase: string | null;\n31\t  /** Acceptance criteria progress (e.g., \"4/9\"). */\n32\t  acProgress: string | null;\n33\t  /** Progress entries for all stories in this epic. */\n34\t  storyProgressEntries: StoryProgressEntry[];\n35\t  /** Driver name (e.g., \"claude-code\"). */\n36\t  driver: string | null;\n37\t  /** Total cost in USD for this lane. */\n38\t  cost: number | null;\n39\t  /** Elapsed time in milliseconds. */\n40\t  elapsedTime: number | null;\n41\t  /** Lane index (1-based for display). */\n42\t  laneIndex?: number;\n43\t}\n44\t\n45\t/** Format cost as $X.XX, or `--` for null. */\n46\texport function formatLaneCost(cost: number | null): string {\n47\t  if (cost == null) return '--';\n48\t  return `$${cost.toFixed(2)}`;\n49\t}\n50\t\n51\t/** Format elapsed time: Xh Xm for >=60min, Xm for >=1min, Xs for <1min, `--` for null. */\n52\texport function formatLaneElapsed(ms: number | null): string {\n53\t  if (ms == null) return '--';\n54\t  const totalSeconds = Math.round(ms / 1000);\n55\t  const minutes = Math.floor(totalSeconds / 60);\n56\t  if (minutes >= 60) {\n57\t    const hours = Math.floor(minutes / 60);\n58\t    const remainingMinutes = minutes % 60;\n59\t    return `${hours}h ${remainingMinutes}m`;\n60\t  }\n61\t  if (minutes >= 1) {\n62\t    return `${minutes}m`;\n63\t  }\n64\t  return `${totalSeconds}s`;\n65\t}\n66\t\n67\t/** Render the story progress bar: ✓ done, ◆ in-progress, ○ pending. */\n68\tfunction StoryProgressBar({ entries }: { entries: StoryProgressEntry[] }) {\n69\t  if (entries.length === 0) return null;\n70\t\n71\t  const items: React.ReactNode[] = [];\n72\t  for (let i = 0; i < entries.length; i++) {\n73\t    const entry = entries[i];\n74\t    if (i > 0) items.push(<Text key={`sp-${i}`}>{' '}</Text>);\n75\t\n76\t    switch (entry.status) {\n77\t      case 'done':\n78\t        items.push(<Text key={`s-${i}`} color=\"green\">{`✓ ${entry.key}`}</Text>);\n79\t        break;\n80\t      case 'in-progress':\n81\t        items.push(<Text key={`s-${i}`} color=\"yellow\">{`◆ ${entry.key}`}</Text>);\n82\t        break;\n83\t      case 'pending':\n84\t        items.push(<Text key={`s-${i}`} dimColor>{`○ ${entry.key}`}</Text>);\n85\t        break;\n86\t    }\n87\t  }\n88\t\n89\t  return <Text> {items}</Text>;\n90\t}\n91\t\n92\t/** Single lane display component. */\n93\texport function Lane(props: LaneProps) {\n94\t  const {\n95\t    epicId,\n96\t    epicTitle,\n97\t    currentStory,\n98\t    phase,\n99\t    acProgress,\n100\t    storyProgressEntries,\n101\t    driver,\n102\t    cost,\n103\t    elapsedTime,\n104\t    laneIndex,\n105\t  } = props;\n106\t\n107\t  const laneLabel = laneIndex != null ? `Lane ${laneIndex}: ` : '';\n108\t  const titleLine = `${laneLabel}Epic ${epicId} \\u2014 ${epicTitle}`;\n109\t\n110\t  const storyParts: string[] = [];\n111\t  if (currentStory) storyParts.push(currentStory);\n112\t  if (phase) storyParts.push(`\\u25C6 ${phase}`);\n113\t  if (acProgress) storyParts.push(`(AC ${acProgress})`);\n114\t  const storyLine = storyParts.length > 0 ? ` ${storyParts.join(' ')}` : null;\n115\t\n116\t  const driverLine = ` ${driver ?? 'unknown'} | ${formatLaneCost(cost)} / ${formatLaneElapsed(elapsedTime)}`;\n117\t\n118\t  return (\n119\t    <Box flexDirection=\"column\">\n120\t      <Text bold>{titleLine}</Text>\n121\t      {storyLine && <Text>{storyLine}</Text>}\n122\t      <StoryProgressBar entries={storyProgressEntries} />\n123\t      <Text dimColor>{driverLine}</Text>\n124\t    </Box>\n125\t  );\n126\t}\n127\t"}]},"parent_tool_use_id":"toolu_01Lyf5tpvBU7eZNwMupgDFgG","session_id":"7e3ded59-6184-4f8b-8f55-ba5e63dae51f","uuid":"c755890d-61b5-4f89-b785-93b92bf16fd6","timestamp":"2026-04-04T02:45:48.304Z"}
