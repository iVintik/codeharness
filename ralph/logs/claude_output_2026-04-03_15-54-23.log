{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B1RzQ1nehBfC9A1U7u9NRP","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { join } from 'node:path';\n3\timport { parse } from 'yaml';\n4\timport { warn } from './output.js';\n5\timport { DispatchError } from './agent-dispatch.js';\n6\timport type { DispatchErrorCode } from './agent-dispatch.js';\n7\t// Note: dispatchAgent is no longer imported — dispatch goes through the driver factory\n8\timport { getDriver } from './agents/drivers/factory.js';\n9\timport { resolveModel } from './agents/model-resolver.js';\n10\timport type { DispatchOpts, DriverHealth, OutputContract } from './agents/types.js';\n11\timport type { ResultEvent, ToolStartEvent } from './agents/stream-parser.js';\n12\timport type { SubagentDefinition } from './agent-resolver.js';\n13\timport type { ResolvedWorkflow, ResolvedTask, FlowStep, LoopBlock } from './workflow-parser.js';\n14\timport {\n15\t  readWorkflowState,\n16\t  writeWorkflowState,\n17\t} from './workflow-state.js';\n18\timport { buildPromptWithContractContext, writeOutputContract } from './agents/output-contract.js';\n19\timport type { WorkflowState, TaskCheckpoint } from './workflow-state.js';\n20\timport { createIsolatedWorkspace } from './source-isolation.js';\n21\timport { generateTraceId, formatTracePrompt, recordTraceId } from './trace-id.js';\n22\timport { resolveSessionId, recordSessionId } from './session-manager.js';\n23\timport type { SessionLookupKey } from './session-manager.js';\n24\timport { parseVerdict, VerdictParseError } from './verdict-parser.js';\n25\timport type { EvaluatorVerdict } from './verdict-parser.js';\n26\timport { evaluateProgress } from './circuit-breaker.js';\n27\t\n28\t// Re-export EvaluatorVerdict for downstream consumers that import from workflow-engine\n29\texport type { EvaluatorVerdict } from './verdict-parser.js';\n30\texport { parseVerdict } from './verdict-parser.js';\n31\t\n32\t// --- Interfaces ---\n33\t\n34\t/**\n35\t * Configuration for the workflow engine.\n36\t */\n37\texport interface EngineConfig {\n38\t  /** The resolved workflow with tasks and flow steps. */\n39\t  workflow: ResolvedWorkflow;\n40\t  /** Pre-compiled agent definitions keyed by agent name. */\n41\t  agents: Record<string, SubagentDefinition>;\n42\t  /** Path to sprint-status.yaml for work item discovery. */\n43\t  sprintStatusPath: string;\n44\t  /** Optional path to issues.yaml for additional work items. */\n45\t  issuesPath?: string;\n46\t  /** Unique identifier for this engine run. */\n47\t  runId: string;\n48\t  /** Project root directory. Defaults to process.cwd(). */\n49\t  projectDir?: string;\n50\t  /** Maximum loop iterations before termination. Defaults to 5. */\n51\t  maxIterations?: number;\n52\t}\n53\t\n54\t/**\n55\t * Result returned by executeWorkflow().\n56\t */\n57\texport interface EngineResult {\n58\t  /** Whether the workflow completed without errors. */\n59\t  success: boolean;\n60\t  /** Number of task dispatches completed. */\n61\t  tasksCompleted: number;\n62\t  /** Number of work items (stories/issues) processed. */\n63\t  storiesProcessed: number;\n64\t  /** Errors encountered during execution. */\n65\t  errors: EngineError[];\n66\t  /** Wall-clock duration of the entire workflow in milliseconds. */\n67\t  durationMs: number;\n68\t}\n69\t\n70\t/**\n71\t * Structured error recorded during workflow execution.\n72\t */\n73\texport interface EngineError {\n74\t  taskName: string;\n75\t  storyKey: string;\n76\t  code: string;\n77\t  message: string;\n78\t}\n79\t\n80\t/**\n81\t * A work item (story or issue) ready for execution.\n82\t */\n83\texport interface WorkItem {\n84\t  key: string;\n85\t  title?: string;\n86\t  source: 'sprint' | 'issues';\n87\t}\n88\t\n89\t// --- Constants ---\n90\t\n91\t/** Sentinel story key for per-run tasks. */\n92\texport const PER_RUN_SENTINEL = '__run__';\n93\t\n94\t/** DispatchError codes that should halt execution immediately. */\n95\tconst HALT_ERROR_CODES = new Set(['RATE_LIMIT', 'NETWORK', 'SDK_INIT']);\n96\t\n97\t/** Default maximum loop iterations before termination. */\n98\tconst DEFAULT_MAX_ITERATIONS = 5;\n99\t\n100\t// --- Crash Recovery: Task Completion Check ---"}]},"parent_tool_use_id":"toolu_01UsAm2qXT84D1u4sW8gSAmJ","session_id":"a29ee53b-c2b0-4802-9455-7215112648b1","uuid":"195e8107-2784-4ee0-87af-77b7ee14af25","timestamp":"2026-04-03T11:58:09.618Z"}
