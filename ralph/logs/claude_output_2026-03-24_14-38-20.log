   53→      lineCoverage: null,\n    54→    },\n    55→    run: {\n    56→      active: false,\n    57→      startedAt: null,\n    58→      iteration: 0,\n    59→      cost: 0,\n    60→      completed: [],\n    61→      failed: [],\n    62→      currentStory: null,\n    63→      currentPhase: null,\n    64→      lastAction: null,\n    65→      acProgress: null,\n    66→    },\n    67→    actionItems: [],\n    68→  };\n    69→}\n    70→\n    71→/** Return a default StoryState */\n    72→function defaultStoryState(): StoryState {\n    73→  return {\n    74→    status: 'backlog',\n    75→    attempts: 0,\n    76→    lastAttempt: null,\n    77→    lastError: null,\n    78→    proofPath: null,\n    79→    acResults: null,\n    80→  };\n    81→}\n    82→\n    83→/**\n    84→ * Write state to disk atomically: write to tmp, then rename.\n    85→ */\n    86→export function writeStateAtomic(state: SprintState): Result<void> {\n    87→  try {\n    88→    const data = JSON.stringify(state, null, 2) + '\\n';\n    89→    const tmp = tmpPath();\n    90→    const final = statePath();\n    91→    writeFileSync(tmp, data, 'utf-8');\n    92→    renameSync(tmp, final);\n    93→    return ok(undefined);\n    94→  } catch (err: unknown) {\n    95→    const msg = err instanceof Error ? err.message : String(err);\n    96→    return fail(`Failed to write sprint state: ${msg}`);\n    97→  }\n    98→}\n    99→\n   100→/**\n   101→ * Read and parse sprint-state.json.\n   102→ * If the file does not exist, attempt migration from old files.\n   103→ * If no old files exist either, return defaultState().\n   104→ * Automatically migrates v1 state to v2.\n   105→ */\n   106→export function getSprintState(): Result<SprintState> {\n   107→  const fp = statePath();\n   108→\n   109→  if (existsSync(fp)) {\n   110→    try {\n   111→      const raw = readFileSync(fp, 'utf-8');\n   112→      const parsed = JSON.parse(raw) as Record<string, unknown>;\n   113→      const version = parsed.version as number | undefined;\n   114→\n   115→      // Already v2 — merge with defaults and return\n   116→      if (version === 2) {\n   117→        const defaults = defaultState();\n   118→        const run = parsed.run as Record<string, unknown> | undefined;\n   119→        const sprint = parsed.sprint as Record<string, unknown> | undefined;\n   120→        const session = parsed.session as Record<string, unknown> | undefined;\n   121→        const observability = parsed.observability as Record<string, unknown> | undefined;\n   122→        const state: SprintState = {\n   123→          ...(parsed as unknown as SprintState),\n   124→          sprint: {\n   125→            ...defaults.sprint,\n   126→            ...(sprint as unknown as SprintState['sprint']),\n   127→          },\n   128→          run: {\n   129→            ...defaults.run,\n   130→            ...(run as unknown as SprintState['run']),\n   131→          },\n   132→          session: {\n   133→            ...defaults.session,\n   134→            ...(session as unknown as SprintState['session']),\n   135→          },\n   136→          observability: {\n   137→            ...defaults.observability,\n   138→            ...(observability as unknown as SprintState['observability']),\n   139→          },\n   140→          retries: (parsed.retries as Record<string, number>) ?? {},\n   141→          flagged: (parsed.flagged as string[]) ?? [],\n   142→          epics: (parsed.epics as Record<string, import('../../types/state.js').EpicState>) ?? {},\n   143→        };\n   144→        return ok(state);\n   145→      }\n   146→\n   147→      // v1 or missing version — migrate to v2\n   148→      const v1State = parsed as unknown as import('../../types/state.js').SprintStateV1;\n   149→      const migrated = migrateV1ToV2(v1State);\n   150→      const writeResult = writeStateAtomic(migrated);\n   151→      if (!writeResult.success) {\n   152→        return fail(writeResult.error);\n   153→      }\n   154→      return ok(migrated);\n   155→    } catch (err: unknown) {\n   156→      const msg = err instanceof Error ? err.message : String(err);\n   157→      return fail(`Failed to read sprint state: ${msg}`);\n   158→    }\n   159→  }\n   160→\n   161→  // No sprint-state.json — try migration from old scattered files\n   162→  const migrationResult = migrateFromOldFormat();\n   163→  if (migrationResult.success) {\n   164→    return migrationResult;\n   165→  }\n   166→\n   167→  // Migration found nothing or failed — return default\n   168→  return ok(defaultState());\n   169→}\n   170→\n   171→/** Recompute sprint summary counts from story data */\n   172→export function computeSprintCounts(\n   173→  stories: Record<string, StoryState>,\n   174→): SprintState['sprint'] {\n   175→  let total = 0;\n   176→  let done = 0;\n   177→  let failed = 0;\n   178→  let blocked = 0;\n   179→  let inProgress: string | null = null;\n   180→\n   181→  for (const [key, story] of Object.entries(stories)) {\n   182→    total++;\n   183→    if (story.status === 'done') done++;\n   184→    else if (story.status === 'failed') failed++;\n   185→    else if (story.status === 'blocked') blocked++;\n   186→    else if (story.status === 'in-progress') inProgress = key;\n   187→  }\n   188→\n   189→  return { total, done, failed, blocked, inProgress };\n   190→}\n   191→\n   192→/**\n   193→ * Update a single story's status in sprint-state.json.\n   194→ * Reads current state, merges update, writes atomically.\n   195→ */\n   196→export function updateStoryStatus(\n   197→  key: string,\n   198→  status: StoryStatus,\n   199→  detail?: StoryDetail,\n   200→): Result<void> {\n   201→  const stateResult = getSprintState();\n   202→  if (!stateResult.success) {\n   203→    return fail(stateResult.error);\n   204→  }\n   205→\n   206→  const current = stateResult.data;\n   207→  const existingStory = current.stories[key] ?? defaultStoryState();\n   208→\n   209→  const isNewAttempt = status === 'in-progress';\n   210→\n   211→  const updatedStory: StoryState = {\n   212→    ...existingStory,\n   213→    status,\n   214→    attempts: isNewAttempt\n   215→      ? existingStory.attempts + 1\n   216→      : existingStory.attempts,\n   217→    lastAttempt: isNewAttempt\n   218→      ? new Date().toISOString()\n   219→      : existingStory.lastAttempt,\n   220→    lastError: detail?.error ?? existingStory.lastError,\n   221→    proofPath: detail?.proofPath ?? existingStory.proofPath,\n   222→    acResults: existingStory.acResults,\n   223→  };\n   224→\n   225→  const updatedStories = { ...current.stories, [key]: updatedStory };\n   226→  const updatedSprint = computeSprintCounts(updatedStories);\n   227→\n   228→  const updatedState: SprintState = {\n   229→    ...current,\n   230→    sprint: updatedSprint,\n   231→    stories: updatedStories,\n   232→  };\n   233→\n   234→  return writeStateAtomic(updatedState);\n   235→}\n   236→\n   237→/**\n   238→ * Update live run progress fields in sprint-state.json.\n   239→ * Only provided fields are updated; omitted fields retain their current values.\n   240→ */\n   241→export function updateRunProgress(update: RunProgressUpdate): Result<void> {\n   242→  const stateResult = getSprintState();\n   243→  if (!stateResult.success) {\n   244→    return fail(stateResult.error);\n   245→  }\n   246→\n   247→  const current = stateResult.data;\n   248→  const updatedRun = {\n   249→    ...current.run,\n   250→    ...(update.currentStory !== undefined && { currentStory: update.currentStory }),\n   251→    ...(update.currentPhase !== undefined && { currentPhase: update.currentPhase }),\n   252→    ...(update.lastAction !== undefined && { lastAction: update.lastAction }),\n   253→    ...(update.acProgress !== undefined && { acProgress: update.acProgress }),\n   254→  };\n   255→\n   256→  const updatedState: SprintState = {\n   257→    ...current,\n   258→    run: updatedRun,\n   259→  };\n   260→\n   261→  return writeStateAtomic(updatedState);\n   262→}\n   263→\n   264→/**\n   265→ * Clear all live run progress fields to null.\n   266→ * Called when a story completes or fails.\n   267→ */\n   268→export function clearRunProgress(): Result<void> {\n   269→  const stateResult = getSprintState();\n   270→  if (!stateResult.success) {\n   271→    return fail(stateResult.error);\n   272→  }\n   273→\n   274→  const current = stateResult.data;\n   275→  const updatedState: SprintState = {\n   276→    ...current,\n   277→    run: {\n   278→      ...current.run,\n   279→      currentStory: null,\n   280→      currentPhase: null,\n   281→      lastAction: null,\n   282→      acProgress: null,\n   283→    },\n   284→  };\n   285→\n   286→  return writeStateAtomic(updatedState);\n   287→}\n   288→"}]},"parent_tool_use_id":null,"session_id":"0e449f80-823c-4489-a784-b43b6c7039d6","uuid":"7dbb70cf-524f-4eb9-acc9-dee4d964e518","timestamp":"2026-03-24T10:51:38.520Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ivintik/dev/personal/codeharness/src/modules/sprint/state.ts","content":"/**\n * Sprint state — read/write unified sprint-state.json with atomic writes.\n */\n\nimport { readFileSync, writeFileSync, renameSync, existsSync } from 'node:fs';\nimport { join } from 'node:path';\nimport { ok, fail } from '../../types/result.js';\nimport type { Result } from '../../types/result.js';\nimport type { SprintState, SprintStateAny, StoryStatus, StoryState } from '../../types/state.js';\nimport type { StoryDetail, RunProgressUpdate } from './types.js';\nimport { migrateFromOldFormat, migrateV1ToV2 } from './migration.js';\n\n/** Resolve project root (directory containing package.json) */\nfunction projectRoot(): string {\n  return process.cwd();\n}\n\n/** Path to the sprint state file */\nexport function statePath(): string {\n  return join(projectRoot(), 'sprint-state.json');\n}\n\n/** Path to the temporary file used for atomic writes */\nfunction tmpPath(): string {\n  return join(projectRoot(), '.sprint-state.json.tmp');\n}\n\n/** Return an empty default SprintState (v2) */\nexport function defaultState(): SprintState {\n  return {\n    version: 2,\n    sprint: {\n      total: 0,\n      done: 0,\n      failed: 0,\n      blocked: 0,\n      inProgress: null,\n    },\n    stories: {},\n    retries: {},\n    flagged: [],\n    epics: {},\n    session: {\n      active: false,\n      startedAt: null,\n      iteration: 0,\n      elapsedSeconds: 0,\n    },\n    observability: {\n      statementCoverage: null,\n      branchCoverage: null,\n      functionCoverage: null,\n      lineCoverage: null,\n    },\n    run: {\n      active: false,\n      startedAt: null,\n      iteration: 0,\n      cost: 0,\n      completed: [],\n      failed: [],\n      currentStory: null,\n      currentPhase: null,\n      lastAction: null,\n      acProgress: null,\n    },\n    actionItems: [],\n  };\n}\n\n/** Return a default StoryState */\nfunction defaultStoryState(): StoryState {\n  return {\n    status: 'backlog',\n    attempts: 0,\n    lastAttempt: null,\n    lastError: null,\n    proofPath: null,\n    acResults: null,\n  };\n}\n\n/**\n * Write state to disk atomically: write to tmp, then rename.\n */\nexport function writeStateAtomic(state: SprintState): Result<void> {\n  try {\n    const data = JSON.stringify(state, null, 2) + '\\n';\n    const tmp = tmpPath();\n    const final = statePath();\n    writeFileSync(tmp, data, 'utf-8');\n    renameSync(tmp, final);\n    return ok(undefined);\n  } catch (err: unknown) {\n    const msg = err instanceof Error ? err.message : String(err);\n    return fail(`Failed to write sprint state: ${msg}`);\n  }\n}\n\n/**\n * Read and parse sprint-state.json.\n * If the file does not exist, attempt migration from old files.\n * If no old files exist either, return defaultState().\n * Automatically migrates v1 state to v2.\n */\nexport function getSprintState(): Result<SprintState> {\n  const fp = statePath();\n\n  if (existsSync(fp)) {\n    try {\n      const raw = readFileSync(fp, 'utf-8');\n      const parsed = JSON.parse(raw) as Record<string, unknown>;\n      const version = parsed.version as number | undefined;\n\n      // Already v2 — merge with defaults and return\n      if (version === 2) {\n        const defaults = defaultState();\n        const run = parsed.run as Record<string, unknown> | undefined;\n        const sprint = parsed.sprint as Record<string, unknown> | undefined;\n        const session = parsed.session as Record<string, unknown> | undefined;\n        const observability = parsed.observability as Record<string, unknown> | undefined;\n        const state: SprintState = {\n          ...(parsed as unknown as SprintState),\n          sprint: {\n            ...defaults.sprint,\n            ...(sprint as unknown as SprintState['sprint']),\n          },\n          run: {\n            ...defaults.run,\n            ...(run as unknown as SprintState['run']),\n          },\n          session: {\n            ...defaults.session,\n            ...(session as unknown as SprintState['session']),\n          },\n          observability: {\n            ...defaults.observability,\n            ...(observability as unknown as SprintState['observability']),\n          },\n          retries: (parsed.retries as Record<string, number>) ?? {},\n          flagged: (parsed.flagged as string[]) ?? [],\n          epics: (parsed.epics as Record<string, import('../../types/state.js').EpicState>) ?? {},\n        };\n        return ok(state);\n      }\n\n      // v1 or missing version — migrate to v2\n      const v1State = parsed as unknown as import('../../types/state.js').SprintStateV1;\n      const migrated = migrateV1ToV2(v1State);\n      const writeResult = writeStateAtomic(migrated);\n      if (!writeResult.success) {\n        return fail(writeResult.error);\n      }\n      return ok(migrated);\n    } catch (err: unknown) {\n      const msg = err instanceof Error ? err.message : String(err);\n      return fail(`Failed to read sprint state: ${msg}`);\n    }\n  }\n\n  // No sprint-state.json — try migration from old scattered files\n  const migrationResult = migrateFromOldFormat();\n  if (migrationResult.success) {\n    return migrationResult;\n  }\n\n  // Migration found nothing or failed — return default\n  return ok(defaultState());\n}\n\n/** Recompute sprint summary counts from story data */\nexport function computeSprintCounts(\n  stories: Record<string, StoryState>,\n): SprintState['sprint'] {\n  let total = 0;\n  let done = 0;\n  let failed = 0;\n  let blocked = 0;\n  let inProgress: string | null = null;\n\n  for (const [key, story] of Object.entries(stories)) {\n    total++;\n    if (story.status === 'done') done++;\n    else if (story.status === 'failed') failed++;\n    else if (story.status === 'blocked') blocked++;\n    else if (story.status === 'in-progress') inProgress = key;\n  }\n\n  return { total, done, failed, blocked, inProgress };\n}\n\n/**\n * Update a single story's status in sprint-state.json.\n * Reads current state, merges update, writes atomically.\n */\nexport function updateStoryStatus(\n  key: string,\n  status: StoryStatus,\n  detail?: StoryDetail,\n): Result<void> {\n  const stateResult = getSprintState();\n  if (!stateResult.success) {\n    return fail(stateResult.error);\n  }\n\n  const current = stateResult.data;\n  const existingStory = current.stories[key] ?? defaultStoryState();\n\n  const isNewAttempt = status === 'in-progress';\n\n  const updatedStory: StoryState = {\n    ...existingStory,\n    status,\n    attempts: isNewAttempt\n      ? existingStory.attempts + 1\n      : existingStory.attempts,\n    lastAttempt: isNewAttempt\n      ? new Date().toISOString()\n      : existingStory.lastAttempt,\n    lastError: detail?.error ?? existingStory.lastError,\n    proofPath: detail?.proofPath ?? existingStory.proofPath,\n    acResults: existingStory.acResults,\n  };\n\n  const updatedStories = { ...current.stories, [key]: updatedStory };\n  const updatedSprint = computeSprintCounts(updatedStories);\n\n  const updatedState: SprintState = {\n    ...current,\n    sprint: updatedSprint,\n    stories: updatedStories,\n  };\n\n  return writeStateAtomic(updatedState);\n}\n\n/**\n * Update live run progress fields in sprint-state.json.\n * Only provided fields are updated; omitted fields retain their current values.\n */\nexport function updateRunProgress(update: RunProgressUpdate): Result<void> {\n  const stateResult = getSprintState();\n  if (!stateResult.success) {\n    return fail(stateResult.error);\n  }\n\n  const current = stateResult.data;\n  const updatedRun = {\n    ...current.run,\n    ...(update.currentStory !== undefined && { currentStory: update.currentStory }),\n    ...(update.currentPhase !== undefined && { currentPhase: update.currentPhase }),\n    ...(update.lastAction !== undefined && { lastAction: update.lastAction }),\n    ...(update.acProgress !== undefined && { acProgress: update.acProgress }),\n  };\n\n  const updatedState: SprintState = {\n    ...current,\n    run: updatedRun,\n  };\n\n  return writeStateAtomic(updatedState);\n}\n\n/**\n * Clear all live run progress fields to null.\n * Called when a story completes or fails.\n */\nexport function clearRunProgress(): Result<void> {\n  const stateResult = getSprintState();\n  if (!stateResult.success) {\n    return fail(stateResult.error);\n  }\n\n  const current = stateResult.data;\n  const updatedState: SprintState = {\n    ...current,\n    run: {\n      ...current.run,\n      currentStory: null,\n      currentPhase: null,\n      lastAction: null,\n      acProgress: null,\n    },\n  };\n\n  return writeStateAtomic(updatedState);\n}\n","numLines":288,"startLine":1,"totalLines":288}}}
