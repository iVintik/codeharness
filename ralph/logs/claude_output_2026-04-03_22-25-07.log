{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GDN45DEitEkfAtbSRvTBg1","type":"tool_result","content":"830\t            writeWorkflowState(currentState, projectDir);\n831\t          }\n832\t        }\n833\t        continue;\n834\t      }\n835\t\n836\t      // --- Agent task path in loop ---\n837\t      const definition = config.agents[task.agent];\n838\t      if (!definition) {\n839\t        warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n840\t        continue;\n841\t      }\n842\t\n843\t      if (task.scope === 'per-story') {\n844\t        // Determine which items to dispatch for\n845\t        const itemsToRetry = lastVerdict ? getFailedItems(lastVerdict, workItems) : workItems;\n846\t\n847\t        for (const item of itemsToRetry) {\n848\t          // Skip if already completed for this iteration (crash recovery — AC #4)\n849\t          if (isLoopTaskCompleted(currentState, taskName, item.key, currentState.iteration)) {\n850\t            warn(`workflow-engine: skipping completed task ${taskName} for ${item.key}`);\n851\t            continue;\n852\t          }\n853\t\n854\t          // Build prompt: inject findings if we have a previous verdict\n855\t          const prompt = lastVerdict\n856\t            ? buildRetryPrompt(item.key, lastVerdict.findings)\n857\t            : undefined;\n858\t\n859\t          try {\n860\t            const dispatchResult = await dispatchTaskWithResult(\n861\t              task, taskName, item.key, definition, currentState, config, prompt, lastOutputContract ?? undefined,\n862\t            );\n863\t            currentState = dispatchResult.updatedState;\n864\t            lastOutputContract = dispatchResult.contract;\n865\t            propagateVerifyFlags(taskName, dispatchResult.contract, projectDir);\n866\t            accumulatedCostUsd += dispatchResult.contract?.cost_usd ?? 0;\n867\t            tasksCompleted++;\n868\t          } catch (err: unknown) {\n869\t            const engineError = handleDispatchError(err, taskName, item.key);\n870\t            errors.push(engineError);\n871\t            currentState = recordErrorInState(currentState, taskName, item.key, engineError);\n872\t            writeWorkflowState(currentState, projectDir);\n873\t\n874\t            if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n875\t              haltedInLoop = true;\n876\t              break;\n877\t            }\n878\t            continue;\n879\t          }\n880\t        }\n881\t\n882\t        if (haltedInLoop) break;\n883\t      } else {\n884\t        // per-run task (e.g., verify)\n885\t        // Skip if already completed for this iteration (crash recovery — AC #4)\n886\t        if (isLoopTaskCompleted(currentState, taskName, PER_RUN_SENTINEL, currentState.iteration)) {\n887\t          warn(`workflow-engine: skipping completed task ${taskName} for ${PER_RUN_SENTINEL}`);\n888\t          continue;\n889\t        }\n890\t\n891\t        try {\n892\t          // We need the dispatch result output to parse verdict\n893\t          const dispatchResult = await dispatchTaskWithResult(\n894\t            task, taskName, PER_RUN_SENTINEL, definition, currentState, config,\n895\t            undefined, lastOutputContract ?? undefined,\n896\t          );\n897\t          currentState = dispatchResult.updatedState;\n898\t          lastOutputContract = dispatchResult.contract;\n899\t          propagateVerifyFlags(taskName, dispatchResult.contract, projectDir);\n900\t          accumulatedCostUsd += dispatchResult.contract?.cost_usd ?? 0;\n901\t          tasksCompleted++;\n902\t\n903\t          // Attempt to parse verdict from output with retry semantics (story 6-2)\n904\t          let verdict: EvaluatorVerdict | null = null;\n905\t          try {\n906\t            verdict = parseVerdict(dispatchResult.output);\n907\t          } catch (parseErr: unknown) {\n908\t            if (parseErr instanceof VerdictParseError && parseErr.retryable) {\n909\t              // Re-dispatch evaluator for one retry attempt\n910\t              warn(`workflow-engine: verdict parse failed, retrying evaluator for ${taskName}`);\n911\t              try {\n912\t                const retryResult = await dispatchTaskWithResult(\n913\t                  task, taskName, PER_RUN_SENTINEL, definition, currentState, config,\n914\t                  undefined, lastOutputContract ?? undefined,\n915\t                );\n916\t                currentState = retryResult.updatedState;\n917\t                lastOutputContract = retryResult.contract;\n918\t                propagateVerifyFlags(taskName, retryResult.contract, projectDir);\n919\t                tasksCompleted++;\n920\t                verdict = parseVerdict(retryResult.output);\n921\t              } catch { // IGNORE: retry failed — fall back to all-UNKNOWN verdict\n922\t                // Second failure: generate all-UNKNOWN verdict\n923\t                verdict = buildAllUnknownVerdict(\n924\t                  workItems,\n925\t                  'Evaluator failed to produce valid JSON after retry',\n926\t                );\n927\t              }\n928\t            }\n929\t            // If not a VerdictParseError or not retryable, verdict stays null\n930\t          }\n931\t          lastVerdict = verdict;\n932\t\n933\t          // Record score in state\n934\t          if (verdict) {\n935\t            const score = {\n936\t              iteration: currentState.iteration,\n937\t              passed: verdict.score.passed,\n938\t              failed: verdict.score.failed,\n939\t              unknown: verdict.score.unknown,\n940\t              total: verdict.score.total,\n941\t              timestamp: new Date().toISOString(),\n942\t            };\n943\t            currentState = {\n944\t              ...currentState,\n945\t              evaluator_scores: [...currentState.evaluator_scores, score],\n946\t            };\n947\t          } else {\n948\t            // Parse failure: record all-UNKNOWN score\n949\t            const totalItems = workItems.length;\n950\t            const score = {\n951\t              iteration: currentState.iteration,\n952\t              passed: 0,\n953\t              failed: 0,\n954\t              unknown: totalItems,\n955\t              total: totalItems,\n956\t              timestamp: new Date().toISOString(),\n957\t            };\n958\t            currentState = {\n959\t              ...currentState,\n960\t              evaluator_scores: [...currentState.evaluator_scores, score],\n961\t            };\n962\t          }\n963\t          writeWorkflowState(currentState, projectDir);\n964\t\n965\t          // Circuit breaker: evaluate progress after recording score\n966\t          const cbDecision = evaluateProgress(currentState.evaluator_scores);\n967\t          if (cbDecision.halt) {\n968\t            currentState = {\n969\t              ...currentState,\n970\t              circuit_breaker: {\n971\t                triggered: true,\n972\t                reason: cbDecision.reason,\n973\t                score_history: cbDecision.scoreHistory,\n974\t              },\n975\t            };\n976\t            writeWorkflowState(currentState, projectDir);\n977\t          }\n978\t        } catch (err: unknown) {\n979\t          const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n980\t          errors.push(engineError);\n981\t          currentState = recordErrorInState(currentState, taskName, PER_RUN_SENTINEL, engineError);\n982\t          writeWorkflowState(currentState, projectDir);\n983\t\n984\t          // Clear stale verdict so next iteration retries all items\n985\t          lastVerdict = null;\n986\t\n987\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n988\t            haltedInLoop = true;\n989\t            break;\n990\t          }\n991\t          continue;\n992\t        }\n993\t      }\n994\t    }\n995\t\n996\t    if (haltedInLoop) {\n997\t      return { state: currentState, errors, tasksCompleted, halted: true, lastContract: lastOutputContract };\n998\t    }\n999\t\n1000\t    // 3. Check termination conditions\n1001\t    if (lastVerdict?.verdict === 'pass') {\n1002\t      // Success: loop passes\n1003\t      return { state: currentState, errors, tasksCompleted, halted: false, lastContract: lastOutputContract };\n1004\t    }\n1005\t\n1006\t    if (currentState.iteration >= maxIterations) {\n1007\t      currentState = { ...currentState, phase: 'max-iterations' };\n1008\t      writeWorkflowState(currentState, projectDir);\n1009\t      return { state: currentState, errors, tasksCompleted, halted: false, lastContract: lastOutputContract };\n1010\t    }\n1011\t\n1012\t    if (currentState.circuit_breaker.triggered) {\n1013\t      currentState = { ...currentState, phase: 'circuit-breaker' };\n1014\t      writeWorkflowState(currentState, projectDir);\n1015\t      return { state: currentState, errors, tasksCompleted, halted: false, lastContract: lastOutputContract };\n1016\t    }\n1017\t  }\n1018\t}\n1019\t\n1020\t\n1021\t// --- Driver Health Check ---\n1022\t\n1023\t/** Default timeout for the health check phase (NFR6). */\n1024\tconst HEALTH_CHECK_TIMEOUT_MS = 5000;\n1025\t\n1026\t/**\n1027\t * Run health checks on all unique drivers referenced in a workflow.\n1028\t *\n1029\t * Collects unique driver names from `workflow.tasks`, resolves each via\n1030\t * `getDriver()`, and runs all `healthCheck()` calls concurrently with a\n1031\t * 5-second timeout (NFR6).\n1032\t *\n1033\t * Throws if any driver is unavailable or if the timeout fires.\n1034\t */\n1035\texport async function checkDriverHealth(workflow: ResolvedWorkflow, timeoutMs?: number): Promise<void> {\n1036\t  // 1. Collect unique driver names from all tasks (skip null agent tasks)\n1037\t  const driverNames = new Set<string>();\n1038\t  for (const task of Object.values(workflow.tasks)) {\n1039\t    if (task.agent === null) continue;\n1040\t    driverNames.add(task.driver ?? 'claude-code');\n1041\t  }\n1042\t\n1043\t  // 2. Resolve drivers\n1044\t  const drivers = new Map<string, ReturnType<typeof getDriver>>();\n1045\t  for (const name of driverNames) {\n1046\t    drivers.set(name, getDriver(name));\n1047\t  }\n1048\t\n1049\t  // 3. Run health checks concurrently, tracking which drivers responded\n1050\t  interface HealthResult { name: string; health: DriverHealth }\n1051\t  const responded = new Set<string>();\n1052\t  const healthChecks = Promise.all(\n1053\t    [...drivers.entries()].map(async ([name, driver]): Promise<HealthResult> => {\n1054\t      const health = await driver.healthCheck();\n1055\t      responded.add(name);\n1056\t      return { name, health };\n1057\t    }),\n1058\t  );\n1059\t\n1060\t  // 4. Race against timeout (NFR6) — clear timer on success to prevent leaks\n1061\t  const effectiveTimeout = timeoutMs ?? HEALTH_CHECK_TIMEOUT_MS;\n1062\t  let timer: ReturnType<typeof setTimeout>;\n1063\t  const timeoutPromise = new Promise<'timeout'>((resolve) => {\n1064\t    timer = setTimeout(() => resolve('timeout'), effectiveTimeout);\n1065\t  });\n1066\t\n1067\t  const result = await Promise.race([healthChecks, timeoutPromise]);\n1068\t\n1069\t  if (result === 'timeout') {\n1070\t    // Report only the drivers that did NOT respond (AC #6)\n1071\t    const pending = [...driverNames].filter((n) => !responded.has(n));\n1072\t    const names = pending.length > 0 ? pending.join(', ') : [...driverNames].join(', ');\n1073\t    throw new Error(\n1074\t      `Driver health check timed out after ${effectiveTimeout}ms. Drivers that did not respond: ${names}`,\n1075\t    );\n1076\t  }\n1077\t\n1078\t  // Health checks completed before timeout — clear the timer\n1079\t  clearTimeout(timer!);"}]},"parent_tool_use_id":"toolu_01Hody5ZigZ3cTLmGuBw8VE3","session_id":"b6bb3bfc-8778-4f16-a616-88028acc2431","uuid":"baa0b489-8114-4424-baa5-59c864303435","timestamp":"2026-04-03T18:31:53.061Z"}
