{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CNnc79WcmfF1NnepY9qJqM","type":"tool_result","content":"     1→#!/usr/bin/env bats\n     2→# Integration tests for codeharness hook scripts\n     3→# Tests each hook with controlled inputs to verify JSON output, exit codes, and behavior.\n     4→\n     5→load '../test_helper'\n     6→\n     7→HOOKS_DIR=\"$PROJECT_ROOT/hooks\"\n     8→\n     9→setup() {\n    10→    setup_test_dir\n    11→}\n    12→\n    13→teardown() {\n    14→    teardown_test_dir\n    15→}\n    16→\n    17→# Helper: create a state file with configurable session flags\n    18→create_state_with_flags() {\n    19→    local tests_passed=\"${1:-false}\"\n    20→    local coverage_met=\"${2:-false}\"\n    21→    local verification_run=\"${3:-false}\"\n    22→    local logs_queried=\"${4:-false}\"\n    23→    mkdir -p \"$TEST_DIR/.claude\"\n    24→    cat > \"$TEST_DIR/.claude/codeharness.local.md\" << EOF\n    25→---\n    26→harness_version: \"0.1.0\"\n    27→initialized: true\n    28→stack: nodejs\n    29→enforcement:\n    30→  frontend: true\n    31→  database: true\n    32→  api: true\n    33→coverage:\n    34→  target: 100\n    35→  baseline: null\n    36→  current: null\n    37→  tool: c8\n    38→session_flags:\n    39→  logs_queried: ${logs_queried}\n    40→  tests_passed: ${tests_passed}\n    41→  coverage_met: ${coverage_met}\n    42→  verification_run: ${verification_run}\n    43→verification_log: []\n    44→---\n    45→\n    46→# Codeharness State\n    47→EOF\n    48→}\n    49→\n    50→# ============================================================\n    51→# session-start.sh tests\n    52→# ============================================================\n    53→\n    54→@test \"session-start: outputs valid JSON when state file exists\" {\n    55→    create_state_with_flags \"true\" \"true\" \"true\" \"true\"\n    56→    run bash \"$HOOKS_DIR/session-start.sh\"\n    57→    [ \"$status\" -eq 0 ]\n    58→    # Output should be valid JSON\n    59→    echo \"$output\" | python3 -c \"import sys,json; json.load(sys.stdin)\" 2>/dev/null || \\\n    60→    echo \"$output\" | node -e \"JSON.parse(require('fs').readFileSync('/dev/stdin','utf8'))\" 2>/dev/null\n    61→}\n    62→\n    63→@test \"session-start: reports health status in message\" {\n    64→    create_state_with_flags \"false\" \"false\" \"false\" \"false\"\n    65→    run bash \"$HOOKS_DIR/session-start.sh\"\n    66→    [ \"$status\" -eq 0 ]\n    67→    [[ \"$output\" == *\"Harness health:\"* ]]\n    68→    [[ \"$output\" == *\"Docker:\"* ]]\n    69→    [[ \"$output\" == *\"Session flags:\"* ]]\n    70→}\n    71→\n    72→@test \"session-start: outputs info when no state file\" {\n    73→    # No state file created\n    74→    run bash \"$HOOKS_DIR/session-start.sh\"\n    75→    [ \"$status\" -eq 0 ]\n    76→    [[ \"$output\" == *\"not initialized\"* ]]\n    77→    # Verify it's valid JSON\n    78→    echo \"$output\" | python3 -c \"import sys,json; json.load(sys.stdin)\" 2>/dev/null || \\\n    79→    echo \"$output\" | node -e \"JSON.parse(require('fs').readFileSync('/dev/stdin','utf8'))\" 2>/dev/null\n    80→}\n    81→\n    82→@test \"session-start: completes within 500ms\" {\n    83→    create_state_with_flags \"true\" \"true\" \"true\" \"true\"\n    84→    local start_ms=$(($(date +%s) * 1000 + $(date +%N 2>/dev/null | head -c 3 || echo 0)))\n    85→    run bash \"$HOOKS_DIR/session-start.sh\"\n    86→    local end_ms=$(($(date +%s) * 1000 + $(date +%N 2>/dev/null | head -c 3 || echo 0)))\n    87→    local elapsed=$((end_ms - start_ms))\n    88→    [ \"$status\" -eq 0 ]\n    89→    # Allow generous 2000ms for CI environments (500ms is target, but CI can be slow)\n    90→    [ \"$elapsed\" -lt 2000 ]\n    91→}\n    92→\n    93→# ============================================================\n    94→# pre-commit-gate.sh tests\n    95→# ============================================================\n    96→\n    97→@test \"pre-commit-gate: allows when all flags true\" {\n    98→    create_state_with_flags \"true\" \"true\" \"true\" \"true\"\n    99→    run bash -c 'echo \"{\\\"tool_name\\\":\\\"Bash\\\",\\\"tool_input\\\":{\\\"command\\\":\\\"git commit -m test\\\"}}\" | bash '\"$HOOKS_DIR/pre-commit-gate.sh\"\n   100→    [ \"$status\" -eq 0 ]\n   101→    [[ \"$output\" == *'\"decision\": \"allow\"'* ]] || [[ -z \"$output\" ]]\n   102→}\n   103→\n   104→@test \"pre-commit-gate: blocks when tests_passed is false\" {\n   105→    create_state_with_flags \"false\" \"true\" \"true\" \"true\"\n   106→    run bash -c 'echo \"{\\\"tool_name\\\":\\\"Bash\\\",\\\"tool_input\\\":{\\\"command\\\":\\\"git commit -m test\\\"}}\" | bash '\"$HOOKS_DIR/pre-commit-gate.sh\"\n   107→    [ \"$status\" -eq 2 ]\n   108→    [[ \"$output\" == *'\"decision\": \"block\"'* ]]\n   109→    [[ \"$output\" == *\"tests_passed\"* ]]\n   110→}\n   111→\n   112→@test \"pre-commit-gate: blocks when coverage_met is false\" {\n   113→    create_state_with_flags \"true\" \"false\" \"true\" \"true\"\n   114→    run bash -c 'echo \"{\\\"tool_name\\\":\\\"Bash\\\",\\\"tool_input\\\":{\\\"command\\\":\\\"git commit -m test\\\"}}\" | bash '\"$HOOKS_DIR/pre-commit-gate.sh\"\n   115→    [ \"$status\" -eq 2 ]\n   116→    [[ \"$output\" == *'\"decision\": \"block\"'* ]]\n   117→    [[ \"$output\" == *\"coverage_met\"* ]]\n   118→}\n   119→\n   120→@test \"pre-commit-gate: blocks when verification_run is false\" {\n   121→    create_state_with_flags \"true\" \"true\" \"false\" \"true\"\n   122→    run bash -c 'echo \"{\\\"tool_name\\\":\\\"Bash\\\",\\\"tool_input\\\":{\\\"command\\\":\\\"git commit -m test\\\"}}\" | bash '\"$HOOKS_DIR/pre-commit-gate.sh\"\n   123→    [ \"$status\" -eq 2 ]\n   124→    [[ \"$output\" == *'\"decision\": \"block\"'* ]]\n   125→    [[ \"$output\" == *\"verification_run\"* ]]\n   126→}\n   127→\n   128→@test \"pre-commit-gate: allows non-commit commands\" {\n   129→    create_state_with_flags \"false\" \"false\" \"false\" \"false\"\n   130→    run bash -c 'echo \"{\\\"tool_name\\\":\\\"Bash\\\",\\\"tool_input\\\":{\\\"command\\\":\\\"ls -la\\\"}}\" | bash '\"$HOOKS_DIR/pre-commit-gate.sh\"\n   131→    [ \"$status\" -eq 0 ]\n   132→}\n   133→\n   134→@test \"pre-commit-gate: allows when state file missing (fail open)\" {\n   135→    # No state file\n   136→    run bash -c 'echo \"{\\\"tool_name\\\":\\\"Bash\\\",\\\"tool_input\\\":{\\\"command\\\":\\\"git commit -m test\\\"}}\" | bash '\"$HOOKS_DIR/pre-commit-gate.sh\"\n   137→    [ \"$status\" -eq 0 ]\n   138→}\n   139→\n   140→@test \"pre-commit-gate: outputs valid JSON on block\" {\n   141→    create_state_with_flags \"false\" \"false\" \"false\" \"false\"\n   142→    run bash -c 'echo \"{\\\"tool_name\\\":\\\"Bash\\\",\\\"tool_input\\\":{\\\"command\\\":\\\"git commit -m test\\\"}}\" | bash '\"$HOOKS_DIR/pre-commit-gate.sh\"\n   143→    [ \"$status\" -eq 2 ]\n   144→    # Verify output is valid JSON\n   145→    echo \"$output\" | python3 -c \"import sys,json; json.load(sys.stdin)\" 2>/dev/null || \\\n   146→    echo \"$output\" | node -e \"JSON.parse(require('fs').readFileSync('/dev/stdin','utf8'))\" 2>/dev/null\n   147→}\n   148→\n   149→@test \"pre-commit-gate: uses exit 2 for block, not exit 1\" {\n   150→    create_state_with_flags \"false\" \"false\" \"false\" \"false\"\n   151→    run bash -c 'echo \"{\\\"tool_name\\\":\\\"Bash\\\",\\\"tool_input\\\":{\\\"command\\\":\\\"git commit -m test\\\"}}\" | bash '\"$HOOKS_DIR/pre-commit-gate.sh\"\n   152→    [ \"$status\" -eq 2 ]\n   153→}\n   154→\n   155→@test \"pre-commit-gate: completes within 500ms\" {\n   156→    create_state_with_flags \"true\" \"true\" \"true\" \"true\"\n   157→    local start_ms=$(($(date +%s) * 1000 + $(date +%N 2>/dev/null | head -c 3 || echo 0)))\n   158→    run bash -c 'echo \"{\\\"tool_name\\\":\\\"Bash\\\",\\\"tool_input\\\":{\\\"command\\\":\\\"git commit -m test\\\"}}\" | bash '\"$HOOKS_DIR/pre-commit-gate.sh\"\n   159→    local end_ms=$(($(date +%s) * 1000 + $(date +%N 2>/dev/null | head -c 3 || echo 0)))\n   160→    local elapsed=$((end_ms - start_ms))\n   161→    [ \"$status\" -eq 0 ]\n   162→    [ \"$elapsed\" -lt 2000 ]\n   163→}\n   164→\n   165→# ============================================================\n   166→# post-write-check.sh tests\n   167→# ============================================================\n   168→\n   169→@test \"post-write-check: prompts for source code files\" {\n   170→    create_state_with_flags \"false\" \"false\" \"false\" \"false\"\n   171→    run bash -c 'echo \"{\\\"tool_name\\\":\\\"Write\\\",\\\"tool_input\\\":{\\\"file_path\\\":\\\"src/index.ts\\\"}}\" | bash '\"$HOOKS_DIR/post-write-check.sh\"\n   172→    [ \"$status\" -eq 0 ]\n   173→    [[ \"$output\" == *\"OTLP instrumentation\"* ]]\n   174→}\n   175→\n   176→@test \"post-write-check: silent for non-source files\" {\n   177→    create_state_with_flags \"false\" \"false\" \"false\" \"false\"\n   178→    run bash -c 'echo \"{\\\"tool_name\\\":\\\"Write\\\",\\\"tool_input\\\":{\\\"file_path\\\":\\\"README.md\\\"}}\" | bash '\"$HOOKS_DIR/post-write-check.sh\"\n   179→    [ \"$status\" -eq 0 ]\n   180→    [ -z \"$output\" ]\n   181→}\n   182→\n   183→@test \"post-write-check: always prompts for source code (observability is mandatory)\" {\n   184→    create_state_with_flags \"false\" \"false\" \"false\" \"false\"\n   185→    run bash -c 'echo \"{\\\"tool_name\\\":\\\"Write\\\",\\\"tool_input\\\":{\\\"file_path\\\":\\\"src/index.ts\\\"}}\" | bash '\"$HOOKS_DIR/post-write-check.sh\"\n   186→    [ \"$status\" -eq 0 ]\n   187→    [[ \"$output\" == *\"OTLP instrumentation\"* ]]\n   188→}\n   189→\n   190→@test \"post-write-check: silent exit when state file missing\" {\n   191→    run bash -c 'echo \"{\\\"tool_name\\\":\\\"Write\\\",\\\"tool_input\\\":{\\\"file_path\\\":\\\"src/index.ts\\\"}}\" | bash '\"$HOOKS_DIR/post-write-check.sh\"\n   192→    [ \"$status\" -eq 0 ]\n   193→}\n   194→\n   195→@test \"post-write-check: