{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Bve1HRyqWGpSny3eh8w2Bb","type":"tool_result","content":"1\t/**\n2\t * Driver Factory & Registry.\n3\t *\n4\t * Module-singleton registry for AgentDriver instances.\n5\t * Drivers are registered explicitly via registerDriver() — no auto-discovery,\n6\t * no filesystem scanning, no dynamic imports.\n7\t *\n8\t * @see architecture-multi-framework.md — \"Register in factory.ts — never auto-discover\"\n9\t */\n10\t\n11\timport type { AgentDriver } from '../types.js';\n12\t\n13\tconst registry = new Map<string, AgentDriver>();\n14\t\n15\t/**\n16\t * Register an AgentDriver by its `name` property.\n17\t * Throws if a driver with the same name is already registered.\n18\t */\n19\texport function registerDriver(driver: AgentDriver): void {\n20\t  if (!driver || typeof driver.name !== 'string') {\n21\t    throw new Error('registerDriver requires a valid AgentDriver with a string name property.');\n22\t  }\n23\t  if (!driver.name) {\n24\t    throw new Error('Driver name must be a non-empty string.');\n25\t  }\n26\t  if (registry.has(driver.name)) {\n27\t    throw new Error(\n28\t      `Driver '${driver.name}' is already registered. Each driver name must be unique.`,\n29\t    );\n30\t  }\n31\t  registry.set(driver.name, driver);\n32\t}\n33\t\n34\t/**\n35\t * Retrieve a registered AgentDriver by name.\n36\t * Throws with a helpful message listing all registered drivers if not found.\n37\t */\n38\texport function getDriver(name: string): AgentDriver {\n39\t  if (!name || typeof name !== 'string') {\n40\t    throw new Error('getDriver requires a non-empty string name.');\n41\t  }\n42\t  const driver = registry.get(name);\n43\t  if (!driver) {\n44\t    const registered = [...registry.keys()];\n45\t    const list =\n46\t      registered.length > 0 ? registered.join(', ') : '(none)';\n47\t    throw new Error(\n48\t      `Driver '${name}' not found. Registered drivers: ${list}`,\n49\t    );\n50\t  }\n51\t  return driver;\n52\t}\n53\t\n54\t/**\n55\t * List all registered driver names.\n56\t * Returns a copy — mutating the returned array does not affect the registry.\n57\t */\n58\texport function listDrivers(): string[] {\n59\t  return [...registry.keys()];\n60\t}\n61\t\n62\t/**\n63\t * Clear all registered drivers. Exported for test isolation.\n64\t */\n65\texport function resetDrivers(): void {\n66\t  registry.clear();\n67\t}\n68\t"}]},"parent_tool_use_id":"toolu_014h63PtwQ6GwMTyMBqzXSRp","session_id":"61d40628-eabe-45b5-b544-2f5989944a22","uuid":"013680f0-aac7-4a36-83b1-61f5060b492d","timestamp":"2026-04-03T06:50:39.146Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016biiWfADg26xKDteobxYho","type":"tool_result","content":"1\t/**\n2\t * Public API for the agents subsystem.\n3\t *\n4\t * Re-exports types (story 10-1), stream parser functions/types,\n5\t * and the driver factory (story 10-2).\n6\t */\n7\t\n8\t// New types (Epic 10)\n9\texport type {\n10\t  AgentDriver,\n11\t  DriverHealth,\n12\t  DriverCapabilities,\n13\t  DispatchOpts,\n14\t  ErrorCategory,\n15\t  OutputContract,\n16\t  TestResults,\n17\t  ACStatus,\n18\t} from './types.js';\n19\t\n20\t// Deprecated types — kept for backward compatibility until story 10-3\n21\t/** @deprecated Use `DispatchOpts` instead. */\n22\texport type { SpawnOpts } from './types.js';\n23\t/** @deprecated Use `AsyncIterable<StreamEvent>` from `dispatch()` instead. */\n24\texport type { AgentProcess } from './types.js';\n25\t/** @deprecated Use `StreamEvent` from `stream-parser.ts` instead. */\n26\texport type { AgentEvent } from './types.js';\n27\t\n28\t// Stream parser\n29\texport { parseStreamLine } from './stream-parser.js';\n30\texport type {\n31\t  StreamEvent,\n32\t  ToolStartEvent,\n33\t  ToolInputEvent,\n34\t  ToolCompleteEvent,\n35\t  TextEvent,\n36\t  RetryEvent,\n37\t  ResultEvent,\n38\t} from './stream-parser.js';\n39\t\n40\t// --- Driver Factory ---\n41\t\n42\texport { getDriver, registerDriver, listDrivers, resetDrivers } from './drivers/factory.js';\n43\t"}]},"parent_tool_use_id":"toolu_014h63PtwQ6GwMTyMBqzXSRp","session_id":"61d40628-eabe-45b5-b544-2f5989944a22","uuid":"71dc2864-3103-4e06-b8a3-91d965f65ec8","timestamp":"2026-04-03T06:50:39.146Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014oFCR8sPjec9XGEQm1WqUf","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach } from 'vitest';\n2\timport { readFileSync } from 'node:fs';\n3\timport { resolve } from 'node:path';\n4\timport type { AgentDriver, DispatchOpts, DriverHealth } from '../types.js';\n5\timport type { StreamEvent } from '../stream-parser.js';\n6\timport {\n7\t  registerDriver,\n8\t  getDriver,\n9\t  listDrivers,\n10\t  resetDrivers,\n11\t} from '../drivers/factory.js';\n12\t\n13\t// --- Helpers ---\n14\t\n15\t/** Creates a minimal mock AgentDriver for testing. */\n16\tfunction createMockDriver(name: string): AgentDriver {\n17\t  return {\n18\t    name,\n19\t    defaultModel: 'mock-model',\n20\t    capabilities: {\n21\t      supportsPlugins: false,\n22\t      supportsStreaming: true,\n23\t      costReporting: false,\n24\t    },\n25\t    async healthCheck(): Promise<DriverHealth> {\n26\t      return { available: true, authenticated: true, version: '1.0.0' };\n27\t    },\n28\t    async *dispatch(_opts: DispatchOpts): AsyncIterable<StreamEvent> {\n29\t      yield { type: 'text', text: 'mock' };\n30\t    },\n31\t    getLastCost(): number | null {\n32\t      return null;\n33\t    },\n34\t  };\n35\t}\n36\t\n37\t// --- Tests ---\n38\t\n39\tdescribe('agents/drivers/factory — Driver Factory & Registry', () => {\n40\t  beforeEach(() => {\n41\t    resetDrivers();\n42\t  });\n43\t\n44\t  describe('registerDriver + getDriver', () => {\n45\t    it('registers a driver and retrieves it by name (same reference)', () => {\n46\t      const driver = createMockDriver('claude-code');\n47\t      registerDriver(driver);\n48\t      const retrieved = getDriver('claude-code');\n49\t      expect(retrieved).toBe(driver); // same reference\n50\t    });\n51\t\n52\t    it('registers multiple drivers and retrieves each by name', () => {\n53\t      const d1 = createMockDriver('claude-code');\n54\t      const d2 = createMockDriver('codex');\n55\t      registerDriver(d1);\n56\t      registerDriver(d2);\n57\t      expect(getDriver('claude-code')).toBe(d1);\n58\t      expect(getDriver('codex')).toBe(d2);\n59\t    });\n60\t  });\n61\t\n62\t  describe('getDriver — unknown name', () => {\n63\t    it('throws when no drivers are registered', () => {\n64\t      expect(() => getDriver('unknown')).toThrow(\"Driver 'unknown' not found\");\n65\t    });\n66\t\n67\t    it('includes the unknown name in the error message', () => {\n68\t      expect(() => getDriver('nonexistent')).toThrow('nonexistent');\n69\t    });\n70\t\n71\t    it('lists registered driver names in the error message', () => {\n72\t      registerDriver(createMockDriver('claude-code'));\n73\t      registerDriver(createMockDriver('opencode'));\n74\t      expect(() => getDriver('codex')).toThrow('claude-code');\n75\t      expect(() => getDriver('codex')).toThrow('opencode');\n76\t    });\n77\t\n78\t    it('shows \"(none)\" when no drivers are registered', () => {\n79\t      expect(() => getDriver('x')).toThrow('(none)');\n80\t    });\n81\t  });\n82\t\n83\t  describe('registerDriver — input validation', () => {\n84\t    it('throws when called with null', () => {\n85\t      expect(() => registerDriver(null as unknown as AgentDriver)).toThrow(\n86\t        'registerDriver requires a valid AgentDriver',\n87\t      );\n88\t    });\n89\t\n90\t    it('throws when called with undefined', () => {\n91\t      expect(() => registerDriver(undefined as unknown as AgentDriver)).toThrow(\n92\t        'registerDriver requires a valid AgentDriver',\n93\t      );\n94\t    });\n95\t\n96\t    it('throws when driver has no name property', () => {\n97\t      expect(() => registerDriver({} as unknown as AgentDriver)).toThrow(\n98\t        'registerDriver requires a valid AgentDriver',\n99\t      );\n100\t    });\n101\t\n102\t    it('throws when driver name is empty string', () => {\n103\t      expect(() => registerDriver(createMockDriver(''))).toThrow(\n104\t        'Driver name must be a non-empty string',\n105\t      );\n106\t    });\n107\t  });\n108\t\n109\t  describe('getDriver — input validation', () => {\n110\t    it('throws when called with empty string', () => {\n111\t      expect(() => getDriver('')).toThrow('getDriver requires a non-empty string name');\n112\t    });\n113\t\n114\t    it('throws when called with null', () => {\n115\t      expect(() => getDriver(null as unknown as string)).toThrow(\n116\t        'getDriver requires a non-empty string name',\n117\t      );\n118\t    });\n119\t\n120\t    it('throws when called with undefined', () => {\n121\t      expect(() => getDriver(undefined as unknown as string)).toThrow(\n122\t        'getDriver requires a non-empty string name',\n123\t      );\n124\t    });\n125\t  });\n126\t\n127\t  describe('registerDriver — duplicate', () => {\n128\t    it('throws when registering a driver with an already-registered name', () => {\n129\t      registerDriver(createMockDriver('claude-code'));\n130\t      expect(() => registerDriver(createMockDriver('claude-code'))).toThrow(\n131\t        \"Driver 'claude-code' is already registered\",\n132\t      );\n133\t    });\n134\t\n135\t    it('includes the duplicate name in the error message', () => {\n136\t      registerDriver(createMockDriver('opencode'));\n137\t      expect(() => registerDriver(createMockDriver('opencode'))).toThrow(\n138\t        'opencode',\n139\t      );\n140\t    });\n141\t  });\n142\t\n143\t  describe('listDrivers', () => {\n144\t    it('returns empty array when no drivers are registered', () => {\n145\t      expect(listDrivers()).toEqual([]);\n146\t    });\n147\t\n148\t    it('returns all registered driver names', () => {\n149\t      registerDriver(createMockDriver('claude-code'));\n150\t      registerDriver(createMockDriver('codex'));\n151\t      registerDriver(createMockDriver('opencode'));\n152\t      expect(listDrivers()).toEqual(['claude-code', 'codex', 'opencode']);\n153\t    });\n154\t\n155\t    it('returns a copy — mutating the result does not affect registry', () => {\n156\t      registerDriver(createMockDriver('claude-code'));\n157\t      const list = listDrivers();\n158\t      list.push('injected');\n159\t      expect(listDrivers()).toEqual(['claude-code']);\n160\t      expect(listDrivers()).not.toContain('injected');\n161\t    });\n162\t  });\n163\t\n164\t  describe('resetDrivers', () => {\n165\t    it('clears all registered drivers', () => {\n166\t      registerDriver(createMockDriver('claude-code'));\n167\t      registerDriver(createMockDriver('codex'));\n168\t      expect(listDrivers()).toHaveLength(2);\n169\t\n170\t      resetDrivers();\n171\t\n172\t      expect(listDrivers()).toEqual([]);\n173\t      expect(() => getDriver('claude-code')).toThrow();\n174\t      expect(() => getDriver('codex')).toThrow();\n175\t    });\n176\t  });\n177\t\n178\t  describe('no auto-discovery', () => {\n179\t    it('factory.ts source has no dynamic import(), readdir, glob, or require() calls', () => {\n180\t      const factoryPath = resolve(\n181\t        import.meta.dirname ?? __dirname,\n182\t        '..',\n183\t        'drivers',\n184\t        'factory.ts',\n185\t      );\n186\t      const source = readFileSync(factoryPath, 'utf-8');\n187\t\n188\t      // Forbidden patterns that would indicate auto-discovery\n189\t      expect(source).not.toMatch(/\\bimport\\s*\\(/);\n190\t      expect(source).not.toMatch(/\\breaddir/i);\n191\t      expect(source).not.toMatch(/\\bglob\\b/i);\n192\t      expect(source).not.toMatch(/\\brequire\\s*\\(/);\n193\t    });\n194\t  });\n195\t\n196\t  describe('barrel re-exports', () => {\n197\t    it('drivers/index.ts re-exports all factory functions', async () => {\n198\t      const barrel = await import('../drivers/index.js');\n199\t      expect(typeof barrel.getDriver).toBe('function');\n200\t      expect(typeof barrel.registerDriver).toBe('function');\n201\t      expect(typeof barrel.listDrivers).toBe('function');\n202\t      expect(typeof barrel.resetDrivers).toBe('function');\n203\t    });\n204\t\n205\t    it('agents/index.ts re-exports factory functions', async () => {\n206\t      const agents = await import('../index.js');\n207\t      expect(typeof agents.getDriver).toBe('function');\n208\t      expect(typeof agents.registerDriver).toBe('function');\n209\t      expect(typeof agents.listDrivers).toBe('function');\n210\t      expect(typeof agents.resetDrivers).toBe('function');\n211\t    });\n212\t  });\n213\t});\n214\t"}]},"parent_tool_use_id":"toolu_014h63PtwQ6GwMTyMBqzXSRp","session_id":"61d40628-eabe-45b5-b544-2f5989944a22","uuid":"f53af8ab-4835-4025-9402-23ca1f5744c5","timestamp":"2026-04-03T06:50:39.146Z"}
