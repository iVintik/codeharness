{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JSiqkhyQxh4UdP2DgXWBVy","type":"tool_result","content":"     1→/**\n     2→ * Showboat proof document template generation.\n     3→ * Creates canonical proof documents with executable evidence blocks\n     4→ * for verification via `showboat verify`.\n     5→ *\n     6→ * Architecture Decision 8: CLI orchestrates verification.\n     7→ */\n     8→\n     9→// ─── Types ──────────────────────────────────────────────────────────────────\n    10→\n    11→export interface EvidenceItem {\n    12→  type: 'exec' | 'image';\n    13→  content: string;\n    14→  path?: string;\n    15→}\n    16→\n    17→export interface AcceptanceCriterion {\n    18→  id: string;\n    19→  description: string;\n    20→  verified: boolean;\n    21→  evidence: EvidenceItem[];\n    22→}\n    23→\n    24→export interface ScreenshotEntry {\n    25→  label: string;\n    26→  path: string;\n    27→}\n    28→\n    29→export interface ShowboatProofConfig {\n    30→  storyId: string;\n    31→  storyTitle: string;\n    32→  acceptanceCriteria: AcceptanceCriterion[];\n    33→  screenshots?: ScreenshotEntry[];\n    34→}\n    35→\n    36→// ─── Template Functions ─────────────────────────────────────────────────────\n    37→\n    38→/**\n    39→ * Generates the verification summary block with AC counts and pass/fail status.\n    40→ */\n    41→export function verificationSummaryBlock(criteria: AcceptanceCriterion[]): string {\n    42→  const total = criteria.length;\n    43→  const verified = criteria.filter(ac => ac.verified).length;\n    44→  const failed = total - verified;\n    45→  const status = failed === 0 && total > 0 ? 'PASS' : 'FAIL';\n    46→\n    47→  const lines: string[] = [\n    48→    '## Verification Summary',\n    49→    '',\n    50→    `| Metric | Value |`,\n    51→    `|--------|-------|`,\n    52→    `| Total ACs | ${total} |`,\n    53→    `| Verified | ${verified} |`,\n    54→    `| Failed | ${failed} |`,\n    55→    `| Showboat Verify | ${status} |`,\n    56→  ];\n    57→\n    58→  return lines.join('\\n');\n    59→}\n    60→\n    61→/**\n    62→ * Renders evidence items for a single AC section.\n    63→ */\n    64→function renderEvidence(evidence: EvidenceItem[]): string {\n    65→  if (evidence.length === 0) {\n    66→    return '<!-- No evidence captured yet -->';\n    67→  }\n    68→\n    69→  const blocks: string[] = [];\n    70→  for (const item of evidence) {\n    71→    if (item.type === 'exec') {\n    72→      blocks.push(`<!-- showboat exec: ${item.content} -->`);\n    73→      blocks.push('```');\n    74→      blocks.push('<!-- output will be captured here -->');\n    75→      blocks.push('```');\n    76→      blocks.push('<!-- /showboat exec -->');\n    77→    } else if (item.type === 'image') {\n    78→      const imgPath = item.path ?? item.content;\n    79→      blocks.push(`<!-- showboat image: ${imgPath} -->`);\n    80→    }\n    81→  }\n    82→\n    83→  return blocks.join('\\n');\n    84→}\n    85→\n    86→/**\n    87→ * Generates the canonical Showboat proof document from a config.\n    88→ * Structure: story header, per-AC sections with showboat blocks, verification summary.\n    89→ */\n    90→export function showboatProofTemplate(config: ShowboatProofConfig): string {\n    91→  const sections: string[] = [];\n    92→\n    93→  // Story header\n    94→  sections.push(`# Proof: ${config.storyId}`);\n    95→  sections.push('');\n    96→  sections.push(`**Story:** ${config.storyTitle}`);\n    97→  sections.push(`**Generated:** ${new Date().toISOString().split('T')[0]}`);\n    98→  sections.push('');\n    99→\n   100→  // Per-AC sections\n   101→  for (const ac of config.acceptanceCriteria) {\n   102→    const statusIcon = ac.verified ? 'PASS' : 'PENDING';\n   103→    sections.push(`## AC ${ac.id}: ${statusIcon}`);\n   104→    sections.push('');\n   105→    sections.push(`> ${ac.description}`);\n   106→    sections.push('');\n   107→    sections.push(renderEvidence(ac.evidence));\n   108→    sections.push('');\n   109→  }\n   110→\n   111→  // Screenshots section (only if screenshots provided)\n   112→  if (config.screenshots && config.screenshots.length > 0) {\n   113→    sections.push('## Screenshots');\n   114→    sections.push('');\n   115→    for (const entry of config.screenshots) {\n   116→      sections.push(`- **${entry.label}**: ${entry.path}`);\n   117→    }\n   118→    sections.push('');\n   119→  }\n   120→\n   121→  // Verification summary\n   122→  sections.push(verificationSummaryBlock(config.acceptanceCriteria));\n   123→  sections.push('');\n   124→\n   125→  return sections.join('\\n');\n   126→}\n   127→"}]},"parent_tool_use_id":"toolu_01L5LiJHunZnUnw7ysWAKpUU","session_id":"7c5953f4-1d55-4aa9-825f-60bc73601e00","uuid":"1081c0e5-6028-4a22-8a30-c3260e4d897e","timestamp":"2026-03-25T02:04:24.650Z"}
