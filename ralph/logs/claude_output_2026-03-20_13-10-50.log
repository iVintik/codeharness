{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PmDDe1LKpji5Dh2x7dSjB3","type":"tool_result","content":"     1→/**\n     2→ * CLI command: `codeharness audit`\n     3→ *\n     4→ * Checks all compliance dimensions and reports project health.\n     5→ * Supports --json for machine-readable output.\n     6→ */\n     7→\n     8→import { Command } from 'commander';\n     9→import { ok as okOutput, fail as failOutput, jsonOutput } from '../lib/output.js';\n    10→import { runPreconditions } from '../lib/onboard-checks.js';\n    11→import { runAudit } from '../modules/audit/index.js';\n    12→import { formatAuditHuman, formatAuditJson } from '../modules/audit/report.js';\n    13→\n    14→export function registerAuditCommand(program: Command): void {\n    15→  program\n    16→    .command('audit')\n    17→    .description('Check all compliance dimensions and report project health')\n    18→    .option('--json', 'Output in machine-readable JSON format')\n    19→    .action(async (opts, cmd) => {\n    20→      const globalOpts = cmd.optsWithGlobals();\n    21→      const isJson = opts.json === true || globalOpts.json === true;\n    22→\n    23→      // Precondition: harness must be initialized (AC #7)\n    24→      const preconditions = runPreconditions();\n    25→      if (!preconditions.canProceed) {\n    26→        if (isJson) {\n    27→          jsonOutput({\n    28→            status: 'fail',\n    29→            message: 'Harness not initialized -- run codeharness init first',\n    30→          });\n    31→        } else {\n    32→          failOutput('Harness not initialized -- run codeharness init first');\n    33→        }\n    34→        process.exitCode = 1;\n    35→        return;\n    36→      }\n    37→\n    38→      // Run audit\n    39→      const result = await runAudit(process.cwd());\n    40→\n    41→      if (!result.success) {\n    42→        if (isJson) {\n    43→          jsonOutput({ status: 'fail', message: result.error });\n    44→        } else {\n    45→          failOutput(result.error);\n    46→        }\n    47→        process.exitCode = 1;\n    48→        return;\n    49→      }\n    50→\n    51→      // Format output\n    52→      if (isJson) {\n    53→        jsonOutput(formatAuditJson(result.data));\n    54→      } else {\n    55→        const lines = formatAuditHuman(result.data);\n    56→        for (const line of lines) {\n    57→          console.log(line);\n    58→        }\n    59→      }\n    60→\n    61→      // Set exit code based on overall status\n    62→      if (result.data.overallStatus === 'fail') {\n    63→        process.exitCode = 1;\n    64→      }\n    65→    });\n    66→}\n    67→"}]},"parent_tool_use_id":"toolu_01HFX9goKWGsXmLXf2BWi9oC","session_id":"0deb1693-f450-4ee3-ba9f-130c7ba0aec5","uuid":"c94dddc4-71aa-4fef-bb1d-1ab591eea22f","timestamp":"2026-03-20T09:15:43.098Z"}
