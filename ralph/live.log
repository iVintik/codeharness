{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DHs86dsPEHGNSnRREMvi3f","type":"tool_result","content":"     1→/**\n     2→ * Sprint module — story selection, status tracking, reporting.\n     3→ */\n     4→\n     5→import { ok, fail } from '../../types/result.js';\n     6→import type { Result } from '../../types/result.js';\n     7→import type { StoryStatus } from '../../types/state.js';\n     8→import type { SprintState } from '../../types/state.js';\n     9→import type {\n    10→  StorySelection,\n    11→  StoryDetail,\n    12→  StatusReport,\n    13→  SelectionResult,\n    14→  FailedStoryDetail,\n    15→  LabeledActionItem,\n    16→  RunSummary,\n    17→  StoryDrillDown,\n    18→  TimeoutReport,\n    19→  TimeoutCapture,\n    20→  FeedbackResult,\n    21→  FailingAc,\n    22→  TimeoutSummary,\n    23→  RunProgressUpdate,\n    24→} from './types.js';\n    25→import {\n    26→  getSprintState as getSprintStateImpl,\n    27→  updateStoryStatus as updateStoryStatusImpl,\n    28→  writeStateAtomic as writeStateAtomicImpl,\n    29→  computeSprintCounts as computeSprintCountsImpl,\n    30→  updateRunProgress as updateRunProgressImpl,\n    31→  clearRunProgress as clearRunProgressImpl,\n    32→  generateSprintStatusYaml as generateSprintStatusYamlImpl,\n    33→  getStoryStatusesFromState as getStoryStatusesFromStateImpl,\n    34→} from './state.js';\n    35→import { selectNextStory } from './selector.js';\n    36→import { generateReport as generateReportImpl, getStoryDrillDown as getStoryDrillDownImpl } from './reporter.js';\n    37→import { captureTimeoutReport as captureTimeoutReportImpl, findLatestTimeoutReport as findLatestTimeoutReportImpl } from './timeout.js';\n    38→import { processVerifyResult as processVerifyResultImpl } from './feedback.js';\n    39→import { validateStateConsistency as validateStateConsistencyImpl } from './validator.js';\n    40→import type { ValidationReport, ValidationIssue } from './validator.js';\n    41→\n    42→export type {\n    43→  StorySelection,\n    44→  StoryDetail,\n    45→  StatusReport,\n    46→  SelectionResult,\n    47→  FailedStoryDetail,\n    48→  LabeledActionItem,\n    49→  RunSummary,\n    50→  StoryDrillDown,\n    51→  TimeoutReport,\n    52→  TimeoutCapture,\n    53→  TimeoutSummary,\n    54→  FeedbackResult,\n    55→  FailingAc,\n    56→  RunProgressUpdate,\n    57→};\n    58→\n    59→export type { ValidationReport, ValidationIssue };\n    60→\n    61→/**\n    62→ * Select the next actionable story.\n    63→ * Also marks retry-exhausted stories as blocked (AC #2).\n    64→ */\n    65→export function getNextStory(): Result<SelectionResult> {\n    66→  const stateResult = getSprintStateImpl();\n    67→  if (!stateResult.success) {\n    68→    return fail(stateResult.error);\n    69→  }\n    70→\n    71→  const selectionResult = selectNextStory(stateResult.data);\n    72→  if (!selectionResult.success) {\n    73→    return fail(selectionResult.error);\n    74→  }\n    75→\n    76→  // Side-effect: mark retry-exhausted stories as blocked (AC #2)\n    77→  for (const exhausted of selectionResult.data.retryExhausted) {\n    78→    updateStoryStatusImpl(exhausted.key, 'blocked', {\n    79→      error: 'retry-exhausted',\n    80→    });\n    81→  }\n    82→\n    83→  return ok(selectionResult.data);\n    84→}\n    85→\n    86→export function updateStoryStatus(\n    87→  key: string,\n    88→  status: StoryStatus,\n    89→  detail?: StoryDetail,\n    90→): Result<void> {\n    91→  return updateStoryStatusImpl(key, status, detail);\n    92→}\n    93→\n    94→export function getSprintState(): Result<SprintState> {\n    95→  return getSprintStateImpl();\n    96→}\n    97→\n    98→export function generateReport(): Result<StatusReport> {\n    99→  const stateResult = getSprintStateImpl();\n   100→  if (!stateResult.success) {\n   101→    return fail(stateResult.error);\n   102→  }\n   103→  return generateReportImpl(stateResult.data);\n   104→}\n   105→\n   106→export function getStoryDrillDown(key: string): Result<StoryDrillDown> {\n   107→  const stateResult = getSprintStateImpl();\n   108→  if (!stateResult.success) {\n   109→    return fail(stateResult.error);\n   110→  }\n   111→\n   112→  // Look up latest timeout report for this story\n   113→  const timeoutResult = findLatestTimeoutReportImpl(key);\n   114→  const timeoutSummary = timeoutResult.success ? timeoutResult.data : null;\n   115→\n   116→  return getStoryDrillDownImpl(stateResult.data, key, { timeoutSummary });\n   117→}\n   118→\n   119→export function captureTimeoutReport(opts: {\n   120→  storyKey: string;\n   121→  iteration: number;\n   122→  durationMinutes: number;\n   123→  outputFile: string;\n   124→  stateSnapshotPath: string;\n   125→}): Result<TimeoutReport> {\n   126→  return captureTimeoutReportImpl(opts);\n   127→}\n   128→\n   129→export function processVerifyResult(\n   130→  storyKey: string,\n   131→  opts?: { maxAttempts?: number },\n   132→): Result<FeedbackResult> {\n   133→  return processVerifyResultImpl(storyKey, opts);\n   134→}\n   135→\n   136→export function validateStateConsistency(\n   137→  statePath: string,\n   138→  sprintStatusPath: string,\n   139→): Result<ValidationReport> {\n   140→  return validateStateConsistencyImpl(statePath, sprintStatusPath);\n   141→}\n   142→\n   143→export function writeStateAtomic(state: SprintState): Result<void> {\n   144→  return writeStateAtomicImpl(state);\n   145→}\n   146→\n   147→export function computeSprintCounts(\n   148→  stories: Record<string, import('../../types/state.js').StoryState>,\n   149→): SprintState['sprint'] {\n   150→  return computeSprintCountsImpl(stories);\n   151→}\n   152→\n   153→export function updateRunProgress(update: RunProgressUpdate): Result<void> {\n   154→  return updateRunProgressImpl(update);\n   155→}\n   156→\n   157→export function clearRunProgress(): Result<void> {\n   158→  return clearRunProgressImpl();\n   159→}\n   160→\n   161→export function generateSprintStatusYaml(state: SprintState): string {\n   162→  return generateSprintStatusYamlImpl(state);\n   163→}\n   164→\n   165→export function getStoryStatusesFromState(state: SprintState): Record<string, string> {\n   166→  return getStoryStatusesFromStateImpl(state);\n   167→}\n   168→\n   169→/**\n   170→ * Read sprint state and derive story statuses as a flat map.\n   171→ * Drop-in replacement for the old readSprintStatus() that parsed YAML.\n   172→ */\n   173→export function readSprintStatusFromState(): Record<string, string> {\n   174→  const stateResult = getSprintStateImpl();\n   175→  if (!stateResult.success) return {};\n   176→  return getStoryStatusesFromStateImpl(stateResult.data);\n   177→}\n   178→"}]},"parent_tool_use_id":"toolu_011K77Q1Nc8EiPZnCgrdVKHN","session_id":"01503c00-15e6-46f1-b837-b4628ff69656","uuid":"7b504dd0-f873-403d-afcc-7d949489f86d","timestamp":"2026-03-24T11:33:06.410Z"}
