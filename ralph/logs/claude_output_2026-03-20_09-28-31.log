IL: Expected 100%\");\n}\nENDSCRIPT\nnode /tmp/test-ac4.mjs 2>&1'","description":"Test computeRuntimeCoverage with multiple scenarios"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":466,"cache_read_input_tokens":68074,"cache_creation":{"ephemeral_5m_input_tokens":466,"ephemeral_1h_input_tokens":0},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01VHAaHy3MWJn8msLB8wMXYz","session_id":"8712fecb-812b-48fe-bd95-ad6ae808447d","uuid":"f533747c-c0a4-4bd6-b56c-44aa702e7db4"}
