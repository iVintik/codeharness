t        .filter((b) => b.length > 0);\n488\t      return branches[0];\n489\t    } catch { // IGNORE: branch listing failure means no branch exists — safe to return undefined\n490\t      return undefined;\n491\t    }\n492\t  }\n493\t\n494\t  /**\n495\t   * Parse `git worktree list --porcelain` output into structured entries.\n496\t   */\n497\t  private parsePorcelainOutput(output: string): Array<{ path: string; branch: string }> {\n498\t    if (!output.trim()) return [];\n499\t\n500\t    const blocks = output.split('\\n\\n').filter((b) => b.trim());\n501\t    const entries: Array<{ path: string; branch: string }> = [];\n502\t\n503\t    for (const block of blocks) {\n504\t      const lines = block.split('\\n');\n505\t      let path = '';\n506\t      let branch = '';\n507\t\n508\t      for (const line of lines) {\n509\t        if (line.startsWith('worktree ')) {\n510\t          path = line.slice('worktree '.length);\n511\t        } else if (line.startsWith('branch ')) {\n512\t          branch = line.slice('branch '.length);\n513\t        }\n514\t      }\n515\t\n516\t      if (path && branch) {\n517\t        entries.push({ path, branch });\n518\t      }\n519\t    }\n520\t\n521\t    return entries;\n522\t  }\n523\t\n524\t  /**\n525\t   * Extract epicId from a branch name like `codeharness/epic-17-slug`.\n526\t   */\n527\t  private extractEpicId(branchName: string): string {\n528\t    const withoutPrefix = branchName.slice(BRANCH_PREFIX.length);\n529\t    const dashIndex = withoutPrefix.indexOf('-');\n530\t    if (dashIndex === -1) return withoutPrefix;\n531\t    return withoutPrefix.slice(0, dashIndex);\n532\t  }\n533\t\n534\t  /**\n535\t   * Detect conflicting files after a failed merge/rebase.\n536\t   * Uses `git diff --name-only --diff-filter=U` to find unmerged paths.\n537\t   */\n538\t  private detectConflicts(): string[] {\n539\t    try {\n540\t      const output = this.execGit('git diff --name-only --diff-filter=U');\n541\t      return output\n542\t        .split('\\n')\n543\t        .map((f) => f.trim())\n544\t        .filter((f) => f.length > 0);\n545\t    } catch { // IGNORE: diff failure means no conflict info available\n546\t      return [];\n547\t    }\n548\t  }\n549\t\n550\t  /**\n551\t   * Abort an in-progress merge or rebase to restore main branch state.\n552\t   */\n553\t  private abortMerge(strategy: MergeStrategy): void {\n554\t    try {\n555\t      if (strategy === 'rebase') {\n556\t        this.execGit('git rebase --abort');\n557\t      } else {\n558\t        this.execGit('git merge --abort');\n559\t      }\n560\t    } catch { // IGNORE: abort may fail if merge already resolved; main state is preserved\n561\t    }\n562\t  }\n563\t\n564\t  /**\n565\t   * Run the test suite and parse results from stdout.\n566\t   * Uses async exec with a 5-minute timeout.\n567\t   */\n568\t  private async runTestSuite(\n569\t    testCommand: string = 'npm test',\n570\t  ): Promise<{ passed: number; failed: number; coverage?: number }> {\n571\t    try {\n572\t      const { stdout } = await execAsync(testCommand, {\n573\t        cwd: this.cwd,\n574\t        timeout: 300_000, // 5 minutes\n575\t      });\n576\t\n577\t      return this.parseTestOutput(stdout);\n578\t    } catch (err: unknown) {\n579\t      // Test command failed (non-zero exit) — parse whatever output we got\n580\t      const stdout = (err as { stdout?: string })?.stdout ?? '';\n581\t      const result = this.parseTestOutput(stdout);\n582\t      // If we couldn't parse anything, report 1 failure\n583\t      if (result.passed === 0 && result.failed === 0) {\n584\t        return { passed: 0, failed: 1 };\n585\t      }\n586\t      return result;\n587\t    }\n588\t  }\n589\t\n590\t  /**\n591\t   * Parse test output to extract pass/fail counts and optional coverage.\n592\t   * Supports common vitest/jest output patterns.\n593\t   */\n594\t  private parseTestOutput(stdout: string): { passed: number; failed: number; coverage?: number } {\n595\t    let passed = 0;\n596\t    let failed = 0;\n597\t    let coverage: number | undefined;\n598\t\n599\t    // Match vitest/jest \"Tests: X passed, Y failed\" or \"X passed\" patterns\n600\t    const passMatch = stdout.match(/(\\d+)\\s+passed/);\n601\t    const failMatch = stdout.match(/(\\d+)\\s+failed/);\n602\t    if (passMatch) passed = parseInt(passMatch[1], 10);\n603\t    if (failMatch) failed = parseInt(failMatch[1], 10);\n604\t\n605\t    // Match coverage percentage patterns like \"All files | 85.5\"\n606\t    const covMatch = stdout.match(/All files[^|]*\\|\\s*([\\d.]+)/);\n607\t    if (covMatch) coverage = parseFloat(covMatch[1]);\n608\t\n609\t    return { passed, failed, ...(coverage !== undefined && { coverage }) };\n610\t  }\n611\t\n612\t  /**\n613\t   * Check if a worktree is orphaned (no active codeharness process).\n614\t   */\n615\t  private isOrphaned(wt: WorktreeInfo): boolean {\n616\t    const laneStatePath = join(wt.path, '.codeharness', 'lane-state.json');\n617\t\n618\t    if (!existsSync(laneStatePath)) {\n619\t      return true;\n620\t    }\n621\t\n622\t    try {\n623\t      const content = readFileSync(laneStatePath, 'utf-8');\n624\t      const state = JSON.parse(content) as { pid?: number };\n625\t\n626\t      if (!state.pid) {\n627\t        return true;\n628\t      }\n629\t\n630\t      // Check if the PID is still running\n631\t      try {\n632\t        process.kill(state.pid, 0);\n633\t        return false; // Process is alive — not orphaned\n634\t      } catch { // IGNORE: ESRCH means process is dead — worktree is orphaned per AC #8\n635\t        return true;\n636\t      }\n637\t    } catch { // IGNORE: unreadable/corrupt lane-state.json means orphaned per AC #8\n638\t      return true;\n639\t    }\n640\t  }\n641\t}\n642\t"}]},"parent_tool_use_id":"toolu_011KW5B7oWpj1MKDHqa2H54S","session_id":"74f4684f-cc80-4828-8405-943cba326449","uuid":"fab5c402-e6ac-4a90-a4cd-46e3d2e3d9e1","timestamp":"2026-04-03T21:45:31.384Z"}
