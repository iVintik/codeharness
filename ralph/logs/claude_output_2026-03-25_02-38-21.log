{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MDWMvXUWRmH6CPoN2iGyc7","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→\n     3→vi.mock('node:child_process', () => ({\n     4→  execFileSync: vi.fn(),\n     5→}));\n     6→\n     7→vi.mock('../../../lib/docker/index.js', () => ({\n     8→  isDockerAvailable: vi.fn(() => true),\n     9→}));\n    10→\n    11→import { execFileSync } from 'node:child_process';\n    12→import { isDockerAvailable } from '../../../lib/docker/index.js';\n    13→import { cleanupContainers } from '../container-cleanup.js';\n    14→\n    15→const mockIsDockerAvailable = vi.mocked(isDockerAvailable);\n    16→const mockExecFileSync = vi.mocked(execFileSync);\n    17→\n    18→beforeEach(() => {\n    19→  vi.clearAllMocks();\n    20→  mockIsDockerAvailable.mockReturnValue(true);\n    21→  // Default: docker ps returns nothing (no stale containers)\n    22→  mockExecFileSync.mockReturnValue(Buffer.from(''));\n    23→});\n    24→\n    25→describe('cleanupContainers', () => {\n    26→  it('returns ok with 0 removed when Docker is unavailable (AC#7)', () => {\n    27→    mockIsDockerAvailable.mockReturnValue(false);\n    28→    const result = cleanupContainers();\n    29→    expect(result.success).toBe(true);\n    30→    if (result.success) {\n    31→      expect(result.data.containersRemoved).toBe(0);\n    32→      expect(result.data.names).toEqual([]);\n    33→    }\n    34→  });\n    35→\n    36→  it('returns ok with 0 when no stale containers exist', () => {\n    37→    mockExecFileSync.mockReturnValue(Buffer.from(''));\n    38→    const result = cleanupContainers();\n    39→    expect(result.success).toBe(true);\n    40→    if (result.success) {\n    41→      expect(result.data.containersRemoved).toBe(0);\n    42→      expect(result.data.names).toEqual([]);\n    43→    }\n    44→  });\n    45→\n    46→  it('removes stale shared containers (AC#3)', () => {\n    47→    mockExecFileSync.mockImplementation((cmd: string, args?: readonly string[]) => {\n    48→      const argsArray = args as string[];\n    49→      // docker ps for shared pattern\n    50→      if (cmd === 'docker' && argsArray?.[0] === 'ps' && argsArray?.includes('name=codeharness-shared-')) {\n    51→        return Buffer.from('codeharness-shared-otel-1\\ncodeharness-shared-victoria-1\\n');\n    52→      }\n    53→      // docker ps for collector pattern\n    54→      if (cmd === 'docker' && argsArray?.[0] === 'ps' && argsArray?.includes('name=codeharness-collector-')) {\n    55→        return Buffer.from('');\n    56→      }\n    57→      // docker rm\n    58→      if (cmd === 'docker' && argsArray?.[0] === 'rm') {\n    59→        return Buffer.from('');\n    60→      }\n    61→      return Buffer.from('');\n    62→    });\n    63→\n    64→    const result = cleanupContainers();\n    65→    expect(result.success).toBe(true);\n    66→    if (result.success) {\n    67→      expect(result.data.containersRemoved).toBe(2);\n    68→      expect(result.data.names).toContain('codeharness-shared-otel-1');\n    69→      expect(result.data.names).toContain('codeharness-shared-victoria-1');\n    70→    }\n    71→  });\n    72→\n    73→  it('removes stale collector containers', () => {\n    74→    mockExecFileSync.mockImplementation((cmd: string, args?: readonly string[]) => {\n    75→      const argsArray = args as string[];\n    76→      if (cmd === 'docker' && argsArray?.[0] === 'ps' && argsArray?.includes('name=codeharness-shared-')) {\n    77→        return Buffer.from('');\n    78→      }\n    79→      if (cmd === 'docker' && argsArray?.[0] === 'ps' && argsArray?.includes('name=codeharness-collector-')) {\n    80→        return Buffer.from('codeharness-collector-otel-1\\n');\n    81→      }\n    82→      if (cmd === 'docker' && argsArray?.[0] === 'rm') {\n    83→        return Buffer.from('');\n    84→      }\n    85→      return Buffer.from('');\n    86→    });\n    87→\n    88→    const result = cleanupContainers();\n    89→    expect(result.success).toBe(true);\n    90→    if (result.success) {\n    91→      expect(result.data.containersRemoved).toBe(1);\n    92→      expect(result.data.names).toContain('codeharness-collector-otel-1');\n    93→    }\n    94→  });\n    95→\n    96→  it('continues if individual container removal fails', () => {\n    97→    let rmCallCount = 0;\n    98→    mockExecFileSync.mockImplementation((cmd: string, args?: readonly string[]) => {\n    99→      const argsArray = args as string[];\n   100→      if (cmd === 'docker' && argsArray?.[0] === 'ps' && argsArray?.includes('name=codeharness-shared-')) {\n   101→        return Buffer.from('container-a\\ncontainer-b\\n');\n   102→      }\n   103→      if (cmd === 'docker' && argsArray?.[0] === 'ps' && argsArray?.includes('name=codeharness-collector-')) {\n   104→        return Buffer.from('');\n   105→      }\n   106→      if (cmd === 'docker' && argsArray?.[0] === 'rm') {\n   107→        rmCallCount++;\n   108→        if (rmCallCount === 1) {\n   109→          throw new Error('removal failed');\n   110→        }\n   111→        return Buffer.from('');\n   112→      }\n   113→      return Buffer.from('');\n   114→    });\n   115→\n   116→    const result = cleanupContainers();\n   117→    expect(result.success).toBe(true);\n   118→    if (result.success) {\n   119→      // Only the second one succeeded\n   120→      expect(result.data.containersRemoved).toBe(1);\n   121→      expect(result.data.names).toContain('container-b');\n   122→    }\n   123→  });\n   124→\n   125→  it('handles docker ps failure gracefully for a pattern', () => {\n   126→    mockExecFileSync.mockImplementation((cmd: string, args?: readonly string[]) => {\n   127→      const argsArray = args as string[];\n   128→      if (cmd === 'docker' && argsArray?.[0] === 'ps' && argsArray?.includes('name=codeharness-shared-')) {\n   129→        throw new Error('docker ps failed');\n   130→      }\n   131→      if (cmd === 'docker' && argsArray?.[0] === 'ps' && argsArray?.includes('name=codeharness-collector-')) {\n   132→        return Buffer.from('codeharness-collector-otel-1\\n');\n   133→      }\n   134→      if (cmd === 'docker' && argsArray?.[0] === 'rm') {\n   135→        return Buffer.from('');\n   136→      }\n   137→      return Buffer.from('');\n   138→    });\n   139→\n   140→    const result = cleanupContainers();\n   141→    expect(result.success).toBe(true);\n   142→    if (result.success) {\n   143→      expect(result.data.containersRemoved).toBe(1);\n   144→    }\n   145→  });\n   146→});\n   147→"}]},"parent_tool_use_id":"toolu_01NbbU2crBRehddb6AAVY9uR","session_id":"174e0897-5fbc-4ae0-bbc6-8b881d5c7525","uuid":"fe497cc0-8064-4b03-95ef-ff38e43bfb54","timestamp":"2026-03-24T22:45:47.412Z"}
