{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NZ9u8PbM2oA63ZkJ3HLHFh","type":"tool_result","content":"1\t/**\n2\t * Public API for the agents subsystem.\n3\t *\n4\t * Re-exports types (story 13-1), stream parser functions/types,\n5\t * and the getDriver() factory (story 13-3).\n6\t *\n7\t * Ralph driver and prompt removed in Story 1.2 — will be replaced\n8\t * by workflow engine in Epic 5.\n9\t */\n10\t\n11\timport type { AgentDriver } from './types.js';\n12\t\n13\t// Types\n14\texport type {\n15\t  SpawnOpts,\n16\t  AgentProcess,\n17\t  AgentEvent,\n18\t  AgentDriver,\n19\t} from './types.js';\n20\t\n21\t// Stream parser\n22\texport { parseStreamLine } from './stream-parser.js';\n23\texport type {\n24\t  StreamEvent,\n25\t  ToolStartEvent,\n26\t  ToolInputEvent,\n27\t  ToolCompleteEvent,\n28\t  TextEvent,\n29\t  RetryEvent,\n30\t  ResultEvent,\n31\t} from './stream-parser.js';\n32\t\n33\t// --- Driver Factory ---\n34\t\n35\t// TODO: v2 workflow-engine (Epic 5) — rebuild getDriver with workflow-based driver\n36\t/**\n37\t * Returns an AgentDriver instance by name.\n38\t * Throws for all driver names — Ralph removed, workflow engine pending (Epic 5).\n39\t */\n40\texport function getDriver(name?: string, _config?: unknown): AgentDriver {\n41\t  const driverName = name ?? 'default';\n42\t  throw new Error(`No agent drivers available (requested: ${driverName}). Workflow engine pending (Epic 5).`);\n43\t}\n44\t"}]},"parent_tool_use_id":"toolu_01NjDqDTPt689SFgjSYPgPWk","session_id":"e499f49a-fe4c-4b28-bb21-4e83348f2671","uuid":"feb1f6aa-c321-43e6-a3da-b62d48b1c515","timestamp":"2026-04-03T06:22:59.019Z"}
