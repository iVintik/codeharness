{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013AgAqhXNf9jkPpitryZjYH","type":"tool_result","content":"     1→/**\n     2→ * Dockerfile template generator — creates stack-appropriate Dockerfiles for user projects.\n     3→ * Returns Result<DockerfileTemplateResult> following the project's Result<T> pattern.\n     4→ *\n     5→ * FR22 (Dockerfile template based on project type).\n     6→ * Supports single-stack and multi-stage (multi-stack) Dockerfile generation.\n     7→ *\n     8→ * Templates are read from static files in templates/dockerfiles/ via renderTemplateFile().\n     9→ */\n    10→\n    11→import { existsSync, writeFileSync } from 'node:fs';\n    12→import { join } from 'node:path';\n    13→import { ok, fail } from '../../types/result.js';\n    14→import type { Result } from '../../types/result.js';\n    15→import type { StackDetection } from '../../lib/stacks/index.js';\n    16→import { getStackProvider } from '../../lib/stacks/index.js';\n    17→import type { StackName } from '../../lib/stacks/index.js';\n    18→import { renderTemplateFile } from '../../lib/templates.js';\n    19→\n    20→/** Result returned by generateDockerfileTemplate */\n    21→export interface DockerfileTemplateResult {\n    22→  readonly path: string;\n    23→  readonly stack: string;\n    24→  readonly stacks: string[];\n    25→}\n    26→\n    27→// ─── Template content generators ────────────────────────────────────────────\n    28→\n    29→function genericTemplate(): string {\n    30→  return renderTemplateFile('templates/dockerfiles/Dockerfile.generic');\n    31→}\n    32→\n    33→// ─── Multi-stage build-stage content extractors ─────────────────────────────\n    34→\n    35→/** COPY directives for each stack in the runtime stage */\n    36→function runtimeCopyDirectives(stacks: string[]): string {\n    37→  const lines: string[] = [];\n    38→  for (const stack of stacks) {\n    39→    const provider = getStackProvider(stack as StackName);\n    40→    if (provider) {\n    41→      lines.push(provider.getRuntimeCopyDirectives());\n    42→    }\n    43→  }\n    44→  return lines.join('\\n');\n    45→}\n    46→\n    47→/** Compose a multi-stage Dockerfile from multiple stack detections */\n    48→function multiStageTemplate(detections: StackDetection[]): string {\n    49→  // Filter to only stacks with a registered provider (all registered providers support multi-stage)\n    50→  const supported = detections.filter(d => getStackProvider(d.stack) !== undefined);\n    51→  if (supported.length === 0) {\n    52→    // All stacks unknown — fall back to generic-like runtime-only Dockerfile\n    53→    return genericTemplate();\n    54→  }\n    55→  const stacks = supported.map(d => d.stack);\n    56→\n    57→  const buildStages: string[] = [];\n    58→  for (const stack of stacks) {\n    59→    const provider = getStackProvider(stack as StackName);\n    60→    if (provider) {\n    61→      buildStages.push(provider.getDockerBuildStage());\n    62→    }\n    63→  }\n    64→\n    65→  const copyLines = runtimeCopyDirectives(stacks);\n    66→\n    67→  return renderTemplateFile('templates/dockerfiles/Dockerfile.multi-stage.tmpl', {\n    68→    BUILD_STAGES: buildStages.join('\\n'),\n    69→    COPY_DIRECTIVES: copyLines,\n    70→  });\n    71→}\n    72→\n    73→// ─── Main generator ─────────────────────────────────────────────────────────\n    74→\n    75→/**\n    76→ * Generate a Dockerfile template based on detected stack type.\n    77→ * Accepts either a string stack name (backward compat) or StackDetection[] for multi-stack.\n    78→ * Returns fail() if a Dockerfile already exists — caller handles messaging.\n    79→ */\n    80→export function generateDockerfileTemplate(\n    81→  projectDir: string,\n    82→  stackOrDetections: string | null | StackDetection[],\n    83→): Result<DockerfileTemplateResult> {\n    84→  if (!projectDir) {\n    85→    return fail('projectDir is required');\n    86→  }\n    87→\n    88→  const dockerfilePath = join(projectDir, 'Dockerfile');\n    89→\n    90→  if (existsSync(dockerfilePath)) {\n    91→    return fail('Dockerfile already exists');\n    92→  }\n    93→\n    94→  // Multi-stack path: StackDetection[] with >1 entry\n    95→  if (Array.isArray(stackOrDetections) && stackOrDetections.length > 1) {\n    96→    const content = multiStageTemplate(stackOrDetections);\n    97→    const stacks = stackOrDetections.map(d => d.stack);\n    98→    try {\n    99→      writeFileSync(dockerfilePath, content, 'utf-8');\n   100→    } catch (err) {\n   101→      const message = err instanceof Error ? err.message : String(err);\n   102→      return fail(`Failed to write Dockerfile: ${message}`);\n   103→    }\n   104→    return ok({ path: dockerfilePath, stack: stacks[0], stacks });\n   105→  }\n   106→\n   107→  // Resolve single stack from StackDetection[] or string\n   108→  const stack: string | null = Array.isArray(stackOrDetections)\n   109→    ? (stackOrDetections.length === 1 ? stackOrDetections[0].stack : null)\n   110→    : stackOrDetections;\n   111→\n   112→  let content: string;\n   113→  let resolvedStack: string;\n   114→\n   115→  const provider = stack ? getStackProvider(stack as StackName) : undefined;\n   116→  if (provider) {\n   117→    content = provider.getDockerfileTemplate();\n   118→    resolvedStack = provider.name;\n   119→  } else {\n   120→    content = genericTemplate();\n   121→    resolvedStack = 'generic';\n   122→  }\n   123→\n   124→  try {\n   125→    writeFileSync(dockerfilePath, content, 'utf-8');\n   126→  } catch (err) {\n   127→    const message = err instanceof Error ? err.message : String(err);\n   128→    return fail(`Failed to write Dockerfile: ${message}`);\n   129→  }\n   130→\n   131→  return ok({ path: dockerfilePath, stack: resolvedStack, stacks: [resolvedStack] });\n   132→}\n   133→"}]},"parent_tool_use_id":"toolu_017LE4Rqhq3H1jAYQjBPXCJU","session_id":"36088b51-1d35-430b-9a0d-289c00965751","uuid":"68ef3195-130b-4c68-b1c3-a9a0c26e599d","timestamp":"2026-03-25T02:10:31.737Z"}
