{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LNVTGTj1cNhQmRcsaHEhLn","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n     2→import { mkdtempSync, rmSync } from 'node:fs';\n     3→import { tmpdir } from 'node:os';\n     4→import { join } from 'node:path';\n     5→import { Command } from 'commander';\n     6→\n     7→// Mock the scanner library\n     8→vi.mock('../../lib/scanner.js', () => ({\n     9→  scanCodebase: vi.fn(),\n    10→  analyzeCoverageGaps: vi.fn(),\n    11→  auditDocumentation: vi.fn(),\n    12→}));\n    13→\n    14→vi.mock('../../lib/output.js', () => ({\n    15→  ok: vi.fn(),\n    16→  fail: vi.fn(),\n    17→  warn: vi.fn(),\n    18→  info: vi.fn(),\n    19→  jsonOutput: vi.fn(),\n    20→}));\n    21→\n    22→vi.mock('../../lib/epic-generator.js', async (importOriginal) => {\n    23→  const actual = await importOriginal() as Record<string, unknown>;\n    24→  return {\n    25→    ...actual,\n    26→    generateOnboardingEpic: vi.fn().mockReturnValue({\n    27→      title: 'Onboarding Epic: Bring Project to Harness Compliance',\n    28→      generatedAt: '2026-03-15T10:00:00Z',\n    29→      stories: [\n    30→        { key: '0.1', title: 'Create ARCHITECTURE.md', type: 'architecture', acceptanceCriteria: ['AC1'] },\n    31→        { key: '0.2', title: 'Add test coverage for src/lib', type: 'coverage', module: 'src/lib', acceptanceCriteria: ['AC2'] },\n    32→      ],\n    33→      summary: { totalStories: 2, coverageStories: 1, docStories: 1, cleanupStories: 0, verificationStories: 0, observabilityStories: 0 },\n    34→    }),\n    35→    writeOnboardingEpic: vi.fn(),\n    36→    formatEpicSummary: vi.fn().mockReturnValue('Onboarding plan: 2 stories (1 coverage, 1 documentation, 0 cleanup)'),\n    37→    promptApproval: vi.fn().mockResolvedValue(true),\n    38→    importOnboardingEpic: vi.fn().mockReturnValue([\n    39→      { storyKey: '0.1', title: 'Create ARCHITECTURE.md', beadsId: 'BEAD-1', status: 'created', storyFilePath: 'path1' },\n    40→      { storyKey: '0.2', title: 'Add test coverage for src/lib', beadsId: 'BEAD-2', status: 'created', storyFilePath: 'path2' },\n    41→    ]),\n    42→  };\n    43→});\n    44→\n    45→vi.mock('../../lib/beads.js', () => ({\n    46→  listIssues: vi.fn().mockReturnValue([]),\n    47→  createIssue: vi.fn(),\n    48→}));\n    49→\n    50→vi.mock('../../lib/onboard-checks.js', () => ({\n    51→  runPreconditions: vi.fn().mockReturnValue({\n    52→    canProceed: true,\n    53→    warnings: [],\n    54→    initialized: true,\n    55→    bmad: true,\n    56→    hooks: true,\n    57→  }),\n    58→  filterTrackedGaps: vi.fn().mockImplementation((stories: any[]) => ({\n    59→    untracked: stories,\n    60→    trackedCount: 0,\n    61→  })),\n    62→  findVerificationGaps: vi.fn().mockReturnValue([]),\n    63→  findPerFileCoverageGaps: vi.fn().mockReturnValue([]),\n    64→  findObservabilityGaps: vi.fn().mockReturnValue([]),\n    65→  getOnboardingProgress: vi.fn().mockReturnValue(null),\n    66→}));\n    67→\n    68→vi.mock('../../lib/scan-cache.js', () => ({\n    69→  saveScanCache: vi.fn(),\n    70→  loadValidCache: vi.fn().mockReturnValue(null),\n    71→}));\n    72→\n    73→import { registerOnboardCommand, resetLastScanResult } from '../onboard.js';\n    74→import {\n    75→  scanCodebase,\n    76→  analyzeCoverageGaps,\n    77→  auditDocumentation,\n    78→} from '../../lib/scanner.js';\n    79→import { fail, info, ok, warn, jsonOutput } from '../../lib/output.js';\n    80→import {\n    81→  generateOnboardingEpic,\n    82→  writeOnboardingEpic,\n    83→  formatEpicSummary,\n    84→  promptApproval,\n    85→  importOnboardingEpic,\n    86→} from '../../lib/epic-generator.js';\n    87→import {\n    88→  runPreconditions,\n    89→  filterTrackedGaps,\n    90→  findVerificationGaps,\n    91→  findPerFileCoverageGaps,\n    92→  findObservabilityGaps,\n    93→  getOnboardingProgress,\n    94→} from '../../lib/onboard-checks.js';\n    95→import { saveScanCache, loadValidCache } from '../../lib/scan-cache.js';\n    96→\n    97→let testDir: string;\n    98→let originalCwd: string;\n    99→\n   100→const mockScanResult = {\n   101→  modules: [\n   102→    { path: 'src/lib', sourceFiles: 5, testFiles: 3 },\n   103→    { path: 'src/commands', sourceFiles: 8, testFiles: 4 },\n   104→  ],\n   105→  totalSourceFiles: 20,\n   106→  artifacts: {\n   107→    hasBmad: false,\n   108→    bmadPath: null,\n   109→  },\n   110→};\n   111→\n   112→const mockCoverageReport = {\n   113→  overall: 85.5,\n   114→  modules: [\n   115→    { path: 'src/lib', coveragePercent: 90, uncoveredFileCount: 1 },\n   116→    { path: 'src/commands', coveragePercent: 80, uncoveredFileCount: 2 },\n   117→  ],\n   118→  uncoveredFiles: 3,\n   119→};\n   120→\n   121→const mockAuditResult = {\n   122→  documents: [\n   123→    { name: 'README.md', grade: 'present' as const, path: 'README.md' },\n   124→    { name: 'AGENTS.md', grade: 'missing' as const, path: null },\n   125→    { name: 'ARCHITECTURE.md', grade: 'missing' as const, path: null },\n   126→  ],\n   127→  summary: 'README.md(present) AGENTS.md(missing) ARCHITECTURE.md(missing)',\n   128→};\n   129→\n   130→beforeEach(() => {\n   131→  vi.clearAllMocks();\n   132→  resetLastScanResult();\n   133→  testDir = mkdtempSync(join(tmpdir(), 'ch-onboard-cmd-test-'));\n   134→  originalCwd = process.cwd();\n   135→  process.chdir(testDir);\n   136→  process.exitCode = undefined;\n   137→\n   138→  // Set up default mocks\n   139→  vi.mocked(scanCodebase).mockReturnValue(mockScanResult);\n   140→  vi.mocked(analyzeCoverageGaps).mockReturnValue(mockCoverageReport);\n   141→  vi.mocked(auditDocumentation).mockReturnValue(mockAuditResult);\n   142→\n   143→  // Re-establish onboard-checks mocks after clearAllMocks\n   144→  vi.mocked(runPreconditions).mockReturnValue({\n   145→    canProceed: true,\n   146→    warnings: [],\n   147→    initialized: true,\n   148→    bmad: true,\n   149→    hooks: true,\n   150→  });\n   151→  vi.mocked(filterTrackedGaps).mockImplementation((stories: any[]) => ({\n   152→    untracked: stories,\n   153→    trackedCount: 0,\n   154→  }));\n   155→  vi.mocked(getOnboardingProgress).mockReturnValue(null);\n   156→\n   157→  // Re-establish scan-cache mocks after clearAllMocks\n   158→  vi.mocked(loadValidCache).mockReturnValue(null);\n   159→\n   160→  // Re-establish epic-generator mocks after clearAllMocks\n   161→  vi.mocked(generateOnboardingEpic).mockReturnValue({\n   162→    title: 'Onboarding Epic: Bring Project to Harness Compliance',\n   163→    generatedAt: '2026-03-15T10:00:00Z',\n   164→    stories: [\n   165→      { key: '0.1', title: 'Create ARCHITECTURE.md', type: 'architecture', acceptanceCriteria: ['AC1'] },\n   166→      { key: '0.2', title: 'Add test coverage for src/lib', type: 'coverage', module: 'src/lib', acceptanceCriteria: ['AC2'] },\n   167→    ],\n   168→    summary: { totalStories: 2, coverageStories: 1, docStories: 1, cleanupStories: 0, verificationStories: 0, observabilityStories: 0 },\n   169→  });\n   170→  vi.mocked(writeOnboardingEpic).mockReturnValue(undefined);\n   171→  vi.mocked(formatEpicSummary).mockReturnValue('Onboarding plan: 2 stories (1 coverage, 1 documentation, 0 cleanup)');\n   172→  vi.mocked(promptApproval).mockResolvedValue(true);\n   173→  vi.mocked(importOnboardingEpic).mockReturnValue([\n   174→    { storyKey: '0.1', title: 'Create ARCHITECTURE.md', beadsId: 'BEAD-1', status: 'created', storyFilePath: 'path1' },\n   175→    { storyKey: '0.2', title: 'Add test coverage for src/lib', beadsId: 'BEAD-2', status: 'created', storyFilePath: 'path2' },\n   176→  ]);\n   177→});\n   178→\n   179→afterEach(() => {\n   180→  process.chdir(originalCwd);\n   181→  process.exitCode = undefined;\n   182→  rmSync(testDir, { recursive: true, force: true });\n   183→});\n   184→\n   185→async function runOnboardCmd(args: string[]): Promise<void> {\n   186→  const program = new Command();\n   187→  program.exitOverride();\n   188→  program.option('--json', 'JSON output');\n   189→  registerOnboardCommand(program);\n   190→  try {\n   191→    await program.parseAsync(['node', 'test', 'onboard', ...args]);\n   192→  } catch {\n   193→    // Commander throws on exitOverride — ignore\n   194→  }\n   195→}\n   196→\n   197→// ─── Tests ──────────────────────────────────────────────────────────────────\n   198→\n   199→describe('onboard command', () => {\n   200→  it('runs all phases including epic generation when no subcommand given', async () => {\n   201→    await runOnboardCmd([]);\n   202→\n   203→    expect(scanCodebase).toHaveBeenCalled();\n   204→    expect(analyzeCoverageGaps).toHaveBeenCalled();\n   205→    expect(auditDocumentation).toHaveBeenCalled();\n   206→    expect(generateOnboardingEpic).toHaveBeenCalled();\n   207→    expect(writeOnboardingEpic).toHaveBeenCalled();\n   208→    expect(info).toHaveBeenCalledWith(\n   209→      'Scan: 20 source files across 2 modules',\n   210→    );\n   211→    expect(info).toHaveBeenCalledWith(\n   212→      'Coverage: 85.5% overall (3 files uncovered)',\n   213→    );\n   214→    expect(info).toHaveBeenCalledWith(\n   215→      'Docs: README.md(present) AGENTS.md(missing) ARCHITECTURE.md(missing)',\n   216→    );\n   217→    // Epic summary printed\n   218→    expect(info).toHaveBeenCalledWith(\n   219→      'Onboarding plan: 2 stories (1 coverage, 1 documentation, 0 cleanup)',\n   220→    );\n   221→  });\n   222→\n   223→  it('passes --min-module-size to scanCodebase', async () => {\n   224→    await runOnboardCmd(['--min-module-size', '5']);\n   225→\n   226→    expect(scanCodebase).toHaveBeenCalledWith(\n   227→      expect.any(String),\n   228→      { minModuleSize: 5 },\n   229→    );\n   230→  });\n   231→\n   232→  it('imports stories on approval in combined mode', async () => {\n   233→    vi.mocked(promptApproval).mockResolvedValue(true);\n   234→\n   235→    await runOnboardCmd([]);\n   236→\n   237→    expect(promptApproval).toHaveBeenCalled();\n   238→    expect(importOnboardingEpic).toHaveBeenCalled();\n   239→    expect(ok).toHaveBeenCalledWith('Onboarding: 2 stories imported into beads');\n   240→    expect(info).toHaveBeenCalledWith('Ready to run: codeharness run');\n   241→  });\n   242→\n   243→  it('does not import on rejection in combined mode', async () => {\n   244→    vi.mocked(promptApproval).mockResolvedValue(false);\n   245→\n   246→    await runOnboardCmd([]);\n   247→\n   248→    expect(promptApproval).toHaveBeenCalled();\n   249→    expect(importOnboardingEpic).not.toHaveBeenCalled();\n   250→    expect(info).toHaveBeenCalledWith(\n   251→      'Plan saved to ralph/onboarding-epic.md \\u2014 edit and re-run when ready',\n   252→    );\n   253→  });\n   254→});\n   255→\n   256→describe('onboard scan subcommand', () => {\n   257→  it('runs only scan phase', async () => {\n   258→    await runOnboardCmd(['scan']);\n   259→\n   260→    expect(scanCodebase).toHaveBeenCalled();\n   261→    expect(analyzeCoverageGaps).not.toHaveBeenCalled();\n   262→    expect(auditDocumentation).not.toHaveBeenCalled();\n   263→    expect(info).toHaveBeenCalledWith(\n   264→      'Scan: 20 source files across 2 modules',\n   265→    );\n   266→  });\n   267→\n   268→  it('outputs JSON with --json flag', async () => {\n   269→    await runOnboardCmd(['scan', '--json']);\n   270→\n   271→    expect(jsonOutput).toHaveBeenCalledWith({\n   272→      preconditions: { initialized: true, bmad: true, hooks: true },\n   273→      scan: mockScanResult,\n   274→    });\n   275→  });\n   276→});\n   277→\n   278→describe('onboard coverage subcommand', () => {\n   279→  it('runs only coverage phase', async () => {\n   280→    await runOnboardCmd(['coverage']);\n   281→\n   282→    // scanCodebase is called to get module info for coverage\n   283→    expect(scanCodebase).toHaveBeenCalled();\n   284→    expect(a