{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EZQjVuigK2EB2v1FLJQ9w2","type":"tool_result","content":"     1→/**\n     2→ * Audit dimension checkers — each wraps an existing module and maps\n     3→ * its output to DimensionResult. Each checker catches its own errors\n     4→ * and never throws (AC #6).\n     5→ */\n     6→\n     7→import { existsSync, readFileSync, readdirSync } from 'node:fs';\n     8→import { join } from 'node:path';\n     9→import { ok, isOk } from '../../types/result.js';\n    10→import type { Result } from '../../types/result.js';\n    11→import type { DimensionResult, AuditGap } from './types.js';\n    12→import { analyze, validateRuntime } from '../observability/index.js';\n    13→import type { AnalyzerResult, RuntimeValidationResult } from '../observability/index.js';\n    14→import { checkOnlyCoverage } from '../../lib/coverage.js';\n    15→import { scanDocHealth } from '../../lib/doc-health.js';\n    16→import { parseProof } from '../verify/index.js';\n    17→import { validateDockerfile } from '../infra/index.js';\n    18→\n    19→type Status = 'pass' | 'fail' | 'warn';\n    20→\n    21→function gap(dimension: string, description: string, suggestedFix: string): AuditGap {\n    22→  return { dimension, description, suggestedFix };\n    23→}\n    24→\n    25→function dimOk(name: string, status: Status, metric: string, gaps: AuditGap[] = []): Result<DimensionResult> {\n    26→  return ok({ name, status, metric, gaps });\n    27→}\n    28→\n    29→function dimCatch(name: string, err: unknown): Result<DimensionResult> {\n    30→  const msg = err instanceof Error ? err.message : String(err);\n    31→  return dimOk(name, 'warn', 'error', [gap(name, `${name} check failed: ${msg}`, `Check ${name} configuration`)]);\n    32→}\n    33→\n    34→function worstStatus(...statuses: Status[]): Status {\n    35→  if (statuses.includes('fail')) return 'fail';\n    36→  if (statuses.includes('warn')) return 'warn';\n    37→  return 'pass';\n    38→}\n    39→\n    40→// ─── Observability (Task 2.1) ───────────────────────────────────────────────\n    41→\n    42→export async function checkObservability(projectDir: string): Promise<Result<DimensionResult>> {\n    43→  try {\n    44→    const gaps: AuditGap[] = [];\n    45→    let sStatus: Status = 'pass', sMetric = '';\n    46→    const sr = analyze(projectDir);\n    47→\n    48→    if (isOk(sr)) {\n    49→      const d: AnalyzerResult = sr.data;\n    50→      if (d.skipped) {\n    51→        sStatus = 'warn';\n    52→        sMetric = `static: skipped (${d.skipReason ?? 'unknown'})`;\n    53→        gaps.push(gap('observability', `Static analysis skipped: ${d.skipReason ?? 'Semgrep not installed'}`, 'Install Semgrep: pip install semgrep'));\n    54→      } else {\n    55→        const n = d.gaps.length;\n    56→        sMetric = `static: ${n} gap${n !== 1 ? 's' : ''}`;\n    57→        if (n > 0) {\n    58→          sStatus = 'warn';\n    59→          for (const g of d.gaps) gaps.push(gap('observability', `${g.file}:${g.line} — ${g.message}`, g.fix ?? 'Add observability instrumentation'));\n    60→        }\n    61→      }\n    62→    } else {\n    63→      sStatus = 'warn';\n    64→      sMetric = 'static: skipped (analysis failed)';\n    65→      gaps.push(gap('observability', `Static analysis failed: ${sr.error}`, 'Check Semgrep installation and rules configuration'));\n    66→    }\n    67→\n    68→    let rStatus: Status = 'pass', rMetric = '';\n    69→    try {\n    70→      const rr = await validateRuntime(projectDir);\n    71→      if (isOk(rr)) {\n    72→        const d: RuntimeValidationResult = rr.data;\n    73→        if (d.skipped) {\n    74→          rStatus = 'warn';\n    75→          rMetric = `runtime: skipped (${d.skipReason ?? 'unknown'})`;\n    76→          gaps.push(gap('observability', `Runtime validation skipped: ${d.skipReason ?? 'backend unreachable'}`, 'Start the observability stack: codeharness stack up'));\n    77→        } else {\n    78→          rMetric = `runtime: ${d.coveragePercent}%`;\n    79→          if (d.coveragePercent < 50) {\n    80→            rStatus = 'warn';\n    81→            gaps.push(gap('observability', `Runtime coverage low: ${d.coveragePercent}%`, 'Add telemetry instrumentation to more modules'));\n    82→          }\n    83→        }\n    84→      } else {\n    85→        rStatus = 'warn';\n    86→        rMetric = 'runtime: skipped (validation failed)';\n    87→        gaps.push(gap('observability', `Runtime validation failed: ${rr.error}`, 'Ensure observability backend is running'));\n    88→      }\n    89→    } catch {\n    90→      rStatus = 'warn';\n    91→      rMetric = 'runtime: skipped (error)';\n    92→      gaps.push(gap('observability', 'Runtime validation threw an unexpected error', 'Check observability stack health'));\n    93→    }\n    94→\n    95→    return dimOk('observability', worstStatus(sStatus, rStatus), `${sMetric}, ${rMetric}`, gaps);\n    96→  } catch (err: unknown) { return dimCatch('observability', err); }\n    97→}\n    98→\n    99→// ─── Testing (Task 2.2) ────────────────────────────────────────────────────\n   100→\n   101→export function checkTesting(projectDir: string): Result<DimensionResult> {\n   102→  try {\n   103→    const r = checkOnlyCoverage(projectDir);\n   104→    if (!r.success) return dimOk('testing', 'warn', 'no coverage data', [gap('testing', 'No coverage tool detected or coverage data unavailable', 'Run tests with coverage: npm run test:coverage')]);\n   105→\n   106→    const pct = r.coveragePercent;\n   107→    const gaps: AuditGap[] = [];\n   108→    let status: Status = 'pass';\n   109→    if (pct < 50) { status = 'fail'; gaps.push(gap('testing', `Test coverage critically low: ${pct}%`, 'Add unit tests to increase coverage above 50%')); }\n   110→    else if (pct < 80) { status = 'warn'; gaps.push(gap('testing', `Test coverage below target: ${pct}%`, 'Add tests to reach 80% coverage target')); }\n   111→    return dimOk('testing', status, `${pct}%`, gaps);\n   112→  } catch (err: unknown) { return dimCatch('testing', err); }\n   113→}\n   114→\n   115→// ─── Documentation (Task 2.3) ──────────────────────────────────────────────\n   116→\n   117→export function checkDocumentation(projectDir: string): Result<DimensionResult> {\n   118→  try {\n   119→    const report = scanDocHealth(projectDir);\n   120→    const gaps: AuditGap[] = [];\n   121→    const { fresh, stale, missing } = report.summary;\n   122→    let status: Status = 'pass';\n   123→\n   124→    if (missing > 0) {\n   125→      status = 'fail';\n   126→      for (const doc of report.documents) if (doc.grade === 'missing') gaps.push(gap('documentation', `Missing: ${doc.path} — ${doc.reason}`, `Create ${doc.path}`));\n   127→    }\n   128→    if (stale > 0) {\n   129→      if (status !== 'fail') status = 'warn';\n   130→      for (const doc of report.documents) if (doc.grade === 'stale') gaps.push(gap('documentation', `Stale: ${doc.path} — ${doc.reason}`, `Update ${doc.path} to reflect current code`));\n   131→    }\n   132→    return dimOk('documentation', status, `${fresh} fresh, ${stale} stale, ${missing} missing`, gaps);\n   133→  } catch (err: unknown) { return dimCatch('documentation', err); }\n   134→}\n   135→\n   136→// ─── Verification (Task 2.4) ───────────────────────────────────────────────\n   137→\n   138→export function checkVerification(projectDir: string): Result<DimensionResult> {\n   139→  try {\n   140→    const gaps: AuditGap[] = [];\n   141→    const sprintPath = join(projectDir, '_bmad-output', 'implementation-artifacts', 'sprint-status.yaml');\n   142→    if (!existsSync(sprintPath)) return dimOk('verification', 'warn', 'no sprint data', [gap('verification', 'No sprint-status.yaml found', 'Run sprint planning to create sprint status')]);\n   143→\n   144→    const vDir = join(projectDir, 'verification');\n   145→    let proofCount = 0, totalChecked = 0;\n   146→\n   147→    if (existsSync(vDir)) {\n   148→      for (const file of readdirSafe(vDir)) {\n   149→        if (!file.endsWith('-proof.md')) continue;\n   150→        totalChecked++;\n   151→        const r = parseProof(join(vDir, file));\n   152→        if (isOk(r) && r.data.passed) { proofCount++; }\n   153→        else { gaps.push(gap('verification', `Story ${file.replace('-proof.md', '')} proof incomplete or failing`, `Run codeharness verify ${file.replace('-proof.md', '')}`)); }\n   154→      }\n   155→    }\n   156→\n   157→    let status: Status = 'pass';\n   158→    if (totalChecked === 0) { status = 'warn'; gaps.push(gap('verification', 'No verification proofs found', 'Run codeharness verify for completed stories')); }\n   159→    else if (proofCount < totalChecked) { status = 'warn'; }\n   160→\n   161→    return dimOk('verification', status, totalChecked > 0 ? `${proofCount}/${totalChecked} verified` : 'no proofs', gaps);\n   162→  } catch (err: unknown) { return dimCatch('verification', err); }\n   163→}\n   164→\n   165→// ─── Infrastructure (Task 2.5) ─────────────────────────────────────────────\n   166→\n   167→export function checkInfrastructure(projectDir: string): Result<DimensionResult> {\n   168→  try {\n   169→    const dfPath = join(projectDir, 'Dockerfile');\n   170→    if (!existsSync(dfPath)) return dimOk('infrastructure', 'fail', 'no Dockerfile', [gap('infrastructure', 'No Dockerfile found', 'Create a Dockerfile for containerized deployment')]);\n   171→\n   172→    let content: string;\n   173→    try { content = readFileSync(dfPath, 'utf-8'); }\n   174→    catch { return dimOk('infrastructure', 'warn', 'Dockerfile unreadable', [gap('infrastructure', 'Dockerfile exists but could not be read', 'Check Dockerfile permissions')]); }\n   175→\n   176→    const fromLines = content.split('\\n').filter(l => /^\\s*FROM\\s+/i.test(l));\n   177→    if (fromLines.length === 0) return dimOk('infrastructure', 'fail', 'invalid Dockerfile', [gap('infrastructure', 'Dockerfile has no FROM instruction', 'Add a FROM instruction with a pinned base image')]);\n   178→\n   179→    const result = validateDockerfile(projectDir);\n   180→    if (!result.success) return dimOk('infrastructure', 'fail', 'validation failed', [gap('infrastructure', result.error, 'Fix Dockerfile validation errors')]);\n   181→\n   182→    const gaps: AuditGap[] = result.data.gaps.map(g => gap('infrastructure', g.description, g.suggestedFix));\n   183→    const issueCount = gaps.length;\n   184→    const status: Status = issueCount > 0 ? 'warn' : 'pass';\n   185→    const metric = issueCount > 0 ? `Dockerfile exists (${issueCount} issue${issueCount !== 1 ? 's' : ''})` : 'Dockerfile valid';\n   186→    return dimOk('infrastructure', status, metric, gaps);\n   187→  } catch (err: unknown) { return dimCatch('infrastructure', err); }\n   188→}\n   189→\n   190→// ─── Helpers ────────────────────────────────────────────────────────────────\n   191→\n   192→function readdirSafe(dir: string): string[] {\n   193→  try { return readdirSync(dir) as string[]; }\n   194→  catch { return []; }\n   195→}\n   196→"}]},"parent_tool_use_id":"toolu_01L29ZYMVj58MqWKkJPFgRHa","session_id":"77451c69-f489-4aef-ba6d-37b512cc36ec","uuid":"e8448acb-2200-4bb0-9190-6c7f169719dd","timestamp":"2026-03-21T05:24:26.127Z"}
