{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DViuBihRTYazps9oSpSid3","type":"tool_result","content":"     1→/**\n     2→ * VictoriaBackend — ObservabilityBackend implementation for the Victoria stack.\n     3→ * Queries Victoria Logs, Victoria Metrics, and Jaeger via their HTTP APIs.\n     4→ * Uses Node.js built-in fetch (no external HTTP dependencies).\n     5→ */\n     6→\n     7→import type {\n     8→  ObservabilityBackend,\n     9→  LogQuery,\n    10→  LogResult,\n    11→  LogEntry,\n    12→  MetricQuery,\n    13→  MetricResult,\n    14→  MetricSeries,\n    15→  MetricDataPoint,\n    16→  TraceQuery,\n    17→  TraceResult,\n    18→  TraceSpan,\n    19→  HealthStatus,\n    20→} from '../../types/observability.js';\n    21→import type { Result } from '../../types/result.js';\n    22→import { ok, fail } from '../../types/result.js';\n    23→import { DEFAULT_PORTS } from './types.js';\n    24→\n    25→/** Configuration for VictoriaBackend service URLs */\n    26→export interface VictoriaConfig {\n    27→  logsUrl?: string;\n    28→  metricsUrl?: string;\n    29→  tracesUrl?: string;\n    30→}\n    31→\n    32→const DEFAULT_LOGS_URL = `http://localhost:${DEFAULT_PORTS.logs}`;\n    33→const DEFAULT_METRICS_URL = `http://localhost:${DEFAULT_PORTS.metrics}`;\n    34→const DEFAULT_TRACES_URL = `http://localhost:${DEFAULT_PORTS.traces}`;\n    35→\n    36→/** Default timeout for query requests (30s) */\n    37→const QUERY_TIMEOUT_MS = 30_000;\n    38→/** Default timeout for health check requests (5s) */\n    39→const HEALTH_TIMEOUT_MS = 5_000;\n    40→\n    41→export class VictoriaBackend implements ObservabilityBackend {\n    42→  readonly type = 'victoria' as const;\n    43→  private readonly logsUrl: string;\n    44→  private readonly metricsUrl: string;\n    45→  private readonly tracesUrl: string;\n    46→\n    47→  constructor(config?: VictoriaConfig) {\n    48→    this.logsUrl = config?.logsUrl ?? DEFAULT_LOGS_URL;\n    49→    this.metricsUrl = config?.metricsUrl ?? DEFAULT_METRICS_URL;\n    50→    this.tracesUrl = config?.tracesUrl ?? DEFAULT_TRACES_URL;\n    51→  }\n    52→\n    53→  async queryLogs(params: LogQuery): Promise<Result<LogResult>> {\n    54→    const url = new URL('/select/logsql/query', this.logsUrl);\n    55→    url.searchParams.set('query', params.query);\n    56→    url.searchParams.set('start', params.timeRange.start);\n    57→    url.searchParams.set('end', params.timeRange.end);\n    58→    if (params.limit !== undefined) {\n    59→      url.searchParams.set('limit', String(params.limit));\n    60→    }\n    61→\n    62→    const endpoint = url.toString();\n    63→    try {\n    64→      const response = await fetch(endpoint, { signal: AbortSignal.timeout(QUERY_TIMEOUT_MS) });\n    65→      if (!response.ok) {\n    66→        return fail(`Victoria Logs returned ${response.status}`, {\n    67→          endpoint,\n    68→          statusCode: response.status,\n    69→        });\n    70→      }\n    71→      const text = await response.text();\n    72→      const entries = parseLogEntries(text);\n    73→      return ok({ entries, total: entries.length });\n    74→    } catch (err) {\n    75→      return fail(errorMessage(err), { endpoint });\n    76→    }\n    77→  }\n    78→\n    79→  async queryMetrics(params: MetricQuery): Promise<Result<MetricResult>> {\n    80→    const url = new URL('/api/v1/query_range', this.metricsUrl);\n    81→    url.searchParams.set('query', params.query);\n    82→    url.searchParams.set('start', params.timeRange.start);\n    83→    url.searchParams.set('end', params.timeRange.end);\n    84→    if (params.step !== undefined) {\n    85→      url.searchParams.set('step', params.step);\n    86→    }\n    87→\n    88→    const endpoint = url.toString();\n    89→    try {\n    90→      const response = await fetch(endpoint, { signal: AbortSignal.timeout(QUERY_TIMEOUT_MS) });\n    91→      if (!response.ok) {\n    92→        return fail(`Victoria Metrics returned ${response.status}`, {\n    93→          endpoint,\n    94→          statusCode: response.status,\n    95→        });\n    96→      }\n    97→      const body = (await response.json()) as PrometheusResponse;\n    98→      const series = parseMetricSeries(body);\n    99→      return ok({ series });\n   100→    } catch (err) {\n   101→      return fail(errorMessage(err), { endpoint });\n   102→    }\n   103→  }\n   104→\n   105→  async queryTraces(params: TraceQuery): Promise<Result<TraceResult>> {\n   106→    const url = new URL('/api/traces', this.tracesUrl);\n   107→    if (params.serviceName) {\n   108→      url.searchParams.set('service', params.serviceName);\n   109→    }\n   110→    if (params.operationName) {\n   111→      url.searchParams.set('operation', params.operationName);\n   112→    }\n   113→    url.searchParams.set('start', params.timeRange.start);\n   114→    url.searchParams.set('end', params.timeRange.end);\n   115→    if (params.limit !== undefined) {\n   116→      url.searchParams.set('limit', String(params.limit));\n   117→    }\n   118→\n   119→    const endpoint = url.toString();\n   120→    try {\n   121→      const response = await fetch(endpoint, { signal: AbortSignal.timeout(QUERY_TIMEOUT_MS) });\n   122→      if (!response.ok) {\n   123→        return fail(`Jaeger returned ${response.status}`, {\n   124→          endpoint,\n   125→          statusCode: response.status,\n   126→        });\n   127→      }\n   128→      const body = (await response.json()) as JaegerResponse;\n   129→      const spans = parseTraceSpans(body);\n   130→      return ok({ spans });\n   131→    } catch (err) {\n   132→      return fail(errorMessage(err), { endpoint });\n   133→    }\n   134→  }\n   135→\n   136→  async healthCheck(): Promise<Result<HealthStatus>> {\n   137→    const start = Date.now();\n   138→    const checks = await Promise.allSettled([\n   139→      fetch(`${this.logsUrl}/health`, { signal: AbortSignal.timeout(HEALTH_TIMEOUT_MS) }),\n   140→      fetch(`${this.metricsUrl}/health`, { signal: AbortSignal.timeout(HEALTH_TIMEOUT_MS) }),\n   141→      fetch(`${this.tracesUrl}/`, { signal: AbortSignal.timeout(HEALTH_TIMEOUT_MS) }),\n   142→    ]);\n   143→    const latencyMs = Date.now() - start;\n   144→\n   145→    const failures: string[] = [];\n   146→    const serviceNames = ['victoria-logs', 'victoria-metrics', 'jaeger'];\n   147→\n   148→    for (let i = 0; i < checks.length; i++) {\n   149→      const check = checks[i];\n   150→      if (check.status === 'rejected') {\n   151→        failures.push(`${serviceNames[i]}: ${errorMessage(check.reason)}`);\n   152→      } else if (!check.value.ok) {\n   153→        failures.push(`${serviceNames[i]}: HTTP ${check.value.status}`);\n   154→      }\n   155→    }\n   156→\n   157→    const healthy = failures.length === 0;\n   158→    const message = healthy\n   159→      ? 'All services healthy'\n   160→      : `Unhealthy: ${failures.join('; ')}`;\n   161→\n   162→    return ok({ healthy, message, latencyMs });\n   163→  }\n   164→}\n   165→\n   166→// --- Internal helpers & response types ---\n   167→\n   168→function errorMessage(err: unknown): string {\n   169→  if (err instanceof Error) return err.message;\n   170→  return String(err);\n   171→}\n   172→\n   173→/** Parse newline-delimited JSON log entries from Victoria Logs */\n   174→function parseLogEntries(text: string): LogEntry[] {\n   175→  if (!text.trim()) return [];\n   176→  const lines = text.trim().split('\\n');\n   177→  const entries: LogEntry[] = [];\n   178→  for (const line of lines) {\n   179→    try {\n   180→      const raw = JSON.parse(line) as Record<string, unknown>;\n   181→      entries.push({\n   182→        timestamp: String(raw._time ?? raw.timestamp ?? ''),\n   183→        message: String(raw._msg ?? raw.message ?? ''),\n   184→        level: String(raw.level ?? raw._level ?? 'unknown'),\n   185→        labels: extractLabels(raw),\n   186→      });\n   187→    } catch {\n   188→      // skip malformed lines\n   189→    }\n   190→  }\n   191→  return entries;\n   192→}\n   193→\n   194→function extractLabels(raw: Record<string, unknown>): Record<string, string> {\n   195→  const labels: Record<string, string> = {};\n   196→  const skip = new Set(['_time', '_msg', 'timestamp', 'message', 'level', '_level']);\n   197→  for (const [k, v] of Object.entries(raw)) {\n   198→    if (!skip.has(k) && v != null && typeof v !== 'object') {\n   199→      labels[k] = String(v);\n   200→    }\n   201→  }\n   202→  return labels;\n   203→}\n   204→\n   205→/** Prometheus-compatible response shape */\n   206→interface PrometheusResponse {\n   207→  data?: {\n   208→    resultType?: string;\n   209→    result?: Array<{\n   210→      metric?: Record<string, string>;\n   211→      values?: Array<[number, string]>;\n   212→    }>;\n   213→  };\n   214→}\n   215→\n   216→function parseMetricSeries(body: PrometheusResponse): MetricSeries[] {\n   217→  const results = body.data?.result ?? [];\n   218→  return results.map((r) => ({\n   219→    labels: r.metric ?? {},\n   220→    dataPoints: (r.values ?? []).map(([ts, val]): MetricDataPoint => ({\n   221→      timestamp: String(ts),\n   222→      value: Number(val),\n   223→    })),\n   224→  }));\n   225→}\n   226→\n   227→/** Jaeger API response shape */\n   228→interface JaegerResponse {\n   229→  data?: Array<{\n   230→    traceID?: string;\n   231→    spans?: Array<{\n   232→      traceID?: string;\n   233→      spanID?: string;\n   234→      references?: Array<{ refType?: string; spanID?: string }>;\n   235→      operationName?: string;\n   236→      process?: { serviceName?: string };\n   237→      startTime?: number;\n   238→      duration?: number;\n   239→      tags?: Array<{ key?: string; value?: unknown }>;\n   240→    }>;\n   241→  }>;\n   242→}\n   243→\n   244→function parseTraceSpans(body: JaegerResponse): TraceSpan[] {\n   245→  const spans: TraceSpan[] = [];\n   246→  for (const trace of body.data ?? []) {\n   247→    for (const s of trace.spans ?? []) {\n   248→      const parentRef = s.references?.find((r) => r.refType === 'CHILD_OF');\n   249→      const tags: Record<string, string> = {};\n   250→      for (const t of s.tags ?? []) {\n   251→        if (t.key) tags[t.key] = String(t.value ?? '');\n   252→      }\n   253→      spans.push({\n   254→        traceId: s.traceID ?? trace.traceID ?? '',\n   255→        spanId: s.spanID ?? '',\n   256→        parentSpanId: parentRef?.spanID ?? null,\n   257→        operationName: s.operationName ?? '',\n   258→        serviceName: s.process?.serviceName ?? '',\n   259→        startTime: String(s.startTime ?? 0),\n   260→        duration: s.duration ?? 0,\n   261→        tags,\n   262→      });\n   263→    }\n   264→  }\n   265→  return spans;\n   266→}\n   267→"}]},"parent_tool_use_id":"toolu_014QEC8wgRDzeoWECp9trCxd","session_id":"c5eaf6a6-ac7c-4707-b82c-6220d711aa9c","uuid":"aa41f1aa-71ed-42a8-ba18-510cbc34cc99","timestamp":"2026-03-20T06:38:00.883Z"}
