{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015mZMjyXKbWw3HKXG1nQimq","type":"tool_result","content":"     1в†’/**\n     2в†’ * README.md template for project documentation.\n     3в†’ * Uses static template from templates/docs/readme.md.tmpl with {{VAR}} interpolation.\n     4в†’ *\n     5в†’ * Generated by `codeharness init` when README.md does not exist.\n     6в†’ * Never overwrites an existing README.md.\n     7в†’ */\n     8в†’\n     9в†’import { renderTemplateFile } from '../lib/templates.js';\n    10в†’\n    11в†’export interface ReadmeTemplateConfig {\n    12в†’  /** Project name (from package.json name or directory basename) */\n    13в†’  projectName: string;\n    14в†’  /** Detected stack: 'nodejs', 'python', 'rust', array of stacks, or null */\n    15в†’  stack: string | string[] | null;\n    16в†’  /** Output of `codeharness --help` for CLI reference section */\n    17в†’  cliHelpOutput: string;\n    18в†’}\n    19в†’\n    20в†’/**\n    21в†’ * Generates README.md content from the template config.\n    22в†’ */\n    23в†’export function readmeTemplate(config: ReadmeTemplateConfig): string {\n    24в†’  const { projectName, stack, cliHelpOutput } = config;\n    25в†’\n    26в†’  const installCommand = getInstallCommand(stack);\n    27в†’\n    28в†’  return renderTemplateFile('templates/docs/readme.md.tmpl', {\n    29в†’    PROJECT_NAME: projectName,\n    30в†’    INSTALL_COMMAND: installCommand,\n    31в†’    CLI_HELP_OUTPUT: cliHelpOutput.trimEnd(),\n    32в†’  });\n    33в†’}\n    34в†’\n    35в†’export function getInstallCommand(stack: string | string[] | null): string {\n    36в†’  if (Array.isArray(stack)) {\n    37в†’    const commands = stack.map(s => getSingleInstallCommand(s));\n    38в†’    // Deduplicate in case multiple stacks share an install command\n    39в†’    return [...new Set(commands)].join('\\n');\n    40в†’  }\n    41в†’  return getSingleInstallCommand(stack);\n    42в†’}\n    43в†’\n    44в†’/** Per-stack install commands, keyed by stack name. */\n    45в†’const INSTALL_COMMANDS: Record<string, string> = {\n    46в†’  python: 'pip install codeharness',\n    47в†’  rust: 'cargo install codeharness',\n    48в†’};\n    49в†’\n    50в†’function getSingleInstallCommand(stack: string | null): string {\n    51в†’  if (stack && INSTALL_COMMANDS[stack]) return INSTALL_COMMANDS[stack];\n    52в†’  return 'npm install -g codeharness';\n    53в†’}\n    54в†’"}]},"parent_tool_use_id":"toolu_011Fip6m9FHVBszWegBeTJVL","session_id":"406ac605-1908-4bc8-82ff-6bd28578af4b","uuid":"65fd4751-81d7-4aa3-a641-c1b7e78c7786","timestamp":"2026-03-25T02:24:39.435Z"}
