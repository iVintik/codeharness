{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01XhCFfi94cFSmv1fp85VdtA","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_013nDhRN67q4MoEPSFe9x25S","name":"Write","input":{"file_path":"/Users/ivintik/dev/personal/codeharness/src/lib/stacks/utils.ts","content":"/**\n * Shared utility functions for stack providers.\n * Extracted from stack-detect.ts to avoid duplication across providers.\n */\n\nimport { existsSync, readFileSync } from 'node:fs';\n\n/** Safely read and parse a JSON file. Returns null on any error. */\nexport function readJsonSafe(path: string): Record<string, unknown> | null {\n  try {\n    if (!existsSync(path)) return null;\n    return JSON.parse(readFileSync(path, 'utf-8')) as Record<string, unknown>;\n  } catch {\n    return null;\n  }\n}\n\n/** Safely read a text file. Returns null on any error. */\nexport function readTextSafe(path: string): string | null {\n  try {\n    if (!existsSync(path)) return null;\n    return readFileSync(path, 'utf-8');\n  } catch {\n    return null;\n  }\n}\n\n/** Collect all dependency names from a package.json object (dependencies + devDependencies). */\nexport function getNodeDeps(pkg: Record<string, unknown>): Set<string> {\n  const deps = new Set<string>();\n  for (const field of ['dependencies', 'devDependencies']) {\n    const section = pkg[field] as Record<string, string> | undefined;\n    if (section && typeof section === 'object') {\n      for (const key of Object.keys(section)) {\n        deps.add(key);\n      }\n    }\n  }\n  return deps;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":205,"cache_read_input_tokens":52600,"cache_creation":{"ephemeral_5m_input_tokens":205,"ephemeral_1h_input_tokens":0},"output_tokens":59,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01ARDMJdo7LDpJboWrzKfH84","session_id":"ec2bf