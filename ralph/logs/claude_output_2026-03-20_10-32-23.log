{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01D6YANb9JizfX4hH9TGDBjH","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n     2→\n     3→// Mock node:child_process\n     4→vi.mock('node:child_process', () => ({\n     5→  execSync: vi.fn(),\n     6→}));\n     7→\n     8→// Mock node:fs\n     9→vi.mock('node:fs', () => ({\n    10→  readdirSync: vi.fn(),\n    11→  statSync: vi.fn(),\n    12→  readFileSync: vi.fn(),\n    13→  writeFileSync: vi.fn(),\n    14→  renameSync: vi.fn(),\n    15→  existsSync: vi.fn(),\n    16→}));\n    17→\n    18→// Mock global fetch\n    19→const mockFetch = vi.fn();\n    20→vi.stubGlobal('fetch', mockFetch);\n    21→\n    22→import { execSync } from 'node:child_process';\n    23→import { readdirSync, statSync } from 'node:fs';\n    24→import {\n    25→  validateRuntime,\n    26→  checkBackendHealth,\n    27→  queryTelemetryEvents,\n    28→  mapEventsToModules,\n    29→} from '../runtime-validator.js';\n    30→import {\n    31→  validateRuntime as barrelValidateRuntime,\n    32→  checkBackendHealth as barrelCheckBackendHealth,\n    33→  queryTelemetryEvents as barrelQueryTelemetryEvents,\n    34→  mapEventsToModules as barrelMapEventsToModules,\n    35→} from '../index.js';\n    36→import type {\n    37→  RuntimeValidationConfig,\n    38→  ModuleTelemetryEntry,\n    39→  RuntimeValidationResult,\n    40→  TelemetryEvent,\n    41→} from '../types.js';\n    42→\n    43→const mockExecSync = vi.mocked(execSync);\n    44→const mockReaddirSync = vi.mocked(readdirSync);\n    45→const mockStatSync = vi.mocked(statSync);\n    46→\n    47→beforeEach(() => {\n    48→  vi.resetAllMocks();\n    49→});\n    50→\n    51→afterEach(() => {\n    52→  vi.restoreAllMocks();\n    53→});\n    54→\n    55→// Helper: mock module discovery\n    56→function setupModuleDiscovery(modules: string[]) {\n    57→  mockReaddirSync.mockReturnValue(modules as unknown as ReturnType<typeof readdirSync>);\n    58→  mockStatSync.mockImplementation((_path) => ({\n    59→    isDirectory: () => true,\n    60→    isFile: () => false,\n    61→  }) as ReturnType<typeof statSync>);\n    62→}\n    63→\n    64→// Helper: make a successful health response\n    65→function mockHealthy() {\n    66→  mockFetch.mockResolvedValueOnce({ ok: true, status: 200 });\n    67→}\n    68→\n    69→// Helper: make a failed health response\n    70→function mockUnhealthy() {\n    71→  mockFetch.mockRejectedValueOnce(new Error('ECONNREFUSED'));\n    72→}\n    73→\n    74→// Helper: make a successful query response with events\n    75→function mockQueryResponse(events: Array<{ source: string; message: string }>) {\n    76→  const ndjson = events\n    77→    .map((e) => JSON.stringify({ _time: '2026-03-20T10:00:00Z', _msg: e.message, source: e.source }))\n    78→    .join('\\n');\n    79→  mockFetch.mockResolvedValueOnce({\n    80→    ok: true,\n    81→    status: 200,\n    82→    text: async () => ndjson,\n    83→  });\n    84→}\n    85→\n    86→// ============================================================\n    87→// Module barrel exports\n    88→// ============================================================\n    89→\n    90→describe('module barrel exports', () => {\n    91→  it('re-exports validateRuntime from index.ts', () => {\n    92→    expect(barrelValidateRuntime).toBe(validateRuntime);\n    93→  });\n    94→\n    95→  it('re-exports checkBackendHealth from index.ts', () => {\n    96→    expect(barrelCheckBackendHealth).toBe(checkBackendHealth);\n    97→  });\n    98→\n    99→  it('re-exports queryTelemetryEvents from index.ts', () => {\n   100→    expect(barrelQueryTelemetryEvents).toBe(queryTelemetryEvents);\n   101→  });\n   102→\n   103→  it('re-exports mapEventsToModules from index.ts', () => {\n   104→    expect(barrelMapEventsToModules).toBe(mapEventsToModules);\n   105→  });\n   106→});\n   107→\n   108→// ============================================================\n   109→// checkBackendHealth\n   110→// ============================================================\n   111→\n   112→describe('checkBackendHealth', () => {\n   113→  it('returns true when health endpoint responds 200', async () => {\n   114→    mockFetch.mockResolvedValueOnce({ ok: true, status: 200 });\n   115→    const result = await checkBackendHealth('http://localhost:9428');\n   116→    expect(result).toBe(true);\n   117→    expect(mockFetch).toHaveBeenCalledWith(\n   118→      'http://localhost:9428/health',\n   119→      expect.objectContaining({ signal: expect.any(AbortSignal) }),\n   120→    );\n   121→  });\n   122→\n   123→  it('returns false when health endpoint returns 503', async () => {\n   124→    mockFetch.mockResolvedValueOnce({ ok: false, status: 503 });\n   125→    const result = await checkBackendHealth('http://localhost:9428');\n   126→    expect(result).toBe(false);\n   127→  });\n   128→\n   129→  it('returns false when fetch throws (ECONNREFUSED)', async () => {\n   130→    mockFetch.mockRejectedValueOnce(new Error('ECONNREFUSED'));\n   131→    const result = await checkBackendHealth('http://localhost:9428');\n   132→    expect(result).toBe(false);\n   133→  });\n   134→});\n   135→\n   136→// ============================================================\n   137→// queryTelemetryEvents\n   138→// ============================================================\n   139→\n   140→describe('queryTelemetryEvents', () => {\n   141→  it('returns parsed events from ndjson response', async () => {\n   142→    const ndjson = [\n   143→      JSON.stringify({ _time: '2026-03-20T10:00:00Z', _msg: 'hello', source: 'moduleA' }),\n   144→      JSON.stringify({ _time: '2026-03-20T10:00:01Z', _msg: 'world', source: 'moduleB' }),\n   145→    ].join('\\n');\n   146→    mockFetch.mockResolvedValueOnce({ ok: true, text: async () => ndjson });\n   147→\n   148→    const result = await queryTelemetryEvents('http://localhost:9428', '2026-03-20T09:00:00Z', '2026-03-20T11:00:00Z');\n   149→    expect(result.success).toBe(true);\n   150→    if (result.success) {\n   151→      expect(result.data).toHaveLength(2);\n   152→      expect(result.data[0].source).toBe('moduleA');\n   153→      expect(result.data[1].message).toBe('world');\n   154→    }\n   155→  });\n   156→\n   157→  it('returns empty array for empty response', async () => {\n   158→    mockFetch.mockResolvedValueOnce({ ok: true, text: async () => '' });\n   159→    const result = await queryTelemetryEvents('http://localhost:9428', 'start', 'end');\n   160→    expect(result.success).toBe(true);\n   161→    if (result.success) {\n   162→      expect(result.data).toHaveLength(0);\n   163→    }\n   164→  });\n   165→\n   166→  it('returns fail when backend returns non-2xx', async () => {\n   167→    mockFetch.mockResolvedValueOnce({ ok: false, status: 500 });\n   168→    const result = await queryTelemetryEvents('http://localhost:9428', 'start', 'end');\n   169→    expect(result.success).toBe(false);\n   170→    if (!result.success) {\n   171→      expect(result.error).toContain('VictoriaLogs returned 500');\n   172→    }\n   173→  });\n   174→\n   175→  it('returns fail when fetch throws', async () => {\n   176→    mockFetch.mockRejectedValueOnce(new Error('timeout'));\n   177→    const result = await queryTelemetryEvents('http://localhost:9428', 'start', 'end');\n   178→    expect(result.success).toBe(false);\n   179→    if (!result.success) {\n   180→      expect(result.error).toContain('Failed to query telemetry events');\n   181→      expect(result.error).toContain('timeout');\n   182→    }\n   183→  });\n   184→\n   185→  it('handles non-Error thrown by fetch', async () => {\n   186→    mockFetch.mockRejectedValueOnce('raw string');\n   187→    const result = await queryTelemetryEvents('http://localhost:9428', 'start', 'end');\n   188→    expect(result.success).toBe(false);\n   189→    if (!result.success) {\n   190→      expect(result.error).toContain('raw string');\n   191→    }\n   192→  });\n   193→\n   194→  it('skips malformed JSON lines', async () => {\n   195→    const ndjson = [\n   196→      JSON.stringify({ _time: 't1', _msg: 'ok', source: 'a' }),\n   197→      'NOT VALID JSON',\n   198→      JSON.stringify({ _time: 't2', _msg: 'ok2', source: 'b' }),\n   199→    ].join('\\n');\n   200→    mockFetch.mockResolvedValueOnce({ ok: true, text: async () => ndjson });\n   201→    const result = await queryTelemetryEvents('http://localhost:9428', 's', 'e');\n   202→    expect(result.success).toBe(true);\n   203→    if (result.success) {\n   204→      expect(result.data).toHaveLength(2);\n   205→    }\n   206→  });\n   207→});\n   208→\n   209→// ============================================================\n   210→// mapEventsToModules\n   211→// ============================================================\n   212→\n   213→describe('mapEventsToModules', () => {\n   214→  it('maps events to modules by source match', () => {\n   215→    const events: TelemetryEvent[] = [\n   216→      { timestamp: 't1', message: 'msg1', source: 'commands/run' },\n   217→      { timestamp: 't2', message: 'msg2', source: 'modules/verify' },\n   218→      { timestamp: 't3', message: 'msg3', source: 'commands/init' },\n   219→    ];\n   220→    const result = mapEventsToModules(events, '/project', ['commands', 'modules', 'types']);\n   221→    expect(result).toHaveLength(3);\n   222→    expect(result[0]).toEqual({ moduleName: 'commands', telemetryDetected: true, eventCount: 2 });\n   223→    expect(result[1]).toEqual({ moduleName: 'modules', telemetryDetected: true, eventCount: 1 });\n   224→    expect(result[2]).toEqual({ moduleName: 'types', telemetryDetected: false, eventCount: 0 });\n   225→  });\n   226→\n   227→  it('maps events by message when source does not match', () => {\n   228→    const events: TelemetryEvent[] = [\n   229→      { timestamp: 't1', message: 'Processing lib data', source: '' },\n   230→    ];\n   231→    const result = mapEventsToModules(events, '/project', ['lib', 'utils']);\n   232→    expect(result[0]).toEqual({ moduleName: 'lib', telemetryDetected: true, eventCount: 1 });\n   233→    expect(result[1]).toEqual({ moduleName: 'utils', telemetryDetected: false, eventCount: 0 });\n   234→  });\n   235→\n   236→  it('returns empty when no modules provided', () => {\n   237→    const events: TelemetryEvent[] = [\n   238→      { timestamp: 't1', message: 'msg', source: 'a' },\n   239→    ];\n   240→    const result = mapEventsToModules(events, '/project');\n   241→    expect(result).toHaveLength(0);\n   242→  });\n   243→\n   244→  it('returns all zero when no events match', () => {\n   245→    const result = mapEventsToModules([], '/project', ['a', 'b', 'c']);\n   246→    expect(result).toHaveLength(3);\n   247→    expect(result.every((e) => !e.telemetryDetected)).toBe(true);\n   248→    expect(result.every((e) => e.eventCount === 0)).toBe(true);\n   249→  });\n   250→});\n   251→\n   252→// ============================================================\n   253→// validateRuntime — skipped (backend unreachable)\n   254→// ============================================================\n   255→\n   256→describe('validateRuntime — backend unreachable (AC #3)', () => {\n   257→  it('returns skipped result with correct message', async () => {\n   258→    mockUnhealthy();\n   259→    setupModuleDiscovery(['commands', 'modules', 'types']);\n   260→\n   261→    const result = await validateRuntime('/project');\n   262→    expect(result.success).toBe(true);\n   263→    if (result.success) {\n   264→      expect(result.data.skipped).toBe(true);\n   265→      expect(result.data.skipReason).toBe(\n   266→        'runtime validation skipped -- observability stack not available',\n   267→      );\n   268→      expect(result.data.coveragePercent).toBe(0);\n   269→      expect(result.data.modulesWithTelemetry).toBe(0);\n   270→      expect(result.data.totalModules).toBe(3);\n   271→      expect(result.data.entries).toHaveLength(3);\n   272→      expect(result.data.entries.every((e) => !e.telemetryDetected)).toBe(true);\n   273→    }\n   274→  });\n   275→\n   276→  it('does not run tests when backend is unreachable', async () => {\n   277→    mockUnhealthy();\n   278→    setupModuleDiscovery([]);\n   279→    await validateRuntime('/project');\n   280→    expect(mockExecSync).not.toHaveBeenCalled();\n   281→  });\n   282→});\n   283→\n   284→// ============================================================\n   285→// validateRuntime — happy path (AC #1)\n   286→// ============================================================\n   287→\n   288→describe('validateRuntime — healthy backend (AC #1)', () => {\n   289→  it('runs tests and queries backend', async () => {\n   290→    mockHealthy();\n   291→    mockExecSync.mockReturnValue(Buffer.from(''));\n   292→    setupModuleDiscovery(['commands', 'modules']);\n   293→\n   294→    // Query response\n   295→    mockQueryResponse([\n   296→      { source: 'commands/run', message: 'test' },\n   297→      { source: 'modules/verify', message: 'test' },\n   298→    ]);\n   299→\n   300→    const result = await validateRuntime('/project');\n   301→    expect(result.success).toBe(true);\n   302→    if (result.success) {\n   303→      expect(result.data.skipped).toBe(false);\n   304→      expect(result.data.totalModules).toBe(2);\n   305→      expect(result.data.modulesWithTelemetry).toBe(2);\n   306→      expect(result.data.coveragePercent).toBe(100);\n   307→    }\n   308→    expect(mockExecSync).toHaveBeenCalledOnce();\n   309→    expect(mockExecSync).toHaveBeenCalledWith(\n   310→      'npm test',\n   311→      expect.objectContaining({\n   312→        cwd: '/project',\n   313→        env: expect.objectContaining({\n   314→          OTEL_EXPORTER_OTLP_ENDPOINT: 'http://localhost:4318',\n   315→        }),\n   316→      }),\n   317→    );\n   318→  });\n   319→});\n   320→\n   321→// ============================================================\n   322→// validateRuntime — coverage computation (AC #2)\n   323→// ============================================================\n   324→\n   325→describe('validateRuntime — coverage computation (AC #2)', () => {\n   326→  it('computes 62.5% with 5/8 modules emitting telemetry', async () => {\n   327→    mockHealthy();\n   328→    mockExecSync.mockReturnValue(Buffer.from(''));\n   329→    setupModuleDiscovery(['m1', 'm2', 'm3', 'm4', 'm5', 'm6', 'm7', 'm8']);\n   330→\n   331→    mockQueryResponse([\n   332→      { source: 'm1/file', message: '' },\n   333→      { source: 'm2/file', message: '' },\n   334→      { source: 'm3/file', message: '' },\n   335→      { source: 'm4/file', message: '' },\n   336→      { source: 'm5/file', message: '' },\n   337→    ]);\n   338→\n   339→    const result = await validateRuntime('/project');\n   340→    expect(result.success).toBe(true);\n   341→    if (result.success) {\n   342→      expect(result.data.totalModules).toBe(8);\n   343→      expect(result.data.modulesWithTelemetry).toBe(5);\n   344→      expect(result.data.coveragePercent).toBe(62.5);\n   345→      // The 3 silent modules\n   346→      const silent = result.data.entries.filter((e) => !e.telemetryDetected);\n   347→      expect(silent).toHaveLength(3);\n   348→      expect(silent.map((s) => s.moduleName).sort()).toEqual(['m6', 'm7', 'm8']);\n   349→    }\n   350→  });\n   351→\n   352→  it('computes 0% when no modules emit telemetry', async () => {\n   353→    mockHealthy();\n   354→    mockExecSync.mockReturnValue(Buffer.from(''));\n   355→    setupModuleDiscovery(['a', 'b', 'c']);\n   356→\n   357→    mockQueryResponse([]);\n   358→\n   359→    const result = await validateRuntime('/project');\n   360→    expect(result.success).toBe(true);\n   361→    if (result.success) {\n   362→      expect(result.data.coveragePercent).toBe(0);\n   363→      expect(result.data.modulesWithTelemetry).toBe(0);\n   364→      expect(result.data.totalModules).toBe(3);\n   365→    }\n   366→  });\n   367→\n   368→  it('computes 100% when all modules emit telemetry', async () => {\n   369→    mockHealthy();\n   370→    mockExecSync.mockReturnValue(Buffer.from(''));\n   371→    setupModuleDiscovery(['x', 'y']);\n   372→\n   373→    mockQueryResponse([\n   374→      { source: 'x/file', message: '' },\n   375→      { source: 'y/file', message: '' },\n   376→    ]);\n   377→\n   378→    const result = await validateRuntime('/project');\n   379→    expect(result.success).toBe(true);\n   380→    if (result.success) {\n   381→      expect(result.data.coveragePercent).toBe(100);\n   382→      expect(result.data.modulesWithTelemetry).toBe(2);\n   383→    }\n   384→  });\n   385→\n   386→  it('computes 0% when project has no modules', async () => {\n   387→    mockHealthy();\n   388→    mockExecSync.mockReturnValue(Buffer.from(''));\n   389→    setupModuleDiscovery([]);\n   390→\n   391→    mockQueryResponse([]);\n   392→\n   393→    const result = await validateRuntime('/project');\n   394→    expect(result.success).toBe(true);\n   395→    if (result.success) {\n   396→      expect(result.data.coveragePercent).toBe(0);\n   397→      expect(result.data.totalModules).toBe(0);\n   398→    }\n   399→  });\n   400→});\n   401→\n   402→// ============================================================\n   403→// validateRuntime — custom config\n   404→// ============================================================\n   405→\n   406→describe('validateRuntime — custom config overrides', () => {\n   407→  it('uses custom test command and endpoints', async () => {\n   408→    mockHealthy();\n   409→    mockExecSync.mockReturnValue(Buffer.from(''));\n   410→    setupModuleDiscovery([]);\n   411→    mockQueryResponse([]);\n   412→\n   413→    await validateRuntime('/project', {\n   414→      testCommand: 'pytest',\n   415→      otlpEndpoint: 'http://otel:4317',\n   416→      queryEndpoint: 'http://vlogs:9428',\n   417→    });\n   418→\n   419→    expect(mockExecSync).toHaveBeenCalledWith(\n   420→      'pytest',\n   421→      expect.objectContaining({\n   422→        env: expect.objectContaining({\n   423→          OTEL_EXPORTER_OTLP_ENDPOINT: 'http://otel:4317',\n   424→        }),\n   425→      }),\n   426→    );\n   427→    // Health check should have used the custom query endpoint\n   428→    expect(mockFetch).toHaveBeenCalledWith(\n   429→      'http://vlogs:9428/health',\n   430→      expect.any(Object),\n   431→    );\n   432→  });\n   433→});\n   434→\n   435→// ============================================================\n   436→// validateRuntime — error handling\n   437→// ============================================================\n   438→\n   439→describe('validateRuntime — error handling', () => {\n   440→  it('rejects empty projectDir', async () => {\n   441→    const result = await validateRuntime('');\n   442→    expect(result.success).toBe(false);\n   443→    if (!result.success) {\n   444→      expect(result.error).toContain('projectDir is required');\n   445→    }\n   446→  });\n   447→\n   448→  it('returns fail when test command fails', async () => {\n   449→    mockHealthy();\n   450→    mockExecSync.mockImplementation(() => {\n   451→      throw new Error('Command failed: npm test');\n   452→    });\n   453→    setupModuleDiscovery([]);\n   454→\n   455→    const result = await validateRuntime('/project');\n   456→    expect(result.success).toBe(false);\n   457→    if (!result.success) {\n   458→      expect(result.error).toContain('Test command failed');\n   459→    }\n   460→  });\n   461→\n   462→  it('returns fail when test command throws non-Error', async () => {\n   463→    mockHealthy();\n   464→    mockExecSync.mockImplementation(() => {\n   465→      throw 'exit code 1'; // eslint-disable-line no-throw-literal\n   466→    });\n   467→    setupModuleDiscovery([]);\n   468→\n   469→    const result = await validateRuntime('/project');\n   470→    expect(result.success).toBe(false);\n   471→    if (!result.success) {\n   472→      expect(result.error).toContain('exit code 1');\n   473→    }\n   474→  });\n   475→\n   476→  it('returns fail when telemetry query fails', async () => {\n   477→    mockHealthy();\n   478→    mockExecSync.mockReturnValue(Buffer.from(''));\n   479→    setupModuleDiscovery([]);\n   480→    // Query endpoint fails\n   481→    mockFetch.mockRejectedValueOnce(new Error('network error'));\n   482→\n   483→    const result = await validateRuntime('/project');\n   484→    expect(result.success).toBe(false);\n   485→    if (!result.success) {\n   486→      expect(result.error).toContain('Failed to query telemetry events');\n   487→    }\n   488→  });\n   489→\n   490→  it('handles missing src/ directory for module discovery', async () => {\n   491→    mockUnhealthy();\n   492→    mockReaddirSync.mockImplementation(() => {\n   493→      throw new Error('ENOENT');\n   494→    });\n   495→\n   496→    const result = await validateRuntime('/project');\n   497→    expect(result.success).toBe(true);\n   498→    if (result.success) {\n   499→      expect(result.data.totalModules).toBe(0);\n   500→      expect(result.data.skipped).toBe(true);\n   501→    }\n   502→  });\n   503→\n   504→  it('skips entries where statSync throws', async () => {\n   505→    mockUnhealthy();\n   506→    mockReaddirSync.mockReturnValue(['good', 'bad'] as unknown as ReturnType<typeof readdirSync>);\n   507→    let callCount = 0;\n   508→    mockStatSync.mockImplementation(() => {\n   509→      callCount++;\n   510→      if (callCount === 2) throw new Error('EACCES');\n   511→      return { isDirectory: () => true, isFile: () => false } as ReturnType<typeof statSync>;\n   512→    });\n   513→\n   514→    const result = await validateRuntime('/project');\n   515→    expect(result.success).toBe(true);\n   516→    if (result.success) {\n   517→      // Only 'good' should be discovered, 'bad' filtered out\n   518→      expect(result.data.totalModules).toBe(1);\n   519→      expect(result.data.entries[0].moduleName).toBe('good');\n   520→    }\n   521→  });\n   522→});\n   523→"}]},"parent_tool_use_id":"toolu_01X8HPzdvjqKbRcjmtsWDTRD","session_id":"c5eaf6a6-ac7c-4707-b82c-6220d711aa9c","uuid":"b1f60ce4-3931-415d-acf4-fa02ade8ddfe","timestamp":"2026-03-20T06:44:46.820Z"}
