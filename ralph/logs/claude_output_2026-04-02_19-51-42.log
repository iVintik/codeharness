{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011hxf4pYUQJD4AwvwozrYLj","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { validateAgentSchema, validateWorkflowSchema } from '../schema-validate.js';\n3\t\n4\t// --- Helpers ---\n5\t\n6\tfunction minimalValidAgent() {\n7\t  return {\n8\t    name: 'evaluator',\n9\t    role: {\n10\t      title: 'Adversarial QA Evaluator',\n11\t      purpose: 'Exercise the built artifact and determine if it actually works',\n12\t    },\n13\t    persona: {\n14\t      identity: 'Senior QA who trusts nothing without evidence',\n15\t      communication_style: 'Blunt, evidence-first',\n16\t      principles: [\n17\t        'Never give the benefit of the doubt',\n18\t        'Every PASS requires evidence',\n19\t      ],\n20\t    },\n21\t  };\n22\t}\n23\t\n24\tfunction agentWithPersonality() {\n25\t  return {\n26\t    ...minimalValidAgent(),\n27\t    personality: {\n28\t      traits: {\n29\t        rigor: 0.98,\n30\t        directness: 0.95,\n31\t        warmth: 0.2,\n32\t      },\n33\t    },\n34\t  };\n35\t}\n36\t\n37\tfunction agentWithDisallowedTools() {\n38\t  return {\n39\t    ...minimalValidAgent(),\n40\t    disallowedTools: ['Edit', 'Write'],\n41\t  };\n42\t}\n43\t\n44\t// --- Tests ---\n45\t\n46\tdescribe('validateAgentSchema', () => {\n47\t  describe('valid agents', () => {\n48\t    it('accepts a minimal valid agent with all required fields (AC #1, #2)', () => {\n49\t      const result = validateAgentSchema(minimalValidAgent());\n50\t      expect(result.valid).toBe(true);\n51\t      expect(result.errors).toEqual([]);\n52\t    });\n53\t\n54\t    it('accepts agent with optional personality.traits in 0-1 range (AC #5)', () => {\n55\t      const result = validateAgentSchema(agentWithPersonality());\n56\t      expect(result.valid).toBe(true);\n57\t      expect(result.errors).toEqual([]);\n58\t    });\n59\t\n60\t    it('accepts agent with valid disallowedTools array', () => {\n61\t      const result = validateAgentSchema(agentWithDisallowedTools());\n62\t      expect(result.valid).toBe(true);\n63\t      expect(result.errors).toEqual([]);\n64\t    });\n65\t\n66\t    it('accepts agent with all optional fields present', () => {\n67\t      const agent = {\n68\t        ...minimalValidAgent(),\n69\t        personality: {\n70\t          traits: {\n71\t            rigor: 0.98,\n72\t            warmth: 0.2,\n73\t          },\n74\t        },\n75\t        disallowedTools: ['Edit', 'Write'],\n76\t      };\n77\t      const result = validateAgentSchema(agent);\n78\t      expect(result.valid).toBe(true);\n79\t      expect(result.errors).toEqual([]);\n80\t    });\n81\t\n82\t    it('accepts personality with empty traits object', () => {\n83\t      const agent = {\n84\t        ...minimalValidAgent(),\n85\t        personality: { traits: {} },\n86\t      };\n87\t      const result = validateAgentSchema(agent);\n88\t      expect(result.valid).toBe(true);\n89\t    });\n90\t\n91\t    it('accepts empty disallowedTools array', () => {\n92\t      const agent = {\n93\t        ...minimalValidAgent(),\n94\t        disallowedTools: [],\n95\t      };\n96\t      const result = validateAgentSchema(agent);\n97\t      expect(result.valid).toBe(true);\n98\t    });\n99\t\n100\t    it('accepts trait values at boundaries (0 and 1)', () => {\n101\t      const agent = {\n102\t        ...minimalValidAgent(),\n103\t        personality: {\n104\t          traits: {\n105\t            minimum: 0,\n106\t            maximum: 1,\n107\t          },\n108\t        },\n109\t      };\n110\t      const result = validateAgentSchema(agent);\n111\t      expect(result.valid).toBe(true);\n112\t    });\n113\t  });\n114\t\n115\t  describe('missing required fields', () => {\n116\t    it('rejects missing name field (AC #3)', () => {\n117\t      const { name: _, ...agent } = minimalValidAgent();\n118\t      const result = validateAgentSchema(agent);\n119\t      expect(result.valid).toBe(false);\n120\t      expect(result.errors.some((e) => e.keyword === 'required' && e.message.includes('name'))).toBe(true);\n121\t    });\n122\t\n123\t    it('rejects missing role field (AC #3)', () => {\n124\t      const { role: _, ...agent } = minimalValidAgent();\n125\t      const result = validateAgentSchema(agent);\n126\t      expect(result.valid).toBe(false);\n127\t      expect(result.errors.some((e) => e.keyword === 'required' && e.message.includes('role'))).toBe(true);\n128\t    });\n129\t\n130\t    it('rejects missing persona field (AC #3)', () => {\n131\t      const { persona: _, ...agent } = minimalValidAgent();\n132\t      const result = validateAgentSchema(agent);\n133\t      expect(result.valid).toBe(false);\n134\t      expect(result.errors.some((e) => e.keyword === 'required' && e.message.includes('persona'))).toBe(true);\n135\t    });\n136\t\n137\t    it('rejects missing role.title', () => {\n138\t      const agent = minimalValidAgent();\n139\t      delete (agent.role as Record<string, unknown>).title;\n140\t      const result = validateAgentSchema(agent);\n141\t      expect(result.valid).toBe(false);\n142\t      expect(result.errors.some((e) => e.keyword === 'required' && e.path === '/role')).toBe(true);\n143\t    });\n144\t\n145\t    it('rejects missing role.purpose', () => {\n146\t      const agent = minimalValidAgent();\n147\t      delete (agent.role as Record<string, unknown>).purpose;\n148\t      const result = validateAgentSchema(agent);\n149\t      expect(result.valid).toBe(false);\n150\t      expect(result.errors.some((e) => e.keyword === 'required' && e.path === '/role')).toBe(true);\n151\t    });\n152\t\n153\t    it('rejects missing persona.identity', () => {\n154\t      const agent = minimalValidAgent();\n155\t      delete (agent.persona as Record<string, unknown>).identity;\n156\t      const result = validateAgentSchema(agent);\n157\t      expect(result.valid).toBe(false);\n158\t      expect(result.errors.some((e) => e.keyword === 'required' && e.pat