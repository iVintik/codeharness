{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012zFcmHbSrfB2P2VHPGx8eL","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { parse } from 'yaml';\n3\timport { warn } from './output.js';\n4\timport { dispatchAgent, DispatchError } from './agent-dispatch.js';\n5\timport type { DispatchOptions, DispatchResult } from './agent-dispatch.js';\n6\timport type { SubagentDefinition } from './agent-resolver.js';\n7\timport type { ResolvedWorkflow, ResolvedTask, FlowStep, LoopBlock } from './workflow-parser.js';\n8\timport {\n9\t  readWorkflowState,\n10\t  writeWorkflowState,\n11\t} from './workflow-state.js';\n12\timport type { WorkflowState, TaskCheckpoint } from './workflow-state.js';\n13\timport { createIsolatedWorkspace } from './source-isolation.js';\n14\timport { generateTraceId, formatTracePrompt, recordTraceId } from './trace-id.js';\n15\timport { resolveSessionId, recordSessionId } from './session-manager.js';\n16\timport type { SessionLookupKey } from './session-manager.js';\n17\t\n18\t// --- Interfaces ---\n19\t\n20\t/**\n21\t * Configuration for the workflow engine.\n22\t */\n23\texport interface EngineConfig {\n24\t  /** The resolved workflow with tasks and flow steps. */\n25\t  workflow: ResolvedWorkflow;\n26\t  /** Pre-compiled agent definitions keyed by agent name. */\n27\t  agents: Record<string, SubagentDefinition>;\n28\t  /** Path to sprint-status.yaml for work item discovery. */\n29\t  sprintStatusPath: string;\n30\t  /** Optional path to issues.yaml for additional work items. */\n31\t  issuesPath?: string;\n32\t  /** Unique identifier for this engine run. */\n33\t  runId: string;\n34\t  /** Project root directory. Defaults to process.cwd(). */\n35\t  projectDir?: string;\n36\t  /** Maximum loop iterations before termination. Defaults to 5. */\n37\t  maxIterations?: number;\n38\t}\n39\t\n40\t/**\n41\t * Evaluator verdict returned by a verify task (AD5).\n42\t */\n43\texport interface EvaluatorVerdict {\n44\t  verdict: 'pass' | 'fail';\n45\t  score: {\n46\t    passed: number;\n47\t    failed: number;\n48\t    unknown: number;\n49\t    total: number;\n50\t  };\n51\t  findings: Array<{\n52\t    ac: number;\n53\t    description: string;\n54\t    status: 'pass' | 'fail' | 'unknown';\n55\t    evidence: {\n56\t      commands_run: string[];\n57\t      output_observed: string;\n58\t      reasoning: string;\n59\t    };\n60\t  }>;\n61\t  evaluator_trace_id?: string;\n62\t  duration_seconds?: number;\n63\t}\n64\t\n65\t/**\n66\t * Result returned by executeWorkflow().\n67\t */\n68\texport interface EngineResult {\n69\t  /** Whether the workflow completed without errors. */\n70\t  success: boolean;\n71\t  /** Number of task dispatches completed. */\n72\t  tasksCompleted: number;\n73\t  /** Number of work items (stories/issues) processed. */\n74\t  storiesProcessed: number;\n75\t  /** Errors encountered during execution. */\n76\t  errors: EngineError[];\n77\t  /** Wall-clock duration of the entire workflow in milliseconds. */\n78\t  durationMs: number;\n79\t}\n80\t\n81\t/**\n82\t * Structured error recorded during workflow execution.\n83\t */\n84\texport interface EngineError {\n85\t  taskName: string;\n86\t  storyKey: string;\n87\t  code: string;\n88\t  message: string;\n89\t}\n90\t\n91\t/**\n92\t * A work item (story or issue) ready for execution.\n93\t */\n94\texport interface WorkItem {\n95\t  key: string;\n96\t  title?: string;\n97\t  source: 'sprint' | 'issues';\n98\t}\n99\t\n100\t// --- Constants ---\n101\t\n102\t/** Sentinel story key for per-run tasks. */\n103\tconst PER_RUN_SENTINEL = '__run__';\n104\t\n105\t/** DispatchError codes that should halt execution immediately. */\n106\tconst HALT_ERROR_CODES = new Set(['RATE_LIMIT', 'NETWORK', 'SDK_INIT']);\n107\t\n108\t/** Default maximum loop iterations before termination. */\n109\tconst DEFAULT_MAX_ITERATIONS = 5;\n110\t\n111\t// --- Work Item Loading ---\n112\t\n113\t/**\n114\t * Load work items from sprint-status.yaml and optionally issues.yaml.\n115\t *\n116\t * Stories are extracted from the `development_status` section of sprint-status.yaml.\n117\t * Issues are extracted from the `issues` array of issues.yaml.\n118\t *\n119\t * Only items with status `backlog` or `ready-for-dev` are included.\n120\t * Epic keys (`epic-*`) and retrospective keys (`*-retrospective`) are excluded.\n121\t *\n122\t * If issues.yaml does not exist, returns only stories (no error).\n123\t */\n124\texport function loadWorkItems(sprintStatusPath: string, issuesPath?: string): WorkItem[] {\n125\t  const items: WorkItem[] = [];\n126\t\n127\t  // --- Load stories from sprint-status.yaml ---\n128\t  if (existsSync(sprintStatusPath)) {\n129\t    let raw: string;\n130\t    try {\n131\t      raw = readFileSync(sprintStatusPath, 'utf-8');\n132\t    } catch { // IGNORE: unreadable file — warn and return empty\n133\t      warn(`workflow-engine: could not read sprint-status.yaml at ${sprintStatusPath}`);\n134\t      return items;\n135\t    }\n136\t\n137\t    let parsed: unknown;\n138\t    try {\n139\t      parsed = parse(raw);\n140\t    } catch { // IGNORE: malformed YAML — warn and return empty\n141\t      warn(`workflow-engine: invalid YAML in sprint-status.yaml at ${sprintStatusPath}`);\n142\t      return items;\n143\t    }\n144\t\n145\t    if (parsed && typeof parsed === 'object') {\n146\t      const data = parsed as Record<string, unknown>;\n147\t      const devStatus = data.development_status as Record<string, unknown> | undefined;\n148\t\n149\t      if (devStatus && typeof devStatus === 'object') {\n150\t        for (const [key, status] of Object.entries(devStatus)) {\n151\t          // Skip epic keys and retrospective keys\n152\t          if (key.startsWith('epic-')) continue;\n153\t          if (key.endsWith('-retrospective')) continue;\n154\t\n155\t          // Only include backlog or ready-for-dev\n156\t          if (status === 'backlog' || status === 'ready-for-dev') {\n157\t            items.push({ key, source: 'sprint' });\n158\t          }\n159\t        }\n160\t      }\n161\t    }\n162\t  }\n163\t\n164\t  // --- Load issues from issues.yaml ---\n165\t  if (issuesPath && existsSync(issuesPath)) {\n166\t    let raw: string;\n167\t    try {\n168\t      raw = readFileSync(issuesPath, 'utf-8');\n169\t    } catch { // IGNORE: unreadable issues file — warn and return what we have\n170\t      warn(`workflow-engine: could not read issues.yaml at ${issuesPath}`);\n171\t      return items;\n172\t    }\n173\t\n174\t    let parsed: unknown;\n175\t    try {\n176\t      parsed = parse(raw);\n177\t    } catch { // IGNORE: malformed issues YAML — warn and return what we have\n178\t      warn(`workflow-engine: invalid YAML in issues.yaml at ${issuesPath}`);\n179\t      return items;\n180\t    }\n181\t\n182\t    if (parsed && typeof parsed === 'object') {\n183\t      const data = parsed as Record<string, unknown>;\n184\t      const issuesList = data.issues as Array<Record<string, unknown>> | undefined;\n185\t\n186\t      if (Array.isArray(issuesList)) {\n187\t        for (const issue of issuesList) {\n188\t          if (issue && typeof issue === 'object') {\n189\t            const status = issue.status as string | undefined;\n190\t            if (status === 'backlog' || status === 'ready-for-dev') {\n191\t              items.push({\n192\t                key: issue.id as string,\n193\t                title: issue.title as string | undefined,\n194\t                source: 'issues',\n195\t              });\n196\t            }\n197\t          }\n198\t        }\n199\t      }\n200\t    }\n201\t  }\n202\t\n203\t  return items;\n204\t}\n205\t\n206\t// --- Single Task Dispatch ---\n207\t\n208\t/**\n209\t * Dispatch a single task for a specific work item (or per-run sentinel).\n210\t *\n211\t * Handles: trace ID generation, session resolution, source isolation,\n212\t * agent dispatch, state checkpointing, and cleanup.\n213\t *\n214\t * Returns the updated workflow state after recording the dispatch.\n215\t */\n216\texport async function dispatchTask(\n217\t  task: ResolvedTask,\n218\t  taskName: string,\n219\t  storyKey: string,\n220\t  definition: SubagentDefinition,\n221\t  state: WorkflowState,\n222\t  config: EngineConfig,\n223\t  customPrompt?: string,\n224\t): Promise<WorkflowState> {\n225\t  const { updatedState } = await dispatchTaskWithResult(\n226\t    task, taskName, storyKey, definition, state, config, customPrompt,\n227\t  );\n228\t  return updatedState;\n229\t}\n230\t\n231\t// --- Flow Step Type Guard ---\n232\t\n233\tfunction isLoopBlock(step: FlowStep): step is LoopBlock {\n234\t  return typeof step === 'object' && step !== null && 'loop' in step;\n235\t}\n236\t\n237\t// --- Core Dispatch (shared by dispatchTask and loop block execution) ---\n238\t\n239\t/**\n240\t * Dispatch a task and return both the updated state and the raw dispatch output.\n241\t * This is the single implementation of task dispatch logic. Both `dispatchTask()`\n242\t * and loop block execution delegate here.\n243\t */\n244\tasync function dispatchTaskWithResult(\n245\t  task: ResolvedTask,\n246\t  taskName: string,\n247\t  storyKey: string,\n248\t  definition: SubagentDefinition,\n249\t  state: WorkflowState,\n250\t  config: EngineConfig,\n251\t  customPrompt?: string,\n252\t): Promise<{ updatedState: WorkflowState; output: string }> {\n253\t  const projectDir = config.projectDir ?? process.cwd();\n254\t\n255\t  // 1. Generate trace ID\n256\t  const traceId = generateTraceId(config.runId, state.iteration, taskName);\n257\t\n258\t  // 2. Format trace prompt\n259\t  const tracePrompt = formatTracePrompt(traceId);\n260\t\n261\t  // 3. Resolve session ID\n262\t  const sessionKey: SessionLookupKey = { taskName, storyKey };\n263\t  const sessionId = resolveSessionId(task.session, sessionKey, state);\n264\t\n265\t  // 4. Build dispatch options based on source_access\n266\t  let dispatchOptions: DispatchOptions;\n267\t  let workspace: Awaited<ReturnType<typeof createIsolatedWorkspace>> | null = null;\n268\t\n269\t  if (task.source_access === false) {\n270\t    workspace = await createIsolatedWorkspace({ runId: config.runId, storyFiles: [] });\n271\t    dispatchOptions = {\n272\t      ...workspace.toDispatchOptions(),\n273\t      sessionId,\n274\t      appendSystemPrompt: tracePrompt,\n275\t    };\n276\t  } else {\n277\t    dispatchOptions = {\n278\t      cwd: projectDir,\n279\t      sessionId,\n280\t      appendSystemPrompt: tracePrompt,\n281\t    };\n282\t  }\n283\t\n284\t  // 5. Construct prompt\n285\t  const prompt = customPrompt\n286\t    ?? (storyKey === PER_RUN_SENTINEL\n287\t      ? `Execute task \"${taskName}\" for the current run.`\n288\t      : `Implement story ${storyKey}`);\n289\t\n290\t  // 6. Dispatch agent\n291\t  let result: DispatchResult;\n292\t  try {\n293\t    result = await dispatchAgent(definition, prompt, dispatchOptions);\n294\t  } finally {\n295\t    // Cleanup workspace regardless of dispatch success/failure\n296\t    if (workspace) {\n297\t      await workspace.cleanup();\n298\t    }\n299\t  }\n300\t\n301\t  // 7. Record session ID (if dispatch returned one)\n302\t  let updatedState = state;\n303\t  if (result.sessionId) {\n304\t    updatedState = recordSessionId(sessionKey, result.sessionId, updatedState);\n305\t  } else {\n306\t    // Append checkpoint manually when no session ID is returned\n307\t    const checkpoint: TaskCheckpoint = {\n308\t      task_name: taskName,\n309\t      story_key: storyKey,\n310\t      completed_at: new Date().toISOString(),\n311\t    };\n312\t    updatedState = {\n313\t      ...updatedState,\n314\t      tasks_completed: [...updatedState.tasks_completed, checkpoint],\n315\t    };\n316\t  }\n317\t\n318\t  // 8. Record trace ID\n319\t  updatedState = recordTraceId(traceId, updatedState);\n320\t\n321\t  // 9. Write state to disk\n322\t  writeWorkflowState(updatedState, projectDir);\n323\t\n324\t  return { updatedState, output: result.output };\n325\t}\n326\t\n327\t// --- Verdict Parsing (Task 2) ---\n328\t\n329\t/**\n330\t * Attempt to parse a DispatchResult.output string as an EvaluatorVerdict.\n331\t * Returns null if parsing fails or required fields are missing.\n332\t */\n333\texport function parseVerdict(output: string): EvaluatorVerdict | null {\n334\t  let parsed: unknown;\n335\t  try {\n336\t    parsed = JSON.parse(output);\n337\t  } catch { // IGNORE: invalid JSON means no verdict — return null\n338\t    return null;\n339\t  }\n340\t\n341\t  if (!parsed || typeof parsed !== 'object') return null;\n342\t\n343\t  const obj = parsed as Record<string, unknown>;\n344\t\n345\t  // Validate required top-level fields\n346\t  if (obj.verdict !== 'pass' && obj.verdict !== 'fail') return null;\n347\t  if (!obj.score || typeof obj.score !== 'object') return null;\n348\t  if (!Array.isArray(obj.findings)) return null;\n349\t\n350\t  const score = obj.score as Record<string, unknown>;\n351\t  if (typeof score.passed !== 'number') return null;\n352\t  if (typeof score.failed !== 'number') return null;\n353\t  if (typeof score.unknown !== 'number') return null;\n354\t  if (typeof score.total !== 'number') return null;\n355\t\n356\t  return parsed as EvaluatorVerdict;\n357\t}\n358\t\n359\t// --- Retry Prompt Construction (Task 3) ---\n360\t\n361\t/**\n362\t * Build a retry prompt with evaluator findings injected.\n363\t * Includes only failed/unknown findings.\n364\t */\n365\texport function buildRetryPrompt(storyKey: string, findings: EvaluatorVerdict['findings']): string {\n366\t  const failedFindings = findings.filter(\n367\t    (f) => f.status === 'fail' || f.status === 'unknown',\n368\t  );\n369\t\n370\t  if (failedFindings.length === 0) {\n371\t    return `Implement story ${storyKey}`;\n372\t  }\n373\t\n374\t  const formattedFindings = failedFindings\n375\t    .map((f) => {\n376\t      const status = f.status.toUpperCase();\n377\t      let entry = `AC #${f.ac} (${status}): ${f.description}`;\n378\t      if (f.evidence?.reasoning) {\n379\t        entry += `\\n  Evidence: ${f.evidence.reasoning}`;\n380\t      }\n381\t      return entry;\n382\t    })\n383\t    .join('\\n\\n');\n384\t\n385\t  return `Retry story ${storyKey}. Previous evaluator findings:\\n\\n${formattedFindings}\\n\\nFocus on fixing the failed criteria above.`;\n386\t}\n387\t\n388\t// --- Failed Story Filtering (Task 4) ---\n389\t\n390\t/**\n391\t * Determine which work items failed based on evaluator findings.\n392\t * If verdict is null (parse failure), returns all items (conservative fallback).\n393\t */\n394\texport function getFailedItems(\n395\t  verdict: EvaluatorVerdict | null,\n396\t  allItems: WorkItem[],\n397\t): WorkItem[] {\n398\t  if (!verdict) return allItems;\n399\t\n400\t  // If verdict passed, no items need retry\n401\t  if (verdict.verdict === 'pass') return [];\n402\t\n403\t  // All items are retried on failure — per-story filtering based on individual\n404\t  // story results is not possible with the current verdict shape (verdict is per-run).\n405\t  // The findings track ACs, not stories. Conservative: retry all on failure.\n406\t  return allItems;\n407\t}\n408\t\n409\t// --- Loop Block Execution (Task 5) ---\n410\t\n411\t/**\n412\t * Result of loop block execution.\n413\t */\n414\tinterface LoopBlockResult {\n415\t  state: WorkflowState;\n416\t  errors: EngineError[];\n417\t  tasksCompleted: number;\n418\t  halted: boolean;\n419\t}\n420\t\n421\t/**\n422\t * Execute a loop block: iterate tasks until pass, max iterations, or circuit breaker.\n423\t */\n424\texport async function executeLoopBlock(\n425\t  loopBlock: LoopBlock,\n426\t  state: WorkflowState,\n427\t  config: EngineConfig,\n428\t  workItems: WorkItem[],\n429\t): Promise<LoopBlockResult> {\n430\t  const projectDir = config.projectDir ?? process.cwd();\n431\t  const maxIterations = config.maxIterations ?? DEFAULT_MAX_ITERATIONS;\n432\t  const errors: EngineError[] = [];\n433\t  let tasksCompleted = 0;\n434\t  let currentState = state;\n435\t  let lastVerdict: EvaluatorVerdict | null = null;\n436\t\n437\t  // Handle empty loop block\n438\t  if (loopBlock.loop.length === 0) {\n439\t    return { state: currentState, errors, tasksCompleted, halted: false };\n440\t  }\n441\t\n442\t  while (true) {\n443\t    // 1. Increment iteration\n444\t    currentState = {\n445\t      ...currentState,\n446\t      iteration: currentState.iteration + 1,\n447\t    };\n448\t    writeWorkflowState(currentState, projectDir);\n449\t\n450\t    let haltedInLoop = false;\n451\t\n452\t    // 2. Execute each task in the loop\n453\t    for (const taskName of loopBlock.loop) {\n454\t      const task = config.workflow.tasks[taskName];\n455\t      if (!task) {\n456\t        warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n457\t        continue;\n458\t      }\n459\t\n460\t      const definition = config.agents[task.agent];\n461\t      if (!definition) {\n462\t        warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n463\t        continue;\n464\t      }\n465\t\n466\t      if (task.scope === 'per-story') {\n467\t        // Determine which items to dispatch for\n468\t        const itemsToRetry = lastVerdict ? getFailedItems(lastVerdict, workItems) : workItems;\n469\t\n470\t        for (const item of itemsToRetry) {\n471\t          // Build prompt: inject findings if we have a previous verdict\n472\t          const prompt = lastVerdict\n473\t            ? buildRetryPrompt(item.key, lastVerdict.findings)\n474\t            : undefined;\n475\t\n476\t          try {\n477\t            currentState = await dispatchTask(\n478\t              task, taskName, item.key, definition, currentState, config, prompt,\n479\t            );\n480\t            tasksCompleted++;\n481\t          } catch (err: unknown) {\n482\t            const engineError = handleDispatchError(err, taskName, item.key);\n483\t            errors.push(engineError);\n484\t            currentState = recordErrorInState(currentState, taskName, item.key, engineError);\n485\t            writeWorkflowState(currentState, projectDir);\n486\t\n487\t            if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n488\t              haltedInLoop = true;\n489\t              break;\n490\t            }\n491\t            continue;\n492\t          }\n493\t        }\n494\t\n495\t        if (haltedInLoop) break;\n496\t      } else {\n497\t        // per-run task (e.g., verify)\n498\t        try {\n499\t          // We need the dispatch result output to parse verdict\n500\t          // dispatchTask doesn't return the DispatchResult directly, so we\n501\t          // intercept via a wrapper that captures the output\n502\t          const dispatchResult = await dispatchTaskWithResult(\n503\t            task, taskName, PER_RUN_SENTINEL, definition, currentState, config,\n504\t          );\n505\t          currentState = dispatchResult.updatedState;\n506\t          tasksCompleted++;\n507\t\n508\t          // Attempt to parse verdict from output\n509\t          const verdict = parseVerdict(dispatchResult.output);\n510\t          lastVerdict = verdict;\n511\t\n512\t          // Record score in state\n513\t          if (verdict) {\n514\t            const score = {\n515\t              iteration: currentState.iteration,\n516\t              passed: verdict.score.passed,\n517\t              failed: verdict.score.failed,\n518\t              unknown: verdict.score.unknown,\n519\t              total: verdict.score.total,\n520\t              timestamp: new Date().toISOString(),\n521\t            };\n522\t            currentState = {\n523\t              ...currentState,\n524\t              evaluator_scores: [...currentState.evaluator_scores, score],\n525\t            };\n526\t          } else {\n527\t            // Parse failure: record all-UNKNOWN score\n528\t            const totalItems = workItems.length;\n529\t            const score = {\n530\t              iteration: currentState.iteration,\n531\t              passed: 0,\n532\t              failed: 0,\n533\t              unknown: totalItems,\n534\t              total: totalItems,\n535\t              timestamp: new Date().toISOString(),\n536\t            };\n537\t            currentState = {\n538\t              ...currentState,\n539\t              evaluator_scores: [...currentState.evaluator_scores, score],\n540\t            };\n541\t          }\n542\t          writeWorkflowState(currentState, projectDir);\n543\t        } catch (err: unknown) {\n544\t          const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n545\t          errors.push(engineError);\n546\t          currentState = recordErrorInState(currentState, taskName, PER_RUN_SENTINEL, engineError);\n547\t          writeWorkflowState(currentState, projectDir);\n548\t\n549\t          // Clear stale verdict so next iteration retries all items\n550\t          lastVerdict = null;\n551\t\n552\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n553\t            haltedInLoop = true;\n554\t            break;\n555\t          }\n556\t          continue;\n557\t        }\n558\t      }\n559\t    }\n560\t\n561\t    if (haltedInLoop) {\n562\t      return { state: currentState, errors, tasksCompleted, halted: true };\n563\t    }\n564\t\n565\t    // 3. Check termination conditions\n566\t    if (lastVerdict?.verdict === 'pass') {\n567\t      // Success: loop passes\n568\t      return { state: currentState, errors, tasksCompleted, halted: false };\n569\t    }\n570\t\n571\t    if (currentState.iteration >= maxIterations) {\n572\t      currentState = { ...currentState, phase: 'max-iterations' };\n573\t      writeWorkflowState(currentState, projectDir);\n574\t      return { state: currentState, errors, tasksCompleted, halted: false };\n575\t    }\n576\t\n577\t    if (currentState.circuit_breaker.triggered) {\n578\t      currentState = { ...currentState, phase: 'circuit-breaker' };\n579\t      writeWorkflowState(currentState, projectDir);\n580\t      return { state: currentState, errors, tasksCompleted, halted: false };\n581\t    }\n582\t  }\n583\t}\n584\t\n585\t\n586\t// --- Main Execution ---\n587\t\n588\t/**\n589\t * Execute a workflow sequentially: iterate through flow steps, dispatch tasks\n590\t * per-story or per-run, checkpoint state after each dispatch.\n591\t *\n592\t * Loop blocks execute iteratively until pass, max-iterations, or circuit-breaker.\n593\t *\n594\t * Returns an EngineResult summarizing the execution.\n595\t */\n596\texport async function executeWorkflow(config: EngineConfig): Promise<EngineResult> {\n597\t  const startMs = Date.now();\n598\t  const projectDir = config.projectDir ?? process.cwd();\n599\t  const errors: EngineError[] = [];\n600\t  let tasksCompleted = 0;\n601\t  const processedStories = new Set<string>();\n602\t\n603\t  // 1. Read or initialize workflow state\n604\t  let state = readWorkflowState(projectDir);\n605\t  state = {\n606\t    ...state,\n607\t    phase: 'executing',\n608\t    started: state.started || new Date().toISOString(),\n609\t    workflow_name: config.workflow.flow.filter((s) => typeof s === 'string').join(' -> '),\n610\t  };\n611\t  writeWorkflowState(state, projectDir);\n612\t\n613\t  // 2. Load work items\n614\t  const workItems = loadWorkItems(config.sprintStatusPath, config.issuesPath);\n615\t\n616\t  // 3. Iterate through flow steps\n617\t  let halted = false;\n618\t  for (const step of config.workflow.flow) {\n619\t    if (halted) break;\n620\t\n621\t    // Execute loop blocks\n622\t    if (isLoopBlock(step)) {\n623\t      const loopResult = await executeLoopBlock(step, state, config, workItems);\n624\t      state = loopResult.state;\n625\t      errors.push(...loopResult.errors);\n626\t      tasksCompleted += loopResult.tasksCompleted;\n627\t\n628\t      // Track processed stories from loop\n629\t      for (const item of workItems) {\n630\t        processedStories.add(item.key);\n631\t      }\n632\t\n633\t      if (loopResult.halted) {\n634\t        halted = true;\n635\t      }\n636\t\n637\t      // If loop ended with max-iterations or circuit-breaker, treat as failure\n638\t      if (state.phase === 'max-iterations' || state.phase === 'circuit-breaker') {\n639\t        halted = true;\n640\t      }\n641\t      continue;\n642\t    }\n643\t\n644\t    // step is a string task name\n645\t    const taskName = step;\n646\t    const task = config.workflow.tasks[taskName];\n647\t\n648\t    if (!task) {\n649\t      warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n650\t      continue;\n651\t    }\n652\t\n653\t    // Look up the agent definition\n654\t    const definition = config.agents[task.agent];\n655\t    if (!definition) {\n656\t      warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n657\t      continue;\n658\t    }\n659\t\n660\t    if (task.scope === 'per-run') {\n661\t      // Per-run: dispatch once with sentinel key\n662\t      try {\n663\t        state = await dispatchTask(task, taskName, PER_RUN_SENTINEL, definition, state, config);\n664\t        tasksCompleted++;\n665\t      } catch (err: unknown) {\n666\t        const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n667\t        errors.push(engineError);\n668\t\n669\t        // Record error checkpoint in state (AC #13)\n670\t        state = recordErrorInState(state, taskName, PER_RUN_SENTINEL, engineError);\n671\t        writeWorkflowState(state, projectDir);\n672\t\n673\t        // Halt on critical errors\n674\t        if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n675\t          halted = true;\n676\t        }\n677\t      }\n678\t    } else {\n679\t      // Per-story: dispatch once per work item\n680\t      for (const item of workItems) {\n681\t        processedStories.add(item.key);\n682\t        try {\n683\t          state = await dispatchTask(task, taskName, item.key, definition, state, config);\n684\t          tasksCompleted++;\n685\t        } catch (err: unknown) {\n686\t          const engineError = handleDispatchError(err, taskName, item.key);\n687\t          errors.push(engineError);\n688\t\n689\t          // Record error checkpoint in state (AC #13)\n690\t          state = recordErrorInState(state, taskName, item.key, engineError);\n691\t          writeWorkflowState(state, projectDir);\n692\t\n693\t          // Halt on critical errors, continue on UNKNOWN\n694\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n695\t            halted = true;\n696\t            break;\n697\t          }\n698\t          // UNKNOWN errors: record and continue to next story\n699\t          continue;\n700\t        }\n701\t      }\n702\t    }\n703\t  }\n704\t\n705\t  // 4. Set final phase if no errors and phase not already set by loop termination\n706\t  if (errors.length === 0 && state.phase !== 'max-iterations' && state.phase !== 'circuit-breaker') {\n707\t    state = { ...state, phase: 'completed' };\n708\t    writeWorkflowState(state, projectDir);\n709\t  }\n710\t\n711\t  // 5. Return result\n712\t  const loopTerminated = state.phase === 'max-iterations' || state.phase === 'circuit-breaker';\n713\t  return {\n714\t    success: errors.length === 0 && !loopTerminated,\n715\t    tasksCompleted,\n716\t    storiesProcessed: processedStories.size,\n717\t    errors,\n718\t    durationMs: Date.now() - startMs,\n719\t  };\n720\t}\n721\t\n722\t// --- Error Handling ---\n723\t\n724\t/**\n725\t * Record a dispatch error in workflow state: set phase to \"error\" and append\n726\t * a TaskCheckpoint with the error details (AC #13).\n727\t */\n728\tfunction recordErrorInState(\n729\t  state: WorkflowState,\n730\t  taskName: string,\n731\t  storyKey: string,\n732\t  error: EngineError,\n733\t): WorkflowState {\n734\t  const errorCheckpoint: TaskCheckpoint = {\n735\t    task_name: taskName,\n736\t    story_key: storyKey,\n737\t    completed_at: new Date().toISOString(),\n738\t  };\n739\t  return {\n740\t    ...state,\n741\t    phase: 'error',\n742\t    tasks_completed: [...state.tasks_completed, errorCheckpoint],\n743\t  };\n744\t}\n745\t\n746\tfunction handleDispatchError(err: unknown, taskName: string, storyKey: string): EngineError {\n747\t  if (err instanceof DispatchError) {\n748\t    return {\n749\t      taskName,\n750\t      storyKey,\n751\t      code: err.code,\n752\t      message: err.message,\n753\t    };\n754\t  }\n755\t\n756\t  const message = err instanceof Error ? err.message : String(err);\n757\t  return {\n758\t    taskName,\n759\t    storyKey,\n760\t    code: 'UNKNOWN',\n761\t    message,\n762\t  };\n763\t}\n764\t"}]},"parent_tool_use_id":"toolu_01RL1K8ArV7Pe3b3p8vDkEdF","session_id":"8b4a1da7-9e18-4302-ad13-ce7f0aff0314","uuid":"c66e67c1-2015-4dc6-b176-ffae80b455f7","timestamp":"2026-04-02T22:46:54.933Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016ajD9gvmAZcysH9Mut29HR","type":"tool_result","content":"1\timport { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n2\timport { join } from 'node:path';\n3\timport { parse, stringify } from 'yaml';\n4\timport { warn } from './output.js';\n5\t\n6\t// --- Interfaces ---\n7\t\n8\texport interface TaskCheckpoint {\n9\t  task_name: string;\n10\t  story_key: string;\n11\t  completed_at: string;\n12\t  session_id?: string;\n13\t}\n14\t\n15\texport interface EvaluatorScore {\n16\t  iteration: number;\n17\t  passed: number;\n18\t  failed: number;\n19\t  unknown: number;\n20\t  total: number;\n21\t  timestamp: string;\n22\t}\n23\t\n24\texport interface CircuitBreakerState {\n25\t  triggered: boolean;\n26\t  reason: string | null;\n27\t  score_history: number[];\n28\t}\n29\t\n30\texport interface WorkflowState {\n31\t  workflow_name: string;\n32\t  started: string;\n33\t  iteration: number;\n34\t  phase: string;\n35\t  tasks_completed: TaskCheckpoint[];\n36\t  evaluator_scores: EvaluatorScore[];\n37\t  circuit_breaker: CircuitBreakerState;\n38\t  trace_ids?: string[];\n39\t}\n40\t\n41\t// --- Constants ---\n42\t\n43\tconst STATE_DIR = '.codeharness';\n44\tconst STATE_FILE = 'workflow-state.yaml';\n45\t\n46\t// --- Functions ---\n47\t\n48\texport function getDefaultWorkflowState(): WorkflowState {\n49\t  return {\n50\t    workflow_name: '',\n51\t    started: '',\n52\t    iteration: 0,\n53\t    phase: 'idle',\n54\t    tasks_completed: [],\n55\t    evaluator_scores: [],\n56\t    circuit_breaker: {\n57\t      triggered: false,\n58\t      reason: null,\n59\t      score_history: [],\n60\t    },\n61\t    trace_ids: [],\n62\t  };\n63\t}\n64\t\n65\texport function writeWorkflowState(state: WorkflowState, dir?: string): void {\n66\t  const baseDir = dir ?? process.cwd();\n67\t  const stateDir = join(baseDir, STATE_DIR);\n68\t  mkdirSync(stateDir, { recursive: true });\n69\t  const yamlContent = stringify(state, { nullStr: 'null' });\n70\t  writeFileSync(join(stateDir, STATE_FILE), yamlContent, 'utf-8');\n71\t}\n72\t\n73\texport function readWorkflowState(dir?: string): WorkflowState {\n74\t  const baseDir = dir ?? process.cwd();\n75\t  const filePath = join(baseDir, STATE_DIR, STATE_FILE);\n76\t\n77\t  if (!existsSync(filePath)) {\n78\t    return getDefaultWorkflowState();\n79\t  }\n80\t\n81\t  let raw: string;\n82\t  try {\n83\t    raw = readFileSync(filePath, 'utf-8');\n84\t  } catch { // IGNORE: unreadable file (permissions, EISDIR, etc.) — recover with defaults\n85\t    warn('workflow-state.yaml could not be read — returning default state');\n86\t    return getDefaultWorkflowState();\n87\t  }\n88\t\n89\t  let parsed: unknown;\n90\t  try {\n91\t    parsed = parse(raw);\n92\t  } catch { // IGNORE: corrupted YAML — recover with defaults\n93\t    warn('workflow-state.yaml contains invalid YAML — returning default state');\n94\t    return getDefaultWorkflowState();\n95\t  }\n96\t\n97\t  if (!isValidWorkflowState(parsed)) {\n98\t    warn('workflow-state.yaml has invalid shape — returning default state');\n99\t    return getDefaultWorkflowState();\n100\t  }\n101\t\n102\t  return parsed;\n103\t}\n104\t\n105\t// --- Validation ---\n106\t\n107\tfunction isValidWorkflowState(value: unknown): value is WorkflowState {\n108\t  if (!value || typeof value !== 'object') return false;\n109\t  const s = value as Record<string, unknown>;\n110\t\n111\t  if (typeof s.workflow_name !== 'string') return false;\n112\t  if (typeof s.started !== 'string') return false;\n113\t  if (typeof s.iteration !== 'number') return false;\n114\t  if (typeof s.phase !== 'string') return false;\n115\t  if (!Array.isArray(s.tasks_completed)) return false;\n116\t  if (!Array.isArray(s.evaluator_scores)) return false;\n117\t  if (!s.circuit_breaker || typeof s.circuit_breaker !== 'object') return false;\n118\t\n119\t  // Validate trace_ids (optional array of strings)\n120\t  if (s.trace_ids !== undefined) {\n121\t    if (!Array.isArray(s.trace_ids)) return false;\n122\t    for (const id of s.trace_ids) {\n123\t      if (typeof id !== 'string') return false;\n124\t    }\n125\t  }\n126\t\n127\t  // Validate tasks_completed element shapes\n128\t  for (const t of s.tasks_completed) {\n129\t    if (!t || typeof t !== 'object') return false;\n130\t    const tc = t as Record<string, unknown>;\n131\t    if (typeof tc.task_name !== 'string') return false;\n132\t    if (typeof tc.story_key !== 'string') return false;\n133\t    if (typeof tc.completed_at !== 'string') return false;\n134\t    if (tc.session_id !== undefined && typeof tc.session_id !== 'string') return false;\n135\t  }\n136\t\n137\t  // Validate evaluator_scores element shapes\n138\t  for (const e of s.evaluator_scores) {\n139\t    if (!e || typeof e !== 'object') return false;\n140\t    const es = e as Record<string, unknown>;\n141\t    if (typeof es.iteration !== 'number') return false;\n142\t    if (typeof es.passed !== 'number') return false;\n143\t    if (typeof es.failed !== 'number') return false;\n144\t    if (typeof es.unknown !== 'number') return false;\n145\t    if (typeof es.total !== 'number') return false;\n146\t    if (typeof es.timestamp !== 'string') return false;\n147\t  }\n148\t\n149\t  const cb = s.circuit_breaker as Record<string, unknown>;\n150\t  if (typeof cb.triggered !== 'boolean') return false;\n151\t  if (cb.reason !== null && typeof cb.reason !== 'string') return false;\n152\t  if (!Array.isArray(cb.score_history)) return false;\n153\t\n154\t  // Validate score_history elements are numbers\n155\t  for (const score of cb.score_history) {\n156\t    if (typeof score !== 'number') return false;\n157\t  }\n158\t\n159\t  return true;\n160\t}\n161\t"}]},"parent_tool_use_id":"toolu_01RL1K8ArV7Pe3b3p8vDkEdF","session_id":"8b4a1da7-9e18-4302-ad13-ce7f0aff0314","uuid":"68782c5f-7c82-476e-82e0-1c36cb227d68","timestamp":"2026-04-02T22:46:54.706Z"}
