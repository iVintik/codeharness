{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012mmsih3K4ypWaMUSwUChoG","type":"tool_result","content":"     1→/**\n     2→ * Documentation scaffolding for project initialization.\n     3→ * Generates AGENTS.md, docs/ directory structure, and README.md.\n     4→ */\n     5→\n     6→import { existsSync, readFileSync } from 'node:fs';\n     7→import { join, basename } from 'node:path';\n     8→import { ok as okOutput } from '../../lib/output.js';\n     9→import { generateFile } from '../../lib/templates.js';\n    10→import { readmeTemplate } from '../../templates/readme.js';\n    11→import type { Result } from '../../types/result.js';\n    12→import { ok, fail } from '../../types/result.js';\n    13→import type { InitDocumentationResult } from './types.js';\n    14→import type { StackDetection } from '../../lib/stacks/index.js';\n    15→import { getStackProvider } from '../../lib/stacks/index.js';\n    16→import type { StackName } from '../../lib/stacks/index.js';\n    17→\n    18→const DO_NOT_EDIT_HEADER = '<!-- DO NOT EDIT MANUALLY -->\\n';\n    19→\n    20→export function getProjectName(projectDir: string): string {\n    21→  try {\n    22→    const pkgPath = join(projectDir, 'package.json');\n    23→    if (existsSync(pkgPath)) {\n    24→      const pkg = JSON.parse(readFileSync(pkgPath, 'utf-8')) as Record<string, unknown>;\n    25→      if (pkg.name && typeof pkg.name === 'string') {\n    26→        return pkg.name;\n    27→      }\n    28→    }\n    29→  } catch {\n    30→    // Fall through to Cargo.toml check\n    31→  }\n    32→\n    33→  // Cargo.toml fallback for Rust projects\n    34→  try {\n    35→    const cargoPath = join(projectDir, 'Cargo.toml');\n    36→    if (existsSync(cargoPath)) {\n    37→      const content = readFileSync(cargoPath, 'utf-8');\n    38→      const packageMatch = content.match(/\\[package\\]([\\s\\S]*?)(?=\\n\\[|$)/s);\n    39→      if (packageMatch) {\n    40→        const nameMatch = packageMatch[1].match(/^\\s*name\\s*=\\s*[\"']([^\"']+)[\"']/m);\n    41→        if (nameMatch) {\n    42→          return nameMatch[1];\n    43→        }\n    44→      }\n    45→    }\n    46→  } catch {\n    47→    // Fall through to basename\n    48→  }\n    49→\n    50→  return basename(projectDir);\n    51→}\n    52→\n    53→export function getStackLabel(stack: string | string[] | null): string {\n    54→  if (Array.isArray(stack)) {\n    55→    if (stack.length === 0) return 'Unknown';\n    56→    return stack.map(s => getStackLabel(s)).join(' + ');\n    57→  }\n    58→  if (!stack) return 'Unknown';\n    59→  const provider = getStackProvider(stack as StackName);\n    60→  return provider ? provider.displayName : 'Unknown';\n    61→}\n    62→\n    63→/** Coverage tool name mapping for state file (uses state-format names, not provider CoverageToolName). */\n    64→const STATE_COVERAGE_TOOLS: Record<string, 'c8' | 'coverage.py' | 'cargo-tarpaulin'> = {\n    65→  nodejs: 'c8',\n    66→  python: 'coverage.py',\n    67→  rust: 'cargo-tarpaulin',\n    68→};\n    69→\n    70→export function getCoverageTool(stack: string | null): 'c8' | 'coverage.py' | 'cargo-tarpaulin' | 'unknown' {\n    71→  if (!stack) return 'c8';\n    72→  return STATE_COVERAGE_TOOLS[stack] ?? 'c8';\n    73→}\n    74→\n    75→export function generateAgentsMdContent(projectDir: string, stack: string | StackDetection[] | null): string {\n    76→  // Multi-stack path: StackDetection[] with more than one entry\n    77→  if (Array.isArray(stack) && stack.length > 1) {\n    78→    return generateMultiStackAgentsMd(projectDir, stack);\n    79→  }\n    80→  // Single-element array: unwrap to string for backward-compatible single-stack output\n    81→  if (Array.isArray(stack)) {\n    82→    stack = stack.length === 1 ? stack[0].stack : null;\n    83→  }\n    84→\n    85→  // Single-stack path: string | null (backward compat)\n    86→  const projectName = basename(projectDir);\n    87→  const provider = stack ? getStackProvider(stack as StackName) : undefined;\n    88→  const stackLabel = provider ? stackDisplayName(stack!) : 'Unknown';\n    89→\n    90→  const lines = [\n    91→    `# ${projectName}`,\n    92→    '',\n    93→    '## Stack',\n    94→    '',\n    95→    `- **Language/Runtime:** ${stackLabel}`,\n    96→    '',\n    97→    '## Build & Test Commands',\n    98→    '',\n    99→  ];\n   100→\n   101→  if (provider) {\n   102→    appendBuildTestCommands(lines, provider.name, '');\n   103→  } else {\n   104→    lines.push('```bash', '# No recognized stack — add build/test commands here', '```');\n   105→  }\n   106→\n   107→  lines.push(\n   108→    '',\n   109→    '## Project Structure',\n   110→    '',\n   111→    '```',\n   112→    `${projectName}/`,\n   113→    '├── src/           # Source code',\n   114→    '├── tests/         # Test files',\n   115→    '├── docs/          # Documentation',\n   116→    '└── .claude/       # Codeharness state',\n   117→    '```',\n   118→    '',\n   119→    '## Conventions',\n   120→    '',\n   121→    '- All changes must pass tests before commit',\n   122→    '- Maintain test coverage targets',\n   123→    '- Follow existing code style and patterns',\n   124→    '',\n   125→  );\n   126→\n   127→  return lines.join('\\n');\n   128→}\n   129→\n   130→/** Maps stack identifier to short display name for AGENTS.md generation (no parenthetical). */\n   131→function stackDisplayName(stack: string): string {\n   132→  const provider = getStackProvider(stack as StackName);\n   133→  if (!provider) return 'Unknown';\n   134→  // Strip parenthetical qualifiers like \" (package.json)\" or \" (Cargo.toml)\"\n   135→  return provider.displayName.replace(/ \\(.*\\)$/, '');\n   136→}\n   137→\n   138→/** Build/test commands per stack, keyed by provider name. Uses provider methods. */\n   139→function appendBuildTestCommands(lines: string[], stack: string, prefix: string): void {\n   140→  const provider = getStackProvider(stack as StackName);\n   141→  if (!provider) return;\n   142→  const buildCmds = provider.getBuildCommands();\n   143→  const testCmds = provider.getTestCommands();\n   144→  lines.push('```bash');\n   145→  for (const cmd of buildCmds) {\n   146→    lines.push(`${prefix}${cmd}`);\n   147→  }\n   148→  for (const cmd of testCmds) {\n   149→    lines.push(`${prefix}${cmd}`);\n   150→  }\n   151→  lines.push('```');\n   152→}\n   153→\n   154→function generateMultiStackAgentsMd(projectDir: string, stacks: StackDetection[]): string {\n   155→  const projectName = basename(projectDir);\n   156→  const stackNames = stacks.map(s => stackDisplayName(s.stack));\n   157→\n   158→  const lines = [\n   159→    `# ${projectName}`,\n   160→    '',\n   161→    '## Stack',\n   162→    '',\n   163→    `- **Language/Runtime:** ${stackNames.join(' + ')}`,\n   164→    '',\n   165→    '## Build & Test Commands',\n   166→    '',\n   167→  ];\n   168→\n   169→  for (const detection of stacks) {\n   170→    const label = stackDisplayName(detection.stack);\n   171→    const heading = detection.dir === '.' ? `### ${label}` : `### ${label} (${detection.dir}/)`;\n   172→    const prefix = detection.dir === '.' ? '' : `cd ${detection.dir} && `;\n   173→\n   174→    lines.push(heading, '');\n   175→\n   176→    appendBuildTestCommands(lines, detection.stack, prefix);\n   177→\n   178→    lines.push('');\n   179→  }\n   180→\n   181→  lines.push(\n   182→    '## Project Structure',\n   183→    '',\n   184→    '```',\n   185→    `${projectName}/`,\n   186→    '├── src/           # Source code',\n   187→    '├── tests/         # Test files',\n   188→    '├── docs/          # Documentation',\n   189→    '└── .claude/       # Codeharness state',\n   190→    '```',\n   191→    '',\n   192→    '## Conventions',\n   193→    '',\n   194→    '- All changes must pass tests before commit',\n   195→    '- Maintain test coverage targets',\n   196→    '- Follow existing code style and patterns',\n   197→    '',\n   198→  );\n   199→\n   200→  return lines.join('\\n');\n   201→}\n   202→\n   203→export function generateDocsIndexContent(): string {\n   204→  return [\n   205→    '# Project Documentation',\n   206→    '',\n   207→    '## Planning Artifacts',\n   208→    '- [Product Requirements](../_bmad-output/planning-artifacts/prd.md)',\n   209→    '- [Architecture](../_bmad-output/planning-artifacts/architecture.md)',\n   210→    '- [Epics & Stories](../_bmad-output/planning-artifacts/epics.md)',\n   211→    '',\n   212→    '## Execution',\n   213→    '- [Active Exec Plans](exec-plans/active/)',\n   214→    '- [Completed Exec Plans](exec-plans/completed/)',\n   215→    '',\n   216→    '## Quality',\n   217→    '- [Quality Reports](quality/)',\n   218→    '- [Generated Reports](generated/)',\n   219→    '',\n   220→  ].join('\\n');\n   221→}\n   222→\n   223→interface ScaffoldDocsOptions {\n   224→  readonly projectDir: string;\n   225→  readonly stack: string | null;\n   226→  readonly stacks?: StackDetection[];\n   227→  readonly isJson: boolean;\n   228→}\n   229→\n   230→export async function scaffoldDocs(opts: ScaffoldDocsOptions): Promise<Result<InitDocumentationResult>> {\n   231→  try {\n   232→    let agentsMd: 'created' | 'exists' | 'skipped' = 'skipped';\n   233→    let docsScaffold: 'created' | 'exists' | 'skipped' = 'skipped';\n   234→    let readme: 'created' | 'exists' | 'skipped' = 'skipped';\n   235→\n   236→    // AGENTS.md\n   237→    const agentsMdPath = join(opts.projectDir, 'AGENTS.md');\n   238→    if (!existsSync(agentsMdPath)) {\n   239→      const stackArg = opts.stacks && opts.stacks.length > 1 ? opts.stacks : opts.stack;\n   240→      const content = generateAgentsMdContent(opts.projectDir, stackArg);\n   241→      generateFile(agentsMdPath, content);\n   242→      agentsMd = 'created';\n   243→    } else {\n   244→      agentsMd = 'exists';\n   245→    }\n   246→\n   247→    // docs/ scaffold\n   248→    const docsDir = join(opts.projectDir, 'docs');\n   249→    if (!existsSync(docsDir)) {\n   250→      generateFile(join(docsDir, 'index.md'), generateDocsIndexContent());\n   251→      generateFile(join(docsDir, 'exec-plans', 'active', '.gitkeep'), '');\n   252→      generateFile(join(docsDir, 'exec-plans', 'completed', '.gitkeep'), '');\n   253→      generateFile(join(docsDir, 'quality', '.gitkeep'), DO_NOT_EDIT_HEADER);\n   254→      generateFile(join(docsDir, 'generated', '.gitkeep'), DO_NOT_EDIT_HEADER);\n   255→      docsScaffold = 'created';\n   256→    } else {\n   257→      docsScaffold = 'exists';\n   258→    }\n   259→\n   260→    // README.md\n   261→    const readmePath = join(opts.projectDir, 'README.md');\n   262→    if (!existsSync(readmePath)) {\n   263→      let cliHelpOutput = '';\n   264→      try {\n   265→        const { execFileSync } = await import('node:child_process');\n   266→        cliHelpOutput = execFileSync(process.execPath, [process.argv[1], '--help'], {\n   267→          stdio: 'pipe',\n   268→          timeout: 10_000,\n   269→        }).toString();\n   270→      } catch {\n   271→        cliHelpOutput = 'Run: codeharness --help';\n   272→      }\n   273→\n   274→      const readmeStack = opts.stacks && opts.stacks.length > 1\n   275→        ? opts.stacks.map(s => s.stack)\n   276→        : opts.stack;\n   277→      const readmeContent = readmeTemplate({\n   278→        projectName: getProjectName(opts.projectDir),\n   279→        stack: readmeStack,\n   280→        cliHelpOutput,\n   281→      });\n   282→      generateFile(readmePath, readmeContent);\n   283→      readme = 'created';\n   284→    } else {\n   285→      readme = 'exists';\n   286→    }\n   287→\n   288→    const result: InitDocumentationResult = { agents_md: agentsMd, docs_scaffold: docsScaffold, readme };\n   289→\n   290→    if (!opts.isJson) {\n   291→      if (result.agents_md === 'created' || result.docs_scaffold === 'created') {\n   292→        okOutput('Documentation: AGENTS.md + docs/ scaffold created');\n   293→      }\n   294→      if (result.readme === 'created') {\n   295→        okOutput('Documentation: README.md created');\n   296→      }\n   297→    }\n   298→\n   299→    return ok(result);\n   300→  } catch (err) {\n   301→    const message = err instanceof Error ? err.message : String(err);\n   302→    return fail(`Documentation scaffold failed: ${message}`);\n   303→  }\n   304→}\n   305→"}]},"parent_tool_use_id":"toolu_01NQFJhfdisZwxGgfMvJomZh","session_id":"01d3be87-3cff-45e1-920c-7390a9e4093c","uuid":"d92c33b6-b430-48f1-adf7-a2b27b34fcc9","timestamp":"2026-03-24T09:58:22.377Z"}
