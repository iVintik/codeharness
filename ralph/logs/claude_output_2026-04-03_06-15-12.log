{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WmGKadtQ6zmECCN6Y96WnW","type":"tool_result","content":"1\t/** Proof quality validation and black-box enforcement. */\n2\timport { existsSync, readFileSync } from 'node:fs';\n3\timport type { ProofQuality, ClassifiedCommand, EvidenceCommandType, BlackBoxEnforcementResult, VerificationTier } from './types.js';\n4\timport { TIER_HIERARCHY, LEGACY_TIER_MAP } from './types.js';\n5\t\n6\t/** Extracts commands from ```bash/```shell blocks and classifies each. */\n7\texport function classifyEvidenceCommands(proofContent: string): ClassifiedCommand[] {\n8\t  const results: ClassifiedCommand[] = [];\n9\t\n10\t  const codeBlockPattern = /```(?:bash|shell)\\n([\\s\\S]*?)```/g;\n11\t  for (const match of proofContent.matchAll(codeBlockPattern)) {\n12\t    const block = match[1].trim();\n13\t    const lines = block.split('\\n').filter(l => l.trim().length > 0);\n14\t    for (const line of lines) {\n15\t      const cmd = line.trim();\n16\t      if (!cmd) continue;\n17\t      results.push({ command: cmd, type: classifyCommand(cmd) });\n18\t    }\n19\t  }\n20\t\n21\t  return results;\n22\t}\n23\t\n24\tfunction classifyCommand(cmd: string): EvidenceCommandType {\n25\t  if (/docker\\s+exec\\b/.test(cmd)) {\n26\t    return 'docker-exec';\n27\t  }\n28\t\n29\t  if (/docker\\s+(ps|logs|inspect|stats|top|port)\\b/.test(cmd)) {\n30\t    return 'docker-host';\n31\t  }\n32\t\n33\t  if (/curl\\b/.test(cmd) && /localhost:(9428|8428|16686)\\b/.test(cmd)) {\n34\t    return 'observability';\n35\t  }\n36\t\n37\t  if (/\\bgrep\\b/.test(cmd) && /\\bsrc\\//.test(cmd)) {\n38\t    return 'grep-src';\n39\t  }\n40\t\n41\t  return 'other';\n42\t}\n43\t\n44\t/** Checks black-box enforcement: rejects >50% grep src/ or missing docker exec per AC. */\n45\texport function checkBlackBoxEnforcement(proofContent: string): BlackBoxEnforcementResult {\n46\t  const commands = classifyEvidenceCommands(proofContent);\n47\t\n48\t  const grepSrcCount = commands.filter(c => c.type === 'grep-src').length;\n49\t  const dockerExecCount = commands.filter(c => c.type === 'docker-exec').length;\n50\t  const observabilityCount = commands.filter(c => c.type === 'observability').length;\n51\t  const otherCount = commands.filter(c => c.type === 'other').length;\n52\t  const totalCommands = commands.length;\n53\t\n54\t  const grepRatio = totalCommands > 0 ? grepSrcCount / totalCommands : 0;\n55\t\n56\t  // Check per-AC docker exec presence\n57\t  const acsMissingDockerExec: number[] = [];\n58\t  const acHeaderPattern = /^## AC ?(\\d+):/gm;\n59\t  const acMatches = [...proofContent.matchAll(acHeaderPattern)];\n60\t\n61\t  if (acMatches.length > 0) {\n62\t    for (let i = 0; i < acMatches.length; i++) {\n63\t      const acNum = parseInt(acMatches[i][1], 10);\n64\t      const start = acMatches[i].index!;\n65\t      const end = i + 1 < acMatches.length ? acMatches[i + 1].index! : proofContent.length;\n66\t      const section = proofContent.slice(start, end);\n67\t\n68\t      // Skip escalated ACs\n69\t      if (section.includes('[ESCALATE]')) continue;\n70\t\n71\t      const sectionCommands = classifyEvidenceCommands(section);\n72\t      const hasBlackBoxEvidence = sectionCommands.some(c =>\n73\t        c.type === 'docker-exec' || c.type === 'docker-host' || c.type === 'observability'\n74\t      );\n75\t      if (!hasBlackBoxEvidence) {\n76\t        acsMissingDockerExec.push(acNum);\n77\t      }\n78\t    }\n79\t  }\n80\t\n81\t  const grepTooHigh = grepRatio > 0.5;\n82\t  const missingDockerExec = acsMissingDockerExec.length > 0;\n83\t  const hasExtractableCommands = totalCommands > 0;\n84\t\n85\t  return {\n86\t    blackBoxPass: !hasExtractableCommands || (!grepTooHigh && !missingDockerExec),\n87\t    grepSrcCount,\n88\t    dockerExecCount,\n89\t    observabilityCount,\n90\t    otherCount,\n91\t    grepRatio,\n92\t    acsMissingDockerExec,\n93\t  };\n94\t}\n95\t\n96\t/** Checks if [FAIL] appears outside code blocks and inline code. */\n97\tfunction hasFailVerdict(section: string): boolean {\n98\t  return section.replace(/```[\\s\\S]*?```/g, '').replace(/`[^`]+`/g, '').includes('[FAIL]');\n99\t}\n100\t\n101\t/** Validates proof quality. `passed` is true when `pending === 0 && verified > 0`. */\n102\texport function validateProofQuality(proofPath: string): ProofQuality {\n103\t  const emptyResult: ProofQuality = {\n104\t    verified: 0, pending: 0, escalated: 0, total: 0, passed: false,\n105\t    grepSrcCount: 0, dockerExecCount: 0, observabilityCount: 0, otherCount: 0,\n106\t    blackBoxPass: false,\n107\t  };\n108\t\n109\t  if (!existsSync(proofPath)) {\n110\t    return emptyResult;\n111\t  }\n112\t\n113\t  const content = readFileSync(proofPath, 'utf-8');\n114\t\n115\t  // Compute black-box enforcement metrics once\n116\t  // Build tier regex dynamically from canonical TIER_HIERARCHY + legacy names\n117\t  const allTierNames = [...TIER_HIERARCHY, ...Object.keys(LEGACY_TIER_MAP)];\n118\t  const uniqueTierNames = [...new Set(allTierNames)];\n119\t  const tierPattern = new RegExp(`\\\\*\\\\*Tier:\\\\*\\\\*\\\\s*(${uniqueTierNames.join('|')})`, 'i');\n120\t  const bbTierMatch = tierPattern.exec(content);\n121\t  const rawTierValue = bbTierMatch ? bbTierMatch[1].toLowerCase() : null;\n122\t  // Normalize legacy tier names to canonical VerificationTier values\n123\t  const normalizedTier: VerificationTier | null = rawTierValue\n124\t    ? (LEGACY_TIER_MAP[rawTierValue] as VerificationTier | undefined) ?? (TIER_HIERARCHY.includes(rawTierValue as VerificationTier) ? rawTierValue as VerificationTier : null)\n125\t    : null;\n126\t  // Only environment-provable requires Docker evidence; all others skip\n127\t  const skipDockerEnforcement = normalizedTier !== null && normalizedTier !== 'environment-provable';\n128\t  // Always compute metrics for diagnostics; override blackBoxPass when skipping\n129\t  const bbRawEnforcement = checkBlackBoxEnforcement(content);\n130\t  const bbEnforcement = skipDockerEnforcement\n131\t    ? { ...bbRawEnforcement, blackBoxPass: true }\n132\t    : bbRawEnforcement;\n133\t\n134\t  /** Helper: merge base counts with black-box metrics */\n135\t  function buildResult(base: {\n136\t    verified: number; pending: number; escalated: number; total: number;\n137\t  }): ProofQuality {\n138\t    const basePassed = base.pending === 0 && base.verified > 0;\n139\t    return {\n140\t      ...base,\n141\t      passed: basePassed && bbEnforcement.blackBoxPass,\n142\t      grepSrcCount: bbEnforcement.grepSrcCount,\n143\t      dockerExecCount: bbEnforcement.dockerExecCount,\n144\t      observabilityCount: bbEnforcement.observabilityCount,\n145\t      otherCount: bbEnforcement.otherCount,\n146\t      blackBoxPass: bbEnforcement.blackBoxPass,\n147\t    };\n148\t  }\n149\t\n150\t  // Format 1: ## AC N: section headers\n151\t  const acHeaderPattern = /^## AC ?(\\d+):/gm;\n152\t  const matches = [...content.matchAll(acHeaderPattern)];\n153\t\n154\t  // Find all ## headings that are NOT AC headers (e.g. ## Summary, ## Test Evidence)\n155\t  // These bound the last AC section so it doesn't bleed into trailing sections\n156\t  const nonAcHeadingPattern = /^## (?!AC ?\\d+:)/gm;\n157\t  const nonAcHeadings = [...content.matchAll(nonAcHeadingPattern)].map(m => m.index!);\n158\t\n159\t  let verified = 0;\n160\t  let pending = 0;\n161\t  let escalated = 0;\n162\t\n163\t  if (matches.length > 0) {\n164\t    for (let i = 0; i < matches.length; i++) {\n165\t      const start = matches[i].index!;\n166\t      // End at the next ## AC header or any non-AC ## heading (e.g. ## Summary), whichever comes first\n167\t      const nextAcEnd = i + 1 < matches.length ? matches[i + 1].index! : content.length;\n168\t      const nextNonAcHeading = nonAcHeadings.find(h => h > start);\n169\t      const end = nextNonAcHeading !== undefined && nextNonAcHeading < nextAcEnd\n170\t        ? nextNonAcHeading\n171\t        : nextAcEnd;\n172\t      const section = content.slice(start, end);\n173\t\n174\t      if (section.includes('[ESCALATE]')) {\n175\t        escalated++;\n176\t        continue;\n177\t      }\n178\t\n179\t      if (hasFailVerdict(section)) {\n180\t        pending++;\n181\t        continue;\n182\t      }\n183\t\n184\t      const hasEvidence =\n185\t        section.includes('<!-- /showboat exec -->') ||\n186\t        section.includes('<!-- showboat image:') ||\n187\t        /```(?:bash|shell)\\n[\\s\\S]*?```\\n+```output\\n/m.test(section);\n188\t\n189\t      if (hasEvidence) {\n190\t        verified++;\n191\t      } else {\n192\t        pending++;\n193\t      }\n194\t    }\n195\t  } else {\n196\t    // Format 2: showboat native — inline --- ACN: markers\n197\t    const inlineAcPattern = /--- AC ?(\\d+):/g;\n198\t    const inlineMatches = [...content.matchAll(inlineAcPattern)];\n199\t    const acNumbers = new Set(inlineMatches.map(m => m[1]));\n200\t\n201\t    if (acNumbers.size === 0) {\n202\t      // Format 3: narrative proofs with === AC N: markers\n203\t      const narrativeAcPattern = /=== AC ?(\\d+):/g;\n204\t      const narrativeMatches = [...content.matchAll(narrativeAcPattern)];\n205\t      const narrativeAcNumbers = new Set(narrativeMatches.map(m => m[1]));\n206\t\n207\t      if (narrativeAcNumbers.size === 0) {\n208\t        // Format 4: bullet-list AC summaries\n209\t        const bulletAcPattern = /^- AC ?(\\d+)[^:\\n]*:/gm;\n210\t        const bulletMatches = [...content.matchAll(bulletAcPattern)];\n211\t        const bulletAcNumbers = new Set(bulletMatches.map(m => m[1]));\n212\t\n213\t        if (bulletAcNumbers.size === 0) {\n214\t          return buildResult({ verified: 0, pending: 0, escalated: 0, total: 0 });\n215\t        }\n216\t\n217\t        let bVerified = 0;\n218\t        let bPending = 0;\n219\t        let bEscalated = 0;\n220\t\n221\t        for (const acNum of bulletAcNumbers) {\n222\t          const bulletPattern = new RegExp(`^- AC ?${acNum}[^:\\\\n]*:(.*)$`, 'm');\n223\t          const bulletMa