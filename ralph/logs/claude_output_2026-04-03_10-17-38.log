{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FdRWcUAaAzqDRRdhXHsoBZ","type":"tool_result","content":"1\t/**\n2\t * AgentDriver abstraction types.\n3\t *\n4\t * Defines the contract that all agent drivers (Ralph, future API-based agents)\n5\t * must implement. See architecture-v3.md Decision 3.\n6\t */\n7\t\n8\timport type { Readable } from 'node:stream';\n9\t\n10\t/**\n11\t * Options for spawning an agent process.\n12\t */\n13\texport interface SpawnOpts {\n14\t  storyKey: string;\n15\t  prompt: string;\n16\t  workDir: string;\n17\t  timeout: number;\n18\t  env?: Record<string, string>;\n19\t}\n20\t\n21\t/**\n22\t * Abstraction over a running agent process.\n23\t * Wraps Node.js ChildProcess but allows non-process-based drivers\n24\t * (direct API calls, WebSocket connections) to implement the same interface.\n25\t */\n26\texport interface AgentProcess {\n27\t  stdout: Readable;\n28\t  stderr: Readable;\n29\t  on(event: 'close', handler: (code: number) => void): void;\n30\t  on(event: 'error', handler: (err: Error) => void): void;\n31\t  kill(signal?: string): void;\n32\t}\n33\t\n34\t/**\n35\t * Discriminated union of events emitted by an agent driver.\n36\t * The `parseOutput()` method converts raw agent output lines into these typed events.\n37\t */\n38\texport type AgentEvent =\n39\t  | { type: 'tool-start'; name: string }\n40\t  | { type: 'tool-input'; partial: string }\n41\t  | { type: 'tool-complete'; name?: string; args?: string }\n42\t  | { type: 'text'; text: string }\n43\t  | { type: 'story-complete'; key: string; details: string }\n44\t  | { type: 'story-failed'; key: string; reason: string }\n45\t  | { type: 'iteration'; count: number }\n46\t  | { type: 'retry'; attempt: number; delay: number }\n47\t  | { type: 'result'; cost: number; sessionId: string };\n48\t\n49\t/**\n50\t * The core agent driver interface.\n51\t * Each driver knows how to spawn an agent, parse its output, and locate its status file.\n52\t */\n53\texport interface AgentDriver {\n54\t  readonly name: string;\n55\t  spawn(opts: SpawnOpts): AgentProcess;\n56\t  parseOutput(line: string): AgentEvent | null;\n57\t  getStatusFile(): string;\n58\t}\n59\t"}]},"parent_tool_use_id":"toolu_01XS4sVgQGUVdaHQcMbvghrp","session_id":"e499f49a-fe4c-4b28-bb21-4e83348f2671","uuid":"bb88c6cd-7cb2-4d33-b783-18a90835f32c","timestamp":"2026-04-03T06:19:04.356Z"}
