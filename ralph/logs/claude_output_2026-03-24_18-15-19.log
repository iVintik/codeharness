{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QA7CqzddRQnCJS2ZMmdjuq","type":"tool_result","content":"     1→/**\n     2→ * Shared test utilities and fixtures.\n     3→ *\n     4→ * Single import point for test helpers, fixtures, and mock factories.\n     5→ * Usage: import { withTempDir, buildSprintState, createFsMock, CARGO_TOML_MINIMAL } from '../../lib/__tests__/helpers.js';\n     6→ */\n     7→\n     8→import { mkdtempSync, rmSync } from 'node:fs';\n     9→import { tmpdir } from 'node:os';\n    10→import { join } from 'node:path';\n    11→\n    12→// ── Re-exports from fixtures ───────────────────────────────────────────────────\n    13→\n    14→export * from './fixtures/cargo-toml-variants.js';\n    15→export * from './fixtures/state-builders.js';\n    16→export * from './fixtures/mock-factories.js';\n    17→\n    18→// ── Temp directory helper ──────────────────────────────────────────────────────\n    19→\n    20→/**\n    21→ * Create a temporary directory, run the callback, then clean up.\n    22→ * Cleanup runs on success, error, or any exception.\n    23→ *\n    24→ * @param fn - async callback receiving the temp directory path\n    25→ * @param prefix - optional prefix for the temp directory name (default: 'ch-test-')\n    26→ */\n    27→export async function withTempDir(\n    28→  fn: (dir: string) => Promise<void>,\n    29→  prefix = 'ch-test-',\n    30→): Promise<void> {\n    31→  const dir = mkdtempSync(join(tmpdir(), prefix));\n    32→  try {\n    33→    await fn(dir);\n    34→  } finally {\n    35→    rmSync(dir, { recursive: true, force: true });\n    36→  }\n    37→}\n    38→"}]},"parent_tool_use_id":"toolu_01E4d2UoNxdYuxQTG5Dezgge","session_id":"8c35c2f7-0e10-4994-a438-2b5cecce3396","uuid":"6c86e75a-a18b-4263-abc7-65dee187ddb0","timestamp":"2026-03-24T14:16:22.497Z"}
