{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012ac5kGpxkqzjZs6vM8JoJw","type":"tool_result","content":"1\t/**\n2\t * WorkflowGraph ã Ink component that renders a schematic workflow graph.\n3\t *\n4\t * Displays tasks as nodes connected by arrows, with status indicators\n5\t * (pending, active, done, failed). Loop blocks are rendered with an\n6\t * iteration counter and visual grouping.\n7\t *\n8\t * When `taskMeta` is provided, renders a multi-row layout:\n9\t *   Row 1: task names with status icons, connected by arrows\n10\t *   Row 2: driver labels (dimmed)\n11\t *   Row 3: cost/time for completed tasks (dimmed)\n12\t *\n13\t * When `taskMeta` is empty or omitted, renders the original single-line format.\n14\t *\n15\t * This is a pure presentational component ã no side effects, no state hooks.\n16\t */\n17\t\n18\timport React from 'react';\n19\timport { Text, Box } from 'ink';\n20\timport type { FlowStep, LoopBlock } from './workflow-parser.js';\n21\timport type { TaskNodeState, TaskNodeMeta } from './ink-components.js';\n22\t\n23\t/** Terminal width, capped to avoid excessive line lengths. */\n24\tconst termWidth = () => Math.min(process.stdout.columns || 60, 80);\n25\t\n26\t/** Spinner frames for active task animation. */\n27\tconst SPINNER_FRAMES = ['ã ', 'ã ', 'ã ¿', 'ã ¡', 'ã ¥', 'ã Ç', 'ã Î', 'ã Ï', 'ã ', 'ã '];\n28\t\n29\texport interface WorkflowGraphProps {\n30\t  flow: FlowStep[];\n31\t  currentTask: string | null;\n32\t  taskStates: Record<string, TaskNodeState>;\n33\t  taskMeta?: Record<string, TaskNodeMeta>;\n34\t}\n35\t\n36\tfunction isLoopBlock(step: FlowStep): step is LoopBlock {\n37\t  return typeof step === 'object' && step !== null && 'loop' in step;\n38\t}\n39\t\n40\t/** Format cost in USD. Returns `...` for null/undefined. */\n41\texport function formatCost(costUsd: number | null | undefined): string {\n42\t  if (costUsd == null) return '...';\n43\t  return `$${costUsd.toFixed(2)}`;\n44\t}\n45\t\n46\t/** Format elapsed time. Returns `Xm` for >=60s, `Xs` for <60s, `...` for null/undefined. */\n47\texport function formatElapsed(ms: number | null | undefined): string {\n48\t  if (ms == null) return '...';\n49\t  const seconds = Math.round(ms / 1000);\n50\t  if (seconds >= 60) {\n51\t    return `${Math.round(seconds / 60)}m`;\n52\t  }\n53\t  return `${seconds}s`;\n54\t}\n55\t\n56\t/** Render a single task name with its status indicator. */\n57\tfunction TaskNode({ name, status, spinnerFrame }: { name: string; status: TaskNodeState | undefined; spinnerFrame?: number }) {\n58\t  const s = status ?? 'pending';\n59\t  switch (s) {\n60\t    case 'done':\n61\t      return <Text color=\"green\">{name} ã</Text>;\n62\t    case 'active': {\n63\t      const frame = SPINNER_FRAMES[(spinnerFrame ?? 0) % SPINNER_FRAMES.length];\n64\t      return <Text color=\"cyan\">{frame} {name}</Text>;\n65\t    }\n66\t    case 'failed':\n67\t      return <Text color=\"red\">{name} ã</Text>;\n68\t    case 'pending':\n69\t    default:\n70\t      return <Text dimColor>{name}</Text>;\n71\t  }\n72\t}\n73\t\n74\t/** Count completed iterations for a loop block based on task states. */\n75\tfunction loopIteration(tasks: string[], taskStates: Record<string, TaskNodeState>): number {\n76\t  // Heuristic: 0 before any task starts, 1 once any task is active/done/failed.\n77\t  const anyStarted = tasks.some(t => {\n78\t    const s = taskStates[t];\n79\t    return s !== undefined && s !== 'pending';\n80\t  });\n81\t  return anyStarted ? 1 : 0;\n82\t}\n83\t\n84\t/** Collect all task names from the flow in order (flattening loop blocks). */\n85\tfunction collectTaskNames(flow: FlowStep[]): string[] {\n86\t  const names: string[] = [];\n87\t  for (const step of flow) {\n88\t    if (isLoopBlock(step)) {\n89\t      names.push(...step.loop);\n90\t    } else {\n91\t      names.push(step);\n92\t    }\n93\t  }\n94\t  return names;\n95\t}\n96\t\n97\t/** Check if taskMeta has any meaningful data. */\n98\tfunction hasMetaData(taskMeta: Record<string, TaskNodeMeta> | undefined): boolean {\n99\t  if (!taskMeta) return false;\n100\t  return Object.keys(taskMeta).length > 0;\n101\t}\n102\t\n103\texport function WorkflowGraph({ flow, currentTask, taskStates, taskMeta }: WorkflowGraphProps) {\n104\t  if (flow.length === 0 || Object.keys(taskStates).length === 0) {\n105\t    return null;\n106\t  }\n107\t\n108\t  const meta = taskMeta ?? {};\n109\t  const showMeta = hasMetaData(taskMeta);\n110\t\n111\t  // Use a ref-based counter for spinner animation.\n112\t  // Since this is a pure component with no hooks, we derive spinner frame\n113\t  // from a simple counter. The parent re-renders on state updates which\n114\t  // advances the display naturally. Use Date.now() to get animation frames.\n115\t  const spinnerFrame = Math.floor(Date.now() / 80);\n116\t\n117\t  // Row 1: task names with status icons and arrows\n118\t  const elements: React.ReactNode[] = [];\n119\t\n120\t  for (let i = 0; i < flow.length; i++) {\n121\t    const step = flow[i];\n122\t\n123\t    if (i > 0) {\n124\t      elements.push(<Text key={`arrow-${i}`}>{' ã '}</Text>);\n125\t    }\n126\t\n127\t    if (isLoopBlock(step)) {\n128\t      const iteration = loopIteration(step.loop, taskStates);\n129\t      const loopNodes: React.ReactNode[] = [];\n130\t      for (let j = 0; j < step.loop.length; j++) {\n131\t        if (j > 0) {\n132\t          loopNodes.push(<Text key={`loop-arrow-${i}-${j}`}>{' ã '}</Text>);\n133\t        }\n134\t        loopNodes.push(\n135\t          <TaskNode key={`loop-task-${i}-${j}`} name={step.loop[j]} status={taskStates[step.loop[j]]} spinnerFrame={spinnerFrame} />\n136\t        );\n137\t      }\n138\t      elements.push(\n139\t        <Text key={`loop-${i}`}>\n140\t          <Text>loop({iteration})[ </Text>\n141\t          {loopNodes}\n142\t          <Text> ]</Text>\n143\t        </Text>\n144\t      );\n145\t    } else {\n146\t      elements.push(\n147\t        <TaskNode key={`task-${i}`} name={step} status={taskStates[step]} spinnerFrame={spinnerFrame} />\n148\t      );\n149\t    }\n150\t  }\n151\t\n152\t  // Row 2 & 3: driver labels and cost/time (only when meta is present)\n153\t  let driverRow: React.ReactNode | null = null;\n154\t  let costRow: React.ReactNode | null = null;\n155\t\n156\t  if (showMeta) {\n157\t    const taskNames = collectTaskNames(flow);\n158\t    const driverParts: string[] = [];\n159\t    const costParts: string[] = [];\n160\t    let hasAnyCost = false;\n161\t\n162\t    for (const name of taskNames) {\n163\t      const m = meta[name];\n164\t      const driver = m?.driver ?? '';\n165\t      driverParts.push(driver);\n166\t\n167\t      const state = taskStates[name];\n168\t      if (state === 'done') {\n169\t        const costStr = formatCost(m?.costUsd);\n170\t        const timeStr = formatElapsed(m?.elapsedMs);\n171\t        costParts.push(`${costStr} / ${timeStr}`);\n172\t        hasAnyCost = true;\n173\t      } else {\n174\t        costParts.push('');\n175\t      }\n176\t    }\n177\t\n178\t    // Build driver row: pad each label to match the task name width in row 1\n179\t    const hasSomeDriver = driverParts.some(d => d.length > 0);\n180\t    if (hasSomeDriver) {\n181\t      const driverLabels: React.ReactNode[] = [];\n182\t      for (let idx = 0; idx < taskNames.length; idx++) {\n183\t        if (idx > 0) {\n184\t          // Spacing to align under arrows ã use same width as ' ã '\n185\t          driverLabels.push(<Text key={`drv-sep-${idx}`}>{'     '}</Text>);\n186\t        }\n187\t        driverLabels.push(\n188\t          <Text key={`drv-${idx}`} dimColor>{driverParts[idx] || ' '}</Text>\n189\t        );\n190\t      }\n191\t      driverRow = <Text>  {driverLabels}</Text>;\n192\t    }\n193\t\n194\t    // Build cost row\n195\t    if (hasAnyCost) {\n196\t      const costLabels: React.ReactNode[] = [];\n197\t      for (let idx = 0; idx < taskNames.length; idx++) {\n198\t        if (idx > 0) {\n199\t          costLabels.push(<Text key={`cost-sep-${idx}`}>{'     '}</Text>);\n200\t        }\n201\t        costLabels.push(\n202\t          <Text key={`cost-${idx}`} dimColor>{costParts[idx] || ' '}</Text>\n203\t        );\n204\t      }\n205\t      costRow = <Text>  {costLabels}</Text>;\n206\t    }\n207\t  }\n208\t\n209\t  return (\n210\t    <Box flexDirection=\"column\">\n211\t      <Text>{'ã'.repeat(termWidth())}</Text>\n212\t      <Text>  {elements}</Text>\n213\t      {driverRow}\n214\t      {costRow}\n215\t      <Text>{'ã'.repeat(termWidth())}</Text>\n216\t    </Box>\n217\t  );\n218\t}\n219\t"}]},"parent_tool_use_id":"toolu_01HHjA9k9oUqnMe2NSedRNzY","session_id":"87203133-5cdd-4288-8e5c-bcff0e178735","uuid":"0d5f10f7-284e-4d13-a95d-15bfeb9ef65f","timestamp":"2026-04-03T11:44:53.977Z"}
