s\n    61→ * integration testing. Checks description against integration keywords\n    62→ * (case-insensitive). Falls back to 'cli-verifiable'.\n    63→ *\n    64→ * @deprecated Use `classifyTier()` instead. Will be removed in a future release.\n    65→ */\n    66→export function classifyVerifiability(description: string): Verifiability {\n    67→  const lower = description.toLowerCase();\n    68→\n    69→  for (const kw of INTEGRATION_KEYWORDS) {\n    70→    if (lower.includes(kw)) return 'integration-required';\n    71→  }\n    72→\n    73→  return 'cli-verifiable';\n    74→}\n    75→\n    76→// ─── Verification Strategy ─────────────────────────────────────────────────\n    77→\n    78→/**\n    79→ * Determines the best verification strategy for an AC.\n    80→ *\n    81→ * Docker is the DEFAULT — it's the safest approach because it runs in an\n    82→ * isolated container that can't corrupt the host environment.\n    83→ *\n    84→ * cli-direct is the fallback when Docker is unavailable (checked at runtime).\n    85→ * escalate is the last resort for things that truly can't be automated.\n    86→ *\n    87→ * @deprecated Use `classifyTier()` instead. Will be removed in a future release.\n    88→ */\n    89→export function classifyStrategy(description: string): VerificationStrategy {\n    90→  const lower = description.toLowerCase();\n    91→\n    92→  // Check for true escalation first (very rare)\n    93→  for (const kw of ESCALATE_KEYWORDS) {\n    94→    if (lower.includes(kw)) return 'escalate';\n    95→  }\n    96→\n    97→  // Default: Docker for everything\n    98→  return 'docker';\n    99→}\n   100→\n   101→// ─── Tier Classification Keywords ────────────────────────────────────────────\n   102→\n   103→const TEST_PROVABLE_KEYWORDS = [\n   104→  'file exists', 'export', 'type', 'interface', 'test passes',\n   105→  'line count', 'coverage', 'refactor', 'rename', 'documentation',\n   106→  'function', 'when inspected', 'config',\n   107→];\n   108→\n   109→const RUNTIME_PROVABLE_KEYWORDS = [\n   110→  'cli command', 'api endpoint', 'http', 'server', 'output shows',\n   111→  'exit code', 'binary', 'runs and produces', 'cli outputs', 'when run',\n   112→];\n   113→\n   114→const ENVIRONMENT_PROVABLE_KEYWORDS = [\n   115→  'docker', 'container', 'observability', 'telemetry', 'database',\n   116→  'queue', 'distributed', 'multi-service', 'end-to-end', 'victorialogs',\n   117→];\n   118→\n   119→const ESCALATE_TIER_KEYWORDS = [\n   120→  'physical hardware', 'human visual', 'paid service', 'gpu',\n   121→  'manual inspection', 'physical display',\n   122→];\n   123→\n   124→/**\n   125→ * Classifies an AC description into a VerificationTier based on keyword matching.\n   126→ * Priority: escalate > environment-provable > runtime-provable > test-provable (default).\n   127→ */\n   128→export function classifyTier(description: string): VerificationTier {\n   129→  const lower = description.toLowerCase();\n   130→  // Check highest priority first\n   131→  for (const kw of ESCALATE_TIER_KEYWORDS) {\n   132→    if (lower.includes(kw)) return 'escalate';\n   133→  }\n   134→  for (const kw of ENVIRONMENT_PROVABLE_KEYWORDS) {\n   135→    if (lower.includes(kw)) return 'environment-provable';\n   136→  }\n   137→  for (const kw of RUNTIME_PROVABLE_KEYWORDS) {\n   138→    if (lower.includes(kw)) return 'runtime-provable';\n   139→  }\n   140→  // Default: test-provable\n   141→  return 'test-provable';\n   142→}\n   143→\n   144→// ─── Verification Tag Parsing ───────────────────────────────────────────────\n   145→\n   146→const VERIFICATION_TAG_PATTERN = /<!--\\s*verification:\\s*(cli-verifiable|integration-required|test-provable|runtime-provable|environment-provable|escalate)\\s*-->/;\n   147→\n   148→/**\n   149→ * Parses a `<!-- verification: ... -->` HTML comment tag from a string.\n   150→ * Accepts both legacy values (cli-verifiable, integration-required) and\n   151→ * new VerificationTier values (test-provable, runtime-provable, etc.).\n   152→ * Legacy values are mapped to VerificationTier via LEGACY_TIER_MAP.\n   153→ * Returns a VerificationTier if found, or null.\n   154→ */\n   155→export function parseVerificationTag(text: string): VerificationTier | null {\n   156→  const match = VERIFICATION_TAG_PATTERN.exec(text);\n   157→  if (!match) return null;\n   158→  const raw = match[1];\n   159→  // Map legacy values to new tiers\n   160→  return (LEGACY_TIER_MAP[raw] ?? raw) as VerificationTier;\n   161→}\n   162→\n   163→// ─── Classification ─────────────────────────────────────────────────────────\n   164→\n   165→/**\n   166→ * Classifies an AC description by keywords.\n   167→ * Checks UI, API, DB keywords (case-insensitive). Falls back to 'general'.\n   168→ */\n   169→export function classifyAC(description: string): 'ui' | 'api' | 'db' | 'general' {\n   170→  const lower = description.toLowerCase();\n   171→\n   172→  for (const kw of UI_KEYWORDS) {\n   173→    if (lower.includes(kw)) return 'ui';\n   174→  }\n   175→  for (const kw of API_KEYWORDS) {\n   176→    if (lower.includes(kw)) return 'api';\n   177→  }\n   178→  for (const kw of DB_KEYWORDS) {\n   179→    if (lower.includes(kw)) return 'db';\n   180→  }\n   181→\n   182→  return 'general';\n   183→}\n   184→\n   185→// ─── Parser ─────────────────────────────────────────────────────────────────\n   186→\n   187→/**\n   188→ * Reads a story markdown file and extracts numbered acceptance criteria.\n   189→ * Finds the `## Acceptance Criteria` section, then parses numbered items.\n   190→ *\n   191→ * @throws Error if file not found (with actionable message)\n   192→ * @returns ParsedAC[] — empty array if no AC section found (with warning)\n   193→ */\n   194→export function parseStoryACs(storyFilePath: string): ParsedAC[] {\n   195→  if (!existsSync(storyFilePath)) {\n   196→    throw new Error(\n   197→      `Story file not found: ${storyFilePath}. Ensure the story file exists at the expected path.`,\n   198→    );\n   199→  }\n   200→\n   201→  const content = readFileSync(storyFilePath, 'utf-8');\n   202→  const lines = content.split('\\n');\n   203→\n   204→  // Find the AC section\n   205→  let acSectionStart = -1;\n   206→  for (let i = 0; i < lines.length; i++) {\n   207→    if (/^##\\s+Acceptance\\s+Criteria/i.test(lines[i])) {\n   208→      acSectionStart = i + 1;\n   209→      break;\n   210→    }\n   211→  }\n   212→\n   213→  if (acSectionStart === -1) {\n   214→    warn('No \"## Acceptance Criteria\" section found in story file');\n   215→    return [];\n   216→  }\n   217→\n   218→  // Find section end (next ## heading or end of file)\n   219→  let acSectionEnd = lines.length;\n   220→  for (let i = acSectionStart; i < lines.length; i++) {\n   221→    if (/^##\\s+/.test(lines[i]) && i !== acSectionStart - 1) {\n   222→      acSectionEnd = i;\n   223→      break;\n   224→    }\n   225→  }\n   226→\n   227→  const acSection = lines.slice(acSectionStart, acSectionEnd).join('\\n');\n   228→\n   229→  // Parse numbered ACs\n   230→  const acPattern = /^\\s*(\\d+)\\.\\s+/;\n   231→  const acs: ParsedAC[] = [];\n   232→  const acLines = acSection.split('\\n');\n   233→\n   234→  let currentId: string | null = null;\n   235→  let currentDesc: string[] = [];\n   236→\n   237→  const flushCurrent = (): void => {\n   238→    if (currentId !== null && currentDesc.length > 0) {\n   239→      const description = currentDesc.join(' ').trim();\n   240→      if (description) {\n   241→        const tag = parseVerificationTag(description);\n   242→        const tier: VerificationTier = tag ?? classifyTier(description);\n   243→        const verifiability = classifyVerifiability(description); // deprecated, kept for compat\n   244→        const strategy = classifyStrategy(description); // deprecated, kept for compat\n   245→        acs.push({\n   246→          id: currentId,\n   247→          description,\n   248→          type: classifyAC(description),\n   249→          verifiability,\n   250→          strategy,\n   251→          tier,\n   252→        });\n   253→      } else {\n   254→        warn(`Skipping malformed AC #${currentId}: empty description`);\n   255→      }\n   256→    }\n   257→  };\n   258→\n   259→  for (const line of acLines) {\n   260→    const match = acPattern.exec(line);\n   261→    if (match) {\n   262→      flushCurrent();\n   263→      currentId = match[1];\n   264→      currentDesc = [line.replace(acPattern, '').trim()];\n   265→    } else if (currentId !== null && line.trim()) {\n   266→      currentDesc.push(line.trim());\n   267→    }\n   268→  }\n   269→\n   270→  // Flush last AC\n   271→  flushCurrent();\n   272→\n   273→  return acs;\n   274→}\n   275→\n   276→// ─── Observability Gap Parser ────────────────────────────────────────────\n   277→\n   278→const AC_HEADING_PATTERN = /^##\\s+AC\\s+(\\d+)/i;\n   279→const OBSERVABILITY_GAP_TAG = '[OBSERVABILITY GAP]';\n   280→\n   281→/**\n   282→ * Parses proof content for `[OBSERVABILITY GAP]` tags.\n   283→ * Scans each AC section (delimited by `## AC N:` headings) for the gap tag.\n   284→ *\n   285→ * @param proofContent - Raw markdown content of the proof document\n   286→ * @returns Per-AC gap presence and aggregate counts\n   287→ */\n   288→export function parseObservabilityGaps(proofContent: string): ObservabilityGapResult {\n   289→  const lines = proofContent.split('\\n');\n   290→  const entries: ObservabilityGapEntry[] = [];\n   291→\n   292→  let currentAcId: string | null = null;\n   293→  let currentSectionLines: string[] = [];\n   294→\n   295→  const flushSection = (): void => {\n   296→    if (currentAcId !== null) {\n   297→      const sectionText = currentSectionLines.join('\\n');\n   298→      const hasGap = sectionText.includes(OBSERVABILITY_GAP_TAG);\n   299→      const gapNote = hasGap\n   300→        ? 'No log events detected for this user interaction'\n   301→        : undefined;\n   302→      entries.push({ acId: currentAcId, hasGap, gapNote });\n   303→    }\n   304→  };\n   305→\n   306→  for (const line of lines) {\n   307→    const match = AC_HEADING_PATTERN.exec(line);\n   308→    if (match) {\n   309→      flushSection();\n   310→      currentAcId = match[1];\n   311→      currentSectionLines = [line];\n   312→    } else if (currentAcId !== null) {\n   313→      currentSectionLines.push(line);\n   314→    }\n   315→  }\n   316→\n   317→  // Flush last section\n   318→  flushSection();\n   319→\n   320→  const totalACs = entries.length;\n   321→  const gapCount = entries.filter(e => e.hasGap).length;\n   322→  const coveredCount = totalACs - gapCount;\n   323→\n   324→  return { entries, totalACs, gapCount, coveredCount };\n   325→}\n   326→"}]},"parent_tool_use_id":"toolu_01XaLJCdGEA6WsjsGauAKPVu","session_id":"6d9d3799-5d0f-4ddf-a676-1dbe6fbfed55","uuid":"176c3ff5-2193-4649-823b-7653706ef9de","timestamp":"2026-03-27T10:25:44.070Z"}
