{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015X9G8cccFiWHcN8NFPoYaZ","type":"tool_result","content":"     1→/**\n     2→ * Rust stack provider — encapsulates all Rust-specific behavior.\n     3→ * Implements every StackProvider method for the rust stack.\n     4→ *\n     5→ * Story 10-4: full implementation following NodejsProvider/PythonProvider patterns.\n     6→ */\n     7→\n     8→import { execFileSync } from 'node:child_process';\n     9→import { existsSync, readFileSync } from 'node:fs';\n    10→import { join } from 'node:path';\n    11→\n    12→import { renderTemplateFile } from '../templates.js';\n    13→import type {\n    14→  AppType,\n    15→  CoverageToolInfo,\n    16→  CoverageToolName,\n    17→  OtlpResult,\n    18→  StackProvider,\n    19→  TestCounts,\n    20→} from './types.js';\n    21→import { readTextSafe, getCargoDepsSection, hasCargoDep } from './utils.js';\n    22→\n    23→/** Dependency names that signal an AI/agent project. */\n    24→const RUST_AGENT_DEPS = ['async-openai', 'anthropic', 'llm-chain'];\n    25→\n    26→/** Dependency names that signal a web framework project. */\n    27→const RUST_WEB_FRAMEWORKS = ['actix-web', 'axum', 'rocket', 'tide', 'warp'];\n    28→\n    29→/** OTLP packages required for Rust instrumentation. */\n    30→const RUST_OTLP_PACKAGES = [\n    31→  'opentelemetry',\n    32→  'opentelemetry-otlp',\n    33→  'tracing-opentelemetry',\n    34→  'tracing-subscriber',\n    35→];\n    36→\n    37→export class RustProvider implements StackProvider {\n    38→  readonly name = 'rust' as const;\n    39→  readonly markers = ['Cargo.toml'];\n    40→  readonly displayName = 'Rust (Cargo.toml)';\n    41→\n    42→  // ── Task 3: detectAppType ──────────────────────────────────────────────\n    43→\n    44→  detectAppType(dir: string): AppType {\n    45→    const cargoContent = readTextSafe(join(dir, 'Cargo.toml'));\n    46→    if (!cargoContent) return 'generic';\n    47→\n    48→    const depsSection = getCargoDepsSection(cargoContent);\n    49→\n    50→    // Priority 1: Agent detection (only in [dependencies], not [dev-dependencies])\n    51→    if (RUST_AGENT_DEPS.some((d) => hasCargoDep(depsSection, d))) {\n    52→      return 'agent';\n    53→    }\n    54→\n    55→    // Priority 2: Server detection (web framework in [dependencies])\n    56→    if (RUST_WEB_FRAMEWORKS.some((d) => hasCargoDep(depsSection, d))) {\n    57→      return 'server';\n    58→    }\n    59→\n    60→    // Priority 3: CLI detection ([[bin]] section present)\n    61→    if (/^\\[\\[bin\\]\\]\\s*$/m.test(cargoContent)) {\n    62→      return 'cli';\n    63→    }\n    64→\n    65→    // Priority 4: Library detection ([lib] section present, no [[bin]])\n    66→    if (/^\\[lib\\]\\s*$/m.test(cargoContent)) {\n    67→      return 'generic';\n    68→    }\n    69→\n    70→    return 'generic';\n    71→  }\n    72→\n    73→  // ── Task 4: getCoverageTool ────────────────────────────────────────────\n    74→\n    75→  getCoverageTool(): CoverageToolName {\n    76→    return 'tarpaulin';\n    77→  }\n    78→\n    79→  // ── Task 5: detectCoverageConfig ───────────────────────────────────────\n    80→\n    81→  detectCoverageConfig(dir: string): CoverageToolInfo {\n    82→    const cargoPath = join(dir, 'Cargo.toml');\n    83→    if (!existsSync(cargoPath)) {\n    84→      return { tool: 'none' };\n    85→    }\n    86→\n    87→    return { tool: 'tarpaulin', configFile: cargoPath };\n    88→  }\n    89→\n    90→  // ── Task 6: getOtlpPackages ────────────────────────────────────────────\n    91→\n    92→  getOtlpPackages(): string[] {\n    93→    return [...RUST_OTLP_PACKAGES];\n    94→  }\n    95→\n    96→  // ── Task 7: installOtlp ───────────────────────────────────────────────\n    97→\n    98→  installOtlp(dir: string): OtlpResult {\n    99→    try {\n   100→      execFileSync('cargo', ['add', ...RUST_OTLP_PACKAGES], {\n   101→        cwd: dir,\n   102→        stdio: 'pipe',\n   103→        timeout: 300_000,\n   104→      });\n   105→      return {\n   106→        success: true,\n   107→        packagesInstalled: [...RUST_OTLP_PACKAGES],\n   108→      };\n   109→    } catch (err) {\n   110→      const message = err instanceof Error ? err.message : 'Unknown error';\n   111→      return {\n   112→        success: false,\n   113→        packagesInstalled: [],\n   114→        error: `Failed to install Rust OTLP packages: ${message.length > 200 ? message.slice(0, 200) + '... (truncated)' : message}`,\n   115→      };\n   116→    }\n   117→  }\n   118→\n   119→  // ── Task 8: getDockerfileTemplate ─────────────────────────────────────\n   120→\n   121→  getDockerfileTemplate(): string {\n   122→    return renderTemplateFile('templates/dockerfiles/Dockerfile.rust');\n   123→  }\n   124→\n   125→  // ── Task 9: getDockerBuildStage ───────────────────────────────────────\n   126→\n   127→  getDockerBuildStage(): string {\n   128→    return `# === Build stage: rust ===\n   129→FROM rust:1.82-slim AS build-rust\n   130→WORKDIR /build\n   131→COPY . .\n   132→RUN cargo build --release\n   133→`;\n   134→  }\n   135→\n   136→  // ── Task 10: getRuntimeCopyDirectives ──────────────────────────────────\n   137→\n   138→  getRuntimeCopyDirectives(): string {\n   139→    return 'COPY --from=build-rust /build/target/release/myapp /usr/local/bin/myapp';\n   140→  }\n   141→\n   142→  // ── Task 11: getBuildCommands ──────────────────────────────────────────\n   143→\n   144→  getBuildCommands(): string[] {\n   145→    return ['cargo build', 'cargo test'];\n   146→  }\n   147→\n   148→  // ── Task 12: getTestCommands ──────────────────────────────────────────\n   149→\n   150→  getTestCommands(): string[] {\n   151→    return ['cargo test'];\n   152→  }\n   153→\n   154→  // ── Task 13: getSemgrepLanguages ──────────────────────────────────────\n   155→\n   156→  getSemgrepLanguages(): string[] {\n   157→    return ['rust'];\n   158→  }\n   159→\n   160→  // ── Task 14: parseTestOutput ──────────────────────────────────────────\n   161→\n   162→  parseTestOutput(output: string): TestCounts {\n   163→    // Cargo test format: \"test result: ok. N passed; M failed; K ignored\"\n   164→    // Workspace projects emit multiple \"test result:\" lines — aggregate all.\n   165→    const pattern = /test result:.*?(\\d+)\\s+passed;\\s*(\\d+)\\s+failed(?:;\\s*(\\d+)\\s+ignored)?/g;\n   166→    let passed = 0;\n   167→    let failed = 0;\n   168→    let skipped = 0;\n   169→    let match: RegExpExecArray | null;\n   170→\n   171→    while ((match = pattern.exec(output)) !== null) {\n   172→      passed += parseInt(match[1], 10);\n   173→      failed += parseInt(match[2], 10);\n   174→      skipped += match[3] ? parseInt(match[3], 10) : 0;\n   175→    }\n   176→\n   177→    const total = passed + failed + skipped;\n   178→    return { passed, failed, skipped, total };\n   179→  }\n   180→\n   181→  // ── Task 15: parseCoverageReport ──────────────────────────────────────\n   182→\n   183→  parseCoverageReport(dir: string): number {\n   184→    const reportPath = join(dir, 'coverage', 'tarpaulin-report.json');\n   185→    if (!existsSync(reportPath)) return 0;\n   186→\n   187→    try {\n   188→      const report = JSON.parse(readFileSync(reportPath, 'utf-8')) as { coverage?: number };\n   189→      return report.coverage ?? 0;\n   190→    } catch {\n   191→      // IGNORE: tarpaulin report may be malformed\n   192→      return 0;\n   193→    }\n   194→  }\n   195→\n   196→  // ── Task 16: getProjectName ───────────────────────────────────────────\n   197→\n   198→  // ── getVerifyDockerfileSection ──────────────────────────────────────\n   199→\n   200→  getVerifyDockerfileSection(projectDir: string): string {\n   201→    // Detect Bevy dependency for system libs (must decide before building the apt-get line)\n   202→    let needsBevy = false;\n   203→    const cargoContent = readTextSafe(join(projectDir, 'Cargo.toml'));\n   204→    if (cargoContent) {\n   205→      const depsSection = getCargoDepsSection(cargoContent);\n   206→      needsBevy = hasCargoDep(depsSection, 'bevy');\n   207→    }\n   208→\n   209→    const aptPackages = ['build-essential', 'pkg-config', 'libssl-dev'];\n   210→    if (needsBevy) {\n   211→      aptPackages.push(\n   212→        'libudev-dev', 'libasound2-dev', 'libwayland-dev',\n   213→        'libxkbcommon-dev', 'libfontconfig1-dev', 'libx11-dev',\n   214→      );\n   215→    }\n   216→\n   217→    const lines: string[] = [\n   218→      '# --- Rust tooling ---',\n   219→      'RUN apt-get update && apt-get install -y --no-install-recommends \\\\',\n   220→      `    ${aptPackages.join(' ')} \\\\`,\n   221→      '    && rm -rf /var/lib/apt/lists/*',\n   222→      'RUN curl --proto \"=https\" --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable',\n   223→      'ENV PATH=\"/root/.cargo/bin:$PATH\"',\n   224→      'RUN rustup component add clippy',\n   225→      'RUN cargo install cargo-tarpaulin',\n   226→    ];\n   227→\n   228→    return lines.join('\\n');\n   229→  }\n   230→\n   231→  getProjectName(dir: string): string | null {\n   232→    const cargoContent = readTextSafe(join(dir, 'Cargo.toml'));\n   233→    if (!cargoContent) return null;\n   234→\n   235→    // Extract the [package] section (up to the next section header or EOF)\n   236→    const packageIdx = cargoContent.search(/^\\[package\\]\\s*$/m);\n   237→    if (packageIdx === -1) return null;\n   238→\n   239→    const afterHeader = cargoContent.slice(\n   240→      packageIdx + cargoContent.slice(packageIdx).indexOf('\\n') + 1,\n   241→    );\n   242→    // Find where next section starts (line beginning with '[')\n   243→    const nextSectionIdx = afterHeader.search(/^\\[/m);\n   244→    const section = nextSectionIdx === -1 ? afterHeader : afterHeader.slice(0, nextSectionIdx);\n   245→\n   246→    // Match name = \"...\" or name = '...' within the [package] section only\n   247→    const nameMatch = /^\\s*name\\s*=\\s*[\"']([^\"']+)[\"']/m.exec(section);\n   248→    return nameMatch ? nameMatch[1] : null;\n   249→  }\n   250→}\n   251→"}]},"parent_tool_use_id":"toolu_01A5VRSCWrKG5o81CvpB3aWg","session_id":"83e99bf1-19ed-4459-85db-f9346f9425ec","uuid":"99051e4b-492a-40a8-89c1-d68526cdfdbd","timestamp":"2026-03-27T09:33:21.070Z"}
