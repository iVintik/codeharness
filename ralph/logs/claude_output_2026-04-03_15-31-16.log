{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M32yUUyvne92UD6xKJKpQG","type":"tool_result","content":"1\t/**\n2\t * Ink UI components ã types and layout components (Header, Separator, StoryBreakdown).\n3\t *\n4\t * Renders a UX-spec-compliant live display with plain text header,\n5\t * ããã separators, and labeled story breakdown sections.\n6\t * Activity components (tools, thoughts, retry) are in ink-activity-components.tsx.\n7\t * The App root component is in ink-app.tsx to avoid circular imports.\n8\t */\n9\t\n10\timport React from 'react';\n11\timport { Text, Box } from 'ink';\n12\timport type { FlowStep } from './workflow-parser.js';\n13\t\n14\t// --- Types ---\n15\t\n16\texport interface SprintInfo {\n17\t  storyKey: string;\n18\t  phase: string;\n19\t  done: number;\n20\t  total: number;\n21\t  elapsed?: string;\n22\t  iterationCount?: number;\n23\t  totalCost?: number;\n24\t  acProgress?: string;\n25\t  currentCommand?: string;\n26\t}\n27\t\n28\texport interface CompletedToolEntry {\n29\t  name: string;\n30\t  args: string;\n31\t}\n32\t\n33\texport type StoryStatusValue = 'done' | 'in-progress' | 'pending' | 'failed' | 'blocked';\n34\t\n35\texport interface StoryStatusEntry {\n36\t  key: string;\n37\t  status: StoryStatusValue;\n38\t  retryCount?: number;\n39\t  maxRetries?: number;\n40\t}\n41\t\n42\texport interface RetryInfo {\n43\t  attempt: number;\n44\t  delay: number;\n45\t}\n46\t\n47\texport interface StoryMessage {\n48\t  type: 'ok' | 'warn' | 'fail';\n49\t  key: string;\n50\t  message: string;\n51\t  details?: string[];\n52\t}\n53\t\n54\texport type TaskNodeState = 'pending' | 'active' | 'done' | 'failed';\n55\t\n56\texport interface RendererState {\n57\t  sprintInfo: SprintInfo | null;\n58\t  stories: StoryStatusEntry[];\n59\t  messages: StoryMessage[];\n60\t  completedTools: CompletedToolEntry[];\n61\t  activeTool: { name: string } | null;\n62\t  activeToolArgs: string;\n63\t  lastThought: string | null;\n64\t  retryInfo: RetryInfo | null;\n65\t  workflowFlow: FlowStep[];\n66\t  currentTaskName: string | null;\n67\t  taskStates: Record<string, TaskNodeState>;\n68\t}\n69\t\n70\t// --- Layout Components ---\n71\t\n72\t/** Full-width separator using ã characters. */\n73\texport function Separator() {\n74\t  const width = process.stdout.columns || 60;\n75\t  return <Text>{'ã'.repeat(width)}</Text>;\n76\t}\n77\t\n78\tfunction shortKey(key: string): string {\n79\t  const m = key.match(/^(\\d+-\\d+)/);\n80\t  return m ? m[1] : key;\n81\t}\n82\t\n83\tfunction formatCost(cost: number): string {\n84\t  return `$${cost.toFixed(2)}`;\n85\t}\n86\t\n87\texport function Header({ info }: { info: SprintInfo | null }) {\n88\t  if (!info) return null;\n89\t\n90\t  const parts: string[] = ['codeharness run'];\n91\t  if (info.iterationCount != null) {\n92\t    parts.push(`iteration ${info.iterationCount}`);\n93\t  }\n94\t  if (info.elapsed) {\n95\t    parts.push(`${info.elapsed} elapsed`);\n96\t  }\n97\t  if (info.totalCost != null) {\n98\t    parts.push(`${formatCost(info.totalCost)} spent`);\n99\t  }\n100\t  const headerLine = parts.join(' | ');\n101\t\n102\t  let phaseLine = '';\n103\t  if (info.phase) {\n104\t    phaseLine = `Phase: ${info.phase}`;\n105\t    if (info.acProgress) {\n106\t      phaseLine += ` ã AC ${info.acProgress}`;\n107\t    }\n108\t    if (info.currentCommand) {\n109\t      phaseLine += ` (${info.currentCommand})`;\n110\t    }\n111\t  }\n112\t\n113\t  return (\n114\t    <Box flexDirection=\"column\">\n115\t      <Text>{headerLine}</Text>\n116\t      <Separator />\n117\t      <Text>{`Story: ${info.storyKey || '(waiting)'}`}</Text>\n118\t      {phaseLine && <Text>{phaseLine}</Text>}\n119\t    </Box>\n120\t  );\n121\t}\n122\t\n123\texport function StoryBreakdown({ stories, sprintInfo }: { stories: StoryStatusEntry[]; sprintInfo?: SprintInfo | null }) {\n124\t  if (stories.length === 0) return null;\n125\t\n126\t  const done: StoryStatusEntry[] = [];\n127\t  const inProgress: StoryStatusEntry[] = [];\n128\t  const pending: StoryStatusEntry[] = [];\n129\t  const failed: StoryStatusEntry[] = [];\n130\t  const blocked: StoryStatusEntry[] = [];\n131\t\n132\t  for (const s of stories) {\n133\t    switch (s.status) {\n134\t      case 'done': done.push(s); break;\n135\t      case 'in-progress': inProgress.push(s); break;\n136\t      case 'pending': pending.push(s); break;\n137\t      case 'failed': failed.push(s); break;\n138\t      case 'blocked': blocked.push(s); break;\n139\t    }\n140\t  }\n141\t\n142\t  const lines: React.ReactNode[] = [];\n143\t\n144\t  if (done.length > 0) {\n145\t    const doneItems = done.map(s => `${shortKey(s.key)} ã`).join('  ');\n146\t    lines.push(\n147\t      <Text key=\"done\"><Text color=\"green\">{'Done: '}</Text><Text color=\"green\">{doneItems}</Text></Text>\n148\t    );\n149\t  }\n150\t\n151\t  if (inProgress.length > 0) {\n152\t    for (const s of inProgress) {\n153\t      let thisText = `${shortKey(s.key)} ã`;\n154\t      if (sprintInfo && sprintInfo.storyKey && shortKey(s.key) === shortKey(sprintInfo.storyKey)) {\n155\t        if (sprintInfo.phase) thisText += ` ${sprintInfo.phase}`;\n156\t        if (sprintInfo.acProgress) thisText += ` (${sprintInfo.acProgress} ACs)`;\n157\t      }\n158\t      lines.push(\n159\t        <Text key={`this-${s.key}`}><Text color=\"cyan\">{'This: '}</Text><Text color=\"cyan\">{thisText}</Text></Text>\n160\t      );\n161\t    }\n162\t  }\n163\t\n164\t  if (pending.length > 0) {\n165\t    lines.push(\n166\t      <Text key=\"next\">\n167\t        <Text>{'Next: '}</Text><Text>{shortKey(pending[0].key)}</Text>\n168\t        {pending.length > 1 && <Text dimColor>{` (+${pending.length - 1} more)`}</Text>}\n169\t      </Text>\n170\t    );\n171\t  }\n172\t\n173\t  if (blocked.length > 0) {\n174\t    const blockedItems = blocked.map(s => {\n175\t      let item = `${shortKey(s.key)} ã`;\n176\t      if (s.retryCount != null && s.maxRetries != null) item += ` (${s.retryCount}/${s.maxRetries})`;\n177\t      return item;\n178\t    }).join('  ');\n179\t    lines.push(\n180\t      <Text key=\"blocked\"><Text color=\"yellow\">{'Blocked: '}</Text><Text color=\"yellow\">{blockedItems}</Text></Text>\n181\t    );\n182\t  }\n183\t\n184\t  if (failed.length > 0) {\n185\t    const failedItems = failed.map(s => {\n186\t      let item = `${shortKey(s.key)} ã`;\n187\t      if (s.retryCount != null && s.maxRetries != null) item += ` (${s.retryCount}/${s.maxRetries})`;\n188\t      return item;\n189\t    }).join('  ');\n190\t    lines.push(\n191\t      <Text key=\"failed\"><Text color=\"red\">{'Failed: '}</Text><Text color=\"red\">{failedItems}</Text></Text>\n192\t    );\n193\t  }\n194\t\n195\t  return (\n196\t    <Box flexDirection=\"column\">\n197\t      {lines}\n198\t    </Box>\n199\t  );\n200\t}\n201\t\n202\t// Re-export activity components so existing consumers don't break\n203\texport { CompletedTool, CompletedTools, ActiveTool, LastThought, RetryNotice, StoryMessageLine } from './ink-activity-components.js';\n204\t\n205\t// Re-export App from ink-app\n206\texport { App } from './ink-app.js';\n207\t"}]},"parent_tool_use_id":"toolu_019DMmBw36UEa9mKyd4eDFiB","session_id":"87203133-5cdd-4288-8e5c-bcff0e178735","uuid":"ff08f16b-7b7c-47fc-a16b-fde12c1e8623","timestamp":"2026-04-03T11:38:15.547Z"}
