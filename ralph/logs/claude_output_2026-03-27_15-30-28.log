{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TqqGum7sS45qfr6vnN2V35","type":"tool_result","content":"     1→/**\n     2→ * Verify module — story verification and proof parsing.\n     3→ * Public interface: only this file should be imported from outside the module.\n     4→ */\n     5→\n     6→import { readFileSync } from 'node:fs';\n     7→import { ok, fail } from '../../types/result.js';\n     8→import type { Result } from '../../types/result.js';\n     9→import { validateProofQuality } from './proof.js';\n    10→import {\n    11→  checkPreconditions as checkPreconditionsImpl,\n    12→  createProofDocument as createProofDocumentImpl,\n    13→  runShowboatVerify as runShowboatVerifyImpl,\n    14→  updateVerificationState as updateVerificationStateImpl,\n    15→  closeBeadsIssue as closeBeadsIssueImpl,\n    16→} from './orchestrator.js';\n    17→import { parseStoryACs as parseStoryACsImpl, parseObservabilityGaps as parseObservabilityGapsImpl } from './parser.js';\n    18→import { computeRuntimeCoverage as computeRuntimeCoverageImpl, saveRuntimeCoverage as saveRuntimeCoverageImpl } from '../observability/index.js';\n    19→import type { VerifyResult, ProofQuality, ObservabilityGapResult } from './types.js';\n    20→\n    21→// Re-export all public types\n    22→export type {\n    23→  VerifyResult,\n    24→  ProofQuality,\n    25→  ObservabilityGapResult,\n    26→  ObservabilityGapEntry,\n    27→  ParsedAC,\n    28→  Verifiability,\n    29→  VerificationTier,\n    30→  VerificationStrategy,\n    31→  ProjectType,\n    32→  PreconditionResult,\n    33→  ShowboatVerifyResult,\n    34→  ClassifiedCommand,\n    35→  EvidenceCommandType,\n    36→  BlackBoxEnforcementResult,\n    37→  BrowserActionResult,\n    38→  DiffResult,\n    39→  BuildOptions,\n    40→  BuildResult,\n    41→  CheckResult,\n    42→} from './types.js';\n    43→\n    44→export { TIER_HIERARCHY, maxTier, LEGACY_TIER_MAP } from './types.js';\n    45→\n    46→// Re-export browser verifier\n    47→export { BrowserVerifier } from './browser.js';\n    48→\n    49→// Re-export orchestrator functions\n    50→export {\n    51→  checkPreconditions,\n    52→  createProofDocument,\n    53→  runShowboatVerify,\n    54→  updateVerificationState,\n    55→  closeBeadsIssue,\n    56→} from './orchestrator.js';\n    57→\n    58→// Re-export parser functions\n    59→export {\n    60→  parseStoryACs,\n    61→  classifyAC,\n    62→  classifyVerifiability,\n    63→  classifyStrategy,\n    64→  classifyTier,\n    65→  parseVerificationTag,\n    66→  parseObservabilityGaps,\n    67→  INTEGRATION_KEYWORDS,\n    68→} from './parser.js';\n    69→\n    70→// Re-export proof functions\n    71→export {\n    72→  validateProofQuality,\n    73→  proofHasContent,\n    74→  classifyEvidenceCommands,\n    75→  checkBlackBoxEnforcement,\n    76→} from './proof.js';\n    77→\n    78→// Re-export validation AC registry\n    79→export {\n    80→  VALIDATION_ACS,\n    81→  FR_ACS,\n    82→  NFR_ACS,\n    83→  UX_ACS,\n    84→  REGRESSION_ACS,\n    85→  ACTION_ITEM_ACS,\n    86→  getACsByCategory,\n    87→  getCliVerifiableACs,\n    88→  getIntegrationRequiredACs,\n    89→  getACById,\n    90→} from './validation-acs.js';\n    91→export type { ValidationAC, VerificationMethod, AcCategory } from './validation-acs.js';\n    92→\n    93→// Re-export validation runner functions and types\n    94→export {\n    95→  createValidationSprint,\n    96→  executeValidationAC,\n    97→  createFixStory,\n    98→  processValidationResult,\n    99→} from './validation-runner.js';\n   100→export {\n   101→  getValidationProgress,\n   102→  runValidationCycle,\n   103→} from './validation-orchestrator.js';\n   104→export type {\n   105→  ValidationACResult,\n   106→  ValidationSprintResult,\n   107→  ValidationCycleResult,\n   108→  ValidationProgress,\n   109→  ValidationVerdict,\n   110→} from './validation-runner-types.js';\n   111→\n   112→// Re-export env functions\n   113→export {\n   114→  buildVerifyImage,\n   115→  detectProjectType,\n   116→  prepareVerifyWorkspace,\n   117→  checkVerifyEnv,\n   118→  cleanupVerifyEnv,\n   119→  cleanupStaleContainers,\n   120→  isValidStoryKey,\n   121→  computeDistHash,\n   122→} from './env.js';\n   123→\n   124→/**\n   125→ * Verify a story by running the full verification pipeline.\n   126→ * Returns Result<VerifyResult> — never throws.\n   127→ */\n   128→export function verifyStory(key: string): Result<VerifyResult> {\n   129→  try {\n   130→    const preconditions = checkPreconditionsImpl(undefined, key);\n   131→    if (!preconditions.passed) {\n   132→      return fail(`Preconditions not met: ${preconditions.failures.join('; ')}`);\n   133→    }\n   134→\n   135→    const storyDir = '_bmad-output/implementation-artifacts';\n   136→    const storyFilePath = `${storyDir}/${key}.md`;\n   137→    const acs = parseStoryACsImpl(storyFilePath);\n   138→    const proofPath = `verification/${key}-proof.md`;\n   139→    const quality = validateProofQuality(proofPath);\n   140→\n   141→    if (!quality.passed) {\n   142→      return fail(\n   143→        `Proof quality check failed: ${quality.verified}/${quality.total} ACs verified`,\n   144→      );\n   145→    }\n   146→\n   147→    const showboatResult = runShowboatVerifyImpl(proofPath);\n   148→    let showboatStatus: 'pass' | 'fail' | 'skipped' = 'skipped';\n   149→    if (showboatResult.output !== 'showboat not available') {\n   150→      showboatStatus = showboatResult.passed ? 'pass' : 'fail';\n   151→    }\n   152→\n   153→    // Parse observability gaps from proof content (Story 2.1)\n   154→    let observabilityGapCount = 0;\n   155→    let runtimeCoveragePercent = 0;\n   156→    try {\n   157→      const proofContent = readFileSync(proofPath, 'utf-8');\n   158→      const gapResult = parseObservabilityGapsImpl(proofContent);\n   159→      observabilityGapCount = gapResult.gapCount;\n   160→      runtimeCoveragePercent =\n   161→        gapResult.totalACs === 0\n   162→          ? 0\n   163→          : (gapResult.coveredCount / gapResult.totalACs) * 100;\n   164→\n   165→      // Persist runtime coverage to sprint-state.json (Story 2.1 AC #4)\n   166→      if (gapResult.totalACs > 0) {\n   167→        const runtimeResult = computeRuntimeCoverageImpl(gapResult);\n   168→        saveRuntimeCoverageImpl('.', runtimeResult);\n   169→      }\n   170→    } catch {\n   171→      // IGNORE: proof file may not exist yet or be unreadable, proceed with defaults\n   172→    }\n   173→\n   174→    const result: VerifyResult = {\n   175→      storyId: key,\n   176→      success: true,\n   177→      totalACs: quality.total,\n   178→      verifiedCount: quality.verified,\n   179→      failedCount: quality.pending,\n   180→      escalatedCount: quality.escalated,\n   181→      proofPath,\n   182→      showboatVerifyStatus: showboatStatus,\n   183→      observabilityGapCount,\n   184→      runtimeCoveragePercent,\n   185→      perAC: acs.map(ac => ({\n   186→        id: ac.id,\n   187→        description: ac.description,\n   188→        verified: true,\n   189→        evidencePaths: [],\n   190→      })),\n   191→    };\n   192→\n   193→    updateVerificationStateImpl(key, result);\n   194→    closeBeadsIssueImpl(key);\n   195→\n   196→    return ok(result);\n   197→  } catch (err: unknown) {\n   198→    const message = err instanceof Error ? err.message : String(err);\n   199→    return fail(message);\n   200→  }\n   201→}\n   202→\n   203→/**\n   204→ * Parse a proof document and return quality metrics.\n   205→ * Returns Result<ProofQuality> — never throws.\n   206→ */\n   207→export function parseProof(path: string): Result<ProofQuality> {\n   208→  try {\n   209→    const quality = validateProofQuality(path);\n   210→    return ok(quality);\n   211→  } catch (err: unknown) {\n   212→    const message = err instanceof Error ? err.message : String(err);\n   213→    return fail(message);\n   214→  }\n   215→}\n   216→"}]},"parent_tool_use_id":"toolu_01LnSVSQepuckZac7ZtmSt3a","session_id":"15a05376-1038-4ca0-9130-3347fd423c16","uuid":"f541d639-f4ac-4756-9940-30037b7ccae9","timestamp":"2026-03-27T11:37:43.107Z"}
