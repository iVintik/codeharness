{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017uNDSNJeQCkKM8bEZvEzbj","type":"tool_result","content":"     1→import { Command } from 'commander';\n     2→import { ok, fail, jsonOutput } from '../lib/output.js';\n     3→import { checkObservabilityCoverageGate } from '../modules/observability/index.js';\n     4→\n     5→export function registerObservabilityGateCommand(program: Command): void {\n     6→  program\n     7→    .command('observability-gate')\n     8→    .description('Check observability coverage against targets (commit gate)')\n     9→    .option('--json', 'Machine-readable JSON output')\n    10→    .option('--min-static <percent>', 'Override static coverage target')\n    11→    .option('--min-runtime <percent>', 'Override runtime coverage target')\n    12→    .action((opts, cmd) => {\n    13→      const globalOpts = cmd.optsWithGlobals();\n    14→      const isJson = opts.json === true || globalOpts.json === true;\n    15→      const root = process.cwd();\n    16→\n    17→      const overrides: { staticTarget?: number; runtimeTarget?: number } = {};\n    18→      if (opts.minStatic !== undefined) {\n    19→        const parsed = parseInt(opts.minStatic, 10);\n    20→        if (isNaN(parsed) || parsed < 0 || parsed > 100) {\n    21→          if (isJson) {\n    22→            jsonOutput({ status: 'error', message: '--min-static must be a number between 0 and 100' });\n    23→          } else {\n    24→            fail('--min-static must be a number between 0 and 100');\n    25→          }\n    26→          process.exitCode = 1;\n    27→          return;\n    28→        }\n    29→        overrides.staticTarget = parsed;\n    30→      }\n    31→      if (opts.minRuntime !== undefined) {\n    32→        const parsed = parseInt(opts.minRuntime, 10);\n    33→        if (isNaN(parsed) || parsed < 0 || parsed > 100) {\n    34→          if (isJson) {\n    35→            jsonOutput({ status: 'error', message: '--min-runtime must be a number between 0 and 100' });\n    36→          } else {\n    37→            fail('--min-runtime must be a number between 0 and 100');\n    38→          }\n    39→          process.exitCode = 1;\n    40→          return;\n    41→        }\n    42→        overrides.runtimeTarget = parsed;\n    43→      }\n    44→\n    45→      const result = checkObservabilityCoverageGate(root, overrides);\n    46→\n    47→      if (!result.success) {\n    48→        if (isJson) {\n    49→          jsonOutput({ status: 'error', message: result.error });\n    50→        } else {\n    51→          fail(`Observability gate error: ${result.error}`);\n    52→        }\n    53→        process.exitCode = 1;\n    54→        return;\n    55→      }\n    56→\n    57→      const gate = result.data;\n    58→\n    59→      if (isJson) {\n    60→        jsonOutput({\n    61→          status: gate.passed ? 'pass' : 'fail',\n    62→          passed: gate.passed,\n    63→          static: {\n    64→            current: gate.staticResult.current,\n    65→            target: gate.staticResult.target,\n    66→            met: gate.staticResult.met,\n    67→            gap: gate.staticResult.gap,\n    68→          },\n    69→          runtime: gate.runtimeResult\n    70→            ? {\n    71→                current: gate.runtimeResult.current,\n    72→                target: gate.runtimeResult.target,\n    73→                met: gate.runtimeResult.met,\n    74→                gap: gate.runtimeResult.gap,\n    75→              }\n    76→            : null,\n    77→          gaps: gate.gapSummary.map(g => ({\n    78→            file: g.file,\n    79→            line: g.line,\n    80→            type: g.type,\n    81→            description: g.description,\n    82→          })),\n    83→        });\n    84→      } else {\n    85→        const staticLine = `Static: ${gate.staticResult.current}% / ${gate.staticResult.target}% target`;\n    86→        if (gate.passed) {\n    87→          ok(`Observability gate passed. ${staticLine}`);\n    88→          if (gate.runtimeResult) {\n    89→            ok(`Runtime: ${gate.runtimeResult.current}% / ${gate.runtimeResult.target}% target`);\n    90→          }\n    91→        } else {\n    92→          fail(`Observability gate failed. ${staticLine}`);\n    93→          if (gate.runtimeResult && !gate.runtimeResult.met) {\n    94→            fail(`Runtime: ${gate.runtimeResult.current}% / ${gate.runtimeResult.target}% target`);\n    95→          }\n    96→          fail('Run `codeharness analyze` to see gaps and fix suggestions.');\n    97→        }\n    98→      }\n    99→\n   100→      if (!gate.passed) {\n   101→        process.exitCode = 1;\n   102→      }\n   103→    });\n   104→}\n   105→"}]},"parent_tool_use_id":"toolu_01HaJKsv5YrKWXVV5tMae9v1","session_id":"2fa32674-558d-4231-8eb7-1997dc535a41","uuid":"0f8e40a9-06ea-4771-b442-50ba824e7dee","timestamp":"2026-03-20T06:15:31.351Z"}
