scope: 'per-story' }),\n        'implement',\n        '5-1-foo',\n        makeDefinition(),\n        makeDefaultState(),\n        makeConfig(),\n      ),\n    ).resolves.not.toThrow();\n\n    expect(mockWarn).toHaveBeenCalledWith(\n      expect.stringContaining('flag propagation failed'),\n    );\n  });\n});"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":391,"cache_read_input_tokens":51786,"cache_creation":{"ephemeral_5m_input_tokens":391,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_017cqb76qurL8ij6LsD8qadk","session_id":"9476bbd2-ee0a-4a5e-ac2a-0ed5228c47bf","uuid":"16105f26-d47f-4b4f-b619-b7a90e70c52c"}
