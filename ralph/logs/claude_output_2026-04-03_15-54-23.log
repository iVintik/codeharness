{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XF98KhLT7QL1Wxxe7qHssG","type":"tool_result","content":"1\t/**\n2\t * Ink UI components — activity display (tools, thoughts, retry, messages).\n3\t *\n4\t * Split from ink-components.tsx to comply with NFR9 (max 300 lines per file).\n5\t * Types are defined in ink-components.tsx and imported here.\n6\t */\n7\t\n8\timport React from 'react';\n9\timport { Text, Box } from 'ink';\n10\timport { Spinner } from '@inkjs/ui';\n11\timport type { CompletedToolEntry, RetryInfo, StoryMessage } from './ink-components.js';\n12\t\n13\t// --- Message Styles ---\n14\t\n15\tconst MESSAGE_STYLE: Record<StoryMessage['type'], { prefix: string; color: string }> = {\n16\t  ok: { prefix: '[OK]', color: 'green' },\n17\t  warn: { prefix: '[WARN]', color: 'yellow' },\n18\t  fail: { prefix: '[FAIL]', color: 'red' },\n19\t};\n20\t\n21\t// --- Components ---\n22\t\n23\texport function StoryMessageLine({ msg }: { msg: StoryMessage }) {\n24\t  const style = MESSAGE_STYLE[msg.type];\n25\t  return (\n26\t    <Box flexDirection=\"column\">\n27\t      <Text>\n28\t        <Text color={style.color} bold>{style.prefix}</Text>\n29\t        <Text>{` Story ${msg.key}: ${msg.message}`}</Text>\n30\t      </Text>\n31\t      {msg.details?.map((d, j) => (\n32\t        <Text key={j} dimColor>{`  └ ${d}`}</Text>\n33\t      ))}\n34\t    </Box>\n35\t  );\n36\t}\n37\t\n38\texport function CompletedTool({ entry }: { entry: CompletedToolEntry }) {\n39\t  const argsSummary = entry.args.length > 60\n40\t    ? entry.args.slice(0, 60) + '…'\n41\t    : entry.args;\n42\t  return (\n43\t    <Text wrap=\"truncate-end\">\n44\t      <Text color=\"green\">{'✓ '}</Text>\n45\t      <Text dimColor>{'['}</Text>\n46\t      <Text>{entry.name}</Text>\n47\t      <Text dimColor>{'] '}</Text>\n48\t      <Text dimColor>{argsSummary}</Text>\n49\t    </Text>\n50\t  );\n51\t}\n52\t\n53\t/** Show only the last N completed tools to keep output compact. */\n54\tconst VISIBLE_COMPLETED_TOOLS = 5;\n55\t\n56\texport function CompletedTools({ tools }: { tools: CompletedToolEntry[] }) {\n57\t  const visible = tools.slice(-VISIBLE_COMPLETED_TOOLS);\n58\t  const hidden = tools.length - visible.length;\n59\t  return (\n60\t    <Box flexDirection=\"column\">\n61\t      {hidden > 0 && <Text dimColor>{`  … ${hidden} earlier tools`}</Text>}\n62\t      {visible.map((entry, i) => (\n63\t        <CompletedTool key={i} entry={entry} />\n64\t      ))}\n65\t    </Box>\n66\t  );\n67\t}\n68\t\n69\texport function ActiveTool({ name }: { name: string }) {\n70\t  return (\n71\t    <Box>\n72\t      <Text color=\"yellow\">{'⚡ '}</Text>\n73\t      <Text dimColor>{'['}</Text>\n74\t      <Text bold>{name}</Text>\n75\t      <Text dimColor>{'] '}</Text>\n76\t      <Spinner label=\"\" />\n77\t    </Box>\n78\t  );\n79\t}\n80\t\n81\texport function LastThought({ text }: { text: string }) {\n82\t  return (\n83\t    <Text wrap=\"truncate-end\">\n84\t      <Text>{'💭 '}</Text>\n85\t      <Text dimColor>{text}</Text>\n86\t    </Text>\n87\t  );\n88\t}\n89\t\n90\texport function RetryNotice({ info }: { info: RetryInfo }) {\n91\t  return (\n92\t    <Text color=\"yellow\">\n93\t      {'⏳ API retry '}\n94\t      {info.attempt}\n95\t      {' (waiting '}\n96\t      {info.delay}\n97\t      {'ms)'}\n98\t    </Text>\n99\t  );\n100\t}\n101\t"}]},"parent_tool_use_id":"toolu_0156ZxQEd4RjGj7cfTpUYE1h","session_id":"a29ee53b-c2b0-4802-9455-7215112648b1","uuid":"9bed4cd8-3163-40cc-bb26-a368a22ae646","timestamp":"2026-04-03T12:03:35.585Z"}
