{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012bbMYSsHiFFVbFJJMLFJsc","type":"tool_result","content":"1\timport { readFileSync, existsSync, readdirSync } from 'node:fs';\n2\timport { resolve, join, dirname } from 'node:path';\n3\timport { fileURLToPath } from 'node:url';\n4\timport os from 'node:os';\n5\timport { parse } from 'yaml';\n6\t\n7\tconst __filename = fileURLToPath(import.meta.url);\n8\tconst __dirname = dirname(__filename);\n9\timport { validateAgentSchema } from './schema-validate.js';\n10\t\n11\t// --- Interfaces ---\n12\t\n13\t/**\n14\t * Agent config shape matching agent.schema.json, plus optional prompt_patches\n15\t * accumulated from patch files.\n16\t */\n17\texport interface ResolvedAgent {\n18\t  name: string;\n19\t  role: {\n20\t    title: string;\n21\t    purpose: string;\n22\t  };\n23\t  persona: {\n24\t    identity: string;\n25\t    communication_style: string;\n26\t    principles: string[];\n27\t  };\n28\t  personality?: {\n29\t    traits: Record<string, number>;\n30\t  };\n31\t  disallowedTools?: string[];\n32\t  plugins?: string[];\n33\t  prompt_patches?: {\n34\t    append?: string;\n35\t  };\n36\t  prompt_template?: string;\n37\t}\n38\t\n39\t/**\n40\t * Compiled subagent definition ready for Agent SDK dispatch.\n41\t */\n42\texport interface SubagentDefinition {\n43\t  name: string;\n44\t  model: string;\n45\t  instructions: string;\n46\t  disallowedTools: string[];\n47\t  plugins?: readonly string[];\n48\t  bare: true;\n49\t}\n50\t\n51\t/**\n52\t * Patch file structure: extends identifies base, overrides deep-merged,\n53\t * prompt_patches preserved separately.\n54\t */\n55\texport interface AgentPatch {\n56\t  extends?: string;\n57\t  overrides?: Record<string, unknown>;\n58\t  prompt_patches?: {\n59\t    append?: string;\n60\t  };\n61\t}\n62\t\n63\t// --- Error Class ---\n64\t\n65\texport class AgentResolveError extends Error {\n66\t  public readonly filePath: string;\n67\t  public readonly errors: Array<{ path: string; message: string }>;\n68\t\n69\t  constructor(\n70\t    message: string,\n71\t    filePath: string,\n72\t    errors?: Array<{ path: string; message: string }>,\n73\t  ) {\n74\t    super(message);\n75\t    this.name = 'AgentResolveError';\n76\t    this.filePath = filePath;\n77\t    this.errors = errors ?? [];\n78\t  }\n79\t}\n80\t\n81\t// --- Constants ---\n82\t\n83\tconst TEMPLATES_DIR = resolve(__dirname, '../../templates/agents');\n84\tconst DEFAULT_MODEL = 'claude-sonnet-4-20250514';\n85\t\n86\t// --- Input Validation ---\n87\t\n88\tconst SAFE_NAME_RE = /^[a-zA-Z0-9_-]+$/;\n89\t\n90\t/**\n91\t * Validate agent name to prevent path traversal and unexpected characters.\n92\t */\n93\tfunction validateName(name: string): void {\n94\t  if (!name || !SAFE_NAME_RE.test(name)) {\n95\t    throw new AgentResolveError(\n96\t      `Invalid agent name: \"${name}\" — must match ${SAFE_NAME_RE}`,\n97\t      '',\n98\t      [{ path: '', message: `Invalid agent name: ${name}` }],\n99\t    );\n100\t  }\n101\t}\n102\t\n103\t// --- Deep Merge ---\n104\t\n105\t/**\n106\t * Deep merge strategy: objects merge recursively, arrays replace, scalars replace.\n107\t */\n108\tfunction deepMerge(base: Record<string, unknown>, patch: Record<string, unknown>): Record<string, unknown> {\n109\t  const result: Record<string, unknown> = { ...base };\n110\t\n111\t  for (const key of Object.keys(patch)) {\n112\t    const baseVal = base[key];\n113\t    const patchVal = patch[key];\n114\t\n115\t    if (\n116\t      patchVal !== null &&\n117\t      typeof patchVal === 'object' &&\n118\t      !Array.isArray(patchVal) &&\n119\t      baseVal !== null &&\n120\t      typeof baseVal === 'object' &&\n121\t      !Array.isArray(baseVal)\n122\t    ) {\n123\t      result[key] = deepMerge(\n124\t        baseVal as Record<string, unknown>,\n125\t        patchVal as Record<string, unknown>,\n126\t      );\n127\t    } else {\n128\t      result[key] = patchVal;\n129\t    }\n130\t  }\n131\t\n132\t  return result;\n133\t}\n134\t\n135\t// --- Embedded Agent Loading ---\n136\t\n137\t/**\n138\t * Load an embedded agent template from templates/agents/{name}.yaml.\n139\t * Throws AgentResolveError if not found or invalid.\n140\t */\n141\texport function loadEmbeddedAgent(name: string): ResolvedAgent {\n142\t  validateName(name);\n143\t  const filePath = join(TEMPLATES_DIR, `${name}.yaml`);\n144\t\n145\t  let raw: string;\n146\t  try {\n147\t    raw = readFileSync(filePath, 'utf-8');\n148\t  } catch { // IGNORE: rethrow as AgentResolveError with context\n149\t    throw new AgentResolveError(\n150\t      `Embedded agent not found: ${name}`,\n151\t      filePath,\n152\t      [{ path: filePath, message: `File not found: ${filePath}` }],\n153\t    );\n154\t  }\n155\t\n156\t  let parsed: unknown;\n157\t  try {\n158\t    parsed = parse(raw);\n159\t  } catch (err: unknown) {\n160\t    const msg = err instanceof Error ? err.message : String(err);\n161\t    throw new AgentResolveError(\n162\t      `Invalid YAML in embedded agent ${name}: ${msg}`,\n163\t      filePath,\n164\t      [{ path: filePath, message: msg }],\n165\t    );\n166\t  }\n167\t\n168\t  const result = validateAgentSchema(parsed);\n169\t  if (!result.valid) {\n170\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n171\t    throw new AgentResolveError(\n172\t      `Schema validation failed for embedded agent ${name}: ${details}`,\n173\t      filePath,\n174\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n175\t    );\n176\t  }\n177\t\n178\t  return parsed as ResolvedAgent;\n179\t}\n180\t\n181\t// --- Embedded Agent Listing ---\n182\t\n183\t/**\n184\t * List all embedded agent template names (filenames without .yaml extension).\n185\t * Returns a sorted array of available agent names.\n186\t */\n187\texport function listEmbeddedAgents(): string[] {\n188\t  try {\n189\t    const files = readdirSync(TEMPLATES_DIR);\n190\t    return files\n191\t      .filter((f) => f.endsWith('.yaml'))\n192\t      .map((f) => f.replace(/\\.yaml$/, ''))\n193\t      .sort();\n194\t  } catch { // IGNORE: directory unreadable — return empty list\n195\t    return [];\n196\t  }\n197\t}\n198\t\n199\t// --- Patch Loading ---\n200\t\n201\t/**\n202\t * Load a patch file. Returns null if the file does not exist (silent skip).\n203\t * Throws AgentResolveError on malformed YAML.\n204\t */\n205\texport function loadPatch(filePath: string): AgentPatch | null {\n206\t  if (!existsSync(filePath)) {\n207\t    return null;\n208\t  }\n209\t\n210\t  let raw: string;\n211\t  try {\n212\t    raw = readFileSync(filePath, 'utf-8');\n213\t  } catch { // IGNORE: file unreadable — treat as missing patch\n214\t    return null;\n215\t  }\n216\t\n217\t  let parsed: unknown;\n218\t  try {\n219\t    parsed = parse(raw);\n220\t  } catch (err: unknown) {\n221\t    const msg = err instanceof Error ? err.message : String(err);\n222\t    throw new AgentResolveError(\n223\t      `Invalid YAML in patch file: ${msg}`,\n224\t      filePath,\n225\t      [{ path: filePath, message: msg }],\n226\t    );\n227\t  }\n228\t\n229\t  if (parsed === null || typeof parsed !== 'object') {\n230\t    throw new AgentResolveError(\n231\t      `Patch file is not a valid object`,\n232\t      filePath,\n233\t      [{ path: filePath, message: 'Patch must be a YAML object' }],\n234\t    );\n235\t  }\n236\t\n237\t  return parsed as AgentPatch;\n238\t}\n239\t\n240\t// --- Patch Merging ---\n241\t\n242\t/**\n243\t * Merge a patch onto a base config. Deep-merges overrides, preserves prompt_patches separately.\n244\t */\n245\texport function mergePatch(\n246\t  base: Record<string, unknown>,\n247\t  patch: AgentPatch,\n248\t): Record<string, unknown> {\n249\t  let result = { ...base };\n250\t\n251\t  if (patch.overrides) {\n252\t    result = deepMerge(result, patch.overrides);\n253\t  }\n254\t\n255\t  if (patch.prompt_patches) {\n256\t    const existing = result.prompt_patches as { append?: string } | undefined;\n257\t    const existingAppend = existing?.append ?? '';\n258\t    const newAppend = patch.prompt_patches.append ?? '';\n259\t\n260\t    if (newAppend) {\n261\t      result.prompt_patches = {\n262\t        append: existingAppend ? `${existingAppend}\\n${newAppend}` : newAppend,\n263\t      };\n264\t    }\n265\t  }\n266\t\n267\t  return result;\n268\t}\n269\t\n270\t// --- Main Resolution ---\n271\t\n272\t/**\n273\t * Resolve an agent through the embedded -> user -> project patch chain.\n274\t * For custom agents (no embedded match, found at project/user level without extends), loads directly.\n275\t */\n276\texport function resolveAgent(name: string, options?: { cwd?: string }): ResolvedAgent {\n277\t  validateName(name);\n278\t  const cwd = options?.cwd ?? process.cwd();\n279\t  const userPatchPath = join(os.homedir(), '.codeharness', 'agents', `${name}.patch.yaml`);\n280\t  const projectPatchPath = join(cwd, '.codeharness', 'agents', `${name}.patch.yaml`);\n281\t\n282\t  // Check for custom agent (project-level full config, no extends)\n283\t  const projectCustomPath = join(cwd, '.codeharness', 'agents', `${name}.yaml`);\n284\t  const userCustomPath = join(os.homedir(), '.codeharness', 'agents', `${name}.yaml`);\n285\t\n286\t  // Try custom agent at project level first, then user level\n287\t  for (const customPath of [projectCustomPath, userCustomPath]) {\n288\t    if (existsSync(customPath)) {\n289\t      const patch = loadPatch(customPath);\n290\t      if (patch && !patch.extends) {\n291\t        // This is a full custom agent, not a patch — load and validate directly\n292\t        const parsed = patch as unknown as Record<string, unknown>;\n293\t        // Strip prompt_patches before schema validation (not in schema, same as patch path)\n294\t        const { prompt_patches: customPP, ...customForValidation } = parsed as Record<string, unknown> & { prompt_patches?: unknown };\n295\t        const result = validateAgentSchema(customForValidation);\n296\t        if (!result.valid) {\n297\t          const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n298\t          throw new AgentResolveError(\n299\t            `Schema validation failed for custom agent ${name}: ${details}`,\n300\t            customPath,\n301\t            result.errors.map((e) => ({ path: e.path, message: e.message })),\n302\t          );\n303\t        }\n304\t        return (customPP ? { ...customForValidation, prompt_patches: customPP } : customForValidation) as unknown as ResolvedAgent;\n305\t      }\n306\t    }\n307\t  }\n308\t\n309\t  // Load embedded base\n310\t  const base = loadEmbeddedAgent(name);\n311\t  let merged: Record<string, unknown> = base as unknown as Record<string, unknown>;\n312\t\n313\t  // Apply user patch\n314\t  const userPatch = loadPatch(userPatchPath);\n315\t  if (userPatch) {\n316\t    merged = mergePatch(merged, userPatch);\n317\t  }\n318\t\n319\t  // Apply project patch\n320\t  const projectPatch = loadPatch(projectPatchPath);\n321\t  if (projectPatch) {\n322\t    merged = mergePatch(merged, projectPatch);\n323\t  }\n324\t\n325\t  // Validate merged result (strip prompt_patches for schema validation since it's not in schema)\n326\t  const { prompt_patches, ...forValidation } = merged as Record<string, unknown> & { prompt_patches?: unknown };\n327\t  const result = validateAgentSchema(forValidation);\n328\t  if (!result.valid) {\n329\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n330\t    const errorPath = projectPatch ? projectPatchPath : userPatch ? userPatchPath : 'merged';\n331\t    throw new AgentResolveError(\n332\t      `Schema validation failed after merging patches for ${name}: ${details}`,\n333\t      errorPath,\n334\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n335\t    );\n336\t  }\n337\t\n338\t  // Re-attach prompt_patches if present, return without mutating forValidation\n339\t  return (prompt_patches\n340\t    ? { ...forValidation, prompt_patches }\n341\t    : forValidation) as unknown as ResolvedAgent;\n342\t}\n343\t\n344\t// --- Subagent Compilation ---\n345\t\n346\t/**\n347\t * Compile a ResolvedAgent into a SubagentDefinition for Agent SDK dispatch.\n348\t */\n349\texport function compileSubagentDefinition(agent: ResolvedAgent): SubagentDefinition {\n350\t  const parts: string[] = [];\n351\t\n352\t  parts.push(`You are ${agent.persona.identity}`);\n353\t  parts.push(`Communication style: ${agent.persona.communication_style}`);\n354\t\n355\t  if (agent.persona.principles.length > 0) {\n356\t    const bullets = agent.persona.principles.map((p) => `- ${p}`).join('\\n');\n357\t    parts.push(`Principles:\\n${bullets}`);\n358\t  }\n359\t\n360\t  if (agent.prompt_patches?.append) {\n361\t    parts.push(agent.prompt_patches.append);\n362\t  }\n363\t\n364\t  if (agent.prompt_template) {\n365\t    parts.push(agent.prompt_template);\n366\t  }\n367\t\n368\t  return {\n369\t    name: agent.name,\n370\t    model: DEFAULT_MODEL,\n371\t    instructions: parts.join('\\n\\n'),\n372\t    disallowedTools: agent.disallowedTools ?? [],\n373\t    ...(agent.plugins?.length ? { plugins: agent.plugins } : {}),\n374\t    bare: true,\n375\t  };\n376\t}\n377\t"}]},"parent_tool_use_id":"toolu_01G5iMphx15BhSxJAMrCWY69","session_id":"49777568-67d3-419d-b985-1c272283fc99","uuid":"a6f2056b-bd5b-4ac7-8923-2fe34b13fd72","timestamp":"2026-04-03T12:34:55.442Z"}
