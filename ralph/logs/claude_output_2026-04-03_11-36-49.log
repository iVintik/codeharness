();\n542\t\n543\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n544\t\n545\t    expect(mockRecordSessionId).toHaveBeenCalledWith(\n546\t      { taskName: 'implement', storyKey: '5-1-foo' },\n547\t      'sess-abc-123',\n548\t      expect.any(Object),\n549\t    );\n550\t  });\n551\t\n552\t  it('appends checkpoint manually when dispatch returns no sessionId', async () => {\n553\t    mockDriverDispatch.mockImplementation(() => makeDriverStream('ok', ''));\n554\t\n555\t    const task = makeTask();\n556\t    const definition = makeDefinition();\n557\t    const state = makeDefaultState();\n558\t    const config = makeConfig();\n559\t\n560\t    const result = await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n561\t\n562\t    // recordSessionId should NOT be called (empty string is falsy)\n563\t    expect(mockRecordSessionId).not.toHaveBeenCalled();\n564\t    // State should have a manually-created checkpoint\n565\t    const writtenState = mockWriteWorkflowState.mock.calls[0][0] as WorkflowState;\n566\t    expect(writtenState.tasks_completed).toHaveLength(1);\n567\t    expect(writtenState.tasks_completed[0].task_name).toBe('implement');\n568\t    expect(writtenState.tasks_completed[0].story_key).toBe('5-1-foo');\n569\t  });\n570\t\n571\t  it('cleans up workspace on dispatch error when source_access is false', async () => {\n572\t    const mockWorkspace = {\n573\t      dir: '/tmp/test',\n574\t      storyFilesDir: '/tmp/test/story-files',\n575\t      verdictDir: '/tmp/test/verdict',\n576\t      toDispatchOptions: () => ({ cwd: '/tmp/test' }),\n577\t      cleanup: vi.fn().mockResolvedValue(undefined),\n578\t    };\n579\t    mockCreateIsolatedWorkspace.mockResolvedValue(mockWorkspace);\n580\t    mockDriverDispatch.mockImplementation(() => makeDriverStreamError(new Error('dispatch failed')));\n581\t\n582\t    const task = makeTask({ source_access: false });\n583\t    const definition = makeDefinition();\n584\t    const