{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B7iEwcJE9gY3uJ5d46qLW5","type":"tool_result","content":"     1→import { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n     2→import { join } from 'node:path';\n     3→import { parse, stringify } from 'yaml';\n     4→import { warn } from './output.js';\n     5→import { detectStack, detectStacks, type StackName } from './stack-detect.js';\n     6→\n     7→export interface HarnessState {\n     8→  harness_version: string;\n     9→  initialized: boolean;\n    10→  stack: string | null;\n    11→  stacks: StackName[];\n    12→  app_type?: 'server' | 'cli' | 'web' | 'agent' | 'generic';\n    13→  enforcement: {\n    14→    frontend: boolean;\n    15→    database: boolean;\n    16→    api: boolean;\n    17→  };\n    18→  coverage: {\n    19→    target: number;\n    20→    baseline: number | null;\n    21→    current: number | null;\n    22→    tool: 'c8' | 'coverage.py' | 'cargo-tarpaulin' | 'unknown';\n    23→    /** Per-stack coverage tools map (stack name -> tool) for multi-stack projects */\n    24→    tools?: Record<string, string>;\n    25→  };\n    26→  session_flags: {\n    27→    logs_queried: boolean;\n    28→    tests_passed: boolean;\n    29→    coverage_met: boolean;\n    30→    verification_run: boolean;\n    31→  };\n    32→  verification_log: string[];\n    33→  otlp?: {\n    34→    enabled: boolean;\n    35→    endpoint: string;\n    36→    service_name: string;\n    37→    mode: 'local-shared' | 'remote-direct' | 'remote-routed';\n    38→    node_require?: string;\n    39→    python_wrapper?: string;\n    40→    cli_env_vars?: Record<string, string>;\n    41→    web_snippet_path?: string;\n    42→    resource_attributes?: string;\n    43→    agent_sdk?: string;\n    44→    rust_env_hint?: string;\n    45→  };\n    46→  retro_issue_targets?: Array<{ repo: string; labels: string[] }>;\n    47→  docker?: {\n    48→    compose_file: string;\n    49→    stack_running: boolean;\n    50→    remote_endpoints?: {\n    51→      logs_url?: string;\n    52→      metrics_url?: string;\n    53→      traces_url?: string;\n    54→    };\n    55→    ports: {\n    56→      logs: number;\n    57→      metrics: number;\n    58→      traces: number;\n    59→      otel_grpc: number;\n    60→      otel_http: number;\n    61→    };\n    62→  };\n    63→}\n    64→\n    65→function migrateState(state: HarnessState): HarnessState {\n    66→  const raw = state as Record<string, unknown>;\n    67→\n    68→  // New format: stacks array already present\n    69→  if (Array.isArray(raw.stacks) && raw.stacks.length > 0) {\n    70→    state.stacks = raw.stacks as StackName[];\n    71→    state.stack = state.stacks[0] ?? null;\n    72→    return state;\n    73→  }\n    74→\n    75→  // Old format: has stack string but no stacks array\n    76→  if (typeof raw.stack === 'string' && raw.stack) {\n    77→    state.stacks = [raw.stack as StackName];\n    78→    return state;\n    79→  }\n    80→\n    81→  // Neither present\n    82→  state.stacks = [];\n    83→  state.stack = null;\n    84→  return state;\n    85→}\n    86→\n    87→const STATE_DIR = '.claude';\n    88→const STATE_FILE = 'codeharness.local.md';\n    89→const DEFAULT_BODY = '\\n# Codeharness State\\n\\nThis file is managed by the codeharness CLI. Do not edit manually.\\n';\n    90→\n    91→export function getDefaultCoverageTool(stack?: string | null): HarnessState['coverage']['tool'] {\n    92→  if (stack === 'python') return 'coverage.py';\n    93→  if (stack === 'rust') return 'cargo-tarpaulin';\n    94→  return 'c8';\n    95→}\n    96→\n    97→export function getDefaultState(stack?: string | null): HarnessState {\n    98→  return {\n    99→    harness_version: '0.1.0',\n   100→    initialized: false,\n   101→    stack: stack ?? null,\n   102→    stacks: stack ? [stack as StackName] : [],\n   103→    enforcement: {\n   104→      frontend: true,\n   105→      database: true,\n   106→      api: true,\n   107→    },\n   108→    coverage: {\n   109→      target: 90,\n   110→      baseline: null,\n   111→      current: null,\n   112→      tool: getDefaultCoverageTool(stack),\n   113→    },\n   114→    session_flags: {\n   115→      logs_queried: false,\n   116→      tests_passed: false,\n   117→      coverage_met: false,\n   118→      verification_run: false,\n   119→    },\n   120→    verification_log: [],\n   121→  };\n   122→}\n   123→\n   124→export function getStatePath(dir: string): string {\n   125→  return join(dir, STATE_DIR, STATE_FILE);\n   126→}\n   127→\n   128→export function writeState(state: HarnessState, dir?: string, body?: string): void {\n   129→  const baseDir = dir ?? process.cwd();\n   130→  const claudeDir = join(baseDir, STATE_DIR);\n   131→  mkdirSync(claudeDir, { recursive: true });\n   132→\n   133→  // Sync stack from stacks[0] for backward compat (shallow copy to avoid mutating caller's object)\n   134→  const toWrite = { ...state };\n   135→  if (toWrite.stacks && toWrite.stacks.length > 0) {\n   136→    toWrite.stack = toWrite.stacks[0];\n   137→  }\n   138→\n   139→  const yamlContent = stringify(toWrite, { nullStr: 'null' });\n   140→  const markdownBody = body ?? DEFAULT_BODY;\n   141→  const fileContent = `---\\n${yamlContent}---\\n${markdownBody}`;\n   142→\n   143→  writeFileSync(join(claudeDir, STATE_FILE), fileContent, 'utf-8');\n   144→}\n   145→\n   146→export function readState(dir?: string): HarnessState {\n   147→  const baseDir = dir ?? process.cwd();\n   148→  const filePath = getStatePath(baseDir);\n   149→\n   150→  if (!existsSync(filePath)) {\n   151→    throw new StateFileNotFoundError();\n   152→  }\n   153→\n   154→  const raw = readFileSync(filePath, 'utf-8');\n   155→  const parts = raw.split('---');\n   156→\n   157→  // parts[0] is empty (before first ---), parts[1] is YAML, rest is body\n   158→  if (parts.length < 3) {\n   159→    return recoverCorruptedState(baseDir);\n   160→  }\n   161→\n   162→  try {\n   163→    const state = parse(parts[1]) as HarnessState;\n   164→    if (!isValidState(state)) {\n   165→      return recoverCorruptedState(baseDir);\n   166→    }\n   167→    return migrateState(state);\n   168→  } catch {\n   169→    return recoverCorruptedState(baseDir);\n   170→  }\n   171→}\n   172→\n   173→export function readStateWithBody(dir?: string): { state: HarnessState; body: string } {\n   174→  const baseDir = dir ?? process.cwd();\n   175→  const filePath = getStatePath(baseDir);\n   176→\n   177→  if (!existsSync(filePath)) {\n   178→    throw new StateFileNotFoundError();\n   179→  }\n   180→\n   181→  const raw = readFileSync(filePath, 'utf-8');\n   182→  const parts = raw.split('---');\n   183→\n   184→  if (parts.length < 3) {\n   185→    const state = recoverCorruptedState(baseDir);\n   186→    return { state, body: DEFAULT_BODY };\n   187→  }\n   188→\n   189→  try {\n   190→    const state = parse(parts[1]) as HarnessState;\n   191→    if (!isValidState(state)) {\n   192→      const recovered = recoverCorruptedState(baseDir);\n   193→      return { state: recovered, body: DEFAULT_BODY };\n   194→    }\n   195→    // Everything after the second --- is the body\n   196→    const body = parts.slice(2).join('---');\n   197→    return { state: migrateState(state), body: body || DEFAULT_BODY };\n   198→  } catch {\n   199→    const state = recoverCorruptedState(baseDir);\n   200→    return { state, body: DEFAULT_BODY };\n   201→  }\n   202→}\n   203→\n   204→function isValidState(state: unknown): state is HarnessState {\n   205→  if (!state || typeof state !== 'object') return false;\n   206→  const s = state as Record<string, unknown>;\n   207→  if (typeof s.harness_version !== 'string') return false;\n   208→  if (typeof s.initialized !== 'boolean') return false;\n   209→  if (s.stack !== null && typeof s.stack !== 'string') return false;\n   210→  if (!s.enforcement || typeof s.enforcement !== 'object') return false;\n   211→  if (!s.coverage || typeof s.coverage !== 'object') return false;\n   212→  if (!s.session_flags || typeof s.session_flags !== 'object') return false;\n   213→  if (!Array.isArray(s.verification_log)) return false;\n   214→  // Accept old format (no stacks) and new format (stacks is array of strings)\n   215→  if (s.stacks !== undefined && !Array.isArray(s.stacks)) return false;\n   216→  if (Array.isArray(s.stacks) && s.stacks.some((v: unknown) => typeof v !== 'string')) return false;\n   217→  return true;\n   218→}\n   219→\n   220→function recoverCorruptedState(dir: string): HarnessState {\n   221→  warn('State file corrupted — recreating from detected config');\n   222→  const stack = detectStack(dir);\n   223→  const allStacks = detectStacks(dir);\n   224→  const state = getDefaultState(stack);\n   225→  // Dedupe: detectStacks may return same stack from multiple dirs\n   226→  const uniqueStackNames = [...new Set(allStacks.map(s => s.stack))];\n   227→  state.stacks = uniqueStackNames;\n   228→  // Sync stack from stacks[0] if stacks were detected but root stack was null\n   229→  if (state.stack === null && uniqueStackNames.length > 0) {\n   230→    state.stack = uniqueStackNames[0];\n   231→  }\n   232→  writeState(state, dir);\n   233→  return state;\n   234→}\n   235→\n   236→export class StateFileNotFoundError extends Error {\n   237→  constructor() {\n   238→    super('No state file found. Run \\'codeharness init\\' first.');\n   239→    this.name = 'StateFileNotFoundError';\n   240→  }\n   241→}\n   242→\n   243→const DANGEROUS_KEYS = new Set(['__proto__', 'constructor', 'prototype']);\n   244→\n   245→function validateKeyPath(keyPath: string): void {\n   246→  const keys = keyPath.split('.');\n   247→  for (const key of keys) {\n   248→    if (DANGEROUS_KEYS.has(key)) {\n   249→      throw new Error(`Invalid key path: '${key}' is not allowed`);\n   250→    }\n   251→  }\n   252→}\n   253→\n   254→export function getNestedValue(obj: Record<string, unknown>, keyPath: string): unknown {\n   255→  validateKeyPath(keyPath);\n   256→  const keys = keyPath.split('.');\n   257→  let current: unknown = obj;\n   258→  for (const key of keys) {\n   259→    if (current === null || current === undefined || typeof current !== 'object') {\n   260→      return undefined;\n   261→    }\n   262→    current = (current as Record<string, unknown>)[key];\n   263→  }\n   264→  return current;\n   265→}\n   266→\n   267→export function setNestedValue(obj: Record<string, unknown>, keyPath: string, value: unknown): void {\n   268→  validateKeyPath(keyPath);\n   269→  const keys = keyPath.split('.');\n   270→  let current: Record<string, unknown> = obj;\n   271→  for (let i = 0; i < keys.length - 1; i++) {\n   272→    const key = keys[i];\n   273→    if (current[key] === undefined || current[key] === null || typeof current[key] !== 'object') {\n   274→      current[key] = {};\n   275→    }\n   276→    current = current[key] as Record<string, unknown>;\n   277→  }\n   278→  current[keys[keys.length - 1]] = value;\n   279→}\n   280→\n   281→export function parseValue(raw: string): unknown {\n   282→  if (raw === 'true') return true;\n   283→  if (raw === 'false') return false;\n   284→  if (raw === 'null') return null;\n   285→  const num = Number(raw);\n   286→  if (!Number.isNaN(num) && raw.trim() !== '') return num;\n   287→  return raw;\n   288→}\n   289→"}]},"parent_tool_use_id":"toolu_01M6iq2XVtx8hbFMRevefAGh","session_id":"01d3be87-3cff-45e1-920c-7390a9e4093c","uuid":"a0e833bf-ac44-4cf8-be7e-dd0aa38f0120","timestamp":"2026-03-24T09:42:59.887Z"}
