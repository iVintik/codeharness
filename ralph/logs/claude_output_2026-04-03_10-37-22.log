{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Mp9nk1Qa9N5y6u7b31JWYe","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { getDriver } from '../index.js';\n3\t\n4\tdescribe('getDriver()', () => {\n5\t  // Ralph driver removed (Story 1.2) — getDriver now throws for all names.\n6\t  // Workflow engine driver will be added in Epic 5.\n7\t\n8\t  it('throws for default driver (no drivers available)', () => {\n9\t    expect(() => getDriver()).toThrow('No agent drivers available');\n10\t  });\n11\t\n12\t  it('throws for explicit ralph driver name', () => {\n13\t    expect(() => getDriver('ralph')).toThrow('No agent drivers available');\n14\t  });\n15\t\n16\t  it('throws for unknown driver names', () => {\n17\t    expect(() => getDriver('unknown-agent')).toThrow('No agent drivers available');\n18\t  });\n19\t\n20\t  it('includes requested driver name in error message', () => {\n21\t    expect(() => getDriver('gpt-pilot')).toThrow('gpt-pilot');\n22\t  });\n23\t});\n24\t"}]},"parent_tool_use_id":"toolu_01TCd6uEz5D6YETUWqShfUU7","session_id":"61d40628-eabe-45b5-b544-2f5989944a22","uuid":"8561beee-e609-4434-b44f-32c02e101bae","timestamp":"2026-04-03T06:42:03.674Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TMEzAz9F2HH9Z3wfDuybV6","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { Readable } from 'node:stream';\n3\timport type {\n4\t  AgentDriver,\n5\t  DispatchOpts,\n6\t  DriverHealth,\n7\t  DriverCapabilities,\n8\t  ErrorCategory,\n9\t  OutputContract,\n10\t  TestResults,\n11\t  ACStatus,\n12\t  // Deprecated types — must still compile\n13\t  AgentProcess,\n14\t  AgentEvent,\n15\t  SpawnOpts,\n16\t} from '../types.js';\n17\timport type { StreamEvent, ResultEvent } from '../stream-parser.js';\n18\timport type {\n19\t  // Barrel re-exports — new types\n20\t  AgentDriver as BarrelAgentDriver,\n21\t  DriverHealth as BarrelDriverHealth,\n22\t  DriverCapabilities as BarrelDriverCapabilities,\n23\t  DispatchOpts as BarrelDispatchOpts,\n24\t  ErrorCategory as BarrelErrorCategory,\n25\t  OutputContract as BarrelOutputContract,\n26\t  TestResults as BarrelTestResults,\n27\t  ACStatus as BarrelACStatus,\n28\t  // Barrel re-exports — deprecated types\n29\t  AgentProcess as BarrelAgentProcess,\n30\t  AgentEvent as BarrelAgentEvent,\n31\t  SpawnOpts as BarrelSpawnOpts,\n32\t} from '../index.js';\n33\t\n34\t// --- Helpers ---\n35\t\n36\t/** Creates a mock AgentDriver implementing the new interface. */\n37\tfunction createMockDriver(): AgentDriver {\n38\t  return {\n39\t    name: 'mock-driver',\n40\t    defaultModel: 'mock-model-v1',\n41\t    capabilities: {\n42\t      supportsPlugins: true,\n43\t      supportsStreaming: true,\n44\t      costReporting: true,\n45\t    },\n46\t    async healthCheck(): Promise<DriverHealth> {\n47\t      return { available: true, authenticated: true, version: '1.0.0' };\n48\t    },\n49\t    async *dispatch(_opts: DispatchOpts): AsyncIterable<StreamEvent> {\n50\t      yield { type: 'text', text: 'hello' };\n51\t      yield { type: 'result', cost: 0.01, sessionId: 'mock-session' };\n52\t    },\n53\t    getLastCost(): number | null {\n54\t      return 0.01;\n55\t    },\n56\t  };\n57\t}\n58\t\n59\t/** Creates a minimal mock AgentProcess for deprecated type tests. */\n60\tfunction createMockProcess(): AgentProcess {\n61\t  const handlers: Record<string, Function> = {};\n62\t  return {\n63\t    stdout: new Readable({ read() {} }),\n64\t    stderr: new Readable({ read() {} }),\n65\t    on(event: string, handler: Function) {\n66\t      handlers[event] = handler;\n67\t    },\n68\t    kill() {},\n69\t  };\n70\t}\n71\t\n72\t// --- New Interface Tests ---\n73\t\n74\tdescribe('agents/types — new AgentDriver interface (Epic 10)', () => {\n75\t  describe('AgentDriver interface', () => {\n76\t    it('satisfies interface with mock implementation', () => {\n77\t      const driver = createMockDriver();\n78\t      expect(driver.name).toBe('mock-driver');\n79\t      expect(driver.defaultModel).toBe('mock-model-v1');\n80\t      expect(driver.capabilities).toBeDefined();\n81\t      expect(typeof driver.healthCheck).toBe('function');\n82\t      expect(typeof driver.dispatch).toBe('function');\n83\t      expect(typeof driver.getLastCost).toBe('function');\n84\t    });\n85\t\n86\t    it('has readonly name and defaultModel', () => {\n87\t      const driver = createMockDriver();\n88\t      expect(driver.name).toBe('mock-driver');\n89\t      expect(driver.defaultModel).toBe('mock-model-v1');\n90\t    });\n91\t\n92\t    it('has readonly capabilities', () => {\n93\t      const driver = createMockDriver();\n94\t      expect(driver.capabilities.supportsPlugins).toBe(true);\n95\t      expect(driver.capabilities.supportsStreaming).toBe(true);\n96\t      expect(driver.capabilities.costReporting).toBe(true);\n97\t    });\n98\t\n99\t    it('healthCheck returns Promise<DriverHealth>', async () => {\n100\t      const driver = createMockDriver();\n101\t      const health = await driver.healthCheck();\n102\t      expect(health.available).toBe(true);\n103\t      expect(health.authenticated).toBe(true);\n104\t      expect(health.version).toBe('1.0.0');\n105\t    });\n106\t\n107\t    it('dispatch returns AsyncIterable<StreamEvent>', async () => {\n108\t      const driver = createMockDriver();\n109\t      const opts: DispatchOpts = {\n110\t        prompt: 'test',\n111\t        model: 'mock-model-v1',\n112\t        cwd: '/tmp',\n113\t        sourceAccess: true,\n114\t      };\n115\t      const events: StreamEvent[] = [];\n116\t      for await (const event of driver.dispatch(opts)) {\n117\t        events.push(event);\n118\t      }\n119\t      expect(events).toHaveLength(2);\n120\t      expect(events[0].type).toBe('text');\n121\t      expect(events[1].type).toBe('result');\n122\t    });\n123\t\n124\t    it('getLastCost returns number or null', () => {\n125\t      const driver = createMockDriver();\n126\t      const cost = driver.getLastCost();\n127\t      expect(cost).toBe(0.01);\n128\t    });\n129\t\n130\t    it('getLastCost can return null', () => {\n131\t      const driver: AgentDriver = {\n132\t        ...createMockDriver(),\n133\t        getLastCost: () => null,\n134\t      };\n135\t      expect(driver.getLastCost()).toBeNull();\n136\t    });\n137\t  });\n138\t\n139\t  describe('DispatchOpts', () => {\n140\t    it('accepts all required fields', () => {\n141\t      const opts: DispatchOpts = {\n142\t        prompt: 'implement story',\n143\t        model: 'claude-sonnet-4-20250514',\n144\t        cwd: '/home/project',\n145\t        sourceAccess: true,\n146\t      };\n147\t      expect(opts.prompt).toBe('implement story');\n148\t      expect(opts.model).toBe('claude-sonnet-4-20250514');\n149\t      expect(opts.cwd).toBe('/home/project');\n150\t      expect(opts.sourceAccess).toBe(true);\n151\t    });\n152\t\n153\t    it('accepts all optional fields', () => {\n154\t      const contract: OutputContract = {\n155\t        version: 1,\n156\t        taskName: 'implement',\n157\t        storyId: '10-1',\n158\t        driver: 'claude-code',\n159\t        model: 'claude-sonnet-4-20250514',\n160\t        timestamp: '2026-04-03T10:00:00Z',\n161\t        cost_usd: null,\n162\t        duration_ms: 0,\n163\t        changedFiles: [],\n164\t        testResults: null,\n165\t        output: '',\n166\t        acceptanceCriteria: [],\n167\t      };\n168\t      const opts: DispatchOpts = {\n169\t        prompt: 'test',\n170\t        model: 'model',\n171\t        cwd: '/tmp',\n172\t        sourceAccess: false,\n173\t        plugins: ['plugin-a', 'plugin-b'],\n174\t        timeout: 30000,\n175\t        outputContract: contract,\n176\t      };\n177\t      expect(opts.plugins).toEqual(['plugin-a', 'plugin-b']);\n178\t      expect(opts.timeout).toBe(30000);\n179\t      expect(opts.outputContract).toBeDefined();\n180\t    });\n181\t\n182\t    it('optional fields are undefined when not provided', () => {\n183\t      const opts: DispatchOpts = {\n184\t        prompt: 'x',\n185\t        model: 'm',\n186\t        cwd: '/',\n187\t        sourceAccess: false,\n188\t      };\n189\t      expect(opts.plugins).toBeUndefined();\n190\t      expect(opts.timeout).toBeUndefined();\n191\t      expect(opts.outputContract).toBeUndefined();\n192\t    });\n193\t  });\n194\t\n195\t  describe('DriverHealth', () => {\n196\t    it('accepts a healthy status', () => {\n197\t      const health: DriverHealth = {\n198\t        available: true,\n199\t        authenticated: true,\n200\t        version: '2.1.0',\n201\t      };\n202\t      expect(health.available).toBe(true);\n203\t      expect(health.authenticated).toBe(true);\n204\t      expect(health.version).toBe('2.1.0');\n205\t      expect(health.error).toBeUndefined();\n206\t    });\n207\t\n208\t    it('accepts an unhealthy status with error', () => {\n209\t      const health: DriverHealth = {\n210\t        available: false,\n211\t        authenticated: false,\n212\t        version: null,\n213\t        error: 'CLI not found on PATH',\n214\t      };\n215\t      expect(health.available).toBe(false);\n216\t      expect(health.version).toBeNull();\n217\t      expect(health.error).toBe('CLI not found on PATH');\n218\t    });\n219\t\n220\t    it('error field is optional', () => {\n221\t      const health: DriverHealth = {\n222\t        available: true,\n223\t        authenticated: true,\n224\t        version: '1.0.0',\n225\t      };\n226\t      expect(health.error).toBeUndefined();\n227\t    });\n228\t  });\n229\t\n230\t  describe('DriverCapabilities', () => {\n231\t    it('accepts capability flags', () => {\n232\t      const caps: DriverCapabilities = {\n233\t        supportsPlugins: true,\n234\t        supportsStreaming: false,\n235\t        costReporting: true,\n236\t      };\n237\t      expect(caps.supportsPlugins).toBe(true);\n238\t      expect(caps.supportsStreaming).toBe(false);\n239\t      expect(caps.costReporting).toBe(true);\n240\t    });\n241\t\n242\t    it('all-false capabilities are valid', () => {\n243\t      const caps: DriverCapabilities = {\n244\t        supportsPlugins: false,\n245\t        supportsStreaming: false,\n246\t        costReporting: false,\n247\t      };\n248\t      expect(caps.supportsPlugins).toBe(false);\n249\t      expect(caps.supportsStreaming).toBe(false);\n250\t      expect(caps.costReporting).toBe(false);\n251\t    });\n252\t  });\n253\t\n254\t  describe('ErrorCategory', () => {\n255\t    it('covers exactly 5 values', () => {\n256\t      const categories: ErrorCategory[] = [\n257\t        'RATE_LIMIT',\n258\t        'NETWORK',\n259\t        'AUTH',\n260\t        'TIMEOUT',\n261\t        'UNKNOWN',\n262\t      ];\n263\t      expect(categories).toHaveLength(5);\n264\t      // Verify each is a valid ErrorCategory (compile-time check)\n265\t      categories.forEach((cat) => {\n266\t        expect(typeof cat).toBe('string');\n267\t      });\n268\t    });\n269\t\n270\t    it('each value is assignable to ErrorCategory', () => {\n271\t      const a: ErrorCategory = 'RATE_LIMIT';\n272\t      const b: ErrorCategory = 'NETWORK';\n273\t      const c: ErrorCategory = 'AUTH';\n274\t      const d: ErrorCategory = 'TIMEOUT';\n275\t      const e: ErrorCategory = 'UNKNOWN';\n276\t      expect([a, b, c, d, e]).toEqual([\n277\t        'RATE_LIMIT',\n278\t        'NETWORK',\n279\t        'AUTH',\n280\t        'TIMEOUT',\n281\t        'UNKNOWN',\n282\t      ]);\n283\t    });\n284\t\n285\t    it('exhaustiveness check — switch covers all categories', () => {\n286\t      // Compile-time exhaustiveness: if ErrorCategory gains a 6th value,\n287\t      // the `never` default will cause a TS error\n288\t      function classifyError(cat: ErrorCategory): string {\n289\t        switch (cat) {\n290\t          case 'RATE_LIMIT': return 'retry';\n291\t          case 'NETWORK': return 'retry';\n292\t          case 'AUTH': return 'fail';\n293\t          case 'TIMEOUT': return 'fail';\n294\t          case 'UNKNOWN': return 'fail';\n295\t          default: {\n296\t            const _exhaustive: never = cat;\n297\t            return _exhaustive;\n298\t          }\n299\t        }\n300\t      }\n301\t      expect(classifyError('RATE_LIMIT')).toBe('retry');\n302\t      expect(classifyError('NETWORK')).toBe('retry');\n303\t      expect(classifyError('AUTH')).toBe('fail');\n304\t      expect(classifyError('TIMEOUT')).toBe('fail');\n305\t      expect(classifyError('UNKNOWN')).toBe('fail');\n306\t    });\n307\t  });\n308\t\n309\t  describe('OutputContract, TestResults, ACStatus', () => {\n310\t    it('accepts a valid OutputContract', () => {\n311\t      const contract: OutputContract = {\n312\t        version: 1,\n313\t        taskName: 'implement-story',\n314\t        storyId: '10-1',\n315\t        driver: 'claude-code',\n316\t        model: 'claude-sonnet-4-20250514',\n317\t        timestamp: '2026-04-03T12:00:00Z',\n318\t        cost_usd: 0.42,\n319\t        duration_ms: 15000,\n320\t        changedFiles: ['src/lib/agents/types.ts'],\n321\t        testResults: { passed: 10, failed: 0, coverage: 95.5 },\n322\t        output: 'Implementation complete',\n323\t        acceptanceCriteria: [\n324\t       