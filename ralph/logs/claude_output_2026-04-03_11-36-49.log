{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011JQYLengbnUvXvTY7gjUb6","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { parse } from 'yaml';\n3\timport { warn } from './output.js';\n4\timport { dispatchAgent, DispatchError } from './agent-dispatch.js';\n5\timport type { DispatchOptions, DispatchResult } from './agent-dispatch.js';\n6\timport type { SubagentDefinition } from './agent-resolver.js';\n7\timport type { ResolvedWorkflow, ResolvedTask, FlowStep, LoopBlock } from './workflow-parser.js';\n8\timport {\n9\t  readWorkflowState,\n10\t  writeWorkflowState,\n11\t} from './workflow-state.js';\n12\timport type { WorkflowState, TaskCheckpoint } from './workflow-state.js';\n13\timport { createIsolatedWorkspace } from './source-isolation.js';\n14\timport { generateTraceId, formatTracePrompt, recordTraceId } from './trace-id.js';\n15\timport { resolveSessionId, recordSessionId } from './session-manager.js';\n16\timport type { SessionLookupKey } from './session-manager.js';\n17\timport { parseVerdict, VerdictParseError } from './verdict-parser.js';\n18\timport type { EvaluatorVerdict } from './verdict-parser.js';\n19\timport { evaluateProgress } from './circuit-breaker.js';\n20\t\n21\t// Re-export EvaluatorVerdict for downstream consumers that import from workflow-engine\n22\texport type { EvaluatorVerdict } from './verdict-parser.js';\n23\texport { parseVerdict } from './verdict-parser.js';\n24\t\n25\t// --- Interfaces ---\n26\t\n27\t/**\n28\t * Configuration for the workflow engine.\n29\t */\n30\texport interface EngineConfig {\n31\t  /** The resolved workflow with tasks and flow steps. */\n32\t  workflow: ResolvedWorkflow;\n33\t  /** Pre-compiled agent definitions keyed by agent name. */\n34\t  agents: Record<string, SubagentDefinition>;\n35\t  /** Path to sprint-status.yaml for work item discovery. */\n36\t  sprintStatusPath: string;\n37\t  /** Optional path to issues.yaml for additional work items. */\n38\t  issuesPath?: string;\n39\t  /** Unique identifier for this engine run. */\n40\t  runId: string;\n41\t  /** Project root directory. Defaults to process.cwd(). */\n42\t  projectDir?: string;\n43\t  /** Maximum loop iterations before termination. Defaults to 5. */\n44\t  maxIterations?: number;\n45\t}\n46\t\n47\t/**\n48\t * Result returned by executeWorkflow().\n49\t */\n50\texport interface EngineResult {\n51\t  /** Whether the workflow completed without errors. */\n52\t  success: boolean;\n53\t  /** Number of task dispatches completed. */\n54\t  tasksCompleted: number;\n55\t  /** Number of work items (stories/issues) processed. */\n56\t  storiesProcessed: number;\n57\t  /** Errors encountered during execution. */\n58\t  errors: EngineError[];\n59\t  /** Wall-clock duration of the entire workflow in milliseconds. */\n60\t  durationMs: number;\n61\t}\n62\t\n63\t/**\n64\t * Structured error recorded during workflow execution.\n65\t */\n66\texport interface EngineError {\n67\t  taskName: string;\n68\t  storyKey: string;\n69\t  code: string;\n70\t  message: string;\n71\t}\n72\t\n73\t/**\n74\t * A work item (story or issue) ready for execution.\n75\t */\n76\texport interface WorkItem {\n77\t  key: string;\n78\t  title?: string;\n79\t  source: 'sprint' | 'issues';\n80\t}\n81\t\n82\t// --- Constants ---\n83\t\n84\t/** Sentinel story key for per-run tasks. */\n85\texport const PER_RUN_SENTINEL = '__run__';\n86\t\n87\t/** DispatchError codes that should halt execution immediately. */\n88\tconst HALT_ERROR_CODES = new Set(['RATE_LIMIT', 'NETWORK', 'SDK_INIT']);\n89\t\n90\t/** Default maximum loop iterations before termination. */\n91\tconst DEFAULT_MAX_ITERATIONS = 5;\n92\t\n93\t// --- Crash Recovery: Task Completion Check ---\n94\t\n95\t/**\n96\t * Check whether a (taskName, storyKey) combination is already recorded\n97\t * in the workflow state's tasks_completed array.\n98\t *\n99\t * Both fields must match for the task to be considered completed.\n100\t * Used by the resume logic to skip already-completed dispatches.\n101\t */\n102\texport function isTaskCompleted(\n103\t  state: WorkflowState,\n104\t  taskName: string,\n105\t  storyKey: string,\n106\t): boolean {\n107\t  return state.tasks_completed.some(\n108\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey && !cp.error,\n109\t  );\n110\t}\n111\t\n112\t/**\n113\t * Check whether a (taskName, storyKey) combination has been completed\n114\t * enough times to cover the current iteration in a loop block.\n115\t *\n116\t * Loop tasks execute the same (taskName, storyKey) pair each iteration,\n117\t * recording a new checkpoint each time. To determine if a task is done\n118\t * for the current iteration, we count how many matching checkpoints exist\n119\t * and compare to the current iteration number.\n120\t */\n121\texport function isLoopTaskCompleted(\n122\t  state: WorkflowState,\n123\t  taskName: string,\n124\t  storyKey: string,\n125\t  iteration: number,\n126\t): boolean {\n127\t  const count = state.tasks_completed.filter(\n128\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey && !cp.error,\n129\t  ).length;\n130\t  return count >= iteration;\n131\t}\n132\t\n133\t// --- Work Item Loading ---\n134\t\n135\t/**\n136\t * Load work items from sprint-status.yaml and optionally issues.yaml.\n137\t *\n138\t * Stories are extracted from the `development_status` section of sprint-status.yaml.\n139\t * Issues are extracted from the `issues` array of issues.yaml.\n140\t *\n141\t * Only items with status `backlog` or `ready-for-dev` are included.\n142\t * Epic keys (`epic-*`) and retrospective keys (`*-retrospective`) are excluded.\n143\t *\n144\t * If issues.yaml does not exist, returns only stories (no error).\n145\t */\n146\texport function loadWorkItems(sprintStatusPath: string, issuesPath?: string): WorkItem[] {\n147\t  const items: WorkItem[] = [];\n148\t\n149\t  // --- Load stories from sprint-status.yaml ---\n150\t  if (existsSync(sprintStatusPath)) {\n151\t    let raw: string;\n152\t    try {\n153\t      raw = readFileSync(sprintStatusPath, 'utf-8');\n154\t    } catch { // IGNORE: unreadable file — warn and return empty\n155\t      warn(`workflow-engine: could not read sprint-status.yaml at ${sprintStatusPath}`);\n156\t      return items;\n157\t    }\n158\t\n159\t    let parsed: unknown;\n160\t    try {\n161\t      parsed = parse(raw);\n162\t    } catch { // IGNORE: malformed YAML — warn and return empty\n163\t      warn(`workflow-engine: invalid YAML in sprint-status.yaml at ${sprintStatusPath}`);\n164\t      return items;\n165\t    }\n166\t\n167\t    if (parsed && typeof parsed === 'object') {\n168\t      const data = parsed as Record<string, unknown>;\n169\t      const devStatus = data.development_status as Record<string, unknown> | undefined;\n170\t\n171\t      if (devStatus && typeof devStatus === 'object') {\n172\t        for (const [key, status] of Object.entries(devStatus)) {\n173\t          // Skip epic keys and retrospective keys\n174\t          if (key.startsWith('epic-')) continue;\n175\t          if (key.endsWith('-retrospective')) continue;\n176\t\n177\t          // Only include backlog or ready-for-dev\n178\t          if (status === 'backlog' || status === 'ready-for-dev') {\n179\t            items.push({ key, source: 'sprint' });\n180\t          }\n181\t        }\n182\t      }\n183\t    }\n184\t  }\n185\t\n186\t  // --- Load issues from issues.yaml ---\n187\t  if (issuesPath && existsSync(issuesPath)) {\n188\t    let raw: string;\n189\t    try {\n190\t      raw = readFileSync(issuesPath, 'utf-8');\n191\t    } catch { // IGNORE: unreadable issues file — warn and return what we have\n192\t      warn(`workflow-engine: could not read issues.yaml at ${issuesPath}`);\n193\t      return items;\n194\t    }\n195\t\n196\t    let parsed: unknown;\n197\t    try {\n198\t      parsed = parse(raw);\n199\t    } catch { // IGNORE: malformed issues YAML — warn and return what we have\n200\t      warn(`workflow-engine: invalid YAML in issues.yaml at ${issuesPath}`);\n201\t      return items;\n202\t    }\n203\t\n204\t    if (parsed && typeof parsed === 'object') {\n205\t      const data = parsed as Record<string, unknown>;\n206\t      const issuesList = data.issues as Array<Record<string, unknown>> | undefined;\n207\t\n208\t      if (Array.isArray(issuesList)) {\n209\t        for (const issue of issuesList) {\n210\t          if (issue && typeof issue === 'object') {\n211\t            const status = issue.status as string | undefined;\n212\t            if (status === 'backlog' || status === 'ready-for-dev') {\n213\t              items.push({\n214\t                key: issue.id as string,\n215\t                title: issue.title as string | undefined,\n216\t                source: 'issues',\n217\t              });\n218\t            }\n219\t          }\n220\t        }\n221\t      }\n222\t    }\n223\t  }\n224\t\n225\t  return items;\n226\t}\n227\t\n228\t// --- Single Task Dispatch ---\n229\t\n230\t/**\n231\t * Dispatch a single task for a specific work item (or per-run sentinel).\n232\t *\n233\t * Handles: trace ID generation, session resolution, source isolation,\n234\t * agent dispatch, state checkpointing, and cleanup.\n235\t *\n236\t * Returns the updated workflow state after recording the dispatch.\n237\t */\n238\texport async function dispatchTask(\n239\t  task: ResolvedTask,\n240\t  taskName: string,\n241\t  storyKey: string,\n242\t  definition: SubagentDefinition,\n243\t  state: WorkflowState,\n244\t  config: EngineConfig,\n245\t  customPrompt?: string,\n246\t): Promise<WorkflowState> {\n247\t  const { updatedState } = await dispatchTaskWithResult(\n248\t    task, taskName, storyKey, definition, state, config, customPrompt,\n249\t  );\n250\t  return updatedState;\n251\t}\n252\t\n253\t// --- Flow Step Type Guard ---\n254\t\n255\tfunction isLoopBlock(step: FlowStep): step is LoopBlock {\n256\t  return typeof step === 'object' && step !== null && 'loop' in step;\n257\t}\n258\t\n259\t// --- Core Dispatch (shared by dispatchTask and loop block execution) ---\n260\t\n261\t/**\n262\t * Dispatch a task and return both the updated state and the raw dispatch output.\n263\t * This is the single implementation of task dispatch logic. Both `dispatchTask()`\n264\t * and loop block execution delegate here.\n265\t */\n266\tasync function dispatchTaskWithResult(\n267\t  task: ResolvedTask,\n268\t  taskName: string,\n269\t  storyKey: string,\n270\t  definition: SubagentDefinition,\n271\t  state: WorkflowState,\n272\t  config: EngineConfig,\n273\t  customPrompt?: string,\n274\t): Promise<{ updatedState: WorkflowState; output: string }> {\n275\t  const projectDir = config.projectDir ?? process.cwd();\n276\t\n277\t  // 1. Generate trace ID\n278\t  const traceId = generateTraceId(config.runId, state.iteration, taskName);\n279\t\n280\t  // 2. Format trace prompt\n281\t  const tracePrompt = formatTracePrompt(traceId);\n282\t\n283\t  // 3. Resolve session ID\n284\t  const sessionKey: SessionLookupKey = { taskName, storyKey };\n285\t  const sessionId = resolveSessionId(task.session, sessionKey, state);\n286\t\n287\t  // 4. Build dispatch options based on source_access\n288\t  let dispatchOptions: DispatchOptions;\n289\t  let workspace: Awaited<ReturnType<typeof createIsolatedWorkspace>> | null = null;\n290\t\n291\t  if (task.source_access === false) {\n292\t    workspace = await createIsolatedWorkspace({ runId: config.runId, storyFiles: [] });\n293\t    dispatchOptions = {\n294\t      ...workspace.toDispatchOptions(),\n295\t      sessionId,\n296\t      appendSystemPrompt: tracePrompt,\n297\t    };\n298\t  } else {\n299\t    dispatchOptions = {\n300\t      cwd: projectDir,\n301\t      sessionId,\n302\t      appendSystemPrompt: tracePrompt,\n303\t    };\n304\t  }\n305\t\n306\t  // 5. Construct prompt\n307\t  const prompt = customPrompt\n308\t    ?? (storyKey === PER_RUN_SENTINEL\n309\t      ? `Execute task \"${taskName}\" for the current run.`\n310\t      : `Implement story ${storyKey}`);\n311\t\n312\t  // 6. Dispatch agent\n313\t  let result: DispatchResult;\n314\t  try {\n315\t    result = await dispatchAgent(definition, prompt, dispatchOptions);\n316\t  } finally {\n317\t    // Cleanup workspace regardless of dispatch success/failure\n318\t    if (workspace) {\n319\t      await workspace.cleanup();\n320\t    }\n321\t  }\n322\t\n323\t  // 7. Record session ID (if dispatch returned one)\n324\t  let updatedState = state;\n325\t  if (result.sessionId) {\n326\t    updatedState = recordSessionId(sessionKey, result.sessionId, updatedState);\n327\t  } else {\n328\t    // Append checkpoint manually when no session ID is returned\n329\t    const checkpoint: TaskCheckpoint = {\n330\t      task_name: taskName,\n331\t      story_key: storyKey,\n332\t      completed_at: new Date().toISOString(),\n333\t    };\n334\t    updatedState = {\n335\t      ...updatedState,\n336\t      tasks_completed: [...updatedState.tasks_completed, checkpoint],\n337\t    };\n338\t  }\n339\t\n340\t  // 8. Record trace ID\n341\t  updatedState = recordTraceId(traceId, updatedState);\n342\t\n343\t  // 9. Write state to disk\n344\t  writeWorkflowState(updatedState, projectDir);\n345\t\n346\t  return { updatedState, output: result.output };\n347\t}\n348\t\n349\t// --- Retry Prompt Construction (Task 3) ---\n350\t\n351\t/**\n352\t * Build a retry prompt with evaluator findings injected.\n353\t * Includes only failed/unknown findings.\n354\t */\n355\texport function buildRetryPrompt(storyKey: string, findings: EvaluatorVerdict['findings']): string {\n356\t  const failedFindings = findings.filter(\n357\t    (f) => f.status === 'fail' || f.status === 'unknown',\n358\t  );\n359\t\n360\t  if (failedFindings.length === 0) {\n361\t    return `Implement story ${storyKey}`;\n362\t  }\n363\t\n364\t  const formattedFindings = failedFindings\n365\t    .map((f) => {\n366\t      const status = f.status.toUpperCase();\n367\t      let entry = `AC #${f.ac} (${status}): ${f.description}`;\n368\t      if (f.evidence?.reasoning) {\n369\t        entry += `\\n  Evidence: ${f.evidence.reasoning}`;\n370\t      }\n371\t      return entry;\n372\t    })\n373\t    .join('\\n\\n');\n374\t\n375\t  return `Retry story ${storyKey}. Previous evaluator findings:\\n\\n${formattedFindings}\\n\\nFocus on fixing the failed criteria above.`;\n376\t}\n377\t\n378\t// --- All-UNKNOWN Verdict Builder ---\n379\t\n380\t/**\n381\t * Build an all-UNKNOWN EvaluatorVerdict as fallback when the evaluator\n382\t * fails to produce valid JSON after retry.\n383\t */\n384\texport function buildAllUnknownVerdict(\n385\t  workItems: WorkItem[],\n386\t  reasoning: string,\n387\t): EvaluatorVerdict {\n388\t  const findings = workItems.map((_, index) => ({\n389\t    ac: index + 1,\n390\t    description: `AC #${index + 1}`,\n391\t    status: 'unknown' as const,\n392\t    evidence: {\n393\t      commands_run: [] as string[],\n394\t      output_observed: '',\n395\t      reasoning,\n396\t    },\n397\t  }));\n398\t\n399\t  return {\n400\t    verdict: 'fail',\n401\t    score: {\n402\t      passed: 0,\n403\t      failed: 0,\n404\t      unknown: findings.length,\n405\t      total: findings.length,\n406\t    },\n407\t    findings,\n408\t  };\n409\t}\n410\t\n411\t// --- Failed Story Filtering (Task 4) ---\n412\t\n413\t/**\n414\t * Determine which work items failed based on evaluator findings.\n415\t * If verdict is null (parse failure), returns all items (conservative fallback).\n416\t */\n417\texport function getFailedItems(\n418\t  verdict: EvaluatorVerdict | null,\n419\t  allItems: WorkItem[],\n420\t): WorkItem[] {\n421\t  if (!verdict) return allItems;\n422\t\n423\t  // If verdict passed, no items need retry\n424\t  if (verdict.verdict === 'pass') return [];\n425\t\n426\t  // All items are retried on failure — per-story filtering based on individual\n427\t  // story results is not possible with the current verdict shape (verdict is per-run).\n428\t  // The findings track ACs, not stories. Conservative: retry all on failure.\n429\t  return allItems;\n430\t}\n431\t\n432\t// --- Loop Block Execution (Task 5) ---\n433\t\n434\t/**\n435\t * Result of loop block execution.\n436\t */\n437\tinterface LoopBlockResult {\n438\t  state: WorkflowState;\n439\t  errors: EngineError[];\n440\t  tasksCompleted: number;\n441\t  halted: boolean;\n442\t}\n443\t\n444\t/**\n445\t * Execute a loop block: iterate tasks until pass, max iterations, or circuit breaker.\n446\t */\n447\texport async function executeLoopBlock(\n448\t  loopBlock: LoopBlock,\n449\t  state: WorkflowState,\n450\t  config: EngineConfig,\n451\t  workItems: WorkItem[],\n452\t): Promise<LoopBlockResult> {\n453\t  const projectDir = config.projectDir ?? process.cwd();\n454\t  const maxIterations = config.maxIterations ?? DEFAULT_MAX_ITERATIONS;\n455\t  const errors: EngineError[] = [];\n456\t  let tasksCompleted = 0;\n457\t  let currentState = state;\n458\t  let lastVerdict: EvaluatorVerdict | null = null;\n459\t\n460\t  // Handle empty loop block\n461\t  if (loopBlock.loop.length === 0) {\n462\t    return { state: currentState, errors, tasksCompleted, halted: false };\n463\t  }\n464\t\n465\t  while (true) {\n466\t    // 1. Determine whether to increment iteration or resume a partial one.\n467\t    //    On fresh start (iteration === 0), always increment.\n468\t    //    On resume (iteration > 0), check if the current iteration is fully done.\n469\t    const nextIteration = currentState.iteration + 1;\n470\t    const allCurrentIterationDone = currentState.iteration > 0 && loopBlock.loop.every((tn) => {\n471\t      const t = config.workflow.tasks[tn];\n472\t      if (!t) return true; // missing task = skip = \"done\"\n473\t      if (t.scope === 'per-story') {\n474\t        return workItems.every((item) =>\n475\t          isLoopTaskCompleted(currentState, tn, item.key, currentState.iteration));\n476\t      }\n477\t      return isLoopTaskCompleted(currentState, tn, PER_RUN_SENTINEL, currentState.iteration);\n478\t    });\n479\t\n480\t    if (currentState.iteration === 0 || allCurrentIterationDone) {\n481\t      // Fresh start or current iteration fully done — advance\n482\t      currentState = {\n483\t        ...currentState,\n484\t        iteration: nextIteration,\n485\t      };\n486\t      writeWorkflowState(currentState, projectDir);\n487\t    }\n488\t    // else: resuming a partially completed iteration — keep current iteration\n489\t\n490\t    let haltedInLoop = false;\n491\t\n492\t    // 2. Execute each task in the loop\n493\t    for (const taskName of loopBlock.loop) {\n494\t      const task = config.workflow.tasks[taskName];\n495\t      if (!task) {\n496\t        warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n497\t        continue;\n498\t      }\n499\t\n500\t      const definition = config.agents[task.agent];\n501\t      if (!definition) {\n502\t        warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n503\t        continue;\n504\t      }\n505\t\n506\t      if (task.scope === 'per-story') {\n507\t        // Determine which items to dispatch for\n508\t        const itemsToRetry = lastVerdict ? getFailedItems(lastVerdict, workItems) : workItems;\n509\t\n510\t        for (const item of itemsToRetry) {\n511\t          // Skip if already completed for this iteration (crash recovery — AC #4)\n512\t          if (isLoopTaskCompleted(currentState, taskName, item.key, currentState.iteration)) {\n513\t            warn(`workflow-engine: skipping completed task ${taskName} for ${item.key}`);\n514\t            continue;\n515\t          }\n516\t\n517\t          // Build prompt: inject findings if we have a previous verdict\n518\t          const prompt = lastVerdict\n519\t            ? buildRetryPrompt(item.key, lastVerdict.findings)\n520\t            : undefined;\n521\t\n522\t          try {\n523\t            currentState = await dispatchTask(\n524\t              task, taskName, item.key, definition, currentState, config, prompt,\n525\t            );\n526\t            tasksCompleted++;\n527\t          } catch (err: unknown) {\n528\t            const engineError = handleDispatchError(err, taskName, item.key);\n529\t            errors.push(engineError);\n530\t            currentState = recordErrorInState(currentState, taskName, item.key, engineError);\n531\t            writeWorkflowState(currentState, projectDir);\n532\t\n533\t            if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n534\t              haltedInLoop = true;\n535\t              break;\n536\t            }\n537\t            continue;\n538\t          }\n539\t        }\n540\t\n541\t        if (haltedInLoop) break;\n542\t      } else {\n543\t        // per-run task (e.g., verify)\n544\t        // Skip if already completed for this iteration (crash recovery — AC #4)\n545\t        if (isLoopTaskCompleted(currentState, taskName, PER_RUN_SENTINEL, currentState.iteration)) {\n546\t          warn(`workflow-engine: skipping completed task ${taskName} for ${PER_RUN_SENTINEL}`);\n547\t          continue;\n548\t        }\n549\t\n550\t        try {\n551\t          // We need the dispatch result output to parse verdict\n552\t          // dispatchTask doesn't return the DispatchResult directly, so we\n553\t          // intercept via a wrapper that captures the output\n554\t          const dispatchResult = await dispatchTaskWithResult(\n555\t            task, taskName, PER_RUN_SENTINEL, definition, currentState, config,\n556\t          );\n557\t          currentState = dispatchResult.updatedState;\n558\t          tasksCompleted++;\n559\t\n560\t          // Attempt to parse verdict from output with retry semantics (story 6-2)\n561\t          let verdict: EvaluatorVerdict | null = null;\n562\t          try {\n563\t            verdict = parseVerdict(dispatchResult.output);\n564\t          } catch (parseErr: unknown) {\n565\t            if (parseErr instanceof VerdictParseError && parseErr.retryable) {\n566\t              // Re-dispatch evaluator for one retry attempt\n567\t              warn(`workflow-engine: verdict parse failed, retrying evaluator for ${taskName}`);\n568\t              try {\n569\t                const retryResult = await dispatchTaskWithResult(\n570\t                  task, taskName, PER_RUN_SENTINEL, definition, currentState, config,\n571\t                );\n572\t                currentState = retryResult.updatedState;\n573\t                tasksCompleted++;\n574\t                verdict = parseVerdict(retryResult.output);\n575\t              } catch { // IGNORE: retry failed — fall back to all-UNKNOWN verdict\n576\t                // Second failure: generate all-UNKNOWN verdict\n577\t                verdict = buildAllUnknownVerdict(\n578\t                  workItems,\n579\t                  'Evaluator failed to produce valid JSON after retry',\n580\t                );\n581\t              }\n582\t            }\n583\t            // If not a VerdictParseError or not retryable, verdict stays null\n584\t          }\n585\t          lastVerdict = verdict;\n586\t\n587\t          // Record score in state\n588\t          if (verdict) {\n589\t            const score = {\n590\t              iteration: currentState.iteration,\n591\t              passed: verdict.score.passed,\n592\t              failed: verdict.score.failed,\n593\t              unknown: verdict.score.unknown,\n594\t              total: verdict.score.total,\n595\t              timestamp: new Date().toISOString(),\n596\t            };\n597\t            currentState = {\n598\t              ...currentState,\n599\t              evaluator_scores: [...currentState.evaluator_scores, score],\n600\t            };\n601\t          } else {\n602\t            // Parse failure: record all-UNKNOWN score\n603\t            const totalItems = workItems.length;\n604\t            const score = {\n605\t              iteration: currentState.iteration,\n606\t              passed: 0,\n607\t              failed: 0,\n608\t              unknown: totalItems,\n609\t              total: totalItems,\n610\t              timestamp: new Date().toISOString(),\n611\t            };\n612\t            currentState = {\n613\t              ...currentState,\n614\t              evaluator_scores: [...currentState.evaluator_scores, score],\n615\t            };\n616\t          }\n617\t          writeWorkflowState(currentState, projectDir);\n618\t\n619\t          // Circuit breaker: evaluate progress after recording score\n620\t          const cbDecision = evaluateProgress(currentState.evaluator_scores);\n621\t          if (cbDecision.halt) {\n622\t            currentState = {\n623\t              ...currentState,\n624\t              circuit_breaker: {\n625\t                triggered: true,\n626\t                reason: cbDecision.reason,\n627\t                score_history: cbDecision.scoreHistory,\n628\t              },\n629\t            };\n630\t            writeWorkflowState(currentState, projectDir);\n631\t          }\n632\t        } catch (err: unknown) {\n633\t          const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n634\t          errors.push(engineError);\n635\t          currentState = recordErrorInState(currentState, taskName, PER_RUN_SENTINEL, engineError);\n636\t          writeWorkflowState(currentState, projectDir);\n637\t\n638\t          // Clear stale verdict so next iteration retries all items\n639\t          lastVerdict = null;\n640\t\n641\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n642\t            haltedInLoop = true;\n643\t            break;\n644\t          }\n645\t          continue;\n646\t        }\n647\t      }\n648\t    }\n649\t\n650\t    if (haltedInLoop) {\n651\t      return { state: currentState, errors, tasksCompleted, halted: true };\n652\t    }\n653\t\n654\t    // 3. Check termination conditions\n655\t    if (lastVerdict?.verdict === 'pass') {\n656\t      // Success: loop passes\n657\t      return { state: currentState, errors, tasksCompleted, halted: false };\n658\t    }\n659\t\n660\t    if (currentState.iteration >= maxIterations) {\n661\t      currentState = { ...currentState, phase: 'max-iterations' };\n662\t      writeWorkflowState(currentState, projectDir);\n663\t      return { state: currentState, errors, tasksCompleted, halted: false };\n664\t    }\n665\t\n666\t    if (currentState.circuit_breaker.triggered) {\n667\t      currentState = { ...currentState, phase: 'circuit-breaker' };\n668\t      writeWorkflowState(currentState, projectDir);\n669\t      return { state: currentState, errors, tasksCompleted, halted: false };\n670\t    }\n671\t  }\n672\t}\n673\t\n674\t\n675\t// --- Main Execution ---\n676\t\n677\t/**\n678\t * Execute a workflow sequentially: iterate through flow steps, dispatch tasks\n679\t * per-story or per-run, checkpoint state after each dispatch.\n680\t *\n681\t * Loop blocks execute iteratively until pass, max-iterations, or circuit-breaker.\n682\t *\n683\t * Returns an EngineResult summarizing the execution.\n684\t */\n685\texport async function executeWorkflow(config: EngineConfig): Promise<EngineResult> {\n686\t  const startMs = Date.now();\n687\t  const projectDir = config.projectDir ?? process.cwd();\n688\t  const errors: EngineError[] = [];\n689\t  let tasksCompleted = 0;\n690\t  const processedStories = new Set<string>();\n691\t\n692\t  // 1. Read or initialize workflow state\n693\t  let state = readWorkflowState(projectDir);\n694\t\n695\t  // Early exit: workflow already completed (AC #6)\n696\t  if (state.phase === 'completed') {\n697\t    return {\n698\t      success: true,\n699\t      tasksCompleted: 0,\n700\t      storiesProcessed: 0,\n701\t      errors: [],\n702\t      durationMs: 0,\n703\t    };\n704\t  }\n705\t\n706\t  state = {\n707\t    ...state,\n708\t    phase: 'executing',\n709\t    started: state.started || new Date().toISOString(),\n710\t    workflow_name: config.workflow.flow.filter((s) => typeof s === 'string').join(' -> '),\n711\t  };\n712\t  writeWorkflowState(state, projectDir);\n713\t\n714\t  // 2. Load work items\n715\t  const workItems = loadWorkItems(config.sprintStatusPath, config.issuesPath);\n716\t\n717\t  // 3. Iterate through flow steps\n718\t  let halted = false;\n719\t  for (const step of config.workflow.flow) {\n720\t    if (halted) break;\n721\t\n722\t    // Execute loop blocks\n723\t    if (isLoopBlock(step)) {\n724\t      const loopResult = await executeLoopBlock(step, state, config, workItems);\n725\t      state = loopResult.state;\n726\t      errors.push(...loopResult.errors);\n727\t      tasksCompleted += loopResult.tasksCompleted;\n728\t\n729\t      // Track processed stories from loop\n730\t      for (const item of workItems) {\n731\t        processedStories.add(item.key);\n732\t      }\n733\t\n734\t      if (loopResult.halted) {\n735\t        halted = true;\n736\t      }\n737\t\n738\t      // If loop ended with max-iterations or circuit-breaker, treat as failure\n739\t      if (state.phase === 'max-iterations' || state.phase === 'circuit-breaker') {\n740\t        halted = true;\n741\t      }\n742\t      continue;\n743\t    }\n744\t\n745\t    // step is a string task name\n746\t    const taskName = step;\n747\t    const task = config.workflow.tasks[taskName];\n748\t\n749\t    if (!task) {\n750\t      warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n751\t      continue;\n752\t    }\n753\t\n754\t    // Look up the agent definition\n755\t    const definition = config.agents[task.agent];\n756\t    if (!definition) {\n757\t      warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n758\t      continue;\n759\t    }\n760\t\n761\t    if (task.scope === 'per-run') {\n762\t      // Skip if already completed (crash recovery — AC #3)\n763\t      if (isTaskCompleted(state, taskName, PER_RUN_SENTINEL)) {\n764\t        warn(`workflow-engine: skipping completed task ${taskName} for ${PER_RUN_SENTINEL}`);\n765\t        continue;\n766\t      }\n767\t\n768\t      // Per-run: dispatch once with sentinel key\n769\t      try {\n770\t        state = await dispatchTask(task, taskName, PER_RUN_SENTINEL, definition, state, config);\n771\t        tasksCompleted++;\n772\t      } catch (err: unknown) {\n773\t        const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n774\t        errors.push(engineError);\n775\t\n776\t        // Record error checkpoint in state (AC #13)\n777\t        state = recordErrorInState(state, taskName, PER_RUN_SENTINEL, engineError);\n778\t        writeWorkflowState(state, projectDir);\n779\t\n780\t        // Halt on critical errors\n781\t        if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n782\t          halted = true;\n783\t        }\n784\t      }\n785\t    } else {\n786\t      // Per-story: dispatch once per work item\n787\t      for (const item of workItems) {\n788\t        processedStories.add(item.key);\n789\t\n790\t        // Skip if already completed (crash recovery — AC #1, #2, #7)\n791\t        if (isTaskCompleted(state, taskName, item.key)) {\n792\t          warn(`workflow-engine: skipping completed task ${taskName} for ${item.key}`);\n793\t          continue;\n794\t        }\n795\t\n796\t        try {\n797\t          state = await dispatchTask(task, taskName, item.key, definition, state, config);\n798\t          tasksCompleted++;\n799\t        } catch (err: unknown) {\n800\t          const engineError = handleDispatchError(err, taskName, item.key);\n801\t          errors.push(engineError);\n802\t\n803\t          // Record error checkpoint in state (AC #13)\n804\t          state = recordErrorInState(state, taskName, item.key, engineError);\n805\t          writeWorkflowState(state, projectDir);\n806\t\n807\t          // Halt on critical errors, continue on UNKNOWN\n808\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n809\t            halted = true;\n810\t            break;\n811\t          }\n812\t          // UNKNOWN errors: record and continue to next story\n813\t          continue;\n814\t        }\n815\t      }\n816\t    }\n817\t  }\n818\t\n819\t  // 4. Set final phase if no errors and phase not already set by loop termination\n820\t  if (errors.length === 0 && state.phase !== 'max-iterations' && state.phase !== 'circuit-breaker') {\n821\t    state = { ...state, phase: 'completed' };\n822\t    writeWorkflowState(state, projectDir);\n823\t  }\n824\t\n825\t  // 5. Return result\n826\t  const loopTerminated = state.phase === 'max-iterations' || state.phase === 'circuit-breaker';\n827\t  return {\n828\t    success: errors.length === 0 && !loopTerminated,\n829\t    tasksCompleted,\n830\t    storiesProcessed: processedStories.size,\n831\t    errors,\n832\t    durationMs: Date.now() - startMs,\n833\t  };\n834\t}\n835\t\n836\t// --- Error Handling ---\n837\t\n838\t/**\n839\t * Record a dispatch error in workflow state: set phase to \"error\" and append\n840\t * a TaskCheckpoint with the error details (AC #13).\n841\t */\n842\tfunction recordErrorInState(\n843\t  state: WorkflowState,\n844\t  taskName: string,\n845\t  storyKey: string,\n846\t  error: EngineError,\n847\t): WorkflowState {\n848\t  const errorCheckpoint: TaskCheckpoint = {\n849\t    task_name: taskName,\n850\t    story_key: storyKey,\n851\t    completed_at: new Date().toISOString(),\n852\t    error: true,\n853\t  };\n854\t  return {\n855\t    ...state,\n856\t    phase: 'error',\n857\t    tasks_completed: [...state.tasks_completed, errorCheckpoint],\n858\t  };\n859\t}\n860\t\n861\tfunction handleDispatchError(err: unknown, taskName: string, storyKey: string): EngineError {\n862\t  if (err instanceof DispatchError) {\n863\t    return {\n864\t      taskName,\n865\t      storyKey,\n866\t      code: err.code,\n867\t      message: err.message,\n868\t    };\n869\t  }\n870\t\n871\t  const message = err instanceof Error ? err.message : String(err);\n872\t  return {\n873\t    taskName,\n874\t    storyKey,\n875\t    code: 'UNKNOWN',\n876\t    message,\n877\t  };\n878\t}\n879\t"}]},"parent_tool_use_id":"toolu_011ACjM7rS7kgs6kygtQ7sim","session_id":"f83470b7-c271-483e-ae93-7fe9bce4b683","uuid":"c08104dd-2d00-44d5-b1ff-c5e87a5de5bf","timestamp":"2026-04-03T07:38:06.673Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014aCpCkSibVPUMQMLpu2kyU","type":"tool_result","content":"1\t/**\n2\t * Driver Factory & Registry.\n3\t *\n4\t * Module-singleton registry for AgentDriver instances.\n5\t * Drivers are registered explicitly via registerDriver() — no auto-discovery,\n6\t * no filesystem scanning, no dynamic imports.\n7\t *\n8\t * @see architecture-multi-framework.md — \"Register in factory.ts — never auto-discover\"\n9\t */\n10\t\n11\timport type { AgentDriver } from '../types.js';\n12\t\n13\tconst registry = new Map<string, AgentDriver>();\n14\t\n15\t/**\n16\t * Register an AgentDriver by its `name` property.\n17\t * Throws if a driver with the same name is already registered.\n18\t */\n19\texport function registerDriver(driver: AgentDriver): void {\n20\t  if (!driver || typeof driver.name !== 'string') {\n21\t    throw new Error('registerDriver requires a valid AgentDriver with a string name property.');\n22\t  }\n23\t  if (!driver.name) {\n24\t    throw new Error('Driver name must be a non-empty string.');\n25\t  }\n26\t  if (registry.has(driver.name)) {\n27\t    throw new Error(\n28\t      `Driver '${driver.name}' is already registered. Each driver name must be unique.`,\n29\t    );\n30\t  }\n31\t  registry.set(driver.name, driver);\n32\t}\n33\t\n34\t/**\n35\t * Retrieve a registered AgentDriver by name.\n36\t * Throws with a helpful message listing all registered drivers if not found.\n37\t */\n38\texport function getDriver(name: string): AgentDriver {\n39\t  if (!name || typeof name !== 'string') {\n40\t    throw new Error('getDriver requires a non-empty string name.');\n41\t  }\n42\t  const driver = registry.get(name);\n43\t  if (!driver) {\n44\t    const registered = [...registry.keys()];\n45\t    const list =\n46\t      registered.length > 0 ? registered.join(', ') : '(none)';\n47\t    throw new Error(\n48\t      `Driver '${name}' not found. Registered drivers: ${list}`,\n49\t    );\n50\t  }\n51\t  return driver;\n52\t}\n53\t\n54\t/**\n55\t * List all registered driver names.\n56\t * Returns a copy — mutating the returned array does not affect the registry.\n57\t */\n58\texport function listDrivers(): string[] {\n59\t  return [...registry.keys()];\n60\t}\n61\t\n62\t/**\n63\t * Clear all registered drivers. Exported for test isolation.\n64\t */\n65\texport function resetDrivers(): void {\n66\t  registry.clear();\n67\t}\n68\t"}]},"parent_tool_use_id":"toolu_011ACjM7rS7kgs6kygtQ7sim","session_id":"f83470b7-c271-483e-ae93-7fe9bce4b683","uuid":"70e871e8-97dc-4e6c-bff5-5838aa991012","timestamp":"2026-04-03T07:38:06.653Z"}
