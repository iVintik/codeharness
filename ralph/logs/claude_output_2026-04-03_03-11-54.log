{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VVhKdJZFXcxSp24kdBFtyS","type":"tool_result","content":"1\timport { existsSync } from 'node:fs';\n2\timport { join } from 'node:path';\n3\timport { Command } from 'commander';\n4\timport { fail, info, ok } from '../lib/output.js';\n5\timport { isDockerAvailable } from '../lib/docker/index.js';\n6\timport { cleanupContainers } from '../modules/infra/index.js';\n7\timport { readSprintStatusFromState, reconcileState } from '../modules/sprint/index.js';\n8\timport { countStories, formatElapsed } from '../lib/run-helpers.js';\n9\timport { parseWorkflow } from '../lib/workflow-parser.js';\n10\timport { resolveAgent, compileSubagentDefinition } from '../lib/agent-resolver.js';\n11\timport { executeWorkflow } from '../lib/workflow-engine.js';\n12\timport { readWorkflowState, writeWorkflowState } from '../lib/workflow-state.js';\n13\timport type { EngineConfig } from '../lib/workflow-engine.js';\n14\timport type { SubagentDefinition } from '../lib/agent-resolver.js';\n15\t\n16\t/** Resolves the plugin directory path (.claude/ in project root). */\n17\texport function resolvePluginDir(): string {\n18\t  return join(process.cwd(), '.claude');\n19\t}\n20\t\n21\t// Re-export helpers that tests import from run.ts\n22\texport { countStories } from '../lib/run-helpers.js';\n23\t\n24\texport function registerRunCommand(program: Command): void {\n25\t  program\n26\t    .command('run')\n27\t    .description('Execute the autonomous coding loop')\n28\t    .option('--max-iterations <n>', 'Maximum loop iterations', '50')\n29\t    .option('--timeout <seconds>', 'Total loop timeout in seconds', '43200')\n30\t    .option('--iteration-timeout <minutes>', 'Per-iteration timeout in minutes', '30')\n31\t    .option('--quiet', 'Suppress terminal output (background mode)', false)\n32\t    .option('--calls <n>', 'Max API calls per hour', '100')\n33\t    .option('--max-story-retries <n>', 'Max retries per story before flagging', '10')\n34\t    .option('--reset', 'Clear retry counters, flagged stories, and circuit breaker before starting', false)\n35\t    .option('--resume', 'Resume from last checkpoint (engine resumes by default)', false)\n36\t    .action(async (options, cmd) => {\n37\t      const globalOpts = cmd.optsWithGlobals();\n38\t      const isJson = !!globalOpts.json;\n39\t      const outputOpts = { json: isJson };\n40\t\n41\t      // 1. Resolve plugin directory\n42\t      const pluginDir = resolvePluginDir();\n43\t      if (!existsSync(pluginDir)) {\n44\t        fail('Plugin directory not found — run codeharness init first', outputOpts);\n45\t        process.exitCode = 1;\n46\t        return;\n47\t      }\n48\t\n49\t      // 1b. Reconcile state (best-effort — failures warn but don't abort)\n50\t      const reconciliation = reconcileState();\n51\t      if (reconciliation.success && reconciliation.data.corrections.length > 0) {\n52\t        for (const correction of reconciliation.data.corrections) {\n53\t          info(`[INFO] Reconciled: ${correction}`, outputOpts);\n54\t        }\n55\t      } else if (!reconciliation.success) {\n56\t        info(`[WARN] State reconciliation failed: ${reconciliation.error}`, outputOpts);\n57\t      }\n58\t\n59\t      // 1c. Docker pre-flight: fail fast if Docker unavailable\n60\t      if (!isDockerAvailable()) {\n61\t        fail('[FAIL] Docker not available — install Docker or start the daemon', outputOpts);\n62\t        process.exitCode = 1;\n63\t        return;\n64\t      }\n65\t      // 1d. Orphan container cleanup (best-effort — failures warn but don't abort)\n66\t      const cleanup = cleanupContainers();\n67\t      if (cleanup.success && cleanup.data.containersRemoved > 0) {\n68\t        info(`[INFO] Cleaned up ${cleanup.data.containersRemoved} orphaned container(s): ${cleanup.data.names.join(', ')}`, outputOpts);\n69\t      } else if (!cleanup.success) {\n70\t        info(`[WARN] Container cleanup failed: ${cleanup.error}`, outputOpts);\n71\t      }\n72\t      // 2. Read sprint status for story count (from sprint-state.json)\n73\t      const statuses = readSprintStatusFromState();\n74\t      const counts = countStories(statuses);\n75\t\n76\t      if (counts.total === 0) {\n77\t        fail('No stories found in sprint-state.json — nothing to execute', outputOpts);\n78\t        process.exitCode = 1;\n79\t        return;\n80\t      }\n81\t\n82\t      if (counts.ready === 0) {\n83\t        fail('No stories ready for execution', outputOpts);\n84\t        process.exitCode = 1;\n85\t        return;\n86\t      }\n87\t\n88\t      info(`Starting autonomous execution — ${counts.ready} ready, ${counts.inProgress} in progress, ${counts.verified} verified, ${counts.done}/${counts.total} done`, outputOpts);\n89\t      // 3. Parse and validate numeric options\n90\t      const maxIterations = parseInt(options.maxIterations, 10);\n91\t      const timeout = parseInt(options.timeout, 10);\n92\t      const iterationTimeout = parseInt(options.iterationTimeout, 10);\n93\t      const calls = parseInt(options.calls, 10);\n94\t      const maxStoryRetries = parseInt(options.maxStoryRetries, 10);\n95\t      if (isNaN(maxIterations) || isNaN(timeout) || isNaN(iterationTimeout) || isNaN(calls) || isNaN(maxStoryRetries)) {\n96\t        fail('Invalid numeric option — --max-iterations, --timeout, --iteration-timeout, --calls, and --max-story-retries must be numbers', outputOpts);\n97\t        process.exitCode = 1;\n98\t        return;\n99\t      }\n100\t\n101\t      // 4. Parse workflow YAML\n102\t      const projectDir = process.cwd();\n103\t      const projectWorkflowPath = join(projectDir, '.codeharness', 'workflows', 'default.yaml');\n104\t      const templateWorkflowPath = join(projectDir, 'templates', 'workflows', 'default.yaml');\n105\t      const workflowPath = existsSync(projectWorkflowPath) ? projectWorkflowPath : templateWorkflowPath;\n106\t\n107\t      let parsedWorkflow;\n108\t      try {\n109\t        parsedWorkflow = parseWorkflow(workflowPath);\n110\t      } catch (err: unknown) {\n111\t        const msg = err instanceof Error ? err.message : String(err);\n112\t        fail(`Failed to parse workflow: ${msg}`, outputOpts);\n113\t        process.exitCode = 1;\n114\t        return;\n115\t      }\n116\t\n117\t      // 5. Resolve agents referenced in workflow\n118\t      const agents: Record<string, SubagentDefinition> = {};\n119\t      try {\n120\t        for (const [, task] of Object.entries(parsedWorkflow.tasks)) {\n121\t          if (!agents[task.agent]) {\n122\t            const resolved = resolveAgent(task.agent, { cwd: projectDir });\n123\t            agents[task.agent] = compileSubagentDefinition(resolved);\n124\t          }\n125\t        }\n126\t      } catch (err: unknown) {\n127\t        const msg = err instanceof Error ? err.message : String(err);\n128\t        fail(`Failed to resolve agents: ${msg}`, outputOpts);\n129\t        process.exitCode = 1;\n130\t        return;\n131\t      }\n132\t\n133\t      // 6. Handle --resume: reset completed state so the engine re-enters execution\n134\t      if (options.resume) {\n135\t        const currentState = readWorkflowState(projectDir);\n136\t        if (currentState.phase === 'completed') {\n137\t          writeWorkflowState({ ...currentState, phase: 'idle' }, projectDir);\n138\t          info('Resuming from completed state — phase reset to idle', outputOpts);\n139\t        }\n140\t      }\n141\t\n142\t      // 7. Build EngineConfig and execute\n143\t      const config: EngineConfig = {\n144\t        workflow: parsedWorkflow,\n145\t        agents,\n146\t        sprintStatusPath: join(projectDir, '_bmad-output', 'implementation-artifacts', 'sprint-status.yaml'),\n147\t        issuesPath: join(projectDir, '.codeharness', 'issues.yaml'),\n148\t        runId: `run-${Date.now()}`,\n149\t        projectDir,\n150\t        maxIterations,\n151\t      };\n152\t\n153\t      try {\n154\t        const result = await executeWorkflow(config);\n155\t\n156\t        if (result.success) {\n157\t          ok(`Workflow completed — ${result.storiesProcessed} stories processed, ${result.tasksCompleted} tasks completed in ${formatElapsed(result.durationMs)}`, outputOpts);\n158\t        } else {\n159\t          fail(`Workflow failed — ${result.storiesProcessed} stories processed, ${result.tasksCompleted} tasks completed, ${result.errors.length} error(s) in ${formatElapsed(result.durationMs)}`, outputOpts);\n160\t          for (const err of result.errors) {\n161\t            info(`  ${err.taskName}/${err.storyKey}: [${err.code}] ${err.message}`, outputOpts);\n162\t          }\n163\t          process.exitCode = 1;\n164\t        }\n165\t      } catch (err: unknown) {\n166\t        const msg = err instanceof Error ? err.message : String(err);\n167\t        fail(`Workflow engine error: ${msg}`, outputOpts);\n168\t        process.exitCode = 1;\n169\t      }\n170\t    });\n171\t}\n172\t"}]},"parent_tool_use_id":"toolu_01Xy8yD9yroHvB5H97Nype24","session_id":"452c48b4-eed2-4c96-83e9-8c71df0bbdac","uuid":"f68c81e9-e768-4370-91ef-d2e004104a82","timestamp":"2026-04-02T23:29:11.643Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NJRzy5UFdHijbo776EWQsQ","type":"tool_result","content":"1\t/**\n2\t * Status formatters — human-readable and JSON formatting for status output.\n3\t * Handles the full status display, docker check, and health check formatting.\n4\t */\n5\t\n6\timport { ok, fail, info, jsonOutput } from '../../lib/output.js';\n7\timport { readState, StateFileNotFoundError } from '../../lib/state.js';\n8\timport { getStackHealth, getCollectorHealth, checkRemoteEndpoint } from '../../lib/docker/index.js';\n9\timport { getOnboardingProgress } from '../../lib/onboard-checks.js';\n10\timport { getStackDir, getComposeFilePath, getElkComposeFilePath } from '../../lib/stack-path.js';\n11\timport { generateReport } from '../sprint/index.js';\n12\timport { getValidationProgress } from '../verify/index.js';\n13\timport { readWorkflowState } from '../../lib/workflow-state.js';\n14\timport type { WorkflowState } from '../../lib/workflow-state.js';\n15\timport { DEFAULT_ENDPOINTS, buildScopedEndpoints, resolveEndpoints, getDefaultEndpointsForBackend } from './endpoints.js';\n16\timport type { HarnessState } from '../../lib/state.js';\n17\timport type { StatusReport } from '../sprint/index.js';\n18\t\n19\t/** Resolve the shared compose file path based on the backend type. */\n20\tfunction resolveSharedCompose(backend: string): string {\n21\t  return backend === 'elk' ? getElkComposeFilePath() : getComposeFilePath();\n22\t}\n23\t\n24\t// ─── Full Status Display ────────────────────────────────────────────────────\n25\t\n26\texport function handleFullStatus(isJson: boolean): void {\n27\t  let state: HarnessState;\n28\t  try {\n29\t    state = readState();\n30\t  } catch (err) {\n31\t    if (err instanceof StateFileNotFoundError) {\n32\t      if (isJson) {\n33\t        jsonOutput({ status: 'fail', message: \"Harness not initialized. Run 'codeharness init' first.\" });\n34\t      } else {\n35\t        fail(\"Harness not initialized. Run 'codeharness init' first.\");\n36\t      }\n37\t      process.exitCode = 1;\n38\t      return;\n39\t    }\n40\t    throw err;\n41\t  }\n42\t\n43\t  if (isJson) {\n44\t    handleFullStatusJson(state);\n45\t    return;\n46\t  }\n47\t\n48\t  // Workflow engine state\n49\t  printWorkflowState();\n50\t\n51\t  // Sprint state sections (Project State, Run, Action Items)\n52\t  printSprintState();\n53\t\n54\t  // Validation progress (if validation stories exist)\n55\t  printValidationProgress();\n56\t\n57\t  // Version & Stack\n58\t  console.log(`Harness: codeharness v${state.harness_version}`);\n59\t  console.log(`Stack: ${state.stack ?? 'unknown'}`);\n60\t  if (state.app_type) {\n61\t    console.log(`App type: ${state.app_type}`);\n62\t    if (state.app_type === 'agent' && state.otlp?.agent_sdk) {\n63\t      console.log(`Agent SDK: ${state.otlp.agent_sdk}`);\n64\t    }\n65\t  }\n66\t\n67\t  // Enforcement\n68\t  const e = state.enforcement;\n69\t  console.log(\n70\t    `Enforcement: front:${e.frontend ? 'ON' : 'OFF'} db:${e.database ? 'ON' : 'OFF'} api:${e.api ? 'ON' : 'OFF'} obs:ON`,\n71\t  );\n72\t\n73\t  // Docker (always shown — observability is mandatory unless backend is 'none')\n74\t  {\n75\t    const backend = state.otlp?.backend ?? 'victoria';\n76\t    const mode = state.otlp?.mode ?? 'local-shared';\n77\t\n78\t    if (backend === 'none') {\n79\t      console.log('Docker: disabled (observability off)');\n80\t    } else if (mode === 'remote-direct') {\n81\t      const endpoint = state.otlp?.endpoint ?? 'unknown';\n82\t      console.log(`Docker: none (remote OTLP at ${endpoint})`);\n83\t    } else if (mode === 'remote-routed') {\n84\t      const re = state.docker?.remote_endpoints;\n85\t      console.log(`Docker: OTel Collector only (backends at ${re?.logs_url ?? 'unknown'}, ${re?.metrics_url ?? 'unknown'}, ${re?.traces_url ?? 'unknown'})`);\n86\t      const sharedComposeFile = getComposeFilePath();\n87\t      const health = getCollectorHealth(sharedComposeFile);\n88\t      for (const svc of health.services) {\n89\t        console.log(`  ${svc.name}: ${svc.running ? 'running' : 'stopped'}`);\n90\t      }\n91\t    } else {\n92\t      const composeFile = state.docker?.compose_file ?? 'docker-compose.harness.yml';\n93\t      const stackDir = getStackDir();\n94\t      const isShared = composeFile.startsWith(stackDir);\n95\t\n96\t      const resolvedComposeFile = isShared ? resolveSharedCompose(backend) : composeFile;\n97\t      const projectName = isShared ? 'codeharness-shared' : undefined;\n98\t      const header = isShared ? 'Docker: shared stack at ~/.codeharness/stack/' : 'Docker:';\n99\t\n100\t      console.log(header);\n101\t      const health = getStackHealth(resolvedComposeFile, projectName);\n102\t      for (const svc of health.services) {\n103\t        console.log(`  ${svc.name}: ${svc.running ? 'running' : 'stopped'}`);\n104\t      }\n105\t      if (health.healthy) {\n106\t        const ep = getDefaultEndpointsForBackend(backend);\n107\t        console.log(\n108\t          `  Endpoints: logs=${ep.logs} metrics=${ep.metrics} traces=${ep.traces}`,\n109\t        );\n110\t      }\n111\t    }\n112\t  }\n113\t\n114\t  // Service-scoped endpoints\n115\t  const serviceName = state.otlp?.service_name;\n116\t  if (serviceName) {\n117\t    const endpoints = resolveEndpoints(state);\n118\t    const scoped = buildScopedEndpoints(endpoints, serviceName, state.otlp?.backend);\n119\t    console.log(`  Scoped: logs=${scoped.logs} metrics=${scoped.metrics} traces=${scoped.traces}`);\n120\t  }\n121\t\n122\t  // Beads — removed (Epic 8 replacement pending)\n123\t\n124\t  // Onboarding progress\n125\t  printOnboardingProgress();\n126\t\n127\t  // Session flags\n128\t  const sf = state.session_flags;\n129\t  console.log(\n130\t    `Session: tests_passed=${sf.tests_passed} coverage_met=${sf.coverage_met} verification_run=${sf.verification_run} logs_queried=${sf.logs_queried}`,\n131\t  );\n132\t\n133\t  // Coverage\n134\t  const currentCov = state.coverage.current !== null ? `${state.coverage.current}%` : '\\u2014';\n135\t  console.log(`Coverage: ${currentCov} / ${state.coverage.target}% target`);\n136\t\n137\t  // Verification log\n138\t  if (state.verification_log.length === 0) {\n139\t    console.log('Verification: no entries');\n140\t  } else {\n141\t    console.log('Verification log:');\n142\t    for (const entry of state.verification_log) {\n143\t      console.log(`  ${entry}`);\n144\t    }\n145\t  }\n146\t}\n147\t\n148\tfunction handleFullStatusJson(state: HarnessState): void {\n149\t  // Docker (always present — observability is mandatory unless backend is 'none')\n150\t  let docker: Record<string, unknown>;\n151\t  {\n152\t    const backend = state.otlp?.backend ?? 'victoria';\n153\t    const mode = state.otlp?.mode ?? 'local-shared';\n154\t\n155\t    if (backend === 'none') {\n156\t      docker = { mode: 'none', message: 'Observability disabled' };\n157\t    } else if (mode === 'remote-direct') {\n158\t      docker = {\n159\t        mode: 'remote-direct',\n160\t        endpoint: state.otlp?.endpoint,\n161\t      };\n162\t    } else if (mode === 'remote-routed') {\n163\t      const sharedComposeFile = getComposeFilePath();\n164\t      const health = getCollectorHealth(sharedComposeFile);\n165\t      docker = {\n166\t        mode: 'remote-routed',\n167\t        healthy: health.healthy,\n168\t        services: health.services,\n169\t        remote_endpoints: state.docker?.remote_endpoints,\n170\t      };\n171\t    } else {\n172\t      const composeFile = state.docker?.compose_file ?? 'docker-compose.harness.yml';\n173\t      const stackDir = getStackDir();\n174\t      const isShared = composeFile.startsWith(stackDir);\n175\t\n176\t      const ep = getDefaultEndpointsForBackend(backend);\n177\t      if (isShared) {\n178\t        const sharedComposeFile = resolveSharedCompose(backend);\n179\t        const health = getStackHealth(sharedComposeFile, 'codeharness-shared');\n180\t        docker = {\n181\t          shared: true,\n182\t          stack_dir: '~/.codeharness/stack/',\n183\t          healthy: health.healthy,\n184\t          services: health.services,\n185\t          ...(health.healthy ? { endpoints: ep } : {}),\n186\t        };\n187\t      } else {\n188\t        const health = getStackHealth(composeFile);\n189\t        docker = {\n190\t          healthy: health.healthy,\n191\t          services: health.services,\n192\t          ...(health.healthy ? { endpoints: ep } : {}),\n193\t        };\n194\t      }\n195\t    }\n196\t  }\n197\t\n198\t  // Resolved endpoints\n199\t  const endpoints = resolveEndpoints(state);\n200\t\n201\t  // Scoped endpoints\n202\t  const serviceName = state.otlp?.service_name;\n203\t  const scoped_endpoints = serviceName ? buildScopedEndpoints(endpoints, serviceName, state.otlp?.backend) : undefined;\n204\t\n205\t  // Onboarding progress\n206\t  const onboarding = getOnboardingProgressData();\n207\t\n208\t  // Sprint state\n209\t  const sprint = getSprintReportData();\n210\t\n211\t  // Validation progress\n212\t  const validationResult = getValidationProgress();\n213\t  const validation = validationResult.success && validationResult.data.total > 0\n214\t    ? validationResult.data : undefined;\n215\t\n216\t  // Workflow engine state\n217\t  const workflowState = getWorkflowStateData();\n218\t\n219\t  jsonOutput({\n220\t    version: state.harness_version,\n221\t    stack: state.stack,\n222\t    ...(state.app_type ? { app_type: state.app_type } : {}),\n223\t    ...(sprint ? { sprint } : {}),\n224\t    ...(validation ? { validation } : {}),\n225\t    ...(workflowState ? { workflow: workflowState } : {}),\n226\t    enforcement: state.enforcement,\n227\t    docker,\n228\t    endpoints,\n229\t    ...(scoped_endpoints ? { scoped_endpoints } : {}),\n230\t    ...(onboarding ? { onboarding } : {}),\n231\t    session_flags: state.session_flags,\n232\t    coverage: state.coverage,\n233\t    verification_log: state.verification_log,\n234\t  });\n235\t}\n236\t\n237\t// ─── Health Check Mode ──────────────────────────────────────────────────────\n238\t\n239\texport async function handleHealthCheck(isJson: boolean): Promise<void> {\n240\t  const checks: { name: string; status: 'ok' | 'fail'; detail: string }[] = [];\n241\t\n242\t  // 1. State file integrity\n243\t  let state: HarnessState | null = null;\n244\t  try {\n245\t    state = readState();\n246\t    checks.push({ name: 'state_file', status: 'ok', detail: 'valid' });\n247\t  } catch {\n248\t    // IGNORE: state file may not exist\n249\t    checks.push({ name: 'state_file', status: 'fail', detail: 'not found' });\n250\t  }\n251\t\n252\t  // 2. Docker health (always checked — observability is mandatory unless backend is 'none')\n253\t  if (state) {\n254\t    const backend = state.otlp?.backend ?? 'victoria';\n255\t    const mode = state.otlp?.mode ?? 'local-shared';\n256\t\n257\t    if (backend === 'none') {\n258\t      checks.push({ name: 'docker', status: 'ok', detail: 'observability disabled — skipped' });\n259\t    } else if (mode === 'remote-direct') {\n260\t      const endpoint = state.otlp?.endpoint ?? '';\n261\t      const result = await checkRemoteEndpoint(endpoint);\n262\t      checks.push({\n263\t        name: 'docker',\n264\t        status: result.reachable ? 'ok' : 'fail',\n265\t        detail: result.reachable ? `remote OTLP reachable (${endpoint})` : `remote OTLP unreachable (${result.error ?? 'unknown'})`,\n266\t      });\n267\t    } else if (mode === 'remote-routed') {\n268\t      const sharedComposeFile = getComposeFilePath();\n269\t      const health = getCollectorHealth(sharedComposeFile);\n270\t      checks.push({\n271\t        name: 'docker',\n272\t        status: health.healthy ? 'ok' : 'fail',\n273\t        detail: health.healthy ? 'OTel Collector running' : (health.remedy ?? 'collector down'),\n274\t      });\n275\t\n276\t      // Check remote endpoints\n277\t      const re = state.docker?.remote_endpoints;\n278\t      if (re) {\n279\t        for (const [label, url] of [['logs', re.logs_url], ['metrics', re.metrics_url], ['traces', re.traces_url]] as const) {\n280\t          if (url) {\n281\t            const result = await checkRemoteEndpoint(url);\n282\t            checks.push({\n283\t              name: `remote_${label}`,\n284\t              status: result.reachable ? 'ok' : 'fail',\n285\t              detail: result.reachable ? `reachable (${url})` : `unreachable (${result.error ?? 'unknown'})`,\n286\t            });\n287\t          }\n288\t        }\n289\t      }\n290\t    } else {\n291\t      const composeFile = state.docker?.compose_file ?? 'docker-compose.harness.yml';\n292\t      const sDir = getStackDir();\n293\t      const isShared = composeFile.startsWith(sDir);\n294\t      const healthComposeFile = isShared ? resolveSharedCompose(backend) : composeFile;\n295\t      const healthProjectName = isShared ? 'codeharness-shared' : undefined;\n296\t      const health = getStackHealth(healthComposeFile, healthProjectName);\n297\t      checks.push({\n298\t        name: 'docker',\n299\t        status: health.healthy ? 'ok' : 'fail',\n300\t        detail: health.healthy ? 'all services running' : (health.remedy ?? 'services down'),\n301\t      });\n302\t    }\n303\t  } else {\n304\t    checks.push({ name: 'docker', status: 'fail', detail: 'cannot check (no state)' });\n305\t  }\n306\t\n307\t  // 3. Issue tracker — placeholder for Epic 8\n308\t  // Beads health check removed; Epic 8 will add issue-tracker health check here.\n309\t\n310\t  const allPassed = checks.every(c => c.status === 'ok');\n311\t\n312\t  if (isJson) {\n313\t    const checksObj: Record<string, { status: string; detail: string }> = {};\n314\t    for (const c of checks) {\n315\t      checksObj[c.name] = { status: c.status, detail: c.detail };\n316\t    }\n317\t    jsonOutput({ status: allPassed ? 'ok' : 'fail', checks: checksObj });\n318\t  } else {\n319\t    for (const c of checks) {\n320\t      const prefix = c.status === 'ok' ? '[OK]' : '[FAIL]';\n321\t      const label = c.name.replace(/_/g, ' ');\n322\t      console.log(`${prefix} ${label[0].toUpperCase() + label.slice(1)}: ${c.detail}`);\n323\t    }\n324\t  }\n325\t\n326\t  process.exitCode = allPassed ? 0 : 1;\n327\t}\n328\t\n329\t// ─── Docker Check ───────────────────────────────────────────────────────────\n330\t\n331\texport async function handleDockerCheck(isJson: boolean): Promise<void> {\n332\t  let state: HarnessState | null = null;\n333\t  try {\n334\t    state = readState();\n335\t  } catch {\n336\t    // IGNORE: state file may not exist or be corrupted\n337\t  }\n338\t\n339\t  const backend = state?.otlp?.backend ?? 'victoria';\n340\t\n341\t  if (backend === 'none') {\n342\t    if (isJson) {\n343\t      jsonOutput({ status: 'ok', mode: 'none', message: 'Observability disabled — no Docker check needed' });\n344\t    } else {\n345\t      info('[INFO] Observability disabled — no Docker check needed');\n346\t    }\n347\t    return;\n348\t  }\n349\t\n350\t  const mode = state?.otlp?.mode ?? 'local-shared';\n351\t\n352\t  if (mode === 'remote-direct') {\n353\t    const endpoint = state?.otlp?.endpoint ?? '';\n354\t    const result = await checkRemoteEndpoint(endpoint);\n355\t    if (isJson) {\n356\t      jsonOutput({\n357\t        status: result.reachable ? 'ok' : 'fail',\n358\t        mode: 'remote-direct',\n359\t        endpoint,\n360\t        reachable: result.reachable,\n361\t        ...(result.error ? { error: result.error } : {}),\n362\t      });\n363\t    } else {\n364\t      if (result.reachable) {\n365\t        ok(`Remote OTLP endpoint: reachable (${endpoint})`);\n366\t      } else {\n367\t        fail(`Remote OTLP endpoint: unreachable (${endpoint})`);\n368\t        if (result.error) {\n369\t          info(`Error: ${result.error}`);\n370\t        }\n371\t      }\n372\t    }\n373\t    return;\n374\t  }\n375\t\n376\t  if (mode === 'remote-routed') {\n377\t    const sharedComposeFile = getComposeFilePath();\n378\t    const health = getCollectorHealth(sharedComposeFile);\n379\t\n380\t    if (isJson) {\n381\t      jsonOutput({\n382\t        status: health.healthy ? 'ok' : 'fail',\n383\t        mode: 'remote-routed',\n384\t        docker: {\n385\t          healthy: health.healthy,\n386\t          services: health.services,\n387\t          remedy: health.remedy,\n388\t        },\n389\t        remote_endpoints: state?.docker?.remote_endpoints,\n390\t      });\n391\t    } else {\n392\t      if (health.healthy) {\n393\t        ok('OTel Collector: running');\n394\t      } else {\n395\t        fail('OTel Collector: not running');\n396\t        if (health.remedy) {\n397\t          info(`-> ${health.remedy}`);\n398\t        }\n399\t      }\n400\t      const re = state?.docker?.remote_endpoints;\n401\t      if (re) {\n402\t        info(`Remote backends: logs=${re.logs_url} metrics=${re.metrics_url} traces=${re.traces_url}`);\n403\t      }\n404\t    }\n405\t    return;\n406\t  }\n407\t\n408\t  // local-shared mode (default)\n409\t  let composeFile = 'docker-compose.harness.yml';\n410\t  let projectName: string | undefined;\n411\t\n412\t  if (state?.docker?.compose_file) {\n413\t    composeFile = state.docker.compose_file;\n414\t  }\n415\t\n416\t  const stackDir = getStackDir();\n417\t  if (composeFile.startsWith(stackDir)) {\n418\t    composeFile = resolveSharedCompose(backend);\n419\t    projectName = 'codeharness-shared';\n420\t  }\n421\t\n422\t  const health = getStackHealth(composeFile, projectName);\n423\t\n424\t  if (isJson) {\n425\t    jsonOutput({\n426\t      status: health.healthy ? 'ok' : 'fail',\n427\t      backend,\n428\t      ...(projectName ? { project_name: projectName } : {}),\n429\t      docker: {\n430\t        healthy: health.healthy,\n431\t        services: health.services,\n432\t        remedy: health.remedy,\n433\t      },\n434\t      ...(health.healthy ? { endpoints: getDefaultEndpointsForBackend(backend) } : {}),\n435\t    });\n436\t    return;\n437\t  }\n438\t\n439\t  const stackLabel = backend === 'elk' ? 'OpenSearch/ELK stack' : 'VictoriaMetrics stack';\n440\t  const ep = getDefaultEndpointsForBackend(backend);\n441\t\n442\t  if (health.healthy) {\n443\t    ok(`${stackLabel}: running${projectName ? ` (project: ${projectName})` : ''}`);\n444\t    for (const svc of health.services) {\n445\t      info(`  ${svc.name}: ${svc.running ? 'running' : 'stopped'}`);\n446\t    }\n447\t    info(`Endpoints: logs=${ep.logs} metrics=${ep.metrics} traces=${ep.traces}`);\n448\t  } else {\n449\t    fail(`${stackLabel}: not running${projectName ? ` (project: ${projectName})` : ''}`);\n450\t    for (const svc of health.services) {\n451\t      if (!svc.running) {\n452\t        info(`  ${svc.name}: down`);\n453\t      }\n454\t    }\n455\t    if (health.remedy) {\n456\t      info(`-> ${health.remedy}`);\n457\t    }\n458\t  }\n459\t}\n460\t\n461\t// ─── Workflow State Helpers ──────────────────────────────────────────────────\n462\t\n463\t/**\n464\t * Format elapsed milliseconds as human-readable duration.\n465\t */\n466\texport function formatElapsed(ms: number): string {\n467\t  const s = Math.floor(ms / 1000);\n468\t  const h = Math.floor(s / 3600);\n469\t  const m = Math.floor((s % 3600) / 60);\n470\t  if (h > 0) return `${h}h${m}m`;\n471\t  if (m > 0) return `${m}m${s % 60}s`;\n472\t  return `${s}s`;\n473\t}\n474\t\n475\tfunction printWorkflowState(): void {\n476\t  const state = readWorkflowState();\n477\t\n478\t  if (state.phase === 'idle' && state.started === '') {\n479\t    console.log('Workflow Engine: No active workflow run');\n480\t    return;\n481\t  }\n482\t\n483\t  console.log('── Workflow Engine ──────────────────────────────────────────────');\n484\t  console.log(`  Phase: ${state.phase}`);\n485\t  console.log(`  Iteration: ${state.iteration}`);\n486\t  console.log(`  Tasks completed: ${state.tasks_completed.length}`);\n487\t\n488\t  if (state.phase === 'executing' && state.started) {\n489\t    const elapsed = Date.now() - Date.parse(state.started);\n490\t    console.log(`  Elapsed: ${formatElapsed(elapsed)}`);\n491\t  }\n492\t\n493\t  if (state.evaluator_scores.length > 0) {\n494\t    const latest = state.evaluator_scores[state.evaluator_scores.length - 1];\n495\t    console.log(`  Evaluator: ${latest.passed}/${latest.total} passed, ${latest.failed} failed, ${latest.unknown} unknown`);\n496\t  }\n497\t\n498\t  console.log(`  Circuit breaker: ${state.circuit_breaker.triggered ? 'TRIGGERED' : 'no'}${state.circuit_breaker.triggered && state.circuit_breaker.reason ? ` — ${state.circuit_breaker.reason}` : ''}`);\n499\t  console.log('');\n500\t}\n501\t\n502\tfunction getWorkflowStateData(): Record<string, unknown> | null {\n503\t  const state = readWorkflowState();\n504\t\n505\t  if (state.phase === 'idle' && state.started === '') {\n506\t    return null;\n507\t  }\n508\t\n509\t  const data: Record<string, unknown> = {\n510\t    workflow_name: state.workflow_name,\n511\t    phase: state.phase,\n512\t    iteration: state.iteration,\n513\t    started: state.started,\n514\t    tasks_completed: state.tasks_completed.length,\n515\t    evaluator_scores: state.evaluator_scores,\n516\t    circuit_breaker: state.circuit_breaker,\n517\t  };\n518\t\n519\t  if (state.phase === 'executing' && state.started) {\n520\t    data.elapsed_ms = Date.now() - Date.parse(state.started);\n521\t    data.elapsed = formatElapsed(data.elapsed_ms as number);\n522\t  }\n523\t\n524\t  return data;\n525\t}\n526\t\n527\t// ─── Sprint State Helpers ────────────────────────────────────────────────────\n528\t\n529\tfunction printSprintState(): void {\n530\t  const reportResult = generateReport();\n531\t  if (!reportResult.success) {\n532\t    console.log('Sprint state: unavailable');\n533\t    return;\n534\t  }\n535\t\n536\t  const r = reportResult.data;\n537\t  console.log(`\\u2500\\u2500 Project State \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500`);\n538\t  console.log(`Sprint: ${r.done}/${r.total} done (${r.sprintPercent}%) | ${r.epicsDone}/${r.epicsTotal} epics complete`);\n539\t\n540\t  if (r.activeRun) {\n541\t    console.log('');\n542\t    console.log(`\\u2500\\u2500 Active Run \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500`);\n543\t    const currentStory = r.inProgress ?? 'none';\n544\t    console.log(`Status: running (iteration ${r.activeRun.iterations}, ${r.activeRun.duration} elapsed)`);\n545\t    console.log(`Current: ${currentStory}`);\n546\t    console.log(`Budget: $${r.activeRun.cost.toFixed(2)} spent`);\n547\t  } else if (r.lastRun) {\n548\t    console.log('');\n549\t    console.log(`\\u2500\\u2500 Last Run Summary \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500`);\n550\t    console.log(`Duration: ${r.lastRun.duration} | Cost: $${r.lastRun.cost.toFixed(2)} | Iterations: ${r.lastRun.iterations}`);\n551\t    console.log(`Completed:  ${r.lastRun.completed.length} stories${r.lastRun.completed.length > 0 ? ` (${r.lastRun.completed.join(', ')})` : ''}`);\n552\t    if (r.failedDetails.length > 0) {\n553\t      console.log(`Failed:     ${r.failedDetails.length} stor${r.failedDetails.length === 1 ? 'y' : 'ies'}`);\n554\t      for (const fd of r.failedDetails) {\n555\t        const acPart = fd.acNumber !== null ? `AC ${fd.acNumber}` : 'unknown AC';\n556\t        console.log(`  \\u2514 ${fd.key}: ${acPart} \\u2014 ${fd.errorLine} (attempt ${fd.attempts}/${fd.maxAttempts})`);\n557\t      }\n558\t    }\n559\t    if (r.lastRun.blocked.length > 0) {\n560\t      console.log(`Blocked:    ${r.lastRun.blocked.length} stories (retry-exhausted)`);\n561\t    }\n562\t  }\n563\t\n564\t  if (r.actionItemsLabeled.length > 0) {\n565\t    console.log('');\n566\t    console.log(`\\u2500\\u2500 Action Items \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500`);\n567\t    for (const la of r.actionItemsLabeled) {\n568\t      console.log(`  [${la.label}] ${la.item.story}: ${la.item.description}`);\n569\t    }\n570\t  }\n571\t\n572\t  console.log('');\n573\t}\n574\t\n575\tfunction printValidationProgress(): void {\n576\t  const result = getValidationProgress();\n577\t  if (!result.success) return;\n578\t  const p = result.data;\n579\t  if (p.total === 0) return;\n580\t  console.log(`Validation: ${p.passed}/${p.total} passed, ${p.failed} failed, ${p.blocked} blocked, ${p.remaining} remaining`);\n581\t}\n582\t\n583\tfunction getSprintReportData(): StatusReport | null {\n584\t  const reportResult = generateReport();\n585\t  if (!reportResult.success) return null;\n586\t  return reportResult.data;\n587\t}\n588\t\n589\t// ─── Beads Helpers (removed — Epic 8 replacement pending) ──────────────────\n590\t\n591\tfunction printOnboardingProgress(): void {\n592\t  const progress = getOnboardingProgress();\n593\t  if (progress) {\n594\t    console.log(`Onboarding: ${progress.resolved}/${progress.total} gaps resolved (${progress.remaining} remaining)`);\n595\t  }\n596\t}\n597\t\n598\tfunction getOnboardingProgressData(): Record<string, unknown> | null {\n599\t  const progress = getOnboardingProgress();\n600\t  if (!progress) {\n601\t    return null;\n602\t  }\n603\t  return {\n604\t    total: progress.total,\n605\t    resolved: progress.resolved,\n606\t    remaining: progress.remaining,\n607\t  };\n608\t}\n609\t\n610\t// TODO: v2 issue tracker (Epic 8) — beads data removed, will be replaced by issue tracker\n611\t"}]},"parent_tool_use_id":"toolu_01Xy8yD9yroHvB5H97Nype24","session_id":"452c48b4-eed2-4c96-83e9-8c71df0bbdac","uuid":"b63109c1-e2db-4d90-a7e2-fa03ae01cf0c","timestamp":"2026-04-02T23:29:11.923Z"}
