{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017NMzr3HM1H6Q8Jufom2ccH","type":"tool_result","content":"1\t/**\n2\t * WorkflowGraph — Ink component that renders a schematic workflow graph.\n3\t *\n4\t * Displays tasks as nodes connected by arrows, with status indicators\n5\t * (pending, active, done, failed). Loop blocks are rendered with an\n6\t * iteration counter and visual grouping.\n7\t *\n8\t * When `taskMeta` is provided, renders a multi-row layout:\n9\t *   Row 1: task names with status icons, connected by arrows\n10\t *   Row 2: driver labels (dimmed)\n11\t *   Row 3: cost/time for completed tasks (dimmed)\n12\t *\n13\t * When `taskMeta` is empty or omitted, renders the original single-line format.\n14\t *\n15\t * This is a pure presentational component — no side effects, no state hooks.\n16\t */\n17\t\n18\timport React from 'react';\n19\timport { Text, Box } from 'ink';\n20\timport type { FlowStep, LoopBlock } from './workflow-parser.js';\n21\timport type { TaskNodeState, TaskNodeMeta } from './ink-components.js';\n22\t\n23\t/** Terminal width, capped to avoid excessive line lengths. */\n24\tconst termWidth = () => Math.min(process.stdout.columns || 60, 80);\n25\t\n26\t/** Spinner frames for active task animation. */\n27\tconst SPINNER_FRAMES = ['⠋', '⠙', '⠹', '⠸', '⠼', '⠴', '⠦', '⠧', '⠇', '⠏'];\n28\t\n29\texport interface WorkflowGraphProps {\n30\t  flow: FlowStep[];\n31\t  currentTask: string | null;\n32\t  taskStates: Record<string, TaskNodeState>;\n33\t  taskMeta?: Record<string, TaskNodeMeta>;\n34\t}\n35\t\n36\tfunction isLoopBlock(step: FlowStep): step is LoopBlock {\n37\t  return typeof step === 'object' && step !== null && 'loop' in step;\n38\t}\n39\t\n40\t/** Format cost in USD. Returns `...` for null/undefined. */\n41\texport function formatCost(costUsd: number | null | undefined): string {\n42\t  if (costUsd == null) return '...';\n43\t  return `$${costUsd.toFixed(2)}`;\n44\t}\n45\t\n46\t/** Format elapsed time. Returns `Xm` for >=60s, `Xs` for <60s, `...` for null/undefined. */\n47\texport function formatElapsed(ms: number | null | undefined): string {\n48\t  if (ms == null) return '...';\n49\t  const seconds = Math.round(ms / 1000);\n50\t  if (seconds >= 60) {\n51\t    return `${Math.floor(seconds / 60)}m`;\n52\t  }\n53\t  return `${seconds}s`;\n54\t}\n55\t\n56\t/** Render a single task name with its status indicator. */\n57\tfunction TaskNode({ name, status, spinnerFrame }: { name: string; status: TaskNodeState | undefined; spinnerFrame?: number }) {\n58\t  const s = status ?? 'pending';\n59\t  switch (s) {\n60\t    case 'done':\n61\t      return <Text color=\"green\">{name} ✓</Text>;\n62\t    case 'active': {\n63\t      const frame = SPINNER_FRAMES[(spinnerFrame ?? 0) % SPINNER_FRAMES.length];\n64\t      return <Text color=\"cyan\">{frame} {name}</Text>;\n65\t    }\n66\t    case 'failed':\n67\t      return <Text color=\"red\">{name} ✗</Text>;\n68\t    case 'pending':\n69\t    default:\n70\t      return <Text dimColor>{name}</Text>;\n71\t  }\n72\t}\n73\t\n74\t/** Count completed iterations for a loop block based on task states. */\n75\tfunction loopIteration(tasks: string[], taskStates: Record<string, TaskNodeState>): number {\n76\t  // Heuristic: 0 before any task starts, 1 once any task is active/done/failed.\n77\t  const anyStarted = tasks.some(t => {\n78\t    const s = taskStates[t];\n79\t    return s !== undefined && s !== 'pending';\n80\t  });\n81\t  return anyStarted ? 1 : 0;\n82\t}\n83\t\n84\t/** Collect all task names from the flow in order (flattening loop blocks). */\n85\tfunction collectTaskNames(flow: FlowStep[]): string[] {\n86\t  const names: string[] = [];\n87\t  for (const step of flow) {\n88\t    if (isLoopBlock(step)) {\n89\t      names.push(...step.loop);\n90\t    } else {\n91\t      names.push(step);\n92\t    }\n93\t  }\n94\t  return names;\n95\t}\n96\t\n97\t/** Check if taskMeta has any meaningful data. */\n98\tfunction hasMetaData(taskMeta: Record<string, TaskNodeMeta> | undefined): boolean {\n99\t  if (!taskMeta) return false;\n100\t  return Object.keys(taskMeta).length > 0;\n101\t}\n102\t\n103\texport function WorkflowGraph({ flow, currentTask, taskStates, taskMeta }: WorkflowGraphProps) {\n104\t  if (flow.length === 0 || Object.keys(taskStates).length === 0) {\n105\t    return null;\n106\t  }\n107\t\n108\t  const meta = taskMeta ?? {};\n109\t  const showMeta = hasMetaData(taskMeta);\n110\t\n111\t  // Derive spinner frame from wall clock. Parent re-renders on state updates\n112\t  // which naturally advances the animation. No hooks needed.\n113\t  const spinnerFrame = Math.floor(Date.now() / 80);\n114\t\n115\t  // Row 1: task names with status icons and arrows\n116\t  const elements: React.ReactNode[] = [];\n117\t\n118\t  for (let i = 0; i < flow.length; i++) {\n119\t    const step = flow[i];\n120\t\n121\t    if (i > 0) {\n122\t      elements.push(<Text key={`arrow-${i}`}>{' → '}</Text>);\n123\t    }\n124\t\n125\t    if (isLoopBlock(step)) {\n126\t      const iteration = loopIteration(step.loop, taskStates);\n127\t      const loopNodes: React.ReactNode[] = [];\n128\t      for (let j = 0; j < step.loop.length; j++) {\n129\t        if (j > 0) {\n130\t          loopNodes.push(<Text key={`loop-arrow-${i}-${j}`}>{' → '}</Text>);\n131\t        }\n132\t        loopNodes.push(\n133\t          <TaskNode key={`loop-task-${i}-${j}`} name={step.loop[j]} status={taskStates[step.loop[j]]} spinnerFrame={spinnerFrame} />\n134\t        );\n135\t      }\n136\t      elements.push(\n137\t        <Text key={`loop-${i}`}>\n138\t          <Text>loop({iteration})[ </Text>\n139\t          {loopNodes}\n140\t          <Text> ]</Text>\n141\t        </Text>\n142\t      );\n143\t    } else {\n144\t      elements.push(\n145\t        <TaskNode key={`task-${i}`} name={step} status={taskStates[step]} spinnerFrame={spinnerFrame} />\n146\t      );\n147\t    }\n148\t  }\n149\t\n150\t  // Row 2 & 3: driver labels and cost/time (only when meta is present)\n151\t  let driverRow: React.ReactNode | null = null;\n152\t  let costRow: React.ReactNode | null = null;\n153\t\n154\t  if (showMeta) {\n155\t    const taskNames = collectTaskNames(flow);\n156\t    const driverParts: string[] = [];\n157\t    const costParts: string[] = [];\n158\t    let hasAnyCost = false;\n159\t\n160\t    for (const name of taskNames) {\n161\t      const m = meta[name];\n162\t      const driver = m?.driver ?? '';\n163\t      driverParts.push(driver);\n164\t\n165\t      const state = taskStates[name];\n166\t      if (state === 'done') {\n167\t        const costStr = formatCost(m?.costUsd);\n168\t        const timeStr = formatElapsed(m?.elapsedMs);\n169\t        costParts.push(`${costStr} / ${timeStr}`);\n170\t        hasAnyCost = true;\n171\t      } else {\n172\t        costParts.push('');\n173\t      }\n174\t    }\n175\t\n176\t    // Build driver row: pad each label to match the task name width in row 1\n177\t    const hasSomeDriver = driverParts.some(d => d.length > 0);\n178\t    if (hasSomeDriver) {\n179\t      const driverLabels: React.ReactNode[] = [];\n180\t      for (let idx = 0; idx < taskNames.length; idx++) {\n181\t        if (idx > 0) {\n182\t          // Spacing to align under arrows — match ' → ' visual width (3 cols)\n183\t          driverLabels.push(<Text key={`drv-sep-${idx}`}>{'   '}</Text>);\n184\t        }\n185\t        driverLabels.push(\n186\t          <Text key={`drv-${idx}`} dimColor>{driverParts[idx] || ' '}</Text>\n187\t        );\n188\t      }\n189\t      driverRow = <Text>  {driverLabels}</Text>;\n190\t    }\n191\t\n192\t    // Build cost row\n193\t    if (hasAnyCost) {\n194\t      const costLabels: React.ReactNode[] = [];\n195\t      for (let idx = 0; idx < taskNames.length; idx++) {\n196\t        if (idx > 0) {\n197\t          costLabels.push(<Text key={`cost-sep-${idx}`}>{'   '}</Text>);\n198\t        }\n199\t        costLabels.push(\n200\t          <Text key={`cost-${idx}`} dimColor>{costParts[idx] || ' '}</Text>\n201\t        );\n202\t      }\n203\t      costRow = <Text>  {costLabels}</Text>;\n204\t    }\n205\t  }\n206\t\n207\t  return (\n208\t    <Box flexDirection=\"column\">\n209\t      <Text>{'━'.repeat(termWidth())}</Text>\n210\t      <Text>  {elements}</Text>\n211\t      {driverRow}\n212\t      {costRow}\n213\t      <Text>{'━'.repeat(termWidth())}</Text>\n214\t    </Box>\n215\t  );\n216\t}\n217\t"}]},"parent_tool_use_id":"toolu_01NegsqtPRQ2T1bc3NRcgCgq","session_id":"568bb8a3-7cec-4d55-8fe6-c91654e95e9c","uuid":"91539b3e-a8a9-44d0-b26a-95ec37ab4181","timestamp":"2026-04-03T23:49:30.460Z"}
