{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011dLHcvEsrC7n9L4ri5ZbLi","type":"tool_result","content":"1\t/**\n2\t * AgentDriver abstraction types.\n3\t *\n4\t * Defines the contract that all agent drivers (Claude Code, Codex, OpenCode)\n5\t * must implement. See architecture-multi-framework.md Decision 1.\n6\t */\n7\t\n8\timport type { Readable } from 'node:stream';\n9\timport type { StreamEvent } from './stream-parser.js';\n10\t\n11\t// --- New Types (Epic 10) ---\n12\t\n13\t/**\n14\t * Health status returned by a driver's healthCheck().\n15\t */\n16\texport interface DriverHealth {\n17\t  readonly available: boolean;\n18\t  readonly authenticated: boolean;\n19\t  readonly version: string | null;\n20\t  readonly error?: string;\n21\t}\n22\t\n23\t/**\n24\t * Capability flags for a driver. Extensible — new boolean fields\n25\t * can be added without breaking existing drivers.\n26\t */\n27\texport interface DriverCapabilities {\n28\t  readonly supportsPlugins: boolean;\n29\t  readonly supportsStreaming: boolean;\n30\t  readonly costReporting: boolean;\n31\t}\n32\t\n33\t/**\n34\t * Error classification categories for driver errors.\n35\t * Drivers must NOT invent new categories.\n36\t *\n37\t * Classification priority:\n38\t * 1. HTTP 429 or \"rate limit\" in message -> RATE_LIMIT\n39\t * 2. ECONNREFUSED, ETIMEDOUT, ENOTFOUND -> NETWORK\n40\t * 3. HTTP 401/403 or \"unauthorized\"/\"forbidden\" -> AUTH\n41\t * 4. Process killed by timeout -> TIMEOUT\n42\t * 5. Everything else -> UNKNOWN\n43\t */\n44\texport type ErrorCategory = 'RATE_LIMIT' | 'NETWORK' | 'AUTH' | 'TIMEOUT' | 'UNKNOWN';\n45\t\n46\t/**\n47\t * Test results summary for an output contract.\n48\t */\n49\texport interface TestResults {\n50\t  readonly passed: number;\n51\t  readonly failed: number;\n52\t  readonly coverage: number | null;\n53\t}\n54\t\n55\t/**\n56\t * Acceptance criteria status entry.\n57\t */\n58\texport interface ACStatus {\n59\t  readonly id: string;\n60\t  readonly description: string;\n61\t  readonly status: string;\n62\t}\n63\t\n64\t/**\n65\t * Structured output contract produced by a dispatch.\n66\t */\n67\texport interface OutputContract {\n68\t  readonly version: number;\n69\t  readonly taskName: string;\n70\t  readonly storyId: string;\n71\t  readonly driver: string;\n72\t  readonly model: string;\n73\t  readonly timestamp: string;\n74\t  readonly cost_usd: number | null;\n75\t  readonly duration_ms: number;\n76\t  readonly changedFiles: readonly string[];\n77\t  readonly testResults: TestResults | null;\n78\t  readonly output: string;\n79\t  readonly acceptanceCriteria: readonly ACStatus[];\n80\t}\n81\t\n82\t/**\n83\t * Options for dispatching a task to a driver.\n84\t */\n85\texport interface DispatchOpts {\n86\t  readonly prompt: string;\n87\t  readonly model: string;\n88\t  readonly cwd: string;\n89\t  readonly sourceAccess: boolean;\n90\t  readonly plugins?: readonly string[];\n91\t  readonly timeout?: number;\n92\t  readonly sessionId?: string;\n93\t  readonly appendSystemPrompt?: string;\n94\t  readonly outputContract?: OutputContract;\n95\t}\n96\t\n97\t/**\n98\t * The core agent driver interface (v2 — Epic 10).\n99\t * Each driver knows how to check health, dispatch tasks, and report cost.\n100\t * `dispatch()` returns `AsyncIterable<StreamEvent>` enabling both in-process\n101\t * (Agent SDK yields) and CLI-wrapped (stdout parsed to events) drivers.\n102\t */\n103\texport interface AgentDriver {\n104\t  readonly name: string;\n105\t  readonly defaultModel: string;\n106\t  readonly capabilities: DriverCapabilities;\n107\t  healthCheck(): Promise<DriverHealth>;\n108\t  dispatch(opts: DispatchOpts): AsyncIterable<StreamEvent>;\n109\t  getLastCost(): number | null;\n110\t}\n111\t\n112\t// --- Deprecated Types (backward compatibility until story 10-3) ---\n113\t\n114\t/**\n115\t * Options for spawning an agent process.\n116\t * @deprecated Use `DispatchOpts` instead. Will be removed after story 10-3.\n117\t */\n118\texport interface SpawnOpts {\n119\t  storyKey: string;\n120\t  prompt: string;\n121\t  workDir: string;\n122\t  timeout: number;\n123\t  env?: Record<string, string>;\n124\t}\n125\t\n126\t/**\n127\t * Abstraction over a running agent process.\n128\t * Wraps Node.js ChildProcess but allows non-process-based drivers\n129\t * (direct API calls, WebSocket connections) to implement the same interface.\n130\t * @deprecated Use `AsyncIterable<StreamEvent>` from `dispatch()` instead. Will be removed after story 10-3.\n131\t */\n132\texport interface AgentProcess {\n133\t  stdout: Readable;\n134\t  stderr: Readable;\n135\t  on(event: 'close', handler: (code: number) => void): void;\n136\t  on(event: 'error', handler: (err: Error) => void): void;\n137\t  kill(signal?: string): void;\n138\t}\n139\t\n140\t/**\n141\t * Discriminated union of events emitted by an agent driver.\n142\t * The `parseOutput()` method converts raw agent output lines into these typed events.\n143\t * @deprecated Use `StreamEvent` from `stream-parser.ts` instead. Will be removed after story 10-3.\n144\t */\n145\texport type AgentEvent =\n146\t  | { type: 'tool-start'; name: string }\n147\t  | { type: 'tool-input'; partial: string }\n148\t  | { type: 'tool-complete'; name?: string; args?: string }\n149\t  | { type: 'text'; text: string }\n150\t  | { type: 'story-complete'; key: string; details: string }\n151\t  | { type: 'story-failed'; key: string; reason: string }\n152\t  | { type: 'iteration'; count: number }\n153\t  | { type: 'retry'; attempt: number; delay: number }\n154\t  | { type: 'result'; cost: number; sessionId: string };\n155\t"}]},"parent_tool_use_id":"toolu_01Bk7b1ye4oD73YHD4mg4V1R","session_id":"8f19e005-5742-4a5a-a61f-d8a88dc16bec","uuid":"3deb3b4f-a830-46fa-8f53-b9cf5bf6c984","timestamp":"2026-04-03T10:28:19.015Z"}
