n('--json', 'JSON output');\n   428→      registerRunCommand(program);\n   429→\n   430→      const runCmd = program.commands.find(c => c.name() === 'run');\n   431→      expect(runCmd).toBeDefined();\n   432→      expect(runCmd!.description()).toBe('Execute the autonomous coding loop');\n   433→\n   434→      const optionNames = runCmd!.options.map(o => o.long);\n   435→      expect(optionNames).toContain('--max-iterations');\n   436→      expect(optionNames).toContain('--timeout');\n   437→      expect(optionNames).toContain('--quiet');\n   438→      expect(optionNames).toContain('--max-story-retries');\n   439→    });\n   440→\n   441→    it('--max-story-retries defaults to 10', async () => {\n   442→      const { registerRunCommand } = await import('../run.js');\n   443→      const program = new Command();\n   444→      program.option('--json', 'JSON output');\n   445→      registerRunCommand(program);\n   446→\n   447→      const runCmd = program.commands.find(c => c.name() === 'run');\n   448→      const retryOpt = runCmd!.options.find(o => o.long === '--max-story-retries');\n   449→      expect(retryOpt!.defaultValue).toBe('10');\n   450→    });\n   451→  });\n   452→\n   453→  describe('AgentDriver integration', () => {\n   454→    it('starts Ink renderer before spawning agent', async () => {\n   455→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   456→      mockPaths({ '.claude': true });\n   457→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   458→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   459→\n   460→      const p = runCommand();\n   461→      await vi.waitFor(() => expect(mockDriverInstance.spawn).toHaveBeenCalled());\n   462→      mockDriverInstance._getChildOnHandlers()['close'](0);\n   463→      await p;\n   464→\n   465→      expect(startRendererMock).toHaveBeenCalledTimes(1);\n   466→      expect(startRendererMock).toHaveBeenCalledWith({ quiet: false });\n   467→    });\n   468→\n   469→  