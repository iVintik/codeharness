{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MjZo5Dva7PR2FsMbvS82D3","type":"tool_result","content":"1\t/**\n2\t * Sprint state types matching architecture decision 2: Unified State Format.\n3\t */\n4\t\n5\t/** All possible story statuses */\n6\texport type StoryStatus =\n7\t  | 'backlog'\n8\t  | 'ready'\n9\t  | 'in-progress'\n10\t  | 'review'\n11\t  | 'verifying'\n12\t  | 'done'\n13\t  | 'failed'\n14\t  | 'blocked';\n15\t\n16\t/** Verdict for a single acceptance criterion check */\n17\texport type AcVerdict = 'pass' | 'fail' | 'escalate' | 'pending';\n18\t\n19\t/** Result of checking one acceptance criterion */\n20\texport interface AcResult {\n21\t  readonly id: string;\n22\t  readonly verdict: AcVerdict;\n23\t}\n24\t\n25\t/** State of an individual story */\n26\texport interface StoryState {\n27\t  readonly status: StoryStatus;\n28\t  readonly attempts: number;\n29\t  readonly lastAttempt: string | null;\n30\t  readonly lastError: string | null;\n31\t  readonly proofPath: string | null;\n32\t  readonly acResults: AcResult[] | null;\n33\t}\n34\t\n35\t/** Source of an action item */\n36\texport type ActionItemSource = 'verification' | 'retro' | 'manual';\n37\t\n38\t/** An action item tracked across sprints */\n39\texport interface ActionItem {\n40\t  readonly id: string;\n41\t  readonly story: string;\n42\t  readonly description: string;\n43\t  readonly source: ActionItemSource;\n44\t  readonly resolved: boolean;\n45\t}\n46\t\n47\t/** State of an epic within the sprint */\n48\texport interface EpicState {\n49\t  readonly status: string;\n50\t  readonly storiesTotal: number;\n51\t  readonly storiesDone: number;\n52\t}\n53\t\n54\t/** Session runtime state */\n55\texport interface SessionState {\n56\t  readonly active: boolean;\n57\t  readonly startedAt: string | null;\n58\t  readonly iteration: number;\n59\t  readonly elapsedSeconds: number;\n60\t}\n61\t\n62\t/** Observability coverage metrics */\n63\texport interface ObservabilityState {\n64\t  readonly statementCoverage: number | null;\n65\t  readonly branchCoverage: number | null;\n66\t  readonly functionCoverage: number | null;\n67\t  readonly lineCoverage: number | null;\n68\t}\n69\t\n70\t/** V1 sprint state (original schema) */\n71\texport interface SprintStateV1 {\n72\t  readonly version: 1;\n73\t  readonly sprint: {\n74\t    readonly total: number;\n75\t    readonly done: number;\n76\t    readonly failed: number;\n77\t    readonly blocked: number;\n78\t    readonly inProgress: string | null;\n79\t  };\n80\t  readonly stories: Record<string, StoryState>;\n81\t  readonly run: {\n82\t    readonly active: boolean;\n83\t    readonly startedAt: string | null;\n84\t    readonly iteration: number;\n85\t    readonly cost: number;\n86\t    readonly completed: string[];\n87\t    readonly failed: string[];\n88\t    readonly currentStory: string | null;\n89\t    readonly currentPhase: 'create' | 'dev' | 'review' | 'verify' | null;\n90\t    readonly lastAction: string | null;\n91\t    readonly acProgress: string | null;\n92\t  };\n93\t  readonly actionItems: ActionItem[];\n94\t}\n95\t\n96\t/** V2 sprint state (unified schema with versioning) */\n97\texport interface SprintStateV2 {\n98\t  readonly version: 2;\n99\t  readonly sprint: {\n100\t    readonly total: number;\n101\t    readonly done: number;\n102\t    readonly failed: number;\n103\t    readonly blocked: number;\n104\t    readonly inProgress: string | null;\n105\t  };\n106\t  readonly stories: Record<string, StoryState>;\n107\t  readonly retries: Record<string, number>;\n108\t  readonly flagged: string[];\n109\t  readonly epics: Record<string, EpicState>;\n110\t  readonly session: SessionState;\n111\t  readonly observability: ObservabilityState;\n112\t  readonly run: {\n113\t    readonly active: boolean;\n114\t    readonly startedAt: string | null;\n115\t    readonly iteration: number;\n116\t    readonly cost: number;\n117\t    readonly completed: string[];\n118\t    readonly failed: string[];\n119\t    readonly currentStory: string | null;\n120\t    readonly currentPhase: 'create' | 'dev' | 'review' | 'verify' | null;\n121\t    readonly lastAction: string | null;\n122\t    readonly acProgress: string | null;\n123\t  };\n124\t  readonly actionItems: ActionItem[];\n125\t}\n126\t\n127\t/** Union of all sprint state versions */\n128\texport type SprintStateAny = SprintStateV1 | SprintStateV2;\n129\t\n130\t/** Top-level sprint state — alias for current version (v2) */\n131\texport type SprintState = SprintStateV2;\n132\t"}]},"parent_tool_use_id":"toolu_01YVAicDPB2Xe9r2bfCAtkWv","session_id":"1e0d780f-040f-4c10-b8e5-df49ae6fae2c","uuid":"27c07306-5a86-4fe7-bed8-aa8909793873","timestamp":"2026-04-03T20:45:16.451Z"}
