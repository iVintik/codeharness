{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014ujKDGFpim6eeGVAkBt8Lk","type":"tool_result","content":"     1→/**\n     2→ * Types for the observability analyzer module.\n     3→ *\n     4→ * These interfaces are tool-agnostic: any static analysis tool\n     5→ * (Semgrep, ESLint, custom) can produce conforming output.\n     6→ * See architecture Decision 1 for rationale.\n     7→ */\n     8→\n     9→/** Severity levels for observability gaps */\n    10→export type GapSeverity = 'error' | 'warning' | 'info';\n    11→\n    12→/**\n    13→ * A single observability gap found by static analysis.\n    14→ *\n    15→ * Maps 1:1 from analyzer output. The `type` field carries the\n    16→ * rule ID from the analyzer (e.g., \"catch-without-logging\"),\n    17→ * NOT a Semgrep-specific identifier.\n    18→ */\n    19→export interface ObservabilityGap {\n    20→  /** File path where the gap was found */\n    21→  readonly file: string;\n    22→  /** Line number in the file */\n    23→  readonly line: number;\n    24→  /** Rule identifier from the analyzer */\n    25→  readonly type: string;\n    26→  /** Human-readable description of the gap */\n    27→  readonly description: string;\n    28→  /** Severity of the gap */\n    29→  readonly severity: GapSeverity;\n    30→}\n    31→\n    32→/**\n    33→ * Summary statistics from an analysis run.\n    34→ */\n    35→export interface AnalyzerSummary {\n    36→  /** Total number of functions scanned */\n    37→  readonly totalFunctions: number;\n    38→  /** Number of functions that have log statements */\n    39→  readonly functionsWithLogs: number;\n    40→  /** Number of error handlers without logging */\n    41→  readonly errorHandlersWithoutLogs: number;\n    42→  /** Coverage percentage: functionsWithLogs / totalFunctions * 100 */\n    43→  readonly coveragePercent: number;\n    44→  /** Distribution of log levels found (e.g., { debug: 5, error: 3 }) */\n    45→  readonly levelDistribution: Record<string, number>;\n    46→}\n    47→\n    48→/**\n    49→ * Configuration for the analyzer module.\n    50→ *\n    51→ * Allows callers to specify which tool to use and where rules live.\n    52→ * Defaults are applied when not provided.\n    53→ */\n    54→export interface AnalyzerConfig {\n    55→  /** The analysis tool to use. Default: 'semgrep' */\n    56→  readonly tool?: string;\n    57→  /** Directory containing analysis rules, relative to project root. Default: 'patches/observability/' */\n    58→  readonly rulesDir?: string;\n    59→  /** Timeout for the analysis subprocess in milliseconds. Default: 60000 */\n    60→  readonly timeout?: number;\n    61→  /**\n    62→   * Total number of functions in the project (from an external count or AST scan).\n    63→   * When provided, enables accurate coverage computation:\n    64→   * coveragePercent = (totalFunctions - functionsWithoutLogs) / totalFunctions * 100.\n    65→   * When omitted, totalFunctions defaults to the count of function-no-debug-log matches\n    66→   * (functions lacking logs), producing 0% coverage as the best conservative estimate.\n    67→   */\n    68→  readonly totalFunctions?: number;\n    69→}\n    70→\n    71→/**\n    72→ * The result of an analysis run, independent of the underlying tool.\n    73→ *\n    74→ * Any static analysis tool that produces this shape can be used as\n    75→ * a drop-in replacement for Semgrep.\n    76→ */\n    77→export interface AnalyzerResult {\n    78→  /** The tool that produced this result (e.g., 'semgrep', 'eslint', 'custom') */\n    79→  readonly tool: string;\n    80→  /** Observability gaps found */\n    81→  readonly gaps: ObservabilityGap[];\n    82→  /** Summary statistics */\n    83→  readonly summary: AnalyzerSummary;\n    84→  /** Whether the analysis was skipped (e.g., tool not installed) */\n    85→  readonly skipped?: boolean;\n    86→  /** Reason the analysis was skipped, if applicable */\n    87→  readonly skipReason?: string;\n    88→}\n    89→\n    90→/**\n    91→ * Raw JSON output from Semgrep's --json flag.\n    92→ * Internal type — not part of the public API.\n    93→ */\n    94→export interface SemgrepRawOutput {\n    95→  readonly results: ReadonlyArray<SemgrepResult>;\n    96→  readonly errors?: ReadonlyArray<unknown>;\n    97→}\n    98→\n    99→// ============================================================\n   100→// Coverage state types (Story 1.3)\n   101→// ============================================================\n   102→\n   103→/** A single coverage history entry with timestamp */\n   104→export interface CoverageHistoryEntry {\n   105→  /** Coverage percentage at this point in time */\n   106→  readonly coveragePercent: number;\n   107→  /** ISO 8601 timestamp when this measurement was taken */\n   108→  readonly timestamp: string;\n   109→}\n   110→\n   111→/** Static analysis coverage state persisted in sprint-state.json */\n   112→export interface StaticCoverageState {\n   113→  /** Current coverage percentage */\n   114→  readonly coveragePercent: number;\n   115→  /** ISO 8601 timestamp of last scan */\n   116→  readonly lastScanTimestamp: string;\n   117→  /** Historical coverage entries */\n   118→  readonly history: readonly CoverageHistoryEntry[];\n   119→  /** Cached observability gaps from last analysis run (persisted by saveCoverageResult) */\n   120→  readonly gaps?: readonly ObservabilityGap[];\n   121→}\n   122→\n   123→/** Coverage targets configuration */\n   124→export interface CoverageTargets {\n   125→  /** Target coverage percentage for static analysis (default 80) */\n   126→  readonly staticTarget: number;\n   127→  /** Target coverage percentage for runtime observability (default 60) */\n   128→  readonly runtimeTarget?: number;\n   129→}\n   130→\n   131→/**\n   132→ * Top-level observability coverage state in sprint-state.json.\n   133→ *\n   134→ * Contains `static` (Story 1.3) and optional `runtime` (Story 2.1) sections.\n   135→ * Follows architecture Decision 2 (Separate Metrics).\n   136→ */\n   137→export interface ObservabilityCoverageState {\n   138→  /** Static analysis coverage metrics */\n   139→  readonly static: StaticCoverageState;\n   140→  /** Coverage targets */\n   141→  readonly targets: CoverageTargets;\n   142→  /** Runtime observability coverage metrics (Story 2.1) */\n   143→  readonly runtime?: RuntimeCoverageState;\n   144→}\n   145→\n   146→// ============================================================\n   147→// Runtime coverage types (Story 2.1)\n   148→// ============================================================\n   149→\n   150→/** A single AC's runtime coverage entry from verification */\n   151→export interface RuntimeCoverageEntry {\n   152→  /** Acceptance criterion identifier */\n   153→  readonly acId: string;\n   154→  /** Whether log events were detected for this AC */\n   155→  readonly logEventsDetected: boolean;\n   156→  /** Number of log events detected */\n   157→  readonly logEventCount: number;\n   158→  /** Gap note if no log events detected */\n   159→  readonly gapNote?: string;\n   160→}\n   161→\n   162→/** Result of computing runtime coverage from parsed observability gaps */\n   163→export interface RuntimeCoverageResult {\n   164→  /** Per-AC runtime coverage entries */\n   165→  readonly entries: readonly RuntimeCoverageEntry[];\n   166→  /** Total number of ACs evaluated */\n   167→  readonly totalACs: number;\n   168→  /** Number of ACs that produced log events */\n   169→  readonly acsWithLogs: number;\n   170→  /** Runtime coverage percentage: acsWithLogs / totalACs * 100 */\n   171→  readonly coveragePercent: number;\n   172→}\n   173→\n   174→/** Runtime coverage state persisted in sprint-state.json */\n   175→export interface RuntimeCoverageState {\n   176→  /** Runtime coverage percentage */\n   177→  readonly coveragePercent: number;\n   178→  /** ISO 8601 timestamp of last validation */\n   179→  readonly lastValidationTimestamp: string;\n   180→  /** Number of modules with telemetry */\n   181→  readonly modulesWithTelemetry: number;\n   182→  /** Total number of modules */\n   183→  readonly totalModules: number;\n   184→  /** Whether telemetry was detected at all */\n   185→  readonly telemetryDetected: boolean;\n   186→}\n   187→\n   188→// ============================================================\n   189→// Coverage gate types (Story 2.2)\n   190→// ============================================================\n   191→\n   192→/** Result of the observability coverage gate check */\n   193→export interface ObservabilityCoverageGateResult {\n   194→  /** Whether the gate passed (all required checks met their targets) */\n   195→  readonly passed: boolean;\n   196→  /** Static coverage check result */\n   197→  readonly staticResult: CoverageTargetResult;\n   198→  /** Runtime coverage check result, or null if no runtime data exists */\n   199→  readonly runtimeResult: CoverageTargetResult | null;\n   200→  /** List of observability gaps for actionable feedback */\n   201→  readonly gapSummary: ObservabilityGap[];\n   202→}\n   203→\n   204→/** Trend comparison between latest and previous coverage entries */\n   205→export interface CoverageTrend {\n   206→  /** Latest coverage percentage */\n   207→  readonly current: number;\n   208→  /** Previous coverage percentage, or null if only one entry */\n   209→  readonly previous: number | null;\n   210→  /** Delta: current - previous, or null if only one entry */\n   211→  readonly delta: number | null;\n   212→  /** Timestamp of latest measurement */\n   213→  readonly currentTimestamp: string;\n   214→  /** Timestamp of previous measurement, or null */\n   215→  readonly previousTimestamp: string | null;\n   216→}\n   217→\n   218→/** Result of checking coverage against a target */\n   219→export interface CoverageTargetResult {\n   220→  /** Whether coverage meets or exceeds the target */\n   221→  readonly met: boolean;\n   222→  /** Current coverage percentage */\n   223→  readonly current: number;\n   224→  /** Target coverage percentage */\n   225→  readonly target: number;\n   226→  /** Gap: target - current (0 if met) */\n   227→  readonly gap: number;\n   228→}\n   229→\n   230→// ============================================================\n   231→// Runtime validation types (Story 2.3)\n   232→// ============================================================\n   233→\n   234→/** Configuration for standalone runtime validation (audit mode) */\n   235→export interface RuntimeValidationConfig {\n   236→  /** Test command to run (default: 'npm test') */\n   237→  readonly testCommand: string;\n   238→  /** OTLP endpoint for telemetry export */\n   239→  readonly otlpEndpoint: string;\n   240→  /** Query endpoint for the observability backend (VictoriaLogs) */\n   241→  readonly queryEndpoint: string;\n   242→  /** Timeout for the entire validation process in milliseconds (default: 120000) */\n   243→  readonly timeoutMs: number;\n   244→}\n   245→\n   246→/** A single module's telemetry status from runtime validation */\n   247→export interface ModuleTelemetryEntry {\n   248→  /** Module name (derived from source directory) */\n   249→  readonly moduleName: string;\n   250→  /** Whether telemetry was detected for this module */\n   251→  readonly telemetryDetected: boolean;\n   252→  /** Number of telemetry events emitted by this module */\n   253→  readonly eventCount: number;\n   254→}\n   255→\n   256→/** Result of a standalone runtime validation run */\n   257→export interface RuntimeValidationResult {\n   258→  /** Per-module telemetry entries */\n   259→  readonly entries: readonly ModuleTelemetryEntry[];\n   260→  /** Total number of modules in the project */\n   261→  readonly totalModules: number;\n   262→  /** Number of modules that emitted telemetry */\n   263→  readonly modulesWithTelemetry: number;\n   264→  /** Runtime coverage percentage: modulesWithTelemetry / totalModules * 100 */\n   265→  readonly coveragePercent: number;\n   266→  /** Whether validation was skipped (e.g., backend unreachable) */\n   267→  readonly skipped: boolean;\n   268→  /** Reason validation was skipped, if applicable */\n   269→  readonly skipReason?: string;\n   270→}\n   271→\n   272→/** A telemetry event returned from the observability backend query */\n   273→export interface TelemetryEvent {\n   274→  /** ISO 8601 timestamp of the event */\n   275→  readonly timestamp: string;\n   276→  /** Log message or event description */\n   277→  readonly message: string;\n   278→  /** Source file or service attribute */\n   279→  readonly source: string;\n   280→}\n   281→\n   282→/** A single result entry from Semgrep JSON output */\n   283→export interface SemgrepResult {\n   284→  readonly check_id: string;\n   285→  readonly path: string;\n   286→  readonly start: { readonly line: number; readonly col: number };\n   287→  readonly end: { readonly line: number; readonly col: number };\n   288→  readonly extra: {\n   289→    readonly message: string;\n   290→    readonly severity: string;\n   291→    readonly metadata?: Record<string, unknown>;\n   292→  };\n   293→}\n   294→"}]},"parent_tool_use_id":"toolu_01St1ZX8VZKJ5rWiDeuqc1Kp","session_id":"63766b2b-ee05-46af-a819-a3f0370845d2","uuid":"199ec572-876e-4f8b-bd32-23a7c3d34c1d","timestamp":"2026-03-21T06:37:57.152Z"}
