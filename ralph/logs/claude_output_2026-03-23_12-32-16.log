{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01C3GCBBCBgkxzsxqnmZs1kz","type":"tool_result","content":"   241→    const content = readFileSync(\n   242→      resolve(PATCHES_DIR, 'rust-catch-without-tracing.yaml'),\n   243→      'utf-8',\n   244→    );\n   245→    const lineCount = content.split('\\n').length;\n   246→    expect(lineCount).toBeLessThan(300);\n   247→  });\n   248→});\n   249→\n   250→// ============================================================\n   251→// rust-error-path-no-tracing.yaml\n   252→// ============================================================\n   253→\n   254→describe('rust-error-path-no-tracing.yaml', () => {\n   255→  let config: SemgrepConfig;\n   256→\n   257→  beforeAll(() => {\n   258→    config = loadRule('rust-error-path-no-tracing.yaml');\n   259→  });\n   260→\n   261→  it('file exists', () => {\n   262→    expect(existsSync(resolve(PATCHES_DIR, 'rust-error-path-no-tracing.yaml'))).toBe(true);\n   263→  });\n   264→\n   265→  it('has exactly one rule', () => {\n   266→    expect(config.rules).toHaveLength(1);\n   267→  });\n   268→\n   269→  it('rule id is rust-error-path-no-tracing', () => {\n   270→    expect(config.rules[0].id).toBe('rust-error-path-no-tracing');\n   271→  });\n   272→\n   273→  it('targets Rust language', () => {\n   274→    expect(config.rules[0].languages).toEqual(['rust']);\n   275→  });\n   276→\n   277→  it('severity is WARNING', () => {\n   278→    expect(config.rules[0].severity).toBe('WARNING');\n   279→  });\n   280→\n   281→  it('has observability category metadata', () => {\n   282→    expect(config.rules[0].metadata?.category).toBe('observability');\n   283→  });\n   284→\n   285→  it('has CWE-778 metadata', () => {\n   286→    expect(config.rules[0].metadata?.cwe).toBe('CWE-778: Insufficient Logging');\n   287→  });\n   288→\n   289→  it('message mentions observability gap', () => {\n   290→    expect(config.rules[0].message).toContain('observability gap');\n   291→  });\n   292→\n   293→  it('has pattern-either covering map_err and unwrap_or_else', () => {\n   294→    const patterns = config.rules[0].patterns!;\n   295→    const patternEither = (patterns[0] as Record<string, unknown>)['pattern-either'] as unknown[];\n   296→\n   297→    const allText = JSON.stringify(patternEither);\n   298→    expect(allText).toContain('map_err');\n   299→    expect(allText).toContain('unwrap_or_else');\n   300→  });\n   301→\n   302→  it('pattern-not entries exclude tracing macros for both map_err and unwrap_or_else', () => {\n   303→    const patterns = config.rules[0].patterns!;\n   304→    const patternNots = patterns\n   305→      .filter(\n   306→        (p) => typeof p === 'object' && p !== null && 'pattern-not' in (p as Record<string, unknown>),\n   307→      )\n   308→      .map((p) => (p as Record<string, string>)['pattern-not']);\n   309→\n   310→    const allExclusions = patternNots.join(' ');\n   311→\n   312→    // Must exclude tracing macros in map_err closures\n   313→    expect(allExclusions).toContain('map_err');\n   314→    expect(allExclusions).toContain('tracing::error!');\n   315→    expect(allExclusions).toContain('tracing::warn!');\n   316→\n   317→    // Must exclude tracing macros in unwrap_or_else closures\n   318→    expect(allExclusions).toContain('unwrap_or_else');\n   319→    expect(allExclusions).toContain('error!(');\n   320→    expect(allExclusions).toContain('warn!(');\n   321→  });\n   322→\n   323→  it('test fixture file exists', () => {\n   324→    expect(existsSync(resolve(PATCHES_DIR, 'rust-error-path-no-tracing.rs'))).toBe(true);\n   325→  });\n   326→\n   327→  it('test fixture has ruleid and ok annotations', () => {\n   328→    const fixture = readFileSync(\n   329→      resolve(PATCHES_DIR, 'rust-error-path-no-tracing.rs'),\n   330→      'utf-8',\n   331→    );\n   332→    expect(fixture).toContain('// ruleid: rust-error-path-no-tracing');\n   333→    expect(fixture).toContain('// ok: rust-error-path-no-tracing');\n   334→  });\n   335→\n   336→  it('file is under 300 lines (NFR1)', () => {\n   337→    const content = readFileSync(\n   338→      resolve(PATCHES_DIR, 'rust-error-path-no-tracing.yaml'),\n   339→      'utf-8',\n   340→    );\n   341→    const lineCount = content.split('\\n').length;\n   342→    expect(lineCount).toBeLessThan(300);\n   343→  });\n   344→});\n   345→\n   346→// ============================================================\n   347→// Cross-rule consistency checks\n   348→// ============================================================\n   349→\n   350→describe('Rust Semgrep rules — cross-rule consistency', () => {\n   351→  it('all three Rust rule files exist in patches/observability/', () => {\n   352→    const expected = [\n   353→      'rust-function-no-tracing.yaml',\n   354→      'rust-catch-without-tracing.yaml',\n   355→      'rust-error-path-no-tracing.yaml',\n   356→    ];\n   357→    for (const filename of expected) {\n   358→      expect(existsSync(resolve(PATCHES_DIR, filename))).toBe(true);\n   359→    }\n   360→  });\n   361→\n   362→  it('all three Rust test fixture files exist', () => {\n   363→    const expected = [\n   364→      'rust-function-no-tracing.rs',\n   365→      'rust-catch-without-tracing.rs',\n   366→      'rust-error-path-no-tracing.rs',\n   367→    ];\n   368→    for (const filename of expected) {\n   369→      expect(existsSync(resolve(PATCHES_DIR, filename))).toBe(true);\n   370→    }\n   371→  });\n   372→\n   373→  it('all rules target only Rust (not JS/TS)', () => {\n   374→    const files = [\n   375→      'rust-function-no-tracing.yaml',\n   376→      'rust-catch-without-tracing.yaml',\n   377→      'rust-error-path-no-tracing.yaml',\n   378→    ];\n   379→    for (const filename of files) {\n   380→      const config = loadRule(filename);\n   381→      expect(config.rules[0].languages).toEqual(['rust']);\n   382→      expect(config.rules[0].languages).not.toContain('typescript');\n   383→      expect(config.rules[0].languages).not.toContain('javascript');\n   384→    }\n   385→  });\n   386→\n   387→  it('all rules share consistent metadata', () => {\n   388→    const files = [\n   389→      'rust-function-no-tracing.yaml',\n   390→      'rust-catch-without-tracing.yaml',\n   391→      'rust-error-path-no-tracing.yaml',\n   392→    ];\n   393→    for (const filename of files) {\n   394→      const config = loadRule(filename);\n   395→      expect(config.rules[0].metadata?.category).toBe('observability');\n   396→      expect(config.rules[0].metadata?.cwe).toBe('CWE-778: Insufficient Logging');\n   397→    }\n   398→  });\n   399→\n   400→  it('Rust rules use tracing crate patterns only (not log crate or println)', () => {\n   401→    const files = [\n   402→      'rust-function-no-tracing.yaml',\n   403→      'rust-catch-without-tracing.yaml',\n   404→      'rust-error-path-no-tracing.yaml',\n   405→    ];\n   406→    for (const filename of files) {\n   407→      const content = readFileSync(resolve(PATCHES_DIR, filename), 'utf-8');\n   408→      // Should not reference log crate or println\n   409→      expect(content).not.toContain('println!');\n   410→      expect(content).not.toContain('log::');\n   411→      expect(content).not.toContain('eprintln!');\n   412→    }\n   413→  });\n   414→\n   415→  it('parseSemgrepOutput correctly handles Rust rule IDs', () => {\n   416→    // Import from analyzer to verify Rust rule IDs work with existing parser\n   417→    const { parseSemgrepOutput } = require('../../observability/analyzer.js');\n   418→\n   419→    const mockOutput = {\n   420→      results: [\n   421→        {\n   422→          check_id: 'rust-function-no-tracing',\n   423→          path: 'src/main.rs',\n   424→          start: { line: 10, col: 1 },\n   425→          end: { line: 15, col: 2 },\n   426→          extra: {\n   427→            message: 'Rust function without tracing instrumentation — observability gap',\n   428→            severity: 'INFO',\n   429→          },\n   430→        },\n   431→        {\n   432→          check_id: 'rust-catch-without-tracing',\n   433→          path: 'src/lib.rs',\n   434→          start: { line: 42, col: 9 },\n   435→          end: { line: 45, col: 10 },\n   436→          extra: {\n   437→            message: 'Rust error match arm without tracing — observability gap',\n   438→            severity: 'WARNING',\n   439→          },\n   440→        },\n   441→        {\n   442→          check_id: 'rust-error-path-no-tracing',\n   443→          path: 'src/handler.rs',\n   444→          start: { line: 88, col: 5 },\n   445→          end: { line: 91, col: 6 },\n   446→          extra: {\n   447→            message: 'Rust error-path closure without tracing — observability gap',\n   448→            severity: 'WARNING',\n   449→          },\n   450→        },\n   451→      ],\n   452→    };\n   453→\n   454→    const gaps = parseSemgrepOutput(mockOutput);\n   455→    expect(gaps).toHaveLength(3);\n   456→\n   457→    expect(gaps[0]).toEqual({\n   458→      file: 'src/main.rs',\n   459→      line: 10,\n   460→      type: 'rust-function-no-tracing',\n   461→      description: 'Rust function without tracing instrumentation — observability gap',\n   462→      severity: 'info',\n   463→    });\n   464→\n   465→    expect(gaps[1]).toEqual({\n   466→      file: 'src/lib.rs',\n   467→      line: 42,\n   468→      type: 'rust-catch-without-tracing',\n   469→      description: 'Rust error match arm without tracing — observability gap',\n   470→      severity: 'warning',\n   471→    });\n   472→\n   473→    expect(gaps[2]).toEqual({\n   474→      file: 'src/handler.rs',\n   475→      line: 88,\n   476→      type: 'rust-error-path-no-tracing',\n   477→      description: 'Rust error-path closure without tracing — observability gap',\n   478→      severity: 'warning',\n   479→    });\n   480→  });\n   481→\n   482→  it('computeSummary counts Rust rule IDs correctly for error handlers', () => {\n   483→    const { computeSummary } = require('../../observability/analyzer.js');\n   484→\n   485→    const gaps = [\n   486→      {\n   487→        file: 'src/main.rs', line: 10,\n   488→        type: 'rust-function-no-tracing',\n   489→        description: 'fn', severity: 'info' as const,\n   490→      },\n   491→      {\n   492→        file: 'src/lib.rs', line: 42,\n   493→        type: 'rust-catch-without-tracing',\n   494→        description: 'catch', severity: 'warning' as const,\n   495→      },\n   496→      {\n   497→        file: 'src/handler.rs', line: 88,\n   498→        type: 'rust-error-path-no-tracing',\n   499→        description: 'err', severity: 'warning' as const,\n   500→      },\n   501→    ];\n   502→\n   503→    const summary = computeSummary(gaps, { totalFunctions: 10 });\n   504→\n   505→    // rust-function-no-tracing counts as a function without logs\n   506→    expect(summary.totalFunctions).toBe(10);\n   507→    expect(summary.functionsWithLogs).toBe(9); // 10 - 1\n   508→\n   509→    // rust-catch-without-tracing and rust-error-path-no-tracing count as error handlers\n   510→    expect(summary.errorHandlersWithoutLogs).toBe(2);\n   511→  });\n   512→});\n   513→"}]},"parent_tool_use_id":"toolu_01Y5Vmp4wHswe3FNr3ap85bX","session_id":"9d3ab825-6dfa-42d3-92d1-28b7bc09852d","uuid":"aefc1bba-dc27-4cb6-b8f1-a6113095eeb7","timestamp":"2026-03-23T08:40:03.108Z"}
