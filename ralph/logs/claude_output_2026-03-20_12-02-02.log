{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SxC4Htsx6aCdRSnoxDT26d","type":"tool_result","content":"     1→/**\n     2→ * Sprint module — story selection, status tracking, reporting.\n     3→ */\n     4→\n     5→import { ok, fail } from '../../types/result.js';\n     6→import type { Result } from '../../types/result.js';\n     7→import type { StoryStatus } from '../../types/state.js';\n     8→import type { SprintState } from '../../types/state.js';\n     9→import type {\n    10→  StorySelection,\n    11→  StoryDetail,\n    12→  StatusReport,\n    13→  SelectionResult,\n    14→  FailedStoryDetail,\n    15→  LabeledActionItem,\n    16→  RunSummary,\n    17→  StoryDrillDown,\n    18→  TimeoutReport,\n    19→  TimeoutCapture,\n    20→  FeedbackResult,\n    21→  FailingAc,\n    22→  TimeoutSummary,\n    23→  RunProgressUpdate,\n    24→} from './types.js';\n    25→import {\n    26→  getSprintState as getSprintStateImpl,\n    27→  updateStoryStatus as updateStoryStatusImpl,\n    28→  writeStateAtomic as writeStateAtomicImpl,\n    29→  computeSprintCounts as computeSprintCountsImpl,\n    30→  updateRunProgress as updateRunProgressImpl,\n    31→  clearRunProgress as clearRunProgressImpl,\n    32→} from './state.js';\n    33→import { selectNextStory } from './selector.js';\n    34→import { generateReport as generateReportImpl, getStoryDrillDown as getStoryDrillDownImpl } from './reporter.js';\n    35→import { captureTimeoutReport as captureTimeoutReportImpl, findLatestTimeoutReport as findLatestTimeoutReportImpl } from './timeout.js';\n    36→import { processVerifyResult as processVerifyResultImpl } from './feedback.js';\n    37→import { validateStateConsistency as validateStateConsistencyImpl } from './validator.js';\n    38→import type { ValidationReport, ValidationIssue } from './validator.js';\n    39→\n    40→export type {\n    41→  StorySelection,\n    42→  StoryDetail,\n    43→  StatusReport,\n    44→  SelectionResult,\n    45→  FailedStoryDetail,\n    46→  LabeledActionItem,\n    47→  RunSummary,\n    48→  StoryDrillDown,\n    49→  TimeoutReport,\n    50→  TimeoutCapture,\n    51→  TimeoutSummary,\n    52→  FeedbackResult,\n    53→  FailingAc,\n    54→  RunProgressUpdate,\n    55→};\n    56→\n    57→export type { ValidationReport, ValidationIssue };\n    58→\n    59→/**\n    60→ * Select the next actionable story.\n    61→ * Also marks retry-exhausted stories as blocked (AC #2).\n    62→ */\n    63→export function getNextStory(): Result<SelectionResult> {\n    64→  const stateResult = getSprintStateImpl();\n    65→  if (!stateResult.success) {\n    66→    return fail(stateResult.error);\n    67→  }\n    68→\n    69→  const selectionResult = selectNextStory(stateResult.data);\n    70→  if (!selectionResult.success) {\n    71→    return fail(selectionResult.error);\n    72→  }\n    73→\n    74→  // Side-effect: mark retry-exhausted stories as blocked (AC #2)\n    75→  for (const exhausted of selectionResult.data.retryExhausted) {\n    76→    updateStoryStatusImpl(exhausted.key, 'blocked', {\n    77→      error: 'retry-exhausted',\n    78→    });\n    79→  }\n    80→\n    81→  return ok(selectionResult.data);\n    82→}\n    83→\n    84→export function updateStoryStatus(\n    85→  key: string,\n    86→  status: StoryStatus,\n    87→  detail?: StoryDetail,\n    88→): Result<void> {\n    89→  return updateStoryStatusImpl(key, status, detail);\n    90→}\n    91→\n    92→export function getSprintState(): Result<SprintState> {\n    93→  return getSprintStateImpl();\n    94→}\n    95→\n    96→export function generateReport(): Result<StatusReport> {\n    97→  const stateResult = getSprintStateImpl();\n    98→  if (!stateResult.success) {\n    99→    return fail(stateResult.error);\n   100→  }\n   101→  return generateReportImpl(stateResult.data);\n   102→}\n   103→\n   104→export function getStoryDrillDown(key: string): Result<StoryDrillDown> {\n   105→  const stateResult = getSprintStateImpl();\n   106→  if (!stateResult.success) {\n   107→    return fail(stateResult.error);\n   108→  }\n   109→\n   110→  // Look up latest timeout report for this story\n   111→  const timeoutResult = findLatestTimeoutReportImpl(key);\n   112→  const timeoutSummary = timeoutResult.success ? timeoutResult.data : null;\n   113→\n   114→  return getStoryDrillDownImpl(stateResult.data, key, { timeoutSummary });\n   115→}\n   116→\n   117→export function captureTimeoutReport(opts: {\n   118→  storyKey: string;\n   119→  iteration: number;\n   120→  durationMinutes: number;\n   121→  outputFile: string;\n   122→  stateSnapshotPath: string;\n   123→}): Result<TimeoutReport> {\n   124→  return captureTimeoutReportImpl(opts);\n   125→}\n   126→\n   127→export function processVerifyResult(\n   128→  storyKey: string,\n   129→  opts?: { maxAttempts?: number },\n   130→): Result<FeedbackResult> {\n   131→  return processVerifyResultImpl(storyKey, opts);\n   132→}\n   133→\n   134→export function validateStateConsistency(\n   135→  statePath: string,\n   136→  sprintStatusPath: string,\n   137→): Result<ValidationReport> {\n   138→  return validateStateConsistencyImpl(statePath, sprintStatusPath);\n   139→}\n   140→\n   141→export function writeStateAtomic(state: SprintState): Result<void> {\n   142→  return writeStateAtomicImpl(state);\n   143→}\n   144→\n   145→export function computeSprintCounts(\n   146→  stories: Record<string, import('../../types/state.js').StoryState>,\n   147→): SprintState['sprint'] {\n   148→  return computeSprintCountsImpl(stories);\n   149→}\n   150→\n   151→export function updateRunProgress(update: RunProgressUpdate): Result<void> {\n   152→  return updateRunProgressImpl(update);\n   153→}\n   154→\n   155→export function clearRunProgress(): Result<void> {\n   156→  return clearRunProgressImpl();\n   157→}\n   158→"}]},"parent_tool_use_id":"toolu_01J5AdAMYAsRdio1YgdnbwDy","session_id":"64c1e9b9-a641-40be-ae67-07aee0c47965","uuid":"8dcf02ef-294e-45c2-809f-cc31177418f5","