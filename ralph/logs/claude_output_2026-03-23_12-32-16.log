{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016eEuxoyuoA6JEDJKkRQRZV","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→\n     3→vi.mock('node:child_process', () => ({\n     4→  execFileSync: vi.fn(),\n     5→}));\n     6→\n     7→import {\n     8→  analyze,\n     9→  checkSemgrepInstalled,\n    10→  runSemgrep,\n    11→  parseSemgrepOutput,\n    12→  computeSummary,\n    13→} from '../analyzer.js';\n    14→import { analyze as analyzeFromBarrel } from '../index.js';\n    15→import { execFileSync } from 'node:child_process';\n    16→import type { SemgrepRawOutput } from '../types.js';\n    17→\n    18→const mockExecFileSync = vi.mocked(execFileSync);\n    19→\n    20→beforeEach(() => {\n    21→  vi.clearAllMocks();\n    22→});\n    23→\n    24→// -- Helper: build a minimal Semgrep raw output --\n    25→function makeSemgrepOutput(\n    26→  results: SemgrepRawOutput['results'],\n    27→): SemgrepRawOutput {\n    28→  return { results };\n    29→}\n    30→\n    31→function makeSemgrepResult(overrides: Partial<SemgrepRawOutput['results'][0]> = {}) {\n    32→  return {\n    33→    check_id: 'catch-without-logging',\n    34→    path: 'src/lib/docker.ts',\n    35→    start: { line: 42, col: 5 },\n    36→    end: { line: 42, col: 50 },\n    37→    extra: {\n    38→      message: 'Catch block without error logging',\n    39→      severity: 'WARNING',\n    40→    },\n    41→    ...overrides,\n    42→  };\n    43→}\n    44→\n    45→// ============================================================\n    46→// Module barrel export (index.ts)\n    47→// ============================================================\n    48→\n    49→describe('module barrel export', () => {\n    50→  it('re-exports analyze from index.ts', () => {\n    51→    expect(analyzeFromBarrel).toBe(analyze);\n    52→  });\n    53→});\n    54→\n    55→// ============================================================\n    56→// checkSemgrepInstalled\n    57→// ============================================================\n    58→\n    59→describe('checkSemgrepInstalled', () => {\n    60→  it('returns true when semgrep --version succeeds', () => {\n    61→    mockExecFileSync.mockReturnValue(Buffer.from('1.50.0'));\n    62→    expect(checkSemgrepInstalled()).toBe(true);\n    63→    expect(mockExecFileSync).toHaveBeenCalledWith(\n    64→      'semgrep',\n    65→      ['--version'],\n    66→      expect.objectContaining({ encoding: 'utf-8', timeout: 5_000 }),\n    67→    );\n    68→  });\n    69→\n    70→  it('returns false when semgrep is not installed', () => {\n    71→    mockExecFileSync.mockImplementation(() => {\n    72→      throw new Error('ENOENT');\n    73→    });\n    74→    expect(checkSemgrepInstalled()).toBe(false);\n    75→  });\n    76→});\n    77→\n    78→// ============================================================\n    79→// runSemgrep\n    80→// ============================================================\n    81→\n    82→describe('runSemgrep', () => {\n    83→  it('spawns semgrep with correct arguments and parses JSON output', () => {\n    84→    const rawOutput = makeSemgrepOutput([makeSemgrepResult()]);\n    85→    mockExecFileSync.mockReturnValue(JSON.stringify(rawOutput));\n    86→\n    87→    const result = runSemgrep('/project', '/project/patches/observability/');\n    88→    expect(result.success).toBe(true);\n    89→    if (result.success) {\n    90→      expect(result.data.results).toHaveLength(1);\n    91→      expect(result.data.results[0].check_id).toBe('catch-without-logging');\n    92→    }\n    93→\n    94→    expect(mockExecFileSync).toHaveBeenCalledWith(\n    95→      'semgrep',\n    96→      ['scan', '--config', '/project/patches/observability/', '--json', '/project'],\n    97→      expect.objectContaining({ encoding: 'utf-8', timeout: 60_000 }),\n    98→    );\n    99→  });\n   100→\n   101→  it('returns fail when semgrep crashes', () => {\n   102→    mockExecFileSync.mockImplementation(() => {\n   103→      throw new Error('semgrep crashed');\n   104→    });\n   105→\n   106→    const result = runSemgrep('/project', '/rules');\n   107→    expect(result.success).toBe(false);\n   108→    if (!result.success) {\n   109→      expect(result.error).toContain('Semgrep scan failed');\n   110→    }\n   111→  });\n   112→\n   113→  it('accepts a custom timeout', () => {\n   114→    mockExecFileSync.mockReturnValue(JSON.stringify(makeSemgrepOutput([])));\n   115→\n   116→    runSemgrep('/project', '/rules', 30_000);\n   117→    expect(mockExecFileSync).toHaveBeenCalledWith(\n   118→      'semgrep',\n   119→      expect.any(Array),\n   120→      expect.objectContaining({ timeout: 30_000 }),\n   121→    );\n   122→  });\n   123→\n   124→  it('returns fail when semgrep returns invalid JSON without results array', () => {\n   125→    mockExecFileSync.mockReturnValue(JSON.stringify({ errors: [] }));\n   126→\n   127→    const result = runSemgrep('/project', '/rules');\n   128→    expect(result.success).toBe(false);\n   129→    if (!result.success) {\n   130→      expect(result.error).toContain('invalid JSON: missing results array');\n   131→    }\n   132→  });\n   133→\n   134→  it('returns fail when semgrep returns non-object JSON', () => {\n   135→    mockExecFileSync.mockReturnValue('\"just a string\"');\n   136→\n   137→    const result = runSemgrep('/project', '/rules');\n   138→    expect(result.success).toBe(false);\n   139→    if (!result.success) {\n   140→      expect(result.error).toContain('invalid JSON: missing results array');\n   141→    }\n   142→  });\n   143→\n   144→  it('returns fail when semgrep returns null JSON', () => {\n   145→    mockExecFileSync.mockReturnValue('null');\n   146→\n   147→    const result = runSemgrep('/project', '/rules');\n   148→    expect(result.success).toBe(false);\n   149→    if (!result.success) {\n   150→      expect(result.error).toContain('invalid JSON: missing results array');\n   151→    }\n   152→  });\n   153→});\n   154→\n   155→// ============================================================\n   156→// parseSemgrepOutput\n   157→// ============================================================\n   158→\n   159→describe('parseSemgrepOutput', () => {\n   160→  it('maps Semgrep JSON results to ObservabilityGap[]', () => {\n   161→    const raw = makeSemgrepOutput([\n   162→      makeSemgrepResult({\n   163→        check_id: 'catch-without-logging',\n   164→        path: 'src/lib/docker.ts',\n   165→        start: { line: 42, col: 5 },\n   166→        extra: { message: 'Catch block without error logging', severity: 'WARNING' },\n   167→      }),\n   168→      makeSemgrepResult({\n   169→        check_id: 'function-no-debug-log',\n   170→        path: 'src/lib/scanner.ts',\n   171→        start: { line: 10, col: 1 },\n   172→        extra: { message: 'Function without debug log', severity: 'INFO' },\n   173→      }),\n   174→    ]);\n   175→\n   176→    const gaps = parseSemgrepOutput(raw);\n   177→    expect(gaps).toHaveLength(2);\n   178→\n   179→    expect(gaps[0]).toEqual({\n   180→      file: 'src/lib/docker.ts',\n   181→      line: 42,\n   182→      type: 'catch-without-logging',\n   183→      description: 'Catch block without error logging',\n   184→      severity: 'warning',\n   185→    });\n   186→\n   187→    expect(gaps[1]).toEqual({\n   188→      file: 'src/lib/scanner.ts',\n   189→      line: 10,\n   190→      type: 'function-no-debug-log',\n   191→      description: 'Function without debug log',\n   192→      severity: 'info',\n   193→    });\n   194→  });\n   195→\n   196→  it('normalizes ERROR severity to error', () => {\n   197→    const raw = makeSemgrepOutput([\n   198→      makeSemgrepResult({\n   199→        extra: { message: 'bad', severity: 'ERROR' },\n   200→      }),\n   201→    ]);\n   202→    const gaps = parseSemgrepOutput(raw);\n   203→    expect(gaps[0].severity).toBe('error');\n   204→  });\n   205→\n   206→  it('normalizes unknown severity to info', () => {\n   207→    const raw = makeSemgrepOutput([\n   208→      makeSemgrepResult({\n   209→        extra: { message: 'note', severity: 'NOTE' },\n   210→      }),\n   211→    ]);\n   212→    const gaps = parseSemgrepOutput(raw);\n   213→    expect(gaps[0].severity).toBe('info');\n   214→  });\n   215→\n   216→  it('returns empty array for empty results', () => {\n   217→    const raw = makeSemgrepOutput([]);\n   218→    expect(parseSemgrepOutput(raw)).toEqual([]);\n   219→  });\n   220→\n   221→  it('returns empty array when results is undefined', () => {\n   222→    // Defensive: handle malformed input even though types say otherwise\n   223→    const raw = {} as SemgrepRawOutput;\n   224→    expect(parseSemgrepOutput(raw)).toEqual([]);\n   225→  });\n   226→\n   227→  it('returns empty array when results is not an array', () => {\n   228→    const raw = { results: 'not-an-array' } as unknown as SemgrepRawOutput;\n   229→    expect(parseSemgrepOutput(raw)).toEqual([]);\n   230→  });\n   231→});\n   232→\n   233→// ============================================================\n   234→// computeSummary\n   235→// ============================================================\n   236→\n   237→describe('computeSummary', () => {\n   238→  it('computes 75% coverage for 20 functions with 15 having logs (AC #5)', () => {\n   239→    // 5 functions without logs = 5 function-no-debug-log matches\n   240→    const gaps = Array.from({ length: 5 }, (_, i) => ({\n   241→      file: `src/file${i}.ts`,\n   242→      line: i + 1,\n   243→      type: 'function-no-debug-log' as const,\n   244→      description: 'Function without debug log',\n   245→      severity: 'warning' as const,\n   246→    }));\n   247→\n   248→    const summary = computeSummary(gaps, { totalFunctions: 20 });\n   249→    expect(summary.totalFunctions).toBe(20);\n   250→    expect(summary.functionsWithLogs).toBe(15);\n   251→    expect(summary.coveragePercent).toBe(75);