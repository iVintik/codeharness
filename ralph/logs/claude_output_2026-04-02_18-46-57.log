{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01MyNwGuBdZ3cAYjKBhxR5LK","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Y3o8bjKDKsYnyrsyabUiGL","name":"Write","input":{"file_path":"/Users/ivintik/dev/personal/codeharness/src/commands/validate.ts","content":"/**\n * CLI command: codeharness validate\n * Parent command with subcommands: schema, self\n * - validate schema: validate workflow YAML files against JSON schemas (Story 2-5)\n * - validate self: run self-validation cycle and produce release gate report (Story 10-3)\n * - validate (no subcommand): defaults to schema validation\n */\nimport { Command } from 'commander';\nimport { registerValidateSchemaCommand, runSchemaValidation } from './validate-schema.js';\nimport { registerValidateSelfCommand } from './validate-self.js';\nimport { ok, fail, jsonOutput } from '../lib/output.js';\n\nexport function registerValidateCommand(program: Command): void {\n  const validateCmd = program\n    .command('validate')\n    .description('Validate workflow YAML files (default) or run self-validation')\n    .action((_opts: Record<string, unknown>, cmd: Command) => {\n      // Default action when no subcommand given: run schema validation\n      const isJson = (cmd.optsWithGlobals() as { json?: boolean }).json === true;\n      const result = runSchemaValidation(process.cwd());\n\n      if (isJson) {\n        jsonOutput(result as unknown as Record<string, unknown>);\n        process.exitCode = result.status === 'pass' ? 0 : 1;\n        return;\n      }\n\n      for (const file of result.files) {\n        if (file.valid) {\n          ok(`Schema: ${file.path}`);\n        } else {\n          fail(`Schema: ${file.path}`);\n          for (const error of file.errors) {\n            console.log(`  ${error.path}: ${error.message}`);\n          }\n        }\n      }\n\n      process.exitCode = result.status === 'pass' ? 0 : 1;\n    });\n\n  registerValidateSchemaCommand(validateCmd);\n  registerValidateSelfCommand(validateCmd);\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1277,"cache_read_input_tokens":33303,"cache_creation":{"ephemeral_5m_input_tokens":1277,"ephemeral_1h_input_tokens":0},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_019SoUcSY6ykbxKMMLbKRkDH","session_id":"5fca15c0-771e-463c-9e4f-c528b230e359","uuid":"bf23162a-6e60-4db6-8895-14ee5ebb7fd5"}
