ck.\n144\t * Simulates what the real driver.dispatch() returns.\n145\t */\n146\tfunction makeDriverStream(output: string, sessionId: string, opts?: { error?: string; errorCategory?: string }) {\n147\t  return (async function* () {\n148\t    if (output) {\n149\t      yield { type: 'text' as const, text: output };\n150\t    }\n151\t    yield {\n152\t      type: 'result' as const,\n153\t      cost: 0.05,\n154\t      sessionId,\n155\t      ...(opts?.error ? { error: opts.error, errorCategory: opts.errorCategory ?? 'UNKNOWN' } : {}),\n156\t    };\n157\t  })();\n158\t}\n159\t\n160\t/**\n161\t * Helper: create an async iterable that throws an error (for testing dispatch failures).\n162\t */\n163\tfunction makeDriverStreamError(err: unknown) {\n164\t  return (async function* () {\n165\t    throw err;\n166\t  })();\n167\t}\n168\t\n169\tfunction makeDefaultState(overrides?: Partial<WorkflowState>): WorkflowState {\n170\t  return {\n171\t    workflow_name: '',\n172\t    started: '',\n173\t    iteration: 0,\n174\t    phase: 'idle',\n175\t    tasks_completed: [],\n176\t    evaluator_scores: [],\n177\t    circuit_breaker: { triggered: false, reason: null, score_history: [] },\n178\t    trace_ids: [],\n179\t    ...overrides,\n180\t  };\n181\t}\n182\t\n183\tfunction makeDefinition(overrides?: Partial<SubagentDefinition>): SubagentDefinition {\n184\t  return {\n185\t    name: 'test-agent',\n186\t    model: 'claude-sonnet-4-20250514',\n187\t    instructions: 'You are a test agent.',\n188\t    disallowedTools: [],\n189\t    bare: true,\n190\t    ...overrides,\n191\t  };\n192\t}\n193\t\n194\tfunction makeTask(overrides?: Partial<ResolvedTask>): ResolvedTask {\n195\t  return {\n196\t    agent: 'dev',\n197\t    scope: 'per-story',\n198\t    session: 'fresh',\n199\t    source_access: true,"}]},"parent_tool_use_id":"toolu_01PJ1ZaMtGAYgkx9N7rYqNxX","session_id":"49777568-67d3-419d-b985-1c272283fc99","uuid":"df4fcb83-6a38-4239-a727-e9924e849027","timestamp":"2026-04-03T12:30:21.555Z"}
