{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016qHa9fD4U4XWeMGK9dg3k5","type":"tool_result","content":"110\t          const msg = err instanceof Error ? err.message : String(err);\n111\t          errors.push({\n112\t            path: `/tasks/${taskName}/agent`,\n113\t            message: `Agent \"${task.agent}\" in task \"${taskName}\" failed to resolve: ${msg}`,\n114\t          });\n115\t        }\n116\t      }\n117\t    }\n118\t  }\n119\t}\n120\t\n121\t// --- Shared Validation & Resolution ---\n122\t\n123\t/**\n124\t * Validate parsed YAML against JSON schema, check referential integrity,\n125\t * apply defaults, and return a typed ResolvedWorkflow.\n126\t * Shared between parseWorkflow (direct file) and resolveWorkflow (patch chain).\n127\t */\n128\tfunction validateAndResolve(parsed: unknown): ResolvedWorkflow {\n129\t  // Validate against JSON schema\n130\t  const result = validateWorkflowSchema(parsed);\n131\t  if (!result.valid) {\n132\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n133\t    throw new WorkflowParseError(\n134\t      `Schema validation failed: ${details}`,\n135\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n136\t    );\n137\t  }\n138\t\n139\t  // At this point, parsed has passed schema validation — safe to cast\n140\t  const data = parsed as { tasks: Record<string, Record<string, unknown>>; flow: unknown[] };\n141\t\n142\t  // Referential integrity check — collect all errors before throwing\n143\t  const taskNames = new Set(Object.keys(data.tasks));\n144\t  const allErrors: Array<{ path: string; message: string }> = [];\n145\t\n146\t  // 1. Flow-to-task dangling reference check\n147\t  for (let i = 0; i < data.flow.length; i++) {\n148\t    const step = data.flow[i];\n149\t    if (typeof step === 'string') {\n150\t      if (!taskNames.has(step)) {\n151\t        allErrors.push({\n152\t          path: `/flow/${i}`,\n153\t          message: `Task \"${step}\" referenced in flow but not defined in tasks`,\n154\t        });\n155\t      }\n156\t    } else if (typeof step === 'object' && step !== null && 'loop' in step) {\n157\t      const loopBlock = step as { loop: string[] };\n158\t      for (let j = 0; j < loopBlock.loop.length; j++) {\n159\t        const ref = loopBlock.loop[j];\n160\t        if (!taskNames.has(ref)) {\n161\t          allErrors.push({\n162\t            path: `/flow/${i}/loop/${j}`,\n163\t            message: `Task \"${ref}\" referenced in loop but not defined in tasks`,\n164\t          });\n165\t        }\n166\t      }\n167\t    }\n168\t  }\n169\t\n170\t  // 2. Driver and agent referential integrity check\n171\t  validateReferentialIntegrity(data, allErrors);\n172\t\n173\t  if (allErrors.length > 0) {\n174\t    const details = allErrors.map((e) => e.message).join('; ');\n175\t    throw new WorkflowParseError(`Referential integrity errors: ${details}`, allErrors);\n176\t  }\n177\t\n178\t  // Apply defaults and build resolved tasks\n179\t  const resolvedTasks: Record<string, ResolvedTask> = {};"}]},"parent_tool_use_id":"toolu_01NbvnX8QKy5nChzR2X7gMdM","session_id":"4b1f7711-6ed7-4488-a0af-b261e761b450","uuid":"b8fcf010-d4c0-4db6-a911-5c9d92d9c63c","timestamp":"2026-04-03T08:42:50.921Z"}
