{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01E8qfttvGVsCJ7GntBXFHuJ","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { render } from 'ink-testing-library';\n3\timport React from 'react';\n4\timport { WorkflowGraph, formatCost, formatElapsed } from '../ink-workflow.js';\n5\timport type { TaskNodeState, TaskNodeMeta } from '../ink-components.js';\n6\timport type { FlowStep } from '../workflow-parser.js';\n7\t\n8\t/** Spinner frames used by TaskNode for active state. */\n9\tconst SPINNER_FRAMES = ['⠋', '⠙', '⠹', '⠸', '⠼', '⠴', '⠦', '⠧', '⠇', '⠏'];\n10\t\n11\tdescribe('WorkflowGraph component', () => {\n12\t  it('renders sequential flow as task1 → task2 → task3', () => {\n13\t    const flow: FlowStep[] = ['create-story', 'implement', 'verify'];\n14\t    const taskStates: Record<string, TaskNodeState> = {\n15\t      'create-story': 'done',\n16\t      'implement': 'active',\n17\t      'verify': 'pending',\n18\t    };\n19\t    const { lastFrame } = render(\n20\t      <WorkflowGraph flow={flow} currentTask=\"implement\" taskStates={taskStates} />\n21\t    );\n22\t    const frame = lastFrame()!;\n23\t    expect(frame).toContain('create-story');\n24\t    expect(frame).toContain('→');\n25\t    expect(frame).toContain('implement');\n26\t    expect(frame).toContain('verify');\n27\t  });\n28\t\n29\t  it('renders loop block as loop(N)[ task1 → task2 ]', () => {\n30\t    const flow: FlowStep[] = ['create-story', { loop: ['implement', 'verify'] }];\n31\t    const taskStates: Record<string, TaskNodeState> = {\n32\t      'create-story': 'done',\n33\t      'implement': 'active',\n34\t      'verify': 'pending',\n35\t    };\n36\t    const { lastFrame } = render(\n37\t      <WorkflowGraph flow={flow} currentTask=\"implement\" taskStates={taskStates} />\n38\t    );\n39\t    const frame = lastFrame()!;\n40\t    expect(frame).toContain('loop(');\n41\t    expect(frame).toContain('[ ');\n42\t    expect(frame).toContain('implement');\n43\t    expect(frame).toContain('verify');\n44\t    expect(frame).toContain(' ]');\n45\t  });\n46\t\n47\t  it('renders pending tasks with dim text (no status symbols)', () => {\n48\t    const flow: FlowStep[] = ['task1'];\n49\t    const taskStates: Record<string, TaskNodeState> = { 'task1': 'pending' };\n50\t    const { lastFrame } = render(\n51\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} />\n52\t    );\n53\t    const frame = lastFrame()!;\n54\t    expect(frame).toContain('task1');\n55\t    // Pending should NOT have status symbols\n56\t    expect(frame).not.toContain('✓');\n57\t    expect(frame).not.toContain('✗');\n58\t    // Should not contain any spinner frame\n59\t    for (const sf of SPINNER_FRAMES) {\n60\t      expect(frame).not.toContain(sf);\n61\t    }\n62\t  });\n63\t\n64\t  it('renders active task with spinner indicator in cyan', () => {\n65\t    const flow: FlowStep[] = ['task1'];\n66\t    const taskStates: Record<string, TaskNodeState> = { 'task1': 'active' };\n67\t    const { lastFrame } = render(\n68\t      <WorkflowGraph flow={flow} currentTask=\"task1\" taskStates={taskStates} />\n69\t    );\n70\t    const frame = lastFrame()!;\n71\t    // Should contain one of the spinner frames\n72\t    const hasSpinner = SPINNER_FRAMES.some(sf => frame.includes(sf));\n73\t    expect(hasSpinner).toBe(true);\n74\t    expect(frame).toContain('task1');\n75\t  });\n76\t\n77\t  it('renders completed task with ✓', () => {\n78\t    const flow: FlowStep[] = ['task1'];\n79\t    const taskStates: Record<string, TaskNodeState> = { 'task1': 'done' };\n80\t    const { lastFrame } = render(\n81\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} />\n82\t    );\n83\t    const frame = lastFrame()!;\n84\t    expect(frame).toContain('✓');\n85\t    expect(frame).toContain('task1');\n86\t  });\n87\t\n88\t  it('renders failed task with ✗', () => {\n89\t    const flow: FlowStep[] = ['task1'];\n90\t    const taskStates: Record<string, TaskNodeState> = { 'task1': 'failed' };\n91\t    const { lastFrame } = render(\n92\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} />\n93\t    );\n94\t    const frame = lastFrame()!;\n95\t    expect(frame).toContain('✗');\n96\t    expect(frame).toContain('task1');\n97\t  });\n98\t\n99\t  it('returns null for empty flow', () => {\n100\t    const { lastFrame } = render(\n101\t      <WorkflowGraph flow={[]} currentTask={null} taskStates={{ task1: 'pending' }} />\n102\t    );\n103\t    expect(lastFrame()).toBe('');\n104\t  });\n105\t\n106\t  it('returns null for empty taskStates', () => {\n107\t    const { lastFrame } = render(\n108\t      <WorkflowGraph flow={['task1']} currentTask={null} taskStates={{}} />\n109\t    );\n110\t    expect(lastFrame()).toBe('');\n111\t  });\n112\t\n113\t  it('renders loop block with iteration 0 when all tasks are pending', () => {\n114\t    const flow: FlowStep[] = [{ loop: ['implement', 'verify'] }];\n115\t    const taskStates: Record<string, TaskNodeState> = {\n116\t      'implement': 'pending',\n117\t      'verify': 'pending',\n118\t    };\n119\t    const { lastFrame } = render(\n120\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} />\n121\t    );\n122\t    const frame = lastFrame()!;\n123\t    expect(frame).toContain('loop(0)');\n124\t    expect(frame).toContain('implement');\n125\t    expect(frame).toContain('verify');\n126\t  });\n127\t\n128\t  it('renders loop block with iteration 1 when a task is done', () => {\n129\t    const flow: FlowStep[] = [{ loop: ['implement', 'verify'] }];\n130\t    const taskStates: Record<string, TaskNodeState> = {\n131\t      'implement': 'done',\n132\t      'verify': 'pending',\n133\t    };\n134\t    const { lastFrame } = render(\n135\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} />\n136\t    );\n137\t    const frame = lastFrame()!;\n138\t    expect(frame).toContain('loop(1)');\n139\t  });\n140\t\n141\t  it('renders loop block with iteration 1 when a task has failed', () => {\n142\t    const flow: FlowStep[] = [{ loop: ['implement', 'verify'] }];\n143\t    const taskStates: Record<string, TaskNodeState> = {\n144\t      'implement': 'failed',\n145\t      'verify': 'pending',\n146\t    };\n147\t    const { lastFrame } = render(\n148\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} />\n149\t    );\n150\t    const frame = lastFrame()!;\n151\t    expect(frame).toContain('loop(1)');\n152\t  });\n153\t\n154\t  it('renders mixed flow with sequential and loop steps', () => {\n155\t    const flow: FlowStep[] = ['create-story', { loop: ['implement', 'verify'] }, 'deploy'];\n156\t    const taskStates: Record<string, TaskNodeState> = {\n157\t      'create-story': 'done',\n158\t      'implement': 'done',\n159\t      'verify': 'active',\n160\t      'deploy': 'pending',\n161\t    };\n162\t    const { lastFrame } = render(\n163\t      <WorkflowGraph flow={flow} currentTask=\"verify\" taskStates={taskStates} />\n164\t    );\n165\t    const frame = lastFrame()!;\n166\t    expect(frame).toContain('create-story');\n167\t    expect(frame).toContain('✓');\n168\t    expect(frame).toContain('loop(');\n169\t    expect(frame).toContain('implement');\n170\t    expect(frame).toContain('verify');\n171\t    expect(frame).toContain('deploy');\n172\t    // Separator lines\n173\t    expect(frame).toContain('━');\n174\t  });\n175\t\n176\t  // --- Driver label tests (AC #5) ---\n177\t\n178\t  it('renders driver label below task name when taskMeta is provided', () => {\n179\t    const flow: FlowStep[] = ['implement', 'verify'];\n180\t    const taskStates: Record<string, TaskNodeState> = {\n181\t      'implement': 'done',\n182\t      'verify': 'active',\n183\t    };\n184\t    const taskMeta: Record<string, TaskNodeMeta> = {\n185\t      'implement': { driver: 'claude-code' },\n186\t      'verify': { driver: 'codex' },\n187\t    };\n188\t    const { lastFrame } = render(\n189\t      <WorkflowGraph flow={flow} currentTask=\"verify\" taskStates={taskStates} taskMeta={taskMeta} />\n190\t    );\n191\t    const frame = lastFrame()!;\n192\t    expect(frame).toContain('claude-code');\n193\t    expect(frame).toContain('codex');\n194\t  });\n195\t\n196\t  // --- Cost/time tests (AC #6, #7) ---\n197\t\n198\t  it('renders cost and elapsed time for completed tasks', () => {\n199\t    const flow: FlowStep[] = ['implement'];\n200\t    const taskStates: Record<string, TaskNodeState> = {\n201\t      'implement': 'done',\n202\t    };\n203\t    const taskMeta: Record<string, TaskNodeMeta> = {\n204\t      'implement': { driver: 'claude-code', costUsd: 0.42, elapsedMs: 240000 },\n205\t    };\n206\t    const { lastFrame } = render(\n207\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} taskMeta={taskMeta} />\n208\t    );\n209\t    const frame = lastFrame()!;\n210\t    expect(frame).toContain('$0.42');\n211\t    expect(frame).toContain('4m');\n212\t  });\n213\t\n214\t  it('renders ... for null cost and normal elapsed time', () => {\n215\t    const flow: FlowStep[] = ['implement'];\n216\t    const taskStates: Record<string, TaskNodeState> = {\n217\t      'implement': 'done',\n218\t    };\n219\t    const taskMeta: Record<string, TaskNodeMeta> = {\n220\t      'implement': { driver: 'codex', costUsd: null, elapsedMs: 120000 },\n221\t    };\n222\t    const { lastFrame } = render(\n223\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} taskMeta={taskMeta} />\n224\t    );\n225\t    const frame = lastFrame()!;\n226\t    expect(frame).toContain('...');\n227\t    expect(frame).toContain('2m');\n228\t    // Should NOT show $0.00\n229\t    expect(frame).not.toContain('$0.00');\n230\t  });\n231\t\n232\t  it('does not render cost row for non-completed tasks', () => {\n233\t    const flow: FlowStep[] = ['implement'];\n234\t    const taskStates: Record<string, TaskNodeState> = {\n235\t      'implement': 'active',\n236\t    };\n237\t    const taskMeta: Record<string, TaskNodeMeta> = {\n238\t      'implement': { driver: 'claude-code', costUsd: 0.42, elapsedMs: 240000 },\n239\t    };\n240\t    const { lastFrame } = render(\n241\t      <WorkflowGraph flow={flow} currentTask=\"implement\" taskStates={taskStates} taskMeta={taskMeta} />\n242\t    );\n243\t    const frame = lastFrame()!;\n244\t    // Driver should still show\n245\t    expect(frame).toContain('claude-code');\n246\t    // Cost should NOT show for active tasks\n247\t    expect(frame).not.toContain('$0.42');\n248\t  });\n249\t\n250\t  // --- taskMeta prop acceptance test (AC #9) ---\n251\t\n252\t  it('accepts taskMeta prop and influences rendering', () => {\n253\t    const flow: FlowStep[] = ['implement', 'verify'];\n254\t    const taskStates: Record<string, TaskNodeState> = {\n255\t      'implement': 'done',\n256\t      'verify': 'pending',\n257\t    };\n258\t    const taskMeta: Record<string, TaskNodeMeta> = {\n259\t      'implement': { driver: 'opencode', costUsd: 1.23, elapsedMs: 45000 },\n260\t    };\n261\t    const { lastFrame } = render(\n262\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} taskMeta={taskMeta} />\n263\t    );\n264\t    const frame = lastFrame()!;\n265\t    expect(frame).toContain('opencode');\n266\t    expect(frame).toContain('$1.23');\n267\t    expect(frame).toContain('45s');\n268\t  });\n269\t\n270\t  // --- Driver labels in loop blocks (AC #5 with loops) ---\n271\t\n272\t  it('renders driver labels for tasks inside loop blocks', () => {\n273\t    const flow: FlowStep[] = ['create-story', { loop: ['implement', 'verify'] }];\n274\t    const taskStates: Record<string, TaskNodeState> = {\n275\t      'create-story': 'done',\n276\t      'implement': 'done',\n277\t      'verify': 'active',\n278\t    };\n279\t    const taskMeta: Record<string, TaskNodeMeta> = {\n280\t      'create-story': { driver: 'claude-code' },\n281\t      'implement': { driver: 'codex', costUsd: 0.50, elapsedMs: 180000 },\n282\t      'verify': { driver: 'opencode' },\n283\t    };\n284\t    const { lastFrame } = render(\n285\t      <WorkflowGraph flow={flow} currentTask=\"verify\" taskStates={taskStates} taskMeta={taskMeta} />\n286\t    );\n287\t    const frame = lastFrame()!;\n288\t    expect(frame).toContain('claude-code');\n289\t    expect(frame).toContain('codex');\n290\t    expect(frame).toContain('opencode');\n291\t    expect(frame).toContain('$0.50');\n292\t    expect(frame).toContain('3m');\n293\t  });\n294\t\n295\t  // --- Backward compatibility: no taskMeta renders identically to single-line ---\n296\t\n297\t  it('renders single-line format when taskMeta is empty', () => {\n298\t    const flow: FlowStep[] = ['implement', 'verify'];\n299\t    const taskStates: Record<string, TaskNodeState> = {\n300\t      'implement': 'done',\n301\t      'verify': 'pending',\n302\t    };\n303\t    const { lastFrame: withoutMeta } = render(\n304\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} />\n305\t    );\n306\t    const { lastFrame: withEmptyMeta } = render(\n307\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} taskMeta={{}} />\n308\t    );\n309\t    expect(withoutMeta()).toBe(withEmptyMeta());\n310\t  });\n311\t});\n312\t\n313\t// --- Format helper tests ---\n314\t\n315\tdescribe('formatCost', () => {\n316\t  it('formats positive cost as $X.XX', () => {\n317\t    expect(formatCost(0.42)).toBe('$0.42');\n318\t    expect(formatCost(1.5)).toBe('$1.50');\n319\t    expect(formatCost(0)).toBe('$0.00');\n320\t    expect(formatCost(12.345)).toBe('$12.35');\n321\t  });\n322\t\n323\t  it('returns ... for null', () => {\n324\t    expect(formatCost(null)).toBe('...');\n325\t  });\n326\t\n327\t  it('returns ... for undefined', () => {\n328\t    expect(formatCost(undefined)).toBe('...');\n329\t  });\n330\t});\n331\t\n332\tdescribe('formatElapsed', () => {\n333\t  it('formats seconds < 60 as Xs', () => {\n334\t    expect(formatElapsed(5000)).toBe('5s');\n335\t    expect(formatElapsed(45000)).toBe('45s');\n336\t    expect(formatElapsed(59000)).toBe('59s');\n337\t  });\n338\t\n339\t  it('formats seconds >= 60 as Xm', () => {\n340\t    expect(formatElapsed(60000)).toBe('1m');\n341\t    expect(formatElapsed(120000)).toBe('2m');\n342\t    expect(formatElapsed(240000)).toBe('4m');\n343\t  });\n344\t\n345\t  it('returns ... for null', () => {\n346\t    expect(formatElapsed(null)).toBe('...');\n347\t  });\n348\t\n349\t  it('returns ... for undefined', () => {\n350\t    expect(formatElapsed(undefined)).toBe('...');\n351\t  });\n352\t\n353\t  it('rounds to nearest second', () => {\n354\t    expect(formatElapsed(1500)).toBe('2s');\n355\t    expect(formatElapsed(500)).toBe('1s');\n356\t  });\n357\t\n358\t  it('floors minutes for fractional values', () => {\n359\t    // 90s = 1.5m → should show 1m not 2m\n360\t    expect(formatElapsed(90000)).toBe('1m');\n361\t    // 150s = 2.5m → should show 2m not 3m\n362\t    expect(formatElapsed(150000)).toBe('2m');\n363\t    // 89.999s rounds to 90s → 1m\n364\t    expect(formatElapsed(89999)).toBe('1m');\n365\t  });\n366\t\n367\t  it('returns 0s for 0ms', () => {\n368\t    expect(formatElapsed(0)).toBe('0s');\n369\t  });\n370\t});\n371\t"}]},"parent_tool_use_id":"toolu_01NegsqtPRQ2T1bc3NRcgCgq","session_id":"568bb8a3-7cec-4d55-8fe6-c91654e95e9c","uuid":"ee2ab007-5956-4937-bcdc-07cc69e153a1","timestamp":"2026-04-03T23:49:41.809Z"}
