{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0168asGoSiPxfazrTTsPEJrX","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { render } from 'ink-testing-library';\n3\timport React from 'react';\n4\timport { LaneContainer, CollapsedLanes, getLayoutMode } from '../ink-lane-container.js';\n5\timport type { LaneData, CollapsedLaneData } from '../ink-lane-container.js';\n6\t\n7\tfunction makeLane(overrides?: Partial<LaneData>): LaneData {\n8\t  return {\n9\t    epicId: '10',\n10\t    epicTitle: 'Driver Interface',\n11\t    currentStory: '10-3',\n12\t    phase: 'dev',\n13\t    acProgress: '4/9',\n14\t    storyProgressEntries: [\n15\t      { key: '10-1', status: 'done' },\n16\t      { key: '10-2', status: 'done' },\n17\t      { key: '10-3', status: 'in-progress' },\n18\t    ],\n19\t    driver: 'claude-code',\n20\t    cost: 4.20,\n21\t    elapsedTime: 1080000,\n22\t    ...overrides,\n23\t  };\n24\t}\n25\t\n26\tdescribe('getLayoutMode', () => {\n27\t  it('returns side-by-side for width >= 120', () => {\n28\t    expect(getLayoutMode(120)).toBe('side-by-side');\n29\t    expect(getLayoutMode(200)).toBe('side-by-side');\n30\t  });\n31\t\n32\t  it('returns stacked for width 80-119', () => {\n33\t    expect(getLayoutMode(80)).toBe('stacked');\n34\t    expect(getLayoutMode(100)).toBe('stacked');\n35\t    expect(getLayoutMode(119)).toBe('stacked');\n36\t  });\n37\t\n38\t  it('returns single for width < 80', () => {\n39\t    expect(getLayoutMode(79)).toBe('single');\n40\t    expect(getLayoutMode(40)).toBe('single');\n41\t    expect(getLayoutMode(1)).toBe('single');\n42\t  });\n43\t});\n44\t\n45\tdescribe('LaneContainer component', () => {\n46\t  it('exports LaneContainer and related types', () => {\n47\t    expect(LaneContainer).toBeDefined();\n48\t    expect(typeof LaneContainer).toBe('function');\n49\t  });\n50\t\n51\t  it('returns null for empty lanes array', () => {\n52\t    const { lastFrame } = render(\n53\t      <LaneContainer lanes={[]} terminalWidth={120} />\n54\t    );\n55\t    expect(lastFrame()).toBe('');\n56\t  });\n57\t\n58\t  it('renders side-by-side layout when terminalWidth >= 120 and 2 lanes', () => {\n59\t    const lanes = [\n60\t      makeLane({ epicId: '10', epicTitle: 'Driver Interface' }),\n61\t      makeLane({ epicId: '14', epicTitle: 'Workflow Schema', currentStory: '14-1' }),\n62\t    ];\n63\t    const { lastFrame } = render(\n64\t      <LaneContainer lanes={lanes} terminalWidth={120} />\n65\t    );\n66\t    const frame = lastFrame()!;\n67\t    // Both lanes should be visible\n68\t    expect(frame).toContain('Epic 10');\n69\t    expect(frame).toContain('Epic 14');\n70\t    expect(frame).toContain('Driver Interface');\n71\t    expect(frame).toContain('Workflow Schema');\n72\t    // Should show lane indices\n73\t    expect(frame).toContain('Lane 1:');\n74\t    expect(frame).toContain('Lane 2:');\n75\t  });\n76\t\n77\t  it('renders stacked layout when terminalWidth 80-119 and 2 lanes', () => {\n78\t    const lanes = [\n79\t      makeLane({ epicId: '10', epicTitle: 'Driver Interface' }),\n80\t      makeLane({ epicId: '14', epicTitle: 'Workflow Schema' }),\n81\t    ];\n82\t    const { lastFrame } = render(\n83\t      <LaneContainer lanes={lanes} terminalWidth={100} />\n84\t    );\n85\t    const frame = lastFrame()!;\n86\t    // Both lanes should still be visible\n87\t    expect(frame).toContain('Epic 10');\n88\t    expect(frame).toContain('Epic 14');\n89\t    expect(frame).toContain('Lane 1:');\n90\t    expect(frame).toContain('Lane 2:');\n91\t  });\n92\t\n93\t  it('renders single-lane layout when terminalWidth < 80', () => {\n94\t    const lanes = [\n95\t      makeLane({ epicId: '10', epicTitle: 'Driver Interface', lastActivityTime: 100 }),\n96\t      makeLane({ epicId: '14', epicTitle: 'Workflow Schema', lastActivityTime: 200 }),\n97\t    ];\n98\t    const { lastFrame } = render(\n99\t      <LaneContainer lanes={lanes} terminalWidth={60} />\n100\t    );\n101\t    const frame = lastFrame()!;\n102\t    // Most recently active lane (14) should be fully rendered\n103\t    expect(frame).toContain('Epic 14');\n104\t    expect(frame).toContain('Workflow Schema');\n105\t    // Other lane should be collapsed (single-line summary)\n106\t    // The collapsed lane for epic 10 appears as a dim line\n107\t    expect(frame).toContain('Driver Interface');\n108\t  });\n109\t\n110\t  it('collapses lanes 3+ to one-line summaries at >= 120 cols', () => {\n111\t    const lanes = [\n112\t      makeLane({ epicId: '10', epicTitle: 'Driver Interface' }),\n113\t      makeLane({ epicId: '14', epicTitle: 'Workflow Schema' }),\n114\t      makeLane({ epicId: '11', epicTitle: 'Event Router', currentStory: '11-1', phase: 'dev', cost: 0.40, elapsedTime: 120000 }),\n115\t    ];\n116\t    const { lastFrame } = render(\n117\t      <LaneContainer lanes={lanes} terminalWidth={140} />\n118\t    );\n119\t    const frame = lastFrame()!;\n120\t    // First two rendered in full\n121\t    expect(frame).toContain('Lane 1:');\n122\t    expect(frame).toContain('Lane 2:');\n123\t    // Third collapsed\n124\t    expect(frame).toContain('Lane 3:');\n125\t    expect(frame).toContain('Event Router');\n126\t    expect(frame).toContain('$0.40');\n127\t  });\n128\t\n129\t  it('renders single lane without lane index (single lane mode)', () => {\n130\t    const lanes = [\n131\t      makeLane({ epicId: '10', epicTitle: 'Driver Interface' }),\n132\t    ];\n133\t    const { lastFrame } = render(\n134\t      <LaneContainer lanes={lanes} terminalWidth={120} />\n135\t    );\n136\t    const frame = lastFrame()!;\n137\t    expect(frame).toContain('Epic 10');\n138\t    expect(frame).toContain('Driver Interface');\n139\t    // Single lane should show Lane 1 index since there's only 1 and it's in side-by-side mode\n140\t    // but with only 1 lane, no collapsed lanes\n141\t    expect(frame).not.toContain('Lane 2:');\n142\t  });\n143\t\n144\t  it('re-evaluates layout when terminalWidth changes', () => {\n145\t    // First render at wide width\n146\t    const lanes = [\n147\t      makeLane({ epicId: '10', epicTitle: 'Driver Interface' }),\n148\t      makeLane({ epicId: '14', epicTitle: 'Workflow Schema' }),\n149\t    ];\n150\t    const { lastFrame: frame1 } = render(\n151\t      <LaneContainer lanes={lanes} terminalWidth={140} />\n152\t    );\n153\t    // Should be side-by-side\n154\t    expect(frame1()!).toContain('Lane 1:');\n155\t    expect(frame1()!).toContain('Lane 2:');\n156\t\n157\t    // Second render at narrow width — separate render call simulates resize\n158\t    const { lastFrame: frame2 } = render(\n159\t      <LaneContainer lanes={lanes} terminalWidth={60} />\n160\t    );\n161\t    // Should be single mode — only one full lane (most recently active wins tie-break)\n162\t    const f2 = frame2()!;\n163\t    // In single mode, the full lane doesn't get a lane index\n164\t    // With no lastActivityTime set, tie-break picks the last lane (Epic 14)\n165\t    expect(f2).toContain('Epic 14'); // at least one is fully rendered\n166\t  });\n167\t\n168\t  it('handles 4 lanes with first 2 full and rest collapsed', () => {\n169\t    const lanes = [\n170\t      makeLane({ epicId: '10', epicTitle: 'A' }),\n171\t      makeLane({ epicId: '11', epicTitle: 'B' }),\n172\t      makeLane({ epicId: '12', epicTitle: 'C', currentStory: '12-1', phase: 'verify', cost: 1.00, elapsedTime: 300000 }),\n173\t      makeLane({ epicId: '13', epicTitle: 'D', currentStory: '13-2', phase: 'dev', cost: 2.50, elapsedTime: 600000 }),\n174\t    ];\n175\t    const { lastFrame } = render(\n176\t      <LaneContainer lanes={lanes} terminalWidth={140} />\n177\t    );\n178\t    const frame = lastFrame()!;\n179\t    expect(frame).toContain('Lane 3:');\n180\t    expect(frame).toContain('Lane 4:');\n181\t    expect(frame).toContain('$1.00');\n182\t    expect(frame).toContain('$2.50');\n183\t  });\n184\t});\n185\t\n186\tdescribe('CollapsedLanes component', () => {\n187\t  it('renders nothing for empty array', () => {\n188\t    const { lastFrame } = render(<CollapsedLanes lanes={[]} />);\n189\t    expect(lastFrame()).toBe('');\n190\t  });\n191\t\n192\t  it('renders collapsed lane format with pipe separators', () => {\n193\t    const lanes: CollapsedLaneData[] = [\n194\t      {\n195\t        laneIndex: 3,\n196\t        epicTitle: 'Workflow Schema',\n197\t        currentStory: '11-1',\n198\t        phase: 'dev',\n199\t        cost: 0.40,\n200\t        elapsedTime: 120000,\n201\t      },\n202\t    ];\n203\t    const { lastFrame } = render(<CollapsedLanes lanes={lanes} />);\n204\t    const frame = lastFrame()!;\n205\t    // Format: Lane N: Epic Title │ story ◆ phase │ $cost / time\n206\t    expect(frame).toContain('Lane 3:');\n207\t    expect(frame).toContain('Workflow Schema');\n208\t    expect(frame).toContain('11-1');\n209\t    expect(frame).toContain('dev');\n210\t    expect(frame).toContain('$0.40');\n211\t    expect(frame).toContain('2m');\n212\t    // Pipe separators\n213\t    expect(frame).toContain('\\u2502'); // │ character\n214\t  });\n215\t\n216\t  it('renders multiple collapsed lanes', () => {\n217\t    const lanes: CollapsedLaneData[] = [\n218\t      {\n219\t        laneIndex: 3,\n220\t        epicTitle: 'Schema',\n221\t        currentStory: '11-1',\n222\t        phase: 'dev',\n223\t        cost: 0.40,\n224\t        elapsedTime: 120000,\n225\t      },\n226\t      {\n227\t        laneIndex: 4,\n228\t        epicTitle: 'Router',\n229\t        currentStory: '12-2',\n230\t        phase: 'verify',\n231\t        cost: 1.10,\n232\t        elapsedTime: 300000,\n233\t      },\n234\t    ];\n235\t    const { lastFrame } = render(<CollapsedLanes lanes={lanes} />);\n236\t    const frame = lastFrame()!;\n237\t    expect(frame).toContain('Lane 3:');\n238\t    expect(frame).toContain('Lane 4:');\n239\t    expect(frame).toContain('Schema');\n240\t    expect(frame).toContain('Router');\n241\t  });\n242\t\n243\t  it('handles null story and phase in collapsed format', () => {\n244\t    const lanes: CollapsedLaneData[] = [\n245\t      {\n246\t        laneIndex: 3,\n247\t        epicTitle: 'Test',\n248\t        currentStory: null,\n249\t        phase: null,\n250\t        cost: null,\n251\t        elapsedTime: null,\n252\t      },\n253\t    ];\n254\t    const { lastFrame } = render(<CollapsedLanes lanes={lanes} />);\n255\t    const frame = lastFrame()!;\n256\t    expect(frame).toContain('Lane 3:');\n257\t    expect(frame).toContain('Test');\n258\t    expect(frame).toContain('--');\n259\t  });\n260\t});\n261\t"}]},"parent_tool_use_id":"toolu_01Lyf5tpvBU7eZNwMupgDFgG","session_id":"7e3ded59-6184-4f8b-8f55-ba5e63dae51f","uuid":"0e668cb1-9e88-47bf-9208-36e591f50c04","timestamp":"2026-04-04T02:45:48.709Z"}
