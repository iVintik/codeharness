{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FWznEy5YVwzfCnerCeKq2t","type":"tool_result","content":"     1→/**\n     2→ * Observability analyzer module — public API.\n     3→ *\n     4→ * All consumers should import from this barrel file only.\n     5→ * Internal implementation details are not re-exported.\n     6→ */\n     7→\n     8→export type {\n     9→  AnalyzerResult,\n    10→  AnalyzerConfig,\n    11→  AnalyzerSummary,\n    12→  ObservabilityGap,\n    13→  GapSeverity,\n    14→  ObservabilityCoverageState,\n    15→  CoverageHistoryEntry,\n    16→  StaticCoverageState,\n    17→  CoverageTargets,\n    18→  CoverageTrend,\n    19→  CoverageTargetResult,\n    20→  ObservabilityCoverageGateResult,\n    21→  RuntimeCoverageEntry,\n    22→  RuntimeCoverageResult,\n    23→  RuntimeCoverageState,\n    24→} from './types.js';\n    25→\n    26→export { analyze } from './analyzer.js';\n    27→\n    28→export {\n    29→  saveCoverageResult,\n    30→  readCoverageState,\n    31→  getCoverageTrend,\n    32→  checkCoverageTarget,\n    33→} from './coverage.js';\n    34→\n    35→export {\n    36→  computeRuntimeCoverage,\n    37→  saveRuntimeCoverage,\n    38→} from './runtime-coverage.js';\n    39→\n    40→export { checkObservabilityCoverageGate } from './coverage-gate.js';\n    41→"}]},"parent_tool_use_id":"toolu_01L7x1Zkv5Yv1DsfgSndzqDQ","session_id":"f7a66acd-0cc1-40de-a592-d59e75273c0b","uuid":"6437f2a1-0e3c-4c21-9413-337d4a0eed8f","timestamp":"2026-03-20T06:00:17.036Z"}
