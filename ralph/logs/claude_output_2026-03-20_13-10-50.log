{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q2d3oD6KmSbAKDBKeMGPgj","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→\n     3→// Mock node:fs\n     4→vi.mock('node:fs', () => ({\n     5→  existsSync: vi.fn(),\n     6→  writeFileSync: vi.fn(),\n     7→  mkdirSync: vi.fn(),\n     8→}));\n     9→\n    10→// Mock sprint state module\n    11→vi.mock('../../sprint/index.js', () => ({\n    12→  getSprintState: vi.fn(),\n    13→  writeStateAtomic: vi.fn(),\n    14→  computeSprintCounts: vi.fn(),\n    15→}));\n    16→\n    17→import { existsSync, writeFileSync, mkdirSync } from 'node:fs';\n    18→import {\n    19→  getSprintState,\n    20→  writeStateAtomic,\n    21→  computeSprintCounts,\n    22→} from '../../sprint/index.js';\n    23→import {\n    24→  generateFixStories,\n    25→  addFixStoriesToState,\n    26→  buildStoryKey,\n    27→  buildStoryMarkdown,\n    28→} from '../fix-generator.js';\n    29→import type { AuditResult, AuditGap } from '../types.js';\n    30→\n    31→const mockExistsSync = vi.mocked(existsSync);\n    32→const mockWriteFileSync = vi.mocked(writeFileSync);\n    33→const mockMkdirSync = vi.mocked(mkdirSync);\n    34→const mockGetSprintState = vi.mocked(getSprintState);\n    35→const mockWriteStateAtomic = vi.mocked(writeStateAtomic);\n    36→const mockComputeSprintCounts = vi.mocked(computeSprintCounts);\n    37→\n    38→function makeGap(dimension: string, description: string, suggestedFix: string): AuditGap {\n    39→  return { dimension, description, suggestedFix };\n    40→}\n    41→\n    42→function makeAuditResult(gaps: Record<string, AuditGap[]>): AuditResult {\n    43→  const dimensions: AuditResult['dimensions'] = {};\n    44→  let gapCount = 0;\n    45→\n    46→  for (const [name, dimGaps] of Object.entries(gaps)) {\n    47→    gapCount += dimGaps.length;\n    48→    dimensions[name] = {\n    49→      name,\n    50→      status: dimGaps.length > 0 ? 'fail' : 'pass',\n    51→      metric: `${dimGaps.length} gaps`,\n    52→      gaps: dimGaps,\n    53→    };\n    54→  }\n    55→\n    56→  return {\n    57→    dimensions,\n    58→    overallStatus: gapCount > 0 ? 'fail' : 'pass',\n    59→    gapCount,\n    60→    durationMs: 42,\n    61→  };\n    62→}\n    63→\n    64→beforeEach(() => {\n    65→  vi.clearAllMocks();\n    66→  mockExistsSync.mockReturnValue(false);\n    67→});\n    68→\n    69→// ─── buildStoryKey ──────────────────────────────────────────────────────────\n    70→\n    71→describe('buildStoryKey', () => {\n    72→  it('generates deterministic key from dimension and index', () => {\n    73→    const gap = makeGap('observability', 'Missing logs', 'Add logs');\n    74→    expect(buildStoryKey(gap, 1)).toBe('audit-fix-observability-1');\n    75→  });\n    76→\n    77→  it('sanitizes dimension name for filesystem safety', () => {\n    78→    const gap = makeGap('Code Quality', 'Issue', 'Fix');\n    79→    expect(buildStoryKey(gap, 2)).toBe('audit-fix-code-quality-2');\n    80→  });\n    81→\n    82→  it('produces same key for same input', () => {\n    83→    const gap = makeGap('testing', 'Low coverage', 'Add tests');\n    84→    const k1 = buildStoryKey(gap, 1);\n    85→    const k2 = buildStoryKey(gap, 1);\n    86→    expect(k1).toBe(k2);\n    87→  });\n    88→});\n    89→\n    90→// ─── buildStoryMarkdown ─────────────────────────────────────────────────────\n    91→\n    92→describe('buildStoryMarkdown', () => {\n    93→  it('follows BMAD format with Status: backlog header', () => {\n    94→    const gap = makeGap('testing', 'Low coverage in src/lib/docker.ts', 'Add unit tests');\n    95→    const md = buildStoryMarkdown(gap, 'audit-fix-testing-1');\n    96→    expect(md).toContain('# Fix: testing — Low coverage in src/lib/docker.ts');\n    97→    expect(md).toContain('Status: backlog');\n    98→  });\n    99→\n   100→  it('includes user story section', () => {\n   101→    const gap = makeGap('testing', 'Missing tests', 'Write tests');\n   102→    const md = buildStoryMarkdown(gap, 'key');\n   103→    expect(md).toContain('## Story');\n   104→    expect(md).toContain('As an operator, I need Missing tests fixed so that audit compliance improves.');\n   105→  });\n   106→\n   107→  it('includes Given/When/Then acceptance criteria', () => {\n   108→    const gap = makeGap('observability', 'No logging', 'Add structured logs');\n   109→    const md = buildStoryMarkdown(gap, 'key');\n   110→    expect(md).toContain('## Acceptance Criteria');\n   111→    expect(md).toContain('**Given**');\n   112→    expect(md).toContain('**When**');\n   113→    expect(md).toContain('**Then**');\n   114→  });\n   115→\n   116→  it('references specific file path from gap description (AC #3)', () => {\n   117→    const gap = makeGap(\n   118→      'observability',\n   119→      'src/lib/docker.ts:42 — Missing error logging',\n   120→      'Add error logging at line 42',\n   121→    );\n   122→    const md = buildStoryMarkdown(gap, 'key');\n   123→    expect(md).toContain('src/lib/docker.ts:42 — Missing error logging');\n   124→  });\n   125→\n   126→  it('includes Dev Notes with audit gap details', () => {\n   127→    const gap = makeGap('testing', 'Low coverage', 'Add tests');\n   128→    const md = buildStoryMarkdown(gap, 'key');\n   129→    expect(md).toContain('## Dev Notes');\n   130→    expect(md).toContain('auto-generated fix story created by `codeharness audit --fix`');\n   131→    expect(md).toContain('**Audit Gap:** testing: Low coverage');\n   132→    expect(md).toContain('**Suggested Fix:** Add tests');\n   133→  });\n   134→});\n   135→\n   136→// ─── generateFixStories ────────────────────────────────────────────────────\n   137→\n   138→describe('generateFixStories', () => {\n   139→  it('returns empty result with 0 gaps (AC #4)', () => {\n   140→    const auditResult = makeAuditResult({ testing: [] });\n   141→    const result = generateFixStories(auditResult);\n   142→    expect(result.success).toBe(true);\n   143→    if (result.success) {\n   144→      expect(result.data.stories).toHaveLength(0);\n   145→      expect(result.data.created).toBe(0);\n   146→      expect(result.data.skipped).toBe(0);\n   147→    }\n   148→  });\n   149→\n   150→  it('creates 3 story files for 3 gaps', () => {\n   151→    const auditResult = makeAuditResult({\n   152→      observability: [\n   153→        makeGap('observability', 'Gap A', 'Fix A'),\n   154→        makeGap('observability', 'Gap B', 'Fix B'),\n   155→      ],\n   156→      testing: [\n   157→        makeGap('testing', 'Gap C', 'Fix C'),\n   158→      ],\n   159→    });\n   160→\n   161→    const result = generateFixStories(auditResult);\n   162→    expect(result.success).toBe(true);\n   163→    if (result.success) {\n   164→      expect(result.data.stories).toHaveLength(3);\n   165→      expect(result.data.created).toBe(3);\n   166→      expect(result.data.skipped).toBe(0);\n   167→      expect(mockWriteFileSync).toHaveBeenCalledTimes(3);\n   168→    }\n   169→  });\n   170→\n   171→  it('writes story files with BMAD markdown content', () => {\n   172→    const auditResult = makeAuditResult({\n   173→      testing: [makeGap('testing', 'Low coverage', 'Add tests')],\n   174→    });\n   175→\n   176→    generateFixStories(auditResult);\n   177→\n   178→    expect(mockWriteFileSync).toHaveBeenCalledTimes(1);\n   179→    const writtenContent = mockWriteFileSync.mock.calls[0][1] as string;\n   180→    expect(writtenContent).toContain('# Fix: testing — Low coverage');\n   181→    expect(writtenContent).toContain('Status: backlog');\n   182→  });\n   183→\n   184→  it('creates parent directory before writing', () => {\n   185→    const auditResult = makeAuditResult({\n   186→      testing: [makeGap('testing', 'Gap', 'Fix')],\n   187→    });\n   188→\n   189→    generateFixStories(auditResult);\n   190→\n   191→    expect(mockMkdirSync).toHaveBeenCalledWith(\n   192→      expect.stringContaining('implementation-artifacts'),\n   193→      { recursive: true },\n   194→    );\n   195→  });\n   196→\n   197→  it('skips existing story files and returns skipped: true (AC #6)', () => {\n   198→    mockExistsSync.mockReturnValue(true);\n   199→\n   200→    const auditResult = makeAuditResult({\n   201→      testing: [makeGap('testing', 'Gap', 'Fix')],\n   202→    });\n   203→\n   204→    const result = generateFixStories(auditResult);\n   205→    expect(result.success).toBe(true);\n   206→    if (result.success) {\n   207→      expect(result.data.stories).toHaveLength(1);\n   208→      expect(result.data.stories[0].skipped).toBe(true);\n   209→      expect(result.data.stories[0].skipReason).toBe('Story file already exists');\n   210→      expect(result.data.created).toBe(0);\n   211→      expect(result.data.skipped).toBe(1);\n   212→      expect(mockWriteFileSync).not.toHaveBeenCalled();\n   213→    }\n   214→  });\n   215→\n   216→  it('story key is deterministic for same gap', () => {\n   217→    const auditResult = makeAuditResult({\n   218→      testing: [makeGap('testing', 'Gap A', 'Fix A')],\n   219→    });\n   220→\n   221→    const r1 = generateFixStories(auditResult);\n   222→    const r2 = generateFixStories(auditResult);\n   223→\n   224→    expect(r1.success && r2.success).toBe(true);\n   225→    if (r1.success && r2.success) {\n   226→      expect(r1.data.stories[0].key).toBe(r2.data.stories[0].key);\n   227→    }\n   228→  });\n   229→\n   230→  it('handles mixed created and skipped stories', () => {\n   231→    // First gap file exists, second does not\n   232→    mockExistsSync\n   233→      .mockReturnValueOnce(true)\n   234→      .mockReturnValueOnce(false);\n   235→\n   236→    const auditResult = makeAuditResult({\n   237→      testing: [\n   238→        makeGap('testing', 'Gap A', 'Fix A'),\n   239→        makeGap('testing', 'Gap B', 'Fix B'),\n   240→      ],\n   241→    });\n   242→\n   243→    const result = generateFixStories(auditResult);\n   244→    expect(result.success).toBe(true);\n   245→    if (result.success) {\n   246→      expect(result.data.created).toBe(1);\n   247→      expect(result.data.skipped).toBe(1);\n   248→      expect(mockWriteFileSync).toHaveBeenCalledTimes(1);\n   249→    }\n   250→  });\n   251→});\n   252→\n   253→// ─── addFixStoriesToState ───────────────────────────────────────────────────\n   254→\n   255→describe('addFixStoriesToState', () => {\n   256→  const defaultState = {\n   257→    version: 1 as const,\n   258→    sprint: { total: 0, done: 0, failed: 0, blocked: 0, inProgress: null },\n   259→    stories: {},\n   260→    run: {\n   261→      active: false,\n   262→      startedAt: null,\n   263→      iteration: 0,\n   264→      cost: 0,\n   265→      completed: [],\n   266→      failed: [],\n   267→      currentStory: null,\n   268→      currentPhase: null,\n   269→      lastAction: null,\n   270→      acProgress: null,\n   271→    },\n   272→    actionItems: [],\n   273→  };\n   274→\n   275→  beforeEach(() => {\n   276→    mockGetSprintState.mockReturnValue({ success: true, data: { ...defaultState } });\n   277→    mockWriteStateAtomic.mockReturnValue({ success: true, data: undefined });\n   278→    mockComputeSprintCounts.mockReturnValue({\n   279→      total: 2, done: 0, failed: 0, blocked: 0, inProgress: null,\n   280→    });\n   281→  });\n   282→\n   283→  it('adds stories to sprint-state.json as backlog entries (AC #2)', () => {\n   284→    const stories = [\n   285→      {\n   286→        key: 'audit-fix-testing-1',\n   287→        filePath: '/path/to/audit-fix-testing-1.md',\n   288→        gap: makeGap('testing', 'Gap', 'Fix'),\n   289→        skipped: false,\n   290→      },\n   291→    ];\n   292→\n   293→    const result = addFixStoriesToState(stories);\n   294→    expect(result.success).toBe(true);\n   295→    expect(mockWriteStateAtomic).toHaveBeenCalledTimes(1);\n   296→\n   297→    const writtenState = mockWriteStateAtomic.mock.calls[0][0];\n   298→    expect(writtenState.stories['audit-fix-testing-1']).toEqual({\n   299→      status: 'backlog',\n   300→      attempts: 0,\n   301→      lastAttempt: null,\n   302→      lastError: null,\n   303→      proofPath: null,\n   304→      acResults: null,\n   305→    });\n   306→  });\n   307→\n   308→  it('creates default state when sprint-state.json is missing (AC #9)', () => {\n   309→    mockGetSprintState.mockReturnValue({ success: true, data: { ...defaultState } });\n   310→\n   311→    const stories = [\n   312→      {\n   313→        key: 'audit-fix-testing-1',\n   314→        filePath: '/path/file.md',\n   315→        gap: makeGap('testing', 'Gap', 'Fix'),\n   316→        skipped: false,\n   317→      },\n   318→    ];\n   319→\n   320→    const result = addFixStoriesToState(stories);\n   321→    expect(result.success).toBe(true);\n   322→    expect(mockGetSprintState).toHaveBeenCalled();\n   323→  });\n   324→\n   325→  it('uses atomic write via writeStateAtomic (AC #8)', () => {\n   326→    const stories = [\n   327→      {\n   328→        key: 'audit-fix-testing-1',\n   329→        filePath: '/path/file.md',\n   330→        gap: makeGap('testing', 'Gap', 'Fix'),\n   331→        skipped: false,\n   332→      },\n   333→    ];\n   334→\n   335→    addFixStoriesToState(stories);\n   336→    expect(mockWriteStateAtomic).toHaveBeenCalledTimes(1);\n   337→  });\n   338→\n   339→  it('recomputes sprint counts after adding stories', () => {\n   340→    const stories = [\n   341→      {\n   342→        key: 'audit-fix-testing-1',\n   343→        filePath: '/path/file.md',\n   344→        gap: makeGap('testing', 'Gap', 'Fix'),\n   345→        skipped: false,\n   346→      },\n   347→    ];\n   348→\n   349→    addFixStoriesToState(stories);\n   350→    expect(mockComputeSprintCounts).toHaveBeenCalledTimes(1);\n   351→    // Verify the recomputed counts are used in the written state\n   352→    const writtenState = mockWriteStateAtomic.mock.calls[0][0];\n   353→    expect(writtenState.sprint.total).toBe(2);\n   354→  });\n   355→\n   356→  it('skips writing when all stories are skipped', () => {\n   357→    const stories = [\n   358→      {\n   359→        key: 'audit-fix-testing-1',\n   360→        filePath: '/path/file.md',\n   361→        gap: makeGap('testing', 'Gap', 'Fix'),\n   362→        skipped: true,\n   363→        skipReason: 'Already exists',\n   364→      },\n   365→    ];\n   366→\n   367→    const result = addFixStoriesToState(stories);\n   368→    expect(result.success).toBe(true);\n   369→    expect(mockGetSprintState).not.toHaveBeenCalled();\n   370→    expect(mockWriteStateAtomic).not.toHaveBeenCalled();\n   371→  });\n   372→\n   373→  it('handles getSprintState failure', () => {\n   374→    mockGetSprintState.mockReturnValue({\n   375→      success: false,\n   376→      error: 'File corrupted',\n   377→    });\n   378→\n   379→    const stories = [\n   380→      {\n   381→        key: 'audit-fix-testing-1',\n   382→        filePath: '/path/file.md',\n   383→        gap: makeGap('testing', 'Gap', 'Fix'),\n   384→        skipped: false,\n   385→      },\n   386→    ];\n   387→\n   388→    const result = addFixStoriesToState(stories);\n   389→    expect(result.success).toBe(false);\n   390→    if (!result.success) {\n   391→      expect(result.error).toBe('File corrupted');\n   392→    }\n   393→  });\n   394→\n   395→  it('preserves existing stories when adding new ones', () => {\n   396→    const existingStories = {\n   397→      'existing-story': {\n   398→        status: 'done' as const,\n   399→        attempts: 2,\n   400→        lastAttempt: '2026-01-01',\n   401→        lastError: null,\n   402→        proofPath: null,\n   403→        acResults: null,\n   404→      },\n   405→    };\n   406→\n   407→    mockGetSprintState.mockReturnValue({\n   408→      success: true,\n   409→      data: { ...defaultState, stories: existingStories },\n   410→    });\n   411→\n   412→    const stories = [\n   413→  