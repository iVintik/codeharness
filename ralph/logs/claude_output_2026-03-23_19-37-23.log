aulin');\n   187→  });\n   188→\n   189→  it('labels Rust stack correctly', () => {\n   190→    const content = generateAgentsMdContent(testDir, 'rust');\n   191→    expect(content).toContain('Rust');\n   192→  });\n   193→});\n   194→\n   195→describe('generateAgentsMdContent — multi-stack', () => {\n   196→  it('generates per-stack sections with directory-relative commands', () => {\n   197→    const content = generateAgentsMdContent(testDir, [\n   198→      { stack: 'nodejs', dir: 'frontend' },\n   199→      { stack: 'rust', dir: 'backend' },\n   200→    ]);\n   201→    expect(content).toContain('### Node.js (frontend/)');\n   202→    expect(content).toContain('### Rust (backend/)');\n   203→    expect(content).toContain('cd frontend && npm install');\n   204→    expect(content).toContain('cd backend && cargo build');\n   205→    expect(content).toContain('cd frontend && npm test');\n   206→    expect(content).toContain('cd backend && cargo test');\n   207→  });\n   208→\n   209→  it('omits cd prefix for root stack (dir === \".\")', () => {\n   210→    const content = generateAgentsMdContent(testDir, [\n   211→      { stack: 'nodejs', dir: '.' },\n   212→      { stack: 'rust', dir: 'backend' },\n   213→    ]);\n   214→    // Root stack should have bare commands\n   215→    expect(content).toContain('npm install');\n   216→    expect(content).not.toContain('cd . &&');\n   217→    // Subdir stack should have cd prefix\n   218→    expect(content).toContain('cd backend && cargo build');\n   219→    // Root heading should not have directory suffix\n   220→    expect(content).toContain('### Node.js');\n   221→    expect(content).not.toContain('### Node.js (./)');\n   222→  });\n   223→\n   224→  it('lists combined stack label in header', () => {\n   225→    const content = generateAgentsMdContent(testDir, [\n   226→      { stack: 'nodejs', dir: 'frontend' },\n   227→      { stack: 'rust', dir: 'backend' },\n   228→    ]);\n   229→    expect(content).toContain('Node.js + Rust');\n   230→  });\n   231→\n   232→  it('single-stack string argument still produces existing output (backward compat)', () => {\n   233→    const content = generateAgentsMdContent(testDir, 'nodejs');\n   234→    expect(content).toContain('npm install');\n   235→    expect(content).toContain('npm test');\n   236→    expect(content).not.toContain('###');\n   237→  });\n   238→\n   239→  it('includes python commands in multi-stack with cd prefix', () => {\n   240→    const content = generateAgentsMdContent(testDir, [\n   241→      { stack: 'python', dir: 'ml' },\n   242→      { stack: 'nodejs', dir: '.' },\n   243→    ]);\n   244→    expect(content).toContain('cd ml && pip install');\n   245→    expect(content).toContain('cd ml && python -m pytest');\n   246→    expect(content).toContain('### Python (ml/)');\n   247→  });\n   248→});\n   249→\n   250→describe('generateDocsIndexContent', () => {\n   251→  it('includes documentation sections', () => {\n   252→    const content = generateDocsIndexContent();\n   253→    expect(content).toContain('Planning Artifacts');\n   254→    expect(content).toContain('Execution');\n   255→    expect(content).toContain('Quality');\n   256→  });\n   257→});\n   258→\n   259→describe('scaffoldDocs', () => {\n   260→  it('creates AGENTS.md when it does not exist', async () => {\n   261→    const result = await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: false });\n   262→    expect(result.success).toBe(true);\n   263→    if (result.success) {\n   264→      expect(result.data.agents_md).toBe('created');\n   265→    }\n   266→  });\n   267→\n   268→  it('reports exists when AGENTS.md already exists', async () => {\n   269→    writeFileSync(join(testDir, 'AGENTS.md'), '# existing');\n   270→    const result = await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: false });\n   271→    expect(result.success).toBe(true);\n   272→    if (result.success) {\n   273→      expect(result.data.agents_md).toBe('exis