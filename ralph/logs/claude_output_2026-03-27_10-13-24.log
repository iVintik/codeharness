{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TbheD4fg4Jf1wpvUMB4Z4Z","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';\n     2→import { mkdtempSync, rmSync, readFileSync, existsSync } from 'node:fs';\n     3→import { tmpdir } from 'node:os';\n     4→import { join } from 'node:path';\n     5→import { Command } from 'commander';\n     6→import { registerProgressCommand } from '../progress.js';\n     7→import type { SprintState } from '../../types/state.js';\n     8→\n     9→// Mock migration so tests don't touch real project files\n    10→vi.mock('../../modules/sprint/migration.js', () => ({\n    11→  migrateFromOldFormat: vi.fn(() => ({\n    12→    success: false,\n    13→    error: 'No old format files found for migration',\n    14→  })),\n    15→}));\n    16→\n    17→let testDir: string;\n    18→let originalCwd: string;\n    19→\n    20→beforeEach(() => {\n    21→  testDir = mkdtempSync(join(tmpdir(), 'ch-cmd-progress-'));\n    22→  originalCwd = process.cwd();\n    23→  process.chdir(testDir);\n    24→});\n    25→\n    26→afterEach(() => {\n    27→  process.chdir(originalCwd);\n    28→  rmSync(testDir, { recursive: true, force: true });\n    29→});\n    30→\n    31→function createCli(): Command {\n    32→  const program = new Command();\n    33→  program.option('--json', 'JSON output');\n    34→  registerProgressCommand(program);\n    35→  return program;\n    36→}\n    37→\n    38→async function runCli(args: string[]): Promise<{ stdout: string; exitCode: number | undefined }> {\n    39→  const logs: string[] = [];\n    40→  const consoleSpy = vi.spyOn(console, 'log').mockImplementation((...a: unknown[]) => {\n    41→    logs.push(a.map(String).join(' '));\n    42→  });\n    43→  process.exitCode = undefined;\n    44→\n    45→  const program = createCli();\n    46→  await program.parseAsync(['node', 'codeharness', ...args]);\n    47→\n    48→  consoleSpy.mockRestore();\n    49→  const exitCode = process.exitCode;\n    50→  process.exitCode = undefined;\n    51→\n    52→  return { stdout: logs.join('\\n'), exitCode };\n    53→}\n    54→\n    55→function readState(): SprintState {\n    56→  const raw = readFileSync(join(process.cwd(), 'sprint-state.json'), 'utf-8');\n    57→  return JSON.parse(raw) as SprintState;\n    58→}\n    59→\n    60→describe('codeharness progress', () => {\n    61→  it('updates story, phase, and action', async () => {\n    62→    const { stdout, exitCode } = await runCli([\n    63→      'progress',\n    64→      '--story', '1-2-user-auth',\n    65→      '--phase', 'dev',\n    66→      '--action', 'Starting development',\n    67→    ]);\n    68→\n    69→    expect(exitCode).toBeUndefined();\n    70→    expect(stdout).toContain('Run progress updated');\n    71→\n    72→    const state = readState();\n    73→    expect(state.run.currentStory).toBe('1-2-user-auth');\n    74→    expect(state.run.currentPhase).toBe('dev');\n    75→    expect(state.run.lastAction).toBe('Starting development');\n    76→  });\n    77→\n    78→  it('updates ac-progress only', async () => {\n    79→    await runCli([\n    80→      'progress',\n    81→      '--story', '1-2-user-auth',\n    82→      '--phase', 'verify',\n    83→    ]);\n    84→\n    85→    const { exitCode } = await runCli([\n    86→      'progress',\n    87→      '--ac-progress', '4/12',\n    88→    ]);\n    89→\n    90→    expect(exitCode).toBeUndefined();\n    91→\n    92→    const state = readState();\n    93→    expect(state.run.acProgress).toBe('4/12');\n    94→    expect(state.run.currentStory).toBe('1-2-user-auth');\n    95→  });\n    96→\n    97→  it('clears all progress fields with --clear', async () => {\n    98→    await runCli([\n    99→      'progress',\n   100→      '--story', '1-2-user-auth',\n   101→      '--phase', 'dev',\n   102→      '--action', 'Working',\n   103→      '--ac-progress', '3/7',\n   104→    ]);\n   105→\n   106→    const { stdout, exitCode } = await runCli(['progress', '--clear']);\n   107→\n   108→    expect(exitCode).toBeUndefined();\n   109→    expect(stdout).toContain('Run progress cleared');\n   110→\n   111→    const state = readState();\n   112→    expect(state.run.currentStory).toBeNull();\n   113→    expect(state.run.currentPhase).toBeNull();\n   114→    expect(state.run.lastAction).toBeNull();\n   115→    expect(state.run.acProgress).toBeNull();\n   116→  });\n   117→\n   118→  it('fails with exit code 1 when no flags provided', async () => {\n   119→    const { stdout, exitCode } = await runCli(['progress']);\n   120→\n   121→    expect(exitCode).toBe(1);\n   122→    expect(stdout).toContain('No progress fields specified');\n   123→  });\n   124→\n   125→  it('supports --json output for update', async () => {\n   126→    const { stdout, exitCode } = await runCli([\n   127→      '--json', 'progress',\n   128→      '--story', 'test-story',\n   129→      '--phase', 'create',\n   130→    ]);\n   131→\n   132→    expect(exitCode).toBeUndefined();\n   133→    const parsed = JSON.parse(stdout);\n   134→    expect(parsed.status).toBe('ok');\n   135→    expect(parsed.updated.currentStory).toBe('test-story');\n   136→  });\n   137→\n   138→  it('rejects invalid phase value', async () => {\n   139→    const { stdout, exitCode } = await runCli([\n   140→      'progress',\n   141→      '--phase', 'garbage',\n   142→    ]);\n   143→\n   144→    expect(exitCode).toBe(1);\n   145→    expect(stdout).toContain('Invalid phase');\n   146→    expect(stdout).toContain('garbage');\n   147→  });\n   148→\n   149→  it('supports --json output for --clear', async () => {\n   150→    const { stdout, exitCode } = await runCli([\n   151→      '--json', 'progress', '--clear',\n   152→    ]);\n   153→\n   154→    expect(exitCode).toBeUndefined();\n   155→    const parsed = JSON.parse(stdout);\n   156→    expect(parsed.status).toBe('ok');\n   157→    expect(parsed.cleared).toBe(true);\n   158→  });\n   159→});\n   160→"}]},"parent_tool_use_id":null,"session_id":"2e5d4728-d8cb-4df9-909c-e75227099f62","uuid":"3d7d0ca0-db0e-4450-879b-44864d8de656","timestamp":"2026-03-27T06:15:57.982Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ivintik/dev/personal/codeharness/src/commands/__tests__/progress.test.ts","content":"import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';\nimport { mkdtempSync, rmSync, readFileSync, existsSync } from 'node:fs';\nimport { tmpdir } from 'node:os';\nimport { join } from 'node:path';\nimport { Command } from 'commander';\nimport { registerProgressCommand } from '../progress.js';\nimport type { SprintState } from '../../types/state.js';\n\n// Mock migration so tests don't touch real project files\nvi.mock('../../modules/sprint/migration.js', () => ({\n  migrateFromOldFormat: vi.fn(() => ({\n    success: false,\n    error: 'No old format files found for migration',\n  })),\n}));\n\nlet testDir: string;\nlet originalCwd: string;\n\nbeforeEach(() => {\n  testDir = mkdtempSync(join(tmpdir(), 'ch-cmd-progress-'));\n  originalCwd = process.cwd();\n  process.chdir(testDir);\n});\n\nafterEach(() => {\n  process.chdir(originalCwd);\n  rmSync(testDir, { recursive: true, force: true });\n});\n\nfunction createCli(): Command {\n  const program = new Command();\n  program.option('--json', 'JSON output');\n  registerProgressCommand(program);\n  return program;\n}\n\nasync function runCli(args: string[]): Promise<{ stdout: string; exitCode: number | undefined }> {\n  const logs: string[] = [];\n  const consoleSpy = vi.spyOn(console, 'log').mockImplementation((...a: unknown[]) => {\n    logs.push(a.map(String).join(' '));\n  });\n  process.exitCode = undefined;\n\n  const program = createCli();\n  await program.parseAsync(['node', 'codeharness', ...args]);\n\n  consoleSpy.mockRestore();\n  const exitCode = process.exitCode;\n  process.exitCode = undefined;\n\n  return { stdout: logs.join('\\n'), exitCode };\n}\n\nfunction readState(): SprintState {\n  const raw = readFileSync(join(process.cwd(), 'sprint-state.json'), 'utf-8');\n  return JSON.parse(raw) as SprintState;\n}\n\ndescribe('codeharness progress', () => {\n  it('updates story, phase, and action', async () => {\n    const { stdout, exitCode } = await runCli([\n      'progress',\n      '--story', '1-2-user-auth',\n      '--phase', 'dev',\n      '--action', 'Starting development',\n    ]);\n\n    expect(exitCode).toBeUndefined();\n    expect(stdout).toContain('Run progress updated');\n\n    const state = readState();\n    expect(state.run.currentStory).toBe('1-2-user-auth');\n    expect(state.run.currentPhase).toBe('dev');\n    expect(state.run.lastAction).toBe('Starting development');\n  });\n\n  it('updates ac-progress only', async () => {\n    await runCli([\n      'progress',\n      '--story', '1-2-user-auth',\n      '--phase', 'verify',\n    ]);\n\n    const { exitCode } = await runCli([\n      'progress',\n      '--ac-progress', '4/12',\n    ]);\n\n    expect(exitCode).toBeUndefined();\n\n    const state = readState();\n    expect(state.run.acProgress).toBe('4/12');\n    expect(state.run.currentStory).toBe('1-2-user-auth');\n  });\n\n  it('clears all progress fields with --clear', async () => {\n    await runCli([\n      'progress',\n      '--story', '1-2-user-auth',\n      '--phase', 'dev',\n      '--action', 'Working',\n      '--ac-progress', '3/7',\n    ]);\n\n    const { stdout, exitCode } = await runCli(['progress', '--clear']);\n\n    expect(exitCode).toBeUndefined();\n    expect(stdout).toContain('Run progress cleared');\n\n    const state = readState();\n    expect(state.run.currentStory).toBeNull();\n    expect(state.run.currentPhase).toBeNull();\n    expect(state.run.lastAction).toBeNull();\n    expect(state.run.acProgress).toBeNull();\n  });\n\n  it('fails with exit code 1 when no flags provided', async () => {\n    const { stdout, exitCode } = await runCli(['progress']);\n\n    expect(exitCode).toBe(1);\n    expect(stdout).toContain('No progress fields specified');\n  });\n\n  it('supports --json output for update', async () => {\n    const { stdout, exitCode } = await runCli([\n      '--json', 'progress',\n      '--story', 'test-story',\n      '--phase', 'create',\n    ]);\n\n    expect(exitCode).toBeUndefined();\n    const parsed = JSON.parse(stdout);\n    expect(parsed.status).toBe('ok');\n    expect(parsed.updated.currentStory).toBe('test-story');\n  });\n\n  it('rejects invalid phase value', async () => {\n    const { stdout, exitCode } = await runCli([\n      'progress',\n      '--phase', 'garbage',\n    ]);\n\n    expect(exitCode).toBe(1);\n    expect(stdout).toContain('Invalid phase');\n    expect(stdout).toContain('garbage');\n  });\n\n  it('supports --json output for --clear', async () => {\n    const { stdout, exitCode } = await runCli([\n      '--json', 'progress', '--clear',\n    ]);\n\n    expect(exitCode).toBeUndefined();\n    const parsed = JSON.parse(stdout);\n    expect(parsed.status).toBe('ok');\n    expect(parsed.cleared).toBe(true);\n  });\n});\n","numLines":160,"startLine":1,"totalLines":160}}}
