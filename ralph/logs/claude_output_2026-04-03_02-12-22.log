ion((path: string) => {\n250\t      if (path === '/path/sprint-status.yaml') return true;\n251\t      return false;\n252\t    });\n253\t    mockReadFileSync.mockReturnValue('yaml');\n254\t    mockParse.mockReturnValue({\n255\t      development_status: {\n256\t        '3-1-foo': 'ready-for-dev',\n257\t      },\n258\t    });\n259\t\n260\t    const items = loadWorkItems('/path/sprint-status.yaml', '/path/issues.yaml');\n261\t\n262\t    expect(items).toEqual([{ key: '3-1-foo', source: 'sprint' }]);\n263\t  });\n264\t\n265\t  it('loads both stories and issues when issues.yaml exists (AC #5)', () => {\n266\t    mockExistsSync.mockReturnValue(true);\n267\t    mockReadFileSync.mockReturnValue('yaml');\n268\t    mockParse\n269\t      .mockReturnValueOnce({\n270\t        development_status: {\n271\t          '3-1-foo': 'ready-for-dev',\n272\t        },\n273\t      })\n274\t      .mockReturnValueOnce({\n275\t        issues: [\n276\t          { id: 'issue-001', title: 'Fix docker timeout', status: 'ready-for-dev' },\n277\t          { id: 'issue-002', title: 'Already done', status: 'done' },\n278\t        ],\n279\t      });\n280\t\n281\t    const items = loadWorkItems('/path/sprint-status.yaml', '/path/issues.yaml');\n282\t\n283\t    expect(items).toEqual([\n284\t      { key: '3-1-foo', source: 'sprint' },\n285\t      { key: 'issue-001', title: 'Fix docker timeout', source: 'issues' },\n286\t    ]);\n287\t  });\n288\t\n289\t  it('handles invalid YAML in sprint-status.yaml gracefully', () => {\n290\t    mockExistsSync.mockReturnValue(true);\n291\t    mockReadFileSync.mockReturnValue('yaml');\n292\t    mockParse.mockImplementation(() => {\n293\t      throw new Error('bad yaml');\n294\t    });\n295\t\n296\t    const items = loadWorkItems('/path/sprint-status.yaml');\n297\t    expect(items).toEqual([]);\n298\t    expect(mockWarn).toHaveBeenCalled();\n299\t  });\n300\t\n301\t  it('handles unreadable sprint-status.yaml file gracefully', () => {\n302\t    mockExistsSync.mockReturnValue(true);\n303\t    mockReadFileSync.mockImplementation(() => {\n304\t      throw new Error('EACCES: permission denied');\n305\t    });\n306\t\n307\t    const items = loadWorkItems('/path/sprint-status.yaml');\n308\t    expect(items).toEqual([]);\n309\t    expect(mockWarn).toHaveBeenCalledWith(\n310\t      expect.stringContaining('could not read sprint-status.yaml'),\n311\t    );\n312\t  });\n313\t\n314\t  it('handles unreadable issues.yaml file gracefully', () => {\n315\t    // sprint-status.yaml is fine\n316\t    mockExistsSync.mockReturnValue(true);\n317\t    let readCount = 0;\n318\t    mockReadFileSync.mockImplementation(() => {\n319\t      readCount++;\n320\t      if (readCount === 1) return 'sprint yaml';\n321\t      throw new Error('EACCES: permission denied');\n322\t    });\n323\t    mockParse.mockReturnValue({\n324\t      development_status: { '3-1-foo': 'ready-for-dev' },\n325\t    });\n326\t\n327\t    const items = loadWorkItems('/path/sprint-status.yaml', '/path/issues.yaml');\n328\t    // Should still have the sprint story\n329\t    expect(items).toEqual([{ key: '3-1-foo', source: 'sprint' }]);\n330\t    expect(mockWarn).toHaveBeenCalledWith(\n331\t      expect.stringContaining('could not read issues.yaml'),\n332\t    );\n333\t  });\n334\t\n335\t  it('handles invalid YAML in issues.yaml gracefully', () => {\n336\t    mockExistsSync.mockReturnValue(true);\n337\t    mockReadFileSync.mockReturnValue('yaml');\n338\t    let parseCount = 0;\n339\t    mockParse.mockImplementation(() => {\n340\t      parseCount++;\n341\t      if (parseCount === 1) {\n342\t        return { development_status: { '3-1-foo': 'ready-for-dev' } };\n343\t      }\n344\t      throw new Error('bad issues yaml');\n345\t    });\n346\t\n347\t    const items = loadWorkItems('/path/sprint-status.yaml', '/path/issues.yaml');\n348\t    expect(items).toEqual([{ key: '3-1-foo', source: 'sprint' }]);\n349\t    expect(mockWarn).toHaveBeenCalledWith(\n350\t      expect.stringContaining('invalid YAML in issues.yaml'),\n351\t    );\n352\t  });\n353\t});\n354\t\n355\tdescribe('dispatchTask', () => {\n356\t  beforeEach(() => {\n357\t    vi.clearAllMocks();\n358\t    setupDefaultMocks();\n359\t  });\n360\t\n361\t  it('generates trace ID and injects trace prompt per dispatch (AC #11)', async () => {\n362\t    const task = makeTask();\n363\t    const definition = makeDefinition();\n364\t    const state = makeDefaultState();\n365\t    const config = makeConfig();\n366\t\n367\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n368\t\n369\t    expect(mockGenerateTraceId).toHaveBeenCalledWith('run-001', 0, 'implement');\n370\t    expect(mockFormatTracePrompt).toHaveBeenCalledWith('ch-run-001-0-implement');\n371\t    expect(mockDispatchAgent).toHaveBeenCalledWith(\n372\t      definition,\n373\t      'Implement story 5-1-foo',\n374\t      expect.objectContaining({\n375\t        appendSystemPrompt: '[TRACE] trace_id=ch-run-001-0-implement',\n376\t      }),\n377\t    );\n378\t  });\n379\t\n380\t  it('resolves session ID for continue boundary (AC #12)', async () => {\n381\t    const task = makeTask({ session: 'continue' });\n382\t    const definition = makeDefinition();\n383\t    const state = makeDefaultState();\n384\t    const config = makeConfig();\n385\t\n386\t    mockResolveSessionId.mockReturnValue('prev-sess-id');\n387\t\n388\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n389\t\n390\t    expect(mockResolveSessionId).toHaveBeenCalledWith(\n391\t      'continue',\n392\t      { taskName: 'implement', storyKey: '5-1-foo' },\n393\t      state,\n394\t    );\n395\t    expect(mockDispatchAgent).toHaveBeenCalledWith(\n396\t      definition,\n397\t      expect.any(String),\n398\t      expect.objectContaining({ sessionId: 'prev-sess-id' }),\n399\t    );\n400\t  });\n401\t\n402\t  it('dispatches with cwd when source_access is true (default) (AC #10)', async () => {\n403\t    const task = makeTask({ source_access: true });\n404\t    const definition = makeDefinition();\n405\t    const state = makeDefaultState();\n406\t    const config = makeConfig({ projectDir: '/my-project' });\n407\t\n408\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n409\t\n410\t    expect(mockCreateIsolatedWorkspace).not.toHaveBeenCalled();\n411\t    expect(mockDispatchAgent).toHaveBeenCalledWith(\n412\t      definition,\n413\t      expect.any(String),\n414\t      expect.objectContaining({ cwd: '/my-project' }),\n415\t    );\n416\t  });\n417\t\n418\t  it('creates isolated workspace when source_access is false (AC #9)', async () => {\n419\t    const mockWorkspace = {\n420\t      dir: '/tmp/codeharness-verify-run-001',\n421\t      storyFilesDir: '/tmp/codeharness-verify-run-001/story-files',\n422\t      verdictDir: '/tmp/codeharness-verify-run-001/verdict',\n423\t      toDispatchOptions: () => ({ cwd: '/tmp/codeharness-verify-run-001' }),\n424\t      cleanup: vi.fn().mockResolvedValue(undefined),\n425\t    };\n426\t    mockCreateIsolatedWorkspace.mockResolvedValue(mockWorkspace);\n427\t\n428\t    const task = makeTask({ source_access: false });\n429\t    const definition = makeDefinition();\n430\t    const state = makeDefaultState();\n431\t    const config = makeConfig();\n432\t\n433\t    await dispatchTask(task, 'verify', '__run__', definition, state, config);\n434\t\n435\t    expect(mockCreateIsolatedWorkspace).toHaveBeenCalledWith({\n436\t      runId: 'run-001',\n437\t      storyFiles: [],\n438\t    });\n439\t    expect(mockDispatchAgent).toHaveBeenCalledWith(\n440\t      definition,\n441\t      expect.any(String),\n442\t      expect.objectContaining({ cwd: '/tmp/codeharness-verify-run-001' }),\n443\t    );\n444\t    expect(mockWorkspace.cleanup).toHaveBeenCalled();\n445\t  });\n446\t\n447\t  it('writes state to disk after each dispatch (AC #4)', async () => {\n448\t    const task = makeTask();\n449\t    const definition = makeDefinition();\n450\t    const state = makeDefaultState();\n451\t    const config = makeConfig();\n452\t\n453\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n454\t\n455\t    expect(mockWriteWorkflowState).toHaveBeenCalled();\n456\t    // State should have the new checkpoint\n457\t    const writtenState = mockWriteWorkflowState.mock.calls[0][0] as WorkflowState;\n458\t    expect(writtenState.trace_ids).toContain('ch-run-001-0-implement');\n459\t  });\n460\t\n461\t  it('records trace ID in workflow state (AC #11)', async () => {\n462\t    const task = makeTask();\n463\t    const definition = makeDefinition();\n464\t    const state = makeDefaultState();\n465\t    const config = makeConfig();\n466\t\n467\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n468\t\n469\t    expect(mockRecordTraceId).toHaveBeenCalledWith('ch-run-001-0-implement', expect.any(Object));\n470\t  });\n471\t\n472\t  it('records session ID after successful dispatch', async () => {\n473\t    const task = makeTask();\n474\t    const definition = makeDefinition();\n475\t    const state = makeDefaultState();\n476\t    const config = makeConfig();\n477\t\n478\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n479\t\n480\t    expect(mockRecordSessionId).toHaveBeenCalledWith(\n481\t      { taskName: 'implement', storyKey: '5-1-foo' },\n482\t      'sess-abc-123',\n483\t      expect.any(Object),\n484\t    );\n485\t  });\n486\t\n487\t  it('appends checkpoint manually when dispatch returns no sessionId', async () => {\n488\t    mockDispatchAgent.mockResolvedValue({\n489\t      sessionId: '',\n490\t      success: true,\n491\t      durationMs: 100,\n492\t      output: 'ok',\n493\t    });\n494\t\n495\t    const task = makeTask();\n496\t    const definition = makeDefinition();\n497\t    const state = makeDefaultState();\n498\t    const config = makeConfig();\n499\t\n500\t    const result = await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n501\t\n502\t    // recordSessionId should NOT be called (empty string is falsy)\n503\t    expect(mockRecordSessionId).not.toHaveBeenCalled();\n504\t    // State should have a manually-created checkpoint\n505\t    const writtenState = mockWriteWorkflowState.mock.calls[0][0] as WorkflowState;\n506\t    expect(writtenState.tasks_completed).toHaveLength(1);\n507\t    expect(writtenState.tasks_completed[0].task_name).toBe('implement');\n508\t    expect(writtenState.tasks_completed[0].story_key).toBe('5-1-foo');\n509\t  });\n510\t\n511\t  it('cleans up workspace on dispatch error when source_access is false', async () => {\n512\t    const mockWorkspace = {\n513\t      dir: '/tmp/test',\n514\t      storyFilesDir: '/tmp/test/story-files',\n515\t      verdictDir: '/tmp/test/verdict',\n516\t      toDispatchOptions: () => ({ cwd: '/tmp/test' }),\n517\t      cleanup: vi.fn().mockResolvedValue(undefined),\n518\t    };\n519\t    mockCreateIsolatedWorkspace.mockResolvedValue(mockWorkspace);\n520\t    mockDispatchAgent.mockRejectedValue(new Error('dispatch failed'));\n521\t\n522\t    const task = makeTask({ source_access: false });\n523\t    const definition = makeDefinition();\n524\t    const state = makeDefaultState();\n525\t    const config = makeConfig();\n526\t\n527\t    await expect(\n528\t      dispatchTask(task, 'verify', '__run__', definition, state, config),\n529\t    ).rejects.toThrow('dispatch failed');\n530\t\n531\t    // Cleanup should still be called\n532\t    expect(mockWorkspace.cleanup).toHaveBeenCalled();\n533\t  });\n534\t\n535\t  it('constructs per-run prompt for sentinel key', async () => {\n536\t    const task = makeTask({ scope: 'per-run' });\n537\t    const definition = makeDefinition();\n538\t    const state = makeDefaultState();\n539\t    const config = makeConfig();\n540\t\n541\t    await dispatchTask(task, 'verify', '__run__', definition, state, config);\n542\t\n543\t    expect(mockDispatchAgent).toHaveBeenCalledWith(\n544\t      definition,\n545\t      'Execute task \"verify\" for the current run.',\n546\t      expect.any(Object),\n547\t    );\n548\t  });\n549\t});\n550\t\n551\tdescribe('executeWorkflow', () => {\n552\t  beforeEach(() => {\n553\t    vi.clearAllMocks();\n554\t    setupDefaultMocks();\n555\t  });\n556\t\n557\t  it('executes flow steps sequentially in order (AC #2)', async () => {\n558\t    const callOrder: string[] = [];\n559\t    mockDispatchAgent.mockImplementation(\n560\t      async (_def: SubagentDefinition, prompt: string) => {\n561\t        callOrder.push(prompt);\n562\t        return { sessionId: 'sess-1', success: true, durationMs: 100, output: 'ok' };\n563\t      },\n564\t    );\n565\t\n566\t    // Two stories, flow: [implement, verify]\n567\t    mockParse.mockReturnValue({\n568\t      development_status: {\n569\t        '3-1-foo': 'ready-for-dev',\n570\t        '3-2-bar': 'backlog',\n571\t      },\n572\t    });\n573\t\n574\t    const config = makeConfig();\n575\t    const result = await executeWorkflow(config);\n576\t\n577\t    expect(result.success).toBe(true);\n578\t    // implement dispatched for each story, then verify once\n579\t    expect(callOrder).toEqual([\n580\t      'Implement story 3-1-foo',\n581\t      'Implement story 3-2-bar',\n582\t      'Execute task \"verify\" for the current run.',\n583\t    ]);\n584\t  });\n585\t\n586\t  it('dispatches per-story task once per story (AC #3)', async () => {\n587\t    mockParse.mockReturnValue({\n588\t      development_status: {\n589\t        '3-1-foo': 'ready-for-dev',\n590\t        '3-2-bar': 'backlog',\n591\t      },\n592\t    });\n593\t\n594\t    const config = makeConfig({\n595\t      workflow: {\n596\t        tasks: { implement: makeTask() },\n597\t        flow: ['implement'],\n598\t      },\n599\t    });\n600\t\n601\t    const result = await executeWorkflow(config);\n602\t\n603\t    expect(mockDispatchAgent).toHaveBeenCalledTimes(2);\n604\t    expect(result.tasksCompleted).toBe(2);\n605\t    expect(result.storiesProcessed).toBe(2);\n606\t  });\n607\t\n608\t  it('dispatches per-run task exactly once with sentinel key (AC #7)', async () => {\n609\t    mockParse.mockReturnValue({\n610\t      development_status: {\n611\t        '3-1-foo': 'ready-for-dev',\n612\t        '3-2-bar': 'backlog',\n613\t      },\n614\t    });\n615\t\n616\t    const config = makeConfig({\n617\t      workflow: {\n618\t        tasks: { verify: makeTask({ scope: 'per-run' }) },\n619\t        flow: ['verify'],\n620\t      },\n621\t    });\n622\t\n623\t    const result = await executeWorkflow(config);\n624\t\n625\t    expect(mockDispatchAgent).toHaveBeenCalledTimes(1);\n626\t    expect(result.tasksCompleted).toBe(1);\n627\t  });\n628\t\n629\t  it('writes state after each task completion (AC #4)', async () => {\n630\t    mockParse.mockReturnValue({\n631\t      development_status: {\n632\t        '3-1-foo': 'ready-for-dev',\n633\t      },\n634\t    });\n635\t\n636\t    const config = makeConfig({\n637\t      workflow: {\n638\t        tasks: { implement: makeTask() },\n639\t        flow: ['implement'],\n640\t      },\n641\t    });\n642\t\n643\t    await executeWorkflow(config);\n644\t\n645\t    // writeWorkflowState called: initial state + after dispatch + final completed state\n646\t    expect(mockWriteWorkflowState).toHaveBeenCalledTimes(3);\n647\t  });\n648\t\n649\t  it('skips loop blocks with warning (AC #8)', async () => {\n650\t    const config = makeConfig({\n651\t      workflow: {\n652\t        tasks: { implement: makeTask() },\n653\t        flow: ['implement', { loop: ['implement'] }],\n654\t      },\n655\t    });\n656\t\n657\t    mockParse.mockReturnValue({\n658\t      development_status: { '3-1-foo': 'ready-for-dev' },\n659\t    });\n660\t\n661\t    const result = await executeWorkflow(config);\n662\t\n663\t    expect(mockWarn).toHaveBeenCalledWith(\n664\t      expect.stringContaining('loop blocks are not yet implemented'),\n665\t    );\n666\t    // Only the string task should have dispatched\n667\t    expect(mockDispatchAgent).toHaveBeenCalledTimes(1);\n668\t    expect(result.success).toBe(true);\n669\t  });\n670\t\n671\t  it('handles DispatchError and records in result (AC #13)', async () => {\n672\t    const { DispatchError } = await import('../agent-dispatch.js');\n673\t    mockDispatchAgent.mockRejectedValue(\n674\t      new DispatchError('rate limited', 'UNKNOWN', 'dev', new Error('inner')),\n675\t    );\n676\t\n677\t    mockParse.mockReturnValue({\n678\t      development_status: { '3-1-foo': 'ready-for-dev' },\n679\t    });\n680\t\n681\t    const config = makeConfig({\n682\t      workflow: {\n683\t        tasks: { implement: makeTask() },\n684\t        flow: ['implement'],\n685\t      },\n686\t    });\n687\t\n688\t    const result = await executeWorkflow(config);\n689\t\n690\t    expect(result.success).toBe(false);\n691\t    expect(result.errors).toHaveLength(1);\n692\t    expect(result.errors[0].code).toBe('UNKNOWN');\n693\t    expect(result.errors[0].taskName).toBe('implement');\n694\t    expect(result.errors[0].storyKey).toBe('3-1-foo');\n695\t  });\n696\t\n697\t  it('halts on RATE_LIMIT dispatch errors (AC #13)', async () => {\n698\t    const { DispatchError } = await import('../agent-dispatch.js');\n699\t    mockDispatchAgent.mockRejectedValue(\n700\t      new DispatchError('rate limited', 'RATE_LIMIT', 'dev', new Error('inner')),\n701\t    );\n702\t\n703\t    mockParse.mockReturnValue({\n704\t      development_status: {\n705\t        '3-1-foo': 'ready-for-dev',\n706\t        '3-2-bar': 'backlog',\n707\t      },\n708\t    });\n709\t\n710\t    const config = makeConfig({\n711\t      workflow: {\n712\t        tasks: { implement: makeTask() },\n713\t        flow: ['implement'],\n714\t      },\n715\t    });\n716\t\n717\t    const result = await executeWorkflow(config);\n718\t\n719\t    expect(result.success).toBe(false);\n720\t    // Should halt after first error — only one dispatch attempted\n721\t    expect(mockDispatchAgent).toHaveBeenCalledTimes(1);\n722\t    expect(result.errors).toHaveLength(1);\n723\t  });\n724\t\n725\t  it('continues on UNKNOWN errors for per-story tasks (AC #13)', async () => {\n726\t    const { DispatchError } = await import('../agent-dispatch.js');\n727\t    let callCount = 0;\n728\t    mockDispatchAgent.mockImplementation(async () => {\n729\t      callCount++;\n730\t      if (callCount === 1) {\n731\t        throw new DispatchError('unknown error', 'UNKNOWN', 'dev', new Error('inner'));\n732\t      }\n733\t      return { sessionId: 'sess-1', success: true, durationMs: 100, output: 'ok' };\n734\t    });\n735\t\n736\t    mockParse.mockReturnValue({\n737\t      development_status: {\n738\t        '3-1-foo': 'ready-for-dev',\n739\t        '3-2-bar': 'backlog',\n740\t      },\n741\t    });\n742\t\n743\t    const config = makeConfig({\n744\t      workflow: {\n745\t        tasks: { implement: makeTask() },\n746\t        flow: ['implement'],\n747\t      },\n748\t    });\n749\t\n750\t    const result = await executeWorkflow(config);\n751\t\n752\t    // Both stories attempted\n753\t    expect(mockDispatchAgent).toHaveBeenCalledTimes(2);\n754\t    expect(result.errors).toHaveLength(1);\n755\t    expect(result.tasksCompleted).toBe(1);\n756\t  });\n757\t\n758\t  it('sets phase to error on dispatch failure', async () => {\n759\t    const { DispatchError } = await import('../agent-dispatch.js');\n760\t    mockDispatchAgent.mockRejectedValue(\n761\t      new DispatchError('fail', 'UNKNOWN', 'dev', new Error('inner')),\n762\t    );\n763\t\n764\t    mockParse.mockReturnValue({\n765\t      development_status: { '3-1-foo': 'ready-for-dev' },\n766\t    });\n767\t\n768\t    const config = makeConfig({\n769\t      workflow: {\n770\t        tasks: { implement: makeTask() },\n771\t        flow: ['implement'],\n772\t      },\n773\t    });\n774\t\n775\t    await executeWorkflow(config);\n776\t\n777\t    // Find the write call that sets phase to \"error\"\n778\t    const errorWrite = mockWriteWorkflowState.mock.calls.find(\n779\t      (call: unknown[]) => (call[0] as WorkflowState).phase === 'error',\n780\t    );\n781\t    expect(errorWrite).toBeDefined();\n782\t  });\n783\t\n784\t  it('sets phase to completed when no errors occur', async () => {\n785\t    mockParse.mockReturnValue({\n786\t      development_status: { '3-1-foo': 'ready-for-dev' },\n787\t    });\n788\t\n789\t    const config = makeConfig({\n790\t      workflow: {\n791\t        tasks: { implement: makeTask() },\n792\t        flow: ['implement'],\n793\t      },\n794\t    });\n795\t\n796\t    await executeWorkflow(config);\n797\t\n798\t    const lastWrite = mockWriteWorkflowState.mock.calls[\n799\t      mockWriteWorkflowState.mock.calls.length - 1\n800\t    ];\n801\t    expect((lastWrite[0] as WorkflowState).phase).toBe('completed');\n802\t  });\n803\t\n804\t  it('initializes workflow state with phase=executing at start', async () => {\n805\t    mockParse.mockReturnValue({\n806\t      development_status: { '3-1-foo': 'ready-for-dev' },\n807\t    });\n808\t\n809\t    const config = makeConfig({\n810\t      workflow: {\n811\t        tasks: { implement: makeTask() },\n812\t        flow: ['implement'],\n813\t      },\n814\t    });\n815\t\n816\t    await executeWorkflow(config);\n817\t\n818\t    const firstWrite = mockWriteWorkflowState.mock.calls[0];\n819\t    expect((firstWrite[0] as WorkflowState).phase).toBe('executing');\n820\t  });\n821\t\n822\t  it('invokes source isolation for per-run task with source_access false', async () => {\n823\t    const mockWorkspace = {\n824\t      dir: '/tmp/test',\n825\t      storyFilesDir: '/tmp/test/story-files',\n826\t      verdictDir: '/tmp/test/verdict',\n827\t      toDispatchOptions: () => ({ cwd: '/tmp/test' }),\n828\t      cleanup: vi.fn().mockResolvedValue(undefined),\n829\t    };\n830\t    mockCreateIsolatedWorkspace.mockResolvedValue(mockWorkspace);\n831\t\n832\t    mockParse.mockReturnValue({\n833\t      development_status: { '3-1-foo': 'ready-for-dev' },\n834\t    });\n835\t\n836\t    const config = makeConfig({\n837\t      workflow: {\n838\t        tasks: {\n839\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n840\t        },\n841\t        flow: ['verify'],\n842\t      },\n843\t    });\n844\t\n845\t    await executeWorkflow(config);\n846\t\n847\t    expect(mockCreateIsolatedWorkspace).toHaveBeenCalled();\n848\t    expect(mockWorkspace.cleanup).toHaveBeenCalled();\n849\t  });\n850\t\n851\t  it('does NOT invoke source isolation for source_access true tasks', async () => {\n852\t    mockParse.mockReturnValue({\n853\t      development_status: { '3-1-foo': 'ready-for-dev' },\n854\t    });\n855\t\n856\t    const config = makeConfig({\n857\t      workflow: {\n858\t        tasks: { implement: makeTask({ source_access: true }) },\n859\t        flow: ['implement'],\n860\t      },\n861\t    });\n862\t\n863\t    await executeWorkflow(config);\n864\t\n865\t    expect(mockCreateIsolatedWorkspace).not.toHaveBeenCalled();\n866\t  });\n867\t\n868\t  it('returns correct EngineResult shape', async () => {\n869\t    mockParse.mockReturnValue({\n870\t      development_status: {\n871\t        '3-1-foo': 'ready-for-dev',\n872\t        '3-2-bar': 'backlog',\n873\t      },\n874\t    });\n875\t\n876\t    const config = makeConfig({\n877\t      workflow: {\n878\t        tasks: {\n879\t          implement: makeTask(),\n880\t          verify: makeTask({ scope: 'per-run' }),\n881\t        },\n882\t        flow: ['implement', 'verify'],\n883\t      },\n884\t    });\n885\t\n886\t    const result = await executeWorkflow(config);\n887\t\n888\t    expect(result).toEqual(\n889\t      expect.objectContaining({\n890\t        success: true,\n891\t        tasksCompleted: 3, // 2 per-story + 1 per-run\n892\t        storiesProcessed: 2,\n893\t        errors: [],\n894\t      }),\n895\t    );\n896\t    expect(typeof result.durationMs).toBe('number');\n897\t    expect(result.durationMs).toBeGreaterThanOrEqual(0);\n898\t  });\n899\t\n900\t  it('handles empty 