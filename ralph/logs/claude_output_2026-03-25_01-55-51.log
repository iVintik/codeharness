{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011VyUctHa2NAnr7jSVF5y6k","type":"tool_result","content":"     1→/**\n     2→ * Retro-to-Sprint pipeline: processes retro action items into TD stories\n     3→ * and manages the persistent epic-TD in sprint state.\n     4→ */\n     5→\n     6→import { writeFileSync, readFileSync, existsSync } from 'node:fs';\n     7→import { join } from 'node:path';\n     8→import { parseRetroSections, isDuplicate } from './retro-parser.js';\n     9→import type { RetroSectionItem } from './retro-parser.js';\n    10→import type { SprintState, EpicState, StoryState } from '../types/state.js';\n    11→\n    12→/** Result of processing retro action items */\n    13→export interface ProcessRetroResult {\n    14→  readonly updatedState: SprintState;\n    15→  readonly created: string[];\n    16→  readonly skipped: string[];\n    17→  readonly backlogAppended: string[];\n    18→}\n    19→\n    20→/**\n    21→ * Generate a slug from item text.\n    22→ * Lowercase, replace non-alphanumeric with hyphens, truncate to 40 chars, trim trailing hyphens.\n    23→ */\n    24→export function generateSlug(text: string): string {\n    25→  return text\n    26→    .toLowerCase()\n    27→    .replace(/[^a-z0-9]+/g, '-')\n    28→    .replace(/^-+|-+$/g, '')\n    29→    .slice(0, 40)\n    30→    .replace(/-+$/, '');\n    31→}\n    32→\n    33→/**\n    34→ * Scan existing TD-* story keys and return the next story number.\n    35→ * Returns max existing N + 1, or 1 if none exist.\n    36→ */\n    37→export function nextTdStoryNumber(state: SprintState): number {\n    38→  let max = 0;\n    39→  for (const key of Object.keys(state.stories)) {\n    40→    const match = key.match(/^TD-(\\d+)-/);\n    41→    if (match) {\n    42→      const n = parseInt(match[1], 10);\n    43→      if (n > max) max = n;\n    44→    }\n    45→  }\n    46→  return max + 1;\n    47→}\n    48→\n    49→/**\n    50→ * Ensure epic-TD exists in state. Creates it if absent.\n    51→ * Returns updated state (immutable — returns new object).\n    52→ */\n    53→export function ensureEpicTd(state: SprintState): SprintState {\n    54→  if (state.epics['epic-TD']) return state;\n    55→  const epicTd: EpicState = {\n    56→    status: 'in-progress',\n    57→    storiesTotal: 0,\n    58→    storiesDone: 0,\n    59→  };\n    60→  return {\n    61→    ...state,\n    62→    epics: { ...state.epics, 'epic-TD': epicTd },\n    63→  };\n    64→}\n    65→\n    66→/**\n    67→ * Add a TD story to sprint state. Increments epic-TD.storiesTotal.\n    68→ * Returns updated state.\n    69→ */\n    70→export function createTdStory(state: SprintState, slug: string): SprintState {\n    71→  const num = nextTdStoryNumber(state);\n    72→  const key = `TD-${num}-${slug}`;\n    73→  const story: StoryState = {\n    74→    status: 'backlog',\n    75→    attempts: 0,\n    76→    lastAttempt: null,\n    77→    lastError: null,\n    78→    proofPath: null,\n    79→    acResults: null,\n    80→  };\n    81→  const currentEpic = state.epics['epic-TD'];\n    82→  const updatedEpic: EpicState = {\n    83→    status: 'in-progress',\n    84→    storiesTotal: (currentEpic?.storiesTotal ?? 0) + 1,\n    85→    storiesDone: currentEpic?.storiesDone ?? 0,\n    86→  };\n    87→  return {\n    88→    ...state,\n    89→    stories: { ...state.stories, [key]: story },\n    90→    epics: { ...state.epics, 'epic-TD': updatedEpic },\n    91→  };\n    92→}\n    93→\n    94→/**\n    95→ * Append backlog items to tech-debt-backlog.md at project root.\n    96→ * Creates the file with a header if it doesn't exist.\n    97→ */\n    98→function appendToBacklogFile(items: string[], projectRoot: string): void {\n    99→  const filePath = join(projectRoot, 'tech-debt-backlog.md');\n   100→  const date = new Date().toISOString().slice(0, 10);\n   101→\n   102→  let content = '';\n   103→  if (existsSync(filePath)) {\n   104→    content = readFileSync(filePath, 'utf-8');\n   105→  } else {\n   106→    content = '## Backlog Items (auto-appended from retros)\\n\\n';\n   107→  }\n   108→\n   109→  for (const item of items) {\n   110→    content += `- [${date}] ${item}\\n`;\n   111→  }\n   112→\n   113→  writeFileSync(filePath, content, 'utf-8');\n   114→}\n   115→\n   116→/**\n   117→ * Get existing TD story titles from state for deduplication.\n   118→ */\n   119→function getExistingTdTitles(state: SprintState): string[] {\n   120→  return Object.keys(state.stories)\n   121→    .filter(k => k.startsWith('TD-'))\n   122→    .map(k => k.replace(/^TD-\\d+-/, '').replace(/-/g, ' '));\n   123→}\n   124→\n   125→/**\n   126→ * Process retro action items into TD stories and backlog entries.\n   127→ *\n   128→ * - fix-now and fix-soon items: create TD-N-slug stories (with dedup check)\n   129→ * - backlog items: append to tech-debt-backlog.md (no sprint-state stories)\n   130→ */\n   131→export function processRetroActionItems(\n   132→  retroContent: string,\n   133→  state: SprintState,\n   134→  projectRoot?: string,\n   135→): ProcessRetroResult {\n   136→  const sectionItems = parseRetroSections(retroContent);\n   137→  const created: string[] = [];\n   138→  const skipped: string[] = [];\n   139→  const backlogAppended: string[] = [];\n   140→\n   141→  let current = ensureEpicTd(state);\n   142→\n   143→  const backlogItems: string[] = [];\n   144→\n   145→  for (const item of sectionItems) {\n   146→    if (item.section === 'backlog') {\n   147→      backlogItems.push(item.text);\n   148→      backlogAppended.push(item.text);\n   149→      continue;\n   150→    }\n   151→\n   152→    // fix-now or fix-soon: create TD story\n   153→    const existingTitles = getExistingTdTitles(current);\n   154→    const dedupResult = isDuplicate(item.text, existingTitles);\n   155→    if (dedupResult.duplicate) {\n   156→      console.log(`[INFO] Skipping duplicate: \"${item.text}\" (matches: \"${dedupResult.matchedTitle}\")`);\n   157→      skipped.push(item.text);\n   158→      continue;\n   159→    }\n   160→\n   161→    const slug = generateSlug(item.text);\n   162→    current = createTdStory(current, slug);\n   163→    created.push(item.text);\n   164→  }\n   165→\n   166→  // Append backlog items to file\n   167→  if (backlogItems.length > 0 && projectRoot) {\n   168→    appendToBacklogFile(backlogItems, projectRoot);\n   169→  }\n   170→\n   171→  return { updatedState: current, created, skipped, backlogAppended };\n   172→}\n   173→"}]},"parent_tool_use_id":"toolu_01QdekhbhdCn1yMfA8HwX61q","session_id":"84a01a9c-e466-45b4-91ef-8201b3712d8d","uuid":"6d331410-a099-479e-9c23-015e2d43cf9c","timestamp":"2026-03-24T21:56:58.032Z"}
