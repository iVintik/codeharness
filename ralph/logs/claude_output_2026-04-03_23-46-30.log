{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NXXKQ4N52WAaKuchZ2UhWQ","type":"tool_result","content":"1\t/** Proof quality validation and black-box enforcement. */\n2\timport { existsSync, readFileSync } from 'node:fs';\n3\timport type { ProofQuality, ClassifiedCommand, EvidenceCommandType, BlackBoxEnforcementResult, VerificationTier } from './types.js';\n4\timport { TIER_HIERARCHY, LEGACY_TIER_MAP } from './types.js';\n5\t\n6\t/** Extracts commands from ```bash/```shell blocks and classifies each. */\n7\texport function classifyEvidenceCommands(proofContent: string): ClassifiedCommand[] {\n8\t  const results: ClassifiedCommand[] = [];\n9\t\n10\t  const codeBlockPattern = /```(?:bash|shell)\\n([\\s\\S]*?)```/g;\n11\t  for (const match of proofContent.matchAll(codeBlockPattern)) {\n12\t    const block = match[1].trim();\n13\t    const lines = block.split('\\n').filter(l => l.trim().length > 0);\n14\t    for (const line of lines) {\n15\t      const cmd = line.trim();\n16\t      if (!cmd) continue;\n17\t      results.push({ command: cmd, type: classifyCommand(cmd) });\n18\t    }\n19\t  }\n20\t\n21\t  return results;\n22\t}\n23\t\n24\tfunction classifyCommand(cmd: string): EvidenceCommandType {\n25\t  if (/docker\\s+exec\\b/.test(cmd)) {\n26\t    return 'docker-exec';\n27\t  }\n28\t\n29\t  if (/docker\\s+(ps|logs|inspect|stats|top|port)\\b/.test(cmd)) {\n30\t    return 'docker-host';\n31\t  }\n32\t\n33\t  if (/curl\\b/.test(cmd) && /localhost:(9428|8428|16686)\\b/.test(cmd)) {\n34\t    return 'observability';\n35\t  }\n36\t\n37\t  if (/\\bgrep\\b/.test(cmd) && /\\bsrc\\//.test(cmd)) {\n38\t    return 'grep-src';\n39\t  }\n40\t\n41\t  return 'other';\n42\t}\n43\t\n44\t/** Checks black-box enforcement: rejects >50% grep src/ or missing docker exec per AC. */\n45\texport function checkBlackBoxEnforcement(proofContent: string): BlackBoxEnforcementResult {\n46\t  const commands = classifyEvidenceCommands(proofContent);\n47\t\n48\t  const grepSrcCount = commands.filter(c => c.type === 'grep-src').length;\n49\t  const dockerExecCount = commands.filter(c => c.type === 'docker-exec').length;\n50\t  const observabilityCount = commands.filter(c => c.type === 'observability').length;\n51\t  const otherCount = commands.filter(c => c.type === 'other').length;\n52\t  const totalCommands = commands.length;\n53\t\n54\t  const grepRatio = totalCommands > 0 ? grepSrcCount / totalCommands : 0;\n55\t\n56\t  // Check per-AC docker exec presence\n57\t  const acsMissingDockerExec: number[] = [];\n58\t  const acHeaderPattern = /^## AC ?(\\d+):/gm;\n59\t  const acMatches = [...proofContent.matchAll(acHeaderPattern)];\n60\t\n61\t  if (acMatches.length > 0) {\n62\t    for (let i = 0; i < acMatches.length; i++) {\n63\t      const acNum = parseInt(acMatches[i][1], 10);\n64\t      const start = acMatches[i].index!;\n65\t      const end = i + 1 < acMatches.length ? acMatches[i + 1].index! : proofContent.length;\n66\t      const section = proofContent.slice(start, end);\n67\t\n68\t      // Skip escalated ACs\n69\t      if (section.includes('[ESCALATE]')) continue;\n70\t\n71\t      const sectionCommands = classifyEvidenceCommands(section);\n72\t      const hasBlackBoxEvidence = sectionCommands.some(c =>\n73\t        c.type === 'docker-exec' || c.type === 'docker-host' || c.type === 'observability'\n74\t      );\n75\t      if (!hasBlackBoxEvidence) {\n76\t        acsMissingDockerExec.push(acNum);\n77\t      }\n78\t    }\n79\t  }\n80\t\n81\t  const grepTooHigh = grepRatio > 0.5;\n82\t  const missingDockerExec = acsMissingDockerExec.length > 0;\n83\t  const hasExtractableCommands = totalCommands > 0;\n84\t\n85\t  return {\n86\t    blackBoxPass: !hasExtractableCommands || (!grepTooHigh && !missingDockerExec),\n87\t    grepSrcCount,\n88\t    dockerExecCount,\n89\t    observabilityCount,\n90\t    otherCount,"}]},"parent_tool_use_id":null,"session_id":"0d8bd255-97e7-4ce2-b430-6ab2ab2aca0a","uuid":"8d7014b8-0931-4426-91dc-0148df346e4d","timestamp":"2026-04-03T19:55:46.486Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ivintik/dev/personal/codeharness/src/modules/verify/proof.ts","content":"/** Proof quality validation and black-box enforcement. */\nimport { existsSync, readFileSync } from 'node:fs';\nimport type { ProofQuality, ClassifiedCommand, EvidenceCommandType, BlackBoxEnforcementResult, VerificationTier } from './types.js';\nimport { TIER_HIERARCHY, LEGACY_TIER_MAP } from './types.js';\n\n/** Extracts commands from ```bash/```shell blocks and classifies each. */\nexport function classifyEvidenceCommands(proofContent: string): ClassifiedCommand[] {\n  const results: ClassifiedCommand[] = [];\n\n  const codeBlockPattern = /```(?:bash|shell)\\n([\\s\\S]*?)```/g;\n  for (const match of proofContent.matchAll(codeBlockPattern)) {\n    const block = match[1].trim();\n    const lines = block.split('\\n').filter(l => l.trim().length > 0);\n    for (const line of lines) {\n      const cmd = line.trim();\n      if (!cmd) continue;\n      results.push({ command: cmd, type: classifyCommand(cmd) });\n    }\n  }\n\n  return results;\n}\n\nfunction classifyCommand(cmd: string): EvidenceCommandType {\n  if (/docker\\s+exec\\b/.test(cmd)) {\n    return 'docker-exec';\n  }\n\n  if (/docker\\s+(ps|logs|inspect|stats|top|port)\\b/.test(cmd)) {\n    return 'docker-host';\n  }\n\n  if (/curl\\b/.test(cmd) && /localhost:(9428|8428|16686)\\b/.test(cmd)) {\n    return 'observability';\n  }\n\n  if (/\\bgrep\\b/.test(cmd) && /\\bsrc\\//.test(cmd)) {\n    return 'grep-src';\n  }\n\n  return 'other';\n}\n\n/** Checks black-box enforcement: rejects >50% grep src/ or missing docker exec per AC. */\nexport function checkBlackBoxEnforcement(proofContent: string): BlackBoxEnforcementResult {\n  const commands = classifyEvidenceCommands(proofContent);\n\n  const grepSrcCount = commands.filter(c => c.type === 'grep-src').length;\n  const dockerExecCount = commands.filter(c => c.type === 'docker-exec').length;\n  const observabilityCount = commands.filter(c => c.type === 'observability').length;\n  const otherCount = commands.filter(c => c.type === 'other').length;\n  const totalCommands = commands.length;\n\n  const grepRatio = totalCommands > 0 ? grepSrcCount / totalCommands : 0;\n\n  // Check per-AC docker exec presence\n  const acsMissingDockerExec: number[] = [];\n  const acHeaderPattern = /^## AC ?(\\d+):/gm;\n  const acMatches = [...proofContent.matchAll(acHeaderPattern)];\n\n  if (acMatches.length > 0) {\n    for (let i = 0; i < acMatches.length; i++) {\n      const acNum = parseInt(acMatches[i][1], 10);\n      const start = acMatches[i].index!;\n      const end = i + 1 < acMatches.length ? acMatches[i + 1].index! : proofContent.length;\n      const section = proofContent.slice(start, end);\n\n      // Skip escalated ACs\n      if (section.includes('[ESCALATE]')) continue;\n\n      const sectionCommands = classifyEvidenceCommands(section);\n      const hasBlackBoxEvidence = sectionCommands.some(c =>\n        c.type === 'docker-exec' || c.type === 'docker-host' || c.type === 'observability'\n      );\n      if (!hasBlackBoxEvidence) {\n        acsMissingDockerExec.push(acNum);\n      }\n    }\n  }\n\n  const grepTooHigh = grepRatio > 0.5;\n  const missingDockerExec = acsMissingDockerExec.length > 0;\n  const hasExtractableCommands = totalCommands > 0;\n\n  return {\n    blackBoxPass: !hasExtractableCommands || (!grepTooHigh && !missingDockerExec),\n    grepSrcCount,\n    dockerExecCount,\n    observabilityCount,\n    otherCount,","numLines":90,"startLine":1,"totalLines":312}}}
