{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PzApd6u3VLxE467Vdme3d9","type":"tool_result","content":"304\t */\n305\texport function resolveWorkflow(options?: { cwd?: string; name?: string }): ResolvedWorkflow {\n306\t  const cwd = options?.cwd ?? process.cwd();\n307\t  const name = options?.name ?? 'default';\n308\t\n309\t  const userPatchPath = join(os.homedir(), '.codeharness', 'workflows', `${name}.patch.yaml`);\n310\t  const projectPatchPath = join(cwd, '.codeharness', 'workflows', `${name}.patch.yaml`);\n311\t\n312\t  // Check for full custom workflow at project level (not a patch — no extends)\n313\t  const projectCustomPath = join(cwd, '.codeharness', 'workflows', `${name}.yaml`);\n314\t  if (existsSync(projectCustomPath)) {\n315\t    const customPatch = loadWorkflowPatch(projectCustomPath);\n316\t    if (customPatch && !customPatch.extends) {\n317\t      // This is a full custom workflow, not a patch — parse directly\n318\t      return parseWorkflow(projectCustomPath);\n319\t    }\n320\t  }\n321\t\n322\t  // Load embedded base\n323\t  const embeddedPath = join(TEMPLATES_DIR, `${name}.yaml`);\n324\t  let raw: string;\n325\t  try {\n326\t    raw = readFileSync(embeddedPath, 'utf-8');\n327\t  } catch (err: unknown) {\n328\t    const detail = err instanceof Error ? err.message : `File not found: ${embeddedPath}`;\n329\t    throw new WorkflowParseError(`Embedded workflow not found: ${name}`, [\n330\t      { path: embeddedPath, message: detail },\n331\t    ]);\n332\t  }\n333\t\n334\t  let baseData: unknown;\n335\t  try {\n336\t    baseData = parse(raw);\n337\t  } catch (err: unknown) {\n338\t    const msg = err instanceof Error ? err.message : String(err);\n339\t    throw new WorkflowParseError(`Invalid YAML in embedded workflow ${name}: ${msg}`, [\n340\t      { path: embeddedPath, message: msg },\n341\t    ]);\n342\t  }\n343\t\n344\t  let merged = baseData as Record<string, unknown>;\n345\t\n346\t  // Apply user-level patch\n347\t  const userPatch = loadWorkflowPatch(userPatchPath);\n348\t  if (userPatch) {\n349\t    merged = mergeWorkflowPatch(merged, userPatch);\n350\t  }\n351\t\n352\t  // Apply project-level patch\n353\t  const projectPatch = loadWorkflowPatch(projectPatchPath);\n354\t  if (projectPatch) {\n355\t    merged = mergeWorkflowPatch(merged, projectPatch);\n356\t  }\n357\t\n358\t  // Validate, check referential integrity, apply defaults, and return\n359\t  return validateAndResolve(merged);\n360\t}\n361\t"}]},"parent_tool_use_id":"toolu_01Rc1jZLz1bpJyVVhPKGgdgx","session_id":"c2800ecc-75a3-43b2-b3d8-396855aa3c3c","uuid":"de767d3e-0cd3-4923-a2df-966ded8451e4","timestamp":"2026-04-03T03:11:48.265Z"}
