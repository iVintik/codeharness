{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015Xgg3ymGA75WBUvgfTXNWu","type":"tool_result","content":"1\timport Ajv from 'ajv';\n2\timport workflowSchema from '../schemas/workflow.schema.json';\n3\t\n4\t// --- Interfaces ---\n5\t\n6\texport interface ValidationError {\n7\t  path: string;\n8\t  message: string;\n9\t  keyword: string;\n10\t}\n11\t\n12\texport interface ValidationResult {\n13\t  valid: boolean;\n14\t  errors: ValidationError[];\n15\t}\n16\t\n17\t// --- Validation ---\n18\t\n19\tconst ajv = new Ajv({ allErrors: true });\n20\tconst validateWorkflow = ajv.compile(workflowSchema);\n21\t\n22\t/**\n23\t * Validate data against a JSON schema.\n24\t * Schema-agnostic: pass any compiled Ajv ValidateFunction.\n25\t */\n26\texport function validateAgainstSchema(\n27\t  data: unknown,\n28\t  validate: ReturnType<typeof ajv.compile>,\n29\t): ValidationResult {\n30\t  const valid = validate(data);\n31\t\n32\t  if (valid) {\n33\t    return { valid: true, errors: [] };\n34\t  }\n35\t\n36\t  const errors: ValidationError[] = (validate.errors ?? []).map((err) => ({\n37\t    path: err.instancePath || '/',\n38\t    message: err.message ?? 'Unknown validation error',\n39\t    keyword: err.keyword,\n40\t  }));\n41\t\n42\t  return { valid: false, errors };\n43\t}\n44\t\n45\t/**\n46\t * Validate data against the workflow YAML schema.\n47\t * Primary entry point for workflow validation.\n48\t */\n49\texport function validateWorkflowSchema(data: unknown): ValidationResult {\n50\t  return validateAgainstSchema(data, validateWorkflow);\n51\t}\n52\t"}]},"parent_tool_use_id":"toolu_01FLHeMC7z4edzYfkx1nRfuA","session_id":"fb9c1538-17c2-48c5-8d63-6a9f60fb8dd3","uuid":"d457021b-4489-484a-82d9-2b7cee915434","timestamp":"2026-04-02T15:12:13.007Z"}
