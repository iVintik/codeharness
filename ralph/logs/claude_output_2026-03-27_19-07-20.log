story\": \"15-5-lint-rule-bare-exception-swallowing\",\n      \"description\": \"None. Story file already existed from prior planning session.\",\n      \"source\": \"retro\",\n      \"resolved\": false\n    },\n    {\n      \"id\": \"migrated-28\",\n      \"story\": \"15-5-lint-rule-bare-exception-swallowing\",\n      \"description\": \"`patches/error-handling/` directory doesn't exist yet вЂ” needs to be created.\",\n      \"source\": \"retro\",\n      \"resolved\": false\n    },\n    {\n      \"id\": \"migrated-29\",\n      \"story\": \"15-5-lint-rule-bare-exception-swallowing\",\n      \"description\": \"AC1 references code-review subagent integration but is tagged cli-verifiable вЂ” borderline.\",\n      \"source\": \"retro\",\n      \"resolved\": false\n    },\n    {\n      \"id\": \"migrated-30\",\n      \"story\": \"15-5-lint-rule-bare-exception-swallowing\",\n      \"description\": \"Story was pre-created. Verification tags already present and correct.\",\n      \"source\": \"retro\",\n      \"resolved\": false\n    },\n    {\n      \"id\": \"migrated-31\",\n      \"story\": \"15-5-lint-rule-bare-exception-swallowing\",\n      \"description\": \"`src/lib/scanner.ts` listed in story but has no Semgrep integration вЂ” actual Semgrep logic lives in `src/modules/observability/analyzer.ts`.\",\n      \"source\": \"retro\",\n      \"resolved\": false\n    },\n    {\n      \"id\": \"migrated-32\",\n      \"story\": \"15-5-lint-rule-bare-exception-swallowing\",\n      \"description\": \"Semgrep test fixtures use annotation format but can only validate with semgrep installed. Vitest tests validate file existence/content only.\",\n      \"source\": \"retro\",\n      \"resolved\": false\n    },\n    {\n      \"id\": \"migrated-33\",\n      \"story\": \"15-5-lint-rule-bare-exception-swallowing\",\n      \"description\": \"`no-bare-except-ellipsis` rule uses Semgrep `...` metavariable вЂ” matches ALL except bodies, not just literal Ellipsis. Correct per AC1 but name mis