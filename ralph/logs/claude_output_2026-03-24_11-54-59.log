   283→    expect(directives).toContain('node_modules');\n   284→    expect(directives).toContain('./app/');\n   285→  });\n   286→});\n   287→\n   288→// ── parseTestOutput (AC12, AC13) ─────────────────────────────────────────────\n   289→\n   290→describe('NodejsProvider.parseTestOutput', () => {\n   291→  it('parses vitest format: \"Tests  12 passed | 3 failed\" (AC12)', () => {\n   292→    const result = provider.parseTestOutput('Tests  12 passed | 3 failed');\n   293→    expect(result).toEqual({ passed: 12, failed: 3, skipped: 0, total: 15 });\n   294→  });\n   295→\n   296→  it('parses vitest format with only passed', () => {\n   297→    const result = provider.parseTestOutput('Tests  5 passed');\n   298→    expect(result).toEqual({ passed: 5, failed: 0, skipped: 0, total: 5 });\n   299→  });\n   300→\n   301→  it('parses jest format: \"Tests:  3 failed, 12 passed, 15 total\" (AC13)', () => {\n   302→    const result = provider.parseTestOutput('Tests:  3 failed, 12 passed, 15 total');\n   303→    expect(result).toEqual({ passed: 12, failed: 3, skipped: 0, total: 15 });\n   304→  });\n   305→\n   306→  it('parses jest format with only passed', () => {\n   307→    const result = provider.parseTestOutput('Tests:  12 passed, 12 total');\n   308→    expect(result).toEqual({ passed: 12, failed: 0, skipped: 0, total: 12 });\n   309→  });\n   310→\n   311→  it('returns zeros for unrecognized output', () => {\n   312→    const result = provider.parseTestOutput('some random output');\n   313→    expect(result).toEqual({ passed: 0, failed: 0, skipped: 0, total: 0 });\n   314→  });\n   315→\n   316→  it('returns zeros for empty string', () => {\n   317→    const result = provider.parseTestOutput('');\n   318→    expect(result).toEqual({ passed: 0, failed: 0, skipped: 0, total: 0 });\n   319→  });\n   320→\n   321→  it('parses vitest output embedded in larger text', () => {\n   322→    const output = `\n   323→ ✓ src/lib/__tests__/foo.test.ts (3)\n   324→ ✗ src/lib/__test