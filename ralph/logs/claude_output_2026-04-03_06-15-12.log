{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PhxcHmiT3q6HK8YvByMB2g","type":"tool_result","content":"148\t */\n149\tfunction importToIssuesYaml(\n150\t  content: string,\n151\t  epicNum: number,\n152\t  dir: string,\n153\t  isJson: boolean,\n154\t): LocalImportResult {\n155\t  const source = `retro-epic-${epicNum}`;\n156\t  const result: LocalImportResult = { imported: 0, skipped: 0, duplicates: 0, issues: [] };\n157\t\n158\t  // Read existing issue titles for dedup\n159\t  const existingIssues = readIssues(dir);\n160\t  const existingTitles = existingIssues.issues.map(i => i.title);\n161\t\n162\t  // Strategy: try section-based first, fall back to table-based\n163\t  const sectionItems = parseRetroSections(content);\n164\t  const actionableSections = sectionItems.filter(i => i.section !== 'backlog');\n165\t  const backlogSections = sectionItems.filter(i => i.section === 'backlog');\n166\t\n167\t  if (actionableSections.length > 0 || backlogSections.length > 0) {\n168\t    // Section-based format found\n169\t    for (const item of backlogSections) {\n170\t      result.skipped++;\n171\t      if (!isJson) {\n172\t        info(`Skipped (backlog — non-actionable): ${item.text}`);\n173\t      }\n174\t    }\n175\t\n176\t    for (const item of actionableSections) {\n177\t      const priority = item.section === 'fix-now' ? 'high' : 'medium';\n178\t\n179\t      // Check for duplicates\n180\t      const dupCheck = isDuplicate(item.text, existingTitles);\n181\t      if (dupCheck.duplicate) {\n182\t        result.duplicates++;\n183\t        if (!isJson) {\n184\t          info(`Skipped (duplicate of \"${dupCheck.matchedTitle}\"): ${item.text}`);\n185\t        }\n186\t        continue;\n187\t      }\n188\t\n189\t      const issue = createIssue(item.text, { priority, source }, dir);\n190\t      existingTitles.push(issue.title);\n191\t      result.imported++;\n192\t      result.issues.push({ id: issue.id, title: issue.title, source: issue.source, priority: issue.priority });\n193\t\n194\t      if (!isJson) {\n195\t        ok(`Imported [${issue.id}] (${priority}): ${item.text}`);\n196\t      }\n197\t    }\n198\t\n199\t    return result;\n200\t  }\n201\t\n202\t  // Fall back to table-based parsing"}]},"parent_tool_use_id":"toolu_01U1QxzZy7C659GJM4oxEmEf","session_id":"3f15b50c-2c9b-40fa-9e63-9fad2199af43","uuid":"0a46861b-5f65-46df-97c3-83d98b3b9204","timestamp":"2026-04-03T02:28:28.627Z"}
