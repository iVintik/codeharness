{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q2LrNkvpLvm2T1jLJSGYvh","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n     2→import { reviewStory } from '../index.js';\n     3→\n     4→// Mock the orchestrator module\n     5→vi.mock('../orchestrator.js', () => ({\n     6→  invokeBmadCodeReview: vi.fn(),\n     7→}));\n     8→\n     9→import { invokeBmadCodeReview } from '../orchestrator.js';\n    10→\n    11→const mockedInvoke = vi.mocked(invokeBmadCodeReview);\n    12→\n    13→beforeEach(() => {\n    14→  vi.clearAllMocks();\n    15→});\n    16→\n    17→afterEach(() => {\n    18→  vi.restoreAllMocks();\n    19→});\n    20→\n    21→describe('reviewStory', () => {\n    22→  it('delegates to invokeBmadCodeReview and returns ok(ReviewResult)', () => {\n    23→    const mockResult = {\n    24→      success: true as const,\n    25→      data: {\n    26→        key: '5-1-test',\n    27→        approved: true,\n    28→        comments: [],\n    29→        duration: 5000,\n    30→        output: 'LGTM',\n    31→      },\n    32→    };\n    33→    mockedInvoke.mockReturnValueOnce(mockResult);\n    34→\n    35→    const result = reviewStory('5-1-test');\n    36→\n    37→    expect(mockedInvoke).toHaveBeenCalledWith('5-1-test', undefined);\n    38→    expect(result.success).toBe(true);\n    39→    if (!result.success) return;\n    40→    expect(result.data.key).toBe('5-1-test');\n    41→    expect(result.data.approved).toBe(true);\n    42→    expect(result.data.comments).toEqual([]);\n    43→    expect(result.data.duration).toBe(5000);\n    44→    expect(result.data.output).toBe('LGTM');\n    45→  });\n    46→\n    47→  it('delegates to invokeBmadCodeReview and returns fail() on error', () => {\n    48→    const mockResult = {\n    49→      success: false as const,\n    50→      error: 'review workflow failed with exit code 1 for story bad-key: error',\n    51→    };\n    52→    mockedInvoke.mockReturnValueOnce(mockResult);\n    53→\n    54→    const result = reviewStory('bad-key');\n    55→\n    56→    expect(mockedInvoke).toHaveBeenCalledWith('bad-key', undefined);\n    57→    expect(result.success).toBe(false);\n    58→    if (result.success) return;\n    59→    expect(result.error).toContain('bad-key');\n    60→  });\n    61→\n    62→  it('passes timeout option through to orchestrator', () => {\n    63→    const mockResult = {\n    64→      success: true as const,\n    65→      data: {\n    66→        key: 'k',\n    67→        approved: true,\n    68→        comments: [],\n    69→        duration: 100,\n    70→        output: '',\n    71→      },\n    72→    };\n    73→    mockedInvoke.mockReturnValueOnce(mockResult);\n    74→\n    75→    reviewStory('k', { timeoutMs: 30_000 });\n    76→\n    77→    expect(mockedInvoke).toHaveBeenCalledWith('k', { timeoutMs: 30_000 });\n    78→  });\n    79→\n    80→  it('returns Result shape — has success discriminant', () => {\n    81→    mockedInvoke.mockReturnValueOnce({\n    82→      success: true as const,\n    83→      data: {\n    84→        key: 'x',\n    85→        approved: true,\n    86→        comments: [],\n    87→        duration: 0,\n    88→        output: '',\n    89→      },\n    90→    });\n    91→\n    92→    const result = reviewStory('x');\n    93→    expect('success' in result).toBe(true);\n    94→    expect(typeof result.success).toBe('boolean');\n    95→  });\n    96→\n    97→  it('no longer returns fail(\"not implemented\")', () => {\n    98→    mockedInvoke.mockReturnValueOnce({\n    99→      success: true as const,\n   100→      data: {\n   101→        key: 'test',\n   102→        approved: true,\n   103→        comments: [],\n   104→        duration: 0,\n   105→        output: '',\n   106→      },\n   107→    });\n   108→\n   109→    const result = reviewStory('test');\n   110→    expect(result.success).toBe(true);\n   111→    if (!result.success) return;\n   112→    // The old stub returned fail('not implemented') — verify that's gone\n   113→    expect(result.data.key).toBe('test');\n   114→  });\n   115→});\n   116→"}]},"parent_tool_use_id":"toolu_01NPoMRLksRrYS1379XfDBqY","session_id":"7be24b04-34e1-424a-85e4-e656cce56dfe","uuid":"e4e3b68b-86fb-4d8b-80b7-a8dce3a23150","timestamp":"2026-03-21T06:10:06.213Z"}
