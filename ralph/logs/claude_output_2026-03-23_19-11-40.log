{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VEgcNNoKKJfWJRPFCNzQLs","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→\n     3→vi.mock('node:fs', () => ({\n     4→  existsSync: vi.fn(),\n     5→  writeFileSync: vi.fn(),\n     6→  readFileSync: vi.fn(),\n     7→}));\n     8→\n     9→import { existsSync, writeFileSync, readFileSync } from 'node:fs';\n    10→import { join } from 'node:path';\n    11→import { generateDockerfileTemplate } from '../dockerfile-template.js';\n    12→import { validateDockerfile } from '../dockerfile-validator.js';\n    13→\n    14→const mockExistsSync = vi.mocked(existsSync);\n    15→const mockWriteFileSync = vi.mocked(writeFileSync);\n    16→\n    17→beforeEach(() => {\n    18→  vi.resetAllMocks();\n    19→});\n    20→\n    21→// ─── Node.js template ───────────────────────────────────────────────────────\n    22→\n    23→describe('generateDockerfileTemplate — nodejs', () => {\n    24→  it('generates Dockerfile with pinned FROM node:22-slim', () => {\n    25→    mockExistsSync.mockReturnValue(false);\n    26→\n    27→    const r = generateDockerfileTemplate('/project', 'nodejs');\n    28→    expect(r.success).toBe(true);\n    29→    if (r.success) {\n    30→      expect(r.data.path).toBe(join('/project', 'Dockerfile'));\n    31→      expect(r.data.stack).toBe('nodejs');\n    32→    }\n    33→\n    34→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    35→    expect(written).toContain('FROM node:22-slim');\n    36→  });\n    37→\n    38→  it('includes npm install -g for binary installation', () => {\n    39→    mockExistsSync.mockReturnValue(false);\n    40→    generateDockerfileTemplate('/project', 'nodejs');\n    41→\n    42→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    43→    expect(written).toContain('npm install -g');\n    44→  });\n    45→\n    46→  it('includes curl and jq verification tools', () => {\n    47→    mockExistsSync.mockReturnValue(false);\n    48→    generateDockerfileTemplate('/project', 'nodejs');\n    49→\n    50→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    51→    expect(written).toContain('curl');\n    52→    expect(written).toContain('jq');\n    53→  });\n    54→\n    55→  it('includes USER node for non-root execution', () => {\n    56→    mockExistsSync.mockReturnValue(false);\n    57→    generateDockerfileTemplate('/project', 'nodejs');\n    58→\n    59→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    60→    expect(written).toContain('USER node');\n    61→  });\n    62→\n    63→  it('includes cache cleanup', () => {\n    64→    mockExistsSync.mockReturnValue(false);\n    65→    generateDockerfileTemplate('/project', 'nodejs');\n    66→\n    67→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    68→    expect(written).toContain('rm -rf /var/lib/apt/lists/*');\n    69→  });\n    70→\n    71→  it('includes inline section comments', () => {\n    72→    mockExistsSync.mockReturnValue(false);\n    73→    generateDockerfileTemplate('/project', 'nodejs');\n    74→\n    75→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    76→    expect(written).toContain('# Base image');\n    77→    expect(written).toContain('# System utilities');\n    78→    expect(written).toContain('# Install project');\n    79→    expect(written).toContain('# Run as non-root');\n    80→  });\n    81→});\n    82→\n    83→// ─── Python template ────────────────────────────────────────────────────────\n    84→\n    85→describe('generateDockerfileTemplate — python', () => {\n    86→  it('generates Dockerfile with pinned FROM python:3.12-slim', () => {\n    87→    mockExistsSync.mockReturnValue(false);\n    88→\n    89→    const r = generateDockerfileTemplate('/project', 'python');\n    90→    expect(r.success).toBe(true);\n    91→    if (r.success) {\n    92→      expect(r.data.path).toBe(join('/project', 'Dockerfile'));\n    93→      expect(r.data.stack).toBe('python');\n    94→    }\n    95→\n    96→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    97→    expect(written).toContain('FROM python:3.12-slim');\n    98→  });\n    99→\n   100→  it('includes pip install for binary installation', () => {\n   101→    mockExistsSync.mockReturnValue(false);\n   102→    generateDockerfileTemplate('/project', 'python');\n   103→\n   104→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   105→    expect(written).toContain('pip install');\n   106→  });\n   107→\n   108→  it('includes curl and jq verification tools', () => {\n   109→    mockExistsSync.mockReturnValue(false);\n   110→    generateDockerfileTemplate('/project', 'python');\n   111→\n   112→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   113→    expect(written).toContain('curl');\n   114→    expect(written).toContain('jq');\n   115→  });\n   116→\n   117→  it('includes USER nobody for non-root execution', () => {\n   118→    mockExistsSync.mockReturnValue(false);\n   119→    generateDockerfileTemplate('/project', 'python');\n   120→\n   121→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   122→    expect(written).toContain('USER nobody');\n   123→  });\n   124→\n   125→  it('includes cache cleanup (apt + pip)', () => {\n   126→    mockExistsSync.mockReturnValue(false);\n   127→    generateDockerfileTemplate('/project', 'python');\n   128→\n   129→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   130→    expect(written).toContain('rm -rf /var/lib/apt/lists/*');\n   131→    expect(written).toContain('pip cache purge');\n   132→  });\n   133→\n   134→  it('includes inline section comments', () => {\n   135→    mockExistsSync.mockReturnValue(false);\n   136→    generateDockerfileTemplate('/project', 'python');\n   137→\n   138→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   139→    expect(written).toContain('# Base image');\n   140→    expect(written).toContain('# System utilities');\n   141→    expect(written).toContain('# Install project');\n   142→    expect(written).toContain('# Run as non-root');\n   143→  });\n   144→});\n   145→\n   146→// ─── Generic template ───────────────────────────────────────────────────────\n   147→\n   148→describe('generateDockerfileTemplate — generic/null', () => {\n   149→  it('generates generic Dockerfile when stack is null', () => {\n   150→    mockExistsSync.mockReturnValue(false);\n   151→\n   152→    const r = generateDockerfileTemplate('/project', null);\n   153→    expect(r.success).toBe(true);\n   154→    if (r.success) {\n   155→      expect(r.data.stack).toBe('generic');\n   156→    }\n   157→\n   158→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   159→    expect(written).toContain('FROM node:22-slim');\n   160→    expect(written).toContain('bash');\n   161→    expect(written).toContain('git');\n   162→  });\n   163→\n   164→  it('generates generic Dockerfile when stack is unknown', () => {\n   165→    mockExistsSync.mockReturnValue(false);\n   166→\n   167→    const r = generateDockerfileTemplate('/project', 'java');\n   168→    expect(r.success).toBe(true);\n   169→    if (r.success) {\n   170→      expect(r.data.stack).toBe('generic');\n   171→    }\n   172→  });\n   173→\n   174→  it('includes curl and jq in generic template', () => {\n   175→    mockExistsSync.mockReturnValue(false);\n   176→    generateDockerfileTemplate('/project', null);\n   177→\n   178→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n   179→    expect(written).toContain('curl');\n   180→    expect(written).toContain('jq');\n   181→  });\n   182→});\n   183→\n   184→// ─── Rust template ──────────────────────────────────────────────────────────\n   185→\n   186→describe('generateDockerfileTemplate — rust', () => {\n   187→  it('returns stack: rust and correct path', () => {\n   188→    mockExists