{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Az1DeGYqvi4wHzNQRNHphp","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { existsSync } from 'node:fs';\n     3→import { join } from 'node:path';\n     4→import {\n     5→  // Re-exported from cargo-toml-variants\n     6→  CARGO_TOML_MINIMAL,\n     7→  CARGO_TOML_ACTIX_WEB,\n     8→  CARGO_TOML_AXUM,\n     9→  CARGO_TOML_ASYNC_OPENAI,\n    10→  CARGO_TOML_WORKSPACE,\n    11→  CARGO_TOML_BINARY,\n    12→  CARGO_TOML_LIBRARY,\n    13→  CARGO_TOML_GENERIC,\n    14→  // Re-exported from state-builders\n    15→  buildSprintState,\n    16→  buildStoryEntry,\n    17→  buildEpicState,\n    18→  buildActionItem,\n    19→  buildSprintStateWithStory,\n    20→  // Re-exported from mock-factories\n    21→  createFsMock,\n    22→  createChildProcessMock,\n    23→  createDockerMock,\n    24→  createStateMock,\n    25→  // helpers.ts own export\n    26→  withTempDir,\n    27→} from './helpers.js';\n    28→\n    29→describe('helpers.ts — re-exports', () => {\n    30→  it('re-exports all cargo-toml-variants', () => {\n    31→    expect(CARGO_TOML_MINIMAL).toBeDefined();\n    32→    expect(CARGO_TOML_ACTIX_WEB).toBeDefined();\n    33→    expect(CARGO_TOML_AXUM).toBeDefined();\n    34→    expect(CARGO_TOML_ASYNC_OPENAI).toBeDefined();\n    35→    expect(CARGO_TOML_WORKSPACE).toBeDefined();\n    36→    expect(CARGO_TOML_BINARY).toBeDefined();\n    37→    expect(CARGO_TOML_LIBRARY).toBeDefined();\n    38→    expect(CARGO_TOML_GENERIC).toBeDefined();\n    39→  });\n    40→\n    41→  it('re-exports all state-builders', () => {\n    42→    expect(typeof buildSprintState).toBe('function');\n    43→    expect(typeof buildStoryEntry).toBe('function');\n    44→    expect(typeof buildEpicState).toBe('function');\n    45→    expect(typeof buildActionItem).toBe('function');\n    46→    expect(typeof buildSprintStateWithStory).toBe('function');\n    47→  });\n    48→\n    49→  it('re-exports all mock-factories', () => {\n    50→    expect(typeof createFsMock).toBe('function');\n    51→    expect(typeof createChildProcessMock).toBe('function');\n    52→    expect(typeof createDockerMock).toBe('function');\n    53→    expect(typeof createStateMock).toBe('function');\n    54→  });\n    55→});\n    56→\n    57→describe('withTempDir', () => {\n    58→  it('creates a temp directory and passes it to the callback', async () => {\n    59→    let capturedDir = '';\n    60→    await withTempDir(async (dir) => {\n    61→      capturedDir = dir;\n    62→      expect(existsSync(dir)).toBe(true);\n    63→    });\n    64→    expect(capturedDir).toBeTruthy();\n    65→  });\n    66→\n    67→  it('cleans up the temp directory after callback completes', async () => {\n    68→    let capturedDir = '';\n    69→    await withTempDir(async (dir) => {\n    70→      capturedDir = dir;\n    71→    });\n    72→    expect(existsSync(capturedDir)).toBe(false);\n    73→  });\n    74→\n    75→  it('cleans up on error', async () => {\n    76→    let capturedDir = '';\n    77→    await expect(\n    78→      withTempDir(async (dir) => {\n    79→        capturedDir = dir;\n    80→        throw new Error('test error');\n    81→      }),\n    82→    ).rejects.toThrow('test error');\n    83→    expect(existsSync(capturedDir)).toBe(false);\n    84→  });\n    85→\n    86→  it('supports custom prefix', async () => {\n    87→    await withTempDir(async (dir) => {\n    88→      const base = dir.split('/').pop() ?? '';\n    89→      expect(base.startsWith('custom-prefix-')).toBe(true);\n    90→    }, 'custom-prefix-');\n    91→  });\n    92→\n    93→  it('default prefix is ch-test-', async () => {\n    94→    await withTempDir(async (dir) => {\n    95→      const base = dir.split('/').pop() ?? '';\n    96→      expect(base.startsWith('ch-test-')).toBe(true);\n    97→    });\n    98→  });\n    99→});\n   100→"}]},"parent_tool_use_id":"toolu_01E4d2UoNxdYuxQTG5Dezgge","session_id":