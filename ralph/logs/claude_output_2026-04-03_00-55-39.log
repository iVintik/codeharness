{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Rr9C6QDEFwzesriNMCUi71","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';\n2\timport {\n3\t  mkdtempSync,\n4\t  rmSync,\n5\t  writeFileSync,\n6\t  existsSync,\n7\t  readdirSync,\n8\t  readFileSync,\n9\t  mkdirSync,\n10\t} from 'node:fs';\n11\timport { tmpdir } from 'node:os';\n12\timport { join } from 'node:path';\n13\t\n14\tvi.mock('../output.js', () => ({\n15\t  warn: vi.fn(),\n16\t}));\n17\t\n18\timport { warn } from '../output.js';\n19\timport { createIsolatedWorkspace } from '../source-isolation.js';\n20\timport type { IsolationOptions, IsolatedWorkspace } from '../source-isolation.js';\n21\t\n22\tlet projectDir: string;\n23\tlet workspace: IsolatedWorkspace | null;\n24\t\n25\tbeforeEach(() => {\n26\t  projectDir = mkdtempSync(join(tmpdir(), 'ch-iso-test-'));\n27\t  workspace = null;\n28\t  vi.clearAllMocks();\n29\t});\n30\t\n31\tafterEach(async () => {\n32\t  // Clean up workspace if test created one\n33\t  if (workspace) {\n34\t    await workspace.cleanup();\n35\t  }\n36\t  rmSync(projectDir, { recursive: true, force: true });\n37\t});\n38\t\n39\tdescribe('createIsolatedWorkspace', () => {\n40\t  it('creates temp dir with expected structure', async () => {\n41\t    workspace = await createIsolatedWorkspace({ runId: 'test-run-1', storyFiles: [] });\n42\t\n43\t    expect(existsSync(workspace.dir)).toBe(true);\n44\t    expect(workspace.dir).toBe('/tmp/codeharness-verify-test-run-1');\n45\t    expect(existsSync(workspace.storyFilesDir)).toBe(true);\n46\t    expect(existsSync(workspace.verdictDir)).toBe(true);\n47\t  });\n48\t\n49\t  it('story-files/ and verdict/ subdirectories exist', async () => {\n50\t    workspace = await createIsolatedWorkspace({ runId: 'test-run-2', storyFiles: [] });\n51\t\n52\t    const entries = readdirSync(workspace.dir);\n53\t    expect(entries).toContain('story-files');\n54\t    expect(entries).toContain('verdict');\n55\t  });\n56\t\n57\t  it('copies story files into story-files/ subdirectory', async () => {\n58\t    // Create dummy story files in project dir\n59\t    const storyFile1 = join(projectDir, 'story-1.md');\n60\t    const storyFile2 = join(projectDir, 'story-2.md');\n61\t    writeFileSync(storyFile1, '# Story 1\\nAC: something');\n62\t    writeFileSync(storyFile2, '# Story 2\\nAC: something else');\n63\t\n64\t    workspace = await createIsolatedWorkspace({\n65\t      runId: 'test-run-3',\n66\t      storyFiles: [storyFile1, storyFile2],\n67\t    });\n68\t\n69\t    const copiedFiles = readdirSync(workspace.storyFilesDir);\n70\t    expect(copiedFiles).toContain('story-1.md');\n71\t    expect(copiedFiles).toContain('story-2.md');\n72\t\n73\t    // Verify content was copied correctly\n74\t    const content1 = readFileSync(join(workspace.storyFilesDir, 'story-1.md'), 'utf-8');\n75\t    expect(content1).toBe('# Story 1\\nAC: something');\n76\t  });\n77\t\n78\t  it('workspace does NOT contain src/ directory', async () => {\n79\t    workspace = await createIsolatedWorkspace({ runId: 'test-run-4', storyFiles: [] });\n80\t\n81\t    const entries = readdirSync(workspace.dir);\n82\t    expect(entries).not.toContain('src');\n83\t    expect(entries).not.toContain('node_modules');\n84\t    expect(entries).not.toContain('package.json');\n85\t  });\n86\t\n87\t  it('empty storyFiles array creates directories but no files in story-files/', async () => {\n88\t    workspace = await createIsolatedWorkspace({ runId: 'test-run-5', storyFiles: [] });\n89\t\n90\t    expect(existsSync(workspace.storyFilesDir)).toBe(true);\n91\t    expect(existsSync(workspace.verdictDir)).toBe(true);\n92\t    const storyEntries = readdirSync(workspace.storyFilesDir);\n93\t    expect(storyEntries).toHaveLength(0);\n94\t  });\n95\t\n96\t  it('verdict/ directory exists in workspace', async () => {\n97\t    workspace = await createIsolatedWorkspace({ runId: 'test-run-6', storyFiles: [] });\n98\t\n99\t    expect(existsSync(workspace.verdictDir)).toBe(true);\n100\t    expect(workspace.verdictDir).toBe(join(workspace.dir, 'verdict'));\n101\t  });\n102\t});\n103\t\n104\tdescribe('missing file handling', () => {\n105\t  it('logs a warning and skips missing story file', async () => {\n106\t    const missingFile = join(projectDir, 'does-not-exist.md');\n107\t\n108\t    workspace = await createIsolatedWorkspace({\n109\t      runId: 'test-run-missing',\n110\t      storyFiles: [missingFile],\n111\t    });\n112\t\n113\t    expect(warn).toHaveBeenCalledWith(\n114\t      expect.stringContaining('story file not found, skipping'),\n115\t    );\n116\t    expect(warn).toHaveBeenCalledWith(\n117\t      expect.stringContaining(missingFile),\n118\t    );\n119\t\n120\t    const storyEntries = readdirSync(workspace.storyFilesDir);\n121\t    expect(storyEntries).toHaveLength(0);\n122\t  });\n123\t\n124\t  it('copies valid files and skips missing ones without throwing', async () => {\n125\t    const validFile = join(projectDir, 'valid-story.md');\n126\t    writeFileSync(validFile, '# Valid');\n127\t    const missingFile = join(projectDir, 'missing-story.md');\n128\t\n129\t    workspace = await createIsolatedWorkspace({\n130\t      runId: 'test-run-mixed',\n131\t      storyFiles: [validFile, missingFile],\n132\t    });\n133\t\n134\t    const storyEntries = readdirSync(workspace.storyFilesDir);\n135\t    expect(storyEntries).toHaveLength(1);\n136\t    expect(storyEntries).toContain('valid-story.md');\n137\t    expect(warn).toHaveBeenCalledTimes(1);\n138\t  });\n139\t});\n140\t\n141\tdescribe('toDispatchOptions', () => {\n142\t  it('returns DispatchOptions with cwd set to the temp directory', async () => {\n143\t    workspace = await createIsolatedWorkspace({ runId: 'test-run-dispatch', storyFiles: [] });\n144\t\n145\t    const opts = workspace.toDispatchOptions();\n146\t    expect(opts).toEqual({ cwd: workspace.dir });\n147\t    expect(opts.cwd).toBe('/tmp/codeharness-verify-test-run-dispatch');\n148\t  });\n149\t});\n150\t\n151\tdescribe('cleanup', () => {\n152\t  it('removes the temp directory and all contents', async () => {\n153\t    workspace = await createIsolatedWorkspace({ runId: 'test-run-cleanup', storyFiles: [] });\n154\t    const dir = workspace.dir;\n155\t\n156\t    expect(existsSync(dir)).toBe(true);\n157\t    await workspace.cleanup();\n158\t    expect(existsSync(dir)).toBe(false);\n159\t\n160\t    // Prevent afterEach from trying to clean up again\n161\t    workspace = null;\n162\t  });\n163\t\n164\t  it('calling cleanup() twice does not throw (idempotent)', async () => {\n165\t    workspace = await createIsolatedWorkspace({ runId: 'test-run-idem', storyFiles: [] });\n166\t\n167\t    await workspace.cleanup();\n168\t    // Second call should not throw\n169\t    await expect(workspace.cleanup()).resolves.toBeUndefined();\n170\t\n171\t    workspace = null;\n172\t  });\n173\t\n174\t  it('cleanup removes files that were copied', async () => {\n175\t    const storyFile = join(projectDir, 'ac.md');\n176\t    writeFileSync(storyFile, '# AC');\n177\t\n178\t    workspace = await createIsolatedWorkspace({\n179\t      runId: 'test-run-cleanup-files',\n180\t      storyFiles: [storyFile],\n181\t    });\n182\t    const dir = workspace.dir;\n183\t\n184\t    expect(existsSync(join(dir, 'story-files', 'ac.md'))).toBe(true);\n185\t    await workspace.cleanup();\n186\t    expect(existsSync(dir)).toBe(false);\n187\t\n188\t    workspace = null;\n189\t  });\n190\t});\n191\t\n192\tdescribe('runId sanitization', () => {\n193\t  it('sanitizes path traversal characters in runId', async () => {\n194\t    workspace = await createIsolatedWorkspace({\n195\t      runId: '../../etc/passwd',\n196\t      storyFiles: [],\n197\t    });\n198\t\n199\t    // Slashes replaced with underscores; leading dots stripped to prevent traversal\n200\t    expect(workspace.dir).toBe('/tmp/codeharness-verify-_.._etc_passwd');\n201\t    // No slash in the runId portion\n202\t    expect(workspace.dir.replace('/tmp/codeharness-verify-', '')).not.toContain('/');\n203\t    expect(existsSync(workspace.dir)).toBe(true);\n204\t  });\n205\t\n206\t  it('sanitizes spaces and special characters in runId', async () => {\n207\t    workspace = await createIsolatedWorkspace({\n208\t      runId: 'run id with spaces & $pecial',\n209\t      storyFiles: [],\n210\t    });\n211\t\n212\t    // Spaces, &, and $ all replaced with underscores\n213\t    expect(workspace.dir).toBe('/tmp/codeharness-verify-run_id_with_spaces____pecial');\n214\t    expect(existsSync(workspace.dir)).toBe(true);\n215\t  });\n216\t\n217\t  it('throws on runId that sanitizes to empty string', async () => {\n218\t    // Leading dots stripped, slashes replaced — '...' becomes empty after stripping\n219\t    await expect(\n220\t      createIsolatedWorkspace({ runId: '...', storyFiles: [] }),\n221\t    ).rejects.toThrow('runId is empty after sanitization');\n222\t  });\n223\t\n224\t  it('preserves valid runId characters', async () => {\n225\t    workspace = await createIsolatedWorkspace({\n226\t      runId: 'valid-run_id.123',\n227\t      storyFiles: [],\n228\t    });\n229\t\n230\t    expect(workspace.dir).toBe('/tmp/codeharness-verify-valid-run_id.123');\n231\t  });\n232\t});\n233\t\n234\tdescribe('pre-existing workspace cleanup', () => {\n235\t  it('cleans stale workspace before creating new one', async () => {\n236\t    // Pre-create a stale workspace with a rogue file\n237\t    const staleDir = '/tmp/codeharness-verify-stale-test';\n238\t    mkdirSync(join(staleDir, 'story-files'), { recursive: true });\n239\t    writeFileSync(join(staleDir, 'story-files', 'rogue.txt'), 'stale data');\n240\t\n241\t    workspace = await createIsolatedWorkspace({\n242\t      runId: 'stale-test',\n243\t      storyFiles: [],\n244\t    });\n245\t\n246\t    // Rogue file should be gone — fresh workspace\n247\t    const storyEntries = readdirSync(workspace.storyFilesDir);\n248\t    expect(storyEntries).toHaveLength(0);\n249\t    expect(existsSync(join(staleDir, 'story-files', 'rogue.txt'))).toBe(false);\n250\t  });\n251\t});\n252\t\n253\tdescribe('filename deduplication', () => {\n254\t  it('deduplicates story files with the same basename', async () => {\n255\t    // Create two story files with the same name in different dirs\n256\t    const dir1 = join(projectDir, 'dir1');\n257\t    const dir2 = join(projectDir, 'dir2');\n258\t    mkdirSync(dir1, { recursive: true });\n259\t    mkdirSync(dir2, { recursive: true });\n260\t    writeFileSync(join(dir1, 'story.md'), '# Story from dir1');\n261\t    writeFileSync(join(dir2, 'story.md'), '# Story from dir2');\n262\t\n263\t    workspace = await createIsolatedWorkspace({\n264\t      runId: 'dedup-test',\n265\t      storyFiles: [join(dir1, 'story.md'), join(dir2, 'story.md')],\n266\t    });\n267\t\n268\t    const files = readdirSync(workspace.storyFilesDir).sort();\n269\t    expect(files).toHaveLength(2);\n270\t    expect(files).toContain('story.md');\n271\t    expect(files).toContain('story-1.md');\n272\t\n273\t    // Verify both contents are preserved\n274\t    const content1 = readFileSync(join(workspace.storyFilesDir, 'story.md'), 'utf-8');\n275\t    const content2 = readFileSync(join(workspace.storyFilesDir, 'story-1.md'), 'utf-8');\n276\t    expect(content1).toBe('# Story from dir1');\n277\t    expect(content2).toBe('# Story from dir2');\n278\t  });\n279\t\n280\t  it('deduplicates files without extensions', async () => {\n281\t    const dir1 = join(projectDir, 'a');\n282\t    const dir2 = join(projectDir, 'b');\n283\t    mkdirSync(dir1, { recursive: true });\n284\t    mkdirSync(dir2, { recursive: true });\n285\t    writeFileSync(join(dir1, 'README'), 'first');\n286\t    writeFileSync(join(dir2, 'README'), 'second');\n287\t\n288\t    workspace = await createIsolatedWorkspace({\n289\t      runId: 'dedup-noext-test',\n290\t      storyFiles: [join(dir1, 'README'), join(dir2, 'README')],\n291\t    });\n292\t\n293\t    const files = readdirSync(workspace.storyFilesDir).sort();\n294\t    expect(files).toHaveLength(2);\n295\t    expect(files).toContain('README');\n296\t    expect(files).toContain('README-1');\n297\t  });\n298\t});\n299\t\n300\tdescribe('toDispatchOptions return shape', () => {\n301\t  it('returns object with only cwd property', async () => {\n302\t    workspace = await createIsolatedWorkspace({ runId: 'shape-test', storyFiles: [] });\n303\t\n304\t    const opts = workspace.toDispatchOptions();\n305\t    expect(Object.keys(opts)).toEqual(['cwd']);\n306\t  });\n307\t});\n308\t\n309\tdescribe('integration point verification', () => {\n310\t  it('evaluator template has disallowedTools: [Edit, Write]', async () => {\n311\t    // Read the evaluator template and verify disallowedTools\n312\t    const { readFileSync: readFs } = await import('node:fs');\n313\t    const { resolve } = await import('node:path');\n314\t    const { parse } = await import('yaml');\n315\t\n316\t    const evalPath = resolve(__dirname, '../../../templates/agents/evaluator.yaml');\n317\t    const raw = readFs(evalPath, 'utf-8');\n318\t    const parsed = parse(raw) as { disallowedTools?: string[] };\n319\t\n320\t    expect(parsed.disallowedTools).toEqual(['Edit', 'Write']);\n321\t  });\n322\t});\n323\t"}]},"parent_tool_use_id":"toolu_015UHexPBr7C4j7cQ2rdJdyp","session_id":"1d3ed03d-179a-4015-85c3-0be0521b6265","uuid":"2462e102-19b6-4c95-a760-ff394440a3d1","timestamp":"2026-04-02T21:25:19.170Z"}
