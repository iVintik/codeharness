{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MfKEvEeaJGxeLqDoZono87","type":"tool_result","content":"     1→/**\n     2→ * CLI command: `codeharness audit`\n     3→ *\n     4→ * Checks all compliance dimensions and reports project health.\n     5→ * Supports --json for machine-readable output.\n     6→ * Supports --fix to generate stories for audit gaps (FR15).\n     7→ */\n     8→\n     9→import { Command } from 'commander';\n    10→import { ok as okOutput, fail as failOutput, info, jsonOutput } from '../lib/output.js';\n    11→import { runPreconditions } from '../lib/onboard-checks.js';\n    12→import { runAudit, generateFixStories, addFixStoriesToState } from '../modules/audit/index.js';\n    13→import { formatAuditHuman, formatAuditJson } from '../modules/audit/report.js';\n    14→import type { Result } from '../types/result.js';\n    15→import type { FixGenerationResult } from '../modules/audit/index.js';\n    16→\n    17→export function registerAuditCommand(program: Command): void {\n    18→  program\n    19→    .command('audit')\n    20→    .description('Check all compliance dimensions and report project health')\n    21→    .option('--json', 'Output in machine-readable JSON format')\n    22→    .option('--fix', 'Generate fix stories for every gap found')\n    23→    .action(async (opts, cmd) => {\n    24→      const globalOpts = cmd.optsWithGlobals();\n    25→      const isJson = opts.json === true || globalOpts.json === true;\n    26→      const isFix = opts.fix === true;\n    27→\n    28→      // Precondition: harness must be initialized (AC #10)\n    29→      const preconditions = runPreconditions();\n    30→      if (!preconditions.canProceed) {\n    31→        if (isJson) {\n    32→          jsonOutput({\n    33→            status: 'fail',\n    34→            message: 'Harness not initialized -- run codeharness init first',\n    35→          });\n    36→        } else {\n    37→          failOutput('Harness not initialized -- run codeharness init first');\n    38→        }\n    39→        process.exitCode = 1;\n    40→        return;\n    41→      }\n    42→\n    43→      // Run audit\n    44→      const result = await runAudit(process.cwd());\n    45→\n    46→      if (!result.success) {\n    47→        if (isJson) {\n    48→          jsonOutput({ status: 'fail', message: result.error });\n    49→        } else {\n    50→          failOutput(result.error);\n    51→        }\n    52→        process.exitCode = 1;\n    53→        return;\n    54→      }\n    55→\n    56→      // Handle --fix flag\n    57→      let fixStories: Result<FixGenerationResult> | undefined;\n    58→\n    59→      if (isFix) {\n    60→        // AC #4: No gaps found\n    61→        if (result.data.gapCount === 0) {\n    62→          if (!isJson) {\n    63→            okOutput('No gaps found -- nothing to fix');\n    64→          }\n    65→        } else {\n    66→          // Generate fix stories\n    67→          const fixResult = generateFixStories(result.data);\n    68→          fixStories = fixResult;\n    69→\n    70→          if (fixResult.success) {\n    71→            // Add to sprint state (AC #2)\n    72→            const stateResult = addFixStoriesToState(fixResult.data.stories);\n    73→            if (!stateResult.success && !isJson) {\n    74→              failOutput(`Failed to update sprint state: ${stateResult.error}`);\n    75→            }\n    76→\n    77→            if (!isJson) {\n    78→              info(`Generated ${fixResult.data.created} fix stories (${fixResult.data.skipped} skipped)`);\n    79→            }\n    80→          } else if (!isJson) {\n    81→            failOutput(fixResult.error);\n    82→          }\n    83→        }\n    84→      }\n    85→\n    86→      // Format output\n    87→      if (isJson) {\n    88→        const jsonData: Record<string, unknown> = formatAuditJson(result.data) as unknown as Record<string, unknown>;\n    89→        // AC #5: Include fixStories in JSON when --fix\n    90→        if (isFix) {\n    91→          if (result.data.gapCount === 0) {\n    92→            jsonData.fixStories = [];\n    93→          } else if (fixStories && fixStories.success) {\n    94→            jsonData.fixStories = fixStories.data.stories.map(s => ({\n    95→              key: s.key,\n    96→              filePath: s.filePath,\n    97→              gap: s.gap,\n    98→              ...(s.skipped ? { skipped: true } : {}),\n    99→            }));\n   100→          }\n   101→        }\n   102→        jsonOutput(jsonData);\n   103→      } else if (!isFix || (isFix && result.data.gapCount > 0)) {\n   104→        // Print human audit output (skip if --fix with no gaps, already printed OK)\n   105→        const lines = formatAuditHuman(result.data);\n   106→        for (const line of lines) {\n   107→          console.log(line);\n   108→        }\n   109→      }\n   110→\n   111→      // Set exit code based on overall status\n   112→      if (result.data.overallStatus === 'fail') {\n   113→        process.exitCode = 1;\n   114→      }\n   115→    });\n   116→}\n   117→"}]},"parent_tool_use_id":"toolu_01KBt1xzNkF45pjf2bZesegY","session_id":"0deb1693-f450-4ee3-ba9f-130c7ba0aec5","uuid":"bad59eff-df3b-4e85-88fa-cd854defef50","timestamp":"2026-03-20T09:22:52.997Z"}
