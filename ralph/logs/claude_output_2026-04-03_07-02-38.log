{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014yWHwbwi6sCw6adrXe7Uej","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach, afterEach } from 'vitest';\n2\timport { mkdtempSync, rmSync, writeFileSync, readFileSync, mkdirSync } from 'node:fs';\n3\timport { tmpdir, homedir } from 'node:os';\n4\timport os from 'node:os';\n5\timport { join } from 'node:path';\n6\timport {\n7\t  parseWorkflow,\n8\t  resolveWorkflow,\n9\t  loadWorkflowPatch,\n10\t  mergeWorkflowPatch,\n11\t  WorkflowParseError,\n12\t  type ResolvedWorkflow,\n13\t  type ResolvedTask,\n14\t  type LoopBlock,\n15\t  type FlowStep,\n16\t  type WorkflowPatch,\n17\t} from '../workflow-parser.js';\n18\t\n19\tlet testDir: string;\n20\t\n21\tbeforeEach(() => {\n22\t  testDir = mkdtempSync(join(tmpdir(), 'ch-wfparser-test-'));\n23\t});\n24\t\n25\tafterEach(() => {\n26\t  rmSync(testDir, { recursive: true, force: true });\n27\t});\n28\t\n29\tfunction writeYaml(filename: string, content: string): string {\n30\t  const filePath = join(testDir, filename);\n31\t  writeFileSync(filePath, content, 'utf-8');\n32\t  return filePath;\n33\t}\n34\t\n35\t// --- Helpers: YAML content ---\n36\t\n37\tconst minimalYaml = `\n38\ttasks:\n39\t  implement:\n40\t    agent: dev\n41\tflow:\n42\t  - implement\n43\t`;\n44\t\n45\tconst fullYaml = `\n46\ttasks:\n47\t  implement:\n48\t    agent: dev\n49\t    scope: per-story\n50\t    session: fresh"}]},"parent_tool_use_id":"toolu_01ChyoLDPrvpbR13hYNAz6e8","session_id":"c2800ecc-75a3-43b2-b3d8-396855aa3c3c","uuid":"086883de-9060-4e21-ac8c-514a59eb88d8","timestamp":"2026-04-03T03:04:51.001Z"}
