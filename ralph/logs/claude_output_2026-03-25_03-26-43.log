{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YXDtVvB43VEEoo4HCzfE96","type":"tool_result","content":"     1→/**\n     2→ * Types for the verify module.\n     3→ * Merged from src/lib/verify.ts and src/lib/verify-parser.ts.\n     4→ */\n     5→\n     6→import type { AcResult } from '../../types/state.js';\n     7→\n     8→// ─── Parser Types ────────────────────────────────────────────────────────────\n     9→\n    10→export type Verifiability = 'cli-verifiable' | 'integration-required';\n    11→\n    12→/**\n    13→ * Verification strategy — how the verifier should approach proving an AC.\n    14→ *\n    15→ * - docker:    Run in a Docker container (default, safest)\n    16→ * - cli-direct: Run CLI commands in the current subprocess (fallback)\n    17→ * - escalate:   Truly impossible — requires physical hardware, external paid\n    18→ *               service, or human judgement. Last resort only.\n    19→ */\n    20→export type VerificationStrategy = 'docker' | 'cli-direct' | 'escalate';\n    21→\n    22→export interface ParsedAC {\n    23→  readonly id: string;\n    24→  readonly description: string;\n    25→  readonly type: 'ui' | 'api' | 'db' | 'general';\n    26→  readonly verifiability: Verifiability;\n    27→  readonly strategy: VerificationStrategy;\n    28→}\n    29→\n    30→// ─── Proof Quality Types ─────────────────────────────────────────────────────\n    31→\n    32→export interface ProofQuality {\n    33→  readonly verified: number;\n    34→  readonly pending: number;\n    35→  readonly escalated: number;\n    36→  readonly total: number;\n    37→  readonly passed: boolean;\n    38→  /** Count of `grep ... src/` commands in evidence (black-box metric) */\n    39→  readonly grepSrcCount: number;\n    40→  /** Count of `docker exec` commands in evidence (black-box metric) */\n    41→  readonly dockerExecCount: number;\n    42→  /** Count of observability query commands in evidence (black-box metric) */\n    43→  readonly observabilityCount: number;\n    44→  /** Count of other commands in evidence (black-box metric) */\n    45→  readonly otherCount: number;\n    46→  /** Whether the proof passes black-box enforcement checks */\n    47→  readonly blackBoxPass: boolean;\n    48→}\n    49→\n    50→export type EvidenceCommandType =\n    51→  | 'docker-exec'\n    52→  | 'docker-host'\n    53→  | 'observability'\n    54→  | 'grep-src'\n    55→  | 'other';\n    56→\n    57→export interface ClassifiedCommand {\n    58→  readonly command: string;\n    59→  readonly type: EvidenceCommandType;\n    60→}\n    61→\n    62→// ─── Orchestrator Types ──────────────────────────────────────────────────────\n    63→\n    64→export interface VerifyResult {\n    65→  readonly storyId: string;\n    66→  readonly success: boolean;\n    67→  readonly totalACs: number;\n    68→  readonly verifiedCount: number;\n    69→  readonly failedCount: number;\n    70→  readonly escalatedCount: number;\n    71→  readonly proofPath: string;\n    72→  readonly showboatVerifyStatus: 'pass' | 'fail' | 'skipped';\n    73→  /** Number of ACs with observability gaps (Story 2.1) */\n    74→  readonly observabilityGapCount: number;\n    75→  /** Runtime coverage percentage: ACs with logs / total ACs * 100 (Story 2.1) */\n    76→  readonly runtimeCoveragePercent: number;\n    77→  readonly perAC: ReadonlyArray<{\n    78→    readonly id: string;\n    79→    readonly description: string;\n    80→    readonly verified: boolean;\n    81→    readonly evidencePaths: readonly string[];\n    82→  }>;\n    83→}\n    84→\n    85→export interface PreconditionResult {\n    86→  readonly passed: boolean;\n    87→  readonly failures: readonly string[];\n    88→}\n    89→\n    90→export interface ShowboatVerifyResult {\n    91→  readonly passed: boolean;\n    92→  readonly output: string;\n    93→}\n    94→\n    95→// ─── Observability Gap Types ─────────────────────────────────────────────\n    96→\n    97→/** Per-AC observability gap presence */\n    98→export interface ObservabilityGapEntry {\n    99→  /** Acceptance criterion identifier */\n   100→  readonly acId: string;\n   101→  /** Whether an observability gap was detected */\n   102→  readonly hasGap: boolean;\n   103→  /** The gap note text, if present */\n   104→  readonly gapNote?: string;\n   105→}\n   106→\n   107→/** Result of parsing observability gaps from proof content */\n   108→export interface ObservabilityGapResult {\n   109→  /** Per-AC gap presence */\n   110→  readonly entries: readonly ObservabilityGapEntry[];\n   111→  /** Total number of ACs found in proof */\n   112→  readonly totalACs: number;\n   113→  /** Number of ACs with observability gaps */\n   114→  readonly gapCount: number;\n   115→  /** Number of ACs without gaps (produced log events) */\n   116→  readonly coveredCount: number;\n   117→}\n   118→\n   119→// ─── Env Types ───────────────────────────────────────────────────────────────\n   120→\n   121→/** Project type for verification strategy selection. */\n   122→export type ProjectType = 'nodejs' | 'python' | 'rust' | 'plugin' | 'generic';\n   123→\n   124→export interface BuildOptions {\n   125→  readonly projectDir?: string;\n   126→}\n   127→\n   128→export interface BuildResult {\n   129→  readonly imageTag: string;\n   130→  readonly imageSize: string;\n   131→  readonly buildTimeMs: number;\n   132→  readonly cached: boolean;\n   133→}\n   134→\n   135→export interface CheckResult {\n   136→  readonly imageExists: boolean;\n   137→  readonly cliWorks: boolean;\n   138→  readonly otelReachable: boolean;\n   139→}\n   140→\n   141→// ─── Browser Verifier Types ──────────────────────────────────────────────────\n   142→\n   143→export interface BrowserActionResult {\n   144→  readonly output: string;\n   145→  readonly screenshotPath?: string;\n   146→  readonly exitCode: number;\n   147→}\n   148→\n   149→export interface DiffResult {\n   150→  readonly hasDifferences: boolean;\n   151→  readonly beforePath: string;\n   152→  readonly afterPath: string;\n   153→}\n   154→\n   155→// ─── Black-Box Enforcement Result ────────────────────────────────────────────\n   156→\n   157→export interface BlackBoxEnforcementResult {\n   158→  readonly blackBoxPass: boolean;\n   159→  readonly grepSrcCount: number;\n   160→  readonly dockerExecCount: number;\n   161→  readonly observabilityCount: number;\n   162→  readonly otherCount: number;\n   163→  readonly grepRatio: number;\n   164→  readonly acsMissingDockerExec: readonly number[];\n   165→}\n   166→"}]},"parent_tool_use_id":"toolu_01AeWcLgyHoXRPKGkiwoR1Eu","session_id":"38809bab-d371-4c03-b647-b7b7381ee002","uuid":"3d86bfce-20ce-4e66-820f-e2ab179b3d6b","timestamp":"2026-03-24T23:36:59.911Z"}
