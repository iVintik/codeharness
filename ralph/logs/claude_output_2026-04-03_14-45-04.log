erations).toContain(2);\n1685\t    expect(iterations).toContain(3);\n1686\t  });\n1687\t\n1688\t  it('halt error (RATE_LIMIT) terminates loop immediately (AC #8)', async () => {\n1689\t    const { DispatchError } = await import('../agent-dispatch.js');\n1690\t    mockDriverDispatch.mockImplementation(() => makeDriverStreamError(\n1691\t      new DispatchError('rate limited', 'RATE_LIMIT', 'dev', new Error('inner')),\n1692\t    ));\n1693\t\n1694\t    mockParse.mockReturnValue({\n1695\t      development_status: { '3-1-foo': 'ready-for-dev' },\n1696\t    });\n1697\t\n1698\t    const config = makeConfig({\n1699\t      workflow: {\n1700\t        tasks: {\n1701\t          retry: makeTask({ scope: 'per-story' }),\n1702\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n1703\t        },\n1704\t        flow: [{ loop: ['retry', 'verify'] }],\n1705\t      },\n1706\t    });\n1707\t\n1708\t    const result = await executeWorkflow(config);\n1709\t\n1710\t    expect(result.success).toBe(false);\n1711\t    expect(result.errors).toHaveLength(1);\n1712\t    expect(result.errors[0].code).toBe('RATE_LIMIT');\n1713\t    // Only one dispatch attempted before halt\n1714\t    expect(mockDriverDispatch).toHaveBeenCalledTimes(1);\n1715\t  });\n1716\t\n1717\t  it('empty loop block terminates immediately', async () => {\n1718\t    mockParse.mockReturnValue({\n1719\t      development_status: { '3-1-foo': 'ready-for-dev' },\n1720\t    });\n1721\t\n1722\t    const config = makeConfig({\n1723\t      workflow: {\n1724\t        tasks: {\n1725\t          retry: makeTask({ scope: 'per-story' }),\n1726\t        },\n1727\t        flow: [{ loop: [] }],\n1728\t      },\n1729\t    });\n1730\t\n1731\t    const result = await executeWorkflow(config);\n1732\t\n1733\t    expect(result.success).toBe(true);\n1734\t    expect(mockDriverDispatch).not.toHaveBeenCalled();\n1735\t  });\n1736\t\n1737\t  it('uses default maxIterations of 5 when not specified', async () => {\n1738\t    let evalCou