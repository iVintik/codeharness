{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XVugxcYUtA9jgc323mg4jD","type":"tool_result","content":"     1→/**\n     2→ * Types for the sprint module.\n     3→ */\n     4→\n     5→import type { StoryStatus, ActionItem, AcVerdict } from '../../types/state.js';\n     6→\n     7→/** Partial update for live run progress fields */\n     8→export interface RunProgressUpdate {\n     9→  readonly currentStory?: string | null;\n    10→  readonly currentPhase?: 'create' | 'dev' | 'review' | 'verify' | null;\n    11→  readonly lastAction?: string | null;\n    12→  readonly acProgress?: string | null;\n    13→}\n    14→\n    15→/** A story selected for development */\n    16→export interface StorySelection {\n    17→  readonly key: string;\n    18→  readonly title: string;\n    19→  readonly priority: number;\n    20→}\n    21→\n    22→/** Detail to attach when updating story status */\n    23→export interface StoryDetail {\n    24→  readonly error?: string;\n    25→  readonly proofPath?: string;\n    26→}\n    27→\n    28→/** Info about a story blocked due to retry exhaustion */\n    29→export interface RetryExhaustedInfo {\n    30→  readonly key: string;\n    31→  readonly attempts: number;\n    32→  readonly reason: 'retry-exhausted';\n    33→}\n    34→\n    35→/** Full result of story selection, including side-effect recommendations */\n    36→export interface SelectionResult {\n    37→  readonly selected: StorySelection | null;\n    38→  readonly retryExhausted: ReadonlyArray<RetryExhaustedInfo>;\n    39→}\n    40→\n    41→/** Detail about a failed story for reporting */\n    42→export interface FailedStoryDetail {\n    43→  readonly key: string;\n    44→  readonly acNumber: number | null;\n    45→  readonly errorLine: string;\n    46→  readonly attempts: number;\n    47→  readonly maxAttempts: number;\n    48→}\n    49→\n    50→/** An action item with a NEW or CARRIED label */\n    51→export interface LabeledActionItem {\n    52→  readonly item: ActionItem;\n    53→  readonly label: 'NEW' | 'CARRIED';\n    54→}\n    55→\n    56→/** Summary of a run (active or completed) */\n    57→export interface RunSummary {\n    58→  readonly duration: string;\n    59→  readonly cost: number;\n    60→  readonly iterations: number;\n    61→  readonly completed: ReadonlyArray<string>;\n    62→  readonly failed: ReadonlyArray<string>;\n    63→  readonly blocked: ReadonlyArray<string>;\n    64→  readonly skipped: ReadonlyArray<string>;\n    65→}\n    66→\n    67→/** Detail for a single acceptance criterion in a drill-down view */\n    68→export interface AcDetail {\n    69→  readonly id: string;\n    70→  readonly verdict: AcVerdict;\n    71→  readonly command?: string;\n    72→  readonly expected?: string;\n    73→  readonly actual?: string;\n    74→  readonly reason?: string;\n    75→  readonly suggestedFix?: string;\n    76→}\n    77→\n    78→/** Record of a single verification attempt */\n    79→export interface AttemptRecord {\n    80→  readonly number: number;\n    81→  readonly outcome: string;\n    82→  readonly failingAc?: string;\n    83→  readonly timestamp?: string;\n    84→}\n    85→\n    86→/** Summary of a proof document */\n    87→export interface ProofSummary {\n    88→  readonly path: string;\n    89→  readonly passCount: number;\n    90→  readonly failCount: number;\n    91→  readonly escalateCount: number;\n    92→  readonly pendingCount: number;\n    93→}\n    94→\n    95→/** Full drill-down detail for a single story */\n    96→export interface StoryDrillDown {\n    97→  readonly key: string;\n    98→  readonly status: StoryStatus;\n    99→  readonly epic: string;\n   100→  readonly attempts: number;\n   101→  readonly maxAttempts: number;\n   102→  readonly lastAttempt: string | null;\n   103→  readonly acDetails: ReadonlyArray<AcDetail>;\n   104→  readonly attemptHistory: ReadonlyArray<AttemptRecord>;\n   105→  readonly proofSummary: ProofSummary | null;\n   106→  readonly timeoutSummary: TimeoutSummary | null;\n   107→}\n   108→\n   109→/** Data captured during a timeout event */\n   110→export interface TimeoutCapture {\n   111→  readonly storyKey: string;\n   112→  readonly iteration: number;\n   113→  readonly durationMinutes: number;\n   114→  readonly gitDiff: string;\n   115→  readonly stateDelta: string;\n   116→  readonly partialStderr: string;\n   117→  readonly timestamp: string;\n   118→}\n   119→\n   120→/** A timeout report with file path and captured data */\n   121→export interface TimeoutReport {\n   122→  readonly filePath: string;\n   123→  readonly capture: TimeoutCapture;\n   124→}\n   125→\n   126→/** Summary of the latest timeout for a story, shown in drill-down */\n   127→export interface TimeoutSummary {\n   128→  readonly reportPath: string;\n   129→  readonly iteration: number;\n   130→  readonly durationMinutes: number;\n   131→  readonly filesChanged: number;\n   132→}\n   133→\n   134→/** A single failing acceptance criterion extracted from a proof document */\n   135→export interface FailingAc {\n   136→  readonly acNumber: number;\n   137→  readonly description: string;\n   138→  readonly errorOutput: string;\n   139→  readonly verdict: string;\n   140→}\n   141→\n   142→/** Result of processing a verification proof for the feedback loop */\n   143→export interface FeedbackResult {\n   144→  readonly storyKey: string;\n   145→  readonly action: 'return-to-dev' | 'mark-done' | 'mark-blocked';\n   146→  readonly failingAcs: ReadonlyArray<FailingAc>;\n   147→  readonly attempts: number;\n   148→}\n   149→\n   150→/** Summary report of sprint status */\n   151→export interface StatusReport {\n   152→  readonly total: number;\n   153→  readonly done: number;\n   154→  readonly failed: number;\n   155→  readonly blocked: number;\n   156→  readonly inProgress: string | null;\n   157→  readonly storyStatuses: ReadonlyArray<{\n   158→    readonly key: string;\n   159→    readonly status: StoryStatus;\n   160→  }>;\n   161→  readonly epicsTotal: number;\n   162→  readonly epicsDone: number;\n   163→  readonly sprintPercent: number;\n   164→  readonly activeRun: RunSummary | null;\n   165→  readonly lastRun: RunSummary | null;\n   166→  readonly failedDetails: ReadonlyArray<FailedStoryDetail>;\n   167→  readonly actionItemsLabeled: ReadonlyArray<LabeledActionItem>;\n   168→}\n   169→"}]},"parent_tool_use_id":"toolu_01E3VQC87sxVSnH1aNNzcpTd","session_id":"d308c3c3-ed4a-4164-bef5-0fade3bd8d38","uuid":"a0c26016-086d-4c81-aa67-c8decdbda00b","timestamp":"2026-03-24T16:42:41.914Z"}
