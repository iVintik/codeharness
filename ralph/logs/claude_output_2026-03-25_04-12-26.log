{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RhiwbWfq552JkQY9Vemcym","type":"tool_result","content":"     1→import { existsSync, readFileSync, writeFileSync } from 'node:fs';\n     2→import type { BeadsIssue } from '../beads.js';\n     3→\n     4→// ─── Types ──────────────────────────────────────────────────────────────────\n     5→\n     6→export interface SyncResult {\n     7→  storyKey: string;\n     8→  beadsId: string;\n     9→  previousStatus: string;\n    10→  newStatus: string;\n    11→  synced: boolean;\n    12→  error?: string;\n    13→}\n    14→\n    15→export type SyncDirection = 'beads-to-files' | 'files-to-beads' | 'bidirectional';\n    16→\n    17→// ─── Status Mapping ─────────────────────────────────────────────────────────\n    18→\n    19→const BEADS_TO_STORY_STATUS: Record<string, string> = {\n    20→  open: 'in-progress',\n    21→  closed: 'done',\n    22→};\n    23→\n    24→const STORY_TO_BEADS_STATUS: Record<string, string> = {\n    25→  backlog: 'open',\n    26→  'ready-for-dev': 'open',\n    27→  'in-progress': 'open',\n    28→  review: 'open',\n    29→  done: 'closed',\n    30→};\n    31→\n    32→export function beadsStatusToStoryStatus(beadsStatus: string): string | null {\n    33→  return BEADS_TO_STORY_STATUS[beadsStatus] ?? null;\n    34→}\n    35→\n    36→export function storyStatusToBeadsStatus(storyStatus: string): string | null {\n    37→  return STORY_TO_BEADS_STATUS[storyStatus] ?? null;\n    38→}\n    39→\n    40→export function storyKeyFromPath(filePath: string): string {\n    41→  const base = filePath.split('/').pop() ?? filePath;\n    42→  return base.replace(/\\.md$/, '');\n    43→}\n    44→\n    45→/**\n    46→ * Extracts story file path from beads issue description field.\n    47→ * The bridge command sets description = story file path.\n    48→ * Returns null if description doesn't contain a valid path.\n    49→ */\n    50→export function resolveStoryFilePath(beadsIssue: BeadsIssue): string | null {\n    51→  const desc = beadsIssue.description;\n    52→  if (!desc || !desc.trim()) {\n    53→    return null;\n    54→  }\n    55→  const trimmed = desc.trim();\n    56→  if (!trimmed.endsWith('.md')) {\n    57→    return null;\n    58→  }\n    59→  return trimmed;\n    60→}\n    61→\n    62→/**\n    63→ * Reads the `Status:` line from a story markdown file.\n    64→ * Returns null if file doesn't exist or has no Status line.\n    65→ */\n    66→export function readStoryFileStatus(filePath: string): string | null {\n    67→  if (!existsSync(filePath)) {\n    68→    return null;\n    69→  }\n    70→  const content = readFileSync(filePath, 'utf-8');\n    71→  const match = content.match(/^Status:\\s*(.+)$/m);\n    72→  if (!match) {\n    73→    return null;\n    74→  }\n    75→  return match[1].trim();\n    76→}\n    77→\n    78→/**\n    79→ * Updates the `Status:` line in a story markdown file in-place.\n    80→ * If no `Status:` line exists, inserts one after the title line.\n    81→ */\n    82→export function updateStoryFileStatus(filePath: string, newStatus: string): void {\n    83→  const content = readFileSync(filePath, 'utf-8');\n    84→  const statusRegex = /^Status:\\s*.+$/m;\n    85→\n    86→  if (statusRegex.test(content)) {\n    87→    const updated = content.replace(statusRegex, `Status: ${newStatus}`);\n    88→    writeFileSync(filePath, updated, 'utf-8');\n    89→  } else {\n    90→    const lines = content.split('\\n');\n    91→    const titleIndex = lines.findIndex(l => l.startsWith('# '));\n    92→    if (titleIndex !== -1) {\n    93→      lines.splice(titleIndex + 1, 0, '', `Status: ${newStatus}`);\n    94→    } else {\n    95→      lines.unshift(`Status: ${newStatus}`, '');\n    96→    }\n    97→    writeFileSync(filePath, lines.join('\\n'), 'utf-8');\n    98→  }\n    99→}\n   100→"}]},"parent_tool_use_id":"toolu_01KNQnUKBFtzFzrosUg6K7qd","session_id":"7d2c764f-deb1-4354-ad31-e0a846d19ae3","uuid":"9b76faac-1bc9-4939-ae06-337d7a6949c2","ti