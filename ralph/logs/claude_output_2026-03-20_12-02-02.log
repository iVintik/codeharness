→    });\n   471→\n   472→    it('--max-story-retries defaults to 3', async () => {\n   473→      const { registerRunCommand } = await import('../run.js');\n   474→      const program = new Command();\n   475→      program.option('--json', 'JSON output');\n   476→      registerRunCommand(program);\n   477→\n   478→      const runCmd = program.commands.find(c => c.name() === 'run');\n   479→      const retryOpt = runCmd!.options.find(o => o.long === '--max-story-retries');\n   480→      expect(retryOpt!.defaultValue).toBe('10');\n   481→    });\n   482→  });\n   483→\n   484→  describe('Ink renderer integration (AC #1, #2, #3)', () => {\n   485→    it('starts Ink renderer before spawning ralph', async () => {\n   486→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   487→      mockPaths({ 'ralph.sh': true, '.claude': true, '.flagged_stories': false });\n   488→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   489→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   490→\n   491→      const p = runCommand();\n   492→      await vi.waitFor(() => expect(spawnMock).toHaveBeenCalled());\n   493→      getChildOnHandlers()['close'](0);\n   494→      await p;\n   495→\n   496→      // startRenderer should have been called before spawn\n   497→      expect(startRendererMock).toHaveBeenCalledTimes(1);\n   498→      expect(startRendererMock).toHaveBeenCalledWith({ quiet: false });\n   499→    });\n   500→\n   501→    it('pipes stdout NDJSON lines through parseStreamLine to renderer.update', async () => {\n   502→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   503→      mockPaths({ 'ralph.sh': true, '.claude': true, '.flagged_stories': false });\n   504→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   505→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   506→\n   507→      const toolStartEvent = { type: 'tool-start', name: 'Read', id: 'abc' };\n   508→      parseStreamLineMock.mo