{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WBoYdtcMhsnu6LvffncpxU","type":"tool_result","content":"     1→/**\n     2→ * RalphDriver — AgentDriver implementation for the Ralph autonomous loop.\n     3→ *\n     4→ * Wraps ralph.sh invocation behind the AgentDriver interface defined in types.ts.\n     5→ * Migrates ralph-specific parsing and spawning logic from run-helpers.ts.\n     6→ */\n     7→\n     8→import { spawn } from 'node:child_process';\n     9→import { existsSync } from 'node:fs';\n    10→import { dirname, join } from 'node:path';\n    11→import { fileURLToPath } from 'node:url';\n    12→import type { AgentDriver, SpawnOpts, AgentProcess, AgentEvent } from './types.js';\n    13→import { parseStreamLine } from './stream-parser.js';\n    14→\n    15→// --- Regex constants (migrated from run-helpers.ts) ---\n    16→\n    17→/** Strip ANSI color codes */\n    18→const ANSI_ESCAPE = /\\x1b\\[[0-9;]*m/g;\n    19→\n    20→/** Strip timestamp prefix from ralph output lines */\n    21→const TIMESTAMP_PREFIX = /^\\[[\\d-]+\\s[\\d:]+\\]\\s*/;\n    22→\n    23→/** Matches: [SUCCESS] Story {key}: DONE ... */\n    24→const SUCCESS_STORY = /\\[SUCCESS\\]\\s+Story\\s+([\\w-]+):\\s+DONE(.*)/;\n    25→\n    26→/** Matches: [WARN] Story {key} exceeded retry limit ... flagging */\n    27→const WARN_STORY_RETRY = /\\[WARN\\]\\s+Story\\s+([\\w-]+)\\s+exceeded retry limit/;\n    28→\n    29→/** Matches: [WARN] Story {key} ... retry N/M */\n    30→const WARN_STORY_RETRYING = /\\[WARN\\]\\s+Story\\s+([\\w-]+)\\s+.*retry\\s+(\\d+)\\/(\\d+)/;\n    31→\n    32→/** Matches: [LOOP] iteration N */\n    33→const LOOP_ITERATION = /\\[LOOP\\]\\s+iteration\\s+(\\d+)/;\n    34→\n    35→/** Matches: [ERROR] ... */\n    36→const ERROR_LINE = /\\[ERROR\\]\\s+(.+)/;\n    37→\n    38→// --- StoryMessage type (local, replaces import from ink-components) ---\n    39→\n    40→interface StoryMessage {\n    41→  type: 'ok' | 'fail' | 'warn';\n    42→  key: string;\n    43→  message: string;\n    44→}\n    45→\n    46→// --- Migrated functions ---\n    47→\n    48→/**\n    49→ * Parse a ralph output line and return a StoryMessage if it matches\n    50→ * a story completion, failure, or warning pattern.\n    51→ * Returns null for non-matching lines.\n    52→ */\n    53→export function parseRalphMessage(rawLine: string): StoryMessage | null {\n    54→  const clean = rawLine.replace(ANSI_ESCAPE, '').replace(TIMESTAMP_PREFIX, '').trim();\n    55→  if (clean.length === 0) return null;\n    56→\n    57→  // [SUCCESS] Story {key}: DONE ...\n    58→  const success = SUCCESS_STORY.exec(clean);\n    59→  if (success) {\n    60→    const key = success[1];\n    61→    const rest = success[2].trim().replace(/^—\\s*/, '');\n    62→    return {\n    63→      type: 'ok',\n    64→      key,\n    65→      message: rest ? `DONE — ${rest}` : 'DONE',\n    66→    };\n    67→  }\n    68→\n    69→  // [WARN] Story {key} exceeded retry limit\n    70→  const retryExceeded = WARN_STORY_RETRY.exec(clean);\n    71→  if (retryExceeded) {\n    72→    return {\n    73→      type: 'fail',\n    74→      key: retryExceeded[1],\n    75→      message: 'exceeded retry limit',\n    76→    };\n    77→  }\n    78→\n    79→  // [WARN] Story {key} — retry N/M\n    80→  const retrying = WARN_STORY_RETRYING.exec(clean);\n    81→  if (retrying) {\n    82→    return {\n    83→      type: 'warn',\n    84→      key: retrying[1],\n    85→      message: `retry ${retrying[2]}/${retrying[3]}`,\n    86→    };\n    87→  }\n    88→\n    89→  // [ERROR] ... — surface as a generic error message\n    90→  const errorMatch = ERROR_LINE.exec(clean);\n    91→  if (errorMatch) {\n    92→    // Try to extract story key from error message\n    93→    const keyMatch = errorMatch[1].match(/Story\\s+([\\w-]+)/);\n    94→    if (keyMatch) {\n    95→      return {\n    96→        type: 'fail',\n    97→        key: keyMatch[1],\n    98→        message: errorMatch[1].trim(),\n    99→      };\n   100→    }\n   101→    // Generic error without a story key — skip (no key to associate)\n   102→    return null;\n   103→  }\n   104→\n   105→  return null;\n   106→}\n   107→\n   108→/**\n   109→ * Parse a ralph stderr line for [LOOP] iteration messages.\n   110→ * Returns the iteration number if found, or null otherwise.\n   111→ */\n   112→export function parseIterationMessage(rawLine: string): number | null {\n   113→  const clean = rawLine.replace(ANSI_ESCAPE, '').replace(TIMESTAMP_PREFIX, '').trim();\n   114→  if (clean.length === 0) return null;\n   115→  const match = LOOP_ITERATION.exec(clean);\n   116→  if (match) {\n   117→    return parseInt(match[1], 10);\n   118→  }\n   119→  return null;\n   120→}\n   121→\n   122→/**\n   123→ * Builds the argument array for spawning Ralph.\n   124→ */\n   125→export function buildSpawnArgs(opts: {\n   126→  ralphPath: string;\n   127→  pluginDir: string;\n   128→  promptFile: string;\n   129→  maxIterations: number;\n   130→  timeout: number;\n   131→  iterationTimeout: number;\n   132→  calls: number;\n   133→  quiet: boolean;\n   134→  maxStoryRetries?: number;\n   135→  reset?: boolean;\n   136→}): string[] {\n   137→  const args = [\n   138→    opts.ralphPath,\n   139→    '--plugin-dir', opts.pluginDir,\n   140→    '--max-iterations', String(opts.maxIterations),\n   141→    '--timeout', String(opts.timeout),\n   142→    '--iteration-timeout', String(opts.iterationTimeout),\n   143→    '--calls', String(opts.calls),\n   144→    '--prompt', opts.promptFile,\n   145→  ];\n   146→\n   147→  // When not quiet, pass --live so ralph tees Claude's stream-json to stdout.\n   148→  if (!opts.quiet) {\n   149→    args.push('--live');\n   150→  }\n   151→\n   152→  if (opts.maxStoryRetries !== undefined) {\n   153→    args.push('--max-story-retries', String(opts.maxStoryRetries));\n   154→  }\n   155→\n   156→  if (opts.reset) {\n   157→    args.push('--reset');\n   158→  }\n   159→\n   160→  return args;\n   161→}\n   162→\n   163→/** Resolves the path to ralph/ralph.sh relative to the package root. */\n   164→export function resolveRalphPath(): string {\n   165→  const currentFile = fileURLToPath(import.meta.url);\n   166→  const currentDir = dirname(currentFile);\n   167→  // currentDir is src/lib/agents (or dist/lib/agents)\n   168→  let root = dirname(dirname(currentDir));\n   169→  if (root.endsWith('/src') || root.endsWith('\\\\src')) {\n   170→    root = dirname(root);\n   171→  }\n   172→  return join(root, 'ralph', 'ralph.sh');\n   173→}\n   174→\n   175→// --- RalphConfig for constructor-time configuration ---\n   176→\n   177→/**\n   178→ * Ralph-specific configuration passed at construction time.\n   179→ * Keeps SpawnOpts agent-agnostic while allowing RalphDriver\n   180→ * to accept all ralph.sh flags.\n   181→ */\n   182→export interface RalphConfig {\n   183→  pluginDir: string;\n   184→  maxIterations?: number;\n   185→  iterationTimeout?: number;\n   186→  calls?: number;\n   187→  quiet?: boolean;\n   188→  maxStoryRetries?: number;\n   189→  reset?: boolean;\n   190→}\n   191→\n   192→// --- RalphDriver class ---\n   193→\n   194→export class RalphDriver implements AgentDriver {\n   195→  readonly name = 'ralph';\n   196→  private readonly config: RalphConfig;\n   197→\n   198→  constructor(config?: RalphConfig) {\n   199→    this.config = config ?? { pluginDir: join(process.cwd(), '.claude') };\n   200→  }\n   201→\n   202→  spawn(opts: SpawnOpts): AgentProcess {\n   203→    const ralphPath = resolveRalphPath();\n   204→    if (!existsSync(ralphPath)) {\n   205→      throw new Error(`Ralph loop not found at ${ralphPath} — reinstall codeharness`);\n   206→    }\n   207→\n   208→    const args = buildSpawnArgs({\n   209→      ralphPath,\n   210→      pluginDir: this.config.pluginDir,\n   211→      promptFile: opts.prompt,\n   212→      maxIterations: this.config.maxIterations ?? 50,\n   213→      timeout: opts.timeout,\n   214→      iterationTimeout: this.config.iterationTimeout ?? 30,\n   215→      calls: this.config.calls ?? 100,\n   216→      quiet: this.config.quiet ?? false,\n   217→      maxStoryRetries: this.config.maxStoryRetries,\n   218→      reset: this.config.reset,\n   219→    });\n   220→\n   221→    const quiet = this.config.quiet ?? false;\n   222→    const child = spawn('bash', args, {\n   223→      cwd: opts.workDir,\n   224→      env: { ...process.env, ...opts.env },\n   225→      stdio: quiet ? 'ignore' : ['inherit', 'pipe', 'pipe'],\n   226→    });\n   227→\n   228→    return child as unknown as AgentProcess;\n   229→  }\n   230→\n   231→  parseOutput(line: string): AgentEvent | null {\n   232→    // 1. Try ralph stderr patterns\n   233→    const iteration = parseIterationMessage(line);\n   234→    if (iteration !== null) {\n   235→      return { type: 'iteration', count: iteration };\n   236→    }\n   237→\n   238→    const msg = parseRalphMessage(line);\n   239→    if (msg) {\n   240→      switch (msg.type) {\n   241→        case 'ok':\n   242→          return { type: 'story-complete', key: msg.key, details: msg.message };\n   243→        case 'fail':\n   244→          return { type: 'story-failed', key: msg.key, reason: msg.message };\n   245→        case 'warn': {\n   246→          // Parse retry N/M from message\n   247→          const retryMatch = msg.message.match(/retry\\s+(\\d+)\\/(\\d+)/);\n   248→          if (retryMatch) {\n   249→            return {\n   250→              type: 'retry',\n   251→              attempt: parseInt(retryMatch[1], 10),\n   252→              delay: 0,\n   253→            };\n   254→          }\n   255→          // Fallback: treat as story-failed\n   256→          return { type: 'story-failed', key: msg.key, reason: msg.message };\n   257→        }\n   258→      }\n   259→    }\n   260→\n   261→    // 2. Fall back to stream-json parser\n   262→    const streamEvent = parseStreamLine(line);\n   263→    if (streamEvent) {\n   264→      switch (streamEvent.type) {\n   265→        case 'tool-start':\n   266→          return { type: 'tool-start', name: streamEvent.name };\n   267→        case 'tool-complete':\n   268→          return { type: 'tool-complete' };\n   269→        case 'text':\n   270→          return { type: 'text', text: streamEvent.text };\n   271→        case 'retry':\n   272→          return { type: 'retry', attempt: streamEvent.attempt, delay: streamEvent.delay };\n   273→        case 'result':\n   274→          return { type: 'result', cost: streamEvent.cost, sessionId: streamEvent.sessionId };\n   275→        case 'tool-input':\n   276→          // tool-input deltas are not mapped to AgentEvent\n   277→          return null;\n   278→      }\n   279→    }\n   280→\n   281→    return null;\n   282→  }\n   283→\n   284→  getStatusFile(): string {\n   285→    return 'ralph/status.json';\n   286→  }\n   287→}\n   288→"}]},"parent_tool_use_id":"toolu_01AeYymucNLjmuqL83DiV485","session_id":"a5a043ae-cfd1-4d51-82dd-d0069edc63ef","uuid":"84a2e3ee-a393-4720-ae07-7ef3c955c27e","timestamp":"2026-03-24T16:30:28.936Z"}
