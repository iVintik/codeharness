{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Wb17v4TYSAmVqZNenQmVLt","type":"tool_result","content":"    80→    const msg = err instanceof Error ? err.message : String(err);\n    81→    return fail(`Failed to write sprint state: ${msg}`);\n    82→  }\n    83→}\n    84→\n    85→/**\n    86→ * Read and parse sprint-state.json.\n    87→ * If the file does not exist, attempt migration from old files.\n    88→ * If no old files exist either, return defaultState().\n    89→ */\n    90→export function getSprintState(): Result<SprintState> {\n    91→  const fp = statePath();\n    92→\n    93→  if (existsSync(fp)) {\n    94→    try {\n    95→      const raw = readFileSync(fp, 'utf-8');\n    96→      const parsed = JSON.parse(raw) as Record<string, unknown>;\n    97→      // Merge with defaults to handle old state files missing new fields\n    98→      const defaults = defaultState();\n    99→      const run = parsed.run as Record<string, unknown> | undefined;\n   100→      const state: SprintState = {\n   101→        ...(parsed as unknown as SprintState),\n   102→        run: {\n   103→          ...defaults.run,\n   104→          ...(run as SprintState['run']),\n   105→        },\n   106→      };\n   107→      return ok(state);\n   108→    } catch (err: unknown) {\n   109→      const msg = err instanceof Error ? err.message : String(err);\n   110→      return fail(`Failed to read sprint state: ${msg}`);\n   111→    }\n   112→  }\n   113→\n   114→  // No sprint-state.json — try migration\n   115→  const migrationResult = migrateFromOldFormat();\n   116→  if (migrationResult.success) {\n   117→    return migrationResult;\n   118→  }\n   119→\n   120→  // Migration found nothing or failed — return default\n   121→  return ok(defaultState());\n   122→}\n   123→\n   124→/** Recompute sprint summary counts from story data */\n   125→export function computeSprintCounts(\n   126→  stories: Record<string, StoryState>,\n   127→): SprintState['sprint'] {\n   128→  let total = 0;\n   129→  let done = 0;\n   130→  let failed = 0;\n   131→  let blocked = 0;\n   132→  let inProgress: string | null = null;\n   133→\n   134→  for (const [key, story] of Object.entries(stories)) {\n   135→    total++;\n   136→    if (story.status === 'done') done++;\n   137→    else if (story.status === 'failed') failed++;\n   138→    else if (story.status === 'blocked') blocked++;\n   139→    else if (story.status === 'in-progress') inProgress = key;\n   140→  }\n   141→\n   142→  return { total, done, failed, blocked, inProgress };\n   143→}\n   144→\n   145→/**\n   146→ * Update a single story's status in sprint-state.json.\n   147→ * Reads current state, merges update, writes atomically.\n   148→ */\n   149→export function updateStoryStatus(\n   150→  key: string,\n   151→  status: StoryStatus,\n   152→  detail?: StoryDetail,\n   153→): Result<void> {\n   154→  const stateResult = getSprintState();\n   155→  if (!stateResult.success) {\n   156→    return fail(stateResult.error);\n   157→  }\n   158→\n   159→  const current = stateResult.data;\n   160→  const existingStory = current.stories[key] ?? defaultStoryState();\n   161→\n   162→  const isNewAttempt = status === 'in-progress';\n   163→\n   164→  const updatedStory: StoryState = {\n   165→    ...existingStory,\n   166→    status,\n   167→    attempts: isNewAttempt\n   168→      ? existingStory.attempts + 1\n   169→      : existingStory.attempts,\n   170→    lastAttempt: isNewAttempt\n   171→      ? new Date().toISOString()\n   172→      : existingStory.lastAttempt,\n   173→    lastError: detail?.error ?? existingStory.lastError,\n   174→    proofPath: detail?.proofPath ?? existingStory.proofPath,\n   175→    acResults: existingStory.acResults,\n   176→  };\n   177→\n   178→  const updatedStories = { ...current.stories, [key]: updatedStory };\n   179→  const updatedSprint = computeSprintCounts(updatedStories);\n   180→\n   181→  const updatedState: SprintState = {\n   182→    ...current,\n   183→    sprint: updatedSprint,\n   184→    stories: updatedStories,\n   185→  };\n   186→\n   187→  return writeStateAtomic(updatedState);\n   188→}\n   189→\n   190→/**\n   191→ * Update live run progress fields in sprint-state.json.\n   192→ * Only provided fields are updated; omitted fields retain their current values.\n   193→ */\n   194→export function updateRunProgress(update: RunProgressUpdate): Result<void> {\n   195→  const stateResult = getSprintState();\n   196→  if (!stateResult.success) {\n   197→    return fail(stateResult.error);\n   198→  }\n   199→"}]},"parent_tool_use_id":"toolu_01GUR1dsNVzUTLzShG1rFUcD","session_id":"0deb1693-f450-4ee3-ba9f-130c7ba0aec5","uuid":"c667d39e-f21e-420c-8337-34f1c2d22230","timestamp":"2026-03-20T09:12:59.666Z"}
