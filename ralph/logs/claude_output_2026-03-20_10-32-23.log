{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014PuRheXsgPEcJBD3Bz3Mdp","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→\n     3→vi.mock('node:fs', () => ({\n     4→  readFileSync: vi.fn(),\n     5→  writeFileSync: vi.fn(),\n     6→  renameSync: vi.fn(),\n     7→  existsSync: vi.fn(),\n     8→}));\n     9→\n    10→import { computeRuntimeCoverage, saveRuntimeCoverage } from '../runtime-coverage.js';\n    11→import {\n    12→  computeRuntimeCoverage as barrelCompute,\n    13→  saveRuntimeCoverage as barrelSave,\n    14→} from '../index.js';\n    15→import { readFileSync, writeFileSync, renameSync, existsSync } from 'node:fs';\n    16→import type { ObservabilityGapResult } from '../../verify/types.js';\n    17→\n    18→const mockReadFileSync = vi.mocked(readFileSync);\n    19→const mockWriteFileSync = vi.mocked(writeFileSync);\n    20→const mockRenameSync = vi.mocked(renameSync);\n    21→const mockExistsSync = vi.mocked(existsSync);\n    22→\n    23→beforeEach(() => {\n    24→  vi.resetAllMocks();\n    25→  vi.useFakeTimers();\n    26→  vi.setSystemTime(new Date('2026-03-19T15:00:00.000Z'));\n    27→});\n    28→\n    29→// ─── Helper ──────────────────────────────────────────────────────────────\n    30→\n    31→function makeGapResult(\n    32→  totalACs: number,\n    33→  gapCount: number,\n    34→): ObservabilityGapResult {\n    35→  const entries = Array.from({ length: totalACs }, (_, i) => ({\n    36→    acId: String(i + 1),\n    37→    hasGap: i >= totalACs - gapCount,\n    38→    gapNote: i >= totalACs - gapCount\n    39→      ? 'No log events detected for this user interaction'\n    40→      : undefined,\n    41→  }));\n    42→  return {\n    43→    entries,\n    44→    totalACs,\n    45→    gapCount,\n    46→    coveredCount: totalACs - gapCount,\n    47→  };\n    48→}\n    49→\n    50→// ============================================================\n    51→// Module barrel exports\n    52→// ============================================================\n    53→\n    54→describe('module barrel exports', () => {\n    55→  it('re-exports computeRuntimeCoverage from index.ts', () => {\n    56→    expect(barrelCompute).toBe(computeRuntimeCoverage);\n    57→  });\n    58→\n    59→  it('re-exports saveRuntimeCoverage from index.ts', () => {\n    60→    expect(barrelSave).toBe(saveRuntimeCoverage);\n    61→  });\n    62→});\n    63→\n    64→// ============================================================\n    65→// computeRuntimeCoverage\n    66→// ============================================================\n    67→\n    68→describe('computeRuntimeCoverage', () => {\n    69→  it('computes 70% coverage with 10 ACs and 7 with logs', () => {\n    70→    const gapResult = makeGapResult(10, 3); // 10 ACs, 3 gaps => 7 with logs\n    71→    const result = computeRuntimeCoverage(gapResult);\n    72→\n    73→    expect(result.totalACs).toBe(10);\n    74→    expect(result.acsWithLogs).toBe(7);\n    75→    expect(result.coveragePercent).toBe(70);\n    76→    expect(result.entries).toHaveLength(10);\n    77→  });\n    78→\n    79→  it('handles 0 ACs without division by zero', () => {\n    80→    const gapResult: ObservabilityGapResult = {\n    81→      entries: [],\n    82→      totalACs: 0,\n    83→      gapCount: 0,\n    84→      coveredCount: 0,\n    85→    };\n    86→    const result = computeRuntimeCoverage(gapResult);\n    87→\n    88→    expect(result.totalACs).toBe(0);\n    89→    expect(result.acsWithLogs).toBe(0);\n    90→    expect(result.coveragePercent).toBe(0);\n    91→    expect(result.entries).toHaveLength(0);\n    92→  });\n    93→\n    94→  it('computes 100% coverage when all ACs have logs', () => {\n    95→    const gapResult = makeGapResult(5, 0); // 5 ACs, 0 gaps\n    96→    const result = computeRuntimeCoverage(gapResult);\n    97→\n    98→    expect(result.totalACs).toBe(5);\n    99→    expect(result.acsWithLogs).toBe(5);\n   100→    expect(result.coveragePercent).toBe(100);\n   101→  });\n   102→\n   103→  it('computes 0% coverage when no ACs have logs', () => {\n   104→    const gapResult = makeGapResult(5, 5); // 5 ACs, all gaps\n   105→    const result = computeRuntimeCoverage(gapResult);\n   106→\n   107→    expect(result.totalACs).toBe(5);\n   108→    expect(result.acsWithLogs).toBe(0);\n   109→    expect(result.coveragePercent).toBe(0);\n   110→  });\n   111→\n   112→  it('sets logEventsDetected correctly per entry', () => {\n   113→    const gapResult = makeGapResult(3, 1); // 3 ACs, 1 gap (last one)\n   114→    const result = computeRuntimeCoverage(gapResult);\n   115→\n   116→    expect(result.entries[0].logEventsDetected).toBe(true);\n   117→    expect(result.entries[0].logEventCount).toBe(1);\n   118→    expect(result.entries[0].gapNote).toBeUndefined();\n   119→\n   120→    expect(result.entries[2].logEventsDetected).toBe(false);\n   121→    expect(result.entries[2].logEventCount).toBe(0);\n   122→    expect(result.entries[2].gapNote).toBe(\n   123→      'No log events detected for this user interaction',\n   124→    );\n   125→  });\n   126→});\n   127→\n   128→// ============================================================\n   129→// saveRuntimeCoverage\n   130→// ============================================================\n   131→\n   132→describe('saveRuntimeCoverage', () => {\n   133→  it('writes to sprint-state.json with correct runtime structure', () => {\n   134→    mockExistsSync.mockReturnValue(false);\n   135→\n   136→    const coverageResult = computeRuntimeCoverage(makeGapResult(10, 3));\n   137→    const result = saveRuntimeCoverage('/project', coverageResult);\n   138→\n   139→    expect(result.success).toBe(true);\n   140→    expect(mockWriteFileSync).toHaveBeenCalledOnce();\n   141→    expect(mockRenameSync).toHaveBeenCalledOnce();\n   142→\n   143→    const writtenData = JSON.parse(\n   144→      mockWriteFileSync.mock.calls[0][1] as string,\n   145→    );\n   146→    expect(writtenData.observability.runtime.coveragePercent).toBe(70);\n   147→    expect(writtenData.observability.runtime.lastValidationTimestamp).toBe(\n   148→      '2026-03-19T15:00:00.000Z',\n   149→    );\n   150→    expect(writtenData.observability.runtime.modulesWithTelemetry).toBe(7);\n   151→    expect(writtenData.observability.runtime.totalModules).toBe(10);\n   152→    expect(writtenData.observability.runtime.telemetryDetected).toBe(true);\n   153→    expect(writtenData.observability.targets.runtimeTarget).toBe(60);\n   154→  });\n   155→\n   156→  it('preserves existing static coverage data', () => {\n   157→    const existingState = JSON.stringify({\n   158→      version: 1,\n   159→      sprint: { total: 5, done: 2 },\n   160→      observability: {\n   161→        static: {\n   162→          coveragePercent: 75,\n   163→          lastScanTimestamp: '2026-03-19T14:30:00.000Z',\n   164→          history: [\n   165→            { coveragePercent: 75, timestamp: '2026-03-19T14:30:00.000Z' },\n   166→          ],\n   167→        },\n   168→        targets: { staticTarget: 80 },\n   169→      },\n   170→    });\n   171→\n   172→    mockExistsSync.mockReturnValue(true);\n   173→    mockReadFileSync.mockReturnValue(existingState);\n   174→\n   175→    const coverageResult = computeRuntimeCoverage(makeGapResult(10, 3));\n   176→    const result = saveRuntimeCoverage('/project', coverageResult);\n   177→\n   178→    expect(result.success).toBe(true);\n   179→    const writtenData = JSON.parse(\n   180→      mockWriteFileSync.mock.calls[0][1] as string,\n   181→    );\n   182→\n   183→    // Static coverage preserved\n   184→    expect(writtenData.observability.static.coveragePercent).toBe(75);\n   185→    expect(writtenData.observability.static.lastScanTimestamp).toBe(\n   186→      '2026-03-19T14:30:00.000Z',\n   187→    );\n   188→    expect(writtenData.observability.static.history).toHaveLength(1);\n   189→\n   190→    // Runtime coverage added\n   191→ 