{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KBGCtC3LkWbV3DfsULed1i","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport fs from 'node:fs';\n3\timport path from 'node:path';\n4\timport YAML from 'yaml';\n5\timport { validateAgentSchema } from '../schema-validate.js';\n6\t\n7\tconst TEMPLATES_DIR = path.resolve(__dirname, '../../../templates/agents');\n8\t\n9\tconst EXPECTED_AGENTS = [\n10\t  'dev',\n11\t  'qa',\n12\t  'architect',\n13\t  'pm',\n14\t  'sm',\n15\t  'analyst',\n16\t  'ux-designer',\n17\t  'tech-writer',\n18\t  'evaluator',\n19\t];\n20\t\n21\t/** Cache parsed agents to avoid redundant fs reads across test groups */\n22\tconst agentCache = new Map<string, Record<string, unknown>>();\n23\t\n24\tfunction loadAgent(name: string): Record<string, unknown> {\n25\t  const cached = agentCache.get(name);\n26\t  if (cached) return cached;\n27\t  const filePath = path.join(TEMPLATES_DIR, `${name}.yaml`);\n28\t  const content = fs.readFileSync(filePath, 'utf-8');\n29\t  const parsed = YAML.parse(content) as Record<string, unknown>;\n30\t  agentCache.set(name, parsed);\n31\t  return parsed;\n32\t}\n33\t\n34\tdescribe('embedded agent templates', () => {\n35\t  describe('directory and file existence (AC #1)', () => {\n36\t    it('templates/agents/ directory exists', () => {\n37\t      expect(fs.existsSync(TEMPLATES_DIR)).toBe(true);\n38\t    });\n39\t\n40\t    it('contains exactly 9 YAML files', () => {\n41\t      const files = fs.readdirSync(TEMPLATES_DIR).filter((f) => f.endsWith('.yaml'));\n42\t      expect(files).toHaveLength(9);\n43\t    });\n44\t\n45\t    it.each(EXPECTED_AGENTS)('%s.yaml exists', (name) => {\n46\t      const filePath = path.join(TEMPLATES_DIR, `${name}.yaml`);\n47\t      expect(fs.existsSync(filePath)).toBe(true);\n48\t    });\n49\t  });\n50\t\n51\t  describe('YAML parsing (AC #2)', () => {\n52\t    it.each(EXPECTED_AGENTS)('%s.yaml parses as valid YAML', (name) => {\n53\t      const agent = loadAgent(name);\n54\t      expect(agent).toBeDefined();\n55\t      expect(typeof agent).toBe('object');\n56\t    });\n57\t\n58\t    it.each(EXPECTED_AGENTS)('%s.yaml has required top-level fields: name, role, persona', (name) => {\n59\t      const agent = loadAgent(name);\n60\t      expect(agent).toHaveProperty('name');\n61\t      expect(agent).toHaveProperty('role');\n62\t      expect(agent).toHaveProperty('persona');\n63\t      expect(typeof agent.name).toBe('string');\n64\t      expect(typeof agent.role).toBe('object');\n65\t      expect(typeof agent.persona).toBe('object');\n66\t\n67\t      const role = agent.role as Record<string, unknown>;\n68\t      expect(role).toHaveProperty('title');\n69\t      expect(role).toHaveProperty('purpose');\n70\t\n71\t      const persona = agent.persona as Record<string, unknown>;\n72\t      expect(persona).toHaveProperty('identity');\n73\t      expect(persona).toHaveProperty('communication_style');\n74\t      expect(persona).toHaveProperty('principles');\n75\t      expect(Array.isArray(persona.principles)).toBe(true);\n76\t    });\n77\t  });\n78\t\n79\t  describe('schema validation (AC #3)', () => {\n80\t    it.each(EXPECTED_AGENTS)('%s.yaml validates against agent.schema.json', (name) => {\n81\t      const agent = loadAgent(name);\n82\t      const result = validateAgentSchema(agent);\n83\t      expect(result).toEqual({ valid: true, errors: [] });\n84\t    });\n85\t  });\n86\t\n87\t  describe('name matches filename (AC #8)', () => {\n88\t    it.each(EXPECTED_AGENTS)('%s.yaml has name field matching filename stem', (name) => {\n89\t      const agent = loadAgent(name);\n90\t      expect(agent.name).toBe(name);\n91\t    });\n92\t  });\n93\t\n94\t  describe('evaluator agent specifics (AC #4, #5)', () => {\n95\t    it('evaluator.yaml contains disallowedTools with Edit and Write', () => {\n96\t      const agent = loadAgent('evaluator');\n97\t      expect(agent.disallowedTools).toBeDefined();\n98\t      expect(Array.isArray(agent.disallowedTools)).toBe(true);\n99\t      const tools = agent.disallowedTools as string[];\n100\t      expect(tools).toContain('Edit');\n101\t      expect(tools).toContain('Write');\n102\t    });\n103\t\n104\t    it('evaluator.yaml persona.principles includes anti-leniency keywords', () => {\n105\t      const agent = loadAgent('evaluator');\n106\t      const persona = agent.persona as Record<string, unknown>;\n107\t      const principles = persona.principles as string[];\n108\t      const joined = principles.join(' ');\n109\t\n110\t      expect(joined).toContain('evidence');\n111\t      expect(joined).toContain('UNKNOWN');\n112\t      expect(joined).toContain('benefit of the doubt');\n113\t    });\n114\t\n115\t    it('evaluator.yaml personality.traits.rigor >= 0.9', () => {\n116\t      const agent = loadAgent('evaluator');\n117\t      const personality = agent.personality as Record<string, unknown>;\n118\t      const traits = personality.traits as Record<string, number>;\n119\t      expect(traits.rigor).toBeGreaterThanOrEqual(0.9);\n120\t    });\n121\t\n122\t    it('evaluator.yaml personality.traits.warmth <= 0.3', () => {\n123\t      const agent = loadAgent('evaluator');\n124\t      const personality = agent.personality as Record<string, unknown>;\n125\t      const traits = personality.traits as Record<string, number>;\n126\t      expect(traits.warmth).toBeLessThanOrEqual(0.3);\n127\t    });\n128\t  });\n129\t\n130\t  describe('BMAD derivation format (AC #6)', () => {\n131\t    const bmadDerived = EXPECTED_AGENTS.filter((n) => n !== 'evaluator');\n132\t\n133\t    it.each(bmadDerived)('%s.yaml uses flat codeharness format (no agent: wrapper)', (name) => {\n134\t      const agent = loadAgent(name);\n135\t      // Must NOT have BMAD-specific sections\n136\t      expect(agent).not.toHaveProperty('agent');\n137\t      expect(agent).not.toHaveProperty('metadata');\n138\t      expect(agent).not.toHaveProperty('menu');\n139\t      expect(agent).not.toHaveProperty('critical_actions');\n140\t      expect(agent).not.toHaveProperty('prompts');\n141\t    });\n142\t\n143\t    it.each(bmadDerived)('%s.yaml does not have personality.traits (only evaluator gets traits)', (name) => {\n144\t      const agent = loadAgent(name);\n145\t      expect(agent).not.toHaveProperty('personality');\n146\t    });\n147\t  });\n148\t\n149\t  describe('BMAD derivation content (AC #6)', () => {\n150\t    const BMAD_AGENTS_DIR = path.resolve(__dirname, '../../../_bmad/bmm/agents');\n151\t\n152\t    /** Map of template name → BMAD agent YAML path */\n153\t    const bmadPaths: Record<string, string> = {\n154\t      dev: path.join(BMAD_AGENTS_DIR, 'dev.agent.yaml'),\n155\t      qa: path.join(BMAD_AGENTS_DIR, 'qa.agent.yaml'),\n156\t      architect: path.join(BMAD_AGENTS_DIR, 'architect.agent.yaml'),\n157\t      pm: path.join(BMAD_AGENTS_DIR, 'pm.agent.yaml'),\n158\t      sm: path.join(BMAD_AGENTS_DIR, 'sm.agent.yaml'),\n159\t      analyst: path.join(BMAD_AGENTS_DIR, 'analyst.agent.yaml'),\n160\t      'ux-designer': path.join(BMAD_AGENTS_DIR, 'ux-designer.agent.yaml'),\n161\t      'tech-writer': path.join(BMAD_AGENTS_DIR, 'tech-writer/tech-writer.agent.yaml'),\n162\t    };\n163\t\n164\t    const bmadDerived = EXPECTED_AGENTS.filter((n) => n !== 'evaluator');\n165\t\n166\t    it.each(bmadDerived)('%s.yaml persona.identity derives from BMAD persona.identity', (name) => {\n167\t      const template = loadAgent(name);\n168\t      const bmadContent = fs.readFileSync(bmadPaths[name], 'utf-8');\n169\t      const bmad = YAML.parse(bmadContent) as Record<string, unknown>;\n170\t      const bmadAgent = bmad.agent as Record<string, unknown>;\n171\t      const bmadPersona = bmadAgent.persona as Record<string, unknown>;\n172\t      const templatePersona = template.persona as Record<string, unknown>;\n173\t\n174\t      // Template identity should contain the core BMAD identity text (possibly trimmed/reformatted)\n175\t      const bmadIdentity = String(bmadPersona.identity).trim();\n176\t      const templateIdentity = String(templatePersona.identity).trim();\n177\t      // At minimum, the first 20 chars of the BMAD identity should appear in the template\n178\t      const bmadPrefix = bmadIdentity.substring(0, 20);\n179\t      expect(templateIdentity).toContain(bmadPrefix);\n180\t    });\n181\t\n182\t    it.each(bmadDerived)('%s.yaml role.title derives from BMAD metadata.title', (name) => {\n183\t      const template = loadAgent(name);\n184\t      const bmadContent = fs.readFileSync(bmadPaths[name], 'utf-8');\n185\t      const bmad = YAML.parse(bmadContent) as Record<string, unknown>;\n186\t      const bmadAgent = bmad.agent as Record<string, unknown>;\n187\t      const bmadMetadata = bmadAgent.metadata as Record<string, unknown>;\n188\t      const templateRole = template.role as Record<string, unknown>;\n189\t\n190\t      expect(templateRole.title).toBe(String(bmadMetadata.title));\n191\t    });\n192\t  });\n193\t\n194\t  describe('no regressions (AC #8)', () => {\n195\t    it('existing schema validation still works for valid agent objects', () => {\n196\t      const result = validateAgentSchema({\n197\t        name: 'test-agent',\n198\t        role: { title: 'Test', purpose: 'Testing' },\n199\t        persona: {\n200\t          identity: 'A test agent',\n201\t          communication_style: 'Direct',\n202\t          principles: ['Be thorough'],\n203\t        },\n204\t      });\n205\t      expect(result).toEqual({ valid: true, errors: [] });\n206\t    });\n207\t\n208\t    it('existing schema validation still rejects invalid agent objects', () => {\n209\t      const result = validateAgentSchema({});\n210\t      expect(result.valid).toBe(false);\n211\t      expect(result.errors.length).toBeGreaterThan(0);\n212\t    });\n213\t  });\n214\t});\n215\t"}]},"parent_tool_use_id":"toolu_01HxnCrGRVZ6a9aAYNaAhVvW","session_id":"82c789c3-0c3c-4e9f-a910-db433860b9ed","uuid":"cfe3c0a6-844d-423e-8ec4-24c304513b35","timestamp":"2026-04-02T15:58:19.753Z"}
