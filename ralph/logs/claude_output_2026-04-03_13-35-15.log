{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01FzJv7ZMmgDCADBry5LUh9B","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_017ZL1s5Ad5TasbDBpsgawCW","name":"Edit","input":{"replace_all":false,"file_path":"/Users/ivintik/dev/personal/codeharness/src/lib/workflow-engine.ts","old_string":"// --- Main Execution ---\n\n/**\n * Execute a workflow sequentially: iterate through flow steps, dispatch tasks\n * per-story or per-run, checkpoint state after each dispatch.","new_string":"// --- Driver Health Check ---\n\n/** Default timeout for the health check phase (NFR6). */\nconst HEALTH_CHECK_TIMEOUT_MS = 5000;\n\n/**\n * Run health checks on all unique drivers referenced in a workflow.\n *\n * Collects unique driver names from `workflow.tasks`, resolves each via\n * `getDriver()`, and runs all `healthCheck()` calls concurrently with a\n * 5-second timeout (NFR6).\n *\n * Throws if any driver is unavailable or if the timeout fires.\n */\nexport async function checkDriverHealth(workflow: ResolvedWorkflow): Promise<void> {\n  // 1. Collect unique driver names from all tasks\n  const driverNames = new Set<string>();\n  for (const task of Object.values(workflow.tasks)) {\n    driverNames.add(task.driver ?? 'claude-code');\n  }\n\n  // 2. Resolve drivers\n  const drivers = new Map<string, ReturnType<typeof getDriver>>();\n  for (const name of driverNames) {\n    drivers.set(name, getDriver(name));\n  }\n\n  // 3. Run health checks concurrently\n  type HealthResult = { name: string; health: DriverHealth };\n  const healthChecks = Promise.all(\n    [...drivers.entries()].map(async ([name, driver]): Promise<HealthResult> => {\n      const health = await driver.healthCheck();\n      return { name, health };\n    }),\n  );\n\n  // 4. Race against timeout (NFR6)\n  const timeoutPromise = new Promise<'timeout'>((resolve) => {\n    setTimeout(() => resolve('timeout'), HEALTH_CHECK_TIMEOUT_MS);\n  });\n\n  const result = await Promise.race([healthChecks, timeoutPromise]);\n\n  if (result === 'timeout') {\n    const names = [...driverNames].join(', ');\n    throw new Error(\n      `Driver health check timed out after ${HEALTH_CHECK_TIMEOUT_MS}ms. Drivers that did not respond: ${names}`,\n    );\n  }\n\n  // 5. Check for failures\n  const failures = result.filter((r) => !r.health.available);\n  if (failures.length > 0) {\n    const details = failures\n      .map((f) => `${f.name}: ${f.health.error ?? 'unavailable'}`)\n      .join('; ');\n    throw new Error(`Driver health check failed: ${details}`);\n  }\n}\n\n// --- Main Execution ---\n\n/**\n * Execute a workflow sequentially: iterate through flow steps, dispatch tasks\n * per-story or per-run, checkpoint state after each dispatch."},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":270,"cache_read_input_tokens":37577,"cache_creation":{"ephemeral_5m_input_tokens":270,"ephemeral_1h_input_tokens":0},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01J1hA6EdKQNp4qhAx3VLe1g","session_id":"b101ea9e-2f9e-4377-9c5a-f109fa318b32","uuid":"0ceb26de-614f-4c0f-b2b0-2666c4a6f685"}
