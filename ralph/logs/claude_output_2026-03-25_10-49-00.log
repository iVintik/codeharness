{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JCV45UfFEjgHALfyqAwPMW","type":"tool_result","content":"     1→/**\n     2→ * Observability analyzer module — runs static analysis and produces\n     3→ * a standardized gap report.\n     4→ *\n     5→ * Currently implements Semgrep integration but the AnalyzerResult\n     6→ * interface is tool-agnostic: any tool producing the same shape\n     7→ * can be used as a drop-in replacement.\n     8→ */\n     9→\n    10→import { execFileSync } from 'node:child_process';\n    11→import { join } from 'node:path';\n    12→import { ok, fail } from '../../types/result.js';\n    13→import type { Result } from '../../types/result.js';\n    14→import type {\n    15→  AnalyzerConfig,\n    16→  AnalyzerResult,\n    17→  AnalyzerSummary,\n    18→  ObservabilityGap,\n    19→  GapSeverity,\n    20→  SemgrepRawOutput,\n    21→} from './types.js';\n    22→\n    23→const DEFAULT_RULES_DIR = 'patches/observability/';\n    24→const DEFAULT_TIMEOUT = 60_000;\n    25→const FUNCTION_NO_LOG_RULE = 'function-no-debug-log';\n    26→const CATCH_WITHOUT_LOGGING_RULE = 'catch-without-logging';\n    27→const ERROR_PATH_NO_LOG_RULE = 'error-path-no-log';\n    28→\n    29→/**\n    30→ * Check if a gap's type (rule ID) matches a known rule name.\n    31→ * Semgrep produces path-prefixed check_ids like\n    32→ * \"tmp.test-ac5c.patches.observability.function-no-debug-log\",\n    33→ * so we use endsWith() rather than strict equality.\n    34→ */\n    35→function matchesRule(gapType: string, ruleName: string): boolean {\n    36→  return gapType === ruleName || gapType.endsWith(`.${ruleName}`);\n    37→}\n    38→\n    39→/**\n    40→ * Run observability analysis on a project directory.\n    41→ *\n    42→ * @param projectDir - Absolute path to the project root\n    43→ * @param config - Optional configuration overriding defaults\n    44→ * @returns Result containing the analysis report, or a skip result if the tool is not installed\n    45→ */\n    46→export function analyze(\n    47→  projectDir: string,\n    48→  config?: AnalyzerConfig,\n    49→): Result<AnalyzerResult> {\n    50→  if (!projectDir || typeof projectDir !== 'string') {\n    51→    return fail('projectDir is required and must be a non-empty string');\n    52→  }\n    53→\n    54→  const tool = config?.tool ?? 'semgrep';\n    55→\n    56→  if (tool !== 'semgrep') {\n    57→    return fail(`Unsupported analyzer tool: ${tool}`);\n    58→  }\n    59→\n    60→  if (!checkSemgrepInstalled()) {\n    61→    return ok({\n    62→      tool: 'semgrep',\n    63→      gaps: [],\n    64→      summary: {\n    65→        totalFunctions: 0,\n    66→        functionsWithLogs: 0,\n    67→        errorHandlersWithoutLogs: 0,\n    68→        coveragePercent: 0,\n    69→        levelDistribution: {},\n    70→      },\n    71→      skipped: true,\n    72→      skipReason: 'static analysis skipped -- install semgrep',\n    73→    });\n    74→  }\n    75→\n    76→  const rulesDir = config?.rulesDir ?? DEFAULT_RULES_DIR;\n    77→  const timeout = config?.timeout ?? DEFAULT_TIMEOUT;\n    78→  const fullRulesDir = join(projectDir, rulesDir);\n    79→\n    80→  const rawResult = runSemgrep(projectDir, fullRulesDir, timeout);\n    81→  if (!rawResult.success) {\n    82→    return fail(rawResult.error);\n    83→  }\n    84→\n    85→  const gaps = parseSemgrepOutput(rawResult.data);\n    86→  const summaryOpts = config?.totalFunctions != null\n    87→    ? { totalFunctions: config.totalFunctions }\n    88→    : undefined;\n    89→  const summary = computeSummary(gaps, summaryOpts);\n    90→\n    91→  return ok({\n    92→    tool: 'semgrep',\n    93→    gaps,\n    94→    summary,\n    95→  });\n    96→}\n    97→\n    98→/**\n    99→ * Check whether Semgrep is installed and available on PATH.\n   100→ */\n   101→export function checkSemgrepInstalled(): boolean {\n   102→  try {\n   103→    execFileSync('semgrep', ['--version'], {\n   104→      encoding: 'utf-8',\n   105→      timeout: 5_000,\n   106→      stdio: 'pipe',\n   107→    });\n   108→    return true;\n   109→  } catch {\n   110→    // IGNORE: grep check may fail if tool not available\n   111→    return false;\n   112→  }\n   113→}\n   114→\n   115→/**\n   116→ * Spawn Semgrep and capture its JSON output.\n   117→ */\n   118→export function runSemgrep(\n   119→  projectDir: string,\n   120→  rulesDir: string,\n   121→  timeout: number = DEFAULT_TIMEOUT,\n   122→): Result<SemgrepRawOutput> {\n   123→  try {\n   124→    const stdout = execFileSync(\n   125→      'semgrep',\n   126→      ['scan', '--config', rulesDir, '--json', projectDir],\n   127→      { encoding: 'utf-8', timeout, stdio: ['pipe', 'pipe', 'pipe'] },\n   128→    );\n   129→    const parsed: unknown = JSON.parse(stdout);\n   130→    if (\n   131→      typeof parsed !== 'object' ||\n   132→      parsed === null ||\n   133→      !Array.isArray((parsed as Record<string, unknown>).results)\n   134→    ) {\n   135→      return fail('Semgrep scan returned invalid JSON: missing results array');\n   136→    }\n   137→    return ok(parsed as SemgrepRawOutput);\n   138→  } catch (error) {\n   139→    return fail(`Semgrep scan failed: ${String(error)}`);\n   140→  }\n   141→}\n   142→\n   143→/**\n   144→ * Parse Semgrep JSON results into tool-agnostic ObservabilityGap[].\n   145→ */\n   146→export function parseSemgrepOutput(raw: SemgrepRawOutput): ObservabilityGap[] {\n   147→  if (!raw.results || !Array.isArray(raw.results)) {\n   148→    return [];\n   149→  }\n   150→  return raw.results.map((r) => ({\n   151→    file: r.path,\n   152→    line: r.start.line,\n   153→    type: r.check_id,\n   154→    description: r.extra.message,\n   155→    severity: normalizeSeverity(r.extra.severity),\n   156→  }));\n   157→}\n   158→\n   159→/**\n   160→ * Compute summary statistics from gaps.\n   161→ *\n   162→ * Coverage formula: functionsWithLogs / totalFunctions * 100.\n   163→ *\n   164→ * Uses Option 3 from architecture notes: the `function-no-debug-log` rule\n   165→ * matches functions WITHOUT logging. Combined with an optional\n   166→ * `totalFunctions` override, this gives exact coverage.\n   167→ *\n   168→ * When totalFunctions is not provided, it equals the count of\n   169→ * function-no-debug-log matches (all detected functions lack logs).\n   170→ *\n   171→ * If totalFunctions is 0, coverage = 100 (no functions = no gaps).\n   172→ *\n   173→ * @param gaps - Parsed observability gaps\n   174→ * @param opts - Optional overrides for function counts (e.g., from external scan)\n   175→ */\n   176→export function computeSummary(\n   177→  gaps: ObservabilityGap[],\n   178→  opts?: { totalFunctions?: number },\n   179→): AnalyzerSummary {\n   180→  const functionsWithoutLogs = gaps.filter(\n   181→    (g) => matchesRule(g.type, FUNCTION_NO_LOG_RULE),\n   182→  ).length;\n   183→\n   184→  const errorHandlersWithoutLogs = gaps.filter(\n   185→    (g) =>\n   186→      matchesRule(g.type, CATCH_WITHOUT_LOGGING_RULE) ||\n   187→      matchesRule(g.type, ERROR_PATH_NO_LOG_RULE),\n   188→  ).length;\n   189→\n   190→  // If totalFunctions is provided externally (e.g., from a complementary\n   191→  // function-counting rule or AST scan), use it. Otherwise, we only know\n   192→  // about the functions that LACK logs.\n   193→  const totalFunctions = opts?.totalFunctions ?? functionsWithoutLogs;\n   194→  const functionsWithLogs = totalFunctions - functionsWithoutLogs;\n   195→  const coveragePercent =\n   196→    totalFunctions === 0\n   197→      ? 100\n   198→      : Math.round((functionsWithLogs / totalFunctions) * 100 * 100) / 100;\n   199→\n   200→  // Build level distribution from gap severities\n   201→  const levelDistribution: Record<string, number> = {};\n   202→  for (const gap of gaps) {\n   203→    levelDistribution[gap.severity] =\n   204→      (levelDistribution[gap.severity] ?? 0) + 1;\n   205→  }\n   206→\n   207→  return {\n   208→    totalFunctions,\n   209→    functionsWithLogs,\n   210→    errorHandlersWithoutLogs,\n   211→    coveragePercent,\n   212→    levelDistribution,\n   213→  };\n   214→}\n   215→\n   216→/** Normalize Semgrep severity string to our GapSeverity union */\n   217→function normalizeSeverity(severity: string): GapSeverity {\n   218→  const lower = severity.toLowerCase();\n   219→  if (lower === 'error') return 'error';\n   220→  if (lower === 'warning') return 'warning';\n   221→  return 'info';\n   222→}\n   223→"}]},"parent_tool_use_id":"toolu_01MaiZ71xHuWaWxP6B1wGjKe","session_id":"3fcb2b1c-e710-401b-91ab-b64a3e9a3996","uuid":"4112959a-8e53-4ae1-95e0-53dccc8f328f","timestamp":"2026-03-25T06:53:21.513Z"}
