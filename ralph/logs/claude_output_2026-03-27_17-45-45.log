ent-provable');\n    47→  });\n    48→\n    49→  it('returns escalate when escalate is present', () => {\n    50→    expect(maxTier(['test-provable', 'escalate'])).toBe('escalate');\n    51→  });\n    52→\n    53→  it('returns escalate for all four tiers', () => {\n    54→    expect(maxTier(['test-provable', 'runtime-provable', 'environment-provable', 'escalate'])).toBe('escalate');\n    55→  });\n    56→\n    57→  it('returns the single tier when array has one element', () => {\n    58→    const tiers: VerificationTier[] = ['runtime-provable'];\n    59→    expect(maxTier(tiers)).toBe('runtime-provable');\n    60→  });\n    61→\n    62→  it('returns environment-provable for [environment-provable, runtime-provable]', () => {\n    63→    expect(maxTier(['environment-provable', 'runtime-provable'])).toBe('environment-provable');\n    64→  });\n    65→\n    66→  it('handles duplicates correctly', () => {\n    67→    expect(maxTier(['test-provable', 'test-provable', 'test-provable'])).toBe('test-provable');\n    68→  });\n    69→\n    70→  it('handles duplicates with higher tier', () => {\n    71→    expect(maxTier(['runtime-provable', 'runtime-provable', 'test-provable'])).toBe('runtime-provable');\n    72→  });\n    73→\n    74→  it('is order-independent', () => {\n    75→    const a = maxTier(['escalate', 'test-provable', 'runtime-provable']);\n    76→    const b = maxTier(['test-provable', 'runtime-provable', 'escalate']);\n    77→    const c = maxTier(['runtime-provable', 'escalate', 'test-provable']);\n    78→    expect(a).toBe('escalate');\n    79→    expect(b).toBe('escalate');\n    80→    expect(c).toBe('escalate');\n    81→  });\n    82→});\n    83→\n    84→// ─── LEGACY_TIER_MAP ────────────────────────────────────────────────────────\n    85→\n    86→describe('LEGACY_TIER_MAP', () => {\n    87→  it('maps cli-verifiable to test-provable (AC7)', () => {\n    88→    expect(LEGACY_TIER_MAP['cli-verifiable']).toBe('test-provable');\n    89→  });\n    90→\n    91→ 