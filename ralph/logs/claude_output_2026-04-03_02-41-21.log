{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DWLYgkWBsuKZyGqW5cfknv","type":"tool_result","content":"60\t  }>;\n61\t  evaluator_trace_id?: string;\n62\t  duration_seconds?: number;\n63\t}\n64\t\n65\t/**\n66\t * Result returned by executeWorkflow().\n67\t */\n68\texport interface EngineResult {\n69\t  /** Whether the workflow completed without errors. */\n70\t  success: boolean;\n71\t  /** Number of task dispatches completed. */\n72\t  tasksCompleted: number;\n73\t  /** Number of work items (stories/issues) processed. */\n74\t  storiesProcessed: number;\n75\t  /** Errors encountered during execution. */\n76\t  errors: EngineError[];\n77\t  /** Wall-clock duration of the entire workflow in milliseconds. */\n78\t  durationMs: number;\n79\t}\n80\t\n81\t/**\n82\t * Structured error recorded during workflow execution.\n83\t */\n84\texport interface EngineError {\n85\t  taskName: string;\n86\t  storyKey: string;\n87\t  code: string;\n88\t  message: string;\n89\t}\n90\t\n91\t/**\n92\t * A work item (story or issue) ready for execution.\n93\t */\n94\texport interface WorkItem {\n95\t  key: string;\n96\t  title?: string;\n97\t  source: 'sprint' | 'issues';\n98\t}\n99\t\n100\t// --- Constants ---\n101\t\n102\t/** Sentinel story key for per-run tasks. */\n103\tconst PER_RUN_SENTINEL = '__run__';\n104\t\n105\t/** DispatchError codes that should halt execution immediately. */\n106\tconst HALT_ERROR_CODES = new Set(['RATE_LIMIT', 'NETWORK', 'SDK_INIT']);\n107\t\n108\t/** Default maximum loop iterations before termination. */\n109\tconst DEFAULT_MAX_ITERATIONS = 5;\n110\t\n111\t// --- Work Item Loading ---\n112\t\n113\t/**\n114\t * Load work items from sprint-status.yaml and optionally issues.yaml.\n115\t *\n116\t * Stories are extracted from the `development_status` section of sprint-status.yaml.\n117\t * Issues are extracted from the `issues` array of issues.yaml.\n118\t *\n119\t * Only items with status `backlog` or `ready-for-dev` are included.\n120\t * Epic keys (`epic-*`) and retrospective keys (`*-retrospective`) are excluded.\n121\t *\n122\t * If issues.yaml does not exist, returns only stories (no error).\n123\t */\n124\texport function loadWorkItems(sprintStatusPath: string, issuesPath?: string): WorkItem[] {\n125\t  const items: WorkItem[] = [];\n126\t\n127\t  // --- Load stories from sprint-status.yaml ---\n128\t  if (existsSync(sprintStatusPath)) {\n129\t    let raw: string;\n130\t    try {\n131\t      raw = readFileSync(sprintStatusPath, 'utf-8');\n132\t    } catch { // IGNORE: unreadable file — warn and return empty\n133\t      warn(`workflow-engine: could not read sprint-status.yaml at ${sprintStatusPath}`);\n134\t      return items;\n135\t    }\n136\t\n137\t    let parsed: unknown;\n138\t    try {\n139\t      parsed = parse(raw);\n140\t    } catch { // IGNORE: malformed YAML — warn and return empty\n141\t      warn(`workflow-engine: invalid YAML in sprint-status.yaml at ${sprintStatusPath}`);\n142\t      return items;\n143\t    }\n144\t\n145\t    if (parsed && typeof parsed === 'object') {\n146\t      const data = parsed as Record<string, unknown>;\n147\t      const devStatus = data.development_status as Record<string, unknown> | undefined;\n148\t\n149\t      if (devStatus && typeof devStatus === 'object') {\n150\t        for (const [key, status] of Object.entries(devStatus)) {\n151\t          // Skip epic keys and retrospective keys\n152\t          if (key.startsWith('epic-')) continue;\n153\t          if (key.endsWith('-retrospective')) continue;\n154\t\n155\t          // Only include backlog or ready-for-dev\n156\t          if (status === 'backlog' || status === 'ready-for-dev') {\n157\t            items.push({ key, source: 'sprint' });\n158\t          }\n159\t        }"}]},"parent_tool_use_id":"toolu_011eJ4iFzBFG7CSy7fE3qSCc","session_id":"8b4a1da7-9e18-4302-ad13-ce7f0aff0314","uuid":"78b15d23-aa28-4d4f-af7d-29f064bf0138","timestamp":"2026-04-02T22:43:19.701Z"}
