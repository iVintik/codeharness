ne.test.tsx\u001b[2m > \u001b[22mformatLaneElapsed\u001b[2m > \u001b[22mformats seconds < 60 as Xs\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m\n \u001b[32m✓\u001b[39m lib/__tests__/ink-lane.test.tsx\u001b[2m > \u001b[22mformatLaneElapsed\u001b[2m > \u001b[22mformats minutes < 60 as Xm\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m\n \u001b[32m✓\u001b[39m lib/__tests__/ink-lane.test.tsx\u001b[2m > \u001b[22mformatLaneElapsed\u001b[2m > \u001b[22mformats >= 60 minutes as Xh Xm\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m\n \u001b[32m✓\u001b[39m lib/__tests__/ink-lane.test.tsx\u001b[2m > \u001b[22mformatLaneElapsed\u001b[2m > \u001b[22mreturns -- for null\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m\n \u001b[32m✓\u001b[39m lib/__tests__/ink-lane.test.tsx\u001b[2m > \u001b[22mformatLaneElapsed\u001b[2m > \u001b[22mreturns 0s for 0ms\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m","is_error":false}]},"parent_tool_use_id":"toolu_01Tp1EiHuLRgwUdvr7VPq3jn","session_id":"0c112080-0896-4e32-96a0-f82adec16922","uuid":"5e6ed3a7-91df-4c20-972a-3c1f9c327b8a","timestamp":"2026-04-04T02:33:39.336Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LwffamypeJLWcpzhQ6Hcr7","type":"tool_result","content":"1\t/**\n2\t * Lane — Ink component that renders a single epic lane's status display.\n3\t *\n4\t * Shows epic title, current story + phase, story progress bar,\n5\t * and driver name + cost/time. Pure presentational component.\n6\t *\n7\t * @see Story 20.1: Lane Container & Lane Components\n8\t */\n9\t\n10\timport React from 'react';\n11\timport { Text, Box } from 'ink';\n12\t\n13\t// --- Types ---\n14\t\n15\texport type StoryProgressStatus = 'done' | 'in-progress' | 'pending';\n16\t\n17\texport interface StoryProgressEntry {\n18\t  key: string;\n19\t  status: StoryProgressStatus;\n20\t}\n21\t\n22\texport interface LaneProps {\n23\t  /** Epic identifier (e.g., \"10\"). */\n24\t  epicId: string;\n25\t  /** Human-readable epic title (e.g., \"Driver Interface\"). */\n26\t  epicTitle: string;\n27\t  /** Current story key (e.g., \"10-3\"). */\n28\t  currentStory: string | null;\n29\t  /** Current phase (e.g., \"dev\", \"verify\"). */\n30\t  phase: string | null;\n31\t  /** Acceptance criteria progress (e.g., \"4/9\"). */\n32\t  acProgress: string | null;\n33\t  /** Progress entries for all stories in this epic. */\n34\t  storyProgressEntries: StoryProgressEntry[];\n35\t  /** Driver name (e.g., \"claude-code\"). */\n36\t  driver: string | null;\n37\t  /** Total cost in USD for this lane. */\n38\t  cost: number | null;\n39\t  /** Elapsed time in milliseconds. */\n40\t  elapsedTime: number | null;\n41\t  /** Lane index (1-based for display). */\n42\t  laneIndex?: number;\n43\t}\n44\t\n45\t/** Format cost as $X.XX, or `--` for null. */\n46\texport function formatLaneCost(cost: number | null): string {\n47\t  if (cost == null) return '--';\n48\t  return `$${cost.toFixed(2)}`;\n49\t}\n50\t\n51\t/** Format elapsed time: Xh Xm for >=60min, Xm for >=1min, Xs for <1min, `--` for null. */\n52\texport function formatLaneElapsed(ms: number | null): string {\n53\t  if (ms == null) return '--';\n54\t  const totalSeconds = Math.round(ms / 1000);\n55\t  const minutes = Math.floor(totalSeconds / 60);\n56\t  if (minutes >= 60) {\n57\t    const hours = Math.floor(minutes / 60);\n58\t    const remainingMinutes = minutes % 60;\n59\t    return `${hours}h ${remainingMinutes}m`;\n60\t  }\n61\t  if (minutes >= 1) {\n62\t    return `${minutes}m`;\n63\t  }\n64\t  return `${totalSeconds}s`;\n65\t}\n66\t\n67\t/** Render the story progress bar: ✓ done, ◆ in-progress, ○ pending. */\n68\tfunction StoryProgressBar({ entries }: { entries: StoryProgressEntry[] }) {\n69\t  if (entries.length === 0) return null;\n70\t\n71\t  const items: React.ReactNode[] = [];\n72\t  for (let i = 0; i < entries.length; i++) {\n73\t    const entry = entries[i];\n74\t    if (i > 0) items.push(<Text key={`sp-${i}`}>{' '}</Text>);\n75\t\n76\t    switch (entry.status) {\n77\t      case 'done':\n78\t        items.push(<Text key={`s-${i}`} color=\"green\">{`✓ ${entry.key}`}</Text>);\n79\t        break;\n80\t      case 'in-progress':\n81\t        items.push(<Text key={`s-${i}`} color=\"yellow\">{`◆ ${entry.key}`}</Text>);\n82\t        break;\n83\t      case 'pending':\n84\t        items.push(<Text key={`s-${i}`} dimColor>{`○ ${entry.key}`}</Text>);\n85\t        break;\n86\t    }\n87\t  }\n88\t\n89\t  return <Text> {items}</Text>;\n90\t}\n91\t\n92\t/** Single lane display component. */\n93\texport function Lane(props: LaneProps) {\n94\t  const {\n95\t    epicId,\n96\t    epicTitle,\n97\t    currentStory,\n98\t    phase,\n99\t    acProgress,\n100\t    storyProgressEntries,\n101\t    driver,\n102\t    cost,\n103\t    elapsedTime,\n104\t    laneIndex,\n105\t  } = props;\n106\t\n107\t  const laneLabel = laneIndex != null ? `Lane ${laneIndex}: ` : '';\n108\t  const titleLine = `${laneLabel}Epic ${epicId} \\u2014 ${epicTitle}`;\n109\t\n110\t  const storyParts: string[] = [];\n111\t  if (currentStory) storyParts.push(currentStory);\n112\t  if (phase) storyParts.push(`\\u25C6 ${phase}`);\n113\t  if (acProgress) storyParts.push(`(AC ${acProgress})`);\n114\t  const storyLine = storyParts.length > 0 ? ` ${storyParts.join(' ')}` : null;\n115\t\n116\t  const driverLine = ` ${driver ?? 'unknown'} | ${formatLaneCost(cost)} / ${formatLaneElapsed(elapsedTime)}`;\n117\t\n118\t  return (\n119\t    <Box flexDirection=\"column\">\n120\t      <Text bold>{titleLine}</Text>\n121\t      {storyLine && <Text>{storyLine}</Text>}\n122\t      <StoryProgressBar entries={storyProgressEntries} />\n123\t      <Text dimColor>{driverLine}</Text>\n124\t    </Box>\n125\t  );\n126\t}\n127\t"}]},"parent_tool_use_id":"toolu_01Tp1EiHuLRgwUdvr7VPq3jn","session_id":"0c112080-0896-4e32-96a0-f82adec16922","uuid":"84e81271-a240-48ed-8071-d49e3b76930f","timestamp":"2026-04-04T02:33:39.337Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015YqQZ5MF1izjFWuiDJAGim","type":"tool_result","content":"1\t/**\n2\t * LaneContainer — Ink component that manages multi-lane layout.\n3\t *\n4\t * Renders lanes side-by-side, stacked, or single depending on terminal width.\n5\t * Lanes 3+ collapse to one-line summaries. Pure presentational component.\n6\t *\n7\t * @see Story 20.1: Lane Container & Lane Components\n8\t */\n9\t\n10\timport React from 'react';\n11\timport { Text, Box } from 'ink';\n12\timport { Lane, formatLaneCost, formatLaneElapsed } from './ink-lane.js';\n13\timport type { StoryProgressEntry } from './ink-lane.js';\n14\t\n15\t// --- Types ---\n16\t\n17\texport type LayoutMode = 'side-by-side' | 'stacked' | 'single';\n18\t\n19\texport interface LaneData {\n20\t  /** Epic identifier. */\n21\t  epicId: string;\n22\t  /** Human-readable epic title. */\n23\t  epicTitle: string;\n24\t  /** Current story key. */\n25\t  currentStory: string | null;\n26\t  /** Current phase. */\n27\t  phase: string | null;\n28\t  /** AC progress (e.g., \"4/9\"). */\n29\t  acProgress: string | null;\n30\t  /** Story progress entries. */\n31\t  storyProgressEntries: StoryProgressEntry[];\n32\t  /** Driver name. */\n33\t  driver: string | null;\n34\t  /** Cost in USD. */\n35\t  cost: number | null;\n36\t  /** Elapsed time in ms. */\n37\t  elapsedTime: number | null;\n38\t  /** Timestamp of last activity (ISO 8601 or epoch ms). */\n39\t  lastActivityTime?: number;\n40\t}\n41\t\n42\texport interface LaneContainerProps {\n43\t  /** All active lanes to render. */\n44\t  lanes: LaneData[];\n45\t  /** Current terminal width in columns. */\n46\t  terminalWidth: number;\n47\t}\n48\t\n49\texport interface CollapsedLaneData {\n50\t  /** Lane index (1-based for display). */\n51\t  laneIndex: number;\n52\t  /** Epic title. */\n53\t  epicTitle: string;\n54\t  /** Current story key. */\n55\t  currentStory: string | null;\n56\t  /** Current phase. */\n57\t  phase: string | null;\n58\t  /** Cost in USD. */\n59\t  cost: number | null;\n60\t  /** Elapsed time in ms. */\n61\t  elapsedTime: number | null;\n62\t}\n63\t\n64\t// --- Helpers ---\n65\t\n66\t/** Determine layout mode from terminal width. */\n67\texport function getLayoutMode(terminalWidth: number): LayoutMode {\n68\t  if (terminalWidth >= 120) return 'side-by-side';\n69\t  if (terminalWidth >= 80) return 'stacked';\n70\t  return 'single';\n71\t}\n72\t\n73\t/** Truncate a string to fit within maxLen, adding ellipsis if needed. */\n74\tfunction truncate(str: string, maxLen: number): string {\n75\t  if (maxLen < 4) return str.slice(0, maxLen);\n76\t  if (str.length <= maxLen) return str;\n77\t  return str.slice(0, maxLen - 1) + '\\u2026';\n78\t}\n79\t\n80\t// --- Sub-components ---\n81\t\n82\t/** Renders collapsed lane summaries as single lines. */\n83\texport function CollapsedLanes({ lanes }: { lanes: CollapsedLaneData[] }) {\n84\t  if (lanes.length === 0) return null;\n85\t\n86\t  return (\n87\t    <Box flexDirection=\"column\">\n88\t      {lanes.map((lane) => {\n89\t        const storyPart = lane.currentStory ?? '--';\n90\t        const phasePart = lane.phase ?? '--';\n91\t        const costPart = formatLaneCost(lane.cost);\n92\t        const timePart = formatLaneElapsed(lane.elapsedTime);\n93\t        const line = `Lane ${lane.laneIndex}: ${lane.epicTitle} \\u2502 ${storyPart} \\u25C6 ${phasePart} \\u2502 ${costPart} / ${timePart}`;\n94\t\n95\t        return (\n96\t          <Text key={`collapsed-${lane.laneIndex}`} dimColor>{line}</Text>\n97\t        );\n98\t      })}\n99\t    </Box>\n100\t  );\n101\t}\n102\t\n103\t/** Multi-lane layout manager. */\n104\texport function LaneContainer({ lanes, terminalWidth }: LaneContainerProps) {\n105\t  if (lanes.length === 0) return null;\n106\t\n107\t  const mode = getLayoutMode(terminalWidth);\n108\t\n109\t  // Determine which lanes are full vs collapsed\n110\t  // In single mode: only most recently active lane is full, rest collapsed\n111\t  // In side-by-side/stacked: first 2 full, rest collapsed\n112\t  let fullLanes: LaneData[];\n113\t  let collapsedLaneData: CollapsedLaneData[];\n114\t\n115\t  if (mode === 'single') {\n116\t    // Find most recently active lane\n117\t    let mostRecentIndex = 0;\n118\t    let mostRecentTime = -Infinity;\n119\t    for (let i = 0; i < lanes.length; i++) {\n120\t      const t = lanes[i].lastActivityTime ?? 0;\n121\t      if (t >= mostRecentTime) {\n122\t        mostRecentTime = t;\n123\t        mostRecentIndex = i;\n124\t      }\n125\t    }\n126\t    fullLanes = [lanes[mostRecentIndex]];\n127\t    collapsedLaneData = lanes\n128\t      .filter((_, i) => i !== mostRecentIndex)\n129\t      .map((lane, i) => {\n130\t        // Calculate original 1-based index\n131\t        const originalIndex = i >= mostRecentIndex ? i + 2 : i + 1;\n132\t        return {\n133\t          laneIndex: originalIndex,\n134\t          epicTitle: truncate(lane.epicTitle, 30),\n135\t          currentStory: lane.currentStory,\n136\t          phase: lane.phase,\n137\t          cost: lane.cost,\n138\t          elapsedTime: lane.elapsedTime,\n139\t        };\n140\t      });\n141\t  } else {\n142\t    // Side-by-side or stacked: first 2 full, rest collapsed\n143\t    fullLanes = lanes.slice(0, 2);\n144\t    collapsedLaneData = lanes.slice(2).map((lane, i) => ({\n145\t      laneIndex: i + 3,\n146\t      epicTitle: truncate(lane.epicTitle, 30),\n147\t      currentStory: lane.currentStory,\n148\t      phase: lane.phase,\n149\t      cost: lane.cost,\n150\t      elapsedTime: lane.elapsedTime,\n151\t    }));\n152\t  }\n153\t\n154\t  // Render full lanes\n155\t  const laneWidth = mode === 'side-by-side'\n156\t    ? Math.floor(terminalWidth / 2) - 1\n157\t    : terminalWidth;\n158\t\n159\t  const fullLaneElements: React.ReactNode[] = [];\n160\t  for (let i = 0; i < fullLanes.length; i++) {\n161\t    const lane = fullLanes[i];\n162\t    const laneIndex = mode === 'single' ? undefined : i + 1;\n163\t    // Add a thin separator between stacked/single full lanes (not in side-by-side)\n164\t    if (i > 0 && mode !== 'side-by-side') {\n165\t      fullLaneElements.push(<Text key={`sep-${i}`} dimColor>{'─'.repeat(Math.min(terminalWidth, 60))}</Text>);\n166\t    }\n167\t    fullLaneElements.push(\n168\t      <Box key={`lane-${lane.epicId}`} width={mode === 'side-by-side' ? laneWidth : undefined} flexDirection=\"column\">\n169\t        <Lane\n170\t          epicId={lane.epicId}\n171\t          epicTitle={lane.epicTitle}\n172\t          currentStory={lane.currentStory}\n173\t          phase={lane.phase}\n174\t          acProgress={lane.acProgress}\n175\t          storyProgressEntries={lane.storyProgressEntries}\n176\t          driver={lane.driver}\n177\t          cost={lane.cost}\n178\t          elapsedTime={lane.elapsedTime}\n179\t          laneIndex={laneIndex}\n180\t        />\n181\t      </Box>\n182\t    );\n183\t  }\n184\t\n185\t  return (\n186\t    <Box flexDirection=\"column\">\n187\t      {mode === 'side-by-side' ? (\n188\t        <Box flexDirection=\"row\">\n189\t          {fullLaneElements}\n190\t        </Box>\n191\t      ) : (\n192\t        <Box flexDirection=\"column\">\n193\t          {fullLaneElements}\n194\t        </Box>\n195\t      )}\n196\t      <CollapsedLanes lanes={collapsedLaneData} />\n197\t    </Box>\n198\t  );\n199\t}\n200\t"}]},"parent_tool_use_id":"toolu_01Tp1EiHuLRgwUdvr7VPq3jn","session_id":"0c112080-0896-4e32-96a0-f82adec16922","uuid":"7b92756b-f424-470f-841b-71282ff9d7c0","timestamp":"2026-04-04T02:33:39.338Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KkVZsRzSWyoyL7vra6JHGE","type":"tool_result","content":"1\t/**\n2\t * Ink App root component — composes layout and activity components.\n3\t *\n4\t * Separated from ink-components.tsx to avoid circular imports\n5\t * (ink-components exports types, ink-activity-components imports them,\n6\t * and this file imports from both).\n7\t */\n8\t\n9\timport React from 'react';\n10\timport { Box, Static } from 'ink';\n11\timport { Header, Separator, StoryBreakdown, type RendererState } from './ink-components.js';\n12\timport { CompletedTools, ActiveTool, LastThought, RetryNotice, StoryMessageLine, DriverCostSummary } from './ink-activity-components.js';\n13\timport { WorkflowGraph } from './ink-workflow.js';\n14\timport { LaneContainer } from './ink-lane-container.js';\n15\timport type { LaneData } from './ink-lane-container.js';\n16\t\n17\texport function App({ state }: { state: RendererState }) {\n18\t  const lanes: LaneData[] | undefined = state.lanes;\n19\t  const laneCount = lanes?.length ?? 0;\n20\t  const terminalWidth = process.stdout.columns || 80;\n21\t\n22\t  return (\n23\t    <Box flexDirection=\"column\">\n24\t      <Static items={state.messages}>\n25\t        {(msg, i) => <StoryMessageLine key={i} msg={msg} />}\n26\t      </Static>\n27\t      <Header info={state.sprintInfo} laneCount={laneCount > 1 ? laneCount : undefined} />\n28\t      {laneCount > 1 ? (\n29\t        <LaneContainer lanes={lanes!} terminalWidth={terminalWidth} />\n30\t      ) : (\n31\t        <>\n32\t          <WorkflowGraph flow={state.workflowFlow} currentTask={state.currentTaskName} taskStates={state.taskStates} taskMeta={state.taskMeta} />\n33\t          <StoryBreakdown stories={state.stories} sprintInfo={state.sprintInfo} />\n34\t          <DriverCostSummary driverCosts={state.driverCosts} />\n35\t        </>\n36\t      )}\n37\t      {state.stories.length > 0 && <Separator />}\n38\t      <Box flexDirection=\"column\" paddingLeft={1}>\n39\t        <CompletedTools tools={state.completedTools} />\n40\t        {state.activeTool && <ActiveTool name={state.activeTool.name} driverName={state.activeDriverName} />}\n41\t        {state.lastThought && <LastThought text={state.lastThought} />}\n42\t        {state.retryInfo && <RetryNotice info={state.retryInfo} />}\n43\t      </Box>\n44\t    </Box>\n45\t  );\n46\t}\n47\t"}]},"parent_tool_use_id":"toolu_01Tp1EiHuLRgwUdvr7VPq3jn","session_id":"0c112080-0896-4e32-96a0-f82adec16922","uuid":"aa8992d5-35b4-4970-a88d-9d7caaf8998d","timestamp":"2026-04-04T02:33:39.338Z"}
