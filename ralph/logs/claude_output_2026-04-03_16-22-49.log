{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012bkUBkiktfzEtbS6XNt1fP","type":"tool_result","content":"240\t * Handles: trace ID generation, session resolution, source isolation,\n241\t * agent dispatch, state checkpointing, and cleanup.\n242\t *\n243\t * Returns the updated workflow state after recording the dispatch.\n244\t */\n245\texport async function dispatchTask(\n246\t  task: ResolvedTask,\n247\t  taskName: string,\n248\t  storyKey: string,\n249\t  definition: SubagentDefinition,\n250\t  state: WorkflowState,\n251\t  config: EngineConfig,\n252\t  customPrompt?: string,\n253\t  previousOutputContract?: OutputContract,\n254\t): Promise<WorkflowState> {\n255\t  const { updatedState } = await dispatchTaskWithResult(\n256\t    task, taskName, storyKey, definition, state, config, customPrompt, previousOutputContract,\n257\t  );\n258\t  return updatedState;\n259\t}\n260\t\n261\t/** Tool names that indicate file write/edit operations across different drivers. */\n262\tconst FILE_WRITE_TOOL_NAMES = new Set([\n263\t  'Write', 'Edit', 'write_to_file', 'edit_file',\n264\t  'write', 'edit', 'WriteFile', 'EditFile',\n265\t]);\n266\t\n267\t// --- Flow Step Type Guard ---\n268\t\n269\tfunction isLoopBlock(step: FlowStep): step is LoopBlock {\n270\t  return typeof step === 'object' && step !== null && 'loop' in step;\n271\t}\n272\t\n273\t// --- Core Dispatch (shared by dispatchTask and loop block execution) ---\n274\t\n275\t/**\n276\t * Dispatch a task and return both the updated state and the raw dispatch output.\n277\t * This is the single implementation of task dispatch logic. Both `dispatchTask()`\n278\t * and loop block execution delegate here.\n279\t */\n280\tasync function dispatchTaskWithResult(\n281\t  task: ResolvedTask,\n282\t  taskName: string,\n283\t  storyKey: string,\n284\t  definition: SubagentDefinition,\n285\t  state: WorkflowState,\n286\t  config: EngineConfig,\n287\t  customPrompt?: string,\n288\t  previousOutputContract?: OutputContract,\n289\t): Promise<{ updatedState: WorkflowState; output: string; contract: OutputContract | null }> {"}]},"parent_tool_use_id":"toolu_01PJ1ZaMtGAYgkx9N7rYqNxX","session_id":"49777568-67d3-419d-b985-1c272283fc99","uuid":"237c63a5-2afa-4615-be85-3d64f179571d","timestamp":"2026-04-03T12:29:39.250Z"}
