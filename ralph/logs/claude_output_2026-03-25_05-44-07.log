xpect(base.receivers.otlp.protocols.http.cors).toBeUndefined();\n   205→    expect(cors.receivers.otlp.protocols.http.cors).toBeDefined();\n   206→  });\n   207→\n   208→  it('inherits resource/default processor from base template', () => {\n   209→    const result = otelCollectorConfigWithCors();\n   210→    const parsed = parse(result) as { processors: Record<string, unknown>; service: { pipelines: Record<string, { processors?: string[] }> } };\n   211→    expect(parsed.processors['resource/default']).toBeDefined();\n   212→    expect(parsed.service.pipelines.logs.processors).toContain('resource/default');\n   213→    expect(parsed.service.pipelines.metrics.processors).toContain('resource/default');\n   214→    expect(parsed.service.pipelines.traces.processors).toContain('resource/default');\n   215→  });\n   216→});\n   217→\n   218→// ─── Resource/default processor tests ────────────────────────────────────────\n   219→\n   220→describe('resource/default processor in base template', () => {\n   221→  it('includes resource/default processor section', () => {\n   222→    const result = otelCollectorConfigTemplate();\n   223→    const parsed = parse(result) as { processors: Record<string, unknown> };\n   224→    expect(parsed.processors).toBeDefined();\n   225→    expect(parsed.processors['resource/default']).toBeDefined();\n   226→  });\n   227→\n   228→  it('processor sets service.name to unknown with insert action (only when absent)', () => {\n   229→    const result = otelCollectorConfigTemplate();\n   230→    const parsed = parse(result) as { processors: { 'resource/default': { attributes: Array<{ key: string; value: string; action: string }> } } };\n   231→    const attrs = parsed.processors['resource/default'].attributes;\n   232→    expect(attrs).toHaveLength(1);\n   233→    expect(attrs[0].key).toBe('service.name');\n   234→    expect(attrs[0].value).toBe('unknown');\n   235→    expect(attrs[0].action).toBe('insert');\n   236→  });\n   237→\n   238→  it('l