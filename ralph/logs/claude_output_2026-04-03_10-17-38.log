{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011CWpHdPPk4MoCNT2fRTXZR","type":"tool_result","content":"1\t/**\n2\t * Stream Event Parser — converts Claude stream-json NDJSON lines into typed events.\n3\t *\n4\t * Stateless per-line: accepts one NDJSON line, returns one typed event or null.\n5\t * Accumulation (e.g., building full tool input from deltas) is the caller's responsibility.\n6\t *\n7\t * Event format reference:\n8\t * - Wrapper type \"stream_event\" contains API events (content_block_start, etc.)\n9\t * - Wrapper type \"system\" contains Claude Code events (api_retry, etc.)\n10\t * - Wrapper type \"result\" is the final event with session_id, cost, result text\n11\t */\n12\t\n13\t// --- Event Types ---\n14\t\n15\texport interface ToolStartEvent {\n16\t  readonly type: 'tool-start';\n17\t  readonly name: string;\n18\t  readonly id: string;\n19\t}\n20\t\n21\texport interface ToolInputEvent {\n22\t  readonly type: 'tool-input';\n23\t  readonly partial: string;\n24\t}\n25\t\n26\texport interface ToolCompleteEvent {\n27\t  readonly type: 'tool-complete';\n28\t}\n29\t\n30\texport interface TextEvent {\n31\t  readonly type: 'text';\n32\t  readonly text: string;\n33\t}\n34\t\n35\texport interface RetryEvent {\n36\t  readonly type: 'retry';\n37\t  readonly attempt: number;\n38\t  readonly delay: number;\n39\t}\n40\t\n41\texport interface ResultEvent {\n42\t  readonly type: 'result';\n43\t  readonly cost: number;\n44\t  readonly sessionId: string;\n45\t}\n46\t\n47\t/** Discriminated union of all stream events the parser can emit. */\n48\texport type StreamEvent =\n49\t  | ToolStartEvent\n50\t  | ToolInputEvent\n51\t  | ToolCompleteEvent\n52\t  | TextEvent\n53\t  | RetryEvent\n54\t  | ResultEvent;\n55\t\n56\t// --- Parser ---\n57\t\n58\t/**\n59\t * Parse a single NDJSON line from Claude's stream-json output.\n60\t *\n61\t * Returns a typed StreamEvent for recognized events, or null for:\n62\t * - Invalid JSON\n63\t * - Empty/whitespace lines\n64\t * - Unrecognized or irrelevant event types (message_start, message_stop, etc.)\n65\t */\n66\texport function parseStreamLine(line: string): StreamEvent | null {\n67\t  const trimmed = line.trim();\n68\t  if (trimmed.length === 0) {\n69\t    return null;\n70\t  }\n71\t\n72\t  let parsed: Record<string, unknown>;\n73\t  try {\n74\t    parsed = JSON.parse(trimmed) as Record<string, unknown>;\n75\t  } catch {\n76\t    // IGNORE: malformed JSON in stream output, skip line\n77\t    return null;\n78\t  }\n79\t\n80\t  if (typeof parsed !== 'object' || parsed === null || Array.isArray(parsed)) {\n81\t    return null;\n82\t  }\n83\t\n84\t  const wrapperType = parsed.type;\n85\t\n86\t  if (wrapperType === 'stream_event') {\n87\t    return parseStreamEvent(parsed);\n88\t  }\n89\t\n90\t  if (wrapperType === 'system') {\n91\t    return parseSystemEvent(parsed);\n92\t  }\n93\t\n94\t  if (wrapperType === 'result') {\n95\t    return parseResultEvent(parsed);\n96\t  }\n97\t\n98\t  return null;\n99\t}\n100\t\n101\t// --- Internal Parsers ---\n102\t\n103\tfunction parseStreamEvent(parsed: Record<string, unknown>): StreamEvent | null {\n104\t  const event = parsed.event as Record<string, unknown> | undefined;\n105\t  if (!event || typeof event !== 'object') {\n106\t    return null;\n107\t  }\n108\t\n109\t  const eventType = event.type as string | undefined;\n110\t\n111\t  if (eventType === 'content_block_start') {\n112\t    return parseContentBlockStart(event);\n113\t  }\n114\t\n115\t  if (eventType === 'content_block_delta') {\n116\t    return parseContentBlockDelta(event);\n117\t  }\n118\t\n119\t  if (eventType === 'content_block_stop') {\n120\t    // NOTE: content_block_stop fires for both tool_use and text blocks.\n121\t    // The parser is stateless and cannot distinguish them. The consumer\n122\t    // (renderer) must track whether the preceding block was a tool_use.\n123\t    return { type: 'tool-complete' };\n124\t  }\n125\t\n126\t  // message_start, message_stop, message_delta — skip\n127\t  return null;\n128\t}\n129\t\n130\tfunction parseContentBlockStart(event: Record<string, unknown>): StreamEvent | null {\n131\t  const contentBlock = event.content_block as Record<string, unknown> | undefined;\n132\t  if (!contentBlock || typeof contentBlock !== 'object') {\n133\t    return null;\n134\t  }\n135\t\n136\t  if (contentBlock.type === 'tool_use') {\n137\t    const name = contentBlock.name;\n138\t    const id = contentBlock.id;\n139\t    if (typeof name === 'string' && typeof id === 'string') {\n140\t      return { type: 'tool-start', name, id };\n141\t    }\n142\t  }\n143\t\n144\t  // content_block_start with type \"text\" — skip (the actual text comes via deltas)\n145\t  return null;\n146\t}\n147\t\n148\tfunction parseContentBlockDelta(event: Record<string, unknown>): StreamEvent | null {\n149\t  const delta = event.delta as Record<string, unknown> | undefined;\n150\t  if (!delta || typeof delta !== 'object') {\n151\t    return null;\n152\t  }\n153\t\n154\t  if (delta.type === 'input_json_delta') {\n155\t    const partialJson = delta.partial_json;\n156\t    if (typeof partialJson === 'string') {\n157\t      return { type: 'tool-input', partial: partialJson };\n158\t    }\n159\t    return null;\n160\t  }\n161\t\n162\t  if (delta.type === 'text_delta') {\n163\t    const text = delta.text;\n164\t    if (typeof text === 'string') {\n165\t      return { type: 'text', text };\n166\t    }\n167\t    return null;\n168\t  }\n169\t\n170\t  return null;\n171\t}\n172\t\n173\tfunction parseSystemEvent(parsed: Record<string, unknown>): StreamEvent | null {\n174\t  const subtype = parsed.subtype as string | undefined;\n175\t  if (subtype === 'api_retry') {\n176\t    const attempt = parsed.attempt;\n177\t    const delay = parsed.retry_delay_ms;\n178\t    if (typeof attempt === 'number' && typeof delay === 'number') {\n179\t      return { type: 'retry', attempt, delay };\n180\t    }\n181\t    return null;\n182\t  }\n183\t\n184\t  return null;\n185\t}\n186\t\n187\tfunction parseResultEvent(parsed: Record<string, unknown>): StreamEvent | null {\n188\t  const costUsd = parsed.cost_usd;\n189\t  const sessionId = parsed.session_id;\n190\t  if (typeof costUsd === 'number' && typeof sessionId === 'string') {\n191\t    return { type: 'result', cost: costUsd, sessionId };\n192\t  }\n193\t  return null;\n194\t}\n195\t"}]},"parent_tool_use_id":"toolu_01XS4sVgQGUVdaHQcMbvghrp","session_id":"e499f49a-fe4c-4b28-bb21-4e83348f2671","uuid":"f29babf8-f714-40ba-9444-707321f9c57b","timestamp":"2026-04-03T06:19:15.286Z"}
