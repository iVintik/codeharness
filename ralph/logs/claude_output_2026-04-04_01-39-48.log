{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Jgu7pDJjgeSSAXRxzXvwYR","type":"tool_result","content":"1\t/**\n2\t * Merge Agent — conflict resolution via driver dispatch with retry loop.\n3\t *\n4\t * Receives a MergeConflictContext with conflicting files, epic descriptions,\n5\t * and an AgentDriver instance. Dispatches the driver to resolve conflicts,\n6\t * validates with the test suite, and retries up to 3 times before escalating.\n7\t *\n8\t * @see Story 18-2: Merge Agent for Conflict Resolution\n9\t */\n10\t\n11\timport { execSync } from 'node:child_process';\n12\timport { readFileSync } from 'node:fs';\n13\timport { join } from 'node:path';\n14\timport { exec } from 'node:child_process';\n15\timport { promisify } from 'node:util';\n16\t\n17\timport type { AgentDriver } from './agents/types.js';\n18\t\n19\tconst execAsync = promisify(exec);\n20\t\n21\t// --- Interfaces ---\n22\t\n23\t/**\n24\t * Context provided to the merge agent for conflict resolution.\n25\t */\n26\texport interface MergeConflictContext {\n27\t  /** Epic identifier. */\n28\t  readonly epicId: string;\n29\t  /** Branch being merged. */\n30\t  readonly branch: string;\n31\t  /** List of conflicting file paths (relative to cwd). */\n32\t  readonly conflicts: string[];\n33\t  /** Description of what the main branch contains. */\n34\t  readonly mainDescription: string;\n35\t  /** Description of what the feature branch was building. */\n36\t  readonly branchDescription: string;\n37\t  /** Working directory (main repo root where merge is in progress). */\n38\t  readonly cwd: string;\n39\t  /** Command to run for test validation. */\n40\t  readonly testCommand: string;\n41\t  /** Driver instance to dispatch for conflict resolution. */\n42\t  readonly driver: AgentDriver;\n43\t}\n44\t\n45\t/**\n46\t * Result of a conflict resolution attempt.\n47\t */\n48\texport interface ConflictResolutionResult {\n49\t  /** Whether all conflicts were resolved and tests pass. */\n50\t  resolved: boolean;\n51\t  /** Number of resolution attempts made. */\n52\t  attempts: number;\n53\t  /** Whether the conflict was escalated for manual resolution. */\n54\t  escalated: boolean;\n55\t  /** Human-readable escalation message with details for manual resolution. */\n56\t  escalationMessage?: string;\n57\t  /** Test suite results from the last successful validation. */\n58\t  testResults?: { passed: number; failed: number; coverage?: number };\n59\t  /** List of files that were resolved. */\n60\t  resolvedFiles?: string[];\n61\t}\n62\t\n63\t// --- Constants ---\n64\t\n65\tconst MAX_ATTEMPTS = 3;\n66\t\n67\t// --- Prompt Construction ---\n68\t\n69\t/**\n70\t * Build the conflict resolution prompt for the driver.\n71\t *\n72\t * Includes file paths with full conflict-marker content, descriptions\n73\t * of both branches, and instructions to resolve preserving both changes.\n74\t */\n75\texport function buildConflictPrompt(ctx: MergeConflictContext, testFailure?: string): string {\n76\t  const conflictSections = ctx.conflicts.map((file) => {\n77\t    try {\n78\t      const content = readFileSync(join(ctx.cwd, file), 'utf-8');\n79\t      return `### ${file}\\n\\`\\`\\`\\n${content}\\n\\`\\`\\``;\n80\t    } catch { // IGNORE: file may be deleted on one side or unreadable — degrade gracefully in prompt\n81\t      return `### ${file}\\n*(File deleted on one side or unreadable)*`;\n82\t    }\n83\t  }).join('\\n\\n');\n84\t\n85\t  let prompt = `Merge conflict in ${ctx.conflicts.length} file(s) between main and ${ctx.branch}.\\n\\n`;\n86\t  prompt += `**Main branch context:** ${ctx.mainDescription}\\n`;\n87\t  prompt += `**Feature branch context:** ${ctx.branchDescription}\\n\\n`;\n88\t  prompt += `**Conflicting files:**\\n\\n${conflictSections}\\n\\n`;\n89\t  prompt += `Resolve ALL conflicts preserving changes from both branches. Both are correct additions.\\n`;\n90\t  prompt += `Write the resolved content to each file, stage with \\`git add\\`, and commit the merge resolution.\\n`;\n91\t\n92\t  if (testFailure) {\n93\t    prompt += `\\n**Previous attempt failed tests:**\\n\\`\\`\\`\\n${testFailure}\\n\\`\\`\\`\\n`;\n94\t    prompt += `Fix the resolution to make all tests pass.\\n`;\n95\t  }\n96\t  return prompt;\n97\t}\n98\t\n99\t// --- Escalation ---\n100\t\n101\t/**\n102\t * Build an escalation message with details for manual resolution.\n103\t */\n104\tfunction buildEscalationMessage(ctx: MergeConflictContext): string {\n105\t  const fileList = ctx.conflicts.map((f) => `  - ${f}`).join('\\n');\n106\t  return [\n107\t    `Merge conflict could not be auto-resolved after ${MAX_ATTEMPTS} attempts.`,\n108\t    ``,\n109\t    `Worktree: ${ctx.cwd}`,\n110\t    `Branch: ${ctx.branch}`,\n111\t    `Epic: ${ctx.epicId}`,\n112\t    ``,\n113\t    `Conflicting files:`,\n114\t    fileList,\n115\t    ``,\n116\t    `To inspect the diff:`,\n117\t    `  git diff ${ctx.branch}`,\n118\t  ].join('\\n');\n119\t}\n120\t\n121\t// --- Test Suite Runner ---\n122\t\n123\t/**\n124\t * Run the test suite and parse results.\n125\t * Returns pass/fail counts, coverage, and raw output for retry context.\n126\t */\n127\tasync function runTestSuite(\n128\t  testCommand: string,\n129\t  cwd: string,\n130\t): Promise<{ passed: number; failed: number; coverage?: number; output: string }> {\n131\t  try {\n132\t    const { stdout } = await execAsync(testCommand, {\n133\t      cwd,\n134\t      timeout: 300_000,\n135\t    });\n136\t    return { ...parseTestOutput(stdout), output: stdout };\n137\t  } catch (err: unknown) {\n138\t    const stdout = (err as { stdout?: string })?.stdout ?? '';\n139\t    const result = parseTestOutput(stdout);\n140\t    if (result.passed === 0 && result.failed === 0) {\n141\t      return { passed: 0, failed: 1, output: stdout || 'Test command failed with no output' };\n142\t    }\n143\t    return { ...result, output: stdout };\n144\t  }\n145\t}\n146\t\n147\t/**\n148\t * Parse test output to extract pass/fail counts and optional coverage.\n149\t */\n150\tfunction parseTestOutput(stdout: string): { passed: number; failed: number; coverage?: number } {\n151\t  let passed = 0;\n152\t  let failed = 0;\n153\t  let coverage: number | undefined;\n154\t\n155\t  const passMatch = stdout.match(/(\\d+)\\s+passed/);\n156\t  const failMatch = stdout.match(/(\\d+)\\s+failed/);\n157\t  if (passMatch) passed = parseInt(passMatch[1], 10);\n158\t  if (failMatch) failed = parseInt(failMatch[1], 10);\n159\t\n160\t  const covMatch = stdout.match(/All files[^|]*\\|\\s*([\\d.]+)/);\n161\t  if (covMatch) coverage = parseFloat(covMatch[1]);\n162\t\n163\t  return { passed, failed, ...(coverage !== undefined && { coverage }) };\n164\t}\n165\t\n166\t// --- Main Entry Point ---\n167\t\n168\t/**\n169\t * Resolve merge conflicts using an agent driver with retry loop.\n170\t *\n171\t * Dispatches the driver with conflict context, validates with the test suite,\n172\t * and retries up to 3 times. After 3 failures, escalates for manual resolution.\n173\t *\n174\t * @param ctx  Merge conflict context with files, descriptions, and driver.\n175\t * @returns Resolution result indicating success, failure, or escalation.\n176\t */\n177\texport async function resolveConflicts(ctx: MergeConflictContext): Promise<ConflictResolutionResult> {\n178\t  // Guard: empty conflict list\n179\t  if (ctx.conflicts.length === 0) {\n180\t    return { resolved: true, attempts: 0, escalated: false };\n181\t  }\n182\t\n183\t  let lastTestFailure: string | undefined;\n184\t\n185\t  for (let attempt = 1; attempt <= MAX_ATTEMPTS; attempt++) {\n186\t    const prompt = buildConflictPrompt(ctx, lastTestFailure);\n187\t\n188\t    // Dispatch driver — consume stream events to completion\n189\t    try {\n190\t      for await (const _event of ctx.driver.dispatch({\n191\t        prompt,\n192\t        model: ctx.driver.defaultModel,\n193\t        cwd: ctx.cwd,\n194\t        sourceAccess: true,\n195\t      })) {\n196\t        // Stream events consumed; merge agent doesn't need to display them\n197\t      }\n198\t    } catch { // IGNORE: driver dispatch failed (network error, rate limit) — treat as failed attempt\n199\t      // Treat as a failed attempt — try to revert and retry\n200\t      try {\n201\t        execSync('git reset --hard HEAD~1', { cwd: ctx.cwd, timeout: 30_000 });\n202\t      } catch { // IGNORE: git reset failed — escalate immediately on corrupted git state\n203\t        return {\n204\t          resolved: false,\n205\t          attempts: attempt,\n206\t          escalated: true,\n207\t          escalationMessage: buildEscalationMessage(ctx),\n208\t        };\n209\t      }\n210\t      lastTestFailure = 'Driver dispatch failed. Retrying with fresh attempt.';\n211\t      continue;\n212\t    }\n213\t\n214\t    // Run test suite\n215\t    const testResults = await runTestSuite(ctx.testCommand, ctx.cwd);\n216\t    if (testResults.failed === 0 && testResults.passed > 0) {\n217\t      return {\n218\t        resolved: true,\n219\t        attempts: attempt,\n220\t        escalated: false,\n221\t        testResults: {\n222\t          passed: testResults.passed,\n223\t          failed: testResults.failed,\n224\t          ...(testResults.coverage !== undefined && { coverage: testResults.coverage }),\n225\t        },\n226\t        resolvedFiles: ctx.conflicts,\n227\t      };\n228\t    }\n229\t\n230\t    // Tests failed — revert and retry\n231\t    lastTestFailure = testResults.output;\n232\t    try {\n233\t      execSync('git reset --hard HEAD~1', { cwd: ctx.cwd, timeout: 30_000 });\n234\t    } catch { // IGNORE: git reset failed after test failure — escalate on corrupted git state\n235\t      return {\n236\t        resolved: false,\n237\t        attempts: attempt,\n238\t        escalated: true,\n239\t        escalationMessage: buildEscalationMessage(ctx),\n240\t      };\n241\t    }\n242\t  }\n243\t\n244\t  // All attempts exhausted — escalate\n245\t  return {\n246\t    resolved: false,\n247\t    attempts: MAX_ATTEMPTS,\n248\t    escalated: true,\n249\t    escalationMessage: buildEscalationMessage(ctx),\n250\t  };\n251\t}\n252\t"}]},"parent_tool_use_id":"toolu_01AAzy1mX2TCPZLWwiowxFDb","session_id":"74f4684f-cc80-4828-8405-943cba326449","uuid":"ed0981ba-0639-4ad0-ad93-a729d7c56c82","timestamp":"2026-04-03T21:58:22.821Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012NRefMh899vY4ZifACzvjV","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, type Mock } from 'vitest';\n2\timport type { AgentDriver, DispatchOpts, DriverCapabilities, DriverHealth } from '../agents/types.js';\n3\timport type { StreamEvent } from '../agents/stream-parser.js';\n4\t\n5\t// Create controllable mocks — must use vi.hoisted so they're available in vi.mock factories\n6\tconst { mockReadFileSync, mockExecSync, mockExecAsync } = vi.hoisted(() => ({\n7\t  mockReadFileSync: vi.fn(),\n8\t  mockExecSync: vi.fn(),\n9\t  mockExecAsync: vi.fn(),\n10\t}));\n11\t\n12\t// Mock node:fs\n13\tvi.mock('node:fs', () => ({\n14\t  readFileSync: mockReadFileSync,\n15\t}));\n16\t\n17\t// Mock node:child_process\n18\tvi.mock('node:child_process', () => ({\n19\t  execSync: mockExecSync,\n20\t  exec: vi.fn(),\n21\t}));\n22\t\n23\t// Mock node:util to return our controllable mockExecAsync\n24\tvi.mock('node:util', () => ({\n25\t  promisify: () => mockExecAsync,\n26\t}));\n27\t\n28\timport {\n29\t  resolveConflicts,\n30\t  buildConflictPrompt,\n31\t  type MergeConflictContext,\n32\t  type ConflictResolutionResult,\n33\t} from '../merge-agent.js';\n34\t\n35\t// --- Test Helpers ---\n36\t\n37\tfunction createMockDriver(overrides?: {\n38\t  dispatchFn?: (opts: DispatchOpts) => AsyncIterable<StreamEvent>;\n39\t}): AgentDriver {\n40\t  const defaultDispatch = async function* (_opts: DispatchOpts): AsyncIterable<StreamEvent> {\n41\t    // Yield nothing — simulates silent resolution\n42\t  };\n43\t\n44\t  return {\n45\t    name: 'mock-driver',\n46\t    defaultModel: 'mock-model',\n47\t    capabilities: {\n48\t      supportsPlugins: false,\n49\t      supportsStreaming: true,\n50\t      costReporting: false,\n51\t      costTier: 1,\n52\t    },\n53\t    healthCheck: vi.fn().mockResolvedValue({\n54\t      available: true,\n55\t      authenticated: true,\n56\t      version: '1.0.0',\n57\t    }),\n58\t    dispatch: overrides?.dispatchFn ?? defaultDispatch,\n59\t    getLastCost: vi.fn().mockReturnValue(null),\n60\t  };\n61\t}\n62\t\n63\tfunction createContext(overrides?: Partial<MergeConflictContext>): MergeConflictContext {\n64\t  return {\n65\t    epicId: '18',\n66\t    branch: 'codeharness/epic-18-feature',\n67\t    conflicts: ['src/index.ts', 'src/utils.ts'],\n68\t    mainDescription: 'Main branch has the base implementation',\n69\t    branchDescription: 'Feature branch adds conflict resolution',\n70\t    cwd: '/repo',\n71\t    testCommand: 'npm test',\n72\t    driver: createMockDriver(),\n73\t    ...overrides,\n74\t  };\n75\t}\n76\t\n77\tdescribe('merge-agent', () => {\n78\t  beforeEach(() => {\n79\t    vi.clearAllMocks();\n80\t  });\n81\t\n82\t  describe('MergeConflictContext interface shape (AC #9)', () => {\n83\t    it('has all required fields', () => {\n84\t      const ctx = createContext();\n85\t      expect(ctx).toHaveProperty('epicId');\n86\t      expect(ctx).toHaveProperty('branch');\n87\t      expect(ctx).toHaveProperty('conflicts');\n88\t      expect(ctx).toHaveProperty('mainDescription');\n89\t      expect(ctx).toHaveProperty('branchDescription');\n90\t      expect(ctx).toHaveProperty('cwd');\n91\t      expect(ctx).toHaveProperty('testCommand');\n92\t      expect(ctx).toHaveProperty('driver');\n93\t    });\n94\t  });\n95\t\n96\t  describe('ConflictResolutionResult interface shape (AC #7)', () => {\n97\t    it('success result has correct shape', () => {\n98\t      const result: ConflictResolutionResult = {\n99\t        resolved: true,\n100\t        attempts: 1,\n101\t        escalated: false,\n102\t        testResults: { passed: 10, failed: 0, coverage: 95 },\n103\t        resolvedFiles: ['src/index.ts'],\n104\t      };\n105\t      expect(result.resolved).toBe(true);\n106\t      expect(result.attempts).toBe(1);\n107\t      expect(result.escalated).toBe(false);\n108\t      expect(result.testResults).toEqual({ passed: 10, failed: 0, coverage: 95 });\n109\t      expect(result.resolvedFiles).toEqual(['src/index.ts']);\n110\t    });\n111\t\n112\t    it('escalated result has correct shape', () => {\n113\t      const result: ConflictResolutionResult = {\n114\t        resolved: false,\n115\t        attempts: 3,\n116\t        escalated: true,\n117\t        escalationMessage: 'Could not resolve after 3 attempts',\n118\t      };\n119\t      expect(result.resolved).toBe(false);\n120\t      expect(result.escalated).toBe(true);\n121\t      expect(result.escalationMessage).toBeDefined();\n122\t      expect(result.testResults).toBeUndefined();\n123\t      expect(result.resolvedFiles).toBeUndefined();\n124\t    });\n125\t  });\n126\t\n127\t  describe('buildConflictPrompt (AC #2, #8)', () => {\n128\t    it('includes conflict markers from files', () => {\n129\t      mockReadFileSync.mockImplementation((path: string) => {\n130\t        if (path.includes('index.ts')) return '<<<<<<< main\\nold code\\n=======\\nnew code\\n>>>>>>> branch';\n131\t        if (path.includes('utils.ts')) return '<<<<<<< main\\nutil old\\n=======\\nutil new\\n>>>>>>> branch';\n132\t        return '';\n133\t      });\n134\t\n135\t      const ctx = createContext();\n136\t      const prompt = buildConflictPrompt(ctx);\n137\t\n138\t      expect(prompt).toContain('src/index.ts');\n139\t      expect(prompt).toContain('src/utils.ts');\n140\t      expect(prompt).toContain('<<<<<<< main');\n141\t      expect(prompt).toContain('>>>>>>> branch');\n142\t    });\n143\t\n144\t    it('includes main and branch descriptions (AC #8)', () => {\n145\t      mockReadFileSync.mockReturnValue('conflict content');\n146\t\n147\t      const ctx = createContext({\n148\t        mainDescription: 'Main has base implementation',\n149\t        branchDescription: 'Branch adds conflict resolver',\n150\t      });\n151\t      const prompt = buildConflictPrompt(ctx);\n152\t\n153\t      expect(prompt).toContain('**Main branch context:** Main has base implementation');\n154\t      expect(prompt).toContain('**Feature branch context:** Branch adds conflict resolver');\n155\t    });\n156\t\n157\t    it('includes instructions to resolve and commit (AC #8)', () => {\n158\t      mockReadFileSync.mockReturnValue('conflict content');\n159\t\n160\t      const ctx = createContext();\n161\t      const prompt = buildConflictPrompt(ctx);\n162\t\n163\t      expect(prompt).toContain('Resolve ALL conflicts preserving changes from both branches');\n164\t      expect(prompt).toContain('Both are correct additions');\n165\t      expect(prompt).toContain('git add');\n166\t      expect(prompt).toContain('commit the merge resolution');\n167\t    });\n168\t\n169\t    it('handles unreadable files gracefully', () => {\n170\t      mockReadFileSync.mockImplementation(() => {\n171\t        throw new Error('ENOENT: no such file');\n172\t      });\n173\t\n174\t      const ctx = createContext();\n175\t      const prompt = buildConflictPrompt(ctx);\n176\t\n177\t      expect(prompt).toContain('deleted on one side or unreadable');\n178\t    });\n179\t\n180\t    it('includes test failure output on retry (AC #5)', () => {\n181\t      mockReadFileSync.mockReturnValue('conflict content');\n182\t\n183\t      const ctx = createContext();\n184\t      const prompt = buildConflictPrompt(ctx, 'FAIL src/index.test.ts\\n  TypeError: undefined is not a function');\n185\t\n186\t      expect(prompt).toContain('**Previous attempt failed tests:**');\n187\t      expect(prompt).toContain('TypeError: undefined is not a function');\n188\t      expect(prompt).toContain('Fix the resolution to make all tests pass');\n189\t    });\n190\t\n191\t    it('includes file count in prompt', () => {\n192\t      mockReadFileSync.mockReturnValue('content');\n193\t\n194\t      const ctx = createContext({ conflicts: ['a.ts', 'b.ts', 'c.ts'] });\n195\t      const prompt = buildConflictPrompt(ctx);\n196\t\n197\t      expect(prompt).toContain('Merge conflict in 3 file(s)');\n198\t    });\n199\t  });\n200\t\n201\t  describe('resolveConflicts — exports (AC #1)', () => {\n202\t    it('exports resolveConflicts function', () => {\n203\t      expect(typeof resolveConflicts).toBe('function');\n204\t    });\n205\t  });\n206\t\n207\t  describe('resolveConflicts — empty conflicts guard', () => {\n208\t    it('returns resolved immediately for empty conflict list', async () => {\n209\t      const ctx = createContext({ conflicts: [] });\n210\t      const result = await resolveConflicts(ctx);\n211\t\n212\t      expect(result.resolved).toBe(true);\n213\t      expect(result.attempts).toBe(0);\n214\t      expect(result.escalated).toBe(false);\n215\t    });\n216\t  });\n217\t\n218\t  describe('resolveConflicts — successful resolution (AC #3, #4)', () => {\n219\t    it('returns resolved on first attempt when tests pass', async () => {\n220\t      mockReadFileSync.mockReturnValue('conflict content');\n221\t      mockExecAsync.mockResolvedValue({ stdout: '10 passed\\n0 failed' });\n222\t\n223\t      const dispatchCalls: DispatchOpts[] = [];\n224\t      const driver = createMockDriver({\n225\t        dispatchFn: async function* (opts: DispatchOpts) {\n226\t          dispatchCalls.push(opts);\n227\t        },\n228\t      });\n229\t\n230\t      const ctx = createContext({ driver });\n231\t      const result = await resolveConflicts(ctx);\n232\t\n233\t      expect(result.resolved).toBe(true);\n234\t      expect(result.attempts).toBe(1);\n235\t      expect(result.escalated).toBe(false);\n236\t      expect(result.testResults).toEqual({ passed: 10, failed: 0 });\n237\t      expect(result.resolvedFiles).toEqual(['src/index.ts', 'src/utils.ts']);\n238\t      expect(dispatchCalls).toHaveLength(1);\n239\t    });\n240\t\n241\t    it('dispatches driver with correct prompt containing conflict markers (AC #2, #8)', async () => {\n242\t      mockReadFileSync.mockReturnValue('<<<<<<< main\\nold\\n=======\\nnew\\n>>>>>>> branch');\n243\t      mockExecAsync.mockResolvedValue({ stdout: '5 passed' });\n244\t\n245\t      const dispatchCalls: DispatchOpts[] = [];\n246\t      const driver = createMockDriver({\n247\t        dispatchFn: async function* (opts: DispatchOpts) {\n248\t          dispatchCalls.push(opts);\n249\t        },\n250\t      });\n251\t\n252\t      const ctx = createContext({ driver });\n253\t      await resolveConflicts(ctx);\n254\t\n255\t      expect(dispatchCalls).toHaveLength(1);\n256\t      expect(dispatchCalls[0].prompt).toContain('<<<<<<< main');\n257\t      expect(dispatchCalls[0].prompt).toContain('>>>>>>> branch');\n258\t      expect(dispatchCalls[0].prompt).toContain('Main branch context:');\n259\t      expect(dispatchCalls[0].prompt).toContain('Feature branch context:');\n260\t      expect(dispatchCalls[0].cwd).toBe('/repo');\n261\t      expect(dispatchCalls[0].sourceAccess).toBe(true);\n262\t    });\n263\t\n264\t    it('includes coverage in test results when available', async () => {\n265\t      mockReadFileSync.mockReturnValue('conflict');\n266\t      mockExecAsync.mockResolvedValue({ stdout: '10 passed\\nAll files | 95.5' });\n267\t\n268\t      const ctx = createContext();\n269\t      const result = await resolveConflicts(ctx);\n270\t\n271\t      expect(result.resolved).toBe(true);\n272\t      expect(result.testResults?.coverage).toBe(95.5);\n273\t    });\n274\t  });\n275\t\n276\t  describe('resolveConflicts — retry on test failure (AC #5)', () => {\n277\t    it('retries up to 3 times with test failure context', async () => {\n278\t      mockReadFileSync.mockReturnValue('conflict content');\n279\t\n280\t      let callCount = 0;\n281\t      mockExecAsync.mockImplementation(async () => {\n282\t        callCount++;\n283\t        if (callCount < 3) {\n284\t          return { stdout: '5 passed\\n2 failed' };\n285\t        }\n286\t        return { stdout: '7 passed\\n0 failed' };\n287\t      });\n288\t\n289\t      const dispatchCalls: DispatchOpts[] = [];\n290\t      const driver = createMockDriver({\n291\t        dispatchFn: async function* (opts: DispatchOpts) {\n292\t          dispatchCalls.push(opts);\n293\t        },\n294\t      });\n295\t\n296\t      const ctx = createContext({ driver });\n297\t      const result = await resolveConflicts(ctx);\n298\t\n299\t      expect(result.resolved).toBe(true);\n300\t      expect(result.attempts).toBe(3);\n301\t      expect(dispatchCalls).toHaveLength(3);\n302\t\n303\t      // Verify git reset was called between attempts\n304\t      const resetCalls = mockExecSync.mock.calls.filter(\n305\t        (c: unknown[]) => (c[0] as string).includes('reset --hard HEAD~1'),\n306\t      );\n307\t      expect(resetCalls).toHaveLength(2);\n308\t    });\n309\t\n310\t    it('retry prompt includes previous test failure output', async () => {\n311\t      mockReadFileSync.mockReturnValue('conflict');\n312\t\n313\t      let callCount = 0;\n314\t      mockExecAsync.mockImplementation(async () => {\n315\t        callCount++;\n316\t        if (callCount === 1) {\n317\t          return { stdout: '3 passed\\n1 failed\\nFAIL: TypeError at line 42' };\n318\t        }\n319\t        return { stdout: '4 passed\\n0 failed' };\n320\t      });\n321\t\n322\t      const dispatchCalls: DispatchOpts[] = [];\n323\t      const driver = createMockDriver({\n324\t        dispatchFn: async function* (opts: DispatchOpts) {\n325\t          dispatchCalls.push(opts);\n326\t        },\n327\t      });\n328\t\n329\t      const ctx = createContext({ driver });\n330\t      await resolveConflicts(ctx);\n331\t\n332\t      expect(dispatchCalls).toHaveLength(2);\n333\t      // Second dispatch should include the failure output\n334\t      expect(dispatchCalls[1].prompt).toContain('Previous attempt failed tests');\n335\t      expect(dispatchCalls[1].prompt).toContain('TypeError at line 42');\n336\t    });\n337\t  });\n338\t\n339\t  describe('resolveConflicts — escalation after 3 failures (AC #6)', () => {\n340\t    it('returns escalated after 3 consecutive failures', async () => {\n341\t      mockReadFileSync.mockReturnValue('conflict');\n342\t      mockExecAsync.mockResolvedValue({ stdout: '3 passed\\n2 failed' });\n343\t\n344\t      const ctx = createContext();\n345\t      const result = await resolveConflicts(ctx);\n346\t\n347\t      expect(result.resolved).toBe(false);\n348\t      expect(result.attempts).toBe(3);\n349\t      expect(result.escalated).toBe(true);\n350\t      expect(result.escalationMessage).toBeDefined();\n351\t    });\n352\t\n353\t    it('escalation message contains worktree path, branch, files, and git diff command', async () => {\n354\t      mockReadFileSync.mockReturnValue('conflict');\n355\t      mockExecAsync.mockResolvedValue({ stdout: '0 passed\\n1 failed' });\n356\t\n357\t      const ctx = createContext({\n358\t        epicId: '42',\n359\t        branch: 'codeharness/epic-42-feature',\n360\t        conflicts: ['src/a.ts', 'src/b.ts'],\n361\t        cwd: '/repo',\n362\t      });\n363\t      const result = await resolveConflicts(ctx);\n364\t\n365\t      expect(result.escalationMessage).toContain('/repo');\n366\t      expect(result.escalationMessage).toContain('codeharness/epic-42-feature');\n367\t      expect(result.escalationMessage).toContain('src/a.ts');\n368\t      expect(result.escalationMessage).toContain('src/b.ts');\n369\t      expect(result.escalationMessage).toContain('git diff');\n370\t    });\n371\t  });\n372\t\n373\t  describe('resolveConflicts — unparseable test output', () => {\n374\t    it('treats zero-passed zero-failed as failure and retries', async () => {\n375\t      mockReadFileSync.mockReturnValue('conflict');\n376\t      mockExecSync.mockReturnValue('');\n377\t\n378\t      // First call: unparseable output (0 passed, 0 failed from parsing)\n379\t      // Second call: valid output\n380\t      let callCount = 0;\n381\t      mockExecAsync.mockImplementation(async () => {\n382\t        callCount++;\n383\t        if (callCount === 1) {\n384\t          return { stdout: 'Build completed successfully.' };\n385\t        }\n386\t        return { stdout: '5 passed\\n0 failed' };\n387\t      });\n388\t\n389\t      const ctx = createContext();\n390\t      const result = await resolveConflicts(ctx);\n391\t\n392\t      expect(result.resolved).toBe(true);\n393\t      expect(result.attempts).toBe(2);\n394\t    });\n395\t  });\n396\t\n397\t  describe('resolveConflicts — driver dispatch failure', () => {\n398\t    it('treats dispatch error as failed attempt and retries', async () => {\n399\t      mockReadFileSync.mockReturnValue('conflict');\n400\t\n401\t      let dispatchCallCount = 0;\n402\t      const driver = createMockDriver({\n403\t        dispatchFn: async function* (_opts: DispatchOpts) {\n404\t          dispatchCallCount++;\n405\t          if (dispatchCallCount === 1) {\n406\t            throw new Error('Network error');\n407\t          }\n408\t          // Second attempt succeeds\n409\t        },\n410\t      });\n411\t\n412\t      mockExecAsync.mockResolvedValue({ stdout: '5 passed\\n0 failed' });\n413\t\n414\t      const ctx = createContext({ driver });\n415\t      const result = await resolveConflicts(ctx);\n416\t\n417\t      expect(result.resolved).toBe(true);\n418\t      expect(result.attempts).toBe(2);\n419\t    });\n420\t\n421\t    it('escalates after 3 consecutive dispatch failures', async () => {\n422\t      mockReadFileSync.mockReturnValue('conflict');\n423\t      mockExecSync.mockReturnValue(''); // git reset succeeds\n424\t\n425\t      const driver = createMockDriver({\n426\t        dispatchFn: async function* () {\n427\t          throw new Error('Network error');\n428\t        },\n429\t      });\n430\t\n431\t      const ctx = createContext({ driver });\n432\t      const result = await resolveConflicts(ctx);\n433\t\n434\t      expect(result.resolved).toBe(false);\n435\t      expect(result.attempts).toBe(3);\n436\t      expect(result.escalated).toBe(true);\n437\t      expect(result.escalationMessage).toBeDefined();\n438\t    });\n439\t\n440\t    it('escalates immediately if git reset fails after dispatch error', async () => {\n441\t      mockReadFileSync.mockReturnValue('conflict');\n442\t      mockExecSync.mockImplementation(() => {\n443\t        throw new Error('git state corrupted');\n444\t      });\n445\t\n446\t      const driver = createMockDriver({\n447\t        dispatchFn: async function* () {\n448\t          throw new Error('Network error');\n449\t        },\n450\t      });\n451\t\n452\t      const ctx = createContext({ driver });\n453\t      const result = await resolveConflicts(ctx);\n454\t\n455\t      expect(result.resolved).toBe(false);\n456\t      expect(result.escalated).toBe(true);\n457\t      expect(result.attempts).toBe(1);\n458\t    });\n459\t  });\n460\t\n461\t  describe('resolveConflicts — test command failure edge cases', () => {\n462\t    it('handles test command that throws with partial stdout', async () => {\n463\t      mockReadFileSync.mockReturnValue('conflict');\n464\t      // Allow git reset to succeed\n465\t      mockExecSync.mockReturnValue('');\n466\t\n467\t      // First call: test command throws with partial output containing pass/fail\n468\t      // Second call: tests pass\n469\t      let callCount = 0;\n470\t      mockExecAsync.mockImplementation(async () => {\n471\t        callCount++;\n472\t        if (callCount === 1) {\n473\t          const err = new Error('Command failed') as Error & { stdout: string };\n474\t          err.stdout = '3 passed\\n2 failed\\nError: some test error';\n475\t          throw err;\n476\t        }\n477\t        return { stdout: '5 passed\\n0 failed' };\n478\t      });\n479\t\n480\t      const ctx = createContext();\n481\t      const result = await resolveConflicts(ctx);\n482\t\n483\t      expect(result.resolved).toBe(true);\n484\t      expect(result.attempts).toBe(2);\n485\t    });\n486\t\n487\t    it('handles test command that throws with no output', async () => {\n488\t      mockReadFileSync.mockReturnValue('conflict');\n489\t      // Allow git reset to succeed\n490\t      mockExecSync.mockReturnValue('');\n491\t\n492\t      mockExecAsync.mockImplementation(async () => {\n493\t        const err = new Error('Command failed') as Error & { stdout: string };\n494\t        err.stdout = '';\n495\t        throw err;\n496\t      });\n497\t\n498\t      const ctx = createContext();\n499\t      const result = await resolveConflicts(ctx);\n500\t\n501\t      // Should exhaust retries and escalate\n502\t      expect(result.resolved).toBe(false);\n503\t      expect(result.attempts).toBe(3);\n504\t      expect(result.escalated).toBe(true);\n505\t    });\n506\t  });\n507\t\n508\t  describe('resolveConflicts — git reset failure during retry', () => {\n509\t    it('escalates immediately if git reset fails after test failure', async () => {\n510\t      mockReadFileSync.mockReturnValue('conflict');\n511\t      mockExecAsync.mockResolvedValue({ stdout: '2 passed\\n1 failed' });\n512\t      mockExecSync.mockImplementation(() => {\n513\t        throw new Error('git state corrupted');\n514\t      });\n515\t\n516\t      const ctx = createContext();\n517\t      const result = await resolveConflicts(ctx);\n518\t\n519\t      expect(result.resolved).toBe(false);\n520\t      expect(result.escalated).toBe(true);\n521\t      expect(result.escalationMessage).toContain('/repo');\n522\t    });\n523\t  });\n524\t});\n525\t"}]},"parent_tool_use_id":"toolu_01AAzy1mX2TCPZLWwiowxFDb","session_id":"74f4684f-cc80-4828-8405-943cba326449","uuid":"9431257e-2119-4959-b274-190e6dd615ab","timestamp":"2026-04-03T21:58:23.113Z"}
