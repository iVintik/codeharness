{
  "name": "codeharness",
  "version": "0.28.2",
  "type": "module",
  "description": "CLI for codeharness — makes autonomous coding agents produce software that actually works",
  "bin": {
    "codeharness": "dist/index.js"
  },
  "files": [
    "dist",
    "bin",
    "patches",
    "templates/Dockerfile.verify",
    "templates/Dockerfile.verify.rust",
    "templates/Dockerfile.verify.generic",
    "templates/dockerfiles/",
    "templates/compose/",
    "templates/prompts/",
    "templates/docs/",
    "templates/otlp/",
    "templates/workflows/",
    "templates/agents/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/iVintik/codeharness.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "bats tests/",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:sizes": "bash scripts/check-file-sizes.sh"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.90",
    "@inkjs/ui": "^2.0.0",
    "ajv": "^8.18.0",
    "commander": "^14.0.3",
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.1.0",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.0"
  }
}
