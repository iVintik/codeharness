{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01C7G3vnxfDifE5hYAAWZgeq","type":"tool_result","content":"1\t/**\n2\t * CLI command: codeharness validate\n3\t * Runs self-validation cycle and produces a release gate report.\n4\t * Story 10-3: Self-Validation Run\n5\t */\n6\timport { Command } from 'commander';\n7\timport { ok, fail, jsonOutput } from '../lib/output.js';\n8\timport {\n9\t  createValidationSprint, runValidationCycle,\n10\t  getValidationProgress, getACById,\n11\t} from '../modules/verify/index.js';\n12\timport type { ValidationProgress } from '../modules/verify/index.js';\n13\t\n14\texport function registerValidateCommand(program: Command): void {\n15\t  program\n16\t    .command('validate')\n17\t    .description('Run self-validation cycle and produce release gate report')\n18\t    .option('--ci', 'CI mode: minimal output, exit code 0 on pass / 1 on fail')\n19\t    .action((options: { ci?: boolean }, cmd: Command) => {\n20\t      const isJson = (cmd.optsWithGlobals() as { json?: boolean }).json === true;\n21\t      const isCi = options.ci === true;\n22\t      const initResult = createValidationSprint();\n23\t      if (!initResult.success) {\n24\t        reportError(initResult.error, isJson);\n25\t        return;\n26\t      }\n27\t      let cycles = 0;\n28\t      let cycle: ReturnType<typeof runValidationCycle>;\n29\t      do {\n30\t        cycle = runValidationCycle();\n31\t        if (!cycle.success) { reportError(cycle.error, isJson); return; }\n32\t        if (cycle.data.action !== 'no-actionable-ac') cycles++;\n33\t      } while (cycle.data.action !== 'no-actionable-ac');\n34\t      const progressResult = getValidationProgress();\n35\t      if (!progressResult.success) { reportError(progressResult.error, isJson); return; }\n36\t      const p = progressResult.data;\n37\t      const allPassed = p.failed === 0 && p.remaining === 0;\n38\t      if (isJson) outputJson(p, cycles, allPassed);\n39\t      else if (isCi) outputCi(p, allPassed);\n40\t      else outputHuman(p, cycles, allPassed);\n41\t      process.exitCode = allPassed ? 0 : 1;\n42\t    });\n43\t}\n44\t\n45\tfunction reportError(msg: string, isJson: boolean): void {\n46\t  if (isJson) jsonOutput({ status: 'fail', message: msg });\n47\t  else fail(msg);\n48\t  process.exitCode = 1;\n49\t}\n50\t\n51\tfunction getFailures(p: ValidationProgress) {\n52\t  return p.perAC\n53\t    .filter(a => a.status === 'failed' || a.status === 'blocked')\n54\t    .map(a => {\n55\t      const ac = getACById(a.acId);\n56\t      return {\n57\t        acId: a.acId, description: ac?.description ?? 'unknown',\n58\t        command: ac?.command, output: a.lastError ?? '',\n59\t        attempts: a.attempts,\n60\t        blocker: a.status === 'blocked' ? 'blocked' : 'failed',\n61\t      };\n62\t    });\n63\t}\n64\t\n65\tfunction outputJson(p: ValidationProgress, cycles: number, allPassed: boolean): void {\n66\t  jsonOutput({\n67\t    status: allPassed ? 'pass' : 'fail',\n68\t    total: p.total, passed: p.passed, failed: p.failed,\n69\t    blocked: p.blocked, remaining: p.remaining, cycles,\n70\t    gate: allPassed ? 'RELEASE GATE: PASS -- v1.0 ready' : 'RELEASE GATE: FAIL',\n71\t    failures: getFailures(p),\n72\t  });\n73\t}\n74\t\n75\tfunction outputCi(p: ValidationProgress, allPassed: boolean): void {\n76\t  if (allPassed) console.log('RELEASE GATE: PASS -- v1.0 ready');\n77\t  else console.log(`RELEASE GATE: FAIL (${p.passed}/${p.total} passed, ${p.failed} failed, ${p.blocked} blocked)`);\n78\t}\n79\t\n80\tfunction outputHuman(p: ValidationProgress, cycles: number, allPassed: boolean): void {\n81\t  console.log(`Total: ${p.total} | Passed: ${p.passed} | Failed: ${p.failed} | Blocked: ${p.blocked} | Cycles: ${cycles}`);\n82\t  if (allPassed) { ok('RELEASE GATE: PASS -- v1.0 ready'); return; }\n83\t  for (const f of getFailures(p)) {\n84\t    console.log(`  AC ${f.acId}: ${f.description}`);\n85\t    if (f.command) console.log(`    Command: ${f.command}`);\n86\t    if (f.output) console.log(`    Output: ${f.output}`);\n87\t    console.log(`    Attempts: ${f.attempts}`);\n88\t    console.log(`    Blocker: ${f.blocker}`);\n89\t  }\n90\t  fail('RELEASE GATE: FAIL');\n91\t}\n92\t"}]},"parent_tool_use_id":"toolu_019SoUcSY6ykbxKMMLbKRkDH","session_id":"5fca15c0-771e-463c-9e4f-c528b230e359","uuid":"d6aa969b-92a7-4387-80d6-673147c68553","timestamp":"2026-04-02T14:52:07.842Z"}
