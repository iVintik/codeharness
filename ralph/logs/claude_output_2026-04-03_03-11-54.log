0\t    cleanupContainersMock: vi.fn((): { success: boolean; data?: { containersRemoved: number; names: string[] }; error?: string } => ({ success: true, data: { containersRemoved: 0, names: [] } })),\n41\t    parseWorkflowMock: vi.fn(() => ({\n42\t      tasks: {\n43\t        implement: { agent: 'dev', scope: 'per-story', session: 'fresh', source_access: true },\n44\t      },\n45\t      flow: ['implement'],\n46\t    })),\n47\t    resolveAgentMock: vi.fn(() => ({\n48\t      name: 'dev',\n49\t      role: { title: 'Developer', purpose: 'Implement code' },\n50\t      persona: { identity: 'A developer', communication_style: 'direct', principles: [] },\n51\t    })),\n52\t    compileSubagentMock: vi.fn(() => ({\n53\t      name: 'dev',\n54\t      model: 'claude-sonnet-4-20250514',\n55\t      instructions: 'You are a developer',\n56\t      disallowedTools: [],\n57\t      bare: true,\n58\t    })),\n59\t    executeWorkflowMock: vi.fn(async () => ({\n60\t      success: true,\n61\t      tasksCompleted: 3,\n62\t      storiesProcessed: 1,\n63\t      errors: [],\n64\t      durationMs: 60000,\n65\t    })),\n66\t  };\n67\t});\n68\t\n69\tvi.mock('../../lib/agents/index.js', () => ({\n70\t  getDriver: (...args: unknown[]) => getDriverMock(...(args as Parameters<typeof getDriverMock>)),\n71\t}));\n72\t\n73\tvi.mock('node:fs', async (importOriginal) => {\n74\t  const actual = await importOriginal<typeof import('node:fs')>();\n75\t  return { ...actual, existsSync: existsSyncMock };\n76\t});\n77\t\n78\tvi.mock('../../lib/ink-renderer.js', () => ({\n79\t  startRenderer: (...args: unknown[]) => startRendererMock(...(args as Parameters<typeof startRendererMock>)),\n80\t}));\n81\t\n82\tvi.mock('../../modules/sprint/index.js', () => ({\n83\t  getSprintState: (...args: unknown[]) => getSprintStateMock(...(args as Parameters<typeof getSprintStateMock>)),\n84\t  readSprintStatusFromState: (...args: unknown[]) => readSprintStatusMock(...(args as Parameters<typeof readSprintStatusMock>)),\n85\t  reconcileState: (...args: unknown[]) => reconcileStateMock(...(args as Parameters<typeof reconcileStateMock>)),\n86\t  updateStoryStatus: vi.fn(() => ({ success: true, data: undefined })),\n87\t  shouldDeferPhase: vi.fn(() => false),\n88\t  getPhaseEstimate: vi.fn(() => 15),\n89\t  computeRemainingMinutes: vi.fn(() => 60),\n90\t}));\n91\t\n92\tvi.mock('../../lib/docker/index.js', () => ({\n93\t  isDockerAvailable: (...args: unknown[]) => isDockerAvailableMock(...(args as Parameters<typeof isDockerAvailableMock>)),\n94\t}));\n95\t\n96\tvi.mock('../../modules/infra/index.js', () => ({\n97\t  cleanupContainers: (...args: unknown[]) => cleanupContainersMock(...(args as Parameters<typeof cleanupContainersMock>)),\n98\t}));\n99\t\n100\tvi.mock('../../lib/workflow-parser.js', () => ({\n101\t  parseWorkflow: (...args: unknown[]) => parseWorkflowMock(...(args as Parameters<typeof parseWorkflowMock>)),\n102\t}));\n103\t\n104\tvi.mock('../../lib/agent-resolver.js', () => ({\n105\t  resolveAgent: (...args: unknown[]) => resolveAgentMock(...(args as Parameters<typeof resolveAgentMock>)),\n106\t  compileSubagentDefinition: (...args: unknown[]) => compileSubagentMock(...(args as Parameters<typeof compileSubagentMock>)),\n107\t}));\n108\t\n109\tvi.mock('../../lib/workflow-engine.js', () => ({\n110\t  executeWorkflow: (...args: unknown[]) => executeWorkflowMock(...(args as Parameters<typeof executeWorkflowMock>)),\n111\t}));\n112\t\n113\t\n114\tdescribe('run command', () => {\n115\t  let tmpDir: string;\n116\t\n117\t  beforeEach(() => {\n118\t    tmpDir = mkdtempSync(join(tmpdir(), 'run-test-'));\n119\t    getDriverMock.mockClear();\n120\t    existsSyncMock.mockReset();\n121\t    existsSyncMock.mockImplementation((p: unknown) => realExistsSync(String(p)));\n122\t    readSprintStatusMock.mockReset();\n123\t    readSprintStatusMock.mockReturnValue({});\n124\t    startRendererMock.mockClear();\n125\t    rendererCleanupMock.mockClear();\n126\t    getSprintStateMock.mockClear();\n127\t    getSprintStateMock.mockReturnValue({ success: false, error: 'no state' });\n128\t    reconcileStateMock.mockClear();\n129\t    reconcileStateMock.mockReturnValue({ success: true, data: { corrections: [], stateChanged: false } });\n130\t    isDockerAvailableMock.mockClear();\n131\t    isDockerAvailableMock.mockReturnValue(true);\n132\t    cleanupContainersMock.mockClear();\n133\t    cleanupContainersMock.mockReturnValue({ success: true, data: { containersRemoved: 0, names: [] } });\n134\t    parseWorkflowMock.mockReset();\n135\t    parseWorkflowMock.mockReturnValue({\n136\t      tasks: {\n137\t        implement: { agent: 'dev', scope: 'per-story', session: 'fresh', source_access: true },\n138\t      },\n139\t      flow: ['implement'],\n140\t    });\n141\t    resolveAgentMock.mockReset();\n142\t    resolveAgentMock.mockReturnValue({\n143\t      name: 'dev',\n144\t      role: { title: 'Developer', purpose: 'Implement code' },\n145\t      persona: { identity: 'A developer', communication_style: 'direct', principles: [] },\n146\t    });\n147\t    compileSubagentMock.mockReset();\n148\t    compileSubagentMock.mockReturnValue({\n149\t      name: 'dev',\n150\t      model: 'claude-sonnet-4-20250514',\n151\t      instructions: 'You are a developer',\n152\t      disallowedTools: [],\n153\t      bare: true,\n154\t    });\n155\t    executeWorkflowMock.mockReset();\n156\t    executeWorkflowMock.mockResolvedValue({\n157\t      success: true,\n158\t      tasksCompleted: 3,\n159\t      storiesProcessed: 1,\n160\t      errors: [],\n161\t      durationMs: 60000,\n162\t    });\n163\t    process.exitCode = undefined;\n164\t  });\n165\t\n166\t  afterEach(() => {\n167\t    rmSync(tmpDir, { recursive: true, force: true });\n168\t    vi.restoreAllMocks();\n169\t    process.exitCode = undefined;\n170\t  });\n171\t\n172\t  function mockPaths(overrides: Record<string, boolean>) {\n173\t    existsSyncMock.mockImplementation((p: unknown) => {\n174\t      const path = String(p);\n175\t      for (const [pattern, value] of Object.entries(overrides)) {\n176\t        if (path.includes(pattern)) return value;\n177\t      }\n178\t      return realExistsSync(path);\n179\t    });\n180\t  }\n181\t\n182\t  async function runCommand(args: string[] = []) {\n183\t    const { registerRunCommand } = await import('../run.js');\n184\t    const program = new Command();\n185\t    program.exitOverride();\n186\t    program.option('--json', 'JSON output');\n187\t    registerRunCommand(program);\n188\t    await program.parseAsync(['node', 'codeharness', 'run', ...args]);\n189\t  }\n190\t\n191\t  describe('resolvePluginDir', () => {\n192\t    it('returns cwd/.claude', () => {\n193\t      expect(resolvePluginDir()).toBe(join(process.cwd(), '.claude'));\n194\t    });\n195\t  });\n196\t\n197\t  describe('countStories (re-export)', () => {\n198\t    it('re-exports countStories from run-helpers.ts', () => {\n199\t      const counts = countStories({ '1-1-story': 'done', '1-2-story': 'backlog' });\n200\t      expect(counts.total).toBe(2);\n201\t      expect(counts.done).toBe(1);\n202\t    });\n203\t  });\n204\t\n205\t  describe('action handler', () => {\n206\t    it('fails when plugin directory not found', async () => {\n207\t      mockPaths({ '.claude': false });\n208\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n209\t\n210\t      await runCommand();\n211\t\n212\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Plugin directory not found'));\n213\t      expect(process.exitCode).toBe(1);\n214\t    });\n215\t\n216\t    it('fails when Docker is unavailable', async () => {\n217\t      mockPaths({ '.claude': true });\n218\t      isDockerAvailableMock.mockReturnValue(false);\n219\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n220\t\n221\t      await runCommand();\n222\t\n223\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Docker not available'));\n224\t      expect(process.exitCode).toBe(1);\n225\t    });\n226\t\n227\t    it('fails when no stories found in sprint state', async () => {\n228\t      mockPaths({ '.claude': true });\n229\t      readSprintStatusMock.mockReturnValue({});\n230\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n231\t\n232\t      await runCommand();\n233\t\n234\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('No stories found'));\n235\t      expect(process.exitCode).toBe(1);\n236\t    });\n237\t\n238\t    it('fails when no stories are ready for execution (AC #9)', async () => {\n239\t      mockPaths({ '.claude': true });\n240\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'done', '1-2-story': 'done' });\n241\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n242\t\n243\t      await runCommand();\n244\t\n245\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('No stories ready for execution'));\n246\t      expect(process.exitCode).toBe(1);\n247\t    });\n248\t\n249\t    it('calls executeWorkflow on success path (AC #1, #2)', async () => {\n250\t      mockPaths({ '.claude': true });\n251\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n252\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n253\t\n254\t      await runCommand();\n255\t\n256\t      expect(parseWorkflowMock).toHaveBeenCalled();\n257\t      expect(resolveAgentMock).toHaveBeenCalled();\n258\t      expect(executeWorkflowMock).toHaveBeenCalled();\n259\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Workflow completed'));\n260\t      expect(process.exitCode).toBeUndefined();\n261\t    });\n262\t\n263\t    it('constructs EngineConfig correctly from CLI options (AC #4)', async () => {\n264\t      mockPaths({ '.claude': true });\n265\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n266\t      vi.spyOn(console, 'log').mockImplementation(() => {});\n267\t\n268\t      await runCommand(['--max-iterations', '10']);\n269\t\n270\t      expect(executeWorkflowMock).toHaveBeenCalled();\n271\t      const config = executeWorkflowMock.mock.calls[0][0];\n272\t      expect(config.maxIterations).toBe(10);\n273\t      expect(config.runId).toMatch(/^run-\\d+$/);\n274\t      expect(config.workflow).toBeDefined();\n275\t      expect(config.agents).toBeDefined();\n276\t      expect(config.sprintStatusPath).toContain('sprint-status.yaml');\n277\t    });\n278\t\n279\t    it('exits 1 on workflow failure (AC #2)', async () => {\n280\t      mockPaths({ '.claude': true });\n281\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n282\t      executeWorkflowMock.mockResolvedValue({\n283\t        success: false,\n284\t        tasksCompleted: 1,\n285\t        storiesProcessed: 1,\n286\t        errors: [{ taskName: 'implement', storyKey: '1-1-story', code: 'UNKNOWN', message: 'dispatch failed' }],\n287\t        durationMs: 5000,\n288\t      });\n289\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n290\t\n291\t      await runCommand();\n292\t\n293\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Workflow failed'));\n294\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('dispatch failed'));\n295\t      expect(process.exitCode).toBe(1);\n296\t    });\n297\t\n298\t    it('exits 1 when executeWorkflow throws', async () => {\n299\t      mockPaths({ '.claude': true });\n300\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n301\t      executeWorkflowMock.mockRejectedValue(new Error('engine crashed'));\n302\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n303\t\n304\t      await runCommand();\n305\t\n306\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Workflow engine error'));\n307\t      expect(process.exitCode).toBe(1);\n308\t    });\n309\t\n310\t    it('exits 1 when wor