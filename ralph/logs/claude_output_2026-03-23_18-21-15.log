{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Mey7sf32mdz1L9tge1uYcr","type":"tool_result","content":"     1→import { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n     2→import { join } from 'node:path';\n     3→import { parse, stringify } from 'yaml';\n     4→import { warn } from './output.js';\n     5→import { detectStack, detectStacks, type StackName } from './stack-detect.js';\n     6→\n     7→export interface HarnessState {\n     8→  harness_version: string;\n     9→  initialized: boolean;\n    10→  stack: string | null;\n    11→  stacks: StackName[];\n    12→  app_type?: 'server' | 'cli' | 'web' | 'agent' | 'generic';\n    13→  enforcement: {\n    14→    frontend: boolean;\n    15→    database: boolean;\n    16→    api: boolean;\n    17→  };\n    18→  coverage: {\n    19→    target: number;\n    20→    baseline: number | null;\n    21→    current: number | null;\n    22→    tool: 'c8' | 'coverage.py' | 'cargo-tarpaulin' | 'unknown';\n    23→  };\n    24→  session_flags: {\n    25→    logs_queried: boolean;\n    26→    tests_passed: boolean;\n    27→    coverage_met: boolean;\n    28→    verification_run: boolean;\n    29→  };\n    30→  verification_log: string[];\n    31→  otlp?: {\n    32→    enabled: boolean;\n    33→    endpoint: string;\n    34→    service_name: string;\n    35→    mode: 'local-shared' | 'remote-direct' | 'remote-routed';\n    36→    node_require?: string;\n    37→    python_wrapper?: string;\n    38→    cli_env_vars?: Record<string, string>;\n    39→    web_snippet_path?: string;\n    40→    resource_attributes?: string;\n    41→    agent_sdk?: string;\n    42→    rust_env_hint?: string;\n    43→  };\n    44→  retro_issue_targets?: Array<{ repo: string; labels: string[] }>;\n    45→  docker?: {\n    46→    compose_file: string;\n    47→    stack_running: boolean;\n    48→    remote_endpoints?: {\n    49→      logs_url?: string;\n    50→      metrics_url?: string;\n    51→      traces_url?: string;\n    52→    };\n    53→    ports: {\n    54→      logs: number;\n    55→      metrics: number;\n    56→      traces: number;\n    57→      otel_grpc: number;\n    58→      otel_http: number;\n    59→    };\n    60→  };\n    61→}\n    62→\n    63→function migrateState(state: HarnessState): HarnessState {\n    64→  const raw = state as Record<string, unknown>;\n    65→\n    66→  // New format: stacks array already present\n    67→  if (Array.isArray(raw.stacks) && raw.stacks.length > 0) {\n    68→    state.stacks = raw.stacks as StackName[];\n    69→    state.stack = state.stacks[0] ?? null;\n    70→    return state;\n    71→  }\n    72→\n    73→  // Old format: has stack string but no stacks array\n    74→  if (typeof raw.stack === 'string' && raw.stack) {\n    75→    state.stacks = [raw.stack as StackName];\n    76→    return state;\n    77→  }\n    78→\n    79→  // Neither present\n    80→  state.stacks = [];\n    81→  state.stack = null;\n    82→  return state;\n    83→}\n    84→\n    85→const STATE_DIR = '.claude';\n    86→const STATE_FILE = 'codeharness.local.md';\n    87→const DEFAULT_BODY = '\\n# Codeharness State\\n\\nThis file is managed by the codeharness CLI. Do not edit manually.\\n';\n    88→\n    89→export function getDefaultCoverageTool(stack?: string | null): HarnessState['coverage']['tool'] {\n    90→  if (stack === 'python') return 'coverage.py';\n    91→  if (stack === 'rust') return 'cargo-tarpaulin';\n    92→  return 'c8';\n    93→}\n    94→\n    95→export function getDefaultState(stack?: string | null): HarnessState {\n    96→  return {\n    97→    harness_version: '0.1.0',\n    98→    initialized: false,\n    99→    stack: stack ?? null,\n   100→    stacks: stack ? [stack as StackName] : [],\n   101→    enforcement: {\n   102→      frontend: true,\n   103→      database: true,\n   104→      api: true,\n   105→    },\n   106→    coverage: {\n   107→      target: 90,\n   108→      baseline: null,\n   109→      current: null,\n   110→      tool: getDefaultCoverageTool(stack),\n   111→    },\n   112→    session_flags: {\n   113→      logs_queried: false,\n   114→      tests_passed: false,\n   115→      coverage_met: false,\n   116→      verification_run: false,\n   117→    },\n   118→    verification_log: [],\n   119→  };\n   120→}\n   121→\n   122→export function getStatePath(dir: string): string {\n   123→  return join(dir, STATE_DIR, STATE_FILE);\n   124→}\n   125→\n   126→export function writeState(state: HarnessState, dir?: string, body?: string): void {\n   127→  const baseDir = dir ?? process.cwd();\n   128→  const claudeDir = join(baseDir, STATE_DIR);\n   129→  mkdirSync(claudeDir, { recursive: true });\n   130→\n   131→  // Sync stack from stacks[0] for backward compat\n   132→  if (state.stacks && state.stacks.length > 0) {\n   133→    state.stack = state.stacks[0];\n   134→  }\n   135→\n   136→  const yamlContent = stringify(state, { nullStr: 'null' });\n   137→  const markdownBody = body ?? DEFAULT_BODY;\n   138→  const fileContent = `---\\n${yamlContent}---\\n${markdownBody}`;\n   139→\n   140→  writeFileSync(join(claudeDir, STATE_FILE), fileContent, 'utf-8');\n   141→}\n   142→\n   143→export function readState(dir?: string): HarnessState {\n   144→  const baseDir = dir ?? process.cwd();\n   145→  const filePath = getStatePath(baseDir);\n   146→\n   147→  if (!existsSync(filePath)) {\n   148→    throw new StateFileNotFoundError();\n   149→  }\n   150→\n   151→  const raw = readFileSync(filePath, 'utf-8');\n   152→  const parts = raw.split('---');\n   153→\n   154→  // parts[0] is empty (before first ---), parts[1] is YAML, rest is body\n   155→  if (parts.length < 3) {\n   156→    return recoverCorruptedState(baseDir);\n   157→  }\n   158→\n   159→  try {\n   160→    const state = parse(parts[1]) as HarnessState;\n   161→    if (!isValidState(state)) {\n   162→      return recoverCorruptedState(baseDir);\n   163→    }\n   164→    return migrateState(state);\n   165→  } catch {\n   166→    return recoverCorruptedState(baseDir);\n   167→  }\n   168→}\n   169→\n   170→export function readStateWithBody(dir?: string): { state: HarnessState; body: string } {\n   171→  const baseDir = dir ?? process.cwd();\n   172→  const filePath = getStatePath(baseDir);\n   173→\n   174→  if (!existsSync(filePath)) {\n   175→    throw new StateFileNotFoundError();\n   176→  }\n   177→\n   178→  const raw = readFileSync(filePath, 'utf-8');\n   179→  const parts = raw.split('---');\n   180→\n   181→  if (parts.length < 3) {\n   182→    const state = recoverCorruptedState(baseDir);\n   183→    return { state, body: DEFAULT_BODY };\n   184→  }\n   185→\n   186→  try {\n   187→    const state = parse(parts[1]) as HarnessState;\n   188→    if (!isValidState(state)) {\n   189→      const recovered = recoverCorruptedState(baseDir);\n   190→      return { state: recovered, body: DEFAULT_BODY };\n   191→    }\n   192→    // Everything after the second --- is the body\n   193→    const body = parts.slice(2).join('---');\n   194→    return { state: migrateState(state), body: body || DEFAULT_BODY };\n   195→  } catch {\n   196→    const state = recoverCorruptedState(baseDir);\n   197→    return { state, body: DEFAULT_BODY };\n   198→  }\n   199→}\n   200→\n   201→function isValidState(state: unknown): state is HarnessState {\n   202→  if (!state || typeof state !== 'object') return false;\n   203→  const s = state as Record<string, unknown>;\n   204→  if (typeof s.harness_version !== 'string') return false;\n   205→  if (typeof s.initialized !== 'boolean') return false;\n   206→  if (s.stack !== null && typeof s.stack !== 'string') return false;\n   207→  if (!s.enforcement || typeof s.enforcement !== 'object') return false;\n   208→  if (!s.coverage || typeof s.coverage !== 'object') return false;\n   209→  if (!s.session_flags || typeof s.session_flags !== 'object') return false;\n   210→  if (!Array.isArray(s.verification_log)) return false;\n   211→  // Accept old format (no stacks) and new format (stacks is array)\n   212→  if (s.stacks !== undefined && !Array.isArray(s.stacks)) return false;\n   213→  return true;\n   214→}\n   215→\n   216→function recoverCorruptedState(dir: string): HarnessState {\n   217→  warn('State file corrupted — recreating from detected config');\n   218→  const stack = detectStack(dir);\n   219→  const allStacks = detectStacks(dir);\n   220→  const state = getDefaultState(stack);\n   221→  // Dedupe: detectStacks may return same stack from multiple dirs\n   222→  const uniqueStackNames = [...new Set(allStacks.map(s => s.stack))];\n   223→  state.stacks = uniqueStackNames;\n   224→  writeState(state, dir);\n   225→  return state;\n   226→}\n   227→\n   228→export class StateFileNotFoundError extends Error {\n   229→  constructor() {\n   230→    super('No state file found. Run \\'codeharness init\\' first.');\n   231→    this.name = 'StateFileNotFoundError';\n   232→  }\n   233→}\n   234→\n   235→const DANGEROUS_KEYS = new Set(['__proto__', 'constructor', 'prototype']);\n   236→\n   237→function validateKeyPath(keyPath: string): void {\n   238→  const keys = keyPath.split('.');\n   239→  for (const key of keys) {\n   240→    if (DANGEROUS_KEYS.has(key)) {\n   241→      throw new Error(`Invalid key path: '${key}' is not allowed`);\n   242→    }\n   243→  }\n   244→}\n   245→\n   246→export function getNestedValue(obj: Record<string, unknown>, keyPath: string): unknown {\n   247→  validateKeyPath(keyPath);\n   248→  const keys = keyPath.split('.');\n   249→  let current: unknown = obj;\n   250→  for (const key of keys) {\n   251→    if (current === null || current === undefined || typeof current !== 'object') {\n   252→      return undefined;\n   253→    }\n   254→    current = (current as Record<string, unknown>)[key];\n   255→  }\n   256→  return current;\n   257→}\n   258→\n   259→export function setNestedValue(obj: Record<string, unknown>, keyPath: string, value: unknown): void {\n   260→  validateKeyPath(keyPath);\n   261→  const keys = keyPath.split('.');\n   262→  let current: Record<string, unknown> = obj;\n   263→  for (let i = 0; i < keys.length - 1; i++) {\n   264→    const key = keys[i];\n   265→    if (current[key] === undefined || current[key] === null || typeof current[key] !== 'object') {\n   266→      current[key] = {};\n   267→    }\n   268→    current = current[key] as Record<string, unknown>;\n   269→  }\n   270→  current[keys[keys.length - 1]] = value;\n   271→}\n   272→\n   273→export function parseValue(raw: string): unknown {\n   274→  if (raw === 'true') return true;\n   275→  if (raw === 'false') return false;\n   276→  if (raw === 'null') return null;\n   277→  const num = Number(raw);\n   278→  if (!Number.isNaN(num) && raw.trim() !== '') return num;\n   279→  return raw;\n   280→}\n   281→"}]},"parent_tool_use_id":"toolu_01GATsxowjKTFTmnhPqJRdwx","session_id":"90f5ac9b-34a6-4398-bbd9-dd5bc4930bef","uuid":"762c3a75-80fc-4c90-b4a2-25f9e0ad390c","timestamp":"2026-03-23T14:32:41.627Z"}
