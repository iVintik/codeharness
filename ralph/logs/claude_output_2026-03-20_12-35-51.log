rue);\n   109→    if (result.success) {\n   110→      expect(result.data.status).toBe('warn');\n   111→      expect(result.data.gaps.length).toBeGreaterThan(0);\n   112→      expect(result.data.gaps[0].description).toContain('Semgrep not installed');\n   113→    }\n   114→  });\n   115→\n   116→  it('returns warn when backend unreachable (runtime skipped)', async () => {\n   117→    mockAnalyze.mockReturnValue({\n   118→      success: true,\n   119→      data: {\n   120→        tool: 'semgrep',\n   121→        gaps: [],\n   122→        summary: { totalFiles: 10, filesWithGaps: 0, totalGaps: 0 },\n   123→      },\n   124→    });\n   125→    mockValidateRuntime.mockResolvedValue({\n   126→      success: true,\n   127→      data: {\n   128→        entries: [],\n   129→        totalModules: 5,\n   130→        modulesWithTelemetry: 0,\n   131→        coveragePercent: 0,\n   132→        skipped: true,\n   133→        skipReason: 'Backend unreachable',\n   134→      },\n   135→    });\n   136→\n   137→    const result = await checkObservability('/project');\n   138→    expect(result.success).toBe(true);\n   139→    if (result.success) {\n   140→      expect(result.data.status).toBe('warn');\n   141→      expect(result.data.gaps.some(g => g.description.includes('Backend unreachable'))).toBe(true);\n   142→    }\n   143→  });\n   144→\n   145→  it('returns warn when analyze fails', async () => {\n   146→    mockAnalyze.mockReturnValue({\n   147→      success: false,\n   148→      error: 'Semgrep binary not found',\n   149→    });\n   150→    mockValidateRuntime.mockResolvedValue({\n   151→      success: true,\n   152→      data: {\n   153→        entries: [],\n   154→        totalModules: 5,\n   155→        modulesWithTelemetry: 5,\n   156→        coveragePercent: 100,\n   157→        skipped: false,\n   158→      },\n   159→    });\n   160→\n   161→    const result = await checkObservability('/project');\n   162→    expect(result.success).toBe(true);\n   163→    if (result.