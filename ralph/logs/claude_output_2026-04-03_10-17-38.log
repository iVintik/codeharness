<StreamEvent>', () => {\n393\t    it('can be consumed with for-await-of', async () => {\n394\t      const driver = createMockDriver();\n395\t      const opts: DispatchOpts = {\n396\t        prompt: 'test',\n397\t        model: 'mock',\n398\t        cwd: '/tmp',\n399\t        sourceAccess: true,\n400\t      };\n401\t      const types: string[] = [];\n402\t      for await (const event of driver.dispatch(opts)) {\n403\t        types.push(event.type);\n404\t      }\n405\t      expect(types).toEqual(['text', 'result']);\n406\t    });\n407\t  });\n408\t});\n409\t\n410\t// --- Deprecated Types Tests (backward compatibility) ---\n411\t\n412\tdescribe('agents/types — deprecated types (backward compat)', () => {\n413\t  describe('SpawnOpts (deprecated)', () => {\n414\t    it('defines required fields: storyKey, prompt, workDir, timeout', () => {\n415\t      const opts: SpawnOpts = {\n416\t        storyKey: '13-1-agent-driver',\n417\t        prompt: 'implement the story',\n418\t        workDir: '/tmp/work',\n419\t        timeout: 60000,\n420\t      };\n421\t      expect(opts.storyKey).toBe('13-1-agent-driver');\n422\t      expect(opts.prompt).toBe('implement the story');\n423\t      expect(opts.workDir).toBe('/tmp/work');\n424\t      expect(opts.timeout).toBe(60000);\n425\t    });\n426\t\n427\t    it('accepts optional env field', () => {\n428\t      const opts: SpawnOpts = {\n429\t        storyKey: 'x',\n430\t        prompt: 'p',\n431\t        workDir: '/w',\n432\t        timeout: 1000,\n433\t        env: { FOO: 'bar' },\n434\t      };\n435\t      expect(opts.env).toEqual({ FOO: 'bar' });\n436\t    });\n437\t  });\n438\t\n439\t  describe('AgentProcess (deprecated)', () => {\n440\t    it('satisfies interface with mock implementation', () => {\n441\t      const proc = createMockProcess();\n442\t      expect(proc.stdout).toBeDefined();\n443\t      expect(proc.stderr).toBeDefined();\n444\t      expect(typeof proc.on).toBe('function');\n445\t      expect(typeof proc.kill).toBe('function');\n446\t    });\n447\t  });\n448\t\n449\t  describe('AgentEvent discriminated union (deprecated)', () => {\n450\t    it('covers all 8 event types', () => {\n451\t      const events: AgentEvent[] = [\n452\t        { type: 'tool-start', name: 'a' },\n453\t        { type: 'tool-input', partial: 'b' },\n454\t        { type: 'tool-complete', name: 'c', args: 'd' },\n455\t        { type: 'text', text: 'e' },\n456\t        { type: 'story-complete', key: 'f', details: 'g' },\n457\t        { type: 'story-failed', key: 'h', reason: 'i' },\n458\t        { type: 'iteration', count: 1 },\n459\t        { type: 'retry', attempt: 1, delay: 1 },\n460\t        { type: 'result', cost: 0, sessionId: 'j' },\n461\t      ];\n462\t      expect(events).toHaveLength(9);\n463\t    });\n464\t  });\n465\t\n466\t  describe('barrel re-exports from index.ts', () => {\n467\t    it('re-exports new types', () => {\n468\t      // Type-level: these compile, proving barrel exports work\n469\t      const health: BarrelDriverHealth = {\n470\t        available: true,\n471\t        authenticated: true,\n472\t        version: '1.0',\n473\t      };\n474\t      const caps: BarrelDriverCapabilities = {\n475\t        supportsPlugins: true,\n476\t        supportsStreaming: true,\n477\t        costReporting: true,\n478\t      };\n479\t      const cat: BarrelErrorCategory = 'RATE_LIMIT';\n480\t      const tr: BarrelTestResults = { passed: 1, failed: 0, coverage: null };\n481\t      const ac: BarrelACStatus = {\n482\t        id: '1',\n483\t        description: 'd',\n484\t        status: 'passed',\n485\t      };\n486\t      const contract: BarrelOutputContract = {\n487\t        version: 1,\n488\t        taskName: 't',\n489\t        storyId: 's',\n490\t        driver: 'd',\n491\t        model: 'm',\n492\t        timestamp: 'ts',\n493\t        cost_usd: null,\n494\t        duration_ms: 0,\n495\t        changedFiles: [],\n496\t        testResults: tr,\n497\t        output: '',\n498\t        acceptanceCriteria: [ac],\n499\t      };\n500\t      const opts: BarrelDispatchOpts = {\n501\t        prompt: 'p',\n502\t        model: 'm',\n503\t        cwd: '/',\n504\t        sourceAccess: true,\n505\t        outputContract: contract,\n506\t      };\n507\t      const driver: BarrelAgentDriver = {\n508\t        name: 'barrel',\n509\t        defaultModel: 'model',\n510\t        capabilities: caps,\n511\t        async healthCheck() {\n512\t          return health;\n513\t        },\n514\t        async *dispatch(_o: BarrelDispatchOpts) {\n515\t          yield { type: 'result' as const, cost: 0, sessionId: '' };\n516\t        },\n517\t        getLastCost: () => null,\n518\t      };\n519\t\n520\t      expect(health.available).toBe(true);\n521\t      expect(caps.supportsPlugins).toBe(true);\n522\t      expect(cat).toBe('RATE_LIMIT');\n523\t      expect(opts.prompt).toBe('p');\n524\t      expect(contract.version).toBe(1);\n525\t      expect(driver.name).toBe('barrel');\n526\t    });\n527\t\n528\t    it('re-exports deprecated types', () => {\n529\t      const opts: BarrelSpawnOpts = {\n530\t        storyKey: 'x',\n531\t        prompt: 'p',\n532\t        workDir: '/w',\n533\t        timeout: 1000,\n534\t      };\n535\t      const proc: BarrelAgentProcess = createMockProcess();\n536\t      const event: BarrelAgentEvent = { type: 'text', text: 'barrel' };\n537\t\n538\t      expect(opts.storyKey).toBe('x');\n539\t      expect(proc.stdout).toBeDefined();\n540\t      expect(event.type).toBe('text');\n541\t    });\n542\t  });\n543\t});\n544\t"}]},"parent_tool_use_id":"toolu_01BpPAVp4Nca1DbqKcGEGyds","session_id":"e499f49a-fe4c-4b28-bb21-4e83348f2671","uuid":"b99e8dae-2434-49ee-9775-723caf742e3b","timestamp":"2026-04-03T06:27:26.768Z"}
