{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DZguLLmzjJ4U9barFhhV5N","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach, afterEach } from 'vitest';\n2\timport { mkdtempSync, rmSync, readFileSync, writeFileSync, mkdirSync, existsSync } from 'node:fs';\n3\timport { tmpdir } from 'node:os';\n4\timport { join } from 'node:path';\n5\timport { parse } from 'yaml';\n6\timport {\n7\t  readIssues,\n8\t  writeIssues,\n9\t  nextIssueId,\n10\t  createIssue,\n11\t  closeIssue,\n12\t  VALID_STATUSES,\n13\t  VALID_PRIORITIES,\n14\t  type Issue,\n15\t  type IssuesFile,\n16\t} from '../issue-tracker.js';\n17\t\n18\tlet testDir: string;\n19\t\n20\tbeforeEach(() => {\n21\t  testDir = mkdtempSync(join(tmpdir(), 'ch-issue-test-'));\n22\t});\n23\t\n24\tafterEach(() => {\n25\t  rmSync(testDir, { recursive: true, force: true });\n26\t});\n27\t\n28\t// ---------------------------------------------------------------------------\n29\t// readIssues\n30\t// ---------------------------------------------------------------------------\n31\t\n32\tdescribe('readIssues', () => {\n33\t  it('returns empty array when file does not exist', () => {\n34\t    const result = readIssues(testDir);\n35\t    expect(result).toEqual({ issues: [] });\n36\t  });\n37\t\n38\t  it('parses existing issues.yaml correctly', () => {\n39\t    const dir = join(testDir, '.codeharness');\n40\t    mkdirSync(dir, { recursive: true });\n41\t    writeFileSync(\n42\t      join(dir, 'issues.yaml'),\n43\t      `issues:\\n  - id: issue-001\\n    title: Bug A\\n    source: manual\\n    priority: high\\n    status: backlog\\n    created_at: \"2026-01-01T00:00:00.000Z\"\\n`,\n44\t      'utf-8',\n45\t    );\n46\t\n47\t    const result = readIssues(testDir);\n48\t    expect(result.issues).toHaveLength(1);\n49\t    expect(result.issues[0].id).toBe('issue-001');\n50\t    expect(result.issues[0].title).toBe('Bug A');\n51\t    expect(result.issues[0].priority).toBe('high');\n52\t    expect(result.issues[0].status).toBe('backlog');\n53\t  });\n54\t\n55\t  it('returns empty array for malformed YAML without issues key', () => {\n56\t    const dir = join(testDir, '.codeharness');\n57\t    mkdirSync(dir, { recursive: true });\n58\t    writeFileSync(join(dir, 'issues.yaml'), 'foo: bar\\n', 'utf-8');\n59\t\n60\t    const result = readIssues(testDir);\n61\t    expect(result).toEqual({ issues: [] });\n62\t  });\n63\t});\n64\t\n65\t// ---------------------------------------------------------------------------\n66\t// writeIssues\n67\t// ---------------------------------------------------------------------------\n68\t\n69\tdescribe('writeIssues', () => {\n70\t  it('creates .codeharness/ directory if needed', () => {\n71\t    const data: IssuesFile = {\n72\t      issues: [\n73\t        {\n74\t          id: 'issue-001',\n75\t          title: 'Test',\n76\t          source: 'manual',\n77\t          priority: 'medium',\n78\t          status: 'backlog',\n79\t          created_at: '2026-01-01T00:00:00.000Z',\n80\t        },\n81\t      ],\n82\t    };\n83\t\n84\t    writeIssues(data, testDir);\n85\t\n86\t    expect(existsSync(join(testDir, '.codeharness'))).toBe(true);\n87\t    expect(existsSync(join(testDir, '.codeharness', 'issues.yaml'))).toBe(true);\n88\t  });\n89\t\n90\t  it('outputs valid YAML matching workflow-engine expected format', () => {\n91\t    const data: IssuesFile = {\n92\t      issues: [\n93\t        {\n94\t          id: 'issue-001',\n95\t          title: 'Docker timeout',\n96\t          source: 'retro-sprint-1',\n97\t          priority: 'high',\n98\t          status: 'backlog',\n99\t          created_at: '2026-01-01T00:00:00.000Z',\n100\t        },\n101\t      ],\n102\t    };\n103\t\n104\t    writeIssues(data, testDir);\n105\t\n106\t    const raw = readFileSync(join(testDir, '.codeharness', 'issues.yaml'), 'utf-8');\n107\t    const parsed = parse(raw) as Record<string, unknown>;\n108\t\n109\t    // Verify structure matches what loadWorkItems() expects\n110\t    expect(parsed).toHaveProperty('issues');\n111\t    expect(Array.isArray(parsed.issues)).toBe(true);\n112\t    const issues = parsed.issues as Array<Record<string, unknown>>;\n113\t    expect(issues[0].id).toBe('issue-001');\n114\t    expect(issues[0].title).toBe('Docker timeout');\n115\t    expect(issues[0].source).toBe('retro-sprint-1');\n116\t    expect(issues[0].priority).toBe('high');\n117\t    expect(issues[0].status).toBe('backlog');\n118\t  });\n119\t});\n120\t\n121\t// ---------------------------------------------------------------------------\n122\t// nextIssueId\n123\t// ---------------------------------------------------------------------------\n124\t\n125\tdescribe('nextIssueId', () => {\n126\t  it('generates issue-001 for empty array', () => {\n127\t    expect(nextIssueId([])).toBe('issue-001');\n128\t  });\n129\t\n130\t  it('increments from highest existing id', () => {\n131\t    const existing: Issue[] = [\n132\t      { id: 'issue-001', title: 'A', source: 'manual', priority: 'low', status: 'done', created_at: '' },\n133\t      { id: 'issue-005', title: 'B', source: 'manual', priority: 'low', status: 'backlog', created_at: '' },\n134\t    ];\n135\t    expect(nextIssueId(existing)).toBe('issue-006');\n136\t  });\n137\t\n138\t  it('handles non-sequential ids correctly', () => {\n139\t    const existing: Issue[] = [\n140\t      { id: 'issue-003', title: 'A', source: 'manual', priority: 'low', status: 'done', created_at: '' },\n141\t    ];\n142\t    expect(nextIssueId(existing)).toBe('issue-004');\n143\t  });\n144\t\n145\t  it('ignores ids that do not match the pattern', () => {\n146\t    const existing: Issue[] = [\n147\t      { id: 'custom-id', title: 'A', source: 'manual', priority: 'low', status: 'done', created_at: '' },\n148\t    ];\n149\t    expect(nextIssueId(existing)).toBe('issue-001');\n150\t  });\n151\t});\n152\t\n153\t// ---------------------------------------------------------------------------\n154\t// createIssue\n155\t// ---------------------------------------------------------------------------\n156\t\n157\tdescribe('createIssue', () => {\n158\t  it('sets defaults: source=manual, priority=medium, status=backlog', () => {\n159\t    const issue = createIssue('Test bug', undefined, testDir);\n160\t\n161\t    expect(issue.source).toBe('manual');\n162\t    expect(issue.priority).toBe('medium');\n163\t    expect(issue.status).toBe('backlog');\n164\t    expect(issue.id).toBe('issue-001');\n165\t    expect(issue.title).toBe('Test bug');\n166\t    expect(issue.created_at).toBeTruthy();\n167\t  });\n168\t\n169\t  it('respects provided priority and source', () => {\n170\t    const issue = createIssue('Bug X', { priority: 'critical', source: 'retro-sprint-2' }, testDir);\n171\t\n172\t    expect(issue.priority).toBe('critical');\n173\t    expect(issue.source).toBe('retro-sprint-2');\n174\t  });\n175\t\n176\t  it('appends without modifying existing issues', () => {\n177\t    const first = createIssue('First', undefined, testDir);\n178\t    const second = createIssue('Second', undefined, testDir);\n179\t\n180\t    expect(first.id).toBe('issue-001');\n181\t    expect(second.id).toBe('issue-002');\n182\t\n183\t    const data = readIssues(testDir);\n184\t    expect(data.issues).toHaveLength(2);\n185\t    expect(data.issues[0].title).toBe('First');\n186\t    expect(data.issues[1].title).toBe('Second');\n187\t  });\n188\t\n189\t  it('persists to disk', () => {\n190\t    createIssue('Persisted', undefined, testDir);\n191\t\n192\t    const raw = readFileSync(join(testDir, '.codeharness', 'issues.yaml'), 'utf-8');\n193\t    expect(raw).toContain('issue-001');\n194\t    expect(raw).toContain('Persisted');\n195\t  });\n196\t\n197\t  it('throws for invalid priority', () => {\n198\t    expect(() => createIssue('Bad priority', { priority: 'garbage' }, testDir)).toThrow(\n199\t      \"Invalid priority 'garbage'\",\n200\t    );\n201\t  });\n202\t\n203\t  it('accepts all valid priorities', () => {\n204\t    for (const p of ['low', 'medium', 'high', 'critical']) {\n205\t      const issue = createIssue(`Priority ${p}`, { priority: p }, testDir);\n206\t      expect(issue.priority).toBe(p);\n207\t    }\n208\t  });\n209\t});\n210\t\n211\t// ---------------------------------------------------------------------------\n212\t// closeIssue\n213\t// ---------------------------------------------------------------------------\n214\t\n215\tdescribe('closeIssue', () => {\n216\t  it('updates status to done', () => {\n217\t    createIssue('To close', undefined, testDir);\n218\t    const closed = closeIssue('issue-001', testDir);\n219\t\n220\t    expect(closed.status).toBe('done');\n221\t    expect(closed.id).toBe('issue-001');\n222\t  });\n223\t\n224\t  it('persists the closed status', () => {\n225\t    createIssue('Persist close', undefined, testDir);\n226\t    closeIssue('issue-001', testDir);\n227\t\n228\t    const data = readIssues(testDir);\n229\t    expect(data.issues[0].status).toBe('done');\n230\t  });\n231\t\n232\t  it('throws for non-existent id', () => {\n233\t    createIssue('Exists', undefined, testDir);\n234\t    expect(() => closeIssue('issue-999', testDir)).toThrow(\"Issue 'issue-999' not found\");\n235\t  });\n236\t});\n237\t\n238\t// ---------------------------------------------------------------------------\n239\t// Constants\n240\t// ---------------------------------------------------------------------------\n241\t\n242\tdescribe('constants', () => {\n243\t  it('VALID_STATUSES contains all expected values', () => {\n244\t    const expected = ['backlog', 'ready', 'in-progress', 'review', 'verifying', 'done', 'failed', 'blocked'];\n245\t    for (const s of expected) {\n246\t      expect(VALID_STATUSES.has(s)).toBe(true);\n247\t    }\n248\t    expect(VALID_STATUSES.size).toBe(8);\n249\t  });\n250\t\n251\t  it('VALID_PRIORITIES contains all expected values', () => {\n252\t    const expected = ['low', 'medium', 'high', 'critical'];\n253\t    for (const p of expected) {\n254\t      expect(VALID_PRIORITIES.has(p)).toBe(true);\n255\t    }\n256\t    expect(VALID_PRIORITIES.size).toBe(4);\n257\t  });\n258\t});\n259\t\n260\t// ---------------------------------------------------------------------------\n261\t// Compatibility with loadWorkItems()\n262\t// ---------------------------------------------------------------------------\n263\t\n264\tdescribe('workflow-engine compatibility', () => {\n265\t  it('created YAML round-trips through yaml parse matching loadWorkItems expectations', () => {\n266\t    createIssue('Docker timeout', { priority: 'high', source: 'retro-sprint-1' }, testDir);\n267\t    createIssue('Memory leak', { priority: 'critical', source: 'manual' }, testDir);\n268\t\n269\t    const raw = readFileSync(join(testDir, '.codeharness', 'issues.yaml'), 'utf-8');\n270\t    const parsed = parse(raw) as Record<string, unknown>;\n271\t\n272\t    // loadWorkItems expects: parsed.issues as Array<Record<string, unknown>>\n273\t    expect(Array.isArray(parsed.issues)).toBe(true);\n274\t    const issues = parsed.issues as Array<Record<string, unknown>>;\n275\t\n276\t    expect(issues).toHaveLength(2);\n277\t\n278\t    // Verify all fields that loadWorkItems accesses\n279\t    expect(issues[0].id).toBe('issue-001');\n280\t    expect(issues[0].title).toBe('Docker timeout');\n281\t    expect(issues[0].status).toBe('backlog');\n282\t\n283\t    expect(issues[1].id).toBe('issue-002');\n284\t    expect(issues[1].title).toBe('Memory leak');\n285\t    expect(issues[1].status).toBe('backlog');\n286\t  });\n287\t});\n288\t"}]},"parent_tool_use_id":"toolu_01U1QxzZy7C659GJM4oxEmEf","session_id":"3f15b50c-2c9b-40fa-9e63-9fad2199af43","uuid":"13faa9b8-1e5c-47a1-9abf-68fa2c90a264","timestamp":"2026-04-03T02:29:13.381Z"}
