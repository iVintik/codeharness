{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0131DAuzttLXnAgHZsauSVtq","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { join, resolve, dirname } from 'node:path';\n3\timport { fileURLToPath } from 'node:url';\n4\timport os from 'node:os';\n5\timport { parse } from 'yaml';\n6\timport { validateWorkflowSchema } from './schema-validate.js';\n7\timport { listDrivers } from './agents/drivers/factory.js';\n8\timport { listEmbeddedAgents, resolveAgent } from './agent-resolver.js';\n9\t\n10\tconst __filename = fileURLToPath(import.meta.url);\n11\tconst __dirname = dirname(__filename);\n12\t\n13\tconst TEMPLATES_DIR = resolve(__dirname, '../../templates/workflows');\n14\t\n15\t// --- Interfaces ---\n16\t\n17\texport interface ResolvedTask {\n18\t  agent: string;\n19\t  scope: 'per-story' | 'per-run';\n20\t  session: 'fresh' | 'continue';\n21\t  source_access: boolean;\n22\t  prompt_template?: string;\n23\t  input_contract?: Record<string, unknown>;\n24\t  output_contract?: Record<string, unknown>;\n25\t  max_budget_usd?: number;\n26\t  driver?: string;\n27\t  model?: string;\n28\t  plugins?: string[];\n29\t}\n30\t\n31\texport interface LoopBlock {\n32\t  loop: string[];\n33\t}\n34\t\n35\texport type FlowStep = string | LoopBlock;\n36\t\n37\texport interface ResolvedWorkflow {\n38\t  tasks: Record<string, ResolvedTask>;\n39\t  flow: FlowStep[];\n40\t}\n41\t\n42\t// --- Error Class ---\n43\t\n44\texport class WorkflowParseError extends Error {\n45\t  public readonly errors: Array<{ path: string; message: string }>;\n46\t\n47\t  constructor(message: string, errors?: Array<{ path: string; message: string }>) {\n48\t    super(message);\n49\t    this.name = 'WorkflowParseError';\n50\t    this.errors = errors ?? [];\n51\t  }\n52\t}\n53\t\n54\t// --- Referential Integrity Validation ---\n55\t\n56\t/**\n57\t * Validate that driver and agent references in tasks point to real registered\n58\t * drivers and resolvable agents. Collects errors into the provided array\n59\t * (does not throw — caller decides when to throw).\n60\t *\n61\t * Driver validation is skipped when the driver registry is empty (parse can\n62\t * be called independently of engine startup).\n63\t *\n64\t * Agent validation tries resolveAgent() first (covers embedded, user-level,\n65\t * and project-level agents), then falls back to listEmbeddedAgents() for\n66\t * the \"available agents\" suggestion in the error message.\n67\t */\n68\tfunction validateReferentialIntegrity(\n69\t  data: { tasks: Record<string, Record<string, unknown>> },\n70\t  _taskNames: Set<string>,\n71\t  errors: Array<{ path: string; message: string }>,\n72\t): void {\n73\t  // Driver validation — only when registry is populated\n74\t  const registeredDrivers = listDrivers();\n75\t  const driverRegistryPopulated = registeredDrivers.length > 0;\n76\t\n77\t  // Agent list for error messages\n78\t  const embeddedAgents = listEmbeddedAgents();\n79\t\n80\t  for (const [taskName, task] of Object.entries(data.tasks)) {\n81\t    // Validate driver field if present\n82\t    if (task.driver !== undefined && typeof task.driver === 'string' && driverRegistryPopulated) {\n83\t      if (!registeredDrivers.includes(task.driver)) {\n84\t        errors.push({\n85\t          path: `/tasks/${taskName}/driver`,\n86\t          message: `Driver \"${task.driver}\" not found in task \"${taskName}\". Registered drivers: ${registeredDrivers.join(', ')}`,\n87\t        });\n88\t      }\n89\t    }\n90\t\n91\t    // Validate agent field if present\n92\t    if (task.agent !== undefined && typeof task.agent === 'string') {\n93\t      let agentExists = false;\n94\t\n95\t      // Try resolveAgent first (covers embedded + user/project overrides)\n96\t      try {\n97\t        resolveAgent(task.agent);\n98\t        agentExists = true;\n99\t      } catch { // IGNORE: agent not resolvable — error collected below\n100\t      }\n101\t\n102\t      if (!agentExists) {\n103\t        const available = embeddedAgents.length > 0 ? embeddedAgents.join(', ') : '(none)';\n104\t        errors.push({\n105\t          path: `/tasks/${taskName}/agent`,\n106\t          message: `Agent \"${task.agent}\" not found in task \"${taskName}\". Available agents: ${available}`,\n107\t        });\n108\t      }\n109\t    }\n110\t  }\n111\t}\n112\t\n113\t// --- Shared Validation & Resolution ---\n114\t\n115\t/**\n116\t * Validate parsed YAML against JSON schema, check referential integrity,\n117\t * apply defaults, and return a typed ResolvedWorkflow.\n118\t * Shared between parseWorkflow (direct file) and resolveWorkflow (patch chain).\n119\t */\n120\tfunction validateAndResolve(parsed: unknown): ResolvedWorkflow {\n121\t  // Validate against JSON schema\n122\t  const result = validateWorkflowSchema(parsed);\n123\t  if (!result.valid) {\n124\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n125\t    throw new WorkflowParseError(\n126\t      `Schema validation failed: ${details}`,\n127\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n128\t    );\n129\t  }\n130\t\n131\t  // At this point, parsed has passed schema validation — safe to cast\n132\t  const data = parsed as { tasks: Record<string, Record<string, unknown>>; flow: unknown[] };\n133\t\n134\t  // Referential integrity check — collect all errors before throwing\n135\t  const taskNames = new Set(Object.keys(data.tasks));\n136\t  const allErrors: Array<{ path: string; message: string }> = [];\n137\t\n138\t  // 1. Flow-to-task dangling reference check\n139\t  for (let i = 0; i < data.flow.length; i++) {\n140\t    const step = data.flow[i];\n141\t    if (typeof step === 'string') {\n142\t      if (!taskNames.has(step)) {\n143\t        allErrors.push({\n144\t          path: `/flow/${i}`,\n145\t          message: `Task \"${step}\" referenced in flow but not defined in tasks`,\n146\t        });\n147\t      }\n148\t    } else if (typeof step === 'object' && step !== null && 'loop' in step) {\n149\t      const loopBlock = step as { loop: string[] };\n150\t      for (let j = 0; j < loopBlock.loop.length; j++) {\n151\t        const ref = loopBlock.loop[j];\n152\t        if (!taskNames.has(ref)) {\n153\t          allErrors.push({\n154\t            path: `/flow/${i}/loop/${j}`,\n155\t            message: `Task \"${ref}\" referenced in loop but not defined in tasks`,\n156\t          });\n157\t        }\n158\t      }\n159\t    }\n160\t  }\n161\t\n162\t  // 2. Driver and agent referential integrity check\n163\t  validateReferentialIntegrity(data, taskNames, allErrors);\n164\t\n165\t  if (allErrors.length > 0) {\n166\t    const details = allErrors.map((e) => e.message).join('; ');\n167\t    throw new WorkflowParseError(`Referential integrity errors: ${details}`, allErrors);\n168\t  }\n169\t\n170\t  // Apply defaults and build resolved tasks\n171\t  const resolvedTasks: Record<string, ResolvedTask> = {};\n172\t  for (const [taskName, task] of Object.entries(data.tasks)) {\n173\t    const resolved: ResolvedTask = {\n174\t      agent: task.agent as string,\n175\t      scope: (task.scope as ResolvedTask['scope']) ?? 'per-story',\n176\t      session: (task.session as ResolvedTask['session']) ?? 'fresh',\n177\t      source_access: (task.source_access as boolean) ?? true,\n178\t    };\n179\t    if (task.prompt_template !== undefined) {\n180\t      resolved.prompt_template = task.prompt_template as string;\n181\t    }\n182\t    if (task.input_contract !== undefined) {\n183\t      resolved.input_contract = task.input_contract as Record<string, unknown>;\n184\t    }\n185\t    if (task.output_contract !== undefined) {\n186\t      resolved.output_contract = task.output_contract as Record<string, unknown>;\n187\t    }\n188\t    if (task.max_budget_usd !== undefined) {\n189\t      resolved.max_budget_usd = task.max_budget_usd as number;\n190\t    }\n191\t    if (task.driver !== undefined) {\n192\t      resolved.driver = task.driver as string;\n193\t    }\n194\t    if (task.model !== undefined) {\n195\t      resolved.model = task.model as string;\n196\t    }\n197\t    if (task.plugins !== undefined) {\n198\t      resolved.plugins = task.plugins as string[];\n199\t    }\n200\t    resolvedTasks[taskName] = resolved;\n201\t  }\n202\t\n203\t  // Build resolved flow\n204\t  const resolvedFlow: FlowStep[] = data.flow.map((step) => {\n205\t    if (typeof step === 'string') {\n206\t      return step;\n207\t    }\n208\t    return step as LoopBlock;\n209\t  });\n210\t\n211\t  return { tasks: resolvedTasks, flow: resolvedFlow };\n212\t}\n213\t\n214\t// --- Parser ---\n215\t\n216\t/**\n217\t * Parse a workflow YAML file from disk, validate it against the JSON schema,\n218\t * check referential integrity, apply defaults, and return a typed ResolvedWorkflow.\n219\t */\n220\texport function parseWorkflow(filePath: string): ResolvedWorkflow {\n221\t  // 1. Read file\n222\t  let raw: string;\n223\t  try {\n224\t    raw = readFileSync(filePath, 'utf-8');\n225\t  } catch (err: unknown) {\n226\t    const code = err instanceof Error && 'code' in err ? (err as NodeJS.ErrnoException).code : undefined;\n227\t    const detail = code === 'ENOENT'\n228\t      ? 'File not found'\n229\t      : code === 'EACCES'\n230\t        ? 'Permission denied'\n231\t        : code === 'EISDIR'\n232\t          ? 'Path is a directory'\n233\t          : 'File not found or unreadable';\n234\t    throw new WorkflowParseError(`${detail}: ${filePath}`, [\n235\t      { path: filePath, message: detail },\n236\t    ]);\n237\t  }\n238\t\n239\t  // 2. Parse YAML\n240\t  let parsed: unknown;\n241\t  try {\n242\t    parsed = parse(raw);\n243\t  } catch (err: unknown) {\n244\t    const yamlMsg = err instanceof Error ? err.message : String(err);\n245\t    throw new WorkflowParseError(`Invalid YAML syntax: ${yamlMsg}`, [\n246\t      { path: filePath, message: yamlMsg },\n247\t    ]);\n248\t  }\n249\t\n250\t  return validateAndResolve(parsed);\n251\t}\n252\t\n253\t// --- Patch Interfaces ---\n254\t\n255\t/**\n256\t * Patch file structure for workflow customization.\n257\t * `extends` identifies the base, `overrides` are deep-merged, `replace` sections wholly overwrite.\n258\t */\n259\texport interface WorkflowPatch {\n260\t  extends?: string;\n261\t  overrides?: Record<string, unknown>;\n262\t  replace?: Record<string, unknown>;\n263\t}\n264\t\n265\t// --- Deep Merge ---\n266\t\n267\t/**\n268\t * Deep merge strategy: objects merge recursively, arrays replace, scalars replace.\n269\t * Same semantics as agent-resolver deepMerge.\n270\t */\n271\tfunction deepMerge(base: Record<string, unknown>, patch: Record<string, unknown>): Record<string, unknown> {\n272\t  const result: Record<string, unknown> = { ...base };\n273\t\n274\t  for (const key of Object.keys(patch)) {\n275\t    const baseVal = base[key];\n276\t    const patchVal = patch[key];\n277\t\n278\t    if (\n279\t      patchVal !== null &&\n280\t      typeof patchVal === 'object' &&\n281\t      !Array.isArray(patchVal) &&\n282\t      baseVal !== null &&\n283\t      typeof baseVal === 'object' &&\n284\t      !Array.isArray(baseVal)\n285\t    ) {\n286\t      result[key] = deepMerge(\n287\t        baseVal as Record<string, unknown>,\n288\t        patchVal as Record<string, unknown>,\n289\t      );\n290\t    } else {\n291\t      result[key] = patchVal;\n292\t    }\n293\t  }\n294\t\n295\t  return result;\n296\t}\n297\t\n298\t// --- Patch Loading ---\n299\t\n300\t/**\n301\t * Load a workflow patch file. Returns null if the file does not exist (silent skip).\n302\t * Throws WorkflowParseError on malformed YAML.\n303\t */\n304\texport function loadWorkflowPatch(filePath: string): WorkflowPatch | null {\n305\t  if (!existsSync(filePath)) {\n306\t    return null;\n307\t  }\n308\t\n309\t  let raw: string;\n310\t  try {\n311\t    raw = readFileSync(filePath, 'utf-8');\n312\t  } catch (err: unknown) {\n313\t    const code = err instanceof Error && 'code' in err ? (err as NodeJS.ErrnoException).code : undefined;\n314\t    if (code === 'ENOENT') {\n315\t      return null; // File disappeared between existsSync and readFileSync — treat as missing\n316\t    }\n317\t    const detail = code === 'EACCES' ? 'Permission denied' : 'File unreadable';\n318\t    throw new WorkflowParseError(`${detail}: ${filePath}`, [\n319\t      { path: filePath, message: detail },\n320\t    ]);\n321\t  }\n322\t\n323\t  let parsed: unknown;\n324\t  try {\n325\t    parsed = parse(raw);\n326\t  } catch (err: unknown) {\n327\t    const msg = err instanceof Error ? err.message : String(err);\n328\t    throw new WorkflowParseError(`Invalid YAML in patch file ${filePath}: ${msg}`, [\n329\t      { path: filePath, message: msg },\n330\t    ]);\n331\t  }\n332\t\n333\t  if (parsed === null || typeof parsed !== 'object') {\n334\t    throw new WorkflowParseError(`Patch file is not a valid object: ${filePath}`, [\n335\t      { path: filePath, message: 'Patch must be a YAML object' },\n336\t    ]);\n337\t  }\n338\t\n339\t  return parsed as WorkflowPatch;\n340\t}\n341\t\n342\t// --- Patch Merging ---\n343\t\n344\t/**\n345\t * Merge a workflow patch onto a base config.\n346\t * Deep-merges `overrides`, then applies `replace` sections as full overwrites.\n347\t */\n348\texport function mergeWorkflowPatch(\n349\t  base: Record<string, unknown>,\n350\t  patch: WorkflowPatch,\n351\t): Record<string, unknown> {\n352\t  let result = { ...base };\n353\t\n354\t  // Deep-merge overrides\n355\t  if (patch.overrides) {\n356\t    result = deepMerge(result, patch.overrides);\n357\t  }\n358\t\n359\t  // Full replacement for replace sections\n360\t  if (patch.replace) {\n361\t    for (const key of Object.keys(patch.replace)) {\n362\t      result[key] = patch.replace[key];\n363\t    }\n364\t  }\n365\t\n366\t  return result;\n367\t}\n368\t\n369\t// --- Main Resolution ---\n370\t\n371\t/**\n372\t * Resolve a workflow through the embedded -> user -> project patch chain.\n373\t *\n374\t * 1. Load embedded workflow from templates/workflows/{name}.yaml\n375\t * 2. Apply user-level patch from ~/.codeharness/workflows/{name}.patch.yaml (if exists)\n376\t * 3. Apply project-level patch from .codeharness/workflows/{name}.patch.yaml (if exists)\n377\t * 4. Validate merged result against JSON schema + referential integrity\n378\t * 5. Apply defaults and return ResolvedWorkflow\n379\t *\n380\t * If a full custom workflow (no patch, no extends) exists at project level, it is loaded directly.\n381\t */\n382\texport function resolveWorkflow(options?: { cwd?: string; name?: string }): ResolvedWorkflow {\n383\t  const cwd = options?.cwd ?? process.cwd();\n384\t  const name = options?.name ?? 'default';\n385\t\n386\t  const userPatchPath = join(os.homedir(), '.codeharness', 'workflows', `${name}.patch.yaml`);\n387\t  const projectPatchPath = join(cwd, '.codeharness', 'workflows', `${name}.patch.yaml`);\n388\t\n389\t  // Check for full custom workflow at project level (not a patch — no extends)\n390\t  const projectCustomPath = join(cwd, '.codeharness', 'workflows', `${name}.yaml`);\n391\t  if (existsSync(projectCustomPath)) {\n392\t    const customPatch = loadWorkflowPatch(projectCustomPath);\n393\t    if (customPatch && !customPatch.extends) {\n394\t      // This is a full custom workflow, not a patch — parse directly\n395\t      return parseWorkflow(projectCustomPath);\n396\t    }\n397\t  }\n398\t\n399\t  // Load embedded base\n400\t  const embeddedPath = join(TEMPLATES_DIR, `${name}.yaml`);\n401\t  let raw: string;\n402\t  try {\n403\t    raw = readFileSync(embeddedPath, 'utf-8');\n404\t  } catch (err: unknown) {\n405\t    const detail = err instanceof Error ? err.message : `File not found: ${embeddedPath}`;\n406\t    throw new WorkflowParseError(`Embedded workflow not found: ${name}`, [\n407\t      { path: embeddedPath, message: detail },\n408\t    ]);\n409\t  }\n410\t\n411\t  let baseData: unknown;\n412\t  try {\n413\t    baseData = parse(raw);\n414\t  } catch (err: unknown) {\n415\t    const msg = err instanceof Error ? err.message : String(err);\n416\t    throw new WorkflowParseError(`Invalid YAML in embedded workflow ${name}: ${msg}`, [\n417\t      { path: embeddedPath, message: msg },\n418\t    ]);\n419\t  }\n420\t\n421\t  let merged = baseData as Record<string, unknown>;\n422\t\n423\t  // Apply user-level patch\n424\t  const userPatch = loadWorkflowPatch(userPatchPath);\n425\t  if (userPatch) {\n426\t    merged = mergeWorkflowPatch(merged, userPatch);\n427\t  }\n428\t\n429\t  // Apply project-level patch\n430\t  const projectPatch = loadWorkflowPatch(projectPatchPath);\n431\t  if (projectPatch) {\n432\t    merged = mergeWorkflowPatch(merged, projectPatch);\n433\t  }\n434\t\n435\t  // Validate, check referential integrity, apply defaults, and return\n436\t  return validateAndResolve(merged);\n437\t}\n438\t"}]},"parent_tool_use_id":"toolu_01U85MaKaYFD6RV3D181SmSg","session_id":"4b1f7711-6ed7-4488-a0af-b261e761b450","uuid":"9ab4c8a0-4fff-44a2-80c6-3e6965e1e199","timestamp":"2026-04-03T08:36:57.655Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PAzWwUrmTN7wtZ1hxtJj7i","type":"tool_result","content":"1\timport { readFileSync, existsSync, readdirSync } from 'node:fs';\n2\timport { resolve, join, dirname } from 'node:path';\n3\timport { fileURLToPath } from 'node:url';\n4\timport os from 'node:os';\n5\timport { parse } from 'yaml';\n6\t\n7\tconst __filename = fileURLToPath(import.meta.url);\n8\tconst __dirname = dirname(__filename);\n9\timport { validateAgentSchema } from './schema-validate.js';\n10\t\n11\t// --- Interfaces ---\n12\t\n13\t/**\n14\t * Agent config shape matching agent.schema.json, plus optional prompt_patches\n15\t * accumulated from patch files.\n16\t */\n17\texport interface ResolvedAgent {\n18\t  name: string;\n19\t  role: {\n20\t    title: string;\n21\t    purpose: string;\n22\t  };\n23\t  persona: {\n24\t    identity: string;\n25\t    communication_style: string;\n26\t    principles: string[];\n27\t  };\n28\t  personality?: {\n29\t    traits: Record<string, number>;\n30\t  };\n31\t  disallowedTools?: string[];\n32\t  prompt_patches?: {\n33\t    append?: string;\n34\t  };\n35\t  prompt_template?: string;\n36\t}\n37\t\n38\t/**\n39\t * Compiled subagent definition ready for Agent SDK dispatch.\n40\t */\n41\texport interface SubagentDefinition {\n42\t  name: string;\n43\t  model: string;\n44\t  instructions: string;\n45\t  disallowedTools: string[];\n46\t  bare: true;\n47\t}\n48\t\n49\t/**\n50\t * Patch file structure: extends identifies base, overrides deep-merged,\n51\t * prompt_patches preserved separately.\n52\t */\n53\texport interface AgentPatch {\n54\t  extends?: string;\n55\t  overrides?: Record<string, unknown>;\n56\t  prompt_patches?: {\n57\t    append?: string;\n58\t  };\n59\t}\n60\t\n61\t// --- Error Class ---\n62\t\n63\texport class AgentResolveError extends Error {\n64\t  public readonly filePath: string;\n65\t  public readonly errors: Array<{ path: string; message: string }>;\n66\t\n67\t  constructor(\n68\t    message: string,\n69\t    filePath: string,\n70\t    errors?: Array<{ path: string; message: string }>,\n71\t  ) {\n72\t    super(message);\n73\t    this.name = 'AgentResolveError';\n74\t    this.filePath = filePath;\n75\t    this.errors = errors ?? [];\n76\t  }\n77\t}\n78\t\n79\t// --- Constants ---\n80\t\n81\tconst TEMPLATES_DIR = resolve(__dirname, '../../templates/agents');\n82\tconst DEFAULT_MODEL = 'claude-sonnet-4-20250514';\n83\t\n84\t// --- Input Validation ---\n85\t\n86\tconst SAFE_NAME_RE = /^[a-zA-Z0-9_-]+$/;\n87\t\n88\t/**\n89\t * Validate agent name to prevent path traversal and unexpected characters.\n90\t */\n91\tfunction validateName(name: string): void {\n92\t  if (!name || !SAFE_NAME_RE.test(name)) {\n93\t    throw new AgentResolveError(\n94\t      `Invalid agent name: \"${name}\" — must match ${SAFE_NAME_RE}`,\n95\t      '',\n96\t      [{ path: '', message: `Invalid agent name: ${name}` }],\n97\t    );\n98\t  }\n99\t}\n100\t\n101\t// --- Deep Merge ---\n102\t\n103\t/**\n104\t * Deep merge strategy: objects merge recursively, arrays replace, scalars replace.\n105\t */\n106\tfunction deepMerge(base: Record<string, unknown>, patch: Record<string, unknown>): Record<string, unknown> {\n107\t  const result: Record<string, unknown> = { ...base };\n108\t\n109\t  for (const key of Object.keys(patch)) {\n110\t    const baseVal = base[key];\n111\t    const patchVal = patch[key];\n112\t\n113\t    if (\n114\t      patchVal !== null &&\n115\t      typeof patchVal === 'object' &&\n116\t      !Array.isArray(patchVal) &&\n117\t      baseVal !== null &&\n118\t      typeof baseVal === 'object' &&\n119\t      !Array.isArray(baseVal)\n120\t    ) {\n121\t      result[key] = deepMerge(\n122\t        baseVal as Record<string, unknown>,\n123\t        patchVal as Record<string, unknown>,\n124\t      );\n125\t    } else {\n126\t      result[key] = patchVal;\n127\t    }\n128\t  }\n129\t\n130\t  return result;\n131\t}\n132\t\n133\t// --- Embedded Agent Loading ---\n134\t\n135\t/**\n136\t * Load an embedded agent template from templates/agents/{name}.yaml.\n137\t * Throws AgentResolveError if not found or invalid.\n138\t */\n139\texport function loadEmbeddedAgent(name: string): ResolvedAgent {\n140\t  validateName(name);\n141\t  const filePath = join(TEMPLATES_DIR, `${name}.yaml`);\n142\t\n143\t  let raw: string;\n144\t  try {\n145\t    raw = readFileSync(filePath, 'utf-8');\n146\t  } catch { // IGNORE: rethrow as AgentResolveError with context\n147\t    throw new AgentResolveError(\n148\t      `Embedded agent not found: ${name}`,\n149\t      filePath,\n150\t      [{ path: filePath, message: `File not found: ${filePath}` }],\n151\t    );\n152\t  }\n153\t\n154\t  let parsed: unknown;\n155\t  try {\n156\t    parsed = parse(raw);\n157\t  } catch (err: unknown) {\n158\t    const msg = err instanceof Error ? err.message : String(err);\n159\t    throw new AgentResolveError(\n160\t      `Invalid YAML in embedded agent ${name}: ${msg}`,\n161\t      filePath,\n162\t      [{ path: filePath, message: msg }],\n163\t    );\n164\t  }\n165\t\n166\t  const result = validateAgentSchema(parsed);\n167\t  if (!result.valid) {\n168\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n169\t    throw new AgentResolveError(\n170\t      `Schema validation failed for embedded agent ${name}: ${details}`,\n171\t      filePath,\n172\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n173\t    );\n174\t  }\n175\t\n176\t  return parsed as ResolvedAgent;\n177\t}\n178\t\n179\t// --- Embedded Agent Listing ---\n180\t\n181\t/**\n182\t * List all embedded agent template names (filenames without .yaml extension).\n183\t * Returns a sorted array of available agent names.\n184\t */\n185\texport function listEmbeddedAgents(): string[] {\n186\t  try {\n187\t    const files = readdirSync(TEMPLATES_DIR);\n188\t    return files\n189\t      .filter((f) => f.endsWith('.yaml'))\n190\t      .map((f) => f.replace(/\\.yaml$/, ''))\n191\t      .sort();\n192\t  } catch { // IGNORE: directory unreadable — return empty list\n193\t    return [];\n194\t  }\n195\t}\n196\t\n197\t// --- Patch Loading ---\n198\t\n199\t/**\n200\t * Load a patch file. Returns null if the file does not exist (silent skip).\n201\t * Throws AgentResolveError on malformed YAML.\n202\t */\n203\texport function loadPatch(filePath: string): AgentPatch | null {\n204\t  if (!existsSync(filePath)) {\n205\t    return null;\n206\t  }\n207\t\n208\t  let raw: string;\n209\t  try {\n210\t    raw = readFileSync(filePath, 'utf-8');\n211\t  } catch { // IGNORE: file unreadable — treat as missing patch\n212\t    return null;\n213\t  }\n214\t\n215\t  let parsed: unknown;\n216\t  try {\n217\t    parsed = parse(raw);\n218\t  } catch (err: unknown) {\n219\t    const msg = err instanceof Error ? err.message : String(err);\n220\t    throw new AgentResolveError(\n221\t      `Invalid YAML in patch file: ${msg}`,\n222\t      filePath,\n223\t      [{ path: filePath, message: msg }],\n224\t    );\n225\t  }\n226\t\n227\t  if (parsed === null || typeof parsed !== 'object') {\n228\t    throw new AgentResolveError(\n229\t      `Patch file is not a valid object`,\n230\t      filePath,\n231\t      [{ path: filePath, message: 'Patch must be a YAML object' }],\n232\t    );\n233\t  }\n234\t\n235\t  return parsed as AgentPatch;\n236\t}\n237\t\n238\t// --- Patch Merging ---\n239\t\n240\t/**\n241\t * Merge a patch onto a base config. Deep-merges overrides, preserves prompt_patches separately.\n242\t */\n243\texport function mergePatch(\n244\t  base: Record<string, unknown>,\n245\t  patch: AgentPatch,\n246\t): Record<string, unknown> {\n247\t  let result = { ...base };\n248\t\n249\t  if (patch.overrides) {\n250\t    result = deepMerge(result, patch.overrides);\n251\t  }\n252\t\n253\t  if (patch.prompt_patches) {\n254\t    const existing = result.prompt_patches as { append?: string } | undefined;\n255\t    const existingAppend = existing?.append ?? '';\n256\t    const newAppend = patch.prompt_patches.append ?? '';\n257\t\n258\t    if (newAppend) {\n259\t      result.prompt_patches = {\n260\t        append: existingAppend ? `${existingAppend}\\n${newAppend}` : newAppend,\n261\t      };\n262\t    }\n263\t  }\n264\t\n265\t  return result;\n266\t}\n267\t\n268\t// --- Main Resolution ---\n269\t\n270\t/**\n271\t * Resolve an agent through the embedded -> user -> project patch chain.\n272\t * For custom agents (no embedded match, found at project/user level without extends), loads directly.\n273\t */\n274\texport function resolveAgent(name: string, options?: { cwd?: string }): ResolvedAgent {\n275\t  validateName(name);\n276\t  const cwd = options?.cwd ?? process.cwd();\n277\t  const userPatchPath = join(os.homedir(), '.codeharness', 'agents', `${name}.patch.yaml`);\n278\t  const projectPatchPath = join(cwd, '.codeharness', 'agents', `${name}.patch.yaml`);\n279\t\n280\t  // Check for custom agent (project-level full config, no extends)\n281\t  const projectCustomPath = join(cwd, '.codeharness', 'agents', `${name}.yaml`);\n282\t  const userCustomPath = join(os.homedir(), '.codeharness', 'agents', `${name}.yaml`);\n283\t\n284\t  // Try custom agent at project level first, then user level\n285\t  for (const customPath of [projectCustomPath, userCustomPath]) {\n286\t    if (existsSync(customPath)) {\n287\t      const patch = loadPatch(customPath);\n288\t      if (patch && !patch.extends) {\n289\t        // This is a full custom agent, not a patch — load and validate directly\n290\t        const parsed = patch as unknown as Record<string, unknown>;\n291\t        // Strip prompt_patches before schema validation (not in schema, same as patch path)\n292\t        const { prompt_patches: customPP, ...customForValidation } = parsed as Record<string, unknown> & { prompt_patches?: unknown };\n293\t        const result = validateAgentSchema(customForValidation);\n294\t        if (!result.valid) {\n295\t          const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n296\t          throw new AgentResolveError(\n297\t            `Schema validation failed for custom agent ${name}: ${details}`,\n298\t            customPath,\n299\t            result.errors.map((e) => ({ path: e.path, message: e.message })),\n300\t          );\n301\t        }\n302\t        return (customPP ? { ...customForValidation, prompt_patches: customPP } : customForValidation) as unknown as ResolvedAgent;\n303\t      }\n304\t    }\n305\t  }\n306\t\n307\t  // Load embedded base\n308\t  const base = loadEmbeddedAgent(name);\n309\t  let merged: Record<string, unknown> = base as unknown as Record<string, unknown>;\n310\t\n311\t  // Apply user patch\n312\t  const userPatch = loadPatch(userPatchPath);\n313\t  if (userPatch) {\n314\t    merged = mergePatch(merged, userPatch);\n315\t  }\n316\t\n317\t  // Apply project patch\n318\t  const projectPatch = loadPatch(projectPatchPath);\n319\t  if (projectPatch) {\n320\t    merged = mergePatch(merged, projectPatch);\n321\t  }\n322\t\n323\t  // Validate merged result (strip prompt_patches for schema validation since it's not in schema)\n324\t  const { prompt_patches, ...forValidation } = merged as Record<string, unknown> & { prompt_patches?: unknown };\n325\t  const result = validateAgentSchema(forValidation);\n326\t  if (!result.valid) {\n327\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n328\t    const errorPath = projectPatch ? projectPatchPath : userPatch ? userPatchPath : 'merged';\n329\t    throw new AgentResolveError(\n330\t      `Schema validation failed after merging patches for ${name}: ${details}`,\n331\t      errorPath,\n332\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n333\t    );\n334\t  }\n335\t\n336\t  // Re-attach prompt_patches if present, return without mutating forValidation\n337\t  return (prompt_patches\n338\t    ? { ...forValidation, prompt_patches }\n339\t    : forValidation) as unknown as ResolvedAgent;\n340\t}\n341\t\n342\t// --- Subagent Compilation ---\n343\t\n344\t/**\n345\t * Compile a ResolvedAgent into a SubagentDefinition for Agent SDK dispatch.\n346\t */\n347\texport function compileSubagentDefinition(agent: ResolvedAgent): SubagentDefinition {\n348\t  const parts: string[] = [];\n349\t\n350\t  parts.push(`You are ${agent.persona.identity}`);\n351\t  parts.push(`Communication style: ${agent.persona.communication_style}`);\n352\t\n353\t  if (agent.persona.principles.length > 0) {\n354\t    const bullets = agent.persona.principles.map((p) => `- ${p}`).join('\\n');\n355\t    parts.push(`Principles:\\n${bullets}`);\n356\t  }\n357\t\n358\t  if (agent.prompt_patches?.append) {\n359\t    parts.push(agent.prompt_patches.append);\n360\t  }\n361\t\n362\t  if (agent.prompt_template) {\n363\t    parts.push(agent.prompt_template);\n364\t  }\n365\t\n366\t  return {\n367\t    name: agent.name,\n368\t    model: DEFAULT_MODEL,\n369\t    instructions: parts.join('\\n\\n'),\n370\t    disallowedTools: agent.disallowedTools ?? [],\n371\t    bare: true,\n372\t  };\n373\t}\n374\t"}]},"parent_tool_use_id":"toolu_01U85MaKaYFD6RV3D181SmSg","session_id":"4b1f7711-6ed7-4488-a0af-b261e761b450","uuid":"e5813cca-f120-4a20-a6cc-23c67a3895a7","timestamp":"2026-04-03T08:36:57.707Z"}
