{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0164p7S1AEeCpwYCwZvAg5aj","type":"tool_result","content":"1\t/**\n2\t * CLI command: codeharness validate\n3\t * Parent command with subcommands: schema, self\n4\t * - validate schema: validate workflow YAML files against JSON schemas (Story 2-5)\n5\t * - validate self: run self-validation cycle and produce release gate report (Story 10-3)\n6\t * - validate (no subcommand): defaults to schema validation\n7\t */\n8\timport { Command } from 'commander';\n9\timport { registerValidateSchemaCommand, runSchemaValidation } from './validate-schema.js';\n10\timport { registerValidateSelfCommand } from './validate-self.js';\n11\timport { ok, fail, jsonOutput } from '../lib/output.js';\n12\t\n13\texport function registerValidateCommand(program: Command): void {\n14\t  const validateCmd = program\n15\t    .command('validate')\n16\t    .description('Validate workflow YAML files (default) or run self-validation')\n17\t    .action((_opts: Record<string, unknown>, cmd: Command) => {\n18\t      // Default action when no subcommand given: run schema validation\n19\t      const isJson = (cmd.optsWithGlobals() as { json?: boolean }).json === true;\n20\t      const result = runSchemaValidation(process.cwd());\n21\t\n22\t      if (isJson) {\n23\t        jsonOutput(result as unknown as Record<string, unknown>);\n24\t        process.exitCode = result.status === 'pass' ? 0 : 1;\n25\t        return;\n26\t      }\n27\t\n28\t      for (const file of result.files) {\n29\t        if (file.valid) {\n30\t          ok(`Schema: ${file.path}`);\n31\t        } else {\n32\t          fail(`Schema: ${file.path}`);\n33\t          for (const error of file.errors) {\n34\t            console.log(`  ${error.path}: ${error.message}`);\n35\t          }\n36\t        }\n37\t      }\n38\t\n39\t      process.exitCode = result.status === 'pass' ? 0 : 1;\n40\t    });\n41\t\n42\t  registerValidateSchemaCommand(validateCmd);\n43\t  registerValidateSelfCommand(validateCmd);\n44\t}\n45\t"}]},"parent_tool_use_id":"toolu_01DuVFpc4kAp6TjMAncLaYvJ","session_id":"5fca15c0-771e-463c-9e4f-c528b230e359","uuid":"d731d706-8457-4c10-8634-e5ad7b114a64","timestamp":"2026-04-02T14:57:40.664Z"}
