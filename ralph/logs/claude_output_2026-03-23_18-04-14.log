n   133→    <action if=\"story file inaccessible\">HALT: \"Cannot develop story without access to story file\"</action>\n   134→    <action if=\"incomplete task or subtask requirements ambiguous\">ASK user to clarify or HALT</action>\n   135→  </step>\n   136→\n   137→  <step n=\"2\" goal=\"Load project context and story information\">\n   138→    <critical>Load all available context to inform implementation</critical>\n   139→\n   140→    <action>Load {project_context} for coding standards and project-wide patterns (if exists)</action>\n   141→    <action>Parse sections: Story, Acceptance Criteria, Tasks/Subtasks, Dev Notes, Dev Agent Record, File List, Change Log, Status</action>\n   142→    <action>Load comprehensive context from story file's Dev Notes section</action>\n   143→    <action>Extract developer guidance from Dev Notes: architecture requirements, previous learnings, technical specifications</action>\n   144→    <action>Use enhanced story context to inform implementation decisions and approaches</action>\n   145→    <output>✅ **Context Loaded**\n   146→      Story and project context available for implementation\n   147→    </output>\n   148→  </step>\n   149→\n   150→  <step n=\"3\" goal=\"Detect review continuation and extract review context\">\n   151→    <critical>Determine if this is a fresh start or continuation after code review</critical>\n   152→\n   153→    <action>Check if \"Senior Developer Review (AI)\" section exists in the story file</action>\n   154→    <action>Check if \"Review Follow-ups (AI)\" subsection exists under Tasks/Subtasks</action>\n   155→\n   156→    <check if=\"Senior Developer Review section exists\">\n   157→      <action>Set review_continuation = true</action>\n   158→      <action>Extract from \"Senior Developer Review (AI)\" section:\n   159→        - Review outcome (Approve/Changes Requested/Blocked)\n   160→        - Review date\n   161→        - Total action items with checkboxes (count checked vs unchecked)\n   162→        - Severity breakdown (High/Med/Low counts)\n   163→      </action>\n   164→      <action>Count unchecked [ ] review follow-up tasks in \"Review Follow-ups (AI)\" subsection</action>\n   165→      <action>Store list of unchecked review items as {{pending_review_items}}</action>\n   166→\n   167→      <output>⏯️ **Resuming Story After Code Review** ({{review_date}})\n   168→\n   169→        **Review Outcome:** {{review_outcome}}\n   170→        **Action Items:** {{unchecked_review_count}} remaining to address\n   171→        **Priorities:** {{high_count}} High, {{med_count}} Medium, {{low_count}} Low\n   172→\n   173→        **Strategy:** Will prioritize review follow-up tasks (marked [AI-Review]) before continuing with regular tasks.\n   174→      </output>\n   175→    </check>\n   176→\n   177→    <check if=\"Senior Developer Review section does NOT exist\">\n   178→      <action>Set review_continuation = false</action>\n   179→      <action>Set {{pending_review_items}} = empty</action>\n   180→\n   181→      <output>🚀 **Starting Fresh Implementation**\n   182→\n   183→        Story: {{story_key}}\n   184→        Story Status: {{current_status}}\n   185→        First incomplete task: {{first_task_description}}\n   186→      </output>\n   187→    </check>\n   188→  </step>\n   189→\n   190→  <step n=\"4\" goal=\"Mark story in-progress\" tag=\"sprint-status\">\n   191→    <check if=\"{{sprint_status}} file exists\">\n   192→      <action>Load the FULL file: {{sprint_status}}</action>\n   193→      <action>Read all development_status entries to find {{story_key}}</action>\n   194→      <action>Get current status value for development_status[{{story_key}}]</action>\n   195→\n   196→      <check if=\"current status == 'ready-for-dev' OR review_continuation == true\">\n   197→        <action>Update the story in the sprint status report to = \"in-progress\"</action>\n   198→        <output>🚀 Starting work on story {{story_key}}\n   199→          Status updated: ready-for-dev → in-progress\n   200→        </output>\n   201→      </check>\n   202→\n   203→      <check if=\"current status == 'in-progress'\">\n   204→        <output>⏯️ Resuming work on story {{story_key}}\n   205→          Story is already marked in-progress\n   206→        </output>\n   207→      </check>\n   208→\n   209→      <check if=\"current status is neither ready-for-dev nor in-progress\">\n   210→        <output>⚠️ Unexpected story status: {{current_status}}\n   211→          Expected ready-for-dev or in-progress. Continuing anyway...\n   212→        </output>\n   213→      </check>\n   214→\n   215→      <action>Store {{current_sprint_status}} for later use</action>\n   216→    </check>\n   217→\n   218→    <check if=\"{{sprint_status}} file does NOT exist\">\n   219→      <output>ℹ️ No sprint status file exists - story progress will be tracked in story file only</output>\n   220→      <action>Set {{current_sprint_status}} = \"no-sprint-tracking\"</action>\n   221→    </check>\n   222→  </step>\n   223→\n   224→  <step n=\"5\" goal=\"Implement task following red-green-refactor cycle\">\n   225→    <critical>FOLLOW THE STORY FILE TASKS/SUBTASKS SEQUENCE EXACTLY AS WRITTEN - NO DEVIATION</critical>\n   226→\n   227→    <action>Review the current task/subtask from the story file - this is your authoritative implementation guide</action>\n   228→    <action>Plan implementation following red-green-refactor cycle</action>\n   229→\n   230→    <!-- RED PHASE -->\n   231→    <action>Write FAILING tests first for the task/subtask functionality</action>\n   232→    <action>Confirm tests fail before implementation - this validates test correctness</action>\n   233→\n   234→    <!-- GREEN PHASE -->\n   235→    <action>Implement MINIMAL code to make tests pass</action>\n   236→    <action>Run tests to confirm they now pass</action>\n   237→    <action>Handle error conditions and edge cases as specified in task/subtask</action>\n   238→\n   239→    <!-- REFACTOR PHASE -->\n   240→    <action>Improve code structure while keeping tests green</action>\n   241→    <action>Ensure code follows architecture patterns and coding standards from Dev Notes</action>\n   242→\n   243→    <action>Document technical approach and decisions in Dev Agent Record → Implementation Plan</action>\n   244→\n   245→    <action if=\"new dependencies required beyond story specifications\">HALT: \"Additional dependencies need user approval\"</action>\n   246→    <action if=\"3 consecutive implementation failures occur\">HALT and request guidance</action>\n   247→    <action if=\"required configuration is missing\">HALT: \"Cannot proceed without necessary configuration files\"</action>\n   248→\n   249→    <critical>NEVER implement anything not mapped to a specific task/subtask in the story file</critical>\n   250→    <critical>NEVER proceed to next task until current task/subtask is complete AND tests pass</critical>\n   251→    <critical>Execute continuously without pausing until all tasks/subtasks are complete or explicit HALT condition</critical>\n   252→    <critical>Do NOT propose to pause for review until Step 9 completion gates are satisfied</critical>\n   253→  </step>\n   254→\n   255→  <!-- CODEHARNESS-PATCH-START:dev-enforcement -->\n   256→  <step n=\"5.5\" goal=\"Harness enforcement gates\">\n   257→    <critical>Codeharness requires these checks before proceeding to tests</critical>\n   258→    <action>Verify AGENTS.md files are updated for all modules touched during implementation</action>\n   259→    <action>Create or update exec-plan in docs/exec-plans/active/ for this story</action>\n   260→    <action>Ensure all new code has appropriate test stubs before writing full tests</action>\n   261→    <action>Run `codeharness coverage` to execute tests with coverage and set session flags (tests_passed, coverage_met)</action>\n   262→    <action>If codeharness coverage is not installed or fails, fall back to running test suite manually and verify 100% coverage target</action>\n   263→    <action if=\"tests_passed is false\">HALT: \"Tests failed — fix tests before continuing\"</action>\n   264→    <action if=\"coverage_met is false\">HALT: \"Coverage target not met — add tests before continuing\"</action>\n   265→  </step>\n   266→  <!-- CODEHARNESS-PATCH-END:dev-enforcement -->\n   267→\n   268→  <step n=\"6\" goal=\"Author comprehensive tests\">\n   269→    <action>Create unit tests for business logic and core functionality introduced/changed by the task</action>\n   270→    <action>Add integration tests for component interactions specified in story requirements</action>\n   271→    <action>Include end-to-end tests for critical user flows when story requirements demand them</action>\n   272→    <action>Cover edge cases and error handling scenarios identified in story Dev Notes</action>\n   273→  </step>\n   274→\n   275→  <step n=\"7\" goal=\"Run validations and tests\">\n   276→    <action>Determine how to run tests for this repo (infer test framework from project structure)</action>\n   277→    <action>Run all existing tests to ensure no regressions</action>\n   278→    <action>Run the new tests to verify implementation correctness</action>\n   279→    <action>Run linting and code quality checks if configured in project</action>\n   280→    <action>Validate implementation meets ALL story acceptance criteria; enforce quantitative thresholds explicitly</action>\n   281→    <action if=\"regression tests fail\">STOP and fix before continuing - identify breaking changes immediately</action>\n   282→    <action if=\"new tests fail\">STOP and fix before continuing - ensure implementation correctness</action>\n   283→  </step>\n   284→\n   285→  <step n=\"8\" goal=\"Validate and mark task complete ONLY when fully done\">\n   286→    <critical>NEVER mark a task complete unless ALL conditions are met - NO LYING OR CHEATING</critical>\n   287→\n   288→    <!-- VALIDATION GATES -->\n   289→    <action>Verify ALL tests for this task/subtask ACTUALLY EXIST and PASS 100%</action>\n   290→    <action>Confirm implementation matches EXACTLY what the task/subtask specifies - no extra features</action>\n   291→    <action>Validate that ALL acceptance criteria related to this task are satisfied</action>\n   292→    <action>Run full test suite to ensure NO regressions introduced</action>\n   293→\n   294→    <!-- REVIEW FOLLOW-UP HANDLING -->\n   295→    <check if=\"task is review follow-up (has [AI-Review] prefix)\">\n   296→      <action>Extract review item details (severity, description, related AC/file)</action>\n   297→      <action>Add to resolution tracking list: {{resolved_review_items}}</action>\n   298→\n   299→      <!-- Mark task in Review Follow-ups section -->\n   300→      <action>Mark task checkbox [x] in \"Tasks/Subtasks → Review Follow-ups (AI)\" section</action>\n   301→\n   302→      <!-- CRITICAL: Also mark corresponding action item in review section -->\n   303→      <action>Find matching action item in \"Senior Developer Review (AI) → Action Items\" section by matching description</action>\n   304→      <action>Mark that action item checkbox [x] as resolved</action>\n   305→\n   306→      <action>Add to Dev Agent Record → Completion Notes: \"✅ Resolved review finding [{{severity}}]: {{description}}\"</action>\n   307→    </check>\n   308→\n   309→    <!-- ONLY MARK COMPLETE IF ALL VALIDATION PASS -->\n   310→    <check if=\"ALL validation gates pass AND tests ACTUALLY exist and pass\">\n   311→      <action>ONLY THEN mark the task (and subtasks) checkbox with [x]</action>\n   312→      <action>Update File List section with ALL new, modified, or deleted files (paths relative to repo root)</action>\n   313→      <action>Add completion notes to Dev Agent Record summarizing what was ACTUALLY implemented and tested</action>\n   314→    </check>\n   315→\n   316→    <check if=\"ANY validation fails\">\n   317→      <action>DO NOT mark task complete - fix issues first