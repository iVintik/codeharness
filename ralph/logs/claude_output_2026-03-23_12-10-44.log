{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LimvVTDWv6ouwGETd67Rvk","type":"tool_result","content":"     1→/**\n     2→ * Documentation scaffolding for project initialization.\n     3→ * Generates AGENTS.md, docs/ directory structure, and README.md.\n     4→ */\n     5→\n     6→import { existsSync, readFileSync } from 'node:fs';\n     7→import { join, basename } from 'node:path';\n     8→import { ok as okOutput } from '../../lib/output.js';\n     9→import { generateFile } from '../../lib/templates.js';\n    10→import { readmeTemplate } from '../../templates/readme.js';\n    11→import type { Result } from '../../types/result.js';\n    12→import { ok, fail } from '../../types/result.js';\n    13→import type { InitDocumentationResult } from './types.js';\n    14→\n    15→const DO_NOT_EDIT_HEADER = '<!-- DO NOT EDIT MANUALLY -->\\n';\n    16→\n    17→export function getProjectName(projectDir: string): string {\n    18→  try {\n    19→    const pkgPath = join(projectDir, 'package.json');\n    20→    if (existsSync(pkgPath)) {\n    21→      const pkg = JSON.parse(readFileSync(pkgPath, 'utf-8')) as Record<string, unknown>;\n    22→      if (pkg.name && typeof pkg.name === 'string') {\n    23→        return pkg.name;\n    24→      }\n    25→    }\n    26→  } catch {\n    27→    // Fall through to basename\n    28→  }\n    29→  return basename(projectDir);\n    30→}\n    31→\n    32→export function getStackLabel(stack: string | null): string {\n    33→  if (stack === 'nodejs') return 'Node.js (package.json)';\n    34→  if (stack === 'python') return 'Python';\n    35→  if (stack === 'rust') return 'Rust (Cargo.toml)';\n    36→  return 'Unknown';\n    37→}\n    38→\n    39→export function getCoverageTool(stack: string | null): 'c8' | 'coverage.py' | 'cargo-tarpaulin' | 'unknown' {\n    40→  if (stack === 'python') return 'coverage.py';\n    41→  if (stack === 'rust') return 'cargo-tarpaulin';\n    42→  return 'c8';\n    43→}\n    44→\n    45→export function generateAgentsMdContent(projectDir: string, stack: string | null): string {\n    46→  const projectName = basename(projectDir);\n    47→  const stackLabel = stack === 'nodejs' ? 'Node.js' : stack === 'python' ? 'Python' : stack === 'rust' ? 'Rust' : 'Unknown';\n    48→\n    49→  const lines = [\n    50→    `# ${projectName}`,\n    51→    '',\n    52→    '## Stack',\n    53→    '',\n    54→    `- **Language/Runtime:** ${stackLabel}`,\n    55→    '',\n    56→    '## Build & Test Commands',\n    57→    '',\n    58→  ];\n    59→\n    60→  if (stack === 'nodejs') {\n    61→    lines.push(\n    62→      '```bash',\n    63→      'npm install    # Install dependencies',\n    64→      'npm run build  # Build the project',\n    65→      'npm test       # Run tests',\n    66→      '```',\n    67→    );\n    68→  } else if (stack === 'python') {\n    69→    lines.push(\n    70→      '```bash',\n    71→      'pip install -r requirements.txt  # Install dependencies',\n    72→      'python -m pytest                 # Run tests',\n    73→      '```',\n    74→    );\n    75→  } else if (stack === 'rust') {\n    76→    lines.push(\n    77→      '```bash',\n    78→      'cargo build    # Build the project',\n    79→      'cargo test     # Run tests',\n    80→      'cargo tarpaulin --out json  # Run coverage',\n    81→      '```',\n    82→    );\n    83→  } else {\n    84→    lines.push('```bash', '# No recognized stack — add build/test commands here', '```');\n    85→  }\n    86→\n    87→  lines.push(\n    88→    '',\n    89→    '## Project Structure',\n    90→    '',\n    91→    '```',\n    92→    `${projectName}/`,\n    93→    '├── src/           # Source code',\n    94→    '├── tests/         # Test files',\n    95→    '├── docs/          # Documentation',\n    96→    '└── .claude/       # Codeharness state',\n    97→    '```',\n    98→    '',\n    99→    '## Conventions',\n   100→    '',\n   101→    '- All changes must pass tests before commit',\n   102→    '- Maintain test coverage targets',\n   103→    '- Follow existing code style and patterns',\n   104→    '',\n   105→  );\n   106→\n   107→  return lines.join('\\n');\n   108→}\n   109→\n   110→export function generateDocsIndexContent(): string {\n   111→  return [\n   112→    '# Project Documentation',\n   113→    '',\n   114→    '## Planning Artifacts',\n   115→    '- [Product Requirements](../_bmad-output/planning-artifacts/prd.md)',\n   116→    '- [Architecture](../_bmad-output/planning-artifacts/architecture.md)',\n   117→    '- [Epics & Stories](../_bmad-output/planning-artifacts/epics.md)',\n   118→    '',\n   119→    '## Execution',\n   120→    '- [Active Exec Plans](exec-plans/active/)',\n   121→    '- [Completed Exec Plans](exec-plans/completed/)',\n   122→    '',\n   123→    '## Quality',\n   124→    '- [Quality Reports](quality/)',\n   125→    '- [Generated Reports](generated/)',\n   126→    '',\n   127→  ].join('\\n');\n   128→}\n   129→\n   130→interface ScaffoldDocsOptions {\n   131→  readonly projectDir: string;\n   132→  readonly stack: string | null;\n   133→  readonly isJson: boolean;\n   134→}\n   135→\n   136→export async function scaffoldDocs(opts: ScaffoldDocsOptions): Promise<Result<InitDocumentationResult>> {\n   137→  try {\n   138→    let agentsMd: 'created' | 'exists' | 'skipped' = 'skipped';\n   139→    let docsScaffold: 'created' | 'exists' | 'skipped' = 'skipped';\n   140→    let readme: 'created' | 'exists' | 'skipped' = 'skipped';\n   141→\n   142→    // AGENTS.md\n   143→    const agentsMdPath = join(opts.projectDir, 'AGENTS.md');\n   144→    if (!existsSync(agentsMdPath)) {\n   145→      const content = generateAgentsMdContent(opts.projectDir, opts.stack);\n   146→      generateFile(agentsMdPath, content);\n   147→      agentsMd = 'created';\n   148→    } else {\n   149→      agentsMd = 'exists';\n   150→    }\n   151→\n   152→    // docs/ scaffold\n   153→    const docsDir = join(opts.projectDir, 'docs');\n   154→    if (!existsSync(docsDir)) {\n   155→      generateFile(join(docsDir, 'index.md'), generateDocsIndexContent());\n   156→      generateFile(join(docsDir, 'exec-plans', 'active', '.gitkeep'), '');\n   157→      generateFile(join(docsDir, 'exec-plans', 'completed', '.gitkeep'), '');\n   158→      generateFile(join(docsDir, 'quality', '.gitkeep'), DO_NOT_EDIT_HEADER);\n   159→      generateFile(join(docsDir, 'generated', '.gitkeep'), DO_NOT_EDIT_HEADER);\n   160→      docsScaffold = 'created';\n   161→    } else {\n   162→      docsScaffold = 'exists';\n   163→    }\n   164→\n   165→    // README.md\n   166→    const readmePath = join(opts.projectDir, 'README.md');\n   167→    if (!existsSync(readmePath)) {\n   168→      let cliHelpOutput = '';\n   169→      try {\n   170→        const { execFileSync } = await import('node:child_process');\n   171→        cliHelpOutput = execFileSync(process.execPath, [process.argv[1], '--help'], {\n   172→          stdio: 'pipe',\n   173→          timeout: 10_000,\n   174→        }).toString();\n   175→      } catch {\n   176→        cliHelpOutput = 'Run: codeharness --help';\n   177→      }\n   178→\n   179→      const readmeContent = readmeTemplate({\n   180→        projectName: getProjectName(opts.projectDir),\n   181→        stack: opts.stack,\n   182→        cliHelpOutput,\n   183→      });\n   184→      generateFile(readmePath, readmeContent);\n   185→      readme = 'created';\n   186→    } else {\n   187→      readme = 'exists';\n   188→    }\n   189→\n   190→    const result: InitDocumentationResult = { agents_md: agentsMd, docs_scaffold: docsScaffold, readme };\n   191→\n   192→    if (!opts.isJson) {\n   193→      if (result.agents_md === 'created' || result.docs_scaffold === 'created') {\n   194→        okOutput('Documentation: AGENTS.md + docs/ scaffold created');\n   195→      }\n   196→      if (result.readme === 'created') {\n   197→        okOutput('Documentation: README.md created');\n   198→      }\n   199→    }\n   200→\n   201→    return ok(result);\n   202→  } catch (err) {\n   203→    const message = err instanceof Error ? err.message : String(err);\n   204→    return fail(`Documentation scaffold failed: ${message}`);\n   205→  }\n   206→}\n   207→"}]},"parent_tool_use_id":"toolu_01336KmdyUhUpLqN2MJiCgMY","session_id":"9c50fb69-0476-4a5d-8998-78fcdfa47c24","uuid":"9a3a870f-1c36-47f9-aeaf-b7b7411b65ea","timestamp":"2026-03-23T08:12:00.632Z"}
