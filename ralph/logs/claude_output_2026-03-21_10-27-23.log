{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Qp6DLKAyCSrK77GBZ3zryo","type":"tool_result","content":"     1→import { describe, it, expect, beforeAll } from 'vitest';\n     2→import { readFileSync } from 'node:fs';\n     3→import { resolve } from 'node:path';\n     4→import { verifyPromptTemplate } from '../../../templates/verify-prompt.js';\n     5→import { parseObservabilityGaps } from '../parser.js';\n     6→\n     7→const ROOT = resolve(__dirname, '..', '..', '..', '..');\n     8→\n     9→let verifyPatch: string;\n    10→\n    11→beforeAll(() => {\n    12→  verifyPatch = readFileSync(\n    13→    resolve(ROOT, 'patches/verify/story-verification.md'),\n    14→    'utf-8',\n    15→  );\n    16→});\n    17→\n    18→// ============================================================\n    19→// Task 6 / AC #1: Patch content validation\n    20→// ============================================================\n    21→\n    22→describe('patches/verify/story-verification.md — Observability Evidence section', () => {\n    23→  it('contains ### Observability Evidence heading', () => {\n    24→    expect(verifyPatch).toContain('### Observability Evidence');\n    25→  });\n    26→\n    27→  it('instructs to query observability backend after each docker exec command', () => {\n    28→    expect(verifyPatch).toContain('After each `docker exec` command');\n    29→    expect(verifyPatch).toContain('query the observability backend');\n    30→    expect(verifyPatch).toContain('log events from the last 30 seconds');\n    31→  });\n    32→\n    33→  it('contains [OBSERVABILITY GAP] tagging instruction', () => {\n    34→    expect(verifyPatch).toContain('[OBSERVABILITY GAP]');\n    35→    expect(verifyPatch).toContain(\n    36→      '[OBSERVABILITY GAP] No log events detected for this user interaction',\n    37→    );\n    38→  });\n    39→\n    40→  it('instructs that observability check failure does not block verification', () => {\n    41→    expect(verifyPatch).toContain('observability check skipped — backend not reachable');\n    42→    expect(verifyPatch).toContain('do NOT fail the verification');\n    43→  });\n    44→\n    45→  it('references the VictoriaLogs query pattern from verify-prompt.ts', () => {\n    46→    expect(verifyPatch).toContain('verify-prompt.ts');\n    47→    expect(verifyPatch).toContain(\n    48→      \"curl 'http://localhost:9428/select/logsql/query?query=_stream_id:*&start=-30s&limit=100'\",\n    49→    );\n    50→  });\n    51→\n    52→  it('instructs proof documents to include both functional and observability evidence', () => {\n    53→    expect(verifyPatch).toContain('functional evidence');\n    54→    expect(verifyPatch).toContain('observability evidence');\n    55→  });\n    56→});\n    57→\n    58→// ============================================================\n    59→// Task 2 / AC #2: verify-prompt.ts already contains observability instructions\n    60→// ============================================================\n    61→\n    62→describe('verify-prompt.ts — observability check regression tests', () => {\n    63→  const baseConfig = {\n    64→    storyKey: 'test-story',\n    65→    storyContent: '# Test Story\\n\\n## Acceptance Criteria\\n\\n1. AC one',\n    66→  };\n    67→\n    68→  it('contains Step 3.5: Observability Check After Each Command section', () => {\n    69→    const prompt = verifyPromptTemplate(baseConfig);\n    70→    expect(prompt).toContain('Step 3.5: Observability Check After Each Command');\n    71→  });\n    72→\n    73→  it('includes VictoriaLogs query URL with default endpoint', () => {\n    74→    const prompt = verifyPromptTemplate(baseConfig);\n    75→    expect(prompt).toContain(\n    76→      \"curl 'http://localhost:9428/select/logsql/query?query=_stream_id:*&start=-30s&limit=100'\",\n    77→    );\n    78→  });\n    79→\n    80→  it('includes [OBSERVABILITY GAP] tagging instruction in the prompt', () => {\n    81→    const prompt = verifyPromptTemplate(baseConfig);\n    82→    expect(prompt).toContain('[OBSERVABILITY GAP]');\n    83→    expect(prompt).toContain('No log events detected for this user interaction');\n    84→  });\n    85→\n    86→  it('uses configured VictoriaLogs endpoint in observability query', () => {\n    87→    const prompt = verifyPromptTemplate({\n    88→      ...baseConfig,\n    89→      observabilityEndpoints: {\n    90→        victoriaLogs: 'http://custom:9999',\n    91→      },\n    92→    });\n    93→    expect(prompt).toContain(\n    94→      \"curl 'http://custom:9999/select/logsql/query?query=_stream_id:*&start=-30s&limit=100'\",\n    95→    );\n    96→  });\n    97→});\n    98→\n    99→// ============================================================\n   100→// Task 3 / AC #3: parseObservabilityGaps with specific AC counts\n   101→// ============================================================\n   102→\n   103→describe('parseObservabilityGaps — Story 5.2 acceptance criteria', () => {\n   104→  it('returns totalACs:8, gapCount:2, coveredCount:6 for 8 ACs with 2 gaps (AC #3)', () => {\n   105→    const proof = [\n   106→      '## AC 1: Feature one\\n\\nEvidence here.\\n',\n   107→      '## AC 2: Feature two\\n\\nEvidence here.\\n',\n   108→      '## AC 3: Feature three\\n\\n[OBSERVABILITY GAP] No log events detected for this user interaction\\n',\n   109→      '## AC 4: Feature four\\n\\nEvidence here.\\n',\n   110→      '## AC 5: Feature five\\n\\nEvidence here.\\n',\n   111→      '## AC 6: Feature six\\n\\n[OBSERVABILITY GAP] No log events detected for this user interaction\\n',\n   112→      '## AC 7: Feature seven\\n\\nEvidence here.\\n',\n   113→      '## AC 8: Feature eight\\n\\nEvidence here.\\n',\n   114→    ].join('\\n');\n   115→\n   116→    const result = parseObservabilityGaps(proof);\n   117→\n   118→    expect(result.totalACs).toBe(8);\n   119→    expect(result.gapCount).toBe(2);\n   120→    expect(result.coveredCount).toBe(6);\n   121→  });\n   122→\n   123→  it('reports 75% runtime observability coverage for 6/8 ACs covered', () => {\n   124→    const proof = [\n   125→      '## AC 1: F1\\n\\nOK\\n',\n   126→      '## AC 2: F2\\n\\nOK\\n',\n   127→      '## AC 3: F3\\n\\n[OBSERVABILITY GAP] No log events detected for this user interaction\\n',\n   128→      '## AC 4: F4\\n\\nOK\\n',\n   129→      '## AC 5: F5\\n\\nOK\\n',\n   130→      '## AC 6: F6\\n\\n[OBSERVABILITY GAP] No log events detected for this user interaction\\n',\n   131→      '## AC 7: F7\\n\\nOK\\n',\n   132→      '## AC 8: F8\\n\\nOK\\n',\n   133→    ].join('\\n');\n   134→\n   135→    const result = parseObservabilityGaps(proof);\n   136→    const coveragePercent =\n   137→      result.totalACs === 0\n   138→        ? 0\n   139→        : (result.coveredCount / result.totalACs) * 100;\n   140→\n   141→    expect(coveragePercent).toBe(75);\n   142→  });\n   143→\n   144→  it('returns zero gaps when all ACs are clean', () => {\n   145→    const proof = [\n   146→      '## AC 1: F1\\n\\nEvidence.\\n',\n   147→      '## AC 2: F2\\n\\nEvidence.\\n',\n   148→      '## AC 3: F3\\n\\nEvidence.\\n',\n   149→    ].join('\\n');\n   150→\n   151→    const result = parseObservabilityGaps(proof);\n   152→\n   153→    expect(result.totalACs).toBe(3);\n   154→    expect(result.gapCount).toBe(0);\n   155→    expect(result.coveredCount).toBe(3);\n   156→  });\n   157→\n   158→  it('returns all gaps when every AC has an observability gap', () => {\n   159→    const proof = [\n   160→      '## AC 1: F1\\n\\n[OBSERVABILITY GAP] No log events detected for this user interaction\\n',\n   161→      '## AC 2: F2\\n\\n[OBSERVABILITY GAP] No log events detected for this user interaction\\n',\n   162→      '## AC 3: F3\\n\\n[OBSERVABILITY GAP] No log events detected for this user interaction\\n',\n   163→    ].join('\\n');\n   164→\n   165→    const result = parseObservabilityGaps(proof);\n   166→\n   167→    expect(result.totalACs).toBe(3);\n   168→    expect(result.gapCount).toBe(3);\n   169→    expect(result.coveredCount).toBe(0);\n   170→  });\n   171→});\n   172→\n   173→// ============================================================\n   174→// Task 4 / AC #4: verifyStory reports observability alongside functional results\n   175→// ============================================================\n   176→\n   177→describe('VerifyResult observability fields — structural contract', () => {\n   178→  it('observabilityGapCount and runtimeCoveragePercent are defined on VerifyResult type', () => {\n   179→    // Import the type and construct a value to prove the fields exist\n   180→    const result = {\n   181→      storyId: 'test',\n   182→      success: true,\n   183→      totalACs: 4,\n   184→      verifiedCount: 4,\n   185→      failedCount: 0,\n   186→      escalatedCount: 0,\n   187→      proofPath: 'verification/test-proof.md',\n   188→      showboatVerifyStatus: 'pass' as const,\n   189→      observabilityGapCount: 1,\n   190→      runtimeCoveragePercent: 75,\n   191→      perAC: [],\n   192→    };\n   193→\n   194→    // These must be present — type-level proof\n   195→    expect(result.observabilityGapCount).toBe(1);\n   196→    expect(result.runtimeCoveragePercent).toBe(75);\n   197→  });\n   198→});\n   199→\n   200→// ============================================================\n   201→// Task 5 / AC #5: saveRuntimeCoverage persists under observability.runtime\n   202→// ============================================================\n   203→\n   204→describe('runtime coverage state structure — contract test', () => {\n   205→  it('computeRuntimeCoverage produces coveragePercent from gap results', async () => {\n   206→    // Dynamic import to avoid conflicting with mocked tests in other files\n   207→    const { computeRuntimeCoverage } = await import(\n   208→      '../../observability/runtime-coverage.js'\n   209→    );\n   210→\n   211→    const gapResult = {\n   212→      entries: [\n   213→        { acId: '1', hasGap: false },\n   214→        { acId: '2', hasGap: false },\n   215→        { acId: '3', hasGap: true, gapNote: 'No log events detected for this user interaction' },\n   216→        { acId: '4', hasGap: false },\n   217→      ],\n   218→      totalACs: 4,\n   219→      gapCount: 1,\n   220→      coveredCount: 3,\n   221→    };\n   222→\n   223→    const result = computeRuntimeCoverage(gapResult);\n   224→\n   225→    expect(result.coveragePercent).toBe(75);\n   226→    expect(result.totalACs).toBe(4);\n   227→    expect(result.acsWithLogs).toBe(3);\n   228→    expect(result.entries).toHaveLength(4);\n   229→    expect(result.entries[2].logEventsDetected).toBe(false);\n   230→    expect(result.entries[0].logEventsDetected).toBe(true);\n   231→  });\n   232→});\n   233→"}]},"parent_tool_use_id":"toolu_01St1ZX8VZKJ5rWiDeuqc1Kp","session_id":"63766b2b-ee05-46af-a819-a3f0370845d2","uuid":"c6188f5e-e5a2-44d8-9405-d571089231de","timestamp":"2026-03-21T06:36:57.370Z"}
