{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Sp1ZkY24NxnBSD738moKHW","type":"tool_result","content":"1\timport Ajv from 'ajv';\n2\timport workflowSchema from '../schemas/workflow.schema.json';\n3\timport agentSchema from '../schemas/agent.schema.json';\n4\t\n5\t// --- Interfaces ---\n6\t\n7\texport interface ValidationError {\n8\t  path: string;\n9\t  message: string;\n10\t  keyword: string;\n11\t}\n12\t\n13\texport interface ValidationResult {\n14\t  valid: boolean;\n15\t  errors: ValidationError[];\n16\t}\n17\t\n18\t// --- Validation ---\n19\t\n20\tconst ajv = new Ajv({ allErrors: true });\n21\tconst validateWorkflow = ajv.compile(workflowSchema);\n22\tconst validateAgent = ajv.compile(agentSchema);\n23\t\n24\t/**\n25\t * Validate data against a JSON schema.\n26\t * Schema-agnostic: pass any compiled Ajv ValidateFunction.\n27\t */\n28\texport function validateAgainstSchema(\n29\t  data: unknown,\n30\t  validate: ReturnType<typeof ajv.compile>,\n31\t): ValidationResult {\n32\t  const valid = validate(data);\n33\t\n34\t  if (valid) {\n35\t    return { valid: true, errors: [] };\n36\t  }\n37\t\n38\t  const errors: ValidationError[] = (validate.errors ?? []).map((err) => ({\n39\t    path: err.instancePath || '/',\n40\t    message: err.message ?? 'Unknown validation error',\n41\t    keyword: err.keyword,\n42\t  }));\n43\t\n44\t  return { valid: false, errors };\n45\t}\n46\t\n47\t/**\n48\t * Validate data against the workflow YAML schema.\n49\t * Primary entry point for workflow validation.\n50\t */\n51\texport function validateWorkflowSchema(data: unknown): ValidationResult {\n52\t  return validateAgainstSchema(data, validateWorkflow);\n53\t}\n54\t\n55\t/**\n56\t * Validate data against the agent configuration schema.\n57\t * Primary entry point for agent config validation.\n58\t */\n59\texport function validateAgentSchema(data: unknown): ValidationResult {\n60\t  return validateAgainstSchema(data, validateAgent);\n61\t}\n62\t"}]},"parent_tool_use_id":"toolu_0155tz15CzD1ijXDNcEpYygc","session_id":"87824d62-8d3a-42e8-9563-dae1782fbf60","uuid":"80c2ad40-2865-4a75-807e-d4f52073eee0","timestamp":"2026-04-02T15:39:41.532Z"}
