{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01JdxsiEu1YBWKLiSzXDpNxb","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Av13iK5MjV9wA2VFoYarrE","name":"Read","input":{"file_path":"/Users/ivintik/dev/personal/codeharness/src/lib/__tests__/ink-renderer.test.tsx"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":10985,"cache_read_input_tokens":22003,"cache_creation":{"ephemeral_5m_input_tokens":10985,"ephemeral_1h_input_tokens":0},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01V53hNpMF7bCUCk5waNmUeL","session_id":"3e8c45fc-a757-4d77-9a55-f32a41bfdb65","uuid":"885f0afb-4b5f-462f-98d4-5f065cfe8df0"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Av13iK5MjV9wA2VFoYarrE","type":"tool_result","content":"     1→import { describe, it, expect, afterEach, vi } from 'vitest';\n     2→import { render } from 'ink-testing-library';\n     3→import React from 'react';\n     4→import { startRenderer } from '../ink-renderer.js';\n     5→import type { RendererHandle } from '../ink-renderer.js';\n     6→import type { StreamEvent } from '../stream-parser.js';\n     7→import {\n     8→  App,\n     9→  Header,\n    10→  CompletedTool,\n    11→  ActiveTool,\n    12→  LastThought,\n    13→  RetryNotice,\n    14→  StoryBreakdown,\n    15→  StoryMessageLine,\n    16→  type RendererState,\n    17→  type SprintInfo,\n    18→  type CompletedToolEntry,\n    19→  type StoryStatusEntry,\n    20→  type StoryMessage,\n    21→} from '../ink-components.js';\n    22→\n    23→// --- Helpers ---\n    24→\n    25→function makeState(overrides?: Partial<RendererState>): RendererState {\n    26→  return {\n    27→    sprintInfo: null,\n    28→    stories: [],\n    29→    messages: [],\n    30→    completedTools: [],\n    31→    activeTool: null,\n    32→    activeToolArgs: '',\n    33→    lastThought: null,\n    34→    retryInfo: null,\n    35→    ...overrides,\n    36→  };\n    37→}\n    38→\n    39→// --- Component Tests (using ink-testing-library) ---\n    40→\n    41→describe('Header component', () => {\n    42→  it('renders sprint info', () => {\n    43→    const info: SprintInfo = {\n    44→      storyKey: '0-5-3',\n    45→      phase: 'dev',\n    46→      done: 3,\n    47→      total: 10,\n    48→    };\n    49→    const { lastFrame } = render(<Header info={info} />);\n    50→    const frame = lastFrame();\n    51→    expect(frame).toContain('◆');\n    52→    expect(frame).toContain('0-5-3');\n    53→    expect(frame).toContain('dev');\n    54→    expect(frame).toContain('3/10');\n    55→  });\n    56→\n    57→  it('renders nothing when info is null', () => {\n    58→    const { lastFrame } = render(<Header info={null} />);\n    59→    expect(lastFrame()).toBe('');\n    60→  });\n    61→});\n    62→\n    63→describe('CompletedTool component', () => {\n    64→  it('renders tool name and args', () => {\n    65→    const entry: CompletedToolEntry = { name: 'Bash', args: 'ls -la' };\n    66→    const { lastFrame } = render(<CompletedTool entry={entry} />);\n    67→    const frame = lastFrame();\n    68→    expect(frame).toContain('✓');\n    69→    expect(frame).toContain('[Bash]');\n    70→    expect(frame).toContain('ls -la');\n    71→  });\n    72→\n    73→  it('truncates long args to 60 chars', () => {\n    74→    const longArgs = 'a'.repeat(100);\n    75→    const entry: CompletedToolEntry = { name: 'Write', args: longArgs };\n    76→    const { lastFrame } = render(<CompletedTool entry={entry} />);\n    77→    const frame = lastFrame()!;\n    78→    expect(frame).toContain('a'.repeat(60) + '…');\n    79→    expect(frame).not.toContain('a'.repeat(61));\n    80→  });\n    81→});\n    82→\n    83→describe('ActiveTool component', () => {\n    84→  it('renders tool name with lightning bolt', () => {\n    85→    const { lastFrame } = render(<ActiveTool name=\"Read\" />);\n    86→    const frame = lastFrame();\n    87→    expect(frame).toContain('⚡');\n    88→    expect(frame).toContain('[Read]');\n    89→  });\n    90→});\n    91→\n    92→describe('LastThought component', () => {\n    93→  it('renders thought text with brain emoji', () => {\n    94→    const { lastFrame } = render(<LastThought text=\"thinking about code\" />);\n    95→    const frame = lastFrame();\n    96→    expect(frame).toContain('💭');\n    97→    expect(frame).toContain('thinking about code');\n    98→  });\n    99→});\n   100→\n   101→describe('LastThought truncation', () => {\n   102→  it('handles emoji without splitting surrogate pairs', () => {\n   103→    // Emoji are multi-byte; truncation should not produce broken characters\n   104→    const text = '🎉🎊🎈🎁🎂'.repeat(20); // lots of emoji\n   105→    const { lastFrame } = render(<LastThought text={text} />);\n   106→    const frame = lastFrame()!;\n   107→    // Should contain the prefix and no broken characters\n   108→    expect(frame).toContain('💭');\n   109→    // Should not throw or produce garbage\n   110→    expect(frame).toBeDefined();\n   111→  });\n   112→});\n   113→\n   114→describe('RetryNotice component', () => {\n   115→  it('renders retry info', () => {\n   116→    const { lastFrame } = render(\n   117→      <RetryNotice info={{ attempt: 2, delay: 5000 }} />,\n   118→    );\n   119→    const frame = lastFrame();\n   120→    expect(frame).toContain('⏳');\n   121→    expect(frame).toContain('retry');\n   122→    expect(frame).toContain('2');\n   123→    expect(frame).toContain('5000');\n   124→  });\n   125→});\n   126→\n   127→describe('App component', () => {\n   128→  it('renders all elements when state is full', () => {\n   129→    const state = makeState({\n   130→      sprintInfo: { storyKey: '1-2-3', phase: 'dev', done: 1, total: 5 },\n   131→      completedTools: [{ name: 'Bash', args: 'echo hello' }],\n   132→      activeTool: { name: 'Read' },\n   133→      lastThought: 'analyzing...',\n   134→      retryInfo: null,\n   135→    });\n   136→    const { lastFrame } = render(<App state={state} />);\n   137→    const frame = lastFrame()!;\n   138→    expect(frame).toContain('1-2-3');\n   139→    expect(frame).toContain('✓');\n   140→    expect(frame).toContain('[Bash]');\n   141→    expect(frame).toContain('⚡');\n   142→    expect(frame).toContain('[Read]');\n   143→    expect(frame).toContain('💭');\n   144→    expect(frame).toContain('analyzing...');\n   145→  });\n   146→\n   147→  it('renders empty state without errors', () => {\n   148→    const state = makeState();\n   149→    const { lastFrame } = render(<App state={state} />);\n   150→    // Should not throw, frame can be empty\n   151→    expect(lastFrame()).toBeDefined();\n   152→  });\n   153→\n   154→  it('renders retry info when present', () => {\n   155→    const state = makeState({\n   156→      retryInfo: { attempt: 3, delay: 10000 },\n   157→    });\n   158→    const { lastFrame } = render(<App state={state} />);\n   159→    const frame = lastFrame()!;\n   160→    expect(frame).toContain('⏳');\n   161→    expect(frame).toContain('3');\n   162→  });\n   163→});\n   164→\n   165→// --- New component tests (Story 0.5.3 rework) ---\n   166→\n   167→describe('Header with elapsed time (AC #3)', () => {\n   168→  it('renders elapsed time when provided', () => {\n   169→    const info: SprintInfo = {\n   170→      storyKey: '3-2',\n   171→      phase: 'verify',\n   172→      done: 18,\n   173→      total: 65,\n   174→      elapsed: '47m',\n   175→    };\n   176→    const { lastFrame } = render(<Header info={info} />);\n   177→    const frame = lastFrame()!;\n   178→    expect(frame).toContain('◆');\n   179→    expect(frame).toContain('3-2');\n   180→    expect(frame).toContain('verify');\n   181→    expect(frame).toContain('47m');\n   182→    expect(frame).toContain('18/65');\n   183→  });\n   184→\n   185→  it('omits elapsed when not provided', () => {\n   186→    const info: SprintInfo = {\n   187→      storyKey: '1-1',\n   188→      phase: 'dev',\n   189→      done: 0,\n   190→      total: 5,\n   191→    };\n   192→    const { lastFrame } = render(<Header info={info} />);\n   193→    const frame = lastFrame()!;\n   194→    expect(frame).toContain('1-1');\n   195→    expect(frame).not.toContain('undefined');\n   196→  });\n   197→});\n   198→\n   199→describe('StoryBreakdown component (AC #4)', () => {\n   200→  it('renders done count and active stories', () => {\n   201→    const stories: StoryStatusEntry[] = [\n   202→      { key: '3-1-some-story', status: 'done' },\n   203→      { key: '4-1-another', status: 'done' },\n   204→      { key: '3-2-current', status: 'in-progress' },\n   205→      { key: '3-3-next-one', status: 'pending' },\n   206→      { key: '0-1-stuck', status: 'blocked' },\n   207→    ];\n   208→    const { lastFrame } = render(<StoryBreakdown stories={stories} />);\n   209→    const frame = lastFrame()!;\n   210→    // Done shows count\n   211→    expect(frame).toContain('2 ✓');\n   212→    expect(frame).toContain('done');\n   213→    expect(frame).not.toContain('3-1-some-story');\n   214→    // In-progress shows full key\n   215→    expect(frame).toContain('3-2-current');\n   216→    expect(frame).toContain('◆');\n   217→    // Pending shows short keys\n   218→    expect(frame).toContain('next:');\n   219→    expect(frame).toContain('3-3');\n   220→    // Blocked\n   221→    expect(frame).toContain('✕');\n   222→    expect(frame).toContain('0-1');\n   223→  });\n   224→\n   225→  it('renders nothing when stories array is empty', () => {\n   226→    const { lastFrame } = render(<StoryBreakdown stories={[]} />);\n   227→    expect(lastFrame()).toBe('');\n   228→  });\n   229→\n   230→  it('renders failed stories', () => {\n   231→    const stories: StoryStatusEntry[] = [\n   232→      { key: '2-3-broken', status: 'failed' },\n   233→    ];\n   234→    const { lastFrame } = render(<StoryBreakdown stories={stories} />);\n   235→    const frame = lastFrame()!;\n   236→    expect(frame).toContain('✗');\n   237→    expect(frame).toContain('2-3');\n   238→  });\n   239→\n   240→  it('truncates pending list to 3 with +N indicator', () => {\n   241→    const stories: StoryStatusEntry[] = [\n   242→      { key: '1-1-a', status: 'pending' },\n   243→      { key: '2-1-b', status: 'pending' },\n   244→      { key: '3-1-c', status: 'pending' },\n   245→      { key: '4-1-d', status: 'pending' },\n   246→      { key: '5-1-e', status: 'pending' },\n   247→    ];\n   248→    const { lastFrame } = render(<StoryBreakdown stories={stories} />);\n   249→    const frame = lastFrame()!;\n   250→    expect(frame).toContain('1-1');\n   251→    expect(frame).toContain('3-1');\n   252→    expect(frame).toContain('+2');\n   253→    expect(frame).not.toContain('4-1');\n   254→  });\n   255→});\n   256→\n   257→describe('StoryMessageLine component (AC #5, #6)', () => {\n   258→  it('renders [OK] message for completed story', () => {\n   259→    const msg: StoryMessage = { type: 'ok', key: '3-2', message: 'DONE — 12/12 ACs verified (18m, $4.20)' };\n   260→    const { lastFrame } = render(<StoryMessageLine msg={msg} />);\n   261→    const frame = lastFrame()!;\n   262→    expect(frame).toContain('[OK]');\n   263→    expect(frame).toContain('Story 3-2');\n   264→    expect(frame).toContain('DONE');\n   265→    expect(frame).toContain('12/12 ACs verified');\n   266→  });\n   267→\n   268→  it('renders [WARN] message with details', () => {\n   269→    const msg: StoryMessage = {\n   270→      type: 'warn',\n   271→      key: '3-3',\n   272→      message: 'verification found 2 failing ACs → returning to dev (attempt 2/10)',\n   273→      details: [\n   274→        'AC 3: bridge --dry-run output missing epic headers',\n   275→        'AC 7: bridge creates duplicate beads issues',\n   276→      ],\n   277→    };\n   278→    const { lastFrame } = render(<StoryMessageLine msg={msg} />);\n   279→    const frame = lastFrame()!;\n   280→    expect(frame).toContain('[WARN]');\n   281→    expect(frame).toContain('Story 3-3');\n   282→    expect(frame).toContain('2 failing ACs');\n   283→    expect(frame).toContain('└ AC 3');\n   284→    expect(frame).toContain('└ AC 7');\n   285→  });\n   286→\n   287→  it('renders [FAIL] message', () => {\n   288→    const msg: StoryMessage = { type: 'fail', key: '2-3', message: 'verification failed at AC 4 (attempt 3/10)' };\n   289→    const { lastFrame } = render(<StoryMessageLine msg={msg} />);\n   290→    const frame = lastFrame()!;\n   291→    expect(frame).toContain('[FAIL]');\n   292→    expect(frame).toContain('Story 2-3');\n   293→  });\n   294→});\n   295→\n   296→// --- Controller API Tests ---\n   297→\n   298→describe('startRenderer', () => {\n   299→  let handle: RendererHandle | null = null;\n   300→\n   301→  afterEach(() => {\n   302→    if (handle) {\n   303→      handle.cleanup();\n   304→      handle = null;\n   305→    }\n   306→  });\n   307→\n   308→  describe('quiet mode (AC #8)', () => {\n   309→    it('returns no-op handle when quiet is true', () => {\n   310→      handle = startRenderer({ quiet: true });\n   311→      // Should not throw on any method\n   312→      handle.update({ type: 'tool-start', name: 'Bash', id: 'x' });\n   313→      handle.update({ type: 'tool-complete' });\n   314→      handle.update({ type: 'text', text: 'hello' });\n   315→      handle.updateSprintState({ storyKey: 'a', phase: 'b', done: 1, total: 2 });\n   316→      handle.updateStories([{ key: '1-1', status: 'done' }]);\n   317→      handle.addMessage({ type: 'ok', key: '1-1', message: 'DONE' });\n   318→      handle.cleanup();\n   319→      // Double cleanup should not throw\n   320→      handle.cleanup();\n   321→    });\n   322→  });\n   323→\n   324→  describe('event handling', () => {\n   325→    it('handles tool-start event', () => {\n   326→      handle = startRenderer({ _forceTTY: true });\n   327→      // Should not throw\n   328→      handle.update({ type: 'tool-start', name: 'Bash', id: 'tool1' });\n   329→    });\n   330→\n   331→    it('handles tool-complete after tool-start (moves to completed)', () => {\n   332→      handle = startRenderer({ _forceTTY: true });\n   333→      handle.update({ type: 'tool-start', name: 'Bash', id: 'tool1' });\n   334→      handle.update({ type: 'tool-input', partial: '{\"command\":' });\n   335→      handle.update({ type: 'tool-input', partial: '\"ls\"}' });\n   336→      handle.update({ type: 'tool-complete' });\n   337→      // No throw = success\n   338→    });\n   339→\n   340→    it('handles tool-complete when no activeTool (text block stop)', () => {\n   341→      handle = startRenderer({ _forceTTY: true });\n   342→      // Directly send tool-complete without tool-start — this is a text block stop\n   343→      handle.update({ type: 'tool-complete' });\n   344→      // Should not throw or add anything to completed tools\n   345→    });\n   346→\n   347→    it('handles text event', () => {\n   348→      handle = startRenderer({ _forceTTY: true });\n   349→      handle.update({ type: 'text', text: 'thinking...' });\n   350→    });\n   351→\n   352→    it('handles retry event', () => {\n   353→      handle = startRenderer({ _forceTTY: true });\n   354→      handle.update({ type: 'retry', attempt: 1, delay: 5000 });\n   355→    });\n   356→\n   357→    it('handles result event (no-op rendering)', () => {\n   358→      handle = startRenderer({ _forceTTY: true });\n   359→      handle.update({ type: 'result', cost: 0.05, sessionId: 'sess_123' });\n   360→    });\n   361→\n   362→    it('clears retry on next tool-start', () => {\n   363→      handle = startRenderer({ _forceTTY: true });\n   364→      handle.update({ type: 'retry', attempt: 1, delay: 5000 });\n   365→      handle.update({ type: 'tool-start', name: 'Bash', id: 'tool1' });\n   366→      // Retry info should be cleared\n   367→    });\n   368→\n   369→    it('clears retry on next text event', () => {\n   370→      handle = startRenderer({ _forceTTY: true });\n   371→      handle.update({ type: 'retry', attempt: 1, delay: 5000 });\n   372→      handle.update({ type: 'text', text: 'thinking...' });\n   373→      // Retry info should be cleared\n   374→    });\n   375→\n   376→    it('clears lastThought on tool-start', () => {\n   377→      handle = startRenderer({ _forceTTY: true });\n   378→      handle.update({ type: 'text', text: 'old thought' });\n   379→      handle.update({ type: 'tool-start', name: 'Bash', id: 'tool1' });\n   380→      // lastThought should be cleared\n   381→    });\n   382→\n   383→    it('text event overwrites previous thought (not append)', () => {\n   384→      handle = startRenderer({ _forceTTY: true });\n   385→      handle.update({ type: 'text', text: 'first thought' });\n   386→      handle.update({ type: 'text', text: 'second thought' });\n   387→      // Only second thought should be displayed\n   388→    });\n   389→\n   390→    it('accumulates tool input args', () => {\n   391→      handle = startRenderer({ _forceTTY: true });\n   392→      handle.update({ type: 'tool-start', name: 'Write', id: 'tool1' });\n   393→      handle.update({ type: 'tool-input', partial: '{\"path\":' });\n   394→      handle.update({ type: 'tool-input', partial: '\"/tmp/test.ts\",' });\n   395→      handle.update({ type: 'tool-input', partial: '\"content\":\"hello\"}' });\n   396→      handle.update({ type: 'tool-complete' });\n   397→      // Should have accumulated all partials into args\n   398→    });\n   399→\n   400→    it('bounds completed tools list at MAX_COMPLETED_TOOLS (50)', () => {\n   401→      handle = startRenderer({ _forceTTY: true });\n   402→      // Add 55 tool cycles to exceed the cap of 50\n   403→      for (let i = 0; i < 55; i++) {\n   404→        handle.update({ type: 'tool-start', name: `Tool${i}`, id: `t${i}` });\n   405→        handle.update({ type: 'tool-input', partial: `arg${i}` });\n   406→        handle.update({ type: 'tool-complete' });\n   407→      }\n   408→      // No throw = success; internally, only the last 50 should be retained\n   409→    });\n   410→\n   411→    it('handles multiple tool cycles', () => {\n   412→      handle = startRenderer({ _forceTTY: true });\n   413→      // First tool\n   414→      handle.update({ type: 'tool-start', name: 'Read', id: 'tool1' });\n   415→      handle.update({ type: 'tool-input', partial: '{\"path\":\"/a\"}' });\n   416→      handle.update({ type: 'tool-complete' });\n   417→      // Second tool\n   418→      handle.update({ type: 'tool-start', name: 'Write', id: 'tool2' });\n   419→      handle.update({ type: 'tool-input', partial: '{\"path\":\"/b\"}' });\n   420→      handle.update({ type: 'tool-complete' });\n   421→      // Both should be in completed list\n   422→    });\n   423→  });\n   424→\n   425→  describe('updateSprintState', () => {\n   426→    it('updates sprint state', () => {\n   427→      handle = startRenderer({ _forceTTY: true });\n   428→      handle.updateSprintState({\n   429→        storyKey: '0-5-3',\n   430→        phase: 'dev',\n   431→        done: 5,\n   432→        total: 12,\n   433→      });\n   434→    });\n   435→\n   436→    it('clears sprint state with undefined', () => {\n   437→      handle = startRenderer({\n   438→        sprintState: { storyKey: 'x', phase: 'dev', done: 1, total: 2 },\n   439→        _forceTTY: true,\n   440→      });\n   441→      handle.updateSprintState(undefined);\n   442→    });\n   443→  });\n   444→\n   445→  describe('updateStories (AC #4)', () => {\n   446→    it('updates story statuses', () => {\n   447→      handle = startRenderer({ _forceTTY: true });\n   448→      handle.updateStories([\n   449→        { key: '3-1', status: 'done' },\n   450→        { key: '3-2', status: 'in-progress' },\n   451→      ]);\n   452→      // No throw = success\n   453→    });\n   454→\n   455→    it('clears stories with empty array', () => {\n   456→      handle = startRenderer({ _forceTTY: true });\n   457→      handle.updateStories([{ key: '1-1', status: 'done' }]);\n   458→      handle.updateStories([]);\n   459→    });\n   460→  });\n   461→\n   462→  describe('addMessage (AC #5, #6)', () => {\n   463→    it('adds story completion message', () => {\n   464→      handle = startRenderer({ _forceTTY: true });\n   465→      handle.addMessage({ type: 'ok', key: '3-2', message: 'DONE — 12/12 ACs verified' });\n   466→    });\n   467→\n   468→    it('adds story failure message with details', () => {\n   469→      handle = startRenderer({ _forceTTY: true });\n   470→      handle.addMessage({\n   471→        type: 'warn',\n   472→        key: '3-3',\n   473→        message: 'verification found 2 failing ACs',\n   474→        details: ['AC 3: missing headers', 'AC 7: duplicate issues'],\n   475→      });\n   476→    });\n   477→\n   478→    it('accumulates multiple messages', () => {\n   479→      handle = startRenderer({ _forceTTY: true });\n   480→      handle.addMessage({ type: 'ok', key: '3-1', message: 'DONE' });\n   481→      handle.addMessage({ type: 'warn', key: '3-2', message: 'failing' });\n   482→      handle.addMessage({ type: 'fail', key: '2-3', message: 'failed' });\n   483→    });\n   484→  });\n   485→\n   486→  describe('quiet mode includes new methods', () => {\n   487→    it('no-op handle has updateStories and addMessage', () => {\n   488→      handle = startRenderer({ quiet: true });\n   489→      handle.updateStories([{ key: '1-1', status: 'done' }]);\n   490→      handle.addMessage({ type: 'ok', key: '1-1', message: 'DONE' });\n   491→      // No throw = success\n   492→    });\n   493→  });\n   494→\n   495→  describe('cleanup (AC #6)', () => {\n   496→    it('can be called multiple times without error', () => {\n   497→      handle = startRenderer({ _forceTTY: true });\n   498→      handle.cleanup();\n   499→      handle.cleanup();\n   500→      handle.cleanup();\n   501→      handle = null; // Prevent afterEach double-cleanup\n   502→    });\n   503→\n   504→    it('ignores updates after cleanup', () => {\n   505→      handle = startRenderer({ _forceTTY: true });\n   506→      handle.cleanup();\n   507→      // These should not throw\n   508→      handle.update({ type: 'tool-start', name: 'Bash', id: 'x' });\n   509→      handle.update({ type: 'text', text: 'hello' });\n   510→      handle.updateSprintState({ storyKey: 'a', phase: 'b', done: 1, total: 2 });\n   511→      handle.updateStories([{ key: '1-1', status: 'done' }]);\n   512→      handle.addMessage({ type: 'ok', key: '1-1', message: 'DONE' });\n   513→      handle = null;\n   514→    });\n   515→  });\n   516→\n   517→  describe('signal handling (AC #9)', () => {\n   518→    it('cleans up and re-raises SIGINT', () => {\n   519→      handle = startRenderer({ _forceTTY: true });\n   520→      const killSpy = vi.spyOn(process, 'kill').mockImplementation(() => true);\n   521→      try {\n   522→        process.emit('SIGINT');\n   523→        expect(killSpy).toHaveBeenCalledWith(process.pid, 'SIGINT');\n   524→        // After signal, further updates should be no-ops (cleaned up)\n   525→        handle.update({ type: 'text', text: 'should be ignored' });\n   526→      } finally {\n   527→        killSpy.mockRestore();\n   528→      }\n   529→      handle = null; // Already cleaned up by signal handler\n   530→    });\n   531→\n   532→    it('cleans up and re-raises SIGTERM', () => {\n   533→      handle = startRenderer({ _forceTTY: true });\n   534→      const killSpy = vi.spyOn(process, 'kill').mockImplementation(() => true);\n   535→      try {\n   536→        process.emit('SIGTERM');\n   537→        expect(killSpy).toHaveBeenCalledWith(process.pid, 'SIGTERM');\n   538→      } finally {\n   539→        killSpy.mockRestore();\n   540→      }\n   541→      handle = null;\n   542→    });\n   543→  });\n   544→\n   545→  describe('non-TTY fallback (AC #6)', () => {\n   546→    it('returns no-op handle when stdout is not a TTY', () => {\n   547→      // In test environment, isTTY is typically undefined\n   548→      handle = startRenderer();\n   549→      // Should behave like quiet mode — no-op\n   550→      handle.update({ type: 'tool-start', name: 'Bash', id: 'x' });\n   551→      handle.update({ type: 'tool-complete' });\n   552→      handle.cleanup();\n   553→      handle = null;\n   554→    });\n   555→  });\n   556→\n   557→  describe('initial sprint state', () => {\n   558→    it('accepts sprint state in options', () => {\n   559→      handle = startRenderer({\n   560→        sprintState: { storyKey: '1-1', phase: 'dev', done: 0, total: 5 },\n   561→        _forceTTY: true,\n   562→      });\n   563→      // No throw = success\n   564→    });\n   565→  });\n   566→});\n   567→\n   568→// --- Integration: full event sequence ---\n   569→\n   570→describe('full event sequence', () => {\n   571→  let handle: RendererHandle;\n   572→\n   573→  afterEach(() => {\n   574→    handle?.cleanup();\n   575→  });\n   576→\n   577→  it('processes a realistic stream of events', () => {\n   578→    handle = startRenderer({\n   579→      sprintState: { storyKey: '0-5-3', phase: 'dev', done: 3, total: 10 },\n   580→      _forceTTY: true,\n   581→    });\n   582→\n   583→    const events: StreamEvent[] = [\n   584→      { type: 'text', text: 'Let me analyze...' },\n   585→      { type: 'tool-complete' }, // text block stop — should be ignored\n   586→      { type: 'tool-start', name: 'Read', id: 'tool1' },\n   587→      { type: 'tool-input', partial: '{\"file_path\":\"/src/index.ts\"}' },\n   588→      { type: 'tool-complete' },\n   589→      { type: 'text', text: 'Now I understand the structure' },\n   590→      { type: 'tool-complete' }, // text block stop — should be ignored\n   591→      { type: 'tool-start', name: 'Write', id: 'tool2' },\n   592→      { type: 'tool-input', partial: '{\"file_path\":\"/src/new.ts\",' },\n   593→      { type: 'tool-input', partial: '\"content\":\"export const x = 1;\"}' },\n   594→      { type: 'tool-complete' },\n   595→      { type: 'retry', attempt: 1, delay: 5000 },\n   596→      { type: 'tool-start', name: 'Bash', id: 'tool3' },\n   597→      { type: 'tool-input', partial: '{\"command\":\"npm test\"}' },\n   598→      { type: 'tool-complete' },\n   599→      { type: 'result', cost: 0.15, sessionId: 'sess_abc' },\n   600→    ];\n   601→\n   602→    for (const event of events) {\n   603→      handle.update(event);\n   604→    }\n   605→    // No throw = success through full sequence\n   606→  });\n   607→});\n   608→"}]},"parent_tool_use_id":"toolu_01V53hNpMF7bCUCk5waNmUeL","session_id":"3e8c45fc-a757-4d77-9a55-f32a41bfdb65","uuid":"bfdd7902-984e-4e47-8116-9465a7d3bc55","timestamp":"2026-03-21T10:48:55.034Z"}
