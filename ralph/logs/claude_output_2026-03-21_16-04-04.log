{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DH6G6KBzuMXsNG7B3uvNtT","type":"tool_result","content":"     1→#!/usr/bin/env bats\n     2→# Tests for Epic 9: Brownfield Onboarding (Stories 9.1-9.7)\n     3→\n     4→load test_helper\n     5→\n     6→ONBOARD_SH=\"$BATS_TEST_DIRNAME/../ralph/onboard.sh\"\n     7→\n     8→setup() {\n     9→    setup_test_dir\n    10→    mkdir -p \"$TEST_DIR/.claude\" \"$TEST_DIR/ralph\"\n    11→\n    12→    cat > \"$TEST_DIR/.claude/codeharness.local.md\" << 'EOF'\n    13→---\n    14→harness_version: \"0.1.0\"\n    15→initialized: true\n    16→stack: \"Node.js\"\n    17→---\n    18→EOF\n    19→\n    20→    # Create a realistic project structure\n    21→    mkdir -p \"$TEST_DIR/src/auth\" \"$TEST_DIR/src/api\" \"$TEST_DIR/src/utils\"\n    22→    echo 'function login() {}' > \"$TEST_DIR/src/auth/login.js\"\n    23→    echo 'function logout() {}' > \"$TEST_DIR/src/auth/logout.js\"\n    24→    echo 'function session() {}' > \"$TEST_DIR/src/auth/session.js\"\n    25→    echo 'const router = {};' > \"$TEST_DIR/src/api/routes.js\"\n    26→    echo 'const middleware = {};' > \"$TEST_DIR/src/api/middleware.js\"\n    27→    echo 'const validate = {};' > \"$TEST_DIR/src/api/validate.js\"\n    28→    echo 'function fmt() {}' > \"$TEST_DIR/src/utils/format.js\"\n    29→    echo '# My Project' > \"$TEST_DIR/README.md\"\n    30→\n    31→    # Test files\n    32→    mkdir -p \"$TEST_DIR/tests\"\n    33→    echo 'test(\"login\")' > \"$TEST_DIR/tests/auth.test.js\"\n    34→\n    35→    git -C \"$TEST_DIR\" add -A && git -C \"$TEST_DIR\" commit -q -m \"initial project\"\n    36→}\n    37→\n    38→teardown() {\n    39→    teardown_test_dir\n    40→}\n    41→\n    42→# ─── Script basics ─────────────────────────────────────────────────────────\n    43→\n    44→@test \"onboard.sh exists\" {\n    45→    [[ -f \"$ONBOARD_SH\" ]]\n    46→}\n    47→\n    48→@test \"onboard.sh is valid bash\" {\n    49→    bash -n \"$ONBOARD_SH\"\n    50→}\n    51→\n    52→@test \"onboard.sh --help exits 0\" {\n    53→    run bash \"$ONBOARD_SH\" --help\n    54→    [[ $status -eq 0 ]]\n    55→}\n    56→\n    57→# ─── Story 9.1-9.6: Onboard CLI delegation tests ─────────────────────────\n    58→# These tests validate onboard.sh argument parsing and error handling.\n    59→# Full subcommand behavior (scan, audit, coverage, epic) is tested\n    60→# via TypeScript unit tests in the CLI, not via BATS.\n    61→# (Replaced 14 broken skip tests in story 7-2.)\n    62→\n    63→@test \"onboard.sh requires --project-dir\" {\n    64→    run bash \"$ONBOARD_SH\" scan\n    65→    [[ $status -ne 0 ]]\n    66→    [[ \"$output\" == *\"--project-dir is required\"* ]]\n    67→}\n    68→\n    69→@test \"onboard.sh rejects unknown options\" {\n    70→    run bash \"$ONBOARD_SH\" scan --bogus-flag\n    71→    [[ $status -ne 0 ]]\n    72→    [[ \"$output\" == *\"Unknown option\"* ]]\n    73→}\n    74→\n    75→@test \"onboard.sh requires a subcommand\" {\n    76→    run bash \"$ONBOARD_SH\" --project-dir \"$TEST_DIR\"\n    77→    [[ $status -ne 0 ]]\n    78→    [[ \"$output\" == *\"specify command\"* ]]\n    79→}\n    80→\n    81→@test \"onboard.sh rejects unknown subcommand\" {\n    82→    run bash \"$ONBOARD_SH\" boguscmd --project-dir \"$TEST_DIR\"\n    83→    [[ $status -ne 0 ]]\n    84→    [[ \"$output\" == *\"Unknown command\"* ]]\n    85→}\n    86→\n    87→@test \"onboard.sh --help mentions scan, coverage, audit, epic\" {\n    88→    run bash \"$ONBOARD_SH\" --help\n    89→    [[ $status -eq 0 ]]\n    90→    [[ \"$output\" == *\"scan\"* ]]\n    91→    [[ \"$output\" == *\"coverage\"* ]]\n    92→    [[ \"$output\" == *\"audit\"* ]]\n    93→    [[ \"$output\" == *\"epic\"* ]]\n    94→}\n    95→\n    96→# ─── Command & Agent ──────────────────────────────────────────────────────\n    97→\n    98→@test \"harness-onboard.md command exists\" {\n    99→    [[ -f \"$BATS_TEST_DIRNAME/../commands/harness-onboard.md\" ]]\n   100→}\n   101→"}]},"parent_tool_use_id":"toolu_01KJ3VFcSXUx8gWVq5mRTLtv","session_id":"00ac9844-6f35-4a8e-aae2-09915fdc37cf","uuid":"e2dcb2dd-8d88-4696-8528-baa950935594","timestamp":"2026-03-21T12:12:37.215Z"}
