ryBlock([]);\n    42→    expect(block).toContain('Total ACs | 0');\n    43→    expect(block).toContain('Verified | 0');\n    44→    expect(block).toContain('Failed | 0');\n    45→    expect(block).toContain('Showboat Verify | FAIL');\n    46→  });\n    47→\n    48→  it('contains summary heading', () => {\n    49→    const block = verificationSummaryBlock([]);\n    50→    expect(block).toContain('## Verification Summary');\n    51→  });\n    52→});\n    53→\n    54→// ─── showboatProofTemplate ──────────────────────────────────────────────────\n    55→\n    56→describe('showboatProofTemplate', () => {\n    57→  it('generates correct markdown structure with story header', () => {\n    58→    const config: ShowboatProofConfig = {\n    59→      storyId: '4-1-test',\n    60→      storyTitle: 'Story 4.1: Test Story',\n    61→      acceptanceCriteria: [\n    62→        { id: '1', description: 'First AC', verified: false, evidence: [] },\n    63→      ],\n    64→    };\n    65→    const result = showboatProofTemplate(config);\n    66→    expect(result).toContain('# Proof: 4-1-test');\n    67→    expect(result).toContain('**Story:** Story 4.1: Test Story');\n    68→    expect(result).toContain('**Generated:**');\n    69→  });\n    70→\n    71→  it('includes AC sections with correct IDs', () => {\n    72→    const config: ShowboatProofConfig = {\n    73→      storyId: '1-1-test',\n    74→      storyTitle: 'Test',\n    75→      acceptanceCriteria: [\n    76→        { id: '1', description: 'First', verified: true, evidence: [] },\n    77→        { id: '2', description: 'Second', verified: false, evidence: [] },\n    78→      ],\n    79→    };\n    80→    const result = showboatProofTemplate(config);\n    81→    expect(result).toContain('## AC 1: PASS');\n    82→    expect(result).toContain('## AC 2: PENDING');\n    83→    expect(result).toContain('> First');\n    84→    expect(result).toContain('> Second');\n    85→  });\n    86→\n    87→  it('includes showboat exec blocks for 