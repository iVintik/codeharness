{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01U8eGvJU1omvMWiY8aFniWE","type":"tool_result","content":"     1→/**\n     2→ * CLI command: `codeharness audit`\n     3→ *\n     4→ * Checks all compliance dimensions and reports project health.\n     5→ * Supports --json for machine-readable output.\n     6→ * Supports --fix to generate stories for audit gaps (FR15).\n     7→ */\n     8→\n     9→import { Command } from 'commander';\n    10→import { ok as okOutput, fail as failOutput, info, jsonOutput } from '../lib/output.js';\n    11→import { runPreconditions } from '../lib/onboard-checks.js';\n    12→import { runAudit, generateFixStories, addFixStoriesToState } from '../modules/audit/index.js';\n    13→import { formatAuditHuman, formatAuditJson } from '../modules/audit/report.js';\n    14→import type { Result } from '../types/result.js';\n    15→import type { FixGenerationResult } from '../modules/audit/index.js';\n    16→\n    17→export function registerAuditCommand(program: Command): void {\n    18→  program\n    19→    .command('audit')\n    20→    .description('Check all compliance dimensions and report project health')\n    21→    .option('--json', 'Output in machine-readable JSON format')\n    22→    .option('--fix', 'Generate fix stories for every gap found')\n    23→    .action(async (opts, cmd) => {\n    24→      const globalOpts = cmd.optsWithGlobals();\n    25→      const isJson = opts.json === true || globalOpts.json === true;\n    26→      const isFix = opts.fix === true;\n    27→\n    28→      // Precondition: harness must be initialized (AC #10)\n    29→      const preconditions = runPreconditions();\n    30→      if (!preconditions.canProceed) {\n    31→        if (isJson) {\n    32→          jsonOutput({\n    33→            status: 'fail',\n    34→            message: 'Harness not initialized -- run codeharness init first',\n    35→          });\n    36→        } else {\n    37→          failOutput('Harness not initialized -- run codeharness init first');\n    38→        }\n    39→        process.exitCode = 1;\n    40→        return;\n    41→      }\n    42→\n    43→      // Run audit\n    44→      const result = await runAudit(process.cwd());\n    45→\n    46→      if (!result.success) {\n    47→        if (isJson) {\n    48→          jsonOutput({ status: 'fail', message: result.error });\n    49→        } else {\n    50→          failOutput(result.error);\n    51→        }\n    52→        process.exitCode = 1;\n    53→        return;\n    54→      }\n    55→\n    56→      // Handle --fix flag\n    57→      let fixStories: Result<FixGenerationResult> | undefined;\n    58→      let fixStateError: string | undefined;\n    59→\n    60→      if (isFix) {\n    61→        // AC #4: No gaps found\n    62→        if (result.data.gapCount === 0) {\n    63→          if (!isJson) {\n    64→            okOutput('No gaps found -- nothing to fix');\n    65→          }\n    66→        } else {\n    67→          // Generate fix stories\n    68→          const fixResult = generateFixStories(result.data);\n    69→          fixStories = fixResult;\n    70→\n    71→          if (fixResult.success) {\n    72→            // Add to sprint state (AC #2)\n    73→            const stateResult = addFixStoriesToState(fixResult.data.stories);\n    74→            if (!stateResult.success) {\n    75→              fixStateError = stateResult.error;\n    76→              if (!isJson) {\n    77→                failOutput(`Failed to update sprint state: ${stateResult.error}`);\n    78→              }\n    79→            }\n    80→\n    81→            if (!isJson) {\n    82→              info(`Generated ${fixResult.data.created} fix stories (${fixResult.data.skipped} skipped)`);\n    83→            }\n    84→          } else if (!isJson) {\n    85→            failOutput(fixResult.error);\n    86→          }\n    87→        }\n    88→      }\n    89→\n    90→      // Format output\n    91→      if (isJson) {\n    92→        const jsonData: Record<string, unknown> = formatAuditJson(result.data) as unknown as Record<string, unknown>;\n    93→        // AC #5: Include fixStories in JSON when --fix\n    94→        if (isFix) {\n    95→          if (result.data.gapCount === 0) {\n    96→            jsonData.fixStories = [];\n    97→          } else if (fixStories && fixStories.success) {\n    98→            jsonData.fixStories = fixStories.data.stories.map(s => ({\n    99→              key: s.key,\n   100→              filePath: s.filePath,\n   101→              gap: s.gap,\n   102→              ...(s.skipped ? { skipped: true } : {}),\n   103→            }));\n   104→            if (fixStateError) {\n   105→              jsonData.fixStateError = fixStateError;\n   106→            }\n   107→          } else if (fixStories && !fixStories.success) {\n   108→            jsonData.fixStories = [];\n   109→            jsonData.fixError = fixStories.error;\n   110→          }\n   111→        }\n   112→        jsonOutput(jsonData);\n   113→      } else if (!isFix || result.data.gapCount > 0) {\n   114→        // Print human audit output (skip if --fix with no gaps, already printed OK)\n   115→        const lines = formatAuditHuman(result.data);\n   116→        for (const line of lines) {\n   117→          console.log(line);\n   118→        }\n   119→      }\n   120→\n   121→      // Set exit code based on overall status\n   122→      if (result.data.overallStatus === 'fail') {\n   123→        process.exitCode = 1;\n   124→      }\n   125→    });\n   126→}\n   127→"}]},"parent_tool_use_id":"toolu_01AaC2GBTKayFeJ7nzqM76bk","session_id":"1c9a200e-72ec-477b-8ec4-6d2e01a30422","uuid":"022f165b-2ae6-441b-aaad-7d969d1b025c","timestamp":"2026-03-21T04:22:58.331Z"}
