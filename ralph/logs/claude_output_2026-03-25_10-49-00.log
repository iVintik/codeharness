{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TBUh3KcZGyx4U755RmT3tZ","type":"tool_result","content":"     1→#!/bin/bash\n     2→# codeharness: PostToolUse hook for Write and Edit tools\n     3→# Prompts agent to verify OTLP instrumentation after code changes.\n     4→# Must complete within 500ms (NFR1).\n     5→# Canonical pattern: valid JSON output always, fail open on errors.\n     6→\n     7→# Error trap: fail open on script errors\n     8→trap 'exit 0' ERR\n     9→\n    10→STATE_FILE=\".claude/codeharness.local.md\"\n    11→\n    12→# If harness not initialized, skip (fail open)\n    13→if [ ! -f \"$STATE_FILE\" ]; then\n    14→  echo \"[WARN] State file not found — skipping post-write check\" >&2\n    15→  exit 0\n    16→fi\n    17→\n    18→# Read hook input to check what file was written\n    19→HOOK_INPUT=$(cat)\n    20→FILE_PATH=$(echo \"$HOOK_INPUT\" | grep -o '\"file_path\"[[:space:]]*:[[:space:]]*\"[^\"]*\"' | head -1 | sed 's/.*\"file_path\"[[:space:]]*:[[:space:]]*\"//' | sed 's/\"$//' || true)\n    21→\n    22→# Only prompt for source code files, not config/docs\n    23→case \"$FILE_PATH\" in\n    24→  *.ts|*.js|*.tsx|*.jsx|*.py|*.go|*.rs)\n    25→    echo '{\"message\": \"New code written. Verify OTLP instrumentation is present.\\n-> Check that new endpoints emit traces and structured logs.\"}'\n    26→    ;;\n    27→  *)\n    28→    # Non-source file, skip\n    29→    exit 0\n    30→    ;;\n    31→esac\n    32→"}]},"parent_tool_use_id":"toolu_01MaiZ71xHuWaWxP6B1wGjKe","session_id":"3fcb2b1c-e710-401b-91ab-b64a3e9a3996","uuid":"bbed51b1-fb81-4c6c-bcdd-e601d59aedc3","timestamp":"2026-03-25T06:52:58.000Z"}
