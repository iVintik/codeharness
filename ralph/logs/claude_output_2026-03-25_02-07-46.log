{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016eqCCmUDkASxZz4SN4HrWe","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { selectNextStory, MAX_STORY_ATTEMPTS } from '../selector.js';\n     3→import type { SprintState, StoryState } from '../../../types/state.js';\n     4→import { buildSprintState, buildStoryEntry } from '../../../lib/__tests__/helpers.js';\n     5→\n     6→/** Helper: build a SprintState with given partial stories */\n     7→function makeState(\n     8→  stories: Record<string, Partial<StoryState>>,\n     9→): SprintState {\n    10→  const full: Record<string, StoryState> = {};\n    11→  for (const [key, partial] of Object.entries(stories)) {\n    12→    full[key] = buildStoryEntry(partial);\n    13→  }\n    14→  return buildSprintState({ stories: full });\n    15→}\n    16→\n    17→/** Helper: build a bad state that throws on stories access */\n    18→function makeBadState(throwValue: unknown): SprintState {\n    19→  const base = buildSprintState();\n    20→  return {\n    21→    ...base,\n    22→    get stories() { throw throwValue; },\n    23→  } as unknown as SprintState;\n    24→}\n    25→\n    26→describe('selectNextStory', () => {\n    27→  it('returns ok with null selected when stories map is empty', () => {\n    28→    const result = selectNextStory(makeState({}));\n    29→    expect(result.success).toBe(true);\n    30→    if (result.success) {\n    31→      expect(result.data.selected).toBeNull();\n    32→      expect(result.data.retryExhausted).toEqual([]);\n    33→    }\n    34→  });\n    35→\n    36→  it('returns ok with null selected when all stories are terminal', () => {\n    37→    const state = makeState({\n    38→      'story-a': { status: 'done' },\n    39→      'story-b': { status: 'failed' },\n    40→      'story-c': { status: 'blocked' },\n    41→    });\n    42→    const result = selectNextStory(state);\n    43→    expect(result.success).toBe(true);\n    44→    if (result.success) {\n    45→      expect(result.data.selected).toBeNull();\n    46→      expect(result.data.retryExhausted).toEqual([]);\n    47→    }\n    48→  });\n    49→\n    50→  it('reports retry-exhausted stories in retryExhausted array', () => {\n    51→    const state = makeState({\n    52→      'story-a': { status: 'backlog', attempts: 10 },\n    53→      'story-b': { status: 'backlog', attempts: 15 },\n    54→    });\n    55→    const result = selectNextStory(state);\n    56→    expect(result.success).toBe(true);\n    57→    if (result.success) {\n    58→      expect(result.data.selected).toBeNull();\n    59→      expect(result.data.retryExhausted).toHaveLength(2);\n    60→      const keys = result.data.retryExhausted.map((r) => r.key).sort();\n    61→      expect(keys).toEqual(['story-a', 'story-b']);\n    62→      for (const info of result.data.retryExhausted) {\n    63→        expect(info.reason).toBe('retry-exhausted');\n    64→      }\n    65→    }\n    66→  });\n    67→\n    68→  it('retry-exhausted stories report correct attempt counts', () => {\n    69→    const state = makeState({ 'story-x': { status: 'verifying', attempts: 12 } });\n    70→    const result = selectNextStory(state);\n    71→    expect(result.success).toBe(true);\n    72→    if (result.success) {\n    73→      expect(result.data.retryExhausted).toHaveLength(1);\n    74→      expect(result.data.retryExhausted[0]).toEqual({\n    75→        key: 'story-x', attempts: 12, reason: 'retry-exhausted',\n    76→      });\n    77→    }\n    78→  });\n    79→\n    80→  it('does not report terminal stories as retry-exhausted even with high attempts', () => {\n    81→    const state = makeState({\n    82→      'story-done': { status: 'done', attempts: 15 },\n    83→      'story-failed': { status: 'failed', attempts: 20 },\n    84→      'story-blocked': { status: 'blocked', attempts: 10 },\n    85→    });\n    86→    const result = selectNextStory(state);\n    87→    expect(result.success).toBe(true);\n    88→    if (result.success) {\n    89→      expect(result.data.selected).toBeNull();\n    90→      expect(result.data.retryExhausted).toEqual([]);\n    91→    }\n    92→  });\n    93→\n    94→  it('returns in-progress story before all others', () => {\n    95→    const state = makeState({\n    96→      'story-backlog': { status: 'backlog' },\n    97→      'story-verifying': { status: 'verifying' },\n    98→      'story-current': { status: 'in-progress', attempts: 3 },\n    99→    });\n   100→    const result = selectNextStory(state);\n   101→    expect(result.success).toBe(true);\n   102→    if (result.success) {\n   103→      expect(result.data.selected!.key).toBe('story-current');\n   104→      expect(result.data.selected!.priority).toBe(0);\n   105→    }\n   106→  });\n   107→\n   108→  it('returns verifying-with-proof before plain verifying', () => {\n   109→    const state = makeState({\n   110→      'story-no-proof': { status: 'verifying', proofPath: null },\n   111→      'story-has-proof': { status: 'verifying', proofPath: 'docs/proof.md' },\n   112→    });\n   113→    const result = selectNextStory(state);\n   114→    expect(result.success).toBe(true);\n   115→    if (result.success) {\n   116→      expect(result.data.selected!.key).toBe('story-has-proof');\n   117→      expect(result.data.selected!.priority).toBe(1);\n   118→    }\n   119→  });\n   120→\n   121→  it('returns verifying before backlog', () => {\n   122→    const state = makeState({\n   123→      'story-backlog': { status: 'backlog' },\n   124→      'story-verifying': { status: 'verifying' },\n   125→    });\n   126→    const result = selectNextStory(state);\n   127→    expect(result.success).toBe(true);\n   128→    if (result.success) {\n   129→      expect(result.data.selected!.key).toBe('story-verifying');\n   130→      expect(result.data.selected!.priority).toBe(2);\n   131→    }\n   132→  });\n   133→\n   134→  it('full priority ordering: in-progress > proof > verifying > backlog', () => {\n   135→    const state = makeState({\n   136→      'story-backlog': { status: 'backlog' },\n   137→      'story-verifying': { status: 'verifying' },\n   138→      'story-proof': { status: 'verifying', proofPath: 'proof.md' },\n   139→      'story-active': { status: 'in-progress' },\n   140→    });\n   141→    const result = selectNextStory(state);\n   142→    expect(result.success).toBe(true);\n   143→    if (result.success) {\n   144→      expect(result.data.selected!.key).toBe('story-active');\n   145→      expect(result.data.selected!.priority).toBe(0);\n   146→    }\n   147→  });\n   148→\n   149→  it('same-tier tiebreak: fewer attempts first', () => {\n   150→    const state = makeState({\n   151→      'story-a': { status: 'backlog', attempts: 5 },\n   152→      'story-b': { status: 'backlog', attempts: 2 },\n   153→      'story-c': { status: 'backlog', attempts: 8 },\n   154→    });\n   155→    const result = selectNextStory(state);\n   156→    expect(result.success).toBe(true);\n   157→    if (result.success) expect(result.data.selected!.key).toBe('story-b');\n   158→  });\n   159→\n   160→  it('same-tier same-attempts tiebreak: lexicographic key order', () => {\n   161→    const state = makeState({\n   162→      'story-charlie': { status: 'backlog', attempts: 0 },\n   163→      'story-alpha': { status: 'backlog', attempts: 0 },\n   164→      'story-bravo': { status: 'backlog', attempts: 0 },\n   165→    });\n   166→    const result = selectNextStory(state);\n   167→    expect(result.success).toBe(true);\n   168→    if (result.success) expect(result.data.selected!.key).toBe('story-alpha');\n   169→  });\n   170→\n   171→  it('cross-epic selection: considers stories from all epics equally', () => {\n   172→    const state = makeState({\n   173→      'epic-2-story-a': { status: 'backlog', attempts: 3 },\n   174→      'epic-3-story-b': { status: 'backlog', attempts: 1 },\n   175→      'epic-2-story-c': { status: 'verifying' },\n   176→    });\n   177→    const result = selectNextStory(state);\n   178→    expect(result.success).toBe(true);\n   179→    if (result.success) expect(result.data.selected!.key).toBe('epic-2-story-c');\n   180→  });\n   181→\n   182→  it.each([\n   183→    ['done', 'done' as const],\n   184→    ['failed', 'failed' as const],\n   185→    ['blocked', 'blocked' as const],\n   186→  ])('excludes %s stories from selection', (_label, status) => {\n   187→    const state = makeState({\n   188→      'story-terminal': { status },\n   189→      'story-backlog': { status: 'backlog' },\n   190→    });\n   191→    const result = selectNextStory(state);\n   192→    expect(result.success).toBe(true);\n   193→    if (result.success) expect(result.data.selected!.key).toBe('story-backlog');\n   194→  });\n   195→\n   196→  it('selects story with attempts < 10 but reports one with attempts >= 10', () => {\n   197→    const state = makeState({\n   198→      'story-exhausted': { status: 'backlog', attempts: 10 },\n   199→      'story-ok': { status: 'backlog', attempts: 9 },\n   200→    });\n   201→    const result = selectNextStory(state);\n   202→    expect(result.success).toBe(true);\n   203→    if (result.success) {\n   204→      expect(result.data.selected!.key).toBe('story-ok');\n   205→      expect(result.data.retryExhausted).toHaveLength(1);\n   206→      expect(result.data.retryExhausted[0].key).toBe('story-exhausted');\n   207→    }\n   208→  });\n   209→\n   210→  it('populates title from key', () => {\n   211→    const state = makeState({ 'my-cool-story': { status: 'backlog' } });\n   212→    const result = selectNextStory(state);\n   213→    expect(result.success).toBe(true);\n   214→    if (result.success) expect(result.data.selected!.title).toBe('My cool story');\n   215→  });\n   216→\n   217→  it('handles empty key in title generation', () => {\n   218→    const state = makeState({ '': { status: 'backlog' } });\n   219→    const result = selectNextStory(state);\n   220→    expect(result.success).toBe(true);\n   221→    if (result.success) expect(result.data.selected!.title).toBe('');\n   222→  });\n   223→\n   224→  it('returns fail() on Error throw', () => {\n   225→    const result = selectNextStory(makeBadState(new Error('corrupt state')));\n   226→    expect(result.success).toBe(false);\n   227→    if (!result.success) {\n   228→      expect(result.error).toContain('Story selection failed');\n   229→      expect(result.error).toContain('corrupt state');\n   230→    }\n   231→  });\n   232→\n   233→  it('returns fail() on non-Error throw', () => {\n   234→    const result = selectNextStory(makeBadState('string error'));\n   235→    expect(result.success).toBe(false);\n   236→    if (!result.success) expect(result.error).toContain('string error');\n   237→  });\n   238→\n   239→  it('handles ready and review statuses as backlog-tier', () => {\n   240→    const state = makeState({\n   241→      'story-ready': { status: 'ready' },\n   242→      'story-review': { status: 'review', attempts: 1 },\n   243→    });\n   244→    const result = selectNextStory(state);\n   245→    expect(result.success).toBe(true);\n   246→    if (result.success) {\n   247→      expect(result.data.selected!.key).toBe('story-ready');\n   248→      expect(result.data.selected!.priority).toBe(3);\n   249→    }\n   250→  });\n   251→\n   252→  it('MAX_STORY_ATTEMPTS is 10', () => {\n   253→    expect(MAX_STORY_ATTEMPTS).toBe(10);\n   254→  });\n   255→\n   256→  // Tech Debt Gate (Story 14-2)\n   257→  const bl = 'backlog' as const, dn = 'done' as const;\n   258→  const ip = 'in-progress' as const, vf = 'verifying' as const;\n   259→  it.each([\n   260→    ['TD backlog before feature', { 'TD-1-fix': { status: bl }, '15-1-ci': { status: bl } }, 'TD-1-fix'],\n   261→    ['all TD done, normal resumes', { 'TD-1-fix': { status: dn }, 'TD-2-log': { status: dn }, '15-1-ci': { status: bl } }, '15-1-ci'],\n   262→    ['in-progress non-TD wins', { 'TD-1-fix': { status: bl }, '15-1-ci': { status: ip } }, '15-1-ci'],\n   263→    ['verifying non-TD wins', { 'TD-1-fix': { status: bl }, '15-1-ci': { status: vf } }, '15-1-ci'],\n   264→    ['no TD stories, normal order', { '15-2-eslint': { status: bl }, '15-1-ci': { status: bl } }, '15-1-ci'],\n   265→    ['TD in-progress = Tier A', { 'TD-1-fix': { status: ip }, '15-1-ci': { status: bl } }, 'TD-1-fix'],\n   266→    ['TD fewer attempts wins', { 'TD-1-fix': { status: bl, attempts: 3 }, 'TD-2-log': { status: bl, attempts: 1 } }, 'TD-2-log'],\n   267→  ])('TD gate: %s', (_label, stories, expectedKey) => {\n   268→    const result = selectNextStory(makeState(stories));\n   269→    expect(result.success).toBe(true);\n   270→    if (result.success) expect(result.data.selected!.key).toBe(expectedKey);\n   271→  });\n   272→\n   273→  it('mixed scenario: selects actionable and reports exhausted', () => {\n   274→    const state = makeState({\n   275→      'story-done': { status: 'done' },\n   276→      'story-exhausted-1': { status: 'in-progress', attempts: 10 },\n   277→      'story-exhausted-2': { status: 'backlog', attempts: 11 },\n   278→      'story-good': { status: 'verifying', proofPath: 'p.md' },\n   279→      'story-blocked': { status: 'blocked' },\n   280→    });\n   281→    const result = selectNextStory(state);\n   282→    expect(result.success).toBe(true);\n   283→    if (result.success) {\n   284→      expect(result.data.selected!.key).toBe('story-good');\n   285→      expect(result.data.selected!.priority).toBe(1);\n   286→      expect(result.data.retryExhausted).toHaveLength(2);\n   287→      const exhaustedKeys = result.data.retryExhausted.map((r) => r.key).sort();\n   288→      expect(exhaustedKeys).toEqual(['story-exhausted-1', 'story-exhausted-2']);\n   289→    }\n   290→  });\n   291→});\n   292→"}]},"parent_tool_use_id":"toolu_01GAEH4HaeS1eW5UR9taZ8z5","session_id":"e0c38769-c734-43c9-928b-954c93aa963e","uuid":"e2ac7e95-a06e-462c-b93c-cdd4d9e8358d","timestamp":"2026-03-24T22:2