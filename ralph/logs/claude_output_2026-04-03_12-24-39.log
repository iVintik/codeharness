ation failed for embedded agent corrupt-agent: /persona: required',\n            '/templates/agents/corrupt-agent.yaml',\n            [{ path: '/persona', message: 'required' }],\n          );\n        }\n        return originalResolveAgent(name);\n      };\n\n      try {\n        const yaml = `\ntasks:\n  implement:\n    agent: corrupt-agent\nflow:\n  - implement\n`;\n        const filePath = writeYaml('corrupt-agent.yaml', yaml);\n\n        expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n        try {\n          parseWorkflow(filePath);\n        } catch (err) {\n          const pe = err as WorkflowParseError;\n          expect(pe.errors.some((e) => e.message.includes('failed to resolve'))).toBe(true);\n          expect(pe.errors.some((e) => e.message.includes('Schema validation failed'))).toBe(true);\n        }\n      } finally {\n        (agentResolver as Record<string, unknown>).resolveAgent = originalResolveAgent;\n      }\n    });\n  });"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1042,"cache_read_input_tokens":66224,"cache_creation":{"ephemeral_5m_input_tokens":1042,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01U85MaKaYFD6RV3D181SmSg","session_id":"4b1f7711-6ed7-4488-a0af-b261e761b450","uuid":"5adb348a-629e-497d-bc70-6b9660e3dd1d"}
