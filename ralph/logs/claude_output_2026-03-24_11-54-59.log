{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NAnmmk6m8dLxxE1GFbUuGN","type":"tool_result","content":"     1→/**\n     2→ * Public API for the stacks subsystem.\n     3→ */\n     4→\n     5→// Types\n     6→export type {\n     7→  StackName,\n     8→  AppType,\n     9→  CoverageToolName,\n    10→  CoverageToolInfo,\n    11→  OtlpResult,\n    12→  TestCounts,\n    13→  StackProvider,\n    14→} from './types.js';\n    15→\n    16→// Registry\n    17→export {\n    18→  registerProvider,\n    19→  getStackProvider,\n    20→  detectStack,\n    21→  detectStacks,\n    22→  type StackDetection,\n    23→  _resetRegistry,\n    24→} from './registry.js';\n    25→\n    26→// Auto-register built-in providers\n    27→import { registerProvider } from './registry.js';\n    28→import { NodejsProvider } from './nodejs.js';\n    29→\n    30→registerProvider(new NodejsProvider());\n    31→"}]},"parent_tool_use_id":"toolu_01ARDMJdo7LDpJboWrzKfH84","session_id":"ec2bf7d9-1cd3-4665-9804-65790a3eadb3","uuid":"76c3eff9-c42d-4df3-87f8-ab90a8580e7b","timestamp":"2026-03-24T07:59:57.432Z"}
