{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01TdCeV9y1t6HJeFGQvvzJn5","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01YCqSwJrpwzXCDz6H5vuvG5","name":"Edit","input":{"replace_all":false,"file_path":"/Users/ivintik/dev/personal/codeharness/src/lib/workflow-engine.ts","old_string":"export async function checkDriverHealth(workflow: ResolvedWorkflow, timeoutMs?: number): Promise<void> {\n  // 1. Collect unique driver names from all tasks\n  const driverNames = new Set<string>();\n  for (const task of Object.values(workflow.tasks)) {\n    driverNames.add(task.driver ?? 'claude-code');\n  }\n\n  // 2. Resolve drivers\n  const drivers = new Map<string, ReturnType<typeof getDriver>>();\n  for (const name of driverNames) {\n    drivers.set(name, getDriver(name));\n  }\n\n  // 3. Run health checks concurrently\n  type HealthResult = { name: string; health: DriverHealth };\n  const healthChecks = Promise.all(\n    [...drivers.entries()].map(async ([name, driver]): Promise<HealthResult> => {\n      const health = await driver.healthCheck();\n      return { name, health };\n    }),\n  );\n\n  // 4. Race against timeout (NFR6)\n  const timeoutPromise = new Promise<'timeout'>((resolve) => {\n    setTimeout(() => resolve('timeout'), timeoutMs ?? HEALTH_CHECK_TIMEOUT_MS);\n  });\n\n  const result = await Promise.race([healthChecks, timeoutPromise]);\n\n  if (result === 'timeout') {\n    const effectiveTimeout = timeoutMs ?? HEALTH_CHECK_TIMEOUT_MS;\n    const names = [...driverNames].join(', ');\n    throw new Error(\n      `Driver health check timed out after ${effectiveTimeout}ms. Drivers that did not respond: ${names}`,\n    );\n  }\n\n  // 5. Check for failures\n  const failures = result.filter((r) => !r.health.available);\n  if (failures.length > 0) {\n    const details = failures\n      .map((f) => `${f.name}: ${f.health.error ?? 'unavailable'}`)\n      .join('; ');\n    throw new Error(`Driver health check failed: ${details}`);\n  }\n}","new_string":"export async function checkDriverHealth(workflow: ResolvedWorkflow, timeoutMs?: number): Promise<void> {\n  // 1. Collect unique driver names from all tasks\n  const driverNames = new Set<string>();\n  for (const task of Object.values(workflow.tasks)) {\n    driverNames.add(task.driver ?? 'claude-code');\n  }\n\n  // 2. Resolve drivers\n  const drivers = new Map<string, ReturnType<typeof getDriver>>();\n  for (const name of driverNames) {\n    drivers.set(name, getDriver(name));\n  }\n\n  // 3. Run health checks concurrently, tracking which drivers responded\n  interface HealthResult { name: string; health: DriverHealth }\n  const responded = new Set<string>();\n  const healthChecks = Promise.all(\n    [...drivers.entries()].map(async ([name, driver]): Promise<HealthResult> => {\n      const health = await driver.healthCheck();\n      responded.add(name);\n      return { name, health };\n    }),\n  );\n\n  // 4. Race against timeout (NFR6) — clear timer on success to prevent leaks\n  const effectiveTimeout = timeoutMs ?? HEALTH_CHECK_TIMEOUT_MS;\n  let timer: ReturnType<typeof setTimeout>;\n  const timeoutPromise = new Promise<'timeout'>((resolve) => {\n    timer = setTimeout(() => resolve('timeout'), effectiveTimeout);\n  });\n\n  const result = await Promise.race([healthChecks, timeoutPromise]);\n\n  if (result === 'timeout') {\n    // Report only the drivers that did NOT respond (AC #6)\n    const pending = [...driverNames].filter((n) => !responded.has(n));\n    const names = pending.length > 0 ? pending.join(', ') : [...driverNames].join(', ');\n    throw new Error(\n      `Driver health check timed out after ${effectiveTimeout}ms. Drivers that did not respond: ${names}`,\n    );\n  }\n\n  // Health checks completed before timeout — clear the timer\n  clearTimeout(timer!);\n\n  // 5. Check for failures\n  const failures = result.filter((r) => !r.health.available);\n  if (failures.length > 0) {\n    const details = failures\n      .map((f) => `${f.name}: ${f.health.error ?? 'unavailable'}`)\n      .join('; ');\n    throw new Error(`Driver health check failed: ${details}`);\n  }\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1053,"cache_read_input_tokens":48615,"cache_creation":{"ephemeral_5m_input_tokens":1053,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01Pu3wXi4pA6EPLQcEQK8Uxb","session_id":"b101ea9e-2f9e-4377-9c5a-f109fa318b32","uuid":"aa4b1a8b-df4b-48c8-91d4-a6438d870ae5"}
