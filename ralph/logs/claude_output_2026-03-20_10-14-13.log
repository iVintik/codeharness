{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XhuTkQaSbNj5EoLmFwdL63","type":"tool_result","content":"     1→/**\n     2→ * Observability coverage gate — checks if coverage meets targets for commit gating.\n     3→ *\n     4→ * Implements Story 2.2: reads cached coverage from sprint-state.json and compares\n     5→ * against targets. Does NOT re-run Semgrep — uses cached results for performance.\n     6→ * Static coverage is always required; runtime is only checked when data exists.\n     7→ */\n     8→\n     9→import { readFileSync, existsSync } from 'node:fs';\n    10→import { join } from 'node:path';\n    11→import { ok, fail } from '../../types/result.js';\n    12→import type { Result } from '../../types/result.js';\n    13→import { readCoverageState } from './coverage.js';\n    14→import type {\n    15→  ObservabilityCoverageGateResult,\n    16→  CoverageTargetResult,\n    17→  ObservabilityGap,\n    18→  GapSeverity,\n    19→} from './types.js';\n    20→\n    21→const DEFAULT_STATIC_TARGET = 80;\n    22→const DEFAULT_RUNTIME_TARGET = 60;\n    23→\n    24→/**\n    25→ * Check observability coverage against targets for commit gating.\n    26→ *\n    27→ * Reads static and runtime coverage from sprint-state.json. Static coverage\n    28→ * is always checked. Runtime coverage is only checked when runtime data exists\n    29→ * in the state file (i.e., after at least one verification run).\n    30→ *\n    31→ * @param projectDir - Project root directory\n    32→ * @param overrides - Optional target overrides\n    33→ * @returns Gate result with pass/fail, per-dimension results, and gap summary\n    34→ */\n    35→export function checkObservabilityCoverageGate(\n    36→  projectDir: string,\n    37→  overrides?: { staticTarget?: number; runtimeTarget?: number },\n    38→): Result<ObservabilityCoverageGateResult> {\n    39→  if (!projectDir || typeof projectDir !== 'string') {\n    40→    return fail('projectDir is required and must be a non-empty string');\n    41→  }\n    42→\n    43→  const stateResult = readCoverageState(projectDir);\n    44→  if (!stateResult.success) {\n    45→    return fail(stateResult.error);\n    46→  }\n    47→\n    48→  const state = stateResult.data;\n    49→  const staticTarget =\n    50→    overrides?.staticTarget ?? state.targets.staticTarget ?? DEFAULT_STATIC_TARGET;\n    51→  const runtimeTarget =\n    52→    overrides?.runtimeTarget ?? state.targets.runtimeTarget ?? DEFAULT_RUNTIME_TARGET;\n    53→\n    54→  // Static coverage check (always required)\n    55→  const staticCurrent = state.static.coveragePercent;\n    56→  const staticMet = staticCurrent >= staticTarget;\n    57→  const staticResult: CoverageTargetResult = {\n    58→    met: staticMet,\n    59→    current: staticCurrent,\n    60→    target: staticTarget,\n    61→    gap: staticMet ? 0 : staticTarget - staticCurrent,\n    62→  };\n    63→\n    64→  // Runtime coverage check (only when runtime data exists)\n    65→  let runtimeResult: CoverageTargetResult | null = null;\n    66→  if (state.runtime) {\n    67→    const runtimeCurrent = state.runtime.coveragePercent;\n    68→    const runtimeMet = runtimeCurrent >= runtimeTarget;\n    69→    runtimeResult = {\n    70→      met: runtimeMet,\n    71→      current: runtimeCurrent,\n    72→      target: runtimeTarget,\n    73→      gap: runtimeMet ? 0 : runtimeTarget - runtimeCurrent,\n    74→    };\n    75→  }\n    76→\n    77→  // Gate passes only when all checked dimensions pass\n    78→  const passed = staticResult.met && (runtimeResult === null || runtimeResult.met);\n    79→\n    80→  // Read cached gaps from sprint-state.json (persisted by saveCoverageResult)\n    81→  const gapSummary = readCachedGaps(projectDir);\n    82→\n    83→  return ok({ passed, staticResult, runtimeResult, gapSummary });\n    84→}\n    85→\n    86→/**\n    87→ * Read cached observability gaps from sprint-state.json.\n    88→ * Returns empty array if no gaps are cached or on any error.\n    89→ */\n    90→function readCachedGaps(projectDir: string): ObservabilityGap[] {\n    91→  try {\n    92→    const fp = join(projectDir, 'sprint-state.json');\n    93→    if (!existsSync(fp)) return [];\n    94→    const raw = JSON.parse(readFileSync(fp, 'utf-8')) as Record<string, unknown>;\n    95→    const obs = raw.observability as Record<string, unknown> | undefined;\n    96→    if (!obs) return [];\n    97→    const staticSection = obs.static as Record<string, unknown> | undefined;\n    98→    if (!staticSection) return [];\n    99→    const gaps = staticSection.gaps;\n   100→    if (!Array.isArray(gaps)) return [];\n   101→    return gaps\n   102→      .filter(\n   103→        (g): g is { file: string; line: number; type: string; description: string; severity: string } =>\n   104→          typeof g === 'object' &&\n   105→          g !== null &&\n   106→          typeof (g as Record<string, unknown>).file === 'string' &&\n   107→          typeof (g as Record<string, unknown>).line === 'number' &&\n   108→          typeof (g as Record<string, unknown>).type === 'string' &&\n   109→          typeof (g as Record<string, unknown>).description === 'string',\n   110→      )\n   111→      .map(g => ({\n   112→        file: g.file,\n   113→        line: g.line,\n   114→        type: g.type,\n   115→        description: g.description,\n   116→        severity: (g.severity === 'error' || g.severity === 'warning' ? g.severity : 'info') as GapSeverity,\n   117→      }));\n   118→  } catch {\n   119→    return [];\n   120→  }\n   121→}\n   122→"}]},"parent_tool_use_id":"toolu_01HaJKsv5YrKWXVV5tMae9v1","session_id":"2fa32674-558d-4231-8eb7-1997dc535a41","uuid":"47e0a9d9-80a4-4399-b127-e19b0976be36","timestamp":"2026-03-20T06:18:55.315Z"}
