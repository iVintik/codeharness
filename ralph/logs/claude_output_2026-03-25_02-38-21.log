{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GqvTDMYt2PAvn9JpMkE4yK","type":"tool_result","content":"     1→import { execFileSync } from 'node:child_process';\n     2→\n     3→export interface DockerServiceStatus {\n     4→  name: string;\n     5→  status: string;\n     6→  port: string;\n     7→}\n     8→\n     9→export interface DockerStartResult {\n    10→  started: boolean;\n    11→  services: DockerServiceStatus[];\n    12→  error?: string;\n    13→}\n    14→\n    15→export interface DockerHealthService {\n    16→  name: string;\n    17→  running: boolean;\n    18→}\n    19→\n    20→export interface DockerHealthResult {\n    21→  healthy: boolean;\n    22→  services: DockerHealthService[];\n    23→  remedy?: string;\n    24→}\n    25→\n    26→export interface RemoteEndpointCheckResult {\n    27→  reachable: boolean;\n    28→  error?: string;\n    29→}\n    30→\n    31→export function isDockerAvailable(): boolean {\n    32→  try {\n    33→    execFileSync('docker', ['--version'], { stdio: 'pipe', timeout: 10_000 });\n    34→    return true;\n    35→  } catch {\n    36→    return false;\n    37→  }\n    38→}\n    39→\n    40→export function isDockerComposeAvailable(): boolean {\n    41→  try {\n    42→    execFileSync('docker', ['compose', 'version'], { stdio: 'pipe', timeout: 10_000 });\n    43→    return true;\n    44→  } catch {\n    45→    return false;\n    46→  }\n    47→}\n    48→\n    49→export function getStackHealth(composeFile: string, projectName?: string): DockerHealthResult {\n    50→  const expectedServices = ['victoria-logs', 'victoria-metrics', 'victoria-traces', 'otel-collector'];\n    51→\n    52→  try {\n    53→    const args = projectName\n    54→      ? ['compose', '-p', projectName, '-f', composeFile, 'ps', '--format', 'json']\n    55→      : ['compose', '-f', composeFile, 'ps', '--format', 'json'];\n    56→\n    57→    const output = execFileSync('docker', args, {\n    58→      stdio: 'pipe',\n    59→      timeout: 15_000,\n    60→    });\n    61→    const text = output.toString().trim();\n    62→    const runningNames = new Set<string>();\n    63→\n    64→    if (text) {\n    65→      const lines = text.split('\\n').filter(l => l.trim());\n    66→      for (const line of lines) {\n    67→        const svc = JSON.parse(line) as { Service?: string; State?: string };\n    68→        if (svc.State === 'running' && svc.Service) {\n    69→          runningNames.add(svc.Service);\n    70→        }\n    71→      }\n    72→    }\n    73→\n    74→    const services: DockerHealthService[] = expectedServices.map(name => ({\n    75→      name,\n    76→      running: runningNames.has(name),\n    77→    }));\n    78→\n    79→    const healthy = services.every(s => s.running);\n    80→    const remedyCmd = projectName\n    81→      ? `docker compose -p ${projectName} -f ${composeFile} up -d`\n    82→      : `docker compose -f ${composeFile} up -d`;\n    83→\n    84→    return {\n    85→      healthy,\n    86→      services,\n    87→      remedy: healthy ? undefined : `Restart: ${remedyCmd}`,\n    88→    };\n    89→  } catch {\n    90→    const remedyCmd = projectName\n    91→      ? `docker compose -p ${projectName} -f ${composeFile} up -d`\n    92→      : `docker compose -f ${composeFile} up -d`;\n    93→\n    94→    const services: DockerHealthService[] = expectedServices.map(name => ({\n    95→      name,\n    96→      running: false,\n    97→    }));\n    98→\n    99→    return {\n   100→      healthy: false,\n   101→      services,\n   102→      remedy: `Restart: ${remedyCmd}`,\n   103→    };\n   104→  }\n   105→}\n   106→\n   107→export function getCollectorHealth(composeFile: string): DockerHealthResult {\n   108→  const expectedServices = ['otel-collector'];\n   109→\n   110→  try {\n   111→    const output = execFileSync('docker', ['compose', '-p', 'codeharness-collector', '-f', composeFile, 'ps', '--format', 'json'], {\n   112→      stdio: 'pipe',\n   113→      timeout: 15_000,\n   114→    });\n   115→    const text = output.toString().trim();\n   116→    const runningNames = new Set<string>();\n   117→\n   118→    if (text) {\n   119→      const lines = text.split('\\n').filter(l => l.trim());\n   120→      for (const line of lines) {\n   121→        const svc = JSON.parse(line) as { Service?: string; State?: string };\n   122→        if (svc.State === 'running' && svc.Service) {\n   123→          runningNames.add(svc.Service);\n   124→        }\n   125→      }\n   126→    }\n   127→\n   128→    const services: DockerHealthService[] = expectedServices.map(name => ({\n   129→      name,\n   130→      running: runningNames.has(name),\n   131→    }));\n   132→\n   133→    const healthy = services.every(s => s.running);\n   134→\n   135→    return {\n   136→      healthy,\n   137→      services,\n   138→      remedy: healthy ? undefined : `Restart: docker compose -p codeharness-collector -f ${composeFile} up -d`,\n   139→    };\n   140→  } catch {\n   141→    const services: DockerHealthService[] = expectedServices.map(name => ({\n   142→      name,\n   143→      running: false,\n   144→    }));\n   145→\n   146→    return {\n   147→      healthy: false,\n   148→      services,\n   149→      remedy: `Restart: docker compose -p codeharness-collector -f ${composeFile} up -d`,\n   150→    };\n   151→  }\n   152→}\n   153→\n   154→export async function checkRemoteEndpoint(url: string): Promise<RemoteEndpointCheckResult> {\n   155→  try {\n   156→    const controller = new AbortController();\n   157→    const timeout = setTimeout(() => controller.abort(), 5000);\n   158→    try {\n   159→      await fetch(url, { signal: controller.signal });\n   160→      return { reachable: true };\n   161→    } finally {\n   162→      clearTimeout(timeout);\n   163→    }\n   164→  } catch (err) {\n   165→    const message = err instanceof Error ? err.message : String(err);\n   166→    return { reachable: false, error: message };\n   167→  }\n   168→}\n   169→