{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018nawk26LtbMgAriVSMpqL6","type":"tool_result","content":"     1→import { Command } from 'commander';\n     2→import { registerInitCommand } from './commands/init.js';\n     3→import { registerBridgeCommand } from './commands/bridge.js';\n     4→import { registerRunCommand } from './commands/run.js';\n     5→import { registerVerifyCommand } from './commands/verify.js';\n     6→import { registerStatusCommand } from './commands/status.js';\n     7→import { registerOnboardCommand } from './commands/onboard.js';\n     8→import { registerTeardownCommand } from './commands/teardown.js';\n     9→import { registerStateCommand } from './commands/state.js';\n    10→import { registerSyncCommand } from './commands/sync.js';\n    11→import { registerCoverageCommand } from './commands/coverage.js';\n    12→import { registerDocHealthCommand } from './commands/doc-health.js';\n    13→import { registerStackCommand } from './commands/stack.js';\n    14→import { registerQueryCommand } from './commands/query.js';\n    15→import { registerRetroImportCommand } from './commands/retro-import.js';\n    16→import { registerGithubImportCommand } from './commands/github-import.js';\n    17→import { registerVerifyEnvCommand } from './commands/verify-env.js';\n    18→import { registerRetryCommand } from './commands/retry.js';\n    19→import { registerTimeoutReportCommand } from './commands/timeout-report.js';\n    20→import { registerValidateStateCommand } from './commands/validate-state.js';\n    21→import { registerValidateCommand } from './commands/validate.js';\n    22→import { registerProgressCommand } from './commands/progress.js';\n    23→import { registerObservabilityGateCommand } from './commands/observability-gate.js';\n    24→import { registerAuditCommand } from './commands/audit.js';\n    25→\n    26→declare const __PKG_VERSION__: string;\n    27→const VERSION = typeof __PKG_VERSION__ !== 'undefined' ? __PKG_VERSION__ : '0.0.0-dev';\n    28→\n    29→export function createProgram(): Command {\n    30→  const program = new Command();\n    31→\n    32→  program\n    33→    .name('codeharness')\n    34→    .description('Makes autonomous coding agents produce software that actually works')\n    35→    .version(VERSION)\n    36→    .option('--json', 'Output in machine-readable JSON format');\n    37→\n    38→  registerInitCommand(program);\n    39→  registerBridgeCommand(program);\n    40→  registerRunCommand(program);\n    41→  registerVerifyCommand(program);\n    42→  registerStatusCommand(program);\n    43→  registerOnboardCommand(program);\n    44→  registerTeardownCommand(program);\n    45→  registerStateCommand(program);\n    46→  registerSyncCommand(program);\n    47→  registerCoverageCommand(program);\n    48→  registerDocHealthCommand(program);\n    49→  registerStackCommand(program);\n    50→  registerQueryCommand(program);\n    51→  registerRetroImportCommand(program);\n    52→  registerGithubImportCommand(program);\n    53→  registerVerifyEnvCommand(program);\n    54→  registerRetryCommand(program);\n    55→  registerTimeoutReportCommand(program);\n    56→  registerValidateStateCommand(program);\n    57→  registerValidateCommand(program);\n    58→  registerProgressCommand(program);\n    59→  registerObservabilityGateCommand(program);\n    60→  registerAuditCommand(program);\n    61→\n    62→  return program;\n    63→}\n    64→\n    65→// Only parse when running as CLI entry point, not when imported in tests\n    66→if (!process.env['VITEST']) {\n    67→  const program = createProgram();\n    68→  program.parse(process.argv);\n    69→}\n    70→"}]},"parent_tool_use_id":"toolu_01AaC2GBTKayFeJ7nzqM76bk","session_id":"1c9a200e-72ec-477b-8ec4-6d2e01a30422","uuid":"c46d5106-7411-4deb-b57b-97418e07fd00","timestamp":"2026-03-21T04:23:08.371Z"}
