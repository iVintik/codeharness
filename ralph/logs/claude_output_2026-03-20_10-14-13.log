{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VrQWFcpehcX5weqFgrEV5w","type":"tool_result","content":"   230→/**\n   231→ * Extract typed ObservabilityCoverageState from raw sprint-state.json data.\n   232→ * Returns defaults when the observability section doesn't exist.\n   233→ */\n   234→function extractCoverageState(\n   235→  state: Record<string, unknown>,\n   236→): ObservabilityCoverageState {\n   237→  const obs = state.observability as Record<string, unknown> | undefined;\n   238→  if (!obs) {\n   239→    return defaultCoverageState();\n   240→  }\n   241→\n   242→  const staticSection = obs.static as Record<string, unknown> | undefined;\n   243→  const targets = obs.targets as Record<string, unknown> | undefined;\n   244→  const runtimeSection = obs.runtime as Record<string, unknown> | undefined;\n   245→\n   246→  const runtime: RuntimeCoverageState | undefined =\n   247→    runtimeSection && typeof runtimeSection.coveragePercent === 'number'\n   248→      ? {\n   249→          coveragePercent: runtimeSection.coveragePercent,\n   250→          lastValidationTimestamp:\n   251→            typeof runtimeSection.lastValidationTimestamp === 'string'\n   252→              ? runtimeSection.lastValidationTimestamp : '',\n   253→          modulesWithTelemetry:\n   254→            typeof runtimeSection.modulesWithTelemetry === 'number'\n   255→              ? runtimeSection.modulesWithTelemetry : 0,\n   256→          totalModules:\n   257→            typeof runtimeSection.totalModules === 'number'\n   258→              ? runtimeSection.totalModules : 0,\n   259→          telemetryDetected:\n   260→            typeof runtimeSection.telemetryDetected === 'boolean'\n   261→              ? runtimeSection.telemetryDetected : false,\n   262→        }\n   263→      : undefined;\n   264→\n   265→  const result: ObservabilityCoverageState = {\n   266→    static: {\n   267→      coveragePercent:\n   268→        typeof staticSection?.coveragePercent === 'number'\n   269→          ? staticSection.coveragePercent\n   270→          : 0,\n   271→      lastScanTimestamp:\n   272→        typeof staticSection?.lastScanTimestamp === 'string'\n   273→          ? staticSection.lastScanTimestamp\n   274→          : '',\n   275→      history: Array.isArray(staticSection?.history)\n   276→        ? (staticSection.history as unknown[]).filter(\n   277→            (entry): entry is { coveragePercent: number; timestamp: string } =>\n   278→              typeof entry === 'object' &&\n   279→              entry !== null &&\n   280→              typeof (entry as Record<string, unknown>).coveragePercent ===\n   281→                'number' &&\n   282→              typeof (entry as Record<string, unknown>).timestamp === 'string',\n   283→          )\n   284→        : [],\n   285→    },\n   286→    targets: {\n   287→      staticTarget:\n   288→        typeof targets?.staticTarget === 'number'\n   289→          ? targets.staticTarget\n   290→          : DEFAULT_STATIC_TARGET,\n   291→      ...(typeof targets?.runtimeTarget === 'number'\n   292→        ? { runtimeTarget: targets.runtimeTarget }\n   293→        : {}),\n   294→    },\n   295→    ...(runtime ? { runtime } : {}),\n   296→  };\n   297→\n   298→  return result;\n   299→}\n   300→"}]},"parent_tool_use_id":"toolu_01KDp23Ghg12YdfCMhs2iDP9","session_id":"2fa32674-558d-4231-8eb7-1997dc535a41","uuid":"8bcd1b6e-f615-4599-abda-b1db13f596ce","timestamp":"2026-03-20T06:20:28.878Z"}
