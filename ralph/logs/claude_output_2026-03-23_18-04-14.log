ual([]);\n   206→  });\n   207→});\n   208→\n   209→describe('detectAppType', () => {\n   210→  // --- CLI detection ---\n   211→  it('returns \"cli\" for Node.js project with bin and no start script', () => {\n   212→    writeFileSync(\n   213→      join(testDir, 'package.json'),\n   214→      JSON.stringify({ name: 'my-cli', bin: { 'my-cli': './dist/cli.js' }, scripts: { build: 'tsc' } }),\n   215→    );\n   216→    expect(detectAppType(testDir, 'nodejs')).toBe('cli');\n   217→  });\n   218→\n   219→  it('returns \"cli\" for Node.js project with bin string and no start script', () => {\n   220→    writeFileSync(\n   221→      join(testDir, 'package.json'),\n   222→      JSON.stringify({ name: 'my-cli', bin: './dist/cli.js' }),\n   223→    );\n   224→    expect(detectAppType(testDir, 'nodejs')).toBe('cli');\n   225→  });\n   226→\n   227→  // --- Web detection ---\n   228→  it('returns \"web\" for Node.js project with react dependency', () => {\n   229→    writeFileSync(\n   230→      join(testDir, 'package.json'),\n   231→      JSON.stringify({ name: 'my-app', dependencies: { react: '^18.0.0' } }),\n   232→    );\n   233→    expect(detectAppType(testDir, 'nodejs')).toBe('web');\n   234→  });\n   235→\n   236→  it('returns \"web\" for Node.js project with vue dependency', () => {\n   237→    writeFileSync(\n   238→      join(testDir, 'package.json'),\n   239→      JSON.stringify({ name: 'my-app', dependencies: { vue: '^3.0.0' } }),\n   240→    );\n   241→    expect(detectAppType(testDir, 'nodejs')).toBe('web');\n   242→  });\n   243→\n   244→  it('returns \"web\" for Node.js project with vite devDependency', () => {\n   245→    writeFileSync(\n   246→      join(testDir, 'package.json'),\n   247→      JSON.stringify({ name: 'my-app', devDependencies: { vite: '^5.0.0' } }),\n   248→    );\n   249→    expect(detectAppType(testDir, 'nodejs')).toBe('web');\n   250→  });\n   251→\n   252→  it('returns \"web\" when index.html exists in project root', () => {\n   253→    w