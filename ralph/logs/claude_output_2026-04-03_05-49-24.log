{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015xTXBkW8eMuBg8WbHaUSZd","type":"tool_result","content":"1\timport { describe, it, expect, vi } from 'vitest';\n2\timport { createProgram } from '../index.js';\n3\t\n4\tdescribe('CLI entry point', () => {\n5\t  it('has correct name and description', () => {\n6\t    const program = createProgram();\n7\t    expect(program.name()).toBe('codeharness');\n8\t    expect(program.description()).toContain('autonomous coding agents');\n9\t  });\n10\t\n11\t  it('reports a valid semver version', () => {\n12\t    const program = createProgram();\n13\t    expect(program.version()).toMatch(/^\\d+\\.\\d+\\.\\d+$/);\n14\t  });\n15\t\n16\t  it('has --json global option', () => {\n17\t    const program = createProgram();\n18\t    const jsonOpt = program.options.find(o => o.long === '--json');\n19\t    expect(jsonOpt).toBeDefined();\n20\t  });\n21\t\n22\t  it('registers all 24 commands', () => {\n23\t    const program = createProgram();\n24\t    const commands = program.commands.filter(\n25\t      (c) => c.name() !== 'help'\n26\t    );\n27\t    const names = commands.map(c => c.name()).sort();\n28\t    // retry command removed (Story 1.2) — merged into workflow-state (Epic 5)\n29\t    expect(names).toEqual([\n30\t      'audit', 'bridge', 'coverage', 'doc-health', 'github-import', 'init', 'issue', 'observability-gate', 'onboard', 'progress', 'query', 'retro-import', 'run', 'stack', 'state', 'stats', 'status', 'sync', 'teardown', 'timeout-report', 'validate', 'validate-state', 'verify', 'verify-env',\n31\t    ]);\n32\t  });\n33\t\n34\t  it('registers stack command with subcommands', () => {\n35\t    const program = createProgram();\n36\t    const stackCmd = program.commands.find(c => c.name() === 'stack');\n37\t    expect(stackCmd).toBeDefined();\n38\t    const subNames = stackCmd!.commands.map(c => c.name()).sort();\n39\t    expect(subNames).toEqual(['start', 'status', 'stop']);\n40\t  });\n41\t\n42\t  it('registers state command with subcommands', () => {\n43\t    const program = createProgram();\n44\t    const stateCmd = program.commands.find(c => c.name() === 'state');\n45\t    expect(stateCmd).toBeDefined();\n46\t    const subNames = stateCmd!.commands.map(c => c.name()).sort();\n47\t    expect(subNames).toEqual(['get', 'reset-session', 'set', 'show']);\n48\t  });\n49\t\n50\t  it('--version outputs version string', async () => {\n51\t    const program = createProgram();\n52\t    program.exitOverride();\n53\t    const writeSpy = vi.spyOn(process.stdout, 'write').mockImplementation(() => true);\n54\t\n55\t    try {\n56\t      await program.parseAsync(['node', 'test', '--version']);\n57\t    } catch {\n58\t      // Commander throws on --version with exitOverride\n59\t    }\n60\t\n61\t    expect(writeSpy).toHaveBeenCalledWith(expect.stringMatching(/\\d+\\.\\d+\\.\\d+/));\n62\t    writeSpy.mockRestore();\n63\t  });\n64\t});\n65\t"}]},"parent_tool_use_id":"toolu_01CMZbq8RrvXCKSwd18t2Hto","session_id":"2800a04b-8151-4215-bf66-1f43973b9365","uuid":"ed679748-a242-4028-9d8b-fb8978f9b07d","timestamp":"2026-04-03T02:01:27.336Z"}
