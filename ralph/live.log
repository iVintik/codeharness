ons when all files above floor', () => {\n   746→    const coverageDir = join(testDir, 'coverage');\n   747→    mkdirSync(coverageDir, { recursive: true });\n   748→    writeFileSync(join(coverageDir, 'coverage-summary.json'), JSON.stringify({\n   749→      total: { statements: { pct: 95 } },\n   750→      '/project/src/good.ts': { statements: { pct: 95 }, branches: { pct: 90 }, functions: { pct: 100 }, lines: { pct: 95 } },\n   751→      '/project/src/also-good.ts': { statements: { pct: 88 }, branches: { pct: 82 }, functions: { pct: 100 }, lines: { pct: 88 } },\n   752→    }));\n   753→\n   754→    const result = checkPerFileCoverage(80, testDir);\n   755→    expect(result.violations).toHaveLength(0);\n   756→    expect(result.totalFiles).toBe(2);\n   757→    expect(result.floor).toBe(80);\n   758→  });\n   759→\n   760→  it('returns violations for files below floor', () => {\n   761→    const coverageDir = join(testDir, 'coverage');\n   762→    mkdirSync(coverageDir, { recursive: true });\n   763→    writeFileSync(join(coverageDir, 'coverage-summary.json'), JSON.stringify({\n   764→      total: { statements: { pct: 85 } },\n   765→      [join(testDir, 'src', 'good.ts')]: { statements: { pct: 100 }, branches: { pct: 100 }, functions: { pct: 100 }, lines: { pct: 100 } },\n   766→      [join(testDir, 'src', 'bad.ts')]: { statements: { pct: 30 }, branches: { pct: 20 }, functions: { pct: 50 }, lines: { pct: 30 } },\n   767→      [join(testDir, 'src', 'also-bad.ts')]: { statements: { pct: 60 }, branches: { pct: 55 }, functions: { pct: 75 }, lines: { pct: 60 } },\n   768→    }));\n   769→\n   770→    const result = checkPerFileCoverage(80, testDir);\n   771→    expect(result.violations).toHaveLength(2);\n   772→    expect(result.totalFiles).toBe(3);\n   773→    // Sorted worst first\n   774→    expect(result.violations[0].statements).toBe(30);\n   775→    expect(result.violations[0].file).toBe(join('src', 'bad.ts'));\n   776→    expect(result.violations[1].statements).to