{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BWWj7SEZkgvLVqTeNYboMY","type":"tool_result","content":"1\t/**\n2\t * Codex Driver — CLI-wrapped driver for OpenAI Codex.\n3\t *\n4\t * Spawns the `codex` CLI binary via child_process.spawn and parses\n5\t * its NDJSON stdout into StreamEvent objects.\n6\t *\n7\t * @see architecture-multi-framework.md — Decision 1: Driver Interface Design\n8\t * @see architecture-multi-framework.md — Decision 2: CLI-Wrapping Strategy\n9\t */\n10\t\n11\timport { spawn } from 'node:child_process';\n12\timport { execFile } from 'node:child_process';\n13\timport { createInterface } from 'node:readline';\n14\timport { promisify } from 'node:util';\n15\timport type {\n16\t  AgentDriver,\n17\t  DispatchOpts,\n18\t  DriverHealth,\n19\t  DriverCapabilities,\n20\t  ErrorCategory,\n21\t} from '../types.js';\n22\timport type { StreamEvent, ResultEvent } from '../stream-parser.js';\n23\t\n24\tconst execFileAsync = promisify(execFile);\n25\t\n26\t// --- Error Classification ---\n27\t\n28\tconst NETWORK_CODES = new Set([\n29\t  'ECONNREFUSED',\n30\t  'ETIMEDOUT',\n31\t  'ENOTFOUND',\n32\t  'ENETUNREACH',\n33\t  'ECONNRESET',\n34\t  'EPIPE',\n35\t]);\n36\t\n37\t/**\n38\t * Classify an error string or Error into a standard ErrorCategory.\n39\t *\n40\t * Priority order:\n41\t * 1. HTTP 429 or \"rate limit\" -> RATE_LIMIT\n42\t * 2. Known network error codes -> NETWORK\n43\t * 3. HTTP 401/403 or \"unauthorized\"/\"forbidden\" -> AUTH\n44\t * 4. Timeout -> TIMEOUT\n45\t * 5. Everything else -> UNKNOWN\n46\t */\n47\texport function classifyError(err: unknown): ErrorCategory {\n48\t  const message = err instanceof Error ? err.message : String(err);\n49\t  const code = (err as { code?: string })?.code;\n50\t  const status = (err as { status?: number })?.status;\n51\t\n52\t  // Rate limit: HTTP 429 or message containing \"rate limit\"\n53\t  if (status === 429 || /rate.?limit/i.test(message)) {\n54\t    return 'RATE_LIMIT';\n55\t  }\n56\t\n57\t  // Network errors: known error codes\n58\t  if (code && NETWORK_CODES.has(code)) {\n59\t    return 'NETWORK';\n60\t  }\n61\t  if (/fetch|network|dns/i.test(message) && /fail|error|timeout/i.test(message)) {\n62\t    return 'NETWORK';\n63\t  }\n64\t  if (/ECONNREFUSED|ETIMEDOUT|ENOTFOUND|ENETUNREACH|ECONNRESET|EPIPE/i.test(message)) {\n65\t    return 'NETWORK';\n66\t  }\n67\t\n68\t  // Auth errors: HTTP 401/403 or auth-related messages\n69\t  if (status === 401 || status === 403 || /unauthorized|forbidden/i.test(message)) {\n70\t    return 'AUTH';\n71\t  }\n72\t\n73\t  // Timeout\n74\t  if (/timeout|timed.?out|aborted/i.test(message)) {\n75\t    return 'TIMEOUT';\n76\t  }\n77\t\n78\t  return 'UNKNOWN';\n79\t}\n80\t\n81\t// --- Line Parser ---\n82\t\n83\t/**\n84\t * Parse a single line of Codex CLI NDJSON output into a StreamEvent.\n85\t * Returns null for unrecognized or unparseable lines.\n86\t */\n87\texport function parseLine(line: string): StreamEvent | null {\n88\t  const trimmed = line.trim();\n89\t  if (trimmed.length === 0) return null;\n90\t\n91\t  let parsed: Record<string, unknown>;\n92\t  try {\n93\t    parsed = JSON.parse(trimmed) as Record<string, unknown>;\n94\t  } catch { // IGNORE: malformed JSON in CLI output — skip unparseable lines\n95\t    return null;\n96\t  }\n97\t\n98\t  if (typeof parsed !== 'object' || parsed === null || Array.isArray(parsed)) {\n99\t    return null;\n100\t  }\n101\t\n102\t  const type = parsed.type as string | undefined;\n103\t\n104\t  if (type === 'tool_call') {\n105\t    const name = parsed.name;\n106\t    const callId = parsed.call_id;\n107\t    if (typeof name === 'string' && typeof callId === 'string') {\n108\t      return { type: 'tool-start', name, id: callId };\n109\t    }\n110\t    return null;\n111\t  }\n112\t\n113\t  if (type === 'tool_input') {\n114\t    const input = parsed.input;\n115\t    if (typeof input === 'string') {\n116\t      return { type: 'tool-input', partial: input };\n117\t    }\n118\t    return null;\n119\t  }\n120\t\n121\t  if (type === 'tool_result') {\n122\t    return { type: 'tool-complete' };\n123\t  }\n124\t\n125\t  if (type === 'message') {\n126\t    const content = parsed.content;\n127\t    if (typeof content === 'string') {\n128\t      return { type: 'text', text: content };\n129\t    }\n130\t    return null;\n131\t  }\n132\t\n133\t  if (type === 'retry') {\n134\t    const attempt = parsed.attempt;\n135\t    const delay = parsed.delay_ms;\n136\t    if (typeof attempt === 'number' && typeof delay === 'number') {\n137\t      return { type: 'retry', attempt, delay };\n138\t    }\n139\t    return null;\n140\t  }\n141\t\n142\t  if (type === 'result') {\n143\t    const costUsd = parsed.cost_usd;\n144\t    const sessionId = parsed.session_id;\n145\t    return {\n146\t      type: 'result',\n147\t      cost: typeof costUsd === 'number' ? costUsd : 0,\n148\t      sessionId: typeof sessionId === 'string' ? sessionId : '',\n149\t      cost_usd: typeof costUsd === 'number' ? costUsd : null,\n150\t    };\n151\t  }\n152\t\n153\t  return null;\n154\t}\n155\t\n156\t// --- Driver Implementation ---\n157\t\n158\t/**\n159\t * CodexDriver — CLI-wrapped AgentDriver for OpenAI Codex.\n160\t *\n161\t * Spawns `codex` CLI via child_process.spawn, parses stdout line-by-line\n162\t * into StreamEvent objects. Stateless between dispatches except `lastCost`.\n163\t */\n164\texport class CodexDriver implements AgentDriver {\n165\t  readonly name = 'codex' as const;\n166\t  readonly defaultModel = 'codex-mini' as const;\n167\t  readonly capabilities: DriverCapabilities = {\n168\t    supportsPlugins: false,\n169\t    supportsStreaming: true,\n170\t    costReporting: true,\n171\t  };\n172\t\n173\t  private lastCost: number | null = null;\n174\t\n175\t  async healthCheck(): Promise<DriverHealth> {\n176\t    // Check if codex binary is on PATH\n177\t    try {\n178\t      await execFileAsync('which', ['codex']);\n179\t    } catch { // IGNORE: binary not on PATH — expected condition for health check\n180\t      return {\n181\t        available: false,\n182\t        authenticated: false,\n183\t        version: null,\n184\t        error: 'codex CLI not found. Install: npm install -g @openai/codex',\n185\t      };\n186\t    }\n187\t\n188\t    // Get version\n189\t    let version: string | null = null;\n190\t    try {\n191\t      const { stdout } = await execFileAsync('codex', ['--version']);\n192\t      version = stdout.trim() || null;\n193\t    } catch { // IGNORE: version check failed — binary exists but version unknown\n194\t      // noop\n195\t    }\n196\t\n197\t    // Check auth status\n198\t    let authenticated = false;\n199\t    try {\n200\t      await execFileAsync('codex', ['auth', 'status']);\n201\t      authenticated = true;\n202\t    } catch { // IGNORE: auth check failed or command not supported — treat as unauthenticated\n203\t      // noop\n204\t    }\n205\t\n206\t    return { available: true, authenticated, version };\n207\t  }\n208\t\n209\t  async *dispatch(opts: DispatchOpts): AsyncGenerator<StreamEvent> {\n210\t    this.lastCost = null;\n211\t\n212\t    // Warn about plugins\n213\t    if (opts.plugins && opts.plugins.length > 0) {\n214\t      console.warn(\n215\t        '[CodexDriver] Codex does not support plugins. Ignoring plugins:',\n216\t        opts.plugins,\n217\t      );\n218\t    }\n219\t\n220\t    // Build CLI args\n221\t    const args: string[] = [];\n222\t    if (opts.model) {\n223\t      args.push('--model', opts.model);\n224\t    }\n225\t    if (opts.cwd) {\n226\t      args.push('--cwd', opts.cwd);\n227\t    }\n228\t    args.push(opts.prompt);\n229\t\n230\t    let yieldedResult = false;\n231\t    let timedOut = false;\n232\t    let timeoutId: ReturnType<typeof setTimeout> | undefined;\n233\t\n234\t    const proc = spawn('codex', args, {\n235\t      stdio: ['ignore', 'pipe', 'pipe'],\n236\t    });\n237\t\n238\t    // Timeout handling\n239\t    if (opts.timeout) {\n240\t      timeoutId = setTimeout(() => {\n241\t        timedOut = true;\n242\t        proc.kill();\n243\t      }, opts.timeout);\n244\t    }\n245\t\n246\t    // Collect stderr for error classification\n247\t    let stderrData = '';\n248\t    proc.stderr.on('data', (chunk: Buffer) => {\n249\t      stderrData += chunk.toString();\n250\t    });\n251\t\n252\t    // Parse stdout line-by-line\n253\t    const rl = createInterface({ input: proc.stdout });\n254\t\n255\t    // Capture close promise BEFORE iterating — close may fire during readline iteration\n256\t    const closePromise = new Promise<number | null>((resolve) => {\n257\t      proc.on('close', (code: number | null) => resolve(code));\n258\t    });\n259\t\n260\t    try {\n261\t      for await (const line of rl) {\n262\t        const event = parseLine(line);\n263\t        if (event) {\n264\t          // Capture cost from result events\n265\t          if (event.type === 'result') {\n266\t            const resultEvent = event as ResultEvent;\n267\t            if (typeof resultEvent.cost_usd === 'number') {\n268\t              this.lastCost = resultEvent.cost_usd;\n269\t            }\n270\t            yield event;\n271\t            yieldedResult = true;\n272\t          } else {\n273\t            yield event;\n274\t          }\n275\t        } else {\n276\t          // Unparseable line — log at debug level and skip\n277\t          console.debug('[CodexDriver] Skipping unparseable line:', line);\n278\t        }\n279\t      }\n280\t\n281\t      // Wait for process to close (promise was registered before readline started)\n282\t      const exitCode = await closePromise;\n283\t\n284\t      // Handle non-zero exit\n285\t      if (exitCode !== null && exitCode !== 0 && !yieldedResult) {\n286\t        const errorText = stderrData || `codex exited with code ${exitCode}`;\n287\t        const category = timedOut ? 'TIMEOUT' : classifyError(errorText);\n288\t\n289\t        yield {\n290\t          type: 'result',\n291\t          cost: this.lastCost ?? 0,\n292\t          sessionId: '',\n293\t          cost_usd: this.lastCost,\n294\t          error: errorText,\n295\t          errorCategory: category,\n296\t        } as ResultEvent;\n297\t        yieldedResult = true;\n298\t      }\n299\t    } catch (err: unknown) {\n300\t      const errorMessage = err instanceof Error ? err.message : String(err);\n301\t      const category = timedOut ? 'TIMEOUT' : classifyError(err);\n302\t\n303\t      yield {\n304\t        type: 'result',\n305\t        cost: this.lastCost ?? 0,\n306\t        sessionId: '',\n307\t        cost_usd: this.lastCost,\n308\t        error: errorMessage,\n309\t        errorCategory: category,\n310\t      } as ResultEvent;\n311\t      yieldedResult = true;\n312\t    } finally {\n313\t      if (timeoutId) {\n314\t        clearTimeout(timeoutId);\n315\t      }\n316\t    }\n317\t\n318\t    // Guarantee a result event is always yielded\n319\t    if (!yieldedResult) {\n320\t      yield {\n321\t        type: 'result',\n322\t        cost: this.lastCost ?? 0,\n323\t        sessionId: '',\n324\t        cost_usd: this.lastCost,\n325\t      } as ResultEvent;\n326\t    }\n327\t  }\n328\t\n329\t  getLastCost(): number | null {\n330\t    return this.lastCost;\n331\t  }\n332\t}\n333\t"}]},"parent_tool_use_id":"toolu_01MERTQEVoM1FQ7mMnPAJnfv","session_id":"49777568-67d3-419d-b985-1c272283fc99","uuid":"71824096-ff80-4411-96bd-a4f0450d0544","timestamp":"2026-04-03T12:24:45.739Z"}
