{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VarvnGFvHvLAA1iZitKkNA","type":"tool_result","content":"     1→/**\n     2→ * Verification environment management: Docker image lifecycle, clean workspace,\n     3→ * and environment checks for black-box verification.\n     4→ */\n     5→import { execFileSync } from 'node:child_process';\n     6→import { existsSync, mkdirSync, readdirSync, readFileSync, cpSync, rmSync, statSync } from 'node:fs';\n     7→import { join, basename } from 'node:path';\n     8→import { createHash } from 'node:crypto';\n     9→import { info } from '../../lib/output.js';\n    10→import { detectStack } from '../../lib/stack-detect.js';\n    11→import { readStateWithBody, writeState } from '../../lib/state.js';\n    12→import { isDockerAvailable } from '../../lib/docker.js';\n    13→import type { BuildOptions, BuildResult, CheckResult, ProjectType } from './types.js';\n    14→\n    15→const IMAGE_TAG = 'codeharness-verify';\n    16→const STORY_DIR = '_bmad-output/implementation-artifacts';\n    17→const TEMP_PREFIX = '/tmp/codeharness-verify-';\n    18→const STATE_KEY_DIST_HASH = 'verify_env_dist_hash';\n    19→\n    20→/** Validates that a story key is safe for file paths and container names. */\n    21→export function isValidStoryKey(storyKey: string): boolean {\n    22→  if (!storyKey || storyKey.includes('..') || storyKey.includes('/') || storyKey.includes('\\\\')) {\n    23→    return false;\n    24→  }\n    25→  return /^[a-zA-Z0-9_-]+$/.test(storyKey);\n    26→}\n    27→\n    28→/** Computes a SHA-256 hash of all files in dist/ for cache invalidation. */\n    29→export function computeDistHash(projectDir: string): string | null {\n    30→  const distDir = join(projectDir, 'dist');\n    31→  if (!existsSync(distDir)) return null;\n    32→  const hash = createHash('sha256');\n    33→  const files = collectFiles(distDir).sort();\n    34→  for (const file of files) {\n    35→    hash.update(file.slice(distDir.length));\n    36→    hash.update(readFileSync(file));\n    37→  }\n    38→  return hash.digest('hex');\n    39→}\n    40→\n    41→function collectFiles(dir: string): string[] {\n    42→  const results: string[] = [];\n    43→  for (const entry of readdirSync(dir, { withFileTypes: true })) {\n    44→    const fullPath = join(dir, entry.name);\n    45→    if (entry.isDirectory()) { results.push(...collectFiles(fullPath)); }\n    46→    else { results.push(fullPath); }\n    47→  }\n    48→  return results;\n    49→}\n    50→\n    51→function getStoredDistHash(projectDir: string): string | null {\n    52→  try {\n    53→    const { state } = readStateWithBody(projectDir);\n    54→    return ((state as unknown as Record<string, unknown>)[STATE_KEY_DIST_HASH] as string) ?? null;\n    55→  } catch { return null; }\n    56→}\n    57→\n    58→function storeDistHash(projectDir: string, hash: string): void {\n    59→  try {\n    60→    const { state, body } = readStateWithBody(projectDir);\n    61→    (state as unknown as Record<string, unknown>)[STATE_KEY_DIST_HASH] = hash;\n    62→    writeState(state, projectDir, body);\n    63→  } catch {\n    64→    info('Could not persist dist hash to state file — cache will not be available until state is initialized');\n    65→  }\n    66→}\n    67→\n    68→/** Detects the project type for verification strategy selection. */\n    69→export function detectProjectType(projectDir: string): ProjectType {\n    70→  const stack = detectStack(projectDir);\n    71→  // Prefer nodejs/python when the project has a buildable package — the npm tarball\n    72→  // or Python wheel includes all distributable files. Plugin-only detection is the\n    73→  // fallback for projects that are purely Claude Code plugins with no build artifact.\n    74→  if (stack === 'nodejs') return 'nodejs';\n    75→  if (stack === 'python') return 'python';\n    76→  if (stack === 'rust') return 'rust';\n    77→  if (existsSync(join(projectDir, '.claude-plugin', 'plugin.json'))) return 'plugin';\n    78→  return 'generic';\n    79→}\n    80→\n    81→/** Builds the verification Docker image with cache invalidation. */\n    82→export function buildVerifyImage(options: BuildOptions = {}): BuildResult {\n    83→  const projectDir = options.projectDir ?? process.cwd();\n    84→  if (!isDockerAvailable()) {\n    85→    throw new Error('Docker is not available. Install Docker and ensure the daemon is running.');\n    86→  }\n    87→  const projectType = detectProjectType(projectDir);\n    88→  const currentHash = computeDistHash(projectDir);\n    89→  if (projectType === 'generic' || projectType === 'plugin' || projectType === 'rust') {\n    90→    // Generic, plugin, and Rust projects may not have dist/ — skip hash check\n    91→  } else if (!currentHash) {\n    92→    throw new Error('No dist/ directory found. Run your build command first (e.g., npm run build).');\n    93→  }\n    94→  if (currentHash) {\n    95→    const storedHash = getStoredDistHash(projectDir);\n    96→    if (storedHash === currentHash && dockerImageExists(IMAGE_TAG)) {\n    97→      return { imageTag: IMAGE_TAG, imageSize: getImageSize(IMAGE_TAG), buildTimeMs: 0, cached: true };\n    98→    }\n    99→  }\n   100→  const startTime = Date.now();\n   101→  if (projectType === 'nodejs') { buildNodeImage(projectDir); }\n   102→  else if (projectType === 'python') { buildPythonImage(projectDir); }\n   103→  else if (projectType === 'rust') { buildSimpleImage(projectDir, 'rust', 300_000); }\n   104→  else if (projectType === 'plugin') { buildPluginImage(projectDir); }\n   105→  else { buildSimpleImage(projectDir, 'generic'); }\n   106→  if (currentHash) { storeDistHash(projectDir, currentHash); }\n   107→  return { imageTag: IMAGE_TAG, imageSize: getImageSize(IMAGE_TAG), buildTimeMs: Date.now() - startTime, cached: false };\n   108→}\n   109→\n   110→function buildNodeImage(projectDir: string): void {\n   111→  const packOutput = execFileSync('npm', ['pack', '--pack-destination', '/tmp'], {\n   112→    cwd: projectDir, stdio: 'pipe', timeout: 60_000,\n   113→  }).toString().trim();\n   114→  const lastLine = packOutput.split('\\n').pop()?.trim();\n   115→  if (!lastLine) throw new Error('npm pack produced no output — cannot determine tarball filename.');\n   116→  const tarballName = basename(lastLine);\n   117→  const tarballPath = join('/tmp', tarballName);\n   118→  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   119→  mkdirSync(buildContext, { recursive: true });\n   120→  try {\n   121→    cpSync(tarballPath, join(buildContext, tarballName));\n   122→    cpSync(resolveDockerfileTemplate(projectDir), join(buildContext, 'Dockerfile'));\n   123→    execFileSync('docker', ['build', '-t', IMAGE_TAG, '--build-arg', `TARBALL=${tarballName}`, '.'], {\n   124→      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   125→    });\n   126→  } finally {\n   127→    rmSync(buildContext, { recursive: true, force: true });\n   128→    rmSync(tarballPath, { force: true });\n   129→  }\n   130→}\n   131→\n   132→function buildPythonImage(projectDir: string): void {\n   133→  const distDir = join(projectDir, 'dist');\n   134→  const distFiles = readdirSync(distDir).filter(f => f.endsWith('.tar.gz') || f.endsWith('.whl'));\n   135→  if (distFiles.length === 0) {\n   136→    throw new Error('No distribution files found in dist/. Run your build command first (e.g., python -m build).');\n   137→  }\n   138→  const distFile = distFiles.filter(f => f.endsWith('.tar.gz'))[0] ?? distFiles[0];\n   139→  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   140→  mkdirSync(buildContext, { recursive: true });\n   141→  try {\n   142→    cpSync(join(distDir, distFile), join(buildContext, distFile));\n   143→    cpSync(resolveDockerfileTemplate(projectDir), join(buildContext, 'Dockerfile'));\n   144→    execFileSync('docker', ['build', '-t', IMAGE_TAG, '--build-arg', `TARBALL=${distFile}`, '.'], {\n   145→      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   146→    });\n   147→  } finally {\n   148→    rmSync(buildContext, { recursive: true, force: true });\n   149→  }\n   150→}\n   151→\n   152→/** Creates a clean temp workspace for verification (no src/, tests/, .git/). */\n   153→export function prepareVerifyWorkspace(storyKey: string, projectDir?: string): string {\n   154→  const root = projectDir ?? process.cwd();\n   155→  if (!isValidStoryKey(storyKey)) {\n   156→    throw new Error(`Invalid story key: ${storyKey}. Keys must contain only alphanumeric characters, hyphens, and underscores.`);\n   157→  }\n   158→  const storyFile = join(root, STORY_DIR, `${storyKey}.md`);\n   159→  if (!existsSync(storyFile)) throw new Error(`Story file not found: ${storyFile}`);\n   160→  const workspace = `${TEMP_PREFIX}${storyKey}`;\n   161→  if (existsSync(workspace)) rmSync(workspace, { recursive: true, force: true });\n   162→  mkdirSync(workspace, { recursive: true });\n   163→  cpSync(storyFile, join(workspace, 'story.md'));\n   164→  const readmePath = join(root, 'README.md');\n   165→  if (existsSync(readmePath)) cpSync(readmePath, join(workspace, 'README.md'));\n   166→  const docsDir = join(root, 'docs');\n   167→  if (existsSync(docsDir) && statSync(docsDir).isDirectory()) {\n   168→    cpSync(docsDir, join(workspace, 'docs'), { recursive: true });\n   169→  }\n   170→  mkdirSync(join(workspace, 'verification'), { recursive: true });\n   171→  return workspace;\n   172→}\n   173→\n   174→/** Validates verification environment: image, CLI, observability. */\n   175→export function checkVerifyEnv(): CheckResult {\n   176→  let imageExists = false;\n   177→  let cliWorks = false;\n   178→  let otelReachable = false;\n   179→\n   180→  imageExists = dockerImageExists(IMAGE_TAG);\n   181→  if (!imageExists) return { imageExists, cliWorks, otelReachable };\n   182→  try {\n   183→    execFileSync('docker', ['run', '--rm', IMAGE_TAG, 'codeharness', '--help'], {\n   184→      stdio: 'pipe', timeout: 30_000,\n   185→    });\n   186→    cliWorks = true;\n   187→  } catch { cliWorks = false; }\n   188→  try {\n   189→    execFileSync('docker', [\n   190→      'run', '--rm', '--add-host=host.docker.internal:host-gateway', IMAGE_TAG,\n   191→      'curl', '-sf', '--max-time', '5', 'http://host.docker.internal:4318/v1/status',\n   192→    ], { stdio: 'pipe', timeout: 30_000 });\n   193→    otelReachable = true;\n   194→  } catch { otelReachable = false; }\n   195→  return { imageExists, cliWorks, otelReachable };\n   196→}\n   197→\n   198→/** Cleans up all stale containers matching `codeharness-verify-*` pattern. Idempotent. */\n   199→export function cleanupStaleContainers(): void {\n   200→  try {\n   201→    const output = execFileSync(\n   202→      'docker', ['ps', '-a', '--filter', 'name=codeharness-verify-', '--format', '{{.Names}}'],\n   203→      { stdio: 'pipe', timeout: 15_000 },\n   204→    ).toString('utf-8').trim();\n   205→    if (output.length === 0) return;\n   206→    const containers = output.split('\\n').filter(name => name.length > 0);\n   207→    for (const name of containers) {\n   208→      try {\n   209→        execFileSync('docker', ['rm', '-f', name], { stdio: 'pipe', timeout: 15_000 });\n   210→      } catch { /* container may already be removed */ }\n   211→    }\n   212→  } catch { /* docker not available or no containers — ignore */ }\n   213→}\n   214→\n   215→/** Removes temp workspace and stops/removes the container. Idempotent. */\n   216→export function cleanupVerifyEnv(storyKey: string): void {\n   217→  if (!isValidStoryKey(storyKey)) {\n   218→    throw new Error(`Invalid story key: ${storyKey}. Keys must contain only alphanumeric characters, hyphens, and underscores.`);\n   219→  }\n   220→  const workspace = `${TEMP_PREFIX}${storyKey}`;\n   221→  const containerName = `codeharness-verify-${storyKey}`;\n   222→  if (existsSync(workspace)) rmSync(workspace, { recursive: true, force: true });\n   223→  try { execFileSync('docker', ['stop', containerName], { stdio: 'pipe', timeout: 15_000 }); }\n   224→  catch { /* container may not exist */ }\n   225→  try { execFileSync('docker', ['rm', '-f', containerName], { stdio: 'pipe', timeout: 15_000 }); }\n   226→  catch { /* container may not exist */ }\n   227→}\n   228→\n   229→function buildPluginImage(projectDir: string): void {\n   230→  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   231→  mkdirSync(buildContext, { recursive: true });\n   232→  try {\n   233→    // Copy plugin source into build context\n   234→    const pluginDir = join(projectDir, '.claude-plugin');\n   235→    cpSync(pluginDir, join(buildContext, '.claude-plugin'), { recursive: true });\n   236→    // Copy any commands, hooks, knowledge, skills directories if they exist\n   237→    for (const dir of ['commands', 'hooks', 'knowledge', 'skills']) {\n   238→      const src = join(projectDir, dir);\n   239→      if (existsSync(src) && statSync(src).isDirectory()) {\n   240→        cpSync(src, join(buildContext, dir), { recursive: true });\n   241→      }\n   242→    }\n   243→    cpSync(resolveDockerfileTemplate(projectDir, 'generic'), join(buildContext, 'Dockerfile'));\n   244→    execFileSync('docker', ['build', '-t', IMAGE_TAG, '.'], {\n   245→      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   246→    });\n   247→  } finally {\n   248→    rmSync(buildContext, { recursive: true, force: true });\n   249→  }\n   250→}\n   251→\n   252→function buildSimpleImage(projectDir: string, variant: string, timeout = 120_000): void {\n   253→  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   254→  mkdirSync(buildContext, { recursive: true });\n   255→  try {\n   256→    cpSync(resolveDockerfileTemplate(projectDir, variant), join(buildContext, 'Dockerfile'));\n   257→    execFileSync('docker', ['build', '-t', IMAGE_TAG, '.'], {\n   258→      cwd: buildContext, stdio: 'pipe', timeout,\n   259→    });\n   260→  } finally {\n   261→    rmSync(buildContext, { recursive: true, force: true });\n   262→  }\n   263→}\n   264→\n   265→const DOCKERFILE_VARIANTS: Record<string, string> = {\n   266→  generic: 'Dockerfile.verify.generic',\n   267→  rust: 'Dockerfile.verify.rust',\n   268→};\n   269→\n   270→function resolveDockerfileTemplate(projectDir: string, variant?: string): string {\n   271→  const filename = (variant && DOCKERFILE_VARIANTS[variant]) ?? 'Dockerfile.verify';\n   272→  const local = join(projectDir, 'templates', filename);\n   273→  if (existsSync(local)) return local;\n   274→  const pkgDir = new URL('../../', import.meta.url).pathname;\n   275→  const pkg = join(pkgDir, 'templates', filename);\n   276→  if (existsSync(pkg)) return pkg;\n   277→  throw new Error(`${filename} not found. Ensure templates/${filename} exists.`);\n   278→}\n   279→\n   280→function dockerImageExists(tag: string): boolean {\n   281→  try {\n   282→    execFileSync('docker', ['image', 'inspect', tag], { stdio: 'pipe', timeout: 10_000 });\n   283→    return true;\n   284→  } catch { return false; }\n   285→}\n   286→\n   287→function getImageSize(tag: string): string {\n   288→  try {\n   289→    const output = execFileSync('docker', ['image', 'inspect', tag, '--format', '{{.Size}}'], {\n   290→      stdio: 'pipe', timeout: 10_000,\n   291→    }).toString().trim();\n   292→    const bytes = parseInt(output, 10);\n   293→    if (isNaN(bytes)) return output;\n   294→    if (bytes >= 1_000_000_000) return `${(bytes / 1_000_000_000).toFixed(1)}GB`;\n   295→    if (bytes >= 1_000_000) return `${(bytes / 1_000_000).toFixed(1)}MB`;\n   296→    if (bytes >= 1_000) return `${(bytes / 1_000).toFixed(1)}KB`;\n   297→    return `${bytes}B`;\n   298→  } catch { return 'unknown'; }\n   299→}\n   300→"}]},"parent_tool_use_id":"toolu_01CVfsuk3fYkb5FT4qRVJXrF","session_id":"58ae4f51-bff6-4a66-807a-d4f10c8bdaa3","uuid":"d893c532-cd68-4347-9f95-7035e3cdf6d7","timestamp":"2026-03-23T15:42:18.429Z"}
