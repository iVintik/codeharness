{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TP8RuYoHVDy1P8YUxPbmgr","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→\n     3→vi.mock('node:child_process', () => ({\n     4→  execFileSync: vi.fn(),\n     5→}));\n     6→\n     7→import { analyze, runSemgrep, parseSemgrepOutput } from '../analyzer.js';\n     8→import { execFileSync } from 'node:child_process';\n     9→import type { SemgrepRawOutput } from '../types.js';\n    10→\n    11→const mockExecFileSync = vi.mocked(execFileSync);\n    12→\n    13→beforeEach(() => {\n    14→  vi.clearAllMocks();\n    15→});\n    16→\n    17→function makeSemgrepOutput(\n    18→  results: SemgrepRawOutput['results'],\n    19→): SemgrepRawOutput {\n    20→  return { results };\n    21→}\n    22→\n    23→// ============================================================\n    24→// Semgrep rule integration: error-handling rules\n    25→// ============================================================\n    26→\n    27→describe('error-handling rules integration', () => {\n    28→  it('parseSemgrepOutput maps no-bare-except-pass findings with error severity', () => {\n    29→    const raw = makeSemgrepOutput([\n    30→      {\n    31→        check_id: 'no-bare-except-pass',\n    32→        path: 'app/main.py',\n    33→        start: { line: 10, col: 1 },\n    34→        end: { line: 13, col: 9 },\n    35→        extra: {\n    36→          message:\n    37→            'Bare `except Exception: pass` swallows errors silently. Handle the error, log it, or add a # IGNORE: comment explaining why.',\n    38→          severity: 'ERROR',\n    39→        },\n    40→      },\n    41→    ]);\n    42→\n    43→    const gaps = parseSemgrepOutput(raw);\n    44→\n    45→    expect(gaps).toHaveLength(1);\n    46→    expect(gaps[0]).toEqual({\n    47→      file: 'app/main.py',\n    48→      line: 10,\n    49→      type: 'no-bare-except-pass',\n    50→      description: expect.stringContaining('except Exception: pass'),\n    51→      severity: 'error',\n    52→    });\n    53→  });\n    54→\n    55→  it('parseSemgrepOutput maps no-bare-except-ellipsis findings with error severity', () => {\n    56→    const raw = makeSemgrepOutput([\n    57→      {\n    58→        check_id: 'no-bare-except-ellipsis',\n    59→        path: 'lib/utils.py',\n    60→        start: { line: 25, col: 1 },\n    61→        end: { line: 28, col: 9 },\n    62→        extra: {\n    63→          message:\n    64→            'Bare `except Exception: ...` swallows errors silently. Handle the error, log it, or add a # IGNORE: comment explaining why.',\n    65→          severity: 'ERROR',\n    66→        },\n    67→      },\n    68→    ]);\n    69→\n    70→    const gaps = parseSemgrepOutput(raw);\n    71→\n    72→    expect(gaps).toHaveLength(1);\n    73→    expect(gaps[0]).toEqual({\n    74→      file: 'lib/utils.py',\n    75→      line: 25,\n    76→      type: 'no-bare-except-ellipsis',\n    77→      description: expect.stringContaining('except Exception: ...'),\n    78→      severity: 'error',\n    79→    });\n    80→  });\n    81→\n    82→  it('ERROR severity from Semgrep normalizes to error (high severity)', () => {\n    83→    const raw = makeSemgrepOutput([\n    84→      {\n    85→        check_id: 'no-bare-except-pass',\n    86→        path: 'test.py',\n    87→        start: { line: 1, col: 1 },\n    88→        end: { line: 4, col: 9 },\n    89→        extra: {\n    90→          message: 'Bare except',\n    91→          severity: 'ERROR',\n    92→        },\n    93→      },\n    94→    ]);\n    95→\n    96→    const gaps = parseSemgrepOutput(raw);\n    97→    expect(gaps[0]!.severity).toBe('error');\n    98→  });\n    99→\n   100→  it('analyze includes error-handling rules directory by default', () => {\n   101→    mockExecFileSync\n   102→      .mockReturnValueOnce(Buffer.from('1.50.0'))\n   103→      .mockReturnValueOnce(JSON.stringify(makeSemgrepOutput([])));\n   104→\n   105→    analyze('/project');\n   106→\n   107→    // Second call is the actual semgrep scan\n   108→    const scanCall = mockExecFileSync.mock.calls[1];\n   109→    expect(scanCall).toBeDefined();\n   110→    const args = scanCall![1] as string[];\n   111→    // Should include --config for both observability and error-handling\n   112→    expect(args).toContain('--config');\n   113→    expect(args.some(a => a.includes('patches/error-handling/'))).toBe(true);\n   114→    expect(args.some(a => a.includes('patches/observability/'))).toBe(true);\n   115→  });\n   116→\n   117→  it('analyze with custom additionalRulesDirs overrides defaults', () => {\n   118→    mockExecFileSync\n   119→      .mockReturnValueOnce(Buffer.from('1.50.0'))\n   120→      .mockReturnValueOnce(JSON.stringify(makeSemgrepOutput([])));\n   121→\n   122→    analyze('/project', { additionalRulesDirs: ['custom/error-rules/'] });\n   123→\n   124→    const scanCall = mockExecFileSync.mock.calls[1];\n   125→    const args = scanCall![1] as string[];\n   126→    expect(args.some(a => a.includes('custom/error-rules/'))).toBe(true);\n   127→    // Should NOT include the default error-handling dir\n   128→    expect(args.some(a => a.includes('patches/error-handling/'))).toBe(false);\n   129→  });\n   130→\n   131→  it('analyze with empty additionalRulesDirs disables additional dirs', () => {\n   132→    mockExecFileSync\n   133→      .mockReturnValueOnce(Buffer.from('1.50.0'))\n   134→      .mockReturnValueOnce(JSON.stringify(makeSemgrepOutput([])));\n   135→\n   136→    analyze('/project', { additionalRulesDirs: [] });\n   137→\n   138→    const scanCall = mockExecFileSync.mock.calls[1];\n   139→    const args = scanCall![1] as string[];\n   140→    // Should only have one --config for the primary rules dir\n   141→    const configIndices = args.reduce<number[]>((acc, a, i) => {\n   142→      if (a === '--config') acc.push(i);\n   143→      return acc;\n   144→    }, []);\n   145→    e