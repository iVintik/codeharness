{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JKcaoAftVL7sjTTvUdEJwE","type":"tool_result","content":"     1→/** Coverage state persistence — tracks observability coverage in sprint-state.json. */\n     2→\n     3→import { readFileSync, writeFileSync, renameSync, existsSync } from 'node:fs';\n     4→import { join } from 'node:path';\n     5→import { ok, fail } from '../../types/result.js';\n     6→import type { Result } from '../../types/result.js';\n     7→import type {\n     8→  AnalyzerResult,\n     9→  ObservabilityCoverageState,\n    10→  CoverageTrend,\n    11→  CoverageTargetResult,\n    12→  RuntimeCoverageState,\n    13→  ObservabilityGap,\n    14→  GapSeverity,\n    15→} from './types.js';\n    16→\n    17→const STATE_FILE = 'sprint-state.json';\n    18→const TMP_FILE = '.sprint-state.json.tmp';\n    19→const DEFAULT_STATIC_TARGET = 80;\n    20→const MAX_HISTORY_ENTRIES = 100;\n    21→\n    22→/** Default observability coverage state when none exists. */\n    23→function defaultCoverageState(): ObservabilityCoverageState {\n    24→  return {\n    25→    static: {\n    26→      coveragePercent: 0,\n    27→      lastScanTimestamp: '',\n    28→      history: [],\n    29→    },\n    30→    targets: {\n    31→      staticTarget: DEFAULT_STATIC_TARGET,\n    32→    },\n    33→  };\n    34→}\n    35→\n    36→/** Read the full sprint-state.json as a generic record. */\n    37→function readStateFile(projectDir: string): Result<Record<string, unknown>> {\n    38→  const fp = join(projectDir, STATE_FILE);\n    39→  if (!existsSync(fp)) {\n    40→    return ok({});\n    41→  }\n    42→  try {\n    43→    const raw = readFileSync(fp, 'utf-8');\n    44→    const parsed = JSON.parse(raw) as Record<string, unknown>;\n    45→    return ok(parsed);\n    46→  } catch (err: unknown) {\n    47→    const msg = err instanceof Error ? err.message : String(err);\n    48→    return fail(`Failed to read ${STATE_FILE}: ${msg}`);\n    49→  }\n    50→}\n    51→\n    52→/** Write sprint-state.json atomically (write to temp, then rename). */\n    53→function writeStateAtomic(\n    54→  projectDir: string,\n    55→  state: Record<string, unknown>,\n    56→): Result<void> {\n    57→  try {\n    58→    const data = JSON.stringify(state, null, 2) + '\\n';\n    59→    const tmp = join(projectDir, TMP_FILE);\n    60→    const final = join(projectDir, STATE_FILE);\n    61→    writeFileSync(tmp, data, 'utf-8');\n    62→    renameSync(tmp, final);\n    63→    return ok(undefined);\n    64→  } catch (err: unknown) {\n    65→    const msg = err instanceof Error ? err.message : String(err);\n    66→    return fail(`Failed to write ${STATE_FILE}: ${msg}`);\n    67→  }\n    68→}\n    69→\n    70→/** Save coverage result from an analysis run into sprint-state.json. */\n    71→export function saveCoverageResult(\n    72→  projectDir: string,\n    73→  result: AnalyzerResult,\n    74→): Result<void> {\n    75→  if (!projectDir || typeof projectDir !== 'string') {\n    76→    return fail('projectDir is required and must be a non-empty string');\n    77→  }\n    78→\n    79→  const stateResult = readStateFile(projectDir);\n    80→  if (!stateResult.success) {\n    81→    return fail(stateResult.error);\n    82→  }\n    83→\n    84→  const state = stateResult.data;\n    85→  const existing = extractCoverageState(state);\n    86→  const timestamp = new Date().toISOString();\n    87→\n    88→  const fullHistory = [\n    89→    ...existing.static.history,\n    90→    { coveragePercent: result.summary.coveragePercent, timestamp },\n    91→  ];\n    92→  // Keep only the most recent entries to prevent unbounded growth\n    93→  const trimmedHistory =\n    94→    fullHistory.length > MAX_HISTORY_ENTRIES\n    95→      ? fullHistory.slice(fullHistory.length - MAX_HISTORY_ENTRIES)\n    96→      : fullHistory;\n    97→\n    98→  const updatedStatic = {\n    99→    coveragePercent: result.summary.coveragePercent,\n   100→    lastScanTimestamp: timestamp,\n   101→    history: trimmedHistory,\n   102→    gaps: result.gaps.map(({ file, line, type, description, severity }) =>\n   103→      ({ file, line, type, description, severity })),\n   104→  };\n   105→\n   106→  const updatedObservability: ObservabilityCoverageState = {\n   107→    static: updatedStatic,\n   108→    targets: existing.targets,\n   109→    ...(existing.runtime ? { runtime: existing.runtime } : {}),\n   110→  };\n   111→\n   112→  const updatedState = {\n   113→    ...state,\n   114→    observability: updatedObservability,\n   115→  };\n   116→\n   117→  return writeStateAtomic(projectDir, updatedState);\n   118→}\n   119→\n   120→/** Read the observability coverage state from sprint-state.json. */\n   121→export function readCoverageState(\n   122→  projectDir: string,\n   123→): Result<ObservabilityCoverageState> {\n   124→  if (!projectDir || typeof projectDir !== 'string') {\n   125→    return fail('projectDir is required and must be a non-empty string');\n   126→  }\n   127→\n   128→  const stateResult = readStateFile(projectDir);\n   129→  if (!stateResult.success) {\n   130→    return fail(stateResult.error);\n   131→  }\n   132→\n   133→  return ok(extractCoverageState(stateResult.data));\n   134→}\n   135→\n   136→/** Get coverage trend by comparing latest vs previous history entries. */\n   137→export function getCoverageTrend(projectDir: string): Result<CoverageTrend> {\n   138→  if (!projectDir || typeof projectDir !== 'string') {\n   139→    return fail('projectDir is required and must be a non-empty string');\n   140→  }\n   141→\n   142→  const stateResult = readCoverageState(projectDir);\n   143→  if (!stateResult.success) {\n   144→    return fail(stateResult.error);\n   145→  }\n   146→\n   147→  const { history } = stateResult.data.static;\n   148→\n   149→  if (history.length === 0) {\n   150→    return ok({\n   151→      current: 0,\n   152→      previous: null,\n   153→      delta: null,\n   154→      currentTimestamp: '',\n   155→      previousTimestamp: null,\n   156→    });\n   157→  }\n   158→\n   159→  const latest = history[history.length - 1];\n   160→\n   161→  if (history.length === 1) {\n   162→    return ok({\n   163→      current: latest.coveragePercent,\n   164→      previous: null,\n   165→      delta: null,\n   166→      currentTimestamp: latest.timestamp,\n   167→      previousTimestamp: null,\n   168→    });\n   169→  }\n   170→\n   171→  const prev = history[history.length - 2];\n   172→  return ok({\n   173→    current: latest.coveragePercent,\n   174→    previous: prev.coveragePercent,\n   175→    delta: latest.coveragePercent - prev.coveragePercent,\n   176→    currentTimestamp: latest.timestamp,\n   177→    previousTimestamp: prev.timestamp,\n   178→  });\n   179→}\n   180→\n   181→/** Check current coverage against a target threshold. */\n   182→export function checkCoverageTarget(\n   183→  projectDir: string,\n   184→  target?: number,\n   185→): Result<CoverageTargetResult> {\n   186→  if (!projectDir || typeof projectDir !== 'string') {\n   187→    return fail('projectDir is required and must be a non-empty string');\n   188→  }\n   189→\n   190→  const stateResult = readCoverageState(projectDir);\n   191→  if (!stateResult.success) {\n   192→    return fail(stateResult.error);\n   193→  }\n   194→\n   195→  const effectiveTarget = target ?? stateResult.data.targets.staticTarget;\n   196→  const current = stateResult.data.static.coveragePercent;\n   197→  const met = current >= effectiveTarget;\n   198→  const gap = met ? 0 : effectiveTarget - current;\n   199→\n   200→  return ok({ met, current, target: effectiveTarget, gap });\n   201→}\n   202→\n   203→/** Extract typed ObservabilityCoverageState from raw sprint-state.json data. */\n   204→function extractCoverageState(\n   205→  state: Record<string, unknown>,\n   206→): ObservabilityCoverageState {\n   207→  const obs = state.observability as Record<string, unknown> | undefined;\n   208→  if (!obs) {\n   209→    return defaultCoverageState();\n   210→  }\n   211→\n   212→  const staticSection = obs.static as Record<string, unknown> | undefined;\n   213→  const targets = obs.targets as Record<string, unknown> | undefined;\n   214→  const runtimeSection = obs.runtime as Record<string, unknown> | undefined;\n   215→\n   216→  const runtime: RuntimeCoverageState | undefined =\n   217→    runtimeSection && typeof runtimeSection.coveragePercent === 'number'\n   218→      ? {\n   219→          coveragePercent: runtimeSection.coveragePercent,\n   220→          lastValidationTimestamp:\n   221→            typeof runtimeSection.lastValidationTimestamp === 'string'\n   222→              ? runtimeSection.lastValidationTimestamp : '',\n   223→          modulesWithTelemetry:\n   224→            typeof runtimeSection.modulesWithTelemetry === 'number'\n   225→              ? runtimeSection.modulesWithTelemetry : 0,\n   226→          totalModules:\n   227→            typeof runtimeSection.totalModules === 'number'\n   228→              ? runtimeSection.totalModules : 0,\n   229→          telemetryDetected:\n   230→            typeof runtimeSection.telemetryDetected === 'boolean'\n   231→              ? runtimeSection.telemetryDetected : false,\n   232→        }\n   233→      : undefined;\n   234→\n   235→  // Parse cached gaps from static section\n   236→  const parsedGaps = parseGapArray(staticSection?.gaps);\n   237→\n   238→  const result: ObservabilityCoverageState = {\n   239→    static: {\n   240→      coveragePercent:\n   241→        typeof staticSection?.coveragePercent === 'number'\n   242→          ? staticSection.coveragePercent\n   243→          : 0,\n   244→      lastScanTimestamp:\n   245→        typeof staticSection?.lastScanTimestamp === 'string'\n   246→          ? staticSection.lastScanTimestamp\n   247→          : '',\n   248→      history: Array.isArray(staticSection?.history)\n   249→        ? (staticSection.history as unknown[]).filter(\n   250→            (entry): entry is { coveragePercent: number; timestamp: string } =>\n   251→              typeof entry === 'object' &&\n   252→              entry !== null &&\n   253→              typeof (entry as Record<string, unknown>).coveragePercent ===\n   254→                'number' &&\n   255→              typeof (entry as Record<string, unknown>).timestamp === 'string',\n   256→          )\n   257→        : [],\n   258→      ...(parsedGaps.length > 0 ? { gaps: parsedGaps } : {}),\n   259→    },\n   260→    targets: {\n   261→      staticTarget:\n   262→        typeof targets?.staticTarget === 'number'\n   263→          ? targets.staticTarget\n   264→          : DEFAULT_STATIC_TARGET,\n   265→      ...(typeof targets?.runtimeTarget === 'number'\n   266→        ? { runtimeTarget: targets.runtimeTarget }\n   267→        : {}),\n   268→    },\n   269→    ...(runtime ? { runtime } : {}),\n   270→  };\n   271→\n   272→  return result;\n   273→}\n   274→\n   275→/** Parse and validate an array of gap objects from raw JSON. */\n   276→function parseGapArray(raw: unknown): ObservabilityGap[] {\n   277→  if (!Array.isArray(raw)) return [];\n   278→  return raw\n   279→    .filter((g): g is Record<string, unknown> => {\n   280→      if (typeof g !== 'object' || g === null) return false;\n   281→      const r = g as Record<string, unknown>;\n   282→      return typeof r.file === 'string' && typeof r.line === 'number'\n   283→        && typeof r.type === 'string' && typeof r.description === 'string';\n   284→    })\n   285→    .map(g => ({\n   286→      file: g.file as string, line: g.line as number,\n   287→      type: g.type as string, description: g.description as string,\n   288→      severity: (g.severity === 'error' || g.severity === 'warning' ? g.severity : 'info') as GapSeverity,\n   289→    }));\n   290→}\n   291→"}]},"parent_tool_use_id":"toolu_014QEC8wgRDzeoWECp9trCxd","session_id":"c5eaf6a6-ac7c-4707-b82c-6220d711aa9c","uuid":"8124a3ea-6576-43fb-97b8-4ceaf188223d","timestamp":"2026-03-20T06:37:45.657Z"}
