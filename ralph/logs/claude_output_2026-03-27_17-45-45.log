{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BFoP9raVbNQUuf7eCRWi1o","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n     2→import { mkdtempSync, rmSync, writeFileSync, mkdirSync } from 'node:fs';\n     3→import { tmpdir } from 'node:os';\n     4→import { join } from 'node:path';\n     5→import { parseStoryACs, classifyAC, classifyVerifiability, classifyStrategy, classifyTier, parseVerificationTag, INTEGRATION_KEYWORDS } from '../parser.js';\n     6→\n     7→// Mock output.ts to suppress warnings during tests\n     8→vi.mock('../../../lib/output.js', () => ({\n     9→  ok: vi.fn(),\n    10→  fail: vi.fn(),\n    11→  warn: vi.fn(),\n    12→  info: vi.fn(),\n    13→  jsonOutput: vi.fn(),\n    14→}));\n    15→\n    16→let testDir: string;\n    17→\n    18→beforeEach(() => {\n    19→  vi.restoreAllMocks();\n    20→  testDir = mkdtempSync(join(tmpdir(), 'ch-verify-parser-test-'));\n    21→});\n    22→\n    23→afterEach(() => {\n    24→  rmSync(testDir, { recursive: true, force: true });\n    25→});\n    26→\n    27→function writeStoryFile(filename: string, content: string): string {\n    28→  const filePath = join(testDir, filename);\n    29→  writeFileSync(filePath, content, 'utf-8');\n    30→  return filePath;\n    31→}\n    32→\n    33→// ─── classifyAC ─────────────────────────────────────────────────────────────\n    34→\n    35→describe('classifyAC', () => {\n    36→  it('classifies UI keywords', () => {\n    37→    expect(classifyAC('use agent-browser to navigate')).toBe('ui');\n    38→    expect(classifyAC('take a screenshot of the page')).toBe('ui');\n    39→    expect(classifyAC('click on the submit button')).toBe('ui');\n    40→    expect(classifyAC('fill the form with data')).toBe('ui');\n    41→    expect(classifyAC('navigate to the home page')).toBe('ui');\n    42→  });\n    43→\n    44→  it('classifies API keywords', () => {\n    45→    expect(classifyAC('make HTTP calls to the endpoint')).toBe('api');\n    46→    expect(classifyAC('use curl to test the API')).toBe('api');\n    47→    expect(classifyAC('verify REST response body')).toBe('api');\n    48→    expect(classifyAC('check the API endpoint status')).toBe('api');\n    49→  });\n    50→\n    51→  it('classifies DB keywords', () => {\n    52→    expect(classifyAC('check database state after insert')).toBe('db');\n    53→    expect(classifyAC('verify DB state via query')).toBe('db');\n    54→    expect(classifyAC('use Database MCP to query')).toBe('db');\n    55→    expect(classifyAC('run SQL to verify')).toBe('db');\n    56→    expect(classifyAC('check the table contents')).toBe('db');\n    57→  });\n    58→\n    59→  it('classifies general when no keywords match', () => {\n    60→    expect(classifyAC('verify the output is correct')).toBe('general');\n    61→    expect(classifyAC('check that the file exists')).toBe('general');\n    62→    expect(classifyAC('ensure the config is valid')).toBe('general');\n    63→  });\n    64→\n    65→  it('is case insensitive', () => {\n    66→    expect(classifyAC('Use AGENT-BROWSER to test')).toBe('ui');\n    67→    expect(classifyAC('Make HTTP calls')).toBe('api');\n    68→    expect(classifyAC('Check DATABASE state')).toBe('db');\n    69→  });\n    70→\n    71→  it('returns first matching type when multiple keywords present', () => {\n    72→    // UI keywords are checked first\n    73→    expect(classifyAC('use agent-browser to call API endpoint')).toBe('ui');\n    74→  });\n    75→});\n    76→\n    77→// ─── parseStoryACs ──────────────────────────────────────────────────────────\n    78→\n    79→describe('parseStoryACs', () => {\n    80→  it('extracts numbered ACs from a standard story file', () => {\n    81→    const filePath = writeStoryFile('story.md', `# Story 4.1: Test Story\n    82→\n    83→Status: ready-for-dev\n    84→\n    85→## Story\n    86→\n    87→As a developer...\n    88→\n    89→## Acceptance Criteria\n    90→\n    91→1. **Given** a developer runs the command, **When** tests pass, **Then** output is shown.\n    92→\n    93→2. **Given** a user opens the app, **When** they click submit, **Then** the form is saved.\n    94→\n    95→## Tasks / Subtasks\n    96→\n    97→- [ ] Task 1: Do something\n    98→`);\n    99→\n   100→    const acs = parseStoryACs(filePath);\n   101→    expect(acs).toHaveLength(2);\n   102→    expect(acs[0].id).toBe('1');\n   103→    expect(acs[0].description).toContain('developer runs the command');\n   104→    expect(acs[0].type).toBe('general');\n   105→    expect(acs[0].verifiability).toBe('cli-verifiable');\n   106→    expect(acs[0].tier).toBe('test-provable');\n   107→    expect(acs[1].id).toBe('2');\n   108→    expect(acs[1].description).toContain('click submit');\n   109→    expect(acs[1].type).toBe('ui');\n   110→    expect(acs[1].verifiability).toBe('cli-verifiable');\n   111→    expect(acs[1].tier).toBe('test-provable');\n   112→  });\n   113→\n   114→  it('handles multi-line ACs', () => {\n   115→    const filePath = writeStoryFile('story.md', `# Story 1.1: Multi\n   116→\n   117→## Acceptance Criteria\n   118→\n   119→1. **Given** a developer runs the verify command,\n   120→   **When** the verification pipeline starts,\n   121→   **Then** preconditions are checked.\n   122→\n   123→## Tasks\n   124→`);\n   125→\n   126→    const acs = parseStoryACs(filePath);\n   127→    expect(acs).toHaveLength(1);\n   128→    expect(acs[0].description).toContain('developer runs the verify command');\n   129→    expect(acs[0].description).toContain('preconditions are checked');\n   130→  });\n   131→\n   132→  it('classifies ACs by type from content', () => {\n   133→    const filePath = writeStoryFile('story.md', `# Story 1.1: Types\n   134→\n   135→## Acceptance Criteria\n   136→\n   137→1. **Given** agent-browser is used, **Then** screenshots are captured.\n   138→\n   139→2. **Given** HTTP calls are made to the API endpoint, **Then** response bodies are inspected.\n   140→\n   141→3. **Given** Database MCP is used for read-only queries, **Then** results are captured.\n   142→\n   143→4. **Given** verification steps complete, **Then** a proof document is created.\n   144→\n   145→## Tasks\n   146→`);\n   147→\n   148→    const acs = parseStoryACs(filePath);\n   149→    expect(acs).toHaveLength(4);\n   150→    expect(acs[0].type).toBe('ui');\n   151→    expect(acs[1].type).toBe('api');\n   152→    expect(acs[2].type).toBe('db');\n   153→    expect(acs[3].type).toBe('general');\n   154→  });\n   155→\n   156→  it('throws with actionable message when file not found', () => {\n   157→    expect(() => parseStoryACs('/nonexistent/path/story.md')).toThrow(\n   158→      'Story file not found: /nonexistent/path/story.md',\n   159→    );\n   160→  });\n   161→\n   162→  it('returns empty array when no AC section exists', () => {\n   163→    const filePath = writeStoryFile('story.md', `# Story 1.1: No ACs\n   164→\n   165→## Story\n   166→\n   167→As a developer...\n   168→\n   169→## Tasks\n   170→\n   171→- [ ] Do something\n   172→`);\n   173→\n   174→    const acs = parseStoryACs(filePath);\n   175→    expect(acs).toEqual([]);\n   176→  });\n   177→\n   178→  it('handles malformed ACs — skips empty descriptions', () => {\n   179→    const filePath = writeStoryFile('story.md', `# Story 1.1: Malformed\n   180→\n   181→## Acceptance Criteria\n   182→\n   183→1. **Given** a valid AC, **Then** it works.\n   184→\n   185→2.\n   186→\n   187→3. **Given** another valid AC, **Then** it also works.\n   188→\n   189→## Tasks\n   190→`);\n   191→\n   192→    const acs = parseStoryACs(filePath);\n   193→    // AC #2 has empty description and should be skipped\n   194→    expect(acs).toHaveLength(2);\n   195→    expect(acs[0].id).toBe('1');\n   196→    expect(acs[1].id).toBe('3');\n   197→  });\n   198→\n   199→  it('handles AC section at end of file (no following section)', () => {\n   200→    const filePath = writeStoryFile('story.md', `# Story 1.1: EOF\n   201→\n   202→## Acceptance Criteria\n   203→\n   204→1. **Given** it is the last section, **Then** it should still parse.\n   205→`);\n   206→\n   207→    const acs = parseStoryACs(filePath);\n   208→    expect(acs).toHaveLength(1);\n   209→    expect(acs[0].description).toContain('last section');\n   210→    expect(acs[0].verifiability).toBe('cli-verifiable');\n   211→  });\n   212→\n   213→  it('reads verification tag from AC line and sets tier accordingly', () => {\n   214→    const filePath = writeStoryFile('story.md', `# Story 12.3: Tags\n   215→\n   216→## Acceptance Criteria\n   217→\n   218→1. **Given** a CLI command, **Then** output is shown. <!-- verification: cli-verifiable -->\n   219→\n   220→2. **Given** sprint planning surfaces retro items, **Then** items appear. <!-- verification: integration-required -->\n   221→\n   222→## Tasks\n   223→`);\n   224→\n   225→    const acs = parseStoryACs(filePath);\n   226→    expect(acs).toHaveLength(2);\n   227→    // Tag cli-verifiable maps to test-provable; verifiability is computed independently\n   228→    expect(acs[0].verifiability).toBe('cli-verifiable');\n   229→    expect(acs[0].tier).toBe('test-provable');\n   230→    // Tag integration-required maps to environment-provable; verifiability is now independent\n   231→    expect(acs[1].verifiability).toBe('cli-verifiable');\n   232→    expect(acs[1].tier).toBe('environment-provable');\n   233→  });\n   234→\n   235→  it('falls back to classifyTier when no verification tag is present', () => {\n   236→    const filePath = writeStoryFile('story.md', `# Story 12.3: Heuristic\n   237→\n   238→## Acceptance Criteria\n   239→\n   240→1. **Given** a CLI command, **Then** output is correct.\n   241→\n   242→2. **Given** an external system connection, **Then** data syncs.\n   243→\n   244→3. **Given** manual verification is needed, **Then** flag for human review.\n   245→\n   246→## Tasks\n   247→`);\n   248→\n   249→    const acs = parseStoryACs(filePath);\n   250→    expect(acs).toHaveLength(3);\n   251→    // \"cli command\" matches RUNTIME_PROVABLE_KEYWORDS\n   252→    expect(acs[0].verifiability).toBe('cli-verifiable');\n   253→    expect(acs[0].tier).toBe('runtime-provable');\n   254→    // \"external system\" matches INTEGRATION_KEYWORDS (verifiability) but no tier keywords -> test-provable\n   255→    expect(acs[1].verifiability).toBe('integration-required');\n   256→    expect(acs[1].tier).toBe('test-provable');\n   257→    // \"manual verification\" matches INTEGRATION_KEYWORDS (verifiability) but no tier keywords -> test-provable\n   258→    expect(acs[2].verifiability).toBe('integration-required');\n   259→    expect(acs[2].tier).toBe('test-provable');\n   260→  });\n   261→\n   262→  it('verification tag overrides heuristic tier classification', () => {\n   263→    const filePath = writeStoryFile('story.md', `# Story 12.3: Override\n   264→\n   265→## Acceptance Criteria\n   266→\n   267→1. **Given** an external system is connected, **Then** output is correct. <!-- verification: cli-verifiable -->\n   268→\n   269→## Tasks\n   270→`);\n   271→\n   272→    const acs = parseStoryACs(filePath);\n   273→    expect(acs).toHaveLength(1);\n   274→    // \"external system\" would heuristically classify tier as test-provable (default),\n   275→    // but the explicit tag (cli-verifiable -> test-provable via LEGACY_TIER_MAP) sets tier.\n   276→    // verifiability is now computed independently by classifyVerifiability\n   277→    expect(acs[0].verifiability).toBe('integration-required');\n   278→    expect(acs[0].tier).toBe('test-provable');\n   279→  });\n   280→\n   281→  it('tier is derived from classifyTier independently of verifiability', () => {\n   282→    const filePath = writeStoryFile('story.md', `# Story 16.1: Tier test\n   283→\n   284→## Acceptance Criteria\n   285→\n   286→1. **Given** an external system is used, **Then** it is verified.\n   287→\n   288→## Tasks\n   289→`);\n   290→\n   291→    const acs = parseStoryACs(filePath);\n   292→    expect(acs).toHaveLength(1);\n   293→    // verifiability matches \"external system\" -> integration-required\n   294→    expect(acs[0].verifiability).toBe('integration-required');\n   295→    // tier uses classifyTier: no tier keywords match -> test-provable (default)\n   296→    expect(acs[0].tier).toBe('test-provable');\n   297→  });\n   298→\n   299→  it('defaults tier to test-provable for cli-verifiable ACs', () => {\n   300→    const filePath = writeStoryFile('story.md', `# Story 16.1: Default tier\n   301→\n   302→## Acceptance Criteria\n   303→\n   304→1. **Given** a simple check, **Then** it passes.\n   305→\n   306→## Tasks\n   307→`);\n   308→\n   309→    const acs = parseStoryACs(filePath);\n   310→    expect(acs).toHaveLength(1);\n   311→    expect(acs[0].verifiability).toBe('cli-verifiable');\n   312→    expect(acs[0].tier).toBe('test-provable');\n   313→  });\n   314→\n   315→  it('derives tier from classifyTier fallback when no tag present (AC11)', () => {\n   316→    const filePath = writeStoryFile('story.md', `# Story 16.2: Tier fallback\n   317→\n   318→## Acceptance Criteria\n   319→\n   320→1. **Given** function X exists, **When** called, **Then** returns Z.\n   321→\n   322→2. **Given** the CLI outputs JSON, **Then** it is valid.\n   323→\n   324→3. **Given** Docker container starts, **Then** services are healthy.\n   325→\n   326→4. **Given** physical display renders correctly, **Then** fps is 60.\n   327→\n   328→## Tasks\n   329→`);\n   330→\n   331→    const acs = parseStoryACs(filePath);\n   332→    expect(acs).toHaveLength(4);\n   333→    expect(acs[0].tier).toBe('test-provable');\n   334→    expect(acs[1].tier).toBe('runtime-provable');\n   335→    expect(acs[2].tier).toBe('environment-provable');\n   336→    expect(acs[3].tier).toBe('escalate');\n   337→  });\n   338→\n   339→  it('parses new verification tier tags from story AC lines', () => {\n   340→    const filePath = writeStoryFile('story.md', `# Story 16.1: New tags\n   341→\n   342→## Acceptance Criteria\n   343→\n   344→1. **Given** a test-provable AC, **Then** it works. <!-- verification: test-provable -->\n   345→\n   346→2. **Given** a runtime-provable AC, **Then** it works. <!-- verification: runtime-provable -->\n   347→\n   348→3. **Given** an environment-provable AC, **Then** it works. <!-- verification: environment-provable -->\n   349→\n   350→4. **Given** an escalate AC, **Then** it works. <!-- verification: escalate -->\n   351→\n   352→## Tasks\n   353→`);\n   354→\n   355→    const acs = parseStoryACs(filePath);\n   356→    expect(acs).toHaveLength(4);\n   357→    expect(acs[0].tier).toBe('test-provable');\n   358→    expect(acs[1].tier).toBe('runtime-provable');\n   359→    expect(acs[2].tier).toBe('environment-provable');\n   360→    expect(acs[3].tier).toBe('escalate');\n   361→  });\n   362→});\n   363→\n   364→// ─── classifyVerifiability ───────────────────────────────────────────────────\n   365→\n   366→describe('classifyVerifiability', () => {\n   367→  it('returns integration-required for descriptions mentioning integration keywords', () => {\n   368→    expect(classifyVerifiability('connects to external system')).toBe('integration-required');\n   369→    expect(classifyVerifiability('uses real infrastructure for testing')).toBe('integration-required');\n   370→    expect(classifyVerifiability('requires manual verification')).toBe('integration-required');\n   371→  });\n   372→\n   373→  it('returns cli-verifiable for descriptions that were previously over-classified', () => {\n   374→    expect(classifyVerifiability('sprint planning surfaces retro action items')).toBe('cli-verifiable');\n   375→    expect(classifyVerifiability('the workflow executes correctly')).toBe('cli-verifiable');\n   376→    expect(classifyVerifiability('run /command to start the process')).toBe('cli-verifiable');\n   377→    expect(classifyVerifiability('user session is active and preserved')).toBe('cli-verifiable');\n   378→    expect(classifyVerifiability('requires multi-step verification')).toBe('cli-verifiable');\n   379→  });\n   380→\n   381→  it('returns cli-verifiable for descriptions without integration keywords', () => {\n   382→    expect(classifyVerifiability('CLI output contains expected text')).toBe('cli-verifiable');\n   383→    expect(classifyVerifiability('file exists at the expected path')).toBe('cli-verifiable');\n   384→    expect(classifyVerifiability('command returns exit code 0')).toBe('cli-verifiable');\n   385→    expect(classifyVerifiability('JSON contains the expected field')).toBe('cli-verifiable');\n   386→    expect(classifyVerifiability('verify the output is correct')).toBe('cli-verifiable');\n   387→  });\n   388→\n   389→  it('is case insensitive', () => {\n   390→    expect(classifyVerifiability('EXTERNAL SYSTEM connection')).toBe('integration-required');\n   391→    expect(classifyVerifiability('Manual Verification required')).toBe('integration-required');\n   392→  });\n   393→});\n   394→\n   395→// ─── parseVerificationTag ────────────────────────────────────────────────────\n   396→\n   397→describe('parseVerificationTag', () => {\n   398→  it('maps legacy cli-verifiable tag to test-provable (AC9)', () => {\n   399→    expect(parseVerificationTag('some text <!-- verification: cli-verifiable -->')).toBe('test-provable');\n   400→  });\n   401→\n   402→  it('maps legacy integration-required tag to environment-provable (AC10)', () => {\n   403→    expect(parseVerificationTag('some text <!-- verification: integration-required -->')).toBe('environment-provable');\n   404→  });\n   405→\n   406→  it('returns null when no tag is present', () => {\n   407→    expect(parseVerificationTag('some text without a tag')).toBeNull();\n   408→  });\n   409→\n   410→  it('handles extra whitespace in tag', () => {\n   411→    expect(parseVerificationTag('text <!--  verification:  cli-verifiable  -->')).toBe('test-provable');\n   412→  });\n   413→\n   414→  it('parses new tier values: test-provable (AC8)', () => {\n   415→    expect(parseVerificationTag('text <!-- verification: test-provable -->')).toBe('test-provable');\n   416→  });\n   417→\n   418→  it('parses new tier values: runtime-provable', () => {\n   419→    expect(parseVerificationTag('text <!-- verification: runtime-provable -->')).toBe('runtime-provable');\n   420→  });\n   421→\n   422→  it('parses new tier values: environment-provable', () => {\n   423→    expect(parseVerificationTag('text <!-- verification: environment-provable -->')).toBe('environment-provable');\n   424→  });\n   425→\n   426→  it('parses new tier values: escalate', () => {\n   427→    expect(parseVerificationTag('text <!-- verification: escalate -->')).toBe('escalate');\n   428→  });\n   429→\n   430→  it('returns VerificationTier type (not legacy Verifiability)', () => {\n   431→    const result = parseVerificationTag('text <!-- verification: test-provable -->');\n   432→    expect(['test-provable', 'runtime-provable', 'environment-provable', 'escalate']).toContain(result);\n   433→  });\n   434→\n   435→  it('maps legacy unit-testable tag to test-provable', () => {\n   436→    expect(parseVerificationTag('text <!-- verification: unit-testable -->')).toBe('test-provable');\n   437→  });\n   438→\n   439→  it('maps legacy black-box tag to environment-provable', () => {\n   440→    expect(parseVerificationTag('text <!-- verification: black-box -->')).toBe('environment-provable');\n   441→  });\n   442→\n   443→  it('returns null for unknown/invalid tag values', () => {\n   444→    expect(parseVerificationTag('text <!-- verification: unknown-value -->')).toBeNull();\n   445→    expect(parseVerificationTag('text <!-- verification: auto -->')).toBeNull();\n   446→  });\n   447→});\n   448→\n   449→// ─── classifyTier ───────────────────────────────────────────────────────────\n   450→\n   451→describe('classifyTier', () => {\n   452→  // AC1: test-provable for function/returns keywords\n   453→  it('returns test-provable for function descriptions (AC1)', () => {\n   454→    expect(classifyTier('Given function X exists, when called with Y, then returns Z')).toBe('test-provable');\n   455→  });\n   456→\n   457→  // AC2: runtime-provable for CLI output keywords\n   458→  it('returns runtime-provable for CLI output descriptions (AC2)', () => {\n   459→    expect(classifyTier('Given the CLI outputs JSON when --format json is passed')).toBe('runtime-provable');\n   460→  });\n   461→\n   462→  // AC3: environment-provable for VictoriaLogs keywords\n   463→  it('returns environment-provable for observability descriptions (AC3)', () => {\n   464→    expect(classifyTier('Given logs appear in VictoriaLogs after the request')).toBe('environment-provable');\n   465→  });\n   466→\n   467→  // AC4: escalate for physical display keywords\n   468→  it('returns escalate for physical hardware descriptions (AC4)', () => {\n   469→    expect(classifyTier('Given 60fps rendering on a physical display')).toBe('escalate');\n   470→  });\n   471→\n   472→  // AC5: test-provable for type/export keywords\n   473→  it('returns test-provable for type/export descriptions (AC5)', () => {\n   474→    expect(classifyTier('Given the type is exported from types.ts')).toBe('test-provable');\n   475→  });\n   476→\n   477→  // AC6: runtime-provable for API endpoint keywords\n   478→  it('returns runtime-provable for API endpoint descriptions (AC6)', () => {\n   479→    expect(classifyTier('Given the API endpoint returns 200')).toBe('runtime-provable');\n   480→  });\n   481→\n   482→  // AC7: environment-provable for Docker/container keywords\n   483→  it('returns environment-provable for Docker descriptions (AC7)', () => {\n   484→    expect(classifyTier('Given the Docker container starts successfully')).toBe('environment-provable');\n   485→  });\n   486→\n   487→  it('defaults to test-provable when no keywords match', () => {\n   488→    expect(classifyTier('Given a simple check, Then it passes')).toBe('test-provable');\n   489→  });\n   490→\n   491→  it('returns test-provable for empty string', () => {\n   492→    expect(classifyTier('')).toBe('test-provable');\n   493→  });\n   494→\n   495→  it('is case insensitive', () => {\n   496→    expect(classifyTier('Given the DOCKER CONTAINER starts')).toBe('environment-provable');\n   497→    expect(classifyTier('Given HTTP server responds')).toBe('runtime-provable');\n   498→    expect(classifyTier('Given PHYSICAL HARDWARE is needed')).toBe('escalate');\n   499→  });\n   500→\n   501→  it('respects priority order: escalate > environment > runtime > test', () => {\n   502→    // Description with both escalate and environment keywords — escalate wins\n   503→    expect(classifyTier('physical hardware with Docker container')).toBe('escalate');\n   504→    // Description with both environment and runtime keywords — environment wins\n   505→    expect(classifyTier('Docker container with HTTP server')).toBe('environment-provable');\n   506→  });\n   507→\n   508→  it('matches multiple test-provable keywords', () => {\n   509→    expect(classifyTier('Given the interface is exported from config')).toBe('test-provable');\n   510→    expect(classifyTier('Given test passes with full coverage')).toBe('test-provable');\n   511→    expect(classifyTier('Given the refactor is complete and documentation updated')).toBe('test-provable');\n   512→  });\n   513→\n   514→  it('matches multiple runtime-provable keywords', () => {\n   515→    expect(classifyTier('Given the server output shows the exit code')).toBe('runtime-provable');\n   516→    expect(classifyTier('Given the binary runs and produces correct output')).toBe('runtime-provable');\n   517→  });\n   518→\n   519→  it('matches multiple environment-provable keywords', () => {\n   520→    expect(classifyTier('Given telemetry flows to the observability stack')).toBe('environment-provable');\n   521→    expect(classifyT