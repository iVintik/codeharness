rorInState(state, taskName, PER_RUN_SENTINEL, engineError);\n1329\t        writeWorkflowState(state, projectDir);\n1330\t\n1331\t        // Halt on critical errors\n1332\t        if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n1333\t          halted = true;\n1334\t        }\n1335\t      }\n1336\t    } else {\n1337\t      // Per-story: dispatch once per work item\n1338\t      for (const item of workItems) {\n1339\t        processedStories.add(item.key);\n1340\t\n1341\t        // Skip if already completed (crash recovery — AC #1, #2, #7)\n1342\t        if (isTaskCompleted(state, taskName, item.key)) {\n1343\t          warn(`workflow-engine: skipping completed task ${taskName} for ${item.key}`);\n1344\t          continue;\n1345\t        }\n1346\t\n1347\t        try {\n1348\t          const dispatchResult = await dispatchTaskWithResult(\n1349\t            task, taskName, item.key, definition, state, config, undefined, lastOutputContract ?? undefined,\n1350\t          );\n1351\t          state = dispatchResult.updatedState;\n1352\t          lastOutputContract = dispatchResult.contract;\n1353\t          propagateVerifyFlags(taskName, dispatchResult.contract, projectDir);\n1354\t          accumulatedCostUsd += dispatchResult.contract?.cost_usd ?? 0;\n1355\t          tasksCompleted++;\n1356\t        } catch (err: unknown) {\n1357\t          const engineError = handleDispatchError(err, taskName, item.key);\n1358\t          errors.push(engineError);\n1359\t\n1360\t          // Record error checkpoint in state (AC #13)\n1361\t          state = recordErrorInState(state, taskName, item.key, engineError);\n1362\t          writeWorkflowState(state, projectDir);\n1363\t\n1364\t          // Halt on critical errors, continue on UNKNOWN\n1365\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n1366\t            halted = true;\n1367\t            break;\n1368\t          }\n1369\t          // UNKNOWN errors: record and continue to next