{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013YvEjMuqT1G9iiE8MPQZyt","type":"tool_result","content":"     1→/**\n     2→ * Onboard precondition checks and gap filtering.\n     3→ *\n     4→ * Story 8.2: Checks prerequisites before onboarding and filters\n     5→ * already-tracked gaps using the gap-id system from story 8-1.\n     6→ */\n     7→\n     8→import { existsSync } from 'node:fs';\n     9→import { join, dirname } from 'node:path';\n    10→import { fileURLToPath } from 'node:url';\n    11→import { getStatePath, readState } from './state.js';\n    12→import { isBmadInstalled } from './bmad.js';\n    13→import { buildGapId, findExistingByGapId } from './beads.js';\n    14→import type { BeadsIssue } from './beads.js';\n    15→import type { OnboardingStory } from './epic-generator.js';\n    16→import { readSprintStatusFromState } from '../modules/sprint/index.js';\n    17→import { checkPerFileCoverage } from './coverage.js';\n    18→import { isStackRunning } from './docker.js';\n    19→\n    20→// ─── Precondition Checks ────────────────────────────────────────────────────\n    21→\n    22→export function checkHarnessInitialized(dir?: string): { ok: boolean } {\n    23→  const statePath = getStatePath(dir ?? process.cwd());\n    24→  return { ok: existsSync(statePath) };\n    25→}\n    26→\n    27→export function checkBmadInstalled(dir?: string): { ok: boolean } {\n    28→  return { ok: isBmadInstalled(dir) };\n    29→}\n    30→\n    31→export function checkHooksRegistered(dir?: string): { ok: boolean } {\n    32→  const __filename = fileURLToPath(import.meta.url);\n    33→  const __dirname = dirname(__filename);\n    34→  const hooksPath = join(__dirname, '..', '..', 'hooks', 'hooks.json');\n    35→  return { ok: existsSync(hooksPath) };\n    36→}\n    37→\n    38→export interface PreconditionResult {\n    39→  canProceed: boolean;\n    40→  warnings: string[];\n    41→  initialized: boolean;\n    42→  bmad: boolean;\n    43→  hooks: boolean;\n    44→}\n    45→\n    46→export function runPreconditions(dir?: string): PreconditionResult {\n    47→  const harnessCheck = checkHarnessInitialized(dir);\n    48→  if (!harnessCheck.ok) {\n    49→    return {\n    50→      canProceed: false,\n    51→      warnings: [],\n    52→      initialized: false,\n    53→      bmad: false,\n    54→      hooks: false,\n    55→    };\n    56→  }\n    57→\n    58→  const warnings: string[] = [];\n    59→  const bmadCheck = checkBmadInstalled(dir);\n    60→  const hooksCheck = checkHooksRegistered(dir);\n    61→\n    62→  if (!bmadCheck.ok) {\n    63→    warnings.push(\n    64→      \"BMAD not installed \\u2014 generated stories won't be executable until init completes\",\n    65→    );\n    66→  }\n    67→  if (!hooksCheck.ok) {\n    68→    warnings.push(\"Hooks not registered \\u2014 enforcement won't be active\");\n    69→  }\n    70→\n    71→  return {\n    72→    canProceed: true,\n    73→    warnings,\n    74→    initialized: true,\n    75→    bmad: bmadCheck.ok,\n    76→    hooks: hooksCheck.ok,\n    77→  };\n    78→}\n    79→\n    80→// ─── Verification Gap Detection ─────────────────────────────────────────────\n    81→\n    82→/**\n    83→ * Story pattern: keys like \"1-1-xxx\", \"4-2-yyy\" — starts with digit-digit-.\n    84→ * Excludes epic/retrospective entries (e.g., \"epic-1\", \"epic-1-retrospective\").\n    85→ */\n    86→const STORY_KEY_PATTERN = /^\\d+-\\d+-/;\n    87→\n    88→/**\n    89→ * Finds stories marked 'done' in sprint-status.yaml that lack proof documents.\n    90→ *\n    91→ * Instead of creating meta-stories (\"create verification proof for X\"),\n    92→ * this resets unverified stories back to 'verifying' status so they go through\n    93→ * the real verification pipeline (showboat exec + showboat verify).\n    94→ *\n    95→ * Returns the count of stories reset for reporting purposes.\n    96→ */\n    97→export function findVerificationGaps(dir?: string): OnboardingStory[] {\n    98→  const statuses = readSprintStatusFromState();\n    99→  const root = dir ?? process.cwd();\n   100→  const unverified: string[] = [];\n   101→\n   102→  for (const [key, status] of Object.entries(statuses)) {\n   103→    if (status !== 'done') continue;\n   104→    if (!STORY_KEY_PATTERN.test(key)) continue;\n   105→\n   106→    const proofPath = join(root, 'verification', `${key}-proof.md`);\n   107→    if (!existsSync(proofPath)) {\n   108→      unverified.push(key);\n   109→    }\n   110→  }\n   111→\n   112→  // Verification is a gate on stories, not a separate story.\n   113→  // Instead of generating meta-stories, we return an empty array.\n   114→  // The harness-run workflow handles verification as Step 3d of every story lifecycle.\n   115→  // Unverified stories should be reset to 'verifying' status via the onboard command.\n   116→  return [];\n   117→}\n   118→\n   119→// ─── Per-File Coverage Gap Detection ────────────────────────────────────────\n   120→\n   121→/**\n   122→ * Finds files below the coverage floor using checkPerFileCoverage.\n   123→ */\n   124→export function findPerFileCoverageGaps(floor: number, dir?: string): OnboardingStory[] {\n   125→  const result = checkPerFileCoverage(floor, dir);\n   126→  const stories: OnboardingStory[] = [];\n   127→  let counter = 1;\n   128→\n   129→  for (const violation of result.violations) {\n   130→    stories.push({\n   131→      key: `0.fc${counter}`,\n   132→      title: `Add test coverage for ${violation.file}`,\n   133→      type: 'coverage',\n   134→      module: violation.file,\n   135→      acceptanceCriteria: [\n   136→        `**Given** ${violation.file} has ${violation.statements}% statement coverage (below ${floor}% floor)\\n**When** the agent writes tests\\n**Then** ${violation.file} reaches at least ${floor}% statement coverage`,\n   137→      ],\n   138→    });\n   139→    counter++;\n   140→  }\n   141→\n   142→  return stories;\n   143→}\n   144→\n   145→// ─── Observability Gap Detection ────────────────────────────────────────────\n   146→\n   147→/**\n   148→ * Checks observability readiness: OTLP config and Docker stack status.\n   149→ */\n   150→export function findObservabilityGaps(dir?: string): OnboardingStory[] {\n   151→  let state;\n   152→  try {\n   153→    state = readState(dir);\n   154→  } catch {\n   155→    // State file missing — fail open\n   156→    return [];\n   157→  }\n   158→\n   159→  const stories: OnboardingStory[] = [];\n   160→\n   161→  // Check OTLP config\n   162→  if (!state.otlp?.enabled) {\n   163→    stories.push({\n   164→      key: '0.o1',\n   165→      title: 'Configure OTLP instrumentation',\n   166→      type: 'observability',\n   167→      module: 'otlp-config',\n   168→      acceptanceCriteria: [\n   169→        '**Given** observability is enabled but OTLP is not configured\\n**When** onboard runs\\n**Then** OTLP instrumentation must be configured with endpoint and service name',\n   170→      ],\n   171→    });\n   172→  }\n   173→\n   174→  // Check Docker stack\n   175→  if (state.docker?.compose_file) {\n   176→    if (!isStackRunning(state.docker.compose_file)) {\n   177→      stories.push({\n   178→        key: '0.o2',\n   179→        title: 'Start Docker observability stack',\n   180→        type: 'observability',\n   181→        module: 'docker-stack',\n   182→        acceptanceCriteria: [\n   183→          '**Given** observability is enabled but Docker stack is not running\\n**When** onboard runs\\n**Then** Docker observability stack must be started',\n   184→        ],\n   185→      });\n   186→    }\n   187→  } else {\n   188→    // No compose file configured at all\n   189→    stories.push({\n   190→      key: '0.o2',\n   191→      title: 'Start Docker observability stack',\n   192→      type: 'observability',\n   193→      module: 'docker-stack',\n   194→      acceptanceCriteria: [\n   195→        '**Given** observability is enabled but Docker compose file is not configured\\n**When** onboard runs\\n**Then** Docker observability stack must be configured and started',\n   196→      ],\n   197→    });\n   198→  }\n   199→\n   200→  return stories;\n   201→}\n   202→\n   203→// ─── Onboarding Progress Tracking ────────────────────────────────────────────\n   204→\n   205→const GAP_ID_PATTERN = /\\[gap:[a-z-]+:[^\\]]+\\]/;\n   206→\n   207→/**\n   208→ * Computes onboarding progress by counting gap-tagged beads issues.\n   209→ * Returns null if no gap-tagged issues exist or beads is unavailable.\n   210→ */\n   211→export function getOnboardingProgress(\n   212→  beadsFns: { listIssues: () => BeadsIssue[] },\n   213→): { total: number; resolved: number; remaining: number } | null {\n   214→  let issues: BeadsIssue[];\n   215→  try {\n   216→    issues = beadsFns.listIssues();\n   217→  } catch {\n   218→    return null;\n   219→  }\n   220→\n   221→  const gapIssues = issues.filter(\n   222→    issue => issue.description && GAP_ID_PATTERN.test(issue.description),\n   223→  );\n   224→\n   225→  if (gapIssues.length === 0) {\n   226→    return null;\n   227→  }\n   228→\n   229→  const total = gapIssues.length;\n   230→  const resolved = gapIssues.filter(\n   231→    issue => issue.status === 'done' || issue.status === 'closed',\n   232→  ).length;\n   233→\n   234→  return { total, resolved, remaining: total - resolved };\n   235→}\n   236→\n   237→// ─── Gap Filtering ──────────────────────────────────────────────────────────\n   238→\n   239→/**\n   240→ * Maps an OnboardingStory to its gap-id string based on story type.\n   241→ */\n   242→export function storyToGapId(story: OnboardingStory): string {\n   243→  switch (story.type) {\n   244→    case 'coverage':\n   245→      return buildGapId('coverage', story.module!);\n   246→    case 'agents-md':\n   247→      return buildGapId('docs', story.module + '/AGENTS.md');\n   248→    case 'architecture':\n   249→      return buildGapId('docs', 'ARCHITECTURE.md');\n   250→    case 'doc-freshness':\n   251→      return buildGapId('docs', 'stale-docs');\n   252→    case 'verification':\n   253→      return buildGapId('verification', story.storyKey!);\n   254→    case 'observability':\n   255→      return buildGapId('observability', story.module!);\n   256→  }\n   257→}\n   258→\n   259→/**\n   260→ * Filters onboarding stories to only those not yet tracked in beads.\n   261→ * Fails open: if listIssues throws, returns all stories as untracked.\n   262→ */\n   263→export function filterTrackedGaps(\n   264→  stories: OnboardingStory[],\n   265→  beadsFns: { listIssues: () => BeadsIssue[] },\n   266→): { untracked: OnboardingStory[]; trackedCount: number } {\n   267→  let existingIssues: BeadsIssue[];\n   268→  try {\n   269→    existingIssues = beadsFns.listIssues();\n   270→  } catch {\n   271→    // Fail open — beads unavailable, return all as untracked\n   272→    return { untracked: [...stories], trackedCount: 0 };\n   273→  }\n   274→\n   275→  const untracked: OnboardingStory[] = [];\n   276→  let trackedCount = 0;\n   277→\n   278→  for (const story of stories) {\n   279→    const gapId = storyToGapId(story);\n   280→    const existing = findExistingByGapId(gapId, existingIssues);\n   281→    if (existing) {\n   282→      trackedCount++;\n   283→    } else {\n   284→      untracked.push(story);\n   285→    }\n   286→  }\n   287→\n   288→  return { untracked, trackedCount };\n   289→}\n   290→"}]},"parent_tool_use_id":"toolu_01S1Fmwybv95nEtmZySwttre","session_id":"bd5543f6-f408-4218-88bd-6e3bcdc37563","uuid":"8782556d-13f6-4201-8130-118ab4e576c4","timestamp":"2026-03-24T11:12:40.529Z"}
