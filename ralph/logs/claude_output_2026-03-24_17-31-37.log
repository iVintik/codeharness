{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Mq34g8aaauHUUkjnqpUZdz","type":"tool_result","content":"     1→/**\n     2→ * Status formatters — human-readable and JSON formatting for status output.\n     3→ * Handles the full status display, docker check, and health check formatting.\n     4→ */\n     5→\n     6→import { ok, fail, info, jsonOutput } from '../../lib/output.js';\n     7→import { readState, StateFileNotFoundError } from '../../lib/state.js';\n     8→import { getStackHealth, getCollectorHealth, isSharedStackRunning, checkRemoteEndpoint } from '../../lib/docker/index.js';\n     9→import { listIssues, isBeadsInitialized } from '../../lib/beads.js';\n    10→import { getOnboardingProgress } from '../../lib/onboard-checks.js';\n    11→import { getStackDir, getComposeFilePath } from '../../lib/stack-path.js';\n    12→import { generateReport } from '../sprint/index.js';\n    13→import { getValidationProgress } from '../verify/index.js';\n    14→import { DEFAULT_ENDPOINTS, buildScopedEndpoints, resolveEndpoints } from './endpoints.js';\n    15→import type { HarnessState } from '../../lib/state.js';\n    16→import type { DockerHealthResult } from '../../lib/docker/index.js';\n    17→import type { StatusReport } from '../sprint/index.js';\n    18→\n    19→// ─── Full Status Display ────────────────────────────────────────────────────\n    20→\n    21→export function handleFullStatus(isJson: boolean): void {\n    22→  let state: HarnessState;\n    23→  try {\n    24→    state = readState();\n    25→  } catch (err) {\n    26→    if (err instanceof StateFileNotFoundError) {\n    27→      if (isJson) {\n    28→        jsonOutput({ status: 'fail', message: \"Harness not initialized. Run 'codeharness init' first.\" });\n    29→      } else {\n    30→        fail(\"Harness not initialized. Run 'codeharness init' first.\");\n    31→      }\n    32→      process.exitCode = 1;\n    33→      return;\n    34→    }\n    35→    throw err;\n    36→  }\n    37→\n    38→  if (isJson) {\n    39→    handleFullStatusJson(state);\n    40→    return;\n    41→  }\n    42→\n    43→  // Sprint state sections (Project State, Run, Action Items)\n    44→  printSprintState();\n    45→\n    46→  // Validation progress (if validation stories exist)\n    47→  printValidationProgress();\n    48→\n    49→  // Version & Stack\n    50→  console.log(`Harness: codeharness v${state.harness_version}`);\n    51→  console.log(`Stack: ${state.stack ?? 'unknown'}`);\n    52→  if (state.app_type) {\n    53→    console.log(`App type: ${state.app_type}`);\n    54→    if (state.app_type === 'agent' && state.otlp?.agent_sdk) {\n    55→      console.log(`Agent SDK: ${state.otlp.agent_sdk}`);\n    56→    }\n    57→  }\n    58→\n    59→  // Enforcement\n    60→  const e = state.enforcement;\n    61→  console.log(\n    62→    `Enforcement: front:${e.frontend ? 'ON' : 'OFF'} db:${e.database ? 'ON' : 'OFF'} api:${e.api ? 'ON' : 'OFF'} obs:ON`,\n    63→  );\n    64→\n    65→  // Docker (always shown — observability is mandatory)\n    66→  {\n    67→    const mode = state.otlp?.mode ?? 'local-shared';\n    68→\n    69→    if (mode === 'remote-direct') {\n    70→      const endpoint = state.otlp?.endpoint ?? 'unknown';\n    71→      console.log(`Docker: none (remote OTLP at ${endpoint})`);\n    72→    } else if (mode === 'remote-routed') {\n    73→      const re = state.docker?.remote_endpoints;\n    74→      console.log(`Docker: OTel Collector only (backends at ${re?.logs_url ?? 'unknown'}, ${re?.metrics_url ?? 'unknown'}, ${re?.traces_url ?? 'unknown'})`);\n    75→      const sharedComposeFile = getComposeFilePath();\n    76→      const health = getCollectorHealth(sharedComposeFile);\n    77→      for (const svc of health.services) {\n    78→        console.log(`  ${svc.name}: ${svc.running ? 'running' : 'stopped'}`);\n    79→      }\n    80→    } else {\n    81→      const composeFile = state.docker?.compose_file ?? 'docker-compose.harness.yml';\n    82→      const stackDir = getStackDir();\n    83→      const isShared = composeFile.startsWith(stackDir);\n    84→\n    85→      const resolvedComposeFile = isShared ? getComposeFilePath() : composeFile;\n    86→      const projectName = isShared ? 'codeharness-shared' : undefined;\n    87→      const header = isShared ? 'Docker: shared stack at ~/.codeharness/stack/' : 'Docker:';\n    88→\n    89→      console.log(header);\n    90→      const health = getStackHealth(resolvedComposeFile, projectName);\n    91→      for (const svc of health.services) {\n    92→        console.log(`  ${svc.name}: ${svc.running ? 'running' : 'stopped'}`);\n    93→      }\n    94→      if (health.healthy) {\n    95→        console.log(\n    96→          `  Endpoints: logs=${DEFAULT_ENDPOINTS.logs} metrics=${DEFAULT_ENDPOINTS.metrics} traces=${DEFAULT_ENDPOINTS.traces}`,\n    97→        );\n    98→      }\n    99→    }\n   100→  }\n   101→\n   102→  // Service-scoped endpoints\n   103→  const serviceName = state.otlp?.service_name;\n   104→  if (serviceName) {\n   105→    const endpoints = resolveEndpoints(state);\n   106→    const scoped = buildScopedEndpoints(endpoints, serviceName);\n   107→    console.log(`  Scoped: logs=${scoped.logs} metrics=${scoped.metrics} traces=${scoped.traces}`);\n   108→  }\n   109→\n   110→  // Beads\n   111→  printBeadsSummary();\n   112→\n   113→  // Onboarding progress\n   114→  printOnboardingProgress();\n   115→\n   116→  // Session flags\n   117→  const sf = state.session_flags;\n   118→  console.log(\n   119→    `Session: tests_passed=${sf.tests_passed} coverage_met=${sf.coverage_met} verification_run=${sf.verification_run} logs_queried=${sf.logs_queried}`,\n   120→  );\n   121→\n   122→  // Coverage\n   123→  const currentCov = state.coverage.current !== null ? `${state.coverage.current}%` : '\\u2014';\n   124→  console.log(`Coverage: ${currentCov} / ${state.coverage.target}% target`);\n   125→\n   126→  // Verification log\n   127→  if (state.verification_log.length === 0) {\n   128→    console.log('Verification: no entries');\n   129→  } else {\n   130→    console.log('Verification log:');\n   131→    for (const entry of state.verification_log) {\n   132→      console.log(`  ${entry}`);\n   133→    }\n   134→  }\n   135→}\n   136→\n   137→function handleFullStatusJson(state: HarnessState): void {\n   138→  // Docker (always present — observability is mandatory)\n   139→  let docker: Record<string, unknown>;\n   140→  {\n   141→    const mode = state.otlp?.mode ?? 'local-shared';\n   142→\n   143→    if (mode === 'remote-direct') {\n   144→      docker = {\n   145→        mode: 'remote-direct',\n   146→        endpoint: state.otlp?.endpoint,\n   147→      };\n   148→    } else if (mode === 'remote-routed') {\n   149→      const sharedComposeFile = getComposeFilePath();\n   150→      const health = getCollectorHealth(sharedComposeFile);\n   151→      docker = {\n   152→        mode: 'remote-routed',\n   153→        healthy: health.healthy,\n   154→        services: health.services,\n   155→        remote_endpoints: state.docker?.remote_endpoints,\n   156→      };\n   157→    } else {\n   158→      const composeFile = state.docker?.compose_file ?? 'docker-compose.harness.yml';\n   159→      const stackDir = getStackDir();\n   160→      const isShared = composeFile.startsWith(stackDir);\n   161→\n   162→      if (isShared) {\n   163→        const sharedComposeFile = getComposeFilePath();\n   164→        const health = getStackHealth(sharedComposeFile, 'codeharness-shared');\n   165→        docker = {\n   166→          shared: true,\n   167→          stack_dir: '~/.codeharness/stack/',\n   168→          healthy: health.healthy,\n   169→          services: health.services,\n   170→          ...(health.healthy ? { endpoints: DEFAULT_ENDPOINTS } : {}),\n   171→        };\n   172→      } else {\n   173→        const health = getStackHealth(composeFile);\n   174→        docker = {\n   175→          healthy: health.healthy,\n   176→          services: health.services,\n   177→          ...(health.healthy ? { endpoints: DEFAULT_ENDPOINTS } : {}),\n   178→        };\n   179→      }\n   180→    }\n   181→  }\n   182→\n   183→  // Resolved endpoints\n   184→  const endpoints = resolveEndpoints(state);\n   185→\n   186→  // Scoped endpoints\n   187→  const serviceName = state.otlp?.service_name;\n   188→  const scoped_endpoints = serviceName ? buildScopedEndpoints(endpoints, serviceName) : undefined;\n   189→\n   190→  // Beads\n   191→  const beads = getBeadsData();\n   192→\n   193→  // Onboarding progress\n   194→  const onboarding = getOnboardingProgressData();\n   195→\n   196→  // Sprint state\n   197→  const sprint = getSprintReportData();\n   198→\n   199→  // Validation progress\n   200→  const validationResult = getValidationProgress();\n   201→  const validation = validationResult.success && validationResult.data.total > 0\n   202→    ? validationResult.data : undefined;\n   203→\n   204→  jsonOutput({\n   205→    version: state.harness_version,\n   206→    stack: state.stack,\n   207→    ...(state.app_type ? { app_type: state.app_type } : {}),\n   208→    ...(sprint ? { sprint } : {}),\n   209→    ...(validation ? { validation } : {}),\n   210→    enforcement: state.enforcement,\n   211→    docker,\n   212→    endpoints,\n   213→    ...(scoped_endpoints ? { scoped_endpoints } : {}),\n   214→    beads,\n   215→    ...(onboarding ? { onboarding } : {}),\n   216→    session_flags: state.session_flags,\n   217→    coverage: state.coverage,\n   218→    verification_log: state.verification_log,\n   219→  });\n   220→}\n   221→\n   222→// ─── Health Check Mode ──────────────────────────────────────────────────────\n   223→\n   224→export async function handleHealthCheck(isJson: boolean): Promise<void> {\n   225→  const checks: { name: string; status: 'ok' | 'fail'; detail: string }[] = [];\n   226→\n   227→  // 1. State file integrity\n   228→  let state: HarnessState | null = null;\n   229→  try {\n   230→    state = readState();\n   231→    checks.push({ name: 'state_file', status: 'ok', detail: 'valid' });\n   232→  } catch {\n   233→    checks.push({ name: 'state_file', status: 'fail', detail: 'not found' });\n   234→  }\n   235→\n   236→  // 2. Docker health (always checked — observability is mandatory)\n   237→  if (state) {\n   238→    const mode = state.otlp?.mode ?? 'local-shared';\n   239→\n   240→    if (mode === 'remote-direct') {\n   241→      const endpoint = state.otlp?.endpoint ?? '';\n   242→      const result = await checkRemoteEndpoint(endpoint);\n   243→      checks.push({\n   244→        name: 'docker',\n   245→        status: result.reachable ? 'ok' : 'fail',\n   246→        detail: result.reachable ? `remote OTLP reachable (${endpoint})` : `remote OTLP unreachable (${result.error ?? 'unknown'})`,\n   247→      });\n   248→    } else if (mode === 'remote-routed') {\n   249→      const sharedComposeFile = getComposeFilePath();\n   250→      const health = getCollectorHealth(sharedComposeFile);\n   251→      checks.push({\n   252→        name: 'docker',\n   253→        status: health.healthy ? 'ok' : 'fail',\n   254→        detail: health.healthy ? 'OTel Collector running' : (health.remedy ?? 'collector down'),\n   255→      });\n   256→\n   257→      // Check remote endpoints\n   258→      const re = state.docker?.remote_endpoints;\n   259→      if (re) {\n   260→        for (const [label, url] of [['logs', re.logs_url], ['metrics', re.metrics_url], ['traces', re.traces_url]] as const) {\n   261→          if (url) {\n   262→            const result = await checkRemoteEndpoint(url);\n   263→            checks.push({\n   264→              name: `remote_${label}`,\n   265→              status: result.reachable ? 'ok' : 'fail',\n   266→              detail: result.reachable ? `reachable (${url})` : `unreachable (${result.error ?? 'unknown'})`,\n   267→            });\n   268→          }\n   269→        }\n   270→      }\n   271→    } else {\n   272→      const composeFile = state.docker?.compose_file ?? 'docker-compose.harness.yml';\n   273→      const sDir = getStackDir();\n   274→      const isShared = composeFile.startsWith(sDir);\n   275→      const healthComposeFile = isShared ? getComposeFilePath() : composeFile;\n   276→      const healthProjectName = isShared ? 'codeharness-shared' : undefined;\n   277→      const health = getStackHealth(healthComposeFile, healthProjectName);\n   278→      checks.push({\n   279→        name: 'docker',\n   280→        status: health.healthy ? 'ok' : 'fail',\n   281→        detail: health.healthy ? 'all services running' : (health.remedy ?? 'services down'),\n   282→      });\n   283→    }\n   284→  } else {\n   285→    checks.push({ name: 'docker', status: 'fail', detail: 'cannot check (no state)' });\n   286→  }\n   287→\n   288→  // 3. Beads availability\n   289→  try {\n   290→    if (isBeadsInitialized()) {\n   291→      listIssues();\n   292→      checks.push({ name: 'beads', status: 'ok', detail: 'available' });\n   293→    } else {\n   294→      checks.push({ name: 'beads', status: 'fail', detail: 'not initialized' });\n   295→    }\n   296→  } catch {\n   297→    checks.push({ name: 'beads', status: 'fail', detail: 'bd command failed' });\n   298→  }\n   299→\n   300→  const allPassed = checks.every(c => c.status === 'ok');\n   301→\n   302→  if (isJson) {\n   303→    const checksObj: Record<string, { status: string; detail: string }> = {};\n   304→    for (const c of checks) {\n   305→      checksObj[c.name] = { status: c.status, detail: c.detail };\n   306→    }\n   307→    jsonOutput({ status: allPassed ? 'ok' : 'fail', checks: checksObj });\n   308→  } else {\n   309→    for (const c of checks) {\n   310→      const prefix = c.status === 'ok' ? '[OK]' : '[FAIL]';\n   311→      const label = c.name.replace(/_/g, ' ');\n   312→      console.log(`${prefix} ${label[0].toUpperCase() + label.slice(1)}: ${c.detail}`);\n   313→    }\n   314→  }\n   315→\n   316→  process.exitCode = allPassed ? 0 : 1;\n   317→}\n   318→\n   319→// ─── Docker Check ───────────────────────────────────────────────────────────\n   320→\n   321→export async function handleDockerCheck(isJson: boolean): Promise<void> {\n   322→  let state: HarnessState | null = null;\n   323→  try {\n   324→    state = readState();\n   325→  } catch {\n   326→    // No state file or corrupted\n   327→  }\n   328→\n   329→  const mode = state?.otlp?.mode ?? 'local-shared';\n   330→\n   331→  if (mode === 'remote-direct') {\n   332→    const endpoint = state?.otlp?.endpoint ?? '';\n   333→    const result = await checkRemoteEndpoint(endpoint);\n   334→    if (isJson) {\n   335→      jsonOutput({\n   336→        status: result.reachable ? 'ok' : 'fail',\n   337→        mode: 'remote-direct',\n   338→        endpoint,\n   339→        reachable: result.reachable,\n   340→        ...(result.error ? { error: result.error } : {}),\n   341→      });\n   342→    } else {\n   343→      if (result.reachable) {\n   344→        ok(`Remote OTLP endpoint: reachable (${endpoint})`);\n   345→      } else {\n   346→        fail(`Remote OTLP endpoint: unreachable (${endpoint})`);\n   347→        if (result.error) {\n   348→          info(`Error: ${result.error}`);\n   349→        }\n   350→      }\n   351→    }\n   352→    return;\n   353→  }\n   354→\n   355→  if (mode === 'remote-routed') {\n   356→    const sharedComposeFile = getComposeFilePath();\n   357→    const health = getCollectorHealth(sharedComposeFile);\n   358→\n   359→    if (isJson) {\n   360→      jsonOutput({\n   361→        status: health.healthy ? 'ok' : 'fail',\n   362→        mode: 'remote-routed',\n   363→        docker: {\n   364→          healthy: health.healthy,\n   365→          services: health.services,\n   366→          remedy: health.remedy,\n   367→        },\n   368→        remote_endpoints: state?.docker?.remote_endpoints,\n   369→      });\n   370→    } else {\n   371→      if (health.healthy) {\n   372→        ok('OTel Collector: running');\n   373→      } else {\n   374→        fail('OTel Collector: not running');\n   375→        if (health.remedy) {\n   376→          info(`-> ${health.remedy}`);\n   377→        }\n   378→      }\n   379→      const re = state?.docker?.remote_endpoints;\n   380→      if (re) {\n   381→        info(`Remote backends: logs=${re.logs_url} metrics=${re.metrics_url} traces=${re.traces_url}`);\n   382→      }\n   383→    }\n   384→    return;\n   385→  }\n   386→\n   387→  // local-shared mode (default)\n   388→  let composeFile = 'docker-compose.harness.yml';\n   389→  let projectName: string | undefined;\n   390→\n   391→  if (state?.docker?.compose_file) {\n   392→    composeFile = state.docker.compose_file;\n   393→  }\n   394→\n   395→  const stackDir = getStackDir();\n   396→  if (composeFile.startsWith(stackDir)) {\n   397→    composeFile = getComposeFilePath();\n   398→    projectName = 'codeharness-shared';\n   399→  }\n   400→\n   401→  const health = getStackHealth(composeFile, projectName);\n   402→\n   403→  if (isJson) {\n   404→    jsonOutput({\n   405→      status: health.healthy ? 'ok' : 'fail',\n   406→      ...(projectName ? { project_name: projectName } : {}),\n   407→      docker: {\n   408→        healthy: health.healthy,\n   409→        services: health.services,\n   410→        remedy: health.remedy,\n   411→      },\n   412→      ...(health.healthy ? { endpoints: DEFAULT_ENDPOINTS } : {}),\n   413→    });\n   414→    return;\n   415→  }\n   416→\n   417→  if (health.healthy) {\n   418→    ok(`VictoriaMetrics stack: running${projectName ? ` (project: ${projectName})` : ''}`);\n   419→    for (const svc of health.services) {\n   420→      info(`  ${svc.name}: ${svc.running ? 'running' : 'stopped'}`);\n   421→    }\n   422→    info(`Endpoints: logs=${DEFAULT_ENDPOINTS.logs} metrics=${DEFAULT_ENDPOINTS.metrics} traces=${DEFAULT_ENDPOINTS.traces}`);\n   423→  } else {\n   424→    fail(`VictoriaMetrics stack: not running${projectName ? ` (project: ${projectName})` : ''}`);\n   425→    for (const svc of health.services) {\n   426→      if (!svc.running) {\n   427→        info(`  ${svc.name}: down`);\n   428→      }\n   429→    }\n   430→    if (health.remedy) {\n   431→      info(`-> ${health.remedy}`);\n   432→    }\n   433→  }\n   434→}\n   435→\n   436→// ─── Sprint State Helpers ────────────────────────────────────────────────────\n   437→\n   438→function printSprintState(): void {\n   439→  const reportResult = generateReport();\n   440→  if (!reportResult.success) {\n   441→    console.log('Sprint state: unavailable');\n   442→    return;\n   443→  }\n   444→\n   445→  const r = reportResult.data;\n   446→  console.log(`\\u2500\\u2500 Project State \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500`);\n   447→  console.log(`Sprint: ${r.done}/${r.total} done (${r.sprintPercent}%) | ${r.epicsDone}/${r.epicsTotal} epics complete`);\n   448→\n   449→  if (r.activeRun) {\n   450→    console.log('');\n   451→    console.log(`\\u2500\\u2500 Active Run \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500`);\n   452→    const currentStory = r.inProgress ?? 'none';\n   453→    console.log(`Status: running (iteration ${r.activeRun.iterations}, ${r.activeRun.duration} elapsed)`);\n   454→    console.log(`Current: ${currentStory}`);\n   455→    console.log(`Budget: $${r.activeRun.cost.toFixed(2)} spent`);\n   456→  } else if (r.lastRun) {\n   457→    console.log('');\n   458→    console.log(`\\u2500\\u2500 Last Run Summary \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500`);\n   459→    console.log(`Duration: ${r.lastRun.duration} | Cost: $${r.lastRun.cost.toFixed(2)} | Iterations: ${r.lastRun.iterations}`);\n   460→    console.log(`Completed:  ${r.lastRun.completed.length} stories${r.lastRun.completed.length > 0 ? ` (${r.lastRun.completed.join(', ')})` : ''}`);\n   461→    if (r.failedDetails.length > 0) {\n   462→      console.log(`Failed:     ${r.failedDetails.length} stor${r.failedDetails.length === 1 ? 'y' : 'ies'}`);\n   463→      for (const fd of r.failedDetails) {\n   464→        const acPart = fd.acNumber !== null ? `AC ${fd.acNumber}` : 'unknown AC';\n   465→        console.log(`  \\u2514 ${fd.key}: ${acPart} \\u2014 ${fd.errorLine} (attempt ${fd.attempts}/${fd.maxAttempts})`);\n   466→      }\n   467→    }\n   468→    if (r.lastRun.blocked.length > 0) {\n   469→      console.log(`Blocked:    ${r.lastRun.blocked.length} stories (retry-exhausted)`);\n   470→    }\n   471→  }\n   472→\n   473→  if (r.actionItemsLabeled.length > 0) {\n   474→    console.log('');\n   475→    console.log(`\\u2500\\u2500 Action Items \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500`);\n   476→    for (const la of r.actionItemsLabeled) {\n   477→      console.log(`  [${la.label}] ${la.item.story}: ${la.item.description}`);\n   478→    }\n   479→  }\n   480→\n   481→  console.log('');\n   482→}\n   483→\n   484→function printValidationProgress(): void {\n   485→  const result = getValidationProgress();\n   486→  if (!result.success) return;\n   487→  const p = result.data;\n   488→  if (p.total === 0) return;\n   489→  console.log(`Validation: ${p.passed}/${p.total} passed, ${p.failed} failed, ${p.blocked} blocked, ${p.remaining} remaining`);\n   490→}\n   491→\n   492→function getSprintReportData(): StatusReport | null {\n   493→  const reportResult = generateReport();\n   494→  if (!reportResult.success) return null;\n   495→  return reportResult.data;\n   496→}\n   497→\n   498→// ─── Beads Helpers ──────────────────────────────────────────────────────────\n   499→\n   500→function printBeadsSummary(): void {\n   501→  if (!isBeadsInitialized()) {\n   502→    console.log('Beads: not initialized');\n   503→    return;\n   504→  }\n   505→\n   506→  try {\n   507→    const issues = listIssues();\n   508→    const byType = new Map<string, number>();\n   509→    const byStatus = new Map<string, number>();\n   510→\n   511→    for (const issue of issues) {\n   512→      byType.set(issue.type, (byType.get(issue.type) ?? 0) + 1);\n   513→      byStatus.set(issue.status, (byStatus.get(issue.status) ?? 0) + 1);\n   514→    }\n   515→\n   516→    const typeParts = Array.from(byType.entries())\n   517→      .map(([t, n]) => `${t}:${n}`)\n   518→      .join(' ');\n   519→    const ready = byStatus.get('ready') ?? 0;\n   520→    const inProgress = byStatus.get('in_progress') ?? 0;\n   521→    const done = byStatus.get('done') ?? 0;\n   522→\n   523→    const typeInfo = typeParts ? ` (${typeParts})` : '';\n   524→    console.log(\n   525→      `Beads: ${issues.length} issues${typeInfo} | ready:${ready} in-progress:${inProgress} done:${done}`,\n   526→    );\n   527→  } catch {\n   528→    console.log('Beads: unavailable (bd command failed)');\n   529→  }\n   530→}\n   531→\n   532→function printOnboardingProgress(): void {\n   533→  const progress = getOnboardingProgress({ listIssues });\n   534→  if (progress) {\n   535→    console.log(`Onboarding: ${progress.resolved}/${progress.total} gaps resolved (${progress.remaining} remaining)`);\n   536→  }\n   537→}\n   538→\n   539→function getOnboardingProgressData(): Record<string, unknown> | null {\n   540→  const progress = getOnboardingProgress({ listIssues });\n   541→  if (!progress) {\n   542→    return null;\n   543→  }\n   544→  return {\n   545→    total: progress.total,\n   546→    resolved: progress.resolved,\n   547→    remaining: progress.remaining,\n   548→  };\n   549→}\n   550→\n   551→function getBeadsData(): Record<string, unknown> {\n   552→  if (!isBeadsInitialized()) {\n   553→    return { initialized: false };\n   554→  }\n   555→\n   556→  try {\n   557→    const issues = listIssues();\n   558→    const issuesByType: Record<string, number> = {};\n   559→    const issuesByStatus: Record<string, number> = {};\n   560→\n   561→    for (const issue of issues) {\n   562→      issuesByType[issue.type] = (issuesByType[issue.type] ?? 0) + 1;\n   563→      issuesByStatus[issue.status] = (issuesByStatus[issue.status] ?? 0) + 1;\n   564→    }\n   565→\n   566→    return {\n   567→      initialized: true,\n   568→      total: issues.length,\n   569→      issues_by_type: issuesByType,\n   570→      issues_by_status: issuesByStatus,\n   571→    };\n   572→  } catch {\n   573→    return { initialized: true, error: 'bd command failed' };\n   574→  }\n   575→}\n   576→"}]},"parent_tool_use_id":"toolu_01VNjZAjpP2pH4BGjYH7gZ11","session_id":"a74f233b-d75f-4731-af98-d5f8de661326","uuid":"241cf797-1cce-499c-b4cd-0ebda428b3ea","timestamp":"2026-03-24T13:42:24.371Z"}
