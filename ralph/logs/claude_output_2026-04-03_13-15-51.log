{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014zC4o3ny2RJcNcfnowwNde","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n2\timport { EventEmitter, Readable } from 'node:stream';\n3\t\n4\t// --- Mock child_process ---\n5\t\n6\tconst mockSpawn = vi.fn();\n7\tconst mockExecFile = vi.fn();\n8\t\n9\tvi.mock('node:child_process', () => ({\n10\t  spawn: (...args: unknown[]) => mockSpawn(...args),\n11\t  execFile: (...args: unknown[]) => mockExecFile(...args),\n12\t}));\n13\t\n14\timport { OpenCodeDriver, parseLine, classifyError } from '../drivers/opencode.js';\n15\timport type { DispatchOpts } from '../types.js';\n16\timport type { StreamEvent, ResultEvent } from '../stream-parser.js';\n17\t\n18\t// --- Helpers ---\n19\t\n20\tfunction makeOpts(overrides?: Partial<DispatchOpts>): DispatchOpts {\n21\t  return {\n22\t    prompt: 'Do the thing',\n23\t    model: 'default',\n24\t    cwd: '/tmp/test',\n25\t    sourceAccess: true,\n26\t    ...overrides,\n27\t  };\n28\t}\n29\t\n30\tasync function collectEvents(iterable: AsyncIterable<StreamEvent>): Promise<StreamEvent[]> {\n31\t  const events: StreamEvent[] = [];\n32\t  for await (const event of iterable) {\n33\t    events.push(event);\n34\t  }\n35\t  return events;\n36\t}\n37\t\n38\t/**\n39\t * Create a mock child process that emits given stdout lines and exits with given code.\n40\t */\n41\tfunction createMockProcess(stdoutLines: string[], exitCode = 0, stderrData = ''): {\n42\t  proc: EventEmitter & {\n43\t    stdout: Readable;\n44\t    stderr: EventEmitter & { on: ReturnType<typeof vi.fn> };\n45\t    kill: ReturnType<typeof vi.fn>;\n46\t  };\n47\t} {\n48\t  const stdout = new Readable({ read() {} });\n49\t  const stderr = new EventEmitter();\n50\t  const proc = new EventEmitter() as EventEmitter & {\n51\t    stdout: Readable;\n52\t    stderr: EventEmitter & { on: ReturnType<typeof vi.fn> };\n53\t    kill: ReturnType<typeof vi.fn>;\n54\t  };\n55\t  proc.stdout = stdout;\n56\t  proc.stderr = stderr as EventEmitter & { on: ReturnType<typeof vi.fn> };\n57\t  proc.kill = vi.fn(() => {\n58\t    // When killed, close the process\n59\t    setTimeout(() => {\n60\t      stdout.push(null);\n61\t      proc.emit('close', 1);\n62\t    }, 5);\n63\t  });\n64\t\n65\t  // Push stderr data\n66\t  if (stderrData) {\n67\t    setTimeout(() => {\n68\t      stderr.emit('data', Buffer.from(stderrData));\n69\t    }, 1);\n70\t  }\n71\t\n72\t  // Push lines to stdout, then close\n73\t  setTimeout(() => {\n74\t    for (const line of stdoutLines) {\n75\t      stdout.push(line + '\\n');\n76\t    }\n77\t    stdout.push(null);\n78\t\n79\t    // Emit close after stdout is consumed\n80\t    setTimeout(() => {\n81\t      proc.emit('close', exitCode);\n82\t    }, 10);\n83\t  }, 1);\n84\t\n85\t  return { proc };\n86\t}\n87\t\n88\t// --- Fixtures as inline data ---\n89\t\n90\tconst SUCCESS_LINES = [\n91\t  '{\"type\":\"tool_call\",\"name\":\"read_file\",\"call_id\":\"oc_call_001\"}',\n92\t  '{\"type\":\"tool_input\",\"call_id\":\"oc_call_001\",\"input\":\"{\\\\\"path\\\\\":\\\\\"/src/main.go\\\\\"}\"}',\n93\t  '{\"type\":\"tool_result\",\"call_id\":\"oc_call_001\",\"output\":\"package main\\\\nfunc main() {}\"}',\n94\t  '{\"type\":\"message\",\"content\":\"I\\'ve read the file. Let me update it now.\"}',\n95\t  '{\"type\":\"tool_call\",\"name\":\"write_file\",\"call_id\":\"oc_call_002\"}',\n96\t  '{\"type\":\"tool_input\",\"call_id\":\"oc_call_002\",\"input\":\"{\\\\\"path\\\\\":\\\\\"/src/main.go\\\\\",\\\\\"content\\\\\":\\\\\"updated\\\\\"}\"}',\n97\t  '{\"type\":\"tool_result\",\"call_id\":\"oc_call_002\",\"output\":\"File written successfully.\"}',\n98\t  '{\"type\":\"message\",\"content\":\"Done. The file has been updated with the print statement.\"}',\n99\t  '{\"type\":\"result\",\"status\":\"completed\",\"cost_usd\":0.0021,\"session_id\":\"opencode-sess-xyz789\"}',\n100\t];\n101\t\n102\tconst UNPARSEABLE_LINES = [\n103\t  'Starting opencode v0.5.0...',\n104\t  'Connecting to API endpoint...',\n105\t  '[progress] Analyzing codebase...',\n106\t  'not valid json {{{',\n107\t];\n108\t\n109\t// --- Tests ---\n110\t\n111\tdescribe('OpenCodeDriver', () => {\n112\t  let driver: OpenCodeDriver;\n113\t\n114\t  beforeEach(() => {\n115\t    vi.clearAllMocks();\n116\t    driver = new OpenCodeDriver();\n117\t  });\n118\t\n119\t  afterEach(() => {\n120\t    vi.restoreAllMocks();\n121\t  });\n122\t\n123\t  describe('class properties (AC #1)', () => {\n124\t    it('has name \"opencode\"', () => {\n125\t      expect(driver.name).toBe('opencode');\n126\t    });\n127\t\n128\t    it('has defaultModel \"default\"', () => {\n129\t      expect(driver.defaultModel).toBe('default');\n130\t    });\n131\t\n132\t    it('has correct capabilities', () => {\n133\t      expect(driver.capabilities).toEqual({\n134\t        supportsPlugins: true,\n135\t        supportsStreaming: true,\n136\t        costReporting: true,\n137\t      });\n138\t    });\n139\t  });\n140\t\n141\t  describe('parseLine (AC #2)', () => {\n142\t    it('parses tool_call to tool-start event', () => {\n143\t      const event = parseLine('{\"type\":\"tool_call\",\"name\":\"read_file\",\"call_id\":\"oc_001\"}');\n144\t      expect(event).toEqual({ type: 'tool-start', name: 'read_file', id: 'oc_001' });\n145\t    });\n146\t\n147\t    it('parses tool_input to tool-input event', () => {\n148\t      const event = parseLine('{\"type\":\"tool_input\",\"call_id\":\"c1\",\"input\":\"{\\\\\"path\\\\\":\\\\\"/a\\\\\"}\"}');\n149\t      expect(event).toEqual({ type: 'tool-input', partial: '{\"path\":\"/a\"}' });\n150\t    });\n151\t\n152\t    it('parses tool_result to tool-complete event', () => {\n153\t      const event = parseLine('{\"type\":\"tool_result\",\"call_id\":\"c1\",\"output\":\"ok\"}');\n154\t      expect(event).toEqual({ type: 'tool-complete' });\n155\t    });\n156\t\n157\t    it('parses message to text event', () => {\n158\t      const event = parseLine('{\"type\":\"message\",\"content\":\"Hello\"}');\n159\t      expect(event).toEqual({ type: 'text', text: 'Hello' });\n160\t    });\n161\t\n162\t    it('parses retry to retry event', () => {\n163\t      const event = parseLine('{\"type\":\"retry\",\"attempt\":2,\"delay_ms\":5000}');\n164\t      expect(event).toEqual({ type: 'retry', attempt: 2, delay: 5000 });\n165\t    });\n166\t\n167\t    it('parses result with cost', () => {\n168\t      const event = parseLine('{\"type\":\"result\",\"cost_usd\":0.0021,\"session_id\":\"sess-123\"}');\n169\t      expect(event).toEqual({\n170\t        type: 'result',\n171\t        cost: 0.0021,\n172\t        sessionId: 'sess-123',\n173\t        cost_usd: 0.0021,\n174\t      });\n175\t    });\n176\t\n177\t    it('parses result without cost (cost_usd is null)', () => {\n178\t      const event = parseLine('{\"type\":\"result\",\"status\":\"completed\",\"session_id\":\"sess-123\"}');\n179\t      expect(event).toEqual({\n180\t        type: 'result',\n181\t        cost: 0,\n182\t        sessionId: 'sess-123',\n183\t        cost_usd: null,\n184\t      });\n185\t    });\n186\t\n187\t    it('returns null for empty lines', () => {\n188\t      expect(parseLine('')).toBeNull();\n189\t      expect(parseLine('   ')).toBeNull();\n190\t    });\n191\t\n192\t    it('returns null for invalid JSON', () => {\n193\t      expect(parseLine('not valid json {{{')).toBeNull();\n194\t    });\n195\t\n196\t    it('returns null for unrecognized type', () => {\n197\t      expect(parseLine('{\"type\":\"unknown_event\",\"data\":\"foo\"}')).toBeNull();\n198\t    });\n199\t\n200\t    it('returns null for arrays', () => {\n201\t      expect(parseLine('[1,2,3]')).toBeNull();\n202\t    });\n203\t\n204\t    it('returns null for primitives', () => {\n205\t      expect(parseLine('\"hello\"')).toBeNull();\n206\t      expect(parseLine('42')).toBeNull();\n207\t    });\n208\t\n209\t    it('returns null for tool_call missing name', () => {\n210\t      expect(parseLine('{\"type\":\"tool_call\",\"call_id\":\"c1\"}')).toBeNull();\n211\t    });\n212\t\n213\t    it('returns null for tool_call missing call_id', () => {\n214\t      expect(parseLine('{\"type\":\"tool_call\",\"name\":\"read_file\"}')).toBeNull();\n215\t    });\n216\t\n217\t    it('returns null for tool_input with non-string input', () => {\n218\t      expect(parseLine('{\"type\":\"tool_input\",\"call_id\":\"c1\",\"input\":42}')).toBeNull();\n219\t    });\n220\t\n221\t    it('returns null for message with non-string content', () => {\n222\t      expect(parseLine('{\"type\":\"message\",\"content\":42}')).toBeNull();\n223\t    });\n224\t\n225\t    it('returns null for message with missing content', () => {\n226\t      expect(parseLine('{\"type\":\"message\"}')).toBeNull();\n227\t    });\n228\t\n229\t    it('returns null for retry with non-number attempt', () => {\n230\t      expect(parseLine('{\"type\":\"retry\",\"attempt\":\"two\",\"delay_ms\":5000}')).toBeNull();\n231\t    });\n232\t\n233\t    it('returns null for retry with non-number delay', () => {\n234\t      expect(parseLine('{\"type\":\"retry\",\"attempt\":2,\"delay_ms\":\"slow\"}')).toBeNull();\n235\t    });\n236\t  });\n237\t\n238\t  describe('classifyError (AC #4)', () => {\n239\t    it('classifies 429 status as RATE_LIMIT', () => {\n240\t      const err = Object.assign(new Error('Rate limit'), { status: 429 });\n241\t      expect(classifyError(err)).toBe('RATE_LIMIT');\n242\t    });\n243\t\n244\t    it('classifies \"rate limit\" in message as RATE_LIMIT', () => {\n245\t      expect(classifyError('You have exceeded your rate limit')).toBe('RATE_LIMIT');\n246\t    });\n247\t\n248\t    it('classifies ECONNREFUSED code as NETWORK', () => {\n249\t      const err = Object.assign(new Error('connect failed'), { code: 'ECONNREFUSED' });\n250\t      expect(classifyError(err)).toBe('NETWORK');\n251\t    });\n252\t\n253\t    it('classifies ECONNREFUSED in message string as NETWORK (via fetch match)', () => {\n254\t      expect(classifyError('fetch failed: connect ECONNREFUSED 127.0.0.1:443')).toBe('NETWORK');\n255\t    });\n256\t\n257\t    it('classifies ECONNREFUSED in message string as NETWORK (via code regex)', () => {\n258\t      expect(classifyError('connect ECONNREFUSED 127.0.0.1:443')).toBe('NETWORK');\n259\t    });\n260\t\n261\t    it('classifies ETIMEDOUT code as NETWORK', () => {\n262\t      const err = Object.assign(new Error('request timed out'), { code: 'ETIMEDOUT' });\n263\t      expect(classifyError(err)).toBe('NETWORK');\n264\t    });\n265\t\n266\t    it('classifies fetch failure message as NETWORK', () => {\n267\t      expect(classifyError('fetch failed: DNS resolution error')).toBe('NETWORK');\n268\t    });\n269\t\n270\t    it('classifies 401 status as AUTH', () => {\n271\t      const err = Object.assign(new Error('Unauthorized'), { status: 401 });\n272\t      expect(classifyError(err)).toBe('AUTH');\n273\t    });\n274\t\n275\t    it('classifies 403 status as AUTH', () => {\n276\t      const err = Object.assign(new Error('Forbidden'), { status: 403 });\n277\t      expect(classifyError(err)).toBe('AUTH');\n278\t    });\n279\t\n280\t    it('classifies \"unauthorized\" in message as AUTH', () => {\n281\t      expect(classifyError('Unauthorized. Please check your API key')).toBe('AUTH');\n282\t    });\n283\t\n284\t    it('classifies timeout in message as TIMEOUT', () => {\n285\t      expect(classifyError('operation timed out')).toBe('TIMEOUT');\n286\t    });\n287\t\n288\t    it('classifies unknown errors as UNKNOWN', () => {\n289\t      expect(classifyError('Something unexpected happened')).toBe('UNKNOWN');\n290\t    });\n291\t\n292\t    it('follows priority order: rate limit before network', () => {\n293\t      const err = Object.assign(new Error('rate limit reached'), { code: 'ECONNRESET' });\n294\t      expect(classifyError(err)).toBe('RATE_LIMIT');\n295\t    });\n296\t\n297\t    it('follows priority order: network before auth', () => {\n298\t      const err = Object.assign(new Error('forbidden'), { code: 'ECONNREFUSED' });\n299\t      expect(classifyError(err)).toBe('NETWORK');\n300\t    });\n301\t  });\n302\t\n303\t  describe('dispatch — successful flow (AC #2, #3, #8)', () => {\n304\t    it('produces correct StreamEvent sequence from fixture lines', async () => {\n305\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n306\t      mockSpawn.mockReturnValue(proc);\n307\t\n308\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n309\t      const types = events.map((e) => e.type);\n310\t\n311\t      expect(types).toEqual([\n312\t        'tool-start',\n313\t        'tool-input',\n314\t        'tool-complete',\n315\t        'text',\n316\t        'tool-start',\n317\t        'tool-input',\n318\t        'tool-complete',\n319\t        'text',\n320\t        'result',\n321\t      ]);\n322\t    });\n323\t\n324\t    it('result event is always the last event', async () => {\n325\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n326\t      mockSpawn.mockReturnValue(proc);\n327\t\n328\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n329\t      expect(events[events.length - 1].type).toBe('result');\n330\t    });\n331\t\n332\t    it('captures cost from CLI output', async () => {\n333\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n334\t      mockSpawn.mockReturnValue(proc);\n335\t\n336\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n337\t      const resultEvent = events.find((e) => e.type === 'result') as ResultEvent;\n338\t      expect(resultEvent.cost_usd).toBe(0.0021);\n339\t      expect(resultEvent.cost).toBe(0.0021);\n340\t    });\n341\t\n342\t    it('getLastCost returns cost after dispatch', async () => {\n343\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n344\t      mockSpawn.mockReturnValue(proc);\n345\t\n346\t      await collectEvents(driver.dispatch(makeOpts()));\n347\t      expect(driver.getLastCost()).toBe(0.0021);\n348\t    });\n349\t  });\n350\t\n351\t  describe('dispatch — cost handling (AC #3)', () => {\n352\t    it('cost_usd is null when CLI does not report cost', async () => {\n353\t      const lines = [\n354\t        '{\"type\":\"message\",\"content\":\"Done.\"}',\n355\t        '{\"type\":\"result\",\"status\":\"completed\",\"session_id\":\"sess-no-cost\"}',\n356\t      ];\n357\t      const { proc } = createMockProcess(lines, 0);\n358\t      mockSpawn.mockReturnValue(proc);\n359\t\n360\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n361\t      const resultEvent = events.find((e) => e.type === 'result') as ResultEvent;\n362\t      expect(resultEvent.cost_usd).toBeNull();\n363\t    });\n364\t\n365\t    it('getLastCost returns null before any dispatch', () => {\n366\t      expect(driver.getLastCost()).toBeNull();\n367\t    });\n368\t\n369\t    it('getLastCost resets on new dispatch', async () => {\n370\t      // First dispatch with cost\n371\t      const { proc: proc1 } = createMockProcess(SUCCESS_LINES, 0);\n372\t      mockSpawn.mockReturnValue(proc1);\n373\t      await collectEvents(driver.dispatch(makeOpts()));\n374\t      expect(driver.getLastCost()).toBe(0.0021);\n375\t\n376\t      // Second dispatch without cost\n377\t      const lines = ['{\"type\":\"result\",\"status\":\"completed\",\"session_id\":\"s\"}'];\n378\t      const { proc: proc2 } = createMockProcess(lines, 0);\n379\t      mockSpawn.mockReturnValue(proc2);\n380\t      await collectEvents(driver.dispatch(makeOpts()));\n381\t      expect(driver.getLastCost()).toBeNull();\n382\t    });\n383\t  });\n384\t\n385\t  describe('dispatch — error handling (AC #4)', () => {\n386\t    it('yields result with RATE_LIMIT on rate limit stderr', async () => {\n387\t      const { proc } = createMockProcess(\n388\t        [],\n389\t        1,\n390\t        'Error: Request failed with status 429: You have exceeded your rate limit.',\n391\t      );\n392\t      mockSpawn.mockReturnValue(proc);\n393\t\n394\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n395\t      const resultEvent = events.find((e) => e.type === 'result') as ResultEvent;\n396\t      expect(resultEvent.errorCategory).toBe('RATE_LIMIT');\n397\t    });\n398\t\n399\t    it('yields result with AUTH on auth failure stderr', async () => {\n400\t      const { proc } = createMockProcess(\n401\t        [],\n402\t        1,\n403\t        'Error: Request failed with status 401: Unauthorized.',\n404\t      );\n405\t      mockSpawn.mockReturnValue(proc);\n406\t\n407\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n408\t      const resultEvent = events.find((e) => e.type === 'result') as ResultEvent;\n409\t      expect(resultEvent.errorCategory).toBe('AUTH');\n410\t    });\n411\t\n412\t    it('yields result with NETWORK on network failure stderr', async () => {\n413\t      const { proc } = createMockProcess(\n414\t        [],\n415\t        1,\n416\t        'Error: fetch failed: connect ECONNREFUSED 127.0.0.1:443',\n417\t      );\n418\t      mockSpawn.mockReturnValue(proc);\n419\t\n420\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n421\t      const resultEvent = events.find((e) => e.type === 'result') as ResultEvent;\n422\t      expect(resultEvent.errorCategory).toBe('NETWORK');\n423\t    });\n424\t\n425\t    it('yields result with UNKNOWN on unrecognized error', async () => {\n426\t      const { proc } = createMockProcess([], 1, 'Something went wrong');\n427\t      mockSpawn.mockReturnValue(proc);\n428\t\n429\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n430\t      const resultEvent = events.find((e) => e.type === 'result') as ResultEvent;\n431\t      expect(resultEvent.errorCategory).toBe('UNKNOWN');\n432\t    });\n433\t\n434\t    it('always yields exactly one result event on error', async () => {\n435\t      const { proc } = createMockProcess([], 1, 'kaboom');\n436\t      mockSpawn.mockReturnValue(proc);\n437\t\n438\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n439\t      const resultEvents = events.filter((e) => e.type === 'result');\n440\t      expect(resultEvents).toHaveLength(1);\n441\t    });\n442\t  });\n443\t\n444\t  describe('dispatch — result guarantee (AC #2)', () => {\n445\t    it('yields result even when stdout is empty and exit code is 0', async () => {\n446\t      const { proc } = createMockProcess([], 0);\n447\t      mockSpawn.mockReturnValue(proc);\n448\t\n449\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n450\t      const resultEvents = events.filter((e) => e.type === 'result');\n451\t      expect(resultEvents).toHaveLength(1);\n452\t    });\n453\t\n454\t    it('yields exactly one result from normal flow', async () => {\n455\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n456\t      mockSpawn.mockReturnValue(proc);\n457\t\n458\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n459\t      const resultEvents = events.filter((e) => e.type === 'result');\n460\t      expect(resultEvents).toHaveLength(1);\n461\t    });\n462\t  });\n463\t\n464\t  describe('dispatch — timeout (AC #6)', () => {\n465\t    it('kills process on timeout and yields TIMEOUT result', async () => {\n466\t      // Create a process that never completes on its own\n467\t      const stdout = new Readable({ read() {} });\n468\t      const stderr = new EventEmitter();\n469\t      const proc = new EventEmitter() as EventEmitter & {\n470\t        stdout: Readable;\n471\t        stderr: EventEmitter;\n472\t        kill: ReturnType<typeof vi.fn>;\n473\t      };\n474\t      proc.stdout = stdout;\n475\t      proc.stderr = stderr;\n476\t      proc.kill = vi.fn(() => {\n477\t        // When killed, end the streams and emit close\n478\t        setTimeout(() => {\n479\t          stdout.push(null);\n480\t          proc.emit('close', 1);\n481\t        }, 5);\n482\t      });\n483\t\n484\t      mockSpawn.mockReturnValue(proc);\n485\t\n486\t      const events = await collectEvents(driver.dispatch(makeOpts({ timeout: 50 })));\n487\t      const resultEvent = events.find((e) => e.type === 'result') as ResultEvent;\n488\t\n489\t      expect(proc.kill).toHaveBeenCalled();\n490\t      expect(resultEvent).toBeDefined();\n491\t      expect(resultEvent.errorCategory).toBe('TIMEOUT');\n492\t    });\n493\t  });\n494\t\n495\t  describe('dispatch — plugins pass-through (AC #7)', () => {\n496\t    it('passes plugins as --plugin flags to CLI', async () => {\n497\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n498\t      mockSpawn.mockReturnValue(proc);\n499\t\n500\t      await collectEvents(\n501\t        driver.dispatch(makeOpts({ plugins: ['plugin-a', 'plugin-b'] })),\n502\t      );\n503\t\n504\t      expect(mockSpawn).toHaveBeenCalledWith(\n505\t        'opencode',\n506\t        expect.arrayContaining(['--plugin', 'plugin-a', '--plugin', 'plugin-b']),\n507\t        { stdio: ['ignore', 'pipe', 'pipe'] },\n508\t      );\n509\t    });\n510\t\n511\t    it('does not add --plugin flags when plugins is empty', async () => {\n512\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n513\t      mockSpawn.mockReturnValue(proc);\n514\t\n515\t      await collectEvents(driver.dispatch(makeOpts({ plugins: [] })));\n516\t\n517\t      const spawnArgs = mockSpawn.mock.calls[0][1] as string[];\n518\t      expect(spawnArgs).not.toContain('--plugin');\n519\t    });\n520\t\n521\t    it('does not add --plugin flags when plugins is undefined', async () => {\n522\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n523\t      mockSpawn.mockReturnValue(proc);\n524\t\n525\t      await collectEvents(driver.dispatch(makeOpts({ plugins: undefined })));\n526\t\n527\t      const spawnArgs = mockSpawn.mock.calls[0][1] as string[];\n528\t      expect(spawnArgs).not.toContain('--plugin');\n529\t    });\n530\t\n531\t    it('proceeds normally with plugins', async () => {\n532\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n533\t      mockSpawn.mockReturnValue(proc);\n534\t\n535\t      const events = await collectEvents(\n536\t        driver.dispatch(makeOpts({ plugins: ['some-plugin'] })),\n537\t      );\n538\t      expect(events.length).toBeGreaterThan(0);\n539\t      expect(events[events.length - 1].type).toBe('result');\n540\t    });\n541\t  });\n542\t\n543\t  describe('dispatch — unparseable lines (AC #2)', () => {\n544\t    it('skips unparseable lines and logs them at debug level', async () => {\n545\t      const debugSpy = vi.spyOn(console, 'debug').mockImplementation(() => {});\n546\t      const lines = [\n547\t        ...UNPARSEABLE_LINES,\n548\t        '{\"type\":\"result\",\"cost_usd\":0.01,\"session_id\":\"s1\"}',\n549\t      ];\n550\t      const { proc } = createMockProcess(lines, 0);\n551\t      mockSpawn.mockReturnValue(proc);\n552\t\n553\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n554\t\n555\t      // Only the result event should be yielded\n556\t      expect(events).toHaveLength(1);\n557\t      expect(events[0].type).toBe('result');\n558\t\n559\t      // All 4 unparseable lines should be debug-logged\n560\t      expect(debugSpy).toHaveBeenCalledTimes(4);\n561\t      debugSpy.mockRestore();\n562\t    });\n563\t  });\n564\t\n565\t  describe('dispatch — event ordering (AC #8)', () => {\n566\t    it('events follow tool-start -> tool-input -> tool-complete, text, result ordering', async () => {\n567\t      const { proc } = createMockProcess(SUCCESS_LINES, 0);\n568\t      mockSpawn.mockReturnValue(proc);\n569\t\n570\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n571\t      const types = events.map((e) => e.type);\n572\t\n573\t      // Verify no result event before the end\n574\t      const resultIndex = types.indexOf('result');\n575\t      expect(resultIndex).toBe(types.length - 1);\n576\t\n577\t      // Verify tool sequences are ordered correctly\n578\t      // First tool use: tool-start, tool-input, tool-complete\n579\t      expect(types[0]).toBe('tool-start');\n580\t      expect(types[1]).toBe('tool-input');\n581\t      expect(types[2]).toBe('tool-complete');\n582\t      // Then text\n583\t      expect(types[3]).toBe('text');\n584\t    });\n585\t  });\n586\t\n587\t  describe('healthCheck (AC #5)', () => {\n588\t    it('returns available: true when binary is found', async () => {\n589\t      mockExecFile.mockImplementation(\n590\t        (cmd: string, args: string[], cb: (err: Error | null, result: { stdout: string }) => void) => {\n591\t          if (cmd === 'which') {\n592\t            cb(null, { stdout: '/usr/local/bin/opencode\\n' });\n593\t          } else if (args[0] === '--version') {\n594\t            cb(null, { stdout: '0.5.0\\n' });\n595\t          } else if (args[0] === 'auth') {\n596\t            cb(null, { stdout: 'authenticated\\n' });\n597\t          }\n598\t        },\n599\t      );\n600\t\n601\t      const health = await driver.healthCheck();\n602\t      expect(health.available).toBe(true);\n603\t      expect(health.version).toBe('0.5.0');\n604\t      expect(health.authenticated).toBe(true);\n605\t    });\n606\t\n607\t    it('returns available: false when binary is not found', async () => {\n608\t      mockExecFile.mockImplementation(\n609\t        (_cmd: string, _args: string[], cb: (err: Error | null) => void) => {\n610\t          cb(new Error('not found'));\n611\t        },\n612\t      );\n613\t\n614\t      const health = await driver.healthCheck();\n615\t      expect(health.available).toBe(false);\n616\t      expect(health.authenticated).toBe(false);\n617\t      expect(health.version).toBeNull();\n618\t      expect(health.error).toBe('opencode not found. Install: https://opencode.ai');\n619\t    });\n620\t\n621\t    it('returns authenticated: false when auth check fails', async () => {\n622\t      mockExecFile.mockImplementation(\n623\t        (cmd: string, args: string[], cb: (err: Error | null, result?: { stdout: string }) => void) => {\n624\t          if (cmd === 'which') {\n625\t            cb(null, { stdout: '/usr/local/bin/opencode\\n' });\n626\t          } else if (args[0] === '--version') {\n627\t            cb(null, { stdout: '0.5.0\\n' });\n628\t          } else if (args[0] === 'auth') {\n629\t            cb(new Error('not authenticated'));\n630\t          }\n631\t        },\n632\t      );\n633\t\n634\t      const health = await driver.healthCheck();\n635\t      expect(health.available).toBe(true);\n636\t      expect(health.authenticated).toBe(false);\n637\t    });\n638\t  });\n639\t\n640\t  describe('dispatch — CLI args', () => {\n641\t    it('passes model, cwd, and prompt to spawn', async () => {\n642\t      const { proc } = createMockProcess(\n643\t        ['{\"type\":\"result\",\"cost_usd\":0.01,\"session_id\":\"s\"}'],\n644\t        0,\n645\t      );\n646\t      mockSpawn.mockReturnValue(proc);\n647\t\n648\t      await collectEvents(\n649\t        driver.dispatch(makeOpts({ model: 'gpt-4o', cwd: '/my/project', prompt: 'hello' })),\n650\t      );\n651\t\n652\t      expect(mockSpawn).toHaveBeenCalledWith(\n653\t        'opencode',\n654\t        ['--model', 'gpt-4o', '--cwd', '/my/project', 'hello'],\n655\t        { stdio: ['ignore', 'pipe', 'pipe'] },\n656\t      );\n657\t    });\n658\t  });\n659\t\n660\t  describe('dispatch — exception during readline (catch block)', () => {\n661\t    it('yields result with error when readline throws', async () => {\n662\t      const stdout = new Readable({\n663\t        read() {\n664\t          // Emit an error instead of data to trigger the catch block\n665\t          process.nextTick(() => this.destroy(new Error('stream exploded')));\n666\t        },\n667\t      });\n668\t      const stderr = new EventEmitter();\n669\t      const proc = new EventEmitter() as EventEmitter & {\n670\t        stdout: Readable;\n671\t        stderr: EventEmitter;\n672\t        kill: ReturnType<typeof vi.fn>;\n673\t      };\n674\t      proc.stdout = stdout;\n675\t      proc.stderr = stderr;\n676\t      proc.kill = vi.fn();\n677\t\n678\t      // Need to emit close after the error\n679\t      stdout.on('error', () => {\n680\t        setTimeout(() => proc.emit('close', 1), 5);\n681\t      });\n682\t\n683\t      mockSpawn.mockReturnValue(proc);\n684\t\n685\t      const events = await collectEvents(driver.dispatch(makeOpts()));\n686\t      const resultEvent = events.find((e) => e.type === 'result') as ResultEvent;\n687\t\n688\t      expect(resultEvent).toBeDefined();\n689\t      expect(resultEvent.error).toContain('stream exploded');\n690\t      expect(resultEvent.errorCategory).toBe('UNKNOWN');\n691\t    });\n692\t  });\n693\t\n694\t  describe('dispatch — no model or cwd in opts', () => {\n695\t    it('does not pass --model or --cwd when opts omit them', async () => {\n696\t      const { proc } = createMockProcess(\n697\t        ['{\"type\":\"result\",\"cost_usd\":0.01,\"session_id\":\"s\"}'],\n698\t        0,\n699\t      );\n700\t      mockSpawn.mockReturnValue(proc);\n701\t\n702\t      await collectEvents(\n703\t        driver.dispatch({ prompt: 'hello', model: '', cwd: '', sourceAccess: true }),\n704\t      );\n705\t\n706\t      expect(mockSpawn).toHaveBeenCalledWith(\n707\t        'opencode',\n708\t        ['hello'],\n709\t        { stdio: ['ignore', 'pipe', 'pipe'] },\n710\t      );\n711\t    });\n712\t  });\n713\t\n714\t  describe('barrel export (AC #9)', () => {\n715\t    it('OpenCodeDriver is re-exported from drivers/index.ts', async () => {\n716\t      const mod = await import('../drivers/index.js');\n717\t      expect(mod.OpenCodeDriver).toBe(OpenCodeDriver);\n718\t    });\n719\t  });\n720\t});\n721\t"}]},"parent_tool_use_id":"toolu_01BAKd4fh9zsWfjMmggZc9Jp","session_id":"65932dfc-6881-4906-8881-56eaa8ade510","uuid":"7ae2e226-88f4-44d5-91ec-ea0e416d3ed6","timestamp":"2026-04-03T09:27:09.505Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DyUJbBsyH1ejPxs7FG3fpp","type":"tool_result","content":"1\t/**\n2\t * Barrel file for drivers subsystem.\n3\t * Re-exports all public symbols from the driver factory.\n4\t */\n5\t\n6\texport { getDriver, registerDriver, listDrivers, resetDrivers } from './factory.js';\n7\texport { ClaudeCodeDriver } from './claude-code.js';\n8\texport { CodexDriver } from './codex.js';\n9\texport { OpenCodeDriver } from './opencode.js';\n10\t"}]},"parent_tool_use_id":"toolu_01BAKd4fh9zsWfjMmggZc9Jp","session_id":"65932dfc-6881-4906-8881-56eaa8ade510","uuid":"e20410d3-78e5-4e1a-a631-4a6122930af6","timestamp":"2026-04-03T09:27:09.502Z"}
