{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KJYFLP6DYnu9SArrZ7bmkZ","type":"tool_result","content":"function verificationSummaryBlock(criteria) {\n  const total = criteria.length;\n  const verified = criteria.filter((ac) => ac.verified).length;\n  const failed = total - verified;\n  const status = failed === 0 && total > 0 ? \"PASS\" : \"FAIL\";\n  const lines = [\n    \"## Verification Summary\",\n    \"\",\n    `| Metric | Value |`,\n    `|--------|-------|`,\n    `| Total ACs | ${total} |`,\n    `| Verified | ${verified} |`,\n    `| Failed | ${failed} |`,\n    `| Showboat Verify | ${status} |`\n  ];\n  return lines.join(\"\\n\");\n}\nfunction renderEvidence(evidence) {\n  if (evidence.length === 0) {\n    return \"<!-- No evidence captured yet -->\";\n  }\n  const blocks = [];\n  for (const item of evidence) {\n    if (item.type === \"exec\") {\n      blocks.push(`<!-- showboat exec: ${item.content} -->`);\n      blocks.push(\"```\");\n      blocks.push(\"<!-- output will be captured here -->\");\n      blocks.push(\"```\");\n      blocks.push(\"<!-- /showboat exec -->\");\n    } else if (item.type === \"image\") {\n      const imgPath = item.path ?? item.content;\n      blocks.push(`<!-- showboat image: ${imgPath} -->`);\n    }\n  }\n  return blocks.join(\"\\n\");\n}\nfunction showboatProofTemplate(config) {\n  const sections = [];\n  sections.push(`# Proof: ${config.storyId}`);\n  sections.push(\"\");\n  sections.push(`**Story:** ${config.storyTitle}`);\n  sections.push(`**Generated:** ${(/* @__PURE__ */ new Date()).toISOString().split(\"T\")[0]}`);\n  sections.push(\"\");\n  for (const ac of config.acceptanceCriteria) {\n    const statusIcon = ac.verified ? \"PASS\" : \"PENDING\";\n    sections.push(`## AC ${ac.id}: ${statusIcon}`);\n    sections.push(\"\");\n    sections.push(`> ${ac.description}`);\n    sections.push(\"\");\n    sections.push(renderEvidence(ac.evidence));\n    sections.push(\"\");\n  }\n  if (config.screenshots && config.screenshots.length > 0) {\n    sections.push(\"## Screenshots\");\n    sections.push(\"\");\n    for (const entry of config.screenshots) {\n      sections.push(`- **${entry.label}**: ${entry.path}`);\n    }\n    sections.push(\"\");\n  }\n  sections.push(verificationSummaryBlock(config.acceptanceCriteria));\n  sections.push(\"\");\n  return sections.join(\"\\n\");\n}\n\n// src/modules/verify/orchestrator.ts\nfunction checkPreconditions(dir, storyId) {\n  const state = readState(dir);\n  const failures = [];\n  if (!state.session_flags.tests_passed) {\n    failures.push(\"tests_passed is false \\u2014 run tests first\");\n  }\n  if (!state.session_flags.coverage_met) {\n    failures.push(\"coverage_met is false \\u2014 ensure coverage target is met\");\n  }\n  if (storyId) {\n    try {\n      const docReport = checkStoryDocFreshness(storyId, dir);\n      if (!docReport.passed) {\n        for (const doc of docReport.documents) {\n          if (doc.grade === \"stale\") {\n            failures.push(doc.reason);\n          } else if (doc.grade === \"missing\") {\n            failures.push(doc.reason);\n          }\n        }\n      }\n    } catch {\n      warn(\"Doc health check failed \\u2014 skipping\");\n    }\n  }\n  return {\n    passed: failures.length === 0,\n    failures\n  };\n}\nfunction createProofDocument(storyId, storyTitle, acs, dir) {\n  const root = dir ?? process.cwd();\n  const verificationDir = join15(root, \"verification\");\n  const screenshotsDir = join15(verificationDir, \"screenshots\");\n  mkdirSync6(verificationDir, { recursive: true });\n  mkdirSync6(screenshotsDir, { recursive: true });\n  const criteria = acs.map((ac) => ({\n    id: ac.id,\n    description: ac.description,\n    verified: false,\n    evidence: []\n  }));\n  const content = showboatProofTemplate({\n    storyId,\n    storyTitle,\n    acceptanceCriteria: criteria\n  });\n  const proofPath = join15(verificationDir, `${storyId}-proof.md`);\n  writeFileSync11(proofPath, content, \"utf-8\");\n  return proofPath;\n}\nfunction runShowboatVerify(proofPath) {\n  try {\n    const output = execFileSync7(\"showboat\", [\"verify\", proofPath], {\n      stdio: \"pipe\",\n      timeout: 3e5\n    });\n    return { passed: true, output: output.toString().trim() };\n  } catch (err) {\n    const message = err instanceof Error ? err.message : String(err);\n    if (message.includes(\"ENOENT\") || message.includes(\"not found\")) {\n      return { passed: false, output: \"showboat not available\" };\n    }\n    const stderr = err?.stderr?.toString().trim() ?? \"\";\n    const stdout = err?.stdout?.toString().trim() ?? \"\";\n    return { passed: false, output: stdout || stderr || message };\n  }\n}\nfunction updateVerificationState(storyId, result, dir) {\n  const { state, body } = readStateWithBody(dir);\n  state.session_flags.verification_run = true;\n  const status = result.success ? \"pass\" : \"fail\";\n  const timestamp = (/* @__PURE__ */ new Date()).toISOString();\n  state.verification_log.push(`${storyId}: ${status} at ${timestamp}`);\n  writeState(state, dir, body);\n}\nfunction closeBeadsIssue(storyId, dir) {\n  const root = dir ?? process.cwd();\n  if (!isBeadsInitialized(root)) {\n    warn(\"Beads not initialized \\u2014 skipping issue close\");\n    return;\n  }\n  try {\n    const issues = listIssues();\n    const issue = issues.find((i) => {\n      const desc = i.description ?? \"\";\n      return desc.includes(storyId);\n    });\n    if (!issue) {\n      warn(`No beads issue found for story ${storyId} \\u2014 skipping issue close`);\n      return;\n    }\n    syncClose(issue.id, { closeIssue, listIssues }, root);\n  } catch (err) {\n    const message = err instanceof Error ? err.message : String(err);\n    warn(`Failed to close beads issue: ${message}`);\n  }\n}\n\n// src/modules/verify/parser.ts\nimport { existsSync as existsSync20, readFileSync as readFileSync17 } from \"fs\";\nvar UI_KEYWORDS = [\n  \"agent-browser\",\n  \"screenshot\",\n  \"navigate\",\n  \"click\",\n  \"form\",\n  \"ui verification\",\n  \"ui acceptance\"\n];\nvar API_KEYWORDS = [\n  \"http\",\n  \"api\",\n  \"endpoint\",\n  \"curl\",\n  \"rest\",\n  \"response bod\"\n];\nvar DB_KEYWORDS = [\n  \"database\",\n  \"db state\",\n  \"db mcp\",\n  \"query\",\n  \"sql\",\n  \"table\"\n];\nvar INTEGRATION_KEYWORDS = [\n  \"external system\",\n  \"real infrastructure\",\n  \"manual verification\"\n];\nvar ESCALATE_KEYWORDS = [\n  \"physical hardware\",\n  \"manual human\",","is_error":false}]},"parent_tool_use_id":"toolu_01VHAaHy3MWJn8msLB8wMXYz","session_id":"8712fecb-812b-48fe-bd95-ad6ae808447d","uuid":"c93ebaba-a763-4f47-a74f-24ca8cf64a47","timestamp":"2026-03-20T05:34:28.641Z"}
