{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0189oaRPX4WvUPEdYobWH8rQ","type":"tool_result","content":"1\t/**\n2\t * codeharness stats — Token consumption and cost analysis.\n3\t * Parses session logs to compute API-equivalent costs by phase, story, tool, and token type.\n4\t * Outputs human-readable report and optionally writes JSON for retro consumption.\n5\t *\n6\t * Ralph-specific log paths removed in Story 1.2 — now reads from session-logs/ directory.\n7\t * TODO: v2 workflow-engine (Epic 5) — session log format may change with workflow engine.\n8\t */\n9\t\n10\timport { existsSync, readdirSync, readFileSync, writeFileSync } from 'node:fs';\n11\timport { join } from 'node:path';\n12\timport { Command } from 'commander';\n13\timport { info, ok, fail, jsonOutput } from '../lib/output.js';\n14\t\n15\t// Opus 4.6 pricing per MTok\n16\tconst RATES = {\n17\t  input: 15.0,\n18\t  output: 75.0,\n19\t  cacheRead: 1.50,\n20\t  cacheWrite: 18.75,\n21\t};\n22\t\n23\tinterface TokenBucket {\n24\t  input: number;\n25\t  output: number;\n26\t  cacheRead: number;\n27\t  cacheWrite: number;\n28\t  calls: number;\n29\t}\n30\t\n31\tfunction emptyBucket(): TokenBucket {\n32\t  return { input: 0, output: 0, cacheRead: 0, cacheWrite: 0, calls: 0 };\n33\t}\n34\t\n35\tfunction bucketCost(b: TokenBucket): number {\n36\t  return (b.input * RATES.input + b.output * RATES.output +\n37\t    b.cacheRead * RATES.cacheRead + b.cacheWrite * RATES.cacheWrite) / 1_000_000;\n38\t}\n39\t\n40\tfunction addToBucket(target: TokenBucket, input: number, output: number, cacheRead: number, cacheWrite: number): void {\n41\t  target.input += input;\n42\t  target.output += output;\n43\t  target.cacheRead += cacheRead;\n44\t  target.cacheWrite += cacheWrite;\n45\t  target.calls += 1;\n46\t}\n47\t\n48\tinterface StatsReport {\n49\t  totalCost: number;\n50\t  totalCalls: number;\n51\t  byPhase: Record<string, TokenBucket>;\n52\t  byStory: Record<string, TokenBucket>;\n53\t  byTool: Record<string, TokenBucket>;\n54\t  byDate: Record<string, TokenBucket>;\n55\t  tokenBreakdown: TokenBucket;\n56\t  avgCostPerStory: number;\n57\t  storiesTracked: number;\n58\t}\n59\t\n60\tfunction parseLogFile(filePath: string, report: {\n61\t  byPhase: Map<string, TokenBucket>;\n62\t  byStory: Map<string, TokenBucket>;\n63\t  byTool: Map<string, TokenBucket>;\n64\t  byDate: Map<string, TokenBucket>;\n65\t  messages: Array<{ input: number; output: number; cacheRead: number; cacheWrite: number; phase: string; story: string; tool: string }>;\n66\t}): void {\n67\t  const basename = filePath.split('/').pop() ?? '';\n68\t  const dateMatch = basename.match(/(\\d{4}-\\d{2}-\\d{2})/);\n69\t  const date = dateMatch ? dateMatch[1] : 'unknown';\n70\t\n71\t  let currentPhase = 'orchestrator';\n72\t  let currentStory = 'unknown';\n73\t  let currentTool = '';\n74\t  let msgInput = 0;\n75\t  let msgOutput = 0;\n76\t  let msgCacheRead = 0;\n77\t  let msgCacheWrite = 0;\n78\t\n79\t  const content = readFileSync(filePath, 'utf-8');\n80\t  for (const line of content.split('\\n')) {\n81\t    if (!line.startsWith('{')) continue;\n82\t    let d: Record<string, unknown>;\n83\t    try { d = JSON.parse(line) as Record<string, unknown>; } catch { continue; } // IGNORE: skip malformed JSON lines in logs\n84\t\n85\t    const typ = d.type as string;\n86\t\n87\t    if (typ === 'stream_event') {\n88\t      const evt = d.event as Record<string, unknown> | undefined;\n89\t      if (!evt) continue;\n90\t      const evtType = evt.type as string;\n91\t\n92\t      if (evtType === 'message_start') {\n93\t        // Record previous message\n94\t        if (msgInput + msgOutput + msgCacheRead + msgCacheWrite > 0) {\n95\t          report.messages.push({ input: msgInput, output: msgOutput, cacheRead: msgCacheRead, cacheWrite: msgCacheWrite, phase: currentPhase, story: currentStory, tool: currentTool });\n96\t        }\n97\t        const usage = ((evt.message as Record<string, unknown>)?.usage ?? {}) as Record<string, number>;\n98\t        msgInput = usage.input_tokens ?? 0;\n99\t        msgCacheRead = usage.cache_read_input_tokens ?? 0;\n100\t        msgCacheWrite = usage.cache_creation_input_tokens ?? 0;\n101\t        msgOutput = 0;\n102\t      } else if (evtType === 'message_delta') {\n103\t        const usage = (evt.usage ?? {}) as Record<string, number>;\n104\t        msgOutput += usage.output_tokens ?? 0;\n105\t      } else if (evtType === 'content_block_start') {\n106\t        const cb = evt.content_block as Record<string, unknown> | undefined;\n107\t        if (cb?.type === 'tool_use') currentTool = (cb.name as string) ?? '';\n108\t      } else if (evtType === 'content_block_delta') {\n109\t        const text = ((evt.delta as Record<string, unknown>)?.text as string) ?? '';\n110\t        // Detect phase from harness-run text output\n111\t        if (text.includes('Step 3a') || text.toLowerCase().includes('create-story')) currentPhase = 'create-story';\n112\t        else if (text.includes('Step 3b') || text.toLowerCase().includes('dev-story')) currentPhase = 'dev-story';\n113\t        else if (text.includes('Step 3c') || text.toLowerCase().includes('code-review') || text.toLowerCase().includes('code review')) currentPhase = 'code-review';\n114\t        else if (text.includes('Step 3d') || text.toLowerCase().includes('verif')) currentPhase = 'verify';\n115\t        else if (text.includes('Step 8') || text.toLowerCase().includes('retro')) currentPhase = 'retro';\n116\t        // Detect story\n117\t        const sm = text.match(/(\\d+-\\d+-[a-z][\\w-]*)/);\n118\t        if (sm) currentStory = sm[1];\n119\t      }\n120\t    }\n121\t\n122\t    // Detect phase from subagent descriptions\n123\t    if (typ === 'system' && (d.subtype as string) === 'task_started') {\n124\t      const desc = ((d.description as string) ?? '').toLowerCase();\n125\t      if (desc.includes('code review') || desc.includes('code-review')) currentPhase = 'code-review';\n126\t      else if (desc.includes('dev-story') || desc.includes('dev story') || desc.includes('implement')) currentPhase = 'dev-story';\n127\t      else if (desc.includes('create-story') || desc.includes('create story')) currentPhase = 'create-story';\n128\t      else if (desc.includes('verif')) currentPhase = 'verify';\n129\t      else if (desc.includes('retro')) currentPhase = 'retro';\n130\t    }\n131\t  }\n132\t\n133\t  // Record last message\n134\t  if (msgInput + msgOutput + msgCacheRead + msgCacheWrite > 0) {\n135\t    report.messages.push({ input: msgInput, output: msgOutput, cacheRead: msgCacheRead, cacheWrite: msgCacheWrite, phase: currentPhase, story: currentStory, tool: currentTool });\n136\t  }\n137\t}\n138\t\n139\tfunction generateReport(projectDir: string, logsDir?: string): StatsReport {\n140\t  const resolvedLogsDir = logsDir ?? join(projectDir, 'session-logs');\n141\t  const logFiles = readdirSync(resolvedLogsDir)\n142\t    .filter(f => f.endsWith('.log'))\n143\t    .sort()\n144\t    .map(f => join(resolvedLogsDir, f));\n145\t\n146\t  const report = {\n147\t    byPhase: new Map<string, TokenBucket>(),\n148\t    byStory: new Map<string, TokenBucket>(),\n149\t    byTool: new Map<string, TokenBucket>(),\n150\t    byDate: new Map<string, TokenBucket>(),\n151\t    messages: [] as Array<{ input: number; output: number; cacheRead: number; cacheWrite: number; phase: string; story: string; tool: string }>,\n152\t  };\n153\t\n154\t  for (const logFile of logFiles) {\n155\t    parseLogFile(logFile, report);\n156\t  }\n157\t\n158\t  // Aggregate messages into buckets\n159\t  const byPhase: Record<string, TokenBucket> = {};\n160\t  const byStory: Record<string, TokenBucket> = {};\n161\t  const byTool: Record<string, TokenBucket> = {};\n162\t  const total = emptyBucket();\n163\t\n164\t  for (const msg of report.messages) {\n165\t    if (!byPhase[msg.phase]) byPhase[msg.phase] = emptyBucket();\n166\t    addToBucket(byPhase[msg.phase], msg.input, msg.output, msg.cacheRead, msg.cacheWrite);\n167\t    if (!byStory[msg.story]) byStory[msg.story] = emptyBucket();\n168\t    addToBucket(byStory[msg.story], msg.input, msg.output, msg.cacheRead, msg.cacheWrite);\n169\t    if (msg.tool) {\n170\t      if (!byTool[msg.tool]) byTool[msg.tool] = emptyBucket();\n171\t      addToBucket(byTool[msg.tool], msg.input, msg.output, msg.cacheRead, msg.cacheWrite);\n172\t    }\n173\t    addToBucket(total, msg.input, msg.output, msg.cacheRead, msg.cacheWrite);\n174\t  }\n175\t\n176\t  const storyKeys = Object.keys(byStory).filter(k => /^\\d+-\\d+-/.test(k));\n177\t  const totalCost = bucketCost(total);\n178\t  const avgCostPerStory = storyKeys.length > 0\n179\t    ? storyKeys.reduce((sum, k) => sum + bucketCost(byStory[k]), 0) / storyKeys.length\n180\t    : 0;\n181\t\n182\t  return {\n183\t    totalCost,\n184\t    totalCalls: report.messages.length,\n185\t    byPhase,\n186\t    byStory,\n187\t    byTool,\n188\t    byDate: {},\n189\t    tokenBreakdown: total,\n190\t    avgCostPerStory,\n191\t    storiesTracked: storyKeys.length,\n192\t  };\n193\t}\n194\t\n195\tfunction formatReport(report: StatsReport): string {\n196\t  const lines: string[] = [];\n197\t  lines.push('# Harness Cost Report');\n198\t  lines.push('');\n199\t  lines.push(`Total API-equivalent cost: $${report.totalCost.toFixed(2)}`);\n200\t  lines.push(`Total API calls: ${report.totalCalls}`);\n201\t  lines.push(`Average cost per story: $${report.avgCostPerStory.toFixed(2)} (${report.storiesTracked} stories)`);\n202\t  lines.push('');\n203\t\n204\t  // Token type breakdown\n205\t  const tb = report.tokenBreakdown;\n206\t  lines.push('## Cost by Token Type');\n207\t  lines.push('');\n208\t  lines.push(`| Type | Tokens | Rate | Cost | % |`);\n209\t  lines.push(`|------|--------|------|------|---|`);\n210\t  const crCost = tb.cacheRead * RATES.cacheRead / 1e6;\n211\t  const cwCost = tb.cacheWrite * RATES.cacheWrite / 1e6;\n212\t  const outCost = tb.output * RATES.output / 1e6;\n213\t  const inpCost = tb.input * RATES.input / 1e6;\n214\t  lines.push(`| Cache reads | ${tb.cacheRead.toLocaleString()} | $1.50/MTok | $${crCost.toFixed(2)} | ${(crCost / report.totalCost * 100).toFixed(0)}% |`);\n215\t  lines.push(`| Cache writes | ${tb.cacheWrite.toLocaleString()} | $18.75/MTok | $${cwCost.toFixed(2)} | ${(cwCost / report.totalCost * 100).toFixed(0)}% |`);\n216\t  lines.push(`| Output | ${tb.output.toLocaleString()} | $75/MTok | $${outCost.toFixed(2)} | ${(outCost / report.totalCost * 100).toFixed(0)}% |`);\n217\t  lines.push(`| Input | ${tb.input.toLocaleString()} | $15/MTok | $${inpCost.toFixed(2)} | ${(inpCost / report.totalCost * 100).toFixed(0)}% |`);\n218\t  lines.push('');\n219\t\n220\t  // By phase\n221\t  lines.push('## Cost by Phase');\n222\t  lines.push('');\n223\t  lines.push(`| Phase | Calls | Cost | % |`);\n224\t  lines.push(`|-------|-------|------|---|`);\n225\t  const sortedPhases = Object.entries(report.byPhase).sort((a, b) => bucketCost(b[1]) - bucketCost(a[1]));\n226\t  for (const [phase, bucket] of sortedPhases) {\n227\t    const c = bucketCost(bucket);\n228\t    lines.push(`| ${phase} | ${bucket.calls} | $${c.toFixed(2)} | ${(c / report.totalCost * 100).toFixed(1)}% |`);\n229\t  }\n230\t  lines.push('');\n231\t\n232\t  // By tool\n233\t  lines.push('## Cost by Tool');\n234\t  lines.push('');\n235\t  lines.push(`| Tool | Calls | Cost | % |`);\n236\t  lines.push(`|------|-------|------|---|`);\n237\t  const sortedTools = Object.entries(report.byTool).sort((a, b) => bucketCost(b[1]) - bucketCost(a[1]));\n238\t  for (const [tool, bucket] of sortedTools.slice(0, 10)) {\n239\t    const c = bucketCost(bucket);\n240\t    lines.push(`| ${tool} | ${bucket.calls} | $${c.toFixed(2)} | ${(c / report.totalCost * 100).toFixed(1)}% |`);\n241\t  }\n242\t  lines.push('');\n243\t\n244\t  // Top stories\n245\t  lines.push('## Top 10 Most Expensive Stories');\n246\t  lines.push('');\n247\t  lines.push(`| Story | Calls | Cost | % |`);\n248\t  lines.push(`|-------|-------|------|---|`);\n249\t  const sortedStories = Object.entries(report.byStory).sort((a, b) => bucketCost(b[1]) - bucketCost(a[1]));\n250\t  for (const [story, bucket] of sortedStories.slice(0, 10)) {\n251\t    const c = bucketCost(bucket);\n252\t    lines.push(`| ${story} | ${bucket.calls} | $${c.toFixed(2)} | ${(c / report.totalCost * 100).toFixed(1)}% |`);\n253\t  }\n254\t\n255\t  return lines.join('\\n');\n256\t}\n257\t\n258\texport function registerStatsCommand(program: Command): void {\n259\t  program\n260\t    .command('stats')\n261\t    .description('Analyze token consumption and cost from session logs')\n262\t    .option('--save', 'Save report to _bmad-output/implementation-artifacts/cost-report.md')\n263\t    .option('--logs-dir <path>', 'Path to session logs directory', 'session-logs')\n264\t    .action((options, cmd) => {\n265\t      const globalOpts = cmd.optsWithGlobals();\n266\t      const isJson = !!globalOpts.json;\n267\t      const projectDir = process.cwd();\n268\t      const logsDir = join(projectDir, options.logsDir as string);\n269\t\n270\t      if (!existsSync(logsDir)) {\n271\t        fail(`No ${options.logsDir as string}/ directory found — run codeharness run first`);\n272\t        process.exitCode = 1;\n273\t        return;\n274\t      }\n275\t\n276\t      const report = generateReport(projectDir, logsDir);\n277\t\n278\t      if (isJson) {\n279\t        jsonOutput(report as unknown as Record<string, unknown>);\n280\t        return;\n281\t      }\n282\t\n283\t      const formatted = formatReport(report);\n284\t      console.log(formatted);\n285\t\n286\t      if (options.save) {\n287\t        const outPath = join(projectDir, '_bmad-output', 'implementation-artifacts', 'cost-report.md');\n288\t        writeFileSync(outPath, formatted, 'utf-8');\n289\t        ok(`Report saved to ${outPath}`);\n290\t      }\n291\t    });\n292\t}\n293\t"}]},"parent_tool_use_id":"toolu_0188XVEoVFKE3hey9xp8FV9P","session_id":"cf16e575-8267-4c58-a992-20b07458710f","uuid":"0bc6ffbe-e232-4274-8b42-1f0d3da3fb8e","timestamp":"2026-04-03T13:20:49.285Z"}
