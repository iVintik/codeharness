{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Kpr6a8id44psZh5nfACEij","type":"tool_result","content":"150\t// --- Tests ---\n151\t\n152\tdescribe('checkDriverHealth', () => {\n153\t  beforeEach(() => {\n154\t    vi.clearAllMocks();\n155\t  });\n156\t\n157\t  it('succeeds when a single driver passes health check', async () => {\n158\t    const workflow: ResolvedWorkflow = {\n159\t      tasks: { implement: makeTask({ driver: 'claude-code' }) },\n160\t      flow: ['implement'],\n161\t    };\n162\t\n163\t    const driver = makeMockDriver('claude-code', makeHealthy());\n164\t    mockGetDriver.mockReturnValue(driver);\n165\t\n166\t    await expect(checkDriverHealth(workflow)).resolves.toBeUndefined();\n167\t    expect(driver.healthCheck).toHaveBeenCalledOnce();\n168\t  });\n169\t\n170\t  it('succeeds when multiple unique drivers all pass', async () => {\n171\t    const workflow: ResolvedWorkflow = {\n172\t      tasks: {\n173\t        implement: makeTask({ driver: 'claude-code' }),\n174\t        codexTask: makeTask({ driver: 'codex' }),\n175\t      },\n176\t      flow: ['implement', 'codexTask'],\n177\t    };\n178\t\n179\t    const claudeDriver = makeMockDriver('claude-code', makeHealthy());\n180\t    const codexDriver = makeMockDriver('codex', makeHealthy());\n181\t    mockGetDriver.mockImplementation((name: string) => {\n182\t      if (name === 'claude-code') return claudeDriver;\n183\t      if (name === 'codex') return codexDriver;\n184\t      throw new Error(`Unknown driver: ${name}`);\n185\t    });\n186\t\n187\t    await expect(checkDriverHealth(workflow)).resolves.toBeUndefined();\n188\t    expect(claudeDriver.healthCheck).toHaveBeenCalledOnce();\n189\t    expect(codexDriver.healthCheck).toHaveBeenCalledOnce();\n190\t  });\n191\t\n192\t  it('deduplicates drivers — healthCheck called once per unique driver', async () => {\n193\t    const workflow: ResolvedWorkflow = {\n194\t      tasks: {\n195\t        task1: makeTask({ driver: 'claude-cod