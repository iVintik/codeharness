Changed: false } })),\n40\t    isDockerAvailableMock: vi.fn(() => true),\n41\t    cleanupContainersMock: vi.fn((): { success: boolean; data?: { containersRemoved: number; names: string[] }; error?: string } => ({ success: true, data: { containersRemoved: 0, names: [] } })),\n42\t    parseWorkflowMock: vi.fn(() => ({\n43\t      tasks: {\n44\t        implement: { agent: 'dev', scope: 'per-story', session: 'fresh', source_access: true },\n45\t      },\n46\t      flow: ['implement'],\n47\t    })),\n48\t    resolveWorkflowMock: vi.fn(() => ({\n49\t      tasks: {\n50\t        implement: { agent: 'dev', scope: 'per-story', session: 'fresh', source_access: true },\n51\t      },\n52\t      flow: ['implement'],\n53\t    })),\n54\t    resolveAgentMock: vi.fn(() => ({\n55\t      name: 'dev',\n56\t      role: { title: 'Developer', purpose: 'Implement code' },\n57\t      persona: { identity: 'A developer', communication_style: 'direct', principles: [] },\n58\t    })),\n59\t    compileSubagentMock: vi.fn(() => ({\n60\t      name: 'dev',\n61\t      model: 'claude-sonnet-4-20250514',\n62\t      instructions: 'You are a developer',\n63\t      disallowedTools: [],\n64\t      bare: true,\n65\t    })),\n66\t    executeWorkflowMock: vi.fn(async () => ({\n67\t      success: true,\n68\t      tasksCompleted: 3,\n69\t      storiesProcessed: 1,\n70\t      errors: [],\n71\t      durationMs: 60000,\n72\t    })),\n73\t    readWorkflowStateMock: vi.fn(() => ({\n74\t      workflow_name: '',\n75\t      started: '',\n76\t      iteration: 0,\n77\t      phase: 'idle',\n78\t      tasks_completed: [],\n79\t      evaluator_scores: [],\n80\t      circuit_breaker: { triggered: false, reason: null, score_history: [] },\n81\t      trace_ids: [],\n82\t    })),\n83\t    writeWorkflowStateMock: vi.fn(),\n84\t  };\n85\t});\n86\t\n87\tvi.mock('../../lib/agents/index.js', () => ({\n88\t  getDriver: (...args: unknown[]) => getDriverMock(...(args as Parameters<typeof getDriverMock>)),\n89\t}));\n90\t\n91\tvi.mock('n