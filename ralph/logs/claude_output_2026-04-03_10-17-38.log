{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MDSqEVEsVz8YjLquUdwkRW","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { Readable } from 'node:stream';\n3\timport type {\n4\t  AgentDriver,\n5\t  AgentProcess,\n6\t  AgentEvent,\n7\t  SpawnOpts,\n8\t} from '../types.js';\n9\timport type {\n10\t  AgentDriver as BarrelAgentDriver,\n11\t  AgentProcess as BarrelAgentProcess,\n12\t  AgentEvent as BarrelAgentEvent,\n13\t  SpawnOpts as BarrelSpawnOpts,\n14\t} from '../index.js';\n15\t\n16\t/** Creates a minimal mock AgentProcess for testing. */\n17\tfunction createMockProcess(): AgentProcess {\n18\t  const handlers: Record<string, Function> = {};\n19\t  return {\n20\t    stdout: new Readable({ read() {} }),\n21\t    stderr: new Readable({ read() {} }),\n22\t    on(event: string, handler: Function) {\n23\t      handlers[event] = handler;\n24\t    },\n25\t    kill() {},\n26\t  };\n27\t}\n28\t\n29\tdescribe('agents/types exports', () => {\n30\t  describe('SpawnOpts', () => {\n31\t    it('defines required fields: storyKey, prompt, workDir, timeout', () => {\n32\t      const opts: SpawnOpts = {\n33\t        storyKey: '13-1-agent-driver',\n34\t        prompt: 'implement the story',\n35\t        workDir: '/tmp/work',\n36\t        timeout: 60000,\n37\t      };\n38\t      expect(opts.storyKey).toBe('13-1-agent-driver');\n39\t      expect(opts.prompt).toBe('implement the story');\n40\t      expect(opts.workDir).toBe('/tmp/work');\n41\t      expect(opts.timeout).toBe(60000);\n42\t    });\n43\t\n44\t    it('accepts optional env field', () => {\n45\t      const opts: SpawnOpts = {\n46\t        storyKey: 'x',\n47\t        prompt: 'p',\n48\t        workDir: '/w',\n49\t        timeout: 1000,\n50\t        env: { FOO: 'bar' },\n51\t      };\n52\t      expect(opts.env).toEqual({ FOO: 'bar' });\n53\t    });\n54\t\n55\t    it('allows env to be undefined', () => {\n56\t      const opts: SpawnOpts = {\n57\t        storyKey: 'x',\n58\t        prompt: 'p',\n59\t        workDir: '/w',\n60\t        timeout: 1000,\n61\t      };\n62\t      expect(opts.env).toBeUndefined();\n63\t    });\n64\t  });\n65\t\n66\t  describe('AgentProcess', () => {\n67\t    it('satisfies interface with mock implementation', () => {\n68\t      const proc = createMockProcess();\n69\t      expect(proc.stdout).toBeDefined();\n70\t      expect(proc.stderr).toBeDefined();\n71\t      expect(typeof proc.on).toBe('function');\n72\t      expect(typeof proc.kill).toBe('function');\n73\t    });\n74\t\n75\t    it('supports on close handler', () => {\n76\t      const proc = createMockProcess();\n77\t      let closeCalled = false;\n78\t      proc.on('close', (_code: number) => {\n79\t        closeCalled = true;\n80\t      });\n81\t      // Type-level: this compiles, proving the overload exists\n82\t      expect(closeCalled).toBe(false);\n83\t    });\n84\t\n85\t    it('supports on error handler', () => {\n86\t      const proc = createMockProcess();\n87\t      let errorCalled = false;\n88\t      proc.on('error', (_err: Error) => {\n89\t        errorCalled = true;\n90\t      });\n91\t      // Type-level: this compiles, proving the error overload exists\n92\t      expect(errorCalled).toBe(false);\n93\t    });\n94\t\n95\t    it('kill accepts optional signal', () => {\n96\t      const proc = createMockProcess();\n97\t      // No-arg call\n98\t      proc.kill();\n99\t      // With signal\n100\t      proc.kill('SIGTERM');\n101\t      expect(typeof proc.kill).toBe('function');\n102\t    });\n103\t  });\n104\t\n105\t  describe('AgentEvent discriminated union', () => {\n106\t    const ALL_EVENT_TYPES = [\n107\t      'tool-start',\n108\t      'tool-complete',\n109\t      'text',\n110\t      'story-complete',\n111\t      'story-failed',\n112\t      'iteration',\n113\t      'retry',\n114\t      'result',\n115\t    ] as const;\n116\t\n117\t    it('covers all 8 event types', () => {\n118\t      expect(ALL_EVENT_TYPES).toHaveLength(8);\n119\t    });\n120\t\n121\t    it('accepts tool-start event', () => {\n122\t      const event: AgentEvent = { type: 'tool-start', name: 'Read' };\n123\t      expect(event.type).toBe('tool-start');\n124\t    });\n125\t\n126\t    it('accepts tool-complete event', () => {\n127\t      const event: AgentEvent = {\n128\t        type: 'tool-complete',\n129\t        name: 'Write',\n130\t        args: '{\"path\": \"/tmp/f\"}',\n131\t      };\n132\t      expect(event.type).toBe('tool-complete');\n133\t    });\n134\t\n135\t    it('accepts text event', () => {\n136\t      const event: AgentEvent = { type: 'text', text: 'hello' };\n137\t      expect(event.type).toBe('text');\n138\t    });\n139\t\n140\t    it('accepts story-complete event', () => {\n141\t      const event: AgentEvent = {\n142\t        type: 'story-complete',\n143\t        key: '13-1',\n144\t        details: 'done',\n145\t      };\n146\t      expect(event.type).toBe('story-complete');\n147\t    });\n148\t\n149\t    it('accepts story-failed event', () => {\n150\t      const event: AgentEvent = {\n151\t        type: 'story-failed',\n152\t        key: '13-1',\n153\t        reason: 'timeout',\n154\t      };\n155\t      expect(event.type).toBe('story-failed');\n156\t    });\n157\t\n158\t    it('accepts iteration event', () => {\n159\t      const event: AgentEvent = { type: 'iteration', count: 3 };\n160\t      expect(event.type).toBe('iteration');\n161\t    });\n162\t\n163\t    it('accepts retry event', () => {\n164\t      const event: AgentEvent = { type: 'retry', attempt: 2, delay: 5000 };\n165\t      expect(event.type).toBe('retry');\n166\t    });\n167\t\n168\t    it('accepts result event', () => {\n169\t      const event: AgentEvent = {\n170\t        type: 'result',\n171\t        cost: 0.42,\n172\t        sessionId: 'abc-123',\n173\t      };\n174\t      expect(event.type).toBe('result');\n175\t    });\n176\t\n177\t    it('narrows type correctly via discriminant', () => {\n178\t      const event: AgentEvent = { type: 'retry', attempt: 1, delay: 2000 };\n179\t      if (event.type === 'retry') {\n180\t        // TypeScript narrows to { type: 'retry'; attempt: number; delay: number }\n181\t        expect(event.attempt).toBe(1);\n182\t        expect(event.delay).toBe(2000);\n183\t      }\n184\t    });\n185\t\n186\t    it('covers every event type with a valid instance', () => {\n187\t      const events: AgentEvent[] = [\n188\t        { type: 'tool-start', name: 'a' },\n189\t        { type: 'tool-complete', name: 'b', args: 'c' },\n190\t        { type: 'text', text: 'd' },\n191\t        { type: 'story-complete', key: 'e', details: 'f' },\n192\t        { type: 'story-failed', key: 'g', reason: 'h' },\n193\t        { type: 'iteration', count: 1 },\n194\t        { type: 'retry', attempt: 1, delay: 1 },\n195\t        { type: 'result', cost: 0, sessionId: 'i' },\n196\t      ];\n197\t      const types = events.map((e) => e.type);\n198\t      expect(types).toEqual([...ALL_EVENT_TYPES]);\n199\t    });\n200\t  });\n201\t\n202\t  describe('AgentDriver interface', () => {\n203\t    it('satisfies interface with mock implementation', () => {\n204\t      const driver: AgentDriver = {\n205\t        name: 'test-driver',\n206\t        spawn(_opts: SpawnOpts): AgentProcess {\n207\t          return createMockProcess();\n208\t        },\n209\t        parseOutput(_line: string): AgentEvent | null {\n210\t          return null;\n211\t        },\n212\t        getStatusFile(): string {\n213\t          return '/tmp/status.json';\n214\t        },\n215\t      };\n216\t      expect(driver.name).toBe('test-driver');\n217\t      expect(typeof driver.spawn).toBe('function');\n218\t      expect(typeof driver.parseOutput).toBe('function');\n219\t      expect(typeof driver.getStatusFile).toBe('function');\n220\t    });\n221\t\n222\t    it('has readonly name property', () => {\n223\t      const driver: AgentDriver = {\n224\t        name: 'immutable',\n225\t        spawn: () => createMockProcess(),\n226\t        parseOutput: () => null,\n227\t        getStatusFile: () => '',\n228\t      };\n229\t      // TypeScript enforces readonly at compile time; runtime check that value exists\n230\t      expect(driver.name).toBe('immutable');\n231\t    });\n232\t\n233\t    it('parseOutput can return null for unrecognized lines', () => {\n234\t      const driver: AgentDriver = {\n235\t        name: 'null-parser',\n236\t        spawn: () => createMockProcess(),\n237\t        parseOutput: () => null,\n238\t        getStatusFile: () => '',\n239\t      };\n240\t      expect(driver.parseOutput('random garbage')).toBeNull();\n241\t    });\n242\t\n243\t    it('parseOutput can return a typed AgentEvent', () => {\n244\t      const prefix = 'TEXT: ';\n245\t      const driver: AgentDriver = {\n246\t        name: 'event-parser',\n247\t        spawn: () => createMockProcess(),\n248\t        parseOutput: (line: string) => {\n249\t          if (line.startsWith(prefix)) {\n250\t            return { type: 'text', text: line.slice(prefix.length) };\n251\t          }\n252\t          return null;\n253\t        },\n254\t        getStatusFile: () => '/tmp/status.json',\n255\t      };\n256\t      const event = driver.parseOutput('TEXT: hello');\n257\t      expect(event).toEqual({ type: 'text', text: 'hello' });\n258\t      expect(driver.parseOutput('unknown')).toBeNull();\n259\t    });\n260\t  });\n261\t\n262\t  describe('barrel re-exports from index.ts', () => {\n263\t    it('re-exports all types from types.ts', () => {\n264\t      // Type-level test: if these imports compile, the barrel re-exports work.\n265\t      // Use the barrel-imported types to construct values, proving they are the same types.\n266\t      const opts: BarrelSpawnOpts = {\n267\t        storyKey: 'barrel-test',\n268\t        prompt: 'p',\n269\t        workDir: '/w',\n270\t        timeout: 1000,\n271\t      };\n272\t      const proc: BarrelAgentProcess = createMockProcess();\n273\t      const event: BarrelAgentEvent = { type: 'text', text: 'barrel' };\n274\t      const driver: BarrelAgentDriver = {\n275\t        name: 'barrel-driver',\n276\t        spawn: () => proc,\n277\t        parseOutput: () => event,\n278\t        getStatusFile: () => '',\n279\t      };\n280\t\n281\t      // Runtime assertions prove the barrel types are usable\n282\t      expect(opts.storyKey).toBe('barrel-test');\n283\t      expect(proc.stdout).toBeDefined();\n284\t      expect(event.type).toBe('text');\n285\t      expect(driver.name).toBe('barrel-driver');\n286\t    });\n287\t  });\n288\t});\n289\t"}]},"parent_tool_use_id":"toolu_01XS4sVgQGUVdaHQcMbvghrp","session_id":"e499f49a-fe4c-4b28-bb21-4e83348f2671","uuid":"b1d78280-d7fa-4073-be48-e4e9244831f4","timestamp":"2026-04-03T06:19:21.679Z"}
