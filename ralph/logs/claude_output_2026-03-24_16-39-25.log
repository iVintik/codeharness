tContaining({ cwd: testDir }),\n   390→    );\n   391→  });\n   392→\n   393→  it('creates otel-web-init.js snippet with endpoint from state', () => {\n   394→    initStateWithOtlp('nodejs');\n   395→    mockExecFileSync.mockReturnValue(Buffer.from(''));\n   396→\n   397→    configureWeb(testDir, 'nodejs');\n   398→\n   399→    expect(existsSync(join(testDir, 'otel-web-init.js'))).toBe(true);\n   400→    const content = readFileSync(join(testDir, 'otel-web-init.js'), 'utf-8');\n   401→    expect(content).toContain('WebTracerProvider');\n   402→    expect(content).toContain('FetchInstrumentation');\n   403→    expect(content).toContain('http://localhost:4318/v1/traces');\n   404→  });\n   405→\n   406→  it('uses custom endpoint from state in web snippet', () => {\n   407→    const state = getDefaultState('nodejs');\n   408→    state.initialized = true;\n   409→    state.otlp = {\n   410→      enabled: true,\n   411→      endpoint: 'https://otel.company.com:4318',\n   412→      service_name: 'test-project',\n   413→      mode: 'remote-direct',\n   414→    };\n   415→    writeState(state, testDir);\n   416→    mockExecFileSync.mockReturnValue(Buffer.from(''));\n   417→\n   418→    configureWeb(testDir, 'nodejs');\n   419→\n   420→    const content = readFileSync(join(testDir, 'otel-web-init.js'), 'utf-8');\n   421→    expect(content).toContain('https://otel.company.com:4318/v1/traces');\n   422→    expect(content).not.toContain('localhost');\n   423→  });\n   424→\n   425→  it('sets web_snippet_path in state', () => {\n   426→    initStateWithOtlp('nodejs');\n   427→    mockExecFileSync.mockReturnValue(Buffer.from(''));\n   428→\n   429→    configureWeb(testDir, 'nodejs');\n   430→\n   431→    const state = readState(testDir);\n   432→    expect(state.otlp!.web_snippet_path).toBe('otel-web-init.js');\n   433→  });\n   434→\n   435→  it('does not fail when npm install fails for web packages', () => {\n   436→    initStateWithOtlp('nodejs');\n   437→    mockExecFileSync.