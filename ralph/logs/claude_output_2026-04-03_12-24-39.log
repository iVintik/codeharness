/agent')).toBe(true);\n1300\t      }\n1301\t    });\n1302\t\n1303\t    it('combines flow-ref and driver/agent errors in a single throw (AC #7)', () => {\n1304\t      registerDriver(mockDriver('claude-code'));\n1305\t\n1306\t      const yaml = `\n1307\ttasks:\n1308\t  implement:\n1309\t    agent: fake-agent\n1310\t    driver: bad-driver\n1311\tflow:\n1312\t  - implement\n1313\t  - nonexistent-task\n1314\t`;\n1315\t      const filePath = writeYaml('combined-errors.yaml', yaml);\n1316\t\n1317\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n1318\t      try {\n1319\t        parseWorkflow(filePath);\n1320\t      } catch (err) {\n1321\t        const pe = err as WorkflowParseError;\n1322\t        // Flow dangling ref\n1323\t        expect(pe.errors.some((e) => e.path === '/flow/1' && e.message.includes('nonexistent-task'))).toBe(true);\n1324\t        // Driver ref\n1325\t        expect(pe.errors.some((e) => e.path === '/tasks/implement/driver' && e.message.includes('bad-driver'))).toBe(true);\n1326\t        // Agent ref\n1327\t        expect(pe.errors.some((e) => e.path === '/tasks/implement/agent' && e.message.includes('fake-agent'))).toBe(true);\n1328\t      }\n1329\t    });\n1330\t  });\n1331\t\n1332\t  describe('absent fields skip validation (AC #5)', () => {\n1333\t    it('workflow with no driver field on any task passes (AC #5)', () => {\n1334\t      const yaml = `\n1335\ttasks:\n1336\t  implement:\n1337\t    agent: dev\n1338\t  verify:\n1339\t    agent: evaluator\n1340\tflow:\n1341\t  - implement\n1342\t  - verify\n1343\t`;\n1344\t      const filePath = writeYaml('no-driver.yaml', yaml);\n1345\t      const result = parseWorkflow(filePath);\n1346\t      expect(result.tasks.implement.driver).toBeUndefined();\n1347\t      expect(result.tasks.verify.driver).toBeUndefined();\n1348\t    });\n1349\t  });\n1350\t\n1351\t  describe('backward compatibility (AC #9)', () => {\n1352\t    it('existing minimal workflow still parses without errors', () => 