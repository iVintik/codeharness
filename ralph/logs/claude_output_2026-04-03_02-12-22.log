{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01JYmLFvrG748bUgFAwPmgcH","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01FmZqtsBXPdmB5bDU8YEXG2","name":"Read","input":{"file_path":"/Users/ivintik/dev/personal/codeharness/src/lib/workflow-engine.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":8389,"cache_read_input_tokens":22153,"cache_creation":{"ephemeral_5m_input_tokens":8389,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_013UbHyVXQj1k3dWQ4gFNapF","session_id":"7447df8e-50f4-441a-b8fe-e85605fee72e","uuid":"d8abbc9f-39a7-49e5-86d8-af1f0b7151e0"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FmZqtsBXPdmB5bDU8YEXG2","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { parse } from 'yaml';\n3\timport { warn } from './output.js';\n4\timport { dispatchAgent, DispatchError } from './agent-dispatch.js';\n5\timport type { DispatchOptions, DispatchResult } from './agent-dispatch.js';\n6\timport type { SubagentDefinition } from './agent-resolver.js';\n7\timport type { ResolvedWorkflow, ResolvedTask, FlowStep, LoopBlock } from './workflow-parser.js';\n8\timport {\n9\t  readWorkflowState,\n10\t  writeWorkflowState,\n11\t} from './workflow-state.js';\n12\timport type { WorkflowState, TaskCheckpoint } from './workflow-state.js';\n13\timport { createIsolatedWorkspace } from './source-isolation.js';\n14\timport { generateTraceId, formatTracePrompt, recordTraceId } from './trace-id.js';\n15\timport { resolveSessionId, recordSessionId } from './session-manager.js';\n16\timport type { SessionLookupKey } from './session-manager.js';\n17\t\n18\t// --- Interfaces ---\n19\t\n20\t/**\n21\t * Configuration for the workflow engine.\n22\t */\n23\texport interface EngineConfig {\n24\t  /** The resolved workflow with tasks and flow steps. */\n25\t  workflow: ResolvedWorkflow;\n26\t  /** Pre-compiled agent definitions keyed by agent name. */\n27\t  agents: Record<string, SubagentDefinition>;\n28\t  /** Path to sprint-status.yaml for work item discovery. */\n29\t  sprintStatusPath: string;\n30\t  /** Optional path to issues.yaml for additional work items. */\n31\t  issuesPath?: string;\n32\t  /** Unique identifier for this engine run. */\n33\t  runId: string;\n34\t  /** Project root directory. Defaults to process.cwd(). */\n35\t  projectDir?: string;\n36\t}\n37\t\n38\t/**\n39\t * Result returned by executeWorkflow().\n40\t */\n41\texport interface EngineResult {\n42\t  /** Whether the workflow completed without errors. */\n43\t  success: boolean;\n44\t  /** Number of task dispatches completed. */\n45\t  tasksCompleted: number;\n46\t  /** Number of work items (stories/issues) processed. */\n47\t  storiesProcessed: number;\n48\t  /** Errors encountered during execution. */\n49\t  errors: EngineError[];\n50\t  /** Wall-clock duration of the entire workflow in milliseconds. */\n51\t  durationMs: number;\n52\t}\n53\t\n54\t/**\n55\t * Structured error recorded during workflow execution.\n56\t */\n57\texport interface EngineError {\n58\t  taskName: string;\n59\t  storyKey: string;\n60\t  code: string;\n61\t  message: string;\n62\t}\n63\t\n64\t/**\n65\t * A work item (story or issue) ready for execution.\n66\t */\n67\texport interface WorkItem {\n68\t  key: string;\n69\t  title?: string;\n70\t  source: 'sprint' | 'issues';\n71\t}\n72\t\n73\t// --- Constants ---\n74\t\n75\t/** Sentinel story key for per-run tasks. */\n76\tconst PER_RUN_SENTINEL = '__run__';\n77\t\n78\t/** DispatchError codes that should halt execution immediately. */\n79\tconst HALT_ERROR_CODES = new Set(['RATE_LIMIT', 'NETWORK', 'SDK_INIT']);\n80\t\n81\t// --- Work Item Loading ---\n82\t\n83\t/**\n84\t * Load work items from sprint-status.yaml and optionally issues.yaml.\n85\t *\n86\t * Stories are extracted from the `development_status` section of sprint-status.yaml.\n87\t * Issues are extracted from the `issues` array of issues.yaml.\n88\t *\n89\t * Only items with status `backlog` or `ready-for-dev` are included.\n90\t * Epic keys (`epic-*`) and retrospective keys (`*-retrospective`) are excluded.\n91\t *\n92\t * If issues.yaml does not exist, returns only stories (no error).\n93\t */\n94\texport function loadWorkItems(sprintStatusPath: string, issuesPath?: string): WorkItem[] {\n95\t  const items: WorkItem[] = [];\n96\t\n97\t  // --- Load stories from sprint-status.yaml ---\n98\t  if (existsSync(sprintStatusPath)) {\n99\t    let raw: string;\n100\t    try {\n101\t      raw = readFileSync(sprintStatusPath, 'utf-8');\n102\t    } catch { // IGNORE: unreadable file — warn and return empty\n103\t      warn(`workflow-engine: could not read sprint-status.yaml at ${sprintStatusPath}`);\n104\t      return items;\n105\t    }\n106\t\n107\t    let parsed: unknown;\n108\t    try {\n109\t      parsed = parse(raw);\n110\t    } catch { // IGNORE: malformed YAML — warn and return empty\n111\t      warn(`workflow-engine: invalid YAML in sprint-status.yaml at ${sprintStatusPath}`);\n112\t      return items;\n113\t    }\n114\t\n115\t    if (parsed && typeof parsed === 'object') {\n116\t      const data = parsed as Record<string, unknown>;\n117\t      const devStatus = data.development_status as Record<string, unknown> | undefined;\n118\t\n119\t      if (devStatus && typeof devStatus === 'object') {\n120\t        for (const [key, status] of Object.entries(devStatus)) {\n121\t          // Skip epic keys and retrospective keys\n122\t          if (key.startsWith('epic-')) continue;\n123\t          if (key.endsWith('-retrospective')) continue;\n124\t\n125\t          // Only include backlog or ready-for-dev\n126\t          if (status === 'backlog' || status === 'ready-for-dev') {\n127\t            items.push({ key, source: 'sprint' });\n128\t          }\n129\t        }\n130\t      }\n131\t    }\n132\t  }\n133\t\n134\t  // --- Load issues from issues.yaml ---\n135\t  if (issuesPath && existsSync(issuesPath)) {\n136\t    let raw: string;\n137\t    try {\n138\t      raw = readFileSync(issuesPath, 'utf-8');\n139\t    } catch { // IGNORE: unreadable issues file — warn and return what we have\n140\t      warn(`workflow-engine: could not read issues.yaml at ${issuesPath}`);\n141\t      return items;\n142\t    }\n143\t\n144\t    let parsed: unknown;\n145\t    try {\n146\t      parsed = parse(raw);\n147\t    } catch { // IGNORE: malformed issues YAML — warn and return what we have\n148\t      warn(`workflow-engine: invalid YAML in issues.yaml at ${issuesPath}`);\n149\t      return items;\n150\t    }\n151\t\n152\t    if (parsed && typeof parsed === 'object') {\n153\t      const data = parsed as Record<string, unknown>;\n154\t      const issuesList = data.issues as Array<Record<string, unknown>> | undefined;\n155\t\n156\t      if (Array.isArray(issuesList)) {\n157\t        for (const issue of issuesList) {\n158\t          if (issue && typeof issue === 'object') {\n159\t            const status = issue.status as string | undefined;\n160\t            if (status === 'backlog' || status === 'ready-for-dev') {\n161\t              items.push({\n162\t                key: issue.id as string,\n163\t                title: issue.title as string | undefined,\n164\t                source: 'issues',\n165\t              });\n166\t            }\n167\t          }\n168\t        }\n169\t      }\n170\t    }\n171\t  }\n172\t\n173\t  return items;\n174\t}\n175\t\n176\t// --- Single Task Dispatch ---\n177\t\n178\t/**\n179\t * Dispatch a single task for a specific work item (or per-run sentinel).\n180\t *\n181\t * Handles: trace ID generation, session resolution, source isolation,\n182\t * agent dispatch, state checkpointing, and cleanup.\n183\t *\n184\t * Returns the updated workflow state after recording the dispatch.\n185\t */\n186\texport async function dispatchTask(\n187\t  task: ResolvedTask,\n188\t  taskName: string,\n189\t  storyKey: string,\n190\t  definition: SubagentDefinition,\n191\t  state: WorkflowState,\n192\t  config: EngineConfig,\n193\t): Promise<WorkflowState> {\n194\t  const projectDir = config.projectDir ?? process.cwd();\n195\t\n196\t  // 1. Generate trace ID\n197\t  const traceId = generateTraceId(config.runId, state.iteration, taskName);\n198\t\n199\t  // 2. Format trace prompt\n200\t  const tracePrompt = formatTracePrompt(traceId);\n201\t\n202\t  // 3. Resolve session ID\n203\t  const sessionKey: SessionLookupKey = { taskName, storyKey };\n204\t  const sessionId = resolveSessionId(task.session, sessionKey, state);\n205\t\n206\t  // 4. Build dispatch options based on source_access\n207\t  let dispatchOptions: DispatchOptions;\n208\t  let workspace: Awaited<ReturnType<typeof createIsolatedWorkspace>> | null = null;\n209\t\n210\t  if (task.source_access === false) {\n211\t    workspace = await createIsolatedWorkspace({ runId: config.runId, storyFiles: [] });\n212\t    dispatchOptions = {\n213\t      ...workspace.toDispatchOptions(),\n214\t      sessionId,\n215\t      appendSystemPrompt: tracePrompt,\n216\t    };\n217\t  } else {\n218\t    dispatchOptions = {\n219\t      cwd: projectDir,\n220\t      sessionId,\n221\t      appendSystemPrompt: tracePrompt,\n222\t    };\n223\t  }\n224\t\n225\t  // 5. Construct prompt\n226\t  const prompt = storyKey === PER_RUN_SENTINEL\n227\t    ? `Execute task \"${taskName}\" for the current run.`\n228\t    : `Implement story ${storyKey}`;\n229\t\n230\t  // 6. Dispatch agent\n231\t  let result: DispatchResult;\n232\t  try {\n233\t    result = await dispatchAgent(definition, prompt, dispatchOptions);\n234\t  } finally {\n235\t    // Cleanup workspace regardless of dispatch success/failure\n236\t    if (workspace) {\n237\t      await workspace.cleanup();\n238\t    }\n239\t  }\n240\t\n241\t  // 7. Record session ID (if dispatch returned one)\n242\t  let updatedState = state;\n243\t  if (result.sessionId) {\n244\t    updatedState = recordSessionId(sessionKey, result.sessionId, updatedState);\n245\t  } else {\n246\t    // Append checkpoint manually when no session ID is returned\n247\t    const checkpoint: TaskCheckpoint = {\n248\t      task_name: taskName,\n249\t      story_key: storyKey,\n250\t      completed_at: new Date().toISOString(),\n251\t    };\n252\t    updatedState = {\n253\t      ...updatedState,\n254\t      tasks_completed: [...updatedState.tasks_completed, checkpoint],\n255\t    };\n256\t  }\n257\t\n258\t  // 8. Record trace ID\n259\t  updatedState = recordTraceId(traceId, updatedState);\n260\t\n261\t  // 9. Write state to disk\n262\t  writeWorkflowState(updatedState, projectDir);\n263\t\n264\t  return updatedState;\n265\t}\n266\t\n267\t// --- Flow Step Type Guard ---\n268\t\n269\tfunction isLoopBlock(step: FlowStep): step is LoopBlock {\n270\t  return typeof step === 'object' && step !== null && 'loop' in step;\n271\t}\n272\t\n273\t// --- Main Execution ---\n274\t\n275\t/**\n276\t * Execute a workflow sequentially: iterate through flow steps, dispatch tasks\n277\t * per-story or per-run, checkpoint state after each dispatch.\n278\t *\n279\t * Loop blocks are skipped with a warning (story 5-2).\n280\t *\n281\t * Returns an EngineResult summarizing the execution.\n282\t */\n283\texport async function executeWorkflow(config: EngineConfig): Promise<EngineResult> {\n284\t  const startMs = Date.now();\n285\t  const projectDir = config.projectDir ?? process.cwd();\n286\t  const errors: EngineError[] = [];\n287\t  let tasksCompleted = 0;\n288\t  const processedStories = new Set<string>();\n289\t\n290\t  // 1. Read or initialize workflow state\n291\t  let state = readWorkflowState(projectDir);\n292\t  state = {\n293\t    ...state,\n294\t    phase: 'executing',\n295\t    started: state.started || new Date().toISOString(),\n296\t    workflow_name: config.workflow.flow.filter((s) => typeof s === 'string').join(' -> '),\n297\t  };\n298\t  writeWorkflowState(state, projectDir);\n299\t\n300\t  // 2. Load work items\n301\t  const workItems = loadWorkItems(config.sprintStatusPath, config.issuesPath);\n302\t\n303\t  // 3. Iterate through flow steps\n304\t  let halted = false;\n305\t  for (const step of config.workflow.flow) {\n306\t    if (halted) break;\n307\t\n308\t    // Skip loop blocks (story 5-2)\n309\t    if (isLoopBlock(step)) {\n310\t      warn('workflow-engine: loop blocks are not yet implemented (story 5-2), skipping');\n311\t      continue;\n312\t    }\n313\t\n314\t    // step is a string task name\n315\t    const taskName = step;\n316\t    const task = config.workflow.tasks[taskName];\n317\t\n318\t    if (!task) {\n319\t      warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n320\t      continue;\n321\t    }\n322\t\n323\t    // Look up the agent definition\n324\t    const definition = config.agents[task.agent];\n325\t    if (!definition) {\n326\t      warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n327\t      continue;\n328\t    }\n329\t\n330\t    if (task.scope === 'per-run') {\n331\t      // Per-run: dispatch once with sentinel key\n332\t      try {\n333\t        state = await dispatchTask(task, taskName, PER_RUN_SENTINEL, definition, state, config);\n334\t        tasksCompleted++;\n335\t      } catch (err: unknown) {\n336\t        const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n337\t        errors.push(engineError);\n338\t\n339\t        // Record error checkpoint in state (AC #13)\n340\t        state = recordErrorInState(state, taskName, PER_RUN_SENTINEL, engineError);\n341\t        writeWorkflowState(state, projectDir);\n342\t\n343\t        // Halt on critical errors\n344\t        if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n345\t          halted = true;\n346\t        }\n347\t      }\n348\t    } else {\n349\t      // Per-story: dispatch once per work item\n350\t      for (const item of workItems) {\n351\t        processedStories.add(item.key);\n352\t        try {\n353\t          state = await dispatchTask(task, taskName, item.key, definition, state, config);\n354\t          tasksCompleted++;\n355\t        } catch (err: unknown) {\n356\t          const engineError = handleDispatchError(err, taskName, item.key);\n357\t          errors.push(engineError);\n358\t\n359\t          // Record error checkpoint in state (AC #13)\n360\t          state = recordErrorInState(state, taskName, item.key, engineError);\n361\t          writeWorkflowState(state, projectDir);\n362\t\n363\t          // Halt on critical errors, continue on UNKNOWN\n364\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n365\t            halted = true;\n366\t            break;\n367\t          }\n368\t          // UNKNOWN errors: record and continue to next story\n369\t          continue;\n370\t        }\n371\t      }\n372\t    }\n373\t  }\n374\t\n375\t  // 4. Set final phase if no errors\n376\t  if (errors.length === 0) {\n377\t    state = { ...state, phase: 'completed' };\n378\t    writeWorkflowState(state, projectDir);\n379\t  }\n380\t\n381\t  // 5. Return result\n382\t  return {\n383\t    success: errors.length === 0,\n384\t    tasksCompleted,\n385\t    storiesProcessed: processedStories.size,\n386\t    errors,\n387\t    durationMs: Date.now() - startMs,\n388\t  };\n389\t}\n390\t\n391\t// --- Error Handling ---\n392\t\n393\t/**\n394\t * Record a dispatch error in workflow state: set phase to \"error\" and append\n395\t * a TaskCheckpoint with the error details (AC #13).\n396\t */\n397\tfunction recordErrorInState(\n398\t  state: WorkflowState,\n399\t  taskName: string,\n400\t  storyKey: string,\n401\t  error: EngineError,\n402\t): WorkflowState {\n403\t  const errorCheckpoint: TaskCheckpoint = {\n404\t    task_name: taskName,\n405\t    story_key: storyKey,\n406\t    completed_at: new Date().toISOString(),\n407\t  };\n408\t  return {\n409\t    ...state,\n410\t    phase: 'error',\n411\t    tasks_completed: [...state.tasks_completed, errorCheckpoint],\n412\t  };\n413\t}\n414\t\n415\tfunction handleDispatchError(err: unknown, taskName: string, storyKey: string): EngineError {\n416\t  if (err instanceof DispatchError) {\n417\t    return {\n418\t      taskName,\n419\t      storyKey,\n420\t      code: err.code,\n421\t      message: err.message,\n422\t    };\n423\t  }\n424\t\n425\t  const message = err instanceof Error ? err.message : String(err);\n426\t  return {\n427\t    taskName,\n428\t    storyKey,\n429\t    code: 'UNKNOWN',\n430\t    message,\n431\t  };\n432\t}\n433\t"}]},"parent_tool_use_id":"toolu_013UbHyVXQj1k3dWQ4gFNapF","session_id":"7447df8e-50f4-441a-b8fe-e85605fee72e","uuid":"2bea8241-f4c2-49c3-a7b3-6facfae2e6b7","timestamp":"2026-04-02T22:17:38.609Z"}
