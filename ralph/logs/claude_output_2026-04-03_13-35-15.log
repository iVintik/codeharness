{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RnevATtfWjN6w6eZ3gYDTu","type":"tool_result","content":"730\t/** Default timeout for the health check phase (NFR6). */\n731\tconst HEALTH_CHECK_TIMEOUT_MS = 5000;\n732\t\n733\t/**\n734\t * Run health checks on all unique drivers referenced in a workflow.\n735\t *\n736\t * Collects unique driver names from `workflow.tasks`, resolves each via\n737\t * `getDriver()`, and runs all `healthCheck()` calls concurrently with a\n738\t * 5-second timeout (NFR6).\n739\t *\n740\t * Throws if any driver is unavailable or if the timeout fires.\n741\t */\n742\texport async function checkDriverHealth(workflow: ResolvedWorkflow): Promise<void> {\n743\t  // 1. Collect unique driver names from all tasks\n744\t  const driverNames = new Set<string>();\n745\t  for (const task of Object.values(workflow.tasks)) {\n746\t    driverNames.add(task.driver ?? 'claude-code');\n747\t  }\n748\t\n749\t  // 2. Resolve drivers\n750\t  const drivers = new Map<string, ReturnType<typeof getDriver>>();\n751\t  for (const name of driverNames) {\n752\t    drivers.set(name, getDriver(name));\n753\t  }\n754\t\n755\t  // 3. Run health checks concurrently\n756\t  type HealthResult = { name: string; health: DriverHealth };\n757\t  const healthChecks = Promise.all(\n758\t    [...drivers.entries()].map(async ([name, driver]): Promise<HealthResult> => {\n759\t      const health = await driver.healthCheck();\n760\t      return { name, health };\n761\t    }),\n762\t  );\n763\t\n764\t  // 4. Race against timeout (NFR6)\n765\t  const timeoutPromise = new Promise<'timeout'>((resolve) => {\n766\t    setTimeout(() => resolve('timeout'), HEALTH_CHECK_TIMEOUT_MS);\n767\t  });\n768\t\n769\t  const result = await Promise.race([healthChecks, timeoutPromise]);\n770\t\n771\t  if (result === 'timeout') {\n772\t    const names = [...driverNames].join(', ');\n773\t    throw new Error(\n774\t      `Driver health check timed out after ${HEALTH_CHECK_TIMEOUT_MS}ms. Drivers that did not respond: ${names}`,\n775\t    );\n776\t  }\n777\t\n778\t  // 5. Check for failures\n779\t  const failures = result.filter((r) => !r.health.available);"}]},"parent_tool_use_id":"toolu_01J1hA6EdKQNp4qhAx3VLe1g","session_id":"b101ea9e-2f9e-4377-9c5a-f109fa318b32","uuid":"cada799e-bd88-433c-a325-18ee9e9d921c","timestamp":"2026-04-03T09:43:49.858Z"}
