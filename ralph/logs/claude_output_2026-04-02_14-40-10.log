{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XHjeuPGHGVSSmZv38qX5yR","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';\n2\timport { mkdtempSync, rmSync, readFileSync, writeFileSync, mkdirSync, existsSync } from 'node:fs';\n3\timport { tmpdir } from 'node:os';\n4\timport { join } from 'node:path';\n5\timport {\n6\t  writeWorkflowState,\n7\t  readWorkflowState,\n8\t  getDefaultWorkflowState,\n9\t  type WorkflowState,\n10\t  type TaskCheckpoint,\n11\t  type EvaluatorScore,\n12\t  type CircuitBreakerState,\n13\t} from '../workflow-state.js';\n14\t\n15\tvi.mock('../output.js', () => ({\n16\t  warn: vi.fn(),\n17\t}));\n18\t\n19\timport { warn } from '../output.js';\n20\t\n21\tlet testDir: string;\n22\t\n23\tbeforeEach(() => {\n24\t  testDir = mkdtempSync(join(tmpdir(), 'ch-wfstate-test-'));\n25\t  vi.clearAllMocks();\n26\t});\n27\t\n28\tafterEach(() => {\n29\t  rmSync(testDir, { recursive: true, force: true });\n30\t});\n31\t\n32\tfunction buildFullState(): WorkflowState {\n33\t  return {\n34\t    workflow_name: 'default',\n35\t    started: '2026-04-02T14:30:00.000Z',\n36\t    iteration: 2,\n37\t    phase: 'verify',\n38\t    tasks_completed: [\n39\t      {\n40\t        task_name: 'implement',\n41\t        story_key: '1-3-workflow-state-module',\n42\t        completed_at: '2026-04-02T14:31:00.000Z',\n43\t        session_id: 'sess_abc123',\n44\t      },\n45\t      {\n46\t        task_name: 'verify',\n47\t        story_key: '1-3-workflow-state-module',\n48\t        completed_at: '2026-04-02T14:35:00.000Z',\n49\t      },\n50\t    ],\n51\t    evaluator_scores: [\n52\t      {\n53\t        iteration: 1,\n54\t        passed: 3,\n55\t        failed: 1,\n56\t        unknown: 0,\n57\t        total: 4,\n58\t        timestamp: '2026-04-02T14:35:00.000Z',\n59\t      },\n60\t    ],\n61\t    circuit_breaker: {\n62\t      triggered: false,\n63\t      reason: null,\n64\t      score_history: [0.75],\n65\t    },\n66\t  };\n67\t}\n68\t\n69\tdescribe('getDefaultWorkflowState', () => {\n70\t  it('returns correct default shape and types', () => {\n71\t    const state = getDefaultWorkflowState();\n72\t    expect(state.workflow_name).toBe('');\n73\t    expect(state.started).toBe('');\n74\t    expect(state.iteration).toBe(0);\n75\t    expect(state.phase).toBe('idle');\n76\t    expect(state.tasks_completed).toEqual([]);\n77\t    expect(state.evaluator_scores).toEqual([]);\n78\t    expect(state.circuit_breaker).toEqual({\n79\t      triggered: false,\n80\t      reason: null,\n81\t      score_history: [],\n82\t    });\n83\t  });\n84\t\n85\t  it('returns a new object each call (no shared references)', () => {\n86\t    const a = getDefaultWorkflowState();\n87\t    const b = getDefaultWorkflowState();\n88\t    expect(a).not.toBe(b);\n89\t    expect(a.tasks_completed).not.toBe(b.tasks_completed);\n90\t    expect(a.circuit_breaker).not.toBe(b.circuit_breaker);\n91\t  });\n92\t});\n93\t\n94\tdescribe('writeWorkflowState', () => {\n95\t  it('creates .codeharness/ directory if missing', () => {\n96\t    const state = getDefaultWorkflowState();\n97\t    writeWorkflowState(state, testDir);\n98\t    expect(existsSync(join(testDir, '.codeharness'))).toBe(true);\n99\t    expect(existsSync(join(testDir, '.codeharness', 'workflow-state.yaml'))).toBe(true);\n100\t  });\n101\t\n102\t  it('writes valid YAML that can be parsed', () => {\n103\t    const state = buildFullState();\n104\t    writeWorkflowState(state, testDir);\n105\t    const raw = readFileSync(join(testDir, '.codeharness', 'workflow-state.yaml'), 'utf-8');\n106\t    expect(raw).toContain('workflow_name: default');\n107\t    expect(raw).toContain('phase: verify');\n108\t    expect(raw).toContain('iteration: 2');\n109\t  });\n110\t\n111\t  it('overwrites existing file completely', () => {\n112\t    const state1 = buildFullState();\n113\t    state1.phase = 'first';\n114\t    writeWorkflowState(state1, testDir);\n115\t\n116\t    const state2 = getDefaultWorkflowState();\n117\t    state2.phase = 'second';\n118\t    writeWorkflowState(state2, testDir);\n119\t\n120\t    const raw = readFileSync(join(testDir, '.codeharness', 'workflow-state.yaml'), 'utf-8');\n121\t    expect(raw).toContain('phase: second');\n122\t    expect(raw).not.toContain('phase: first');\n123\t  });\n124\t\n125\t  it('handles nested .codeharness directory already existing', () => {\n126\t    mkdirSync(join(testDir, '.codeharness'), { recursive: true });\n127\t    const state = getDefaultWorkflowState();\n128\t    writeWorkflowState(state, testDir);\n129\t    expect(existsSync(join(testDir, '.codeharness', 'workflow-state.yaml'))).toBe(true);\n130\t  });\n131\t});\n132\t\n133\tdescribe('readWorkflowState', () => {\n134\t  it('returns default state when file does not exist', () => {\n135\t    const state = readWorkflowState(testDir);\n136\t    expect(state).toEqual(getDefaultWorkflowState());\n137\t  });\n138\t\n139\t  it('does not warn when file simply does not exist', () => {\n140\t    readWorkflowState(testDir);\n141\t    expect(warn).not.toHaveBeenCalled();\n142\t  });\n143\t\n144\t  it('returns default state and warns on corrupted YAML', () => {\n145\t    mkdirSync(join(testDir, '.codeharness'), { recursive: true });\n146\t    writeFileSync(join(testDir, '.codeharness', 'workflow-state.yaml'), '{{{{not yaml at all', 'utf-8');\n147\t    const state = readWorkflowState(testDir);\n148\t    expect(state).toEqual(getDefaultWorkflowState());\n149\t    expect(warn).toHaveBeenCalledWith(expect.stringContaining('invalid YAML'));\n150\t  });\n151\t\n152\t  it('returns default state and warns on empty file', () => {\n153\t    mkdirSync(join(testDir, '.codeharness'), { recursive: true });\n154\t    writeFileSync(join(testDir, '.codeharness', 'workflow-state.yaml'), '', 'utf-8');\n155\t    // Empty string parses to null in yaml, which fails shape check\n156\t    const state = readWorkflowState(testDir);\n157\t    expect(state).toEqual(getDefaultWorkflowState());\n158\t    expect(warn).toHaveBeenCalledWith(expect.stringContaining('invalid shape'));\n159\t  });\n160\t\n161\t  it('returns default state and warns on invalid shape (missing fields)', () => {\n162\t    mkdirSync(join(testDir, '.codeharness'), { recursive: true });\n163\t    writeFileSync(\n164\t      join(testDir, '.codeharness', 'workflow-state.yaml'),\n165\t      'workflow_name: test\\niteration: 1\\n',\n166\t      'utf-8',\n167\t    );\n168\t    const state = readWorkflowState(testDir);\n169\t    expect(state).toEqual(getDefaultWorkflowState());\n170\t    expect(warn).toHaveBeenCalledWith(expect.stringContaining('invalid shape'));\n171\t  });\n172\t\n173\t  it('returns default state and warns when file exists but is unreadable (e.g. directory)', () => {\n174\t    mkdirSync(join(testDir, '.codeharness', 'workflow-state.yaml'), { recursive: true });\n175\t    const state = readWorkflowState(testDir);\n176\t    expect(state).toEqual(getDefaultWorkflowState());\n177\t    expect(warn).toHaveBeenCalledWith(expect.stringContaining('could not be read'));\n178\t  });\n179\t\n180\t  it('returns default state and warns when circuit_breaker is missing', () => {\n181\t    mkdirSync(join(testDir, '.codeharness'), { recursive: true });\n182\t    const partial = `workflow_name: test\n183\tstarted: \"2026-01-01T00:00:00Z\"\n184\titeration: 1\n185\tphase: idle\n186\ttasks_completed: []\n187\tevaluator_scores: []\n188\t`;\n189\t    writeFileSync(join(testDir, '.codeharness', 'workflow-state.yaml'), partial, 'utf-8');\n190\t    const state = readWorkflowState(testDir);\n191\t    expect(state).toEqual(getDefaultWorkflowState());\n192\t    expect(warn).toHaveBeenCalled();\n193\t  });\n194\t});\n195\t\n196\tdescribe('round-trip fidelity', () => {\n197\t  it('write then read preserves all fields', () => {\n198\t    const original = buildFullState();\n199\t    writeWorkflowState(original, testDir);\n200\t    const restored = readWorkflowState(testDir);\n201\t 