= checkInfrastructure('/project');\n   637→    expect(result.success).toBe(true);\n   638→    if (result.success) {\n   639→      expect(result.data.status).toBe('warn');\n   640→      expect(result.data.metric).toBe('Dockerfile unreadable');\n   641→      expect(result.data.gaps[0].description).toContain('could not be read');\n   642→    }\n   643→  });\n   644→\n   645→  it('returns warn when checkInfrastructure outer catch fires', () => {\n   646→    mockValidateDockerfile.mockImplementation(() => {\n   647→      throw new Error('Disk error');\n   648→    });\n   649→\n   650→    const result = checkInfrastructure('/project');\n   651→    expect(result.success).toBe(true);\n   652→    if (result.success) {\n   653→      expect(result.data.status).toBe('warn');\n   654→      expect(result.data.gaps[0].description).toContain('Disk error');\n   655→    }\n   656→  });\n   657→\n   658→  it('returns pass with digest-pinned image and no gaps', () => {\n   659→    mockValidateDockerfile.mockReturnValue({\n   660→      success: true,\n   661→      data: { passed: true, gaps: [], warnings: [] },\n   662→    });\n   663→\n   664→    const result = checkInfrastructure('/project');\n   665→    expect(result.success).toBe(true);\n   666→    if (result.success) {\n   667→      expect(result.data.status).toBe('pass');\n   668→    }\n   669→  });\n   670→\n   671→  it('returns fail when validateDockerfile returns failure Result', () => {\n   672→    mockValidateDockerfile.mockReturnValue({\n   673→      success: false,\n   674→      error: 'Dockerfile validation error',\n   675→    });\n   676→\n   677→    const result = checkInfrastructure('/project');\n   678→    expect(result.success).toBe(true);\n   679→    if (result.success) {\n   680→      expect(result.data.status).toBe('fail');\n   681→      expect(result.data.metric).toBe('validation failed');\n   682→    }\n   683→  });\n   684→\n   685→  it('backward compatibility: no Dockerfile still returns fail', () => {\n   686→