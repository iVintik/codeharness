{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013CEmqUxbZuW9q23kTSxRqL","type":"tool_result","content":"1\timport { existsSync, readFileSync, writeFileSync } from 'node:fs';\n2\timport { join } from 'node:path';\n3\timport { parse } from 'yaml';\n4\timport { warn } from '../output.js';\n5\t\n6\tconst SPRINT_STATUS_PATH = '_bmad-output/implementation-artifacts/sprint-status.yaml';\n7\t\n8\t/**\n9\t * Reads sprint-status.yaml and returns the development_status map.\n10\t */\n11\texport function readSprintStatus(dir?: string): Record<string, string> {\n12\t  const root = dir ?? process.cwd();\n13\t  const filePath = join(root, SPRINT_STATUS_PATH);\n14\t  if (!existsSync(filePath)) {\n15\t    return {};\n16\t  }\n17\t  try {\n18\t    const content = readFileSync(filePath, 'utf-8');\n19\t    const parsed = parse(content) as Record<string, unknown> | null;\n20\t    if (!parsed || typeof parsed !== 'object') {\n21\t      return {};\n22\t    }\n23\t    const devStatus = parsed.development_status;\n24\t    if (!devStatus || typeof devStatus !== 'object') {\n25\t      return {};\n26\t    }\n27\t    return devStatus as Record<string, string>;\n28\t  } catch {\n29\t    // IGNORE: sprint-status.yaml may not exist or be malformed\n30\t    return {};\n31\t  }\n32\t}\n33\t\n34\t/**\n35\t * Updates a single story's status in sprint-status.yaml while preserving structure and comments.\n36\t * Uses line-level text replacement to preserve YAML comments.\n37\t */\n38\texport function updateSprintStatus(storyKey: string, newStatus: string, dir?: string): void {\n39\t  const root = dir ?? process.cwd();\n40\t  const filePath = join(root, SPRINT_STATUS_PATH);\n41\t  if (!existsSync(filePath)) {\n42\t    warn(`sprint-status.yaml not found at ${filePath}, skipping update`);\n43\t    return;\n44\t  }\n45\t\n46\t  const content = readFileSync(filePath, 'utf-8');\n47\t\n48\t  const keyPattern = new RegExp(`^(\\\\s*${escapeRegExp(storyKey)}:\\\\s*)\\\\S+(.*)$`, 'm');\n49\t  if (!keyPattern.test(content)) {\n50\t    return;\n51\t  }\n52\t\n53\t  const updated = content.replace(keyPattern, `$1${newStatus}$2`);\n54\t  writeFileSync(filePath, updated, 'utf-8');\n55\t}\n56\t\n57\tfunction escapeRegExp(s: string): string {\n58\t  return s.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n59\t}\n60\t\n61\t// ─── Onboarding Epic → Sprint Status ────────────────────────────────────────\n62\t\n63\tfunction nextEpicNumber(statuses: Record<string, string>): number {\n64\t  let max = -1;\n65\t  for (const key of Object.keys(statuses)) {\n66\t    const match = key.match(/^epic-(\\d+)$/);\n67\t    if (match) {\n68\t      const n = parseInt(match[1], 10);\n69\t      if (n > max) max = n;\n70\t    }\n71\t  }\n72\t  return max + 1;\n73\t}\n74\t\n75\tfunction slugify(title: string): string {\n76\t  return title\n77\t    .toLowerCase()\n78\t    .replace(/[^a-z0-9]+/g, '-')\n79\t    .replace(/^-+|-+$/g, '')\n80\t    .slice(0, 60);\n81\t}\n82\t\n83\texport interface OnboardingStoryEntry {\n84\t  title: string;\n85\t  key?: string;\n86\t}\n87\t\n88\t/**\n89\t * Appends an onboarding epic with stories to sprint-status.yaml.\n90\t */\n91\texport function appendOnboardingEpicToSprint(\n92\t  stories: OnboardingStoryEntry[],\n93\t  dir?: string,\n94\t): { epicNumber: number; storyKeys: string[] } {\n95\t  const root = dir ?? process.cwd();\n96\t  const filePath = join(root, SPRINT_STATUS_PATH);\n97\t\n98\t  if (!existsSync(filePath)) {\n99\t    warn(`sprint-status.yaml not found at ${filePath}, cannot append onboarding epic`);\n100\t    return { epicNumber: -1, storyKeys: [] };\n101\t  }\n102\t\n103\t  const statuses = readSprintStatus(dir);\n104\t  const epicNum = nextEpicNumber(statuses);\n105\t  const storyKeys: string[] = [];\n106\t\n107\t  const lines: string[] = [''];\n108\t  lines.push(`  epic-${epicNum}: backlog`);\n109\t\n110\t  for (let i = 0; i < stories.length; i++) {\n111\t    const slug = slugify(stories[i].title);\n112\t    const storyKey = `${epicNum}-${i + 1}-${slug}`;\n113\t    storyKeys.push(storyKey);\n114\t    lines.push(`  ${storyKey}: backlog`);\n115\t  }\n116\t\n117\t  lines.push(`  epic-${epicNum}-retrospective: optional`);\n118\t  lines.push('');\n119\t\n120\t  const content = readFileSync(filePath, 'utf-8');\n121\t  const updated = content.trimEnd() + '\\n' + lines.join('\\n');\n122\t  writeFileSync(filePath, updated, 'utf-8');\n123\t\n124\t  return { epicNumber: epicNum, storyKeys };\n125\t}\n126\t"}]},"parent_tool_use_id":null,"session_id":"aeb5b1ee-06a7-4bdc-8279-6cd22d306d14","uuid":"b65094a0-e61b-4eed-8e41-d8f28ff6bc38","timestamp":"2026-04-02T10:45:26.188Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ivintik/dev/personal/codeharness/src/lib/sync/sprint-yaml.ts","content":"import { existsSync, readFileSync, writeFileSync } from 'node:fs';\nimport { join } from 'node:path';\nimport { parse } from 'yaml';\nimport { warn } from '../output.js';\n\nconst SPRINT_STATUS_PATH = '_bmad-output/implementation-artifacts/sprint-status.yaml';\n\n/**\n * Reads sprint-status.yaml and returns the development_status map.\n */\nexport function readSprintStatus(dir?: string): Record<string, string> {\n  const root = dir ?? process.cwd();\n  const filePath = join(root, SPRINT_STATUS_PATH);\n  if (!existsSync(filePath)) {\n    return {};\n  }\n  try {\n    const content = readFileSync(filePath, 'utf-8');\n    const parsed = parse(content) as Record<string, unknown> | null;\n    if (!parsed || typeof parsed !== 'object') {\n      return {};\n    }\n    const devStatus = parsed.development_status;\n    if (!devStatus || typeof devStatus !== 'object') {\n      return {};\n    }\n    return devStatus as Record<string, string>;\n  } catch {\n    // IGNORE: sprint-status.yaml may not exist or be malformed\n    return {};\n  }\n}\n\n/**\n * Updates a single story's status in sprint-status.yaml while preserving structure and comments.\n * Uses line-level text replacement to preserve YAML comments.\n */\nexport function updateSprintStatus(storyKey: string, newStatus: string, dir?: string): void {\n  const root = dir ?? process.cwd();\n  const filePath = join(root, SPRINT_STATUS_PATH);\n  if (!existsSync(filePath)) {\n    warn(`sprint-status.yaml not found at ${filePath}, skipping update`);\n    return;\n  }\n\n  const content = readFileSync(filePath, 'utf-8');\n\n  const keyPattern = new RegExp(`^(\\\\s*${escapeRegExp(storyKey)}:\\\\s*)\\\\S+(.*)$`, 'm');\n  if (!keyPattern.test(content)) {\n    return;\n  }\n\n  const updated = content.replace(keyPattern, `$1${newStatus}$2`);\n  writeFileSync(filePath, updated, 'utf-8');\n}\n\nfunction escapeRegExp(s: string): string {\n  return s.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n}\n\n// ─── Onboarding Epic → Sprint Status ────────────────────────────────────────\n\nfunction nextEpicNumber(statuses: Record<string, string>): number {\n  let max = -1;\n  for (const key of Object.keys(statuses)) {\n    const match = key.match(/^epic-(\\d+)$/);\n    if (match) {\n      const n = parseInt(match[1], 10);\n      if (n > max) max = n;\n    }\n  }\n  return max + 1;\n}\n\nfunction slugify(title: string): string {\n  return title\n    .toLowerCase()\n    .replace(/[^a-z0-9]+/g, '-')\n    .replace(/^-+|-+$/g, '')\n    .slice(0, 60);\n}\n\nexport interface OnboardingStoryEntry {\n  title: string;\n  key?: string;\n}\n\n/**\n * Appends an onboarding epic with stories to sprint-status.yaml.\n */\nexport function appendOnboardingEpicToSprint(\n  stories: OnboardingStoryEntry[],\n  dir?: string,\n): { epicNumber: number; storyKeys: string[] } {\n  const root = dir ?? process.cwd();\n  const filePath = join(root, SPRINT_STATUS_PATH);\n\n  if (!existsSync(filePath)) {\n    warn(`sprint-status.yaml not found at ${filePath}, cannot append onboarding epic`);\n    return { epicNumber: -1, storyKeys: [] };\n  }\n\n  const statuses = readSprintStatus(dir);\n  const epicNum = nextEpicNumber(statuses);\n  const storyKeys: string[] = [];\n\n  const lines: string[] = [''];\n  lines.push(`  epic-${epicNum}: backlog`);\n\n  for (let i = 0; i < stories.length; i++) {\n    const slug = slugify(stories[i].title);\n    const storyKey = `${epicNum}-${i + 1}-${slug}`;\n    storyKeys.push(storyKey);\n    lines.push(`  ${storyKey}: backlog`);\n  }\n\n  lines.push(`  epic-${epicNum}-retrospective: optional`);\n  lines.push('');\n\n  const content = readFileSync(filePath, 'utf-8');\n  const updated = content.trimEnd() + '\\n' + lines.join('\\n');\n  writeFileSync(filePath, updated, 'utf-8');\n\n  return { epicNumber: epicNum, storyKeys };\n}\n","numLines":126,"startLine":1,"totalLines":126}}}
