 StoryStatusEntry[] = [\n245\t      { key: '1-1-stuck', status: 'blocked' },\n246\t    ];\n247\t    const { lastFrame } = render(<StoryBreakdown stories={stories} />);\n248\t    const frame = lastFrame()!;\n249\t    expect(frame).toContain('Blocked:');\n250\t    expect(frame).toContain('1-1 ✕');\n251\t    expect(frame).not.toContain('(');\n252\t  });\n253\t\n254\t  it('does not match story 3-20 as current when sprint info says 3-2 (key prefix collision)', () => {\n255\t    const stories: StoryStatusEntry[] = [\n256\t      { key: '3-2-current', status: 'in-progress' },\n257\t      { key: '3-20-other', status: 'in-progress' },\n258\t    ];\n259\t    const sprintInfo: SprintInfo = {\n260\t      storyKey: '3-2-current',\n261\t      phase: 'verifying',\n262\t      done: 5,\n263\t      total: 10,\n264\t      acProgress: '8/12',\n265\t    };\n266\t    const { lastFrame } = render(<StoryBreakdown stories={stories} sprintInfo={sprintInfo} />);\n267\t    const frame = lastFrame()!;\n268\t    // 3-2 should have phase info, 3-20 should NOT\n269\t    expect(frame).toContain('3-2 ◆ verifying (8/12 ACs)');\n270\t    expect(frame).toMatch(/3-20 ◆(?! verifying)/);\n271\t  });\n272\t});\n273\t\n274\tdescribe('CompletedTool component', () => {\n275\t  it('renders tool name and args', () => {\n276\t    const entry: CompletedToolEntry = { name: 'Bash', args: 'ls -la' };\n277\t    const { lastFrame } = render(<CompletedTool entry={entry} />);\n278\t    const frame = lastFrame();\n279\t    expect(frame).toContain('✓');\n280\t    expect(frame).toContain('[Bash]');\n281\t    expect(frame).toContain('ls -la');\n282\t  });\n283\t\n284\t  it('truncates long args to 60 chars', () => {\n285\t    const longArgs = 'a'.repeat(100);\n286\t    const entry: CompletedToolEntry = { name: 'Write', args: longArgs };\n287\t    const { lastFrame } = render(<CompletedTool entry={entry} />);\n288\t    const frame = lastFrame()!;\n289\t    expect(frame).toContain('a'.repeat(60) + '…');\n290\t    expect(frame).not.toContain('a'.repeat(61));\n291\t  });\n292\t});\n293\t\n294\tdescribe('ActiveTool component', () => {\n295\t  it('renders tool name with lightning bolt', () => {\n296\t    const { lastFrame } = render(<ActiveTool name=\"Read\" />);\n297\t    const frame = lastFrame();\n298\t    expect(frame).toContain('⚡');\n299\t    expect(frame).toContain('[Read]');\n300\t  });\n301\t});\n302\t\n303\tdescribe('LastThought component', () => {\n304\t  it('renders thought text with brain emoji', () => {\n305\t    const { lastFrame } = render(<LastThought text=\"thinking about code\" />);\n306\t    const frame = lastFrame();\n307\t    expect(frame).toContain('💭');\n308\t    expect(frame).toContain('thinking about code');\n309\t  });\n310\t});\n311\t\n312\tdescribe('LastThought truncation', () => {\n313\t  it('handles emoji without splitting surrogate pairs', () => {\n314\t    const text = '🎉🎊🎈🎁🎂'.repeat(20);\n315\t    const { lastFrame } = render(<LastThought text={text} />);\n316\t    const frame = lastFrame()!;\n317\t    expect(frame).toContain('💭');\n318\t    expect(frame).toBeDefined();\n319\t  });\n320\t});\n321\t\n322\tdescribe('RetryNotice component', () => {\n323\t  it('renders retry info', () => {\n324\t    const { lastFrame } = render(\n325\t      <RetryNotice info={{ attempt: 2, delay: 5000 }} />,\n326\t    );\n327\t    const frame = lastFrame();\n328\t    expect(frame).toContain('⏳');\n329\t    expect(frame).toContain('retry');\n330\t    expect(frame).toContain('2');\n331\t    expect(frame).toContain('5000');\n332\t  });\n333\t});\n334\t\n335\tdescribe('StoryMessageLine component (AC #5, #6)', () => {\n336\t  it('renders [OK] message for completed story', () => {\n337\t    const msg: StoryMessage = { type: 'ok', key: '3-2', message: 'DONE — 12/12 ACs verified (18m, $4.20)' };\n338\t    const { lastFrame } = render(<StoryMessageLine msg={msg} />);\n339\t    const frame = lastFrame()!;\n340\t    expect(frame).toContain('[OK]');\n341\t    expect(frame).toContain('Story 3-2');\n342\t    expect(frame).toContain('DONE');\n343\t    expect(frame).toContain('12/12 ACs verified');\n344\t  });\n345\t\n346\t  it('renders [WARN] message with details', () => {\n347\t    const msg: StoryMessage = {\n348\t      type: 'warn',\n349\t      key: '3-3',\n350\t      message: 'verification found 2 failing ACs → returning to dev (attempt 2/10)',\n351\t      details: [\n352\t        'AC 3: bridge --dry-run output missing epic headers',\n353\t        'AC 7: bridge creates duplicate beads issues',\n354\t      ],\n355\t    };\n356\t    const { lastFrame } = render(<StoryMessageLine msg={msg} />);\n357\t    const frame = lastFrame()!;\n358\t    expect(frame).toContain('[WARN]');\n359\t    expect(frame).toContain('Story 3-3');\n360\t    expect(frame).toContain('2 failing ACs');\n361\t    expect(frame).toContain('└ AC 3');\n362\t    expect(frame).toContain('└ AC 7');\n363\t  });\n364\t\n365\t  it('renders [FAIL] message', () => {\n366\t    const msg: StoryMessage = { type: 'fail', key: '2-3', message: 'verification failed at AC 4 (attempt 3/10)' };\n367\t    const { lastFrame } = render(<StoryMessageLine msg={msg} />);\n368\t    const frame = lastFrame()!;\n369\t    expect(frame).toContain('[FAIL]');\n370\t    expect(frame).toContain('Story 2-3');\n371\t  });\n372\t\n373\t  it('renders [OK] with detail lines for proof, duration, and cost', () => {\n374\t    const msg: StoryMessage = {\n375\t      type: 'ok',\n376\t      key: '3-2',\n377\t      message: 'DONE — 12/12 ACs verified',\n378\t      details: [\n379\t        'Proof: verification/3-2-proof.md',\n380\t        'Duration: 18m | Cost: $4.20',\n381\t      ],\n382\t    };\n383\t    const { lastFrame } = render(<StoryMessageLine msg={msg} />);\n384\t    const frame = lastFrame()!;\n385\t    expect(frame).toContain('[OK]');\n386\t    expect(frame).toContain('Story 3-2: DONE');\n387\t    expect(frame).toContain('└ Proof: verification/3-2-proof.md');\n388\t    expect(frame).toContain('└ Duration: 18m | Cost: $4.20');\n389\t  });\n390\t});\n391\t\n392\tdescribe('App component', () => {\n393\t  it('renders all elements when state is full', () => {\n394\t    const state = makeState({\n395\t      sprintInfo: {\n396\t        storyKey: '1-2-3',\n397\t        phase: 'dev',\n398\t        done: 1,\n399\t        total: 5,\n400\t        iterationCount: 1,\n401\t        totalCost: 2.50,\n402\t      },\n403\t      completedTools: [{ name: 'Bash', args: 'echo hello' }],\n404\t      activeTool: { name: 'Read' },\n405\t      lastThought: 'analyzing...',\n406\t      retryInfo: null,\n407\t    });\n408\t    const { lastFrame } = render(<App state={state} />);\n409\t    const frame = lastFrame()!;\n410\t    expect(frame).toContain('codeharness run');\n411\t    expect(frame).toContain('Story: 1-2-3');\n412\t    expect(frame).toContain('✓');\n413\t    expect(frame).toContain('[Bash]');\n414\t    expect(frame).toContain('⚡');\n415\t    expect(frame).toContain('[Read]');\n416\t    expect(frame).toContain('💭');\n417\t    expect(frame).toContain('analyzing...');\n418\t  });\n419\t\n420\t  it('renders empty state without errors', () => {\n421\t    const state = makeState();\n422\t    const { lastFrame } = render(<App state={state} />);\n423\t    expect(lastFrame()).toBeDefined();\n424\t  });\n425\t\n426\t  it('renders retry info when present', () => {\n427\t    const state = makeState({\n428\t      retryInfo: { attempt: 3, delay: 10000 },\n429\t    });\n430\t    const { lastFrame } = render(<App state={state} />);\n431\t    const frame = lastFrame()!;\n432\t    expect(frame).toContain('⏳');\n433\t    expect(frame).toContain('3');\n434\t  });\n435\t\n436\t  it('renders bottom separator after story breakdown', () => {\n437\t    const state = makeState({\n438\t      sprintInfo: { storyKey: '3-2', phase: 'dev', done: 1, total: 5 },\n439\t      stories: [\n440\t        { key: '3-1-done', status: 'done' },\n441\t        { key: '3-2-current', status: 'in-progress' },\n442\t      ],\n443\t    });\n444\t    const { lastFrame } = render(<App state={state} />);\n445\t    const frame = lastFrame()!;\n446\t    // Should have separators\n447\t    const separatorCount = (frame.match(/━━━/g) || []).length;\n448\t    expect(separatorCount).toBeGreaterThanOrEqual(2); // header separator + bottom separator\n449\t  });\n450\t});\n451\t\n452\t// --- Controller API Tests ---\n453\t\n454\tdescribe('startRenderer', () => {\n455\t  let handle: RendererHandle | null = null;\n456\t\n457\t  afterEach(() => {\n458\t    if (handle) {\n459\t      handle.cleanup();\n460\t      handle = null;\n461\t    }\n462\t  });\n463\t\n464\t  describe('quiet mode (AC #8)', () => {\n465\t    it('returns no-op handle when quiet is true', () => {\n466\t      handle = startRenderer({ quiet: true });\n467\t      handle.update({ type: 'tool-start', name: 'Bash', id: 'x' });\n468\t      handle.update({ type: 'tool-complete' });\n469\t      handle.update({ type: 'text', text: 'hello' });\n470\t      handle.updateSprintState({ storyKey: 'a', phase: 'b', done: 1, total: 2 });\n471\t      handle.updateStories([{ key: '1-1', status: 'done' }]);\n472\t      handle.addMessage({ type: 'ok', key: '1-1', message: 'DONE' });\n473\t      handle.cleanup();\n474\t      handle.cleanup();\n475\t    });\n476\t  });\n477\t\n478\t  describe('event handling', () => {\n479\t    it('handles tool-start event', () => {\n480\t      handle = startRenderer({ _forceTTY: true });\n481\t      handle.update({ type: 'tool-start', name: 'Bash', id: 'tool1' });\n482\t    });\n483\t\n484\t    it('handles tool-complete after tool-start (moves to completed)', () => {\n485\t      handle = startRenderer({ _forceTTY: true });\n486\t      handle.update({ type: 'tool-start', name: 'Bash', id: 'tool1' });\n487\t      handle.update({ type: 'tool-input', partial: '{\"command\":' });\n488\t      handle.update({ type: 'tool-input', partial: '\"ls\"}' });\n489\t      handle.update({ type: 'tool-complete' });\n490\t    });\n491\t\n492\t    it('handles tool-complete when no activeTool (text block stop)', () => {\n493\t      handle = startRenderer({ _forceTTY: true });\n494\t      handle.update({ type: 'tool-complete' });\n495\t    });\n496\t\n497\t    it('handles text event', () => {\n498\t      handle = startRenderer({ _forceTTY: true });\n499\t      handle.update({ type: 'text', text: 'thinking...' });\n500\t    });\n501\t\n502\t    it('handles retry event', () => {\n503\t      handle = startRenderer({ _forceTTY: true });\n504\t      handle.update({ type: 'retry', attempt: 1, delay: 5000 });\n505\t    });\n506\t\n507\t    it('handles result event and accumulates cost', () => {\n508\t      handle = startRenderer({\n509\t        sprintState: { storyKey: 'a', phase: 'b', done: 1, total: 2 },\n510\t        _forceTTY: true,\n511\t      });\n512\t      handle.update({ type: 'result', cost: 0.05, sessionId: 'sess_123' });\n513\t      // Cost should be accumulated in sprintInfo\n514\t    });\n515\t\n516\t    it('preserves accumulated cost when updateSprintState is called without cost', () => {\n517\t      handle = startRenderer({\n518\t        sprintState: { storyKey: 'a', phase: 'b', done: 1, total: 2 },\n519\t        _forceTTY: true,\n520\t      });\n521\t      // Accumulate cost via result events\n522\t      handle.update({ type: 'result', cost: 0.05, sessionId: 'sess_1' });\n523\t      handle.update({ type: 'result', cost: 0.10, sessionId: 'sess_2' });\n524\t      // Sprint state refresh (simulating the 5s polling interval) should NOT wipe cost\n525\t      handle.updateSprintState({ storyKey: 'a', phase: 'b', done: 2, total: 5, elapsed: '5m', iterationCount: 2 });\n526\t      // Cost should still be preserved (0.15 total) — this test ensures the bug fix works\n527\t    });\n528\t\n529\t    it('clears retry on next tool-start', () => {\n530\t      handle = startRenderer({ _forceTTY: true });\n531\t      handle.update({ type: 'retry', attempt: 1, delay: 5000 });\n532\t      handle.update({ type: 'tool-start', name: 'Bash', id: 'tool1' });\n533\t    });\n534\t\n535\t    it('clears retry on next text event', () => {\n536\t      handle = startRenderer({ _forceTTY: true });\n537\t      handle.update({ type: 'retry', attempt: 1, delay: 5000 });\n538\t      handle.update({ type: 'text', text: 'thinking...' });\n539\t    });\n540\t\n541\t    it('clears lastThought on tool-start', () => {\n542\t      handle = startRenderer({ _forceTTY: true });\n543\t      handle.update({ type: 'text', text: 'old thought' });\n544\t      handle.update({ type: 'tool-start', name: 'Bash', id: 'tool1' });\n545\t    });\n546\t\n547\t    it('text event overwrites previous thought (not append)', () => {\n548\t      handle = startRenderer({ _forceTTY: true });\n549\t      handle.update({ type: 'text', text: 'first thought' });\n550\t      handle.update({ type: 'text', text: 'second thought' });\n551\t    });\n552\t\n553\t    it('accumulates tool input args', () => {\n554\t      handle = startRenderer({ _forceTTY: true });\n555\t      handle.update({ type: 'tool-start', name: 'Write', id: 'tool1' });\n556\t      handle.update({ type: 'tool-input', partial: '{\"path\":' });\n557\t      handle.update({ type: 'tool-input', partial: '\"/tmp/test.ts\",' });\n558\t      handle.update({ type: 'tool-input', partial: '\"content\":\"hello\"}' });\n559\t      handle.update({ type: 'tool-complete' });\n560\t    });\n561\t\n562\t    it('bounds completed tools list at MAX_COMPLETED_TOOLS (50)', () => {\n563\t      handle = startRenderer({ _forceTTY: true });\n564\t      for (let i = 0; i < 55; i++) {\n565\t        handle.update({ type: 'tool-start', name: `Tool${i}`, id: `t${i}` });\n566\t        handle.update({ type: 'tool-input', partial: `arg${i}` });\n567\t        handle.update({ type: 'tool-complete' });\n568\t      }\n569\t    });\n570\t\n571\t    it('handles multiple tool cycles', () => {\n572\t      handle = startRenderer({ _forceTTY: true });\n573\t      handle.update({ type: 'tool-start', name: 'Read', id: 'tool1' });\n