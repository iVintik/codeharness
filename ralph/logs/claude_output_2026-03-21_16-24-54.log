validateDockerfile('/project');\n    52→    expect(r.success).toBe(true);\n    53→    if (r.success) {\n    54→      const fromGaps = r.data.gaps.filter(g => g.rule === 'pinned-from');\n    55→      expect(fromGaps.length).toBeGreaterThan(0);\n    56→      expect(fromGaps[0].description).toContain('unpinned base image');\n    57→    }\n    58→  });\n    59→\n    60→  it('passes for digest-pinned image', () => {\n    61→    mockExistsSync.mockReturnValue(true);\n    62→    mockReadFileSync.mockReturnValue(\n    63→      goodDockerfile().replace('FROM node:22-slim', 'FROM node@sha256:abc123def456'),\n    64→    );\n    65→\n    66→    const r = validateDockerfile('/project');\n    67→    expect(r.success).toBe(true);\n    68→    if (r.success) {\n    69→      const fromGaps = r.data.gaps.filter(g => g.rule === 'pinned-from');\n    70→      expect(fromGaps).toHaveLength(0);\n    71→    }\n    72→  });\n    73→\n    74→  it('fails for node (no tag)', () => {\n    75→    mockExistsSync.mockReturnValue(true);\n    76→    mockReadFileSync.mockReturnValue(\n    77→      goodDockerfile().replace('FROM node:22-slim', 'FROM node'),\n    78→    );\n    79→\n    80→    const r = validateDockerfile('/project');\n    81→    expect(r.success).toBe(true);\n    82→    if (r.success) {\n    83→      const fromGaps = r.data.gaps.filter(g => g.rule === 'pinned-from');\n    84→      expect(fromGaps.length).toBeGreaterThan(0);\n    85→      expect(fromGaps[0].description).toContain('unpinned base image');\n    86→    }\n    87→  });\n    88→});\n    89→\n    90→// ─── Project binary on PATH ─────────────────────────────────────────────────\n    91→\n    92→describe('project binary on PATH', () => {\n    93→  it('passes with npm install -g', () => {\n    94→    mockExistsSync.mockReturnValue(true);\n    95→    mockReadFileSync.mockReturnValue(goodDockerfile());\n    96→\n    97→    const r = validateDockerfile('/project');\n    98→    expect(r.success).toBe(true);\n    99→    if (r.success