{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CbWt83qBSd46hqSBCC5E9h","type":"tool_result","content":"1\t/**\n2\t * Telemetry Writer.\n3\t *\n4\t * Writes structured NDJSON telemetry entries after each story completes.\n5\t * Entries are appended to `.codeharness/telemetry.jsonl` for later analysis\n6\t * by epic retros — no per-session LLM cost.\n7\t *\n8\t * @see Story 16-3: Telemetry Writer\n9\t */\n10\t\n11\timport { appendFileSync, existsSync, mkdirSync, readFileSync } from 'node:fs';\n12\timport { join } from 'node:path';\n13\t\n14\timport type { ACStatus, TestResults } from './agents/types.js';\n15\timport type { TaskContext, NullTaskResult } from './null-task-registry.js';\n16\t\n17\t// --- Interfaces ---\n18\t\n19\t/**\n20\t * Re-export TestResults as TestResultsSummary for backward compatibility.\n21\t * Telemetry entries use the same shape as the agent driver's TestResults.\n22\t */\n23\texport type TestResultsSummary = TestResults;\n24\t\n25\t/**\n26\t * Acceptance criteria result stored in telemetry.\n27\t */\n28\texport interface ACResult {\n29\t  readonly id: string;\n30\t  readonly description: string;\n31\t  readonly status: string;\n32\t}\n33\t\n34\t/**\n35\t * A single telemetry entry written as one NDJSON line.\n36\t */\n37\texport interface TelemetryEntry {\n38\t  version: 1;\n39\t  timestamp: string;\n40\t  storyKey: string;\n41\t  epicId: string;\n42\t  duration_ms: number;\n43\t  cost_usd: number | null;\n44\t  attempts: number | null;\n45\t  acResults: ACResult[] | null;\n46\t  filesChanged: string[];\n47\t  testResults: TestResultsSummary | null;\n48\t  errors: string[];\n49\t}\n50\t\n51\t// --- Constants ---\n52\t\n53\tconst TELEMETRY_DIR = '.codeharness';\n54\tconst TELEMETRY_FILE = 'telemetry.jsonl';\n55\t\n56\t// --- Functions ---\n57\t\n58\t/**\n59\t * Extract epicId from a storyKey.\n60\t * Pattern: `{epicNum}-{storyNum}-{slug}` -> `{epicNum}`.\n61\t * Sentinel `__run__` -> `\"unknown\"`.\n62\t */\n63\tfunction extractEpicId(storyKey: string): string {\n64\t  if (storyKey === '__run__') return 'unknown';\n65\t  const dash = storyKey.indexOf('-');\n66\t  if (dash === -1) return storyKey;\n67\t  return storyKey.slice(0, dash);\n68\t}\n69\t\n70\t/**\n71\t * Write a telemetry entry after a story completes.\n72\t *\n73\t * Appends one NDJSON line to `.codeharness/telemetry.jsonl`.\n74\t * Creates the `.codeharness/` directory if it does not exist.\n75\t */\n76\texport async function writeTelemetryEntry(ctx: TaskContext): Promise<NullTaskResult> {\n77\t  const epicId = extractEpicId(ctx.storyKey);\n78\t  const contract = ctx.outputContract;\n79\t\n80\t  const entry: TelemetryEntry = {\n81\t    version: 1,\n82\t    timestamp: new Date().toISOString(),\n83\t    storyKey: ctx.storyKey,\n84\t    epicId,\n85\t    duration_ms: ctx.durationMs,\n86\t    cost_usd: ctx.cost ?? null,\n87\t    attempts: null,\n88\t    acResults: contract?.acceptanceCriteria\n89\t      ? (contract.acceptanceCriteria as readonly ACStatus[]).map((ac) => ({\n90\t          id: ac.id,\n91\t          description: ac.description,\n92\t          status: ac.status,\n93\t        }))\n94\t      : null,\n95\t    filesChanged: contract?.changedFiles ? [...contract.changedFiles] : [],\n96\t    testResults: contract?.testResults\n97\t      ? {\n98\t          passed: contract.testResults.passed,\n99\t          failed: contract.testResults.failed,\n100\t          coverage: contract.testResults.coverage,\n101\t        }\n102\t      : null,\n103\t    errors: [],\n104\t  };\n105\t\n106\t  const dir = join(ctx.projectDir, TELEMETRY_DIR);\n107\t  mkdirSync(dir, { recursive: true });\n108\t  appendFileSync(join(dir, TELEMETRY_FILE), JSON.stringify(entry) + '\\n');\n109\t\n110\t  return { success: true, output: `telemetry: entry written for ${ctx.storyKey}` };\n111\t}\n112\t\n113\t/**\n114\t * Read telemetry entries for a specific epic.\n115\t *\n116\t * Returns entries whose `epicId` matches, in insertion order.\n117\t * Returns `[]` if the file does not exist.\n118\t * Skips corrupted (non-JSON) lines silently.\n119\t */\n120\texport function readTelemetryForEpic(epicId: string, projectDir: string): TelemetryEntry[] {\n121\t  const filePath = join(projectDir, TELEMETRY_DIR, TELEMETRY_FILE);\n122\t\n123\t  if (!existsSync(filePath)) return [];\n124\t\n125\t  const content = readFileSync(filePath, 'utf-8');\n126\t  const lines = content.split('\\n').filter((line) => line.trim() !== '');\n127\t  const entries: TelemetryEntry[] = [];\n128\t\n129\t  for (const line of lines) {\n130\t    try {\n131\t      const parsed = JSON.parse(line) as TelemetryEntry;\n132\t      if (parsed.epicId === epicId) {\n133\t        entries.push(parsed);\n134\t      }\n135\t    } catch { // IGNORE: corrupted NDJSON lines are expected and safely skipped per AC #10\n136\t      continue;\n137\t    }\n138\t  }\n139\t\n140\t  return entries;\n141\t}\n142\t"}]},"parent_tool_use_id":"toolu_01MhSojYxQi6QD3G7L9MYQcx","session_id":"187035da-d60e-40cf-8aef-09e6134be246","uuid":"ebe21eda-3492-4786-b60c-7274e9accf13","timestamp":"2026-04-03T19:21:23.725Z"}
