{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UezK9q8CyywYDFmrLHKyjS","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import {\n     3→  formatElapsed,\n     4→  mapSprintStatus,\n     5→  mapSprintStatuses,\n     6→  parseRalphMessage,\n     7→  countStories,\n     8→  buildSpawnArgs,\n     9→} from '../run-helpers.js';\n    10→\n    11→describe('formatElapsed', () => {\n    12→  it('formats 0ms as \"0m\"', () => {\n    13→    expect(formatElapsed(0)).toBe('0m');\n    14→  });\n    15→\n    16→  it('formats sub-minute as \"0m\"', () => {\n    17→    expect(formatElapsed(30_000)).toBe('0m');\n    18→  });\n    19→\n    20→  it('formats 1 minute', () => {\n    21→    expect(formatElapsed(60_000)).toBe('1m');\n    22→  });\n    23→\n    24→  it('formats 47 minutes', () => {\n    25→    expect(formatElapsed(47 * 60_000)).toBe('47m');\n    26→  });\n    27→\n    28→  it('formats 60 minutes as \"1h0m\"', () => {\n    29→    expect(formatElapsed(60 * 60_000)).toBe('1h0m');\n    30→  });"}]},"parent_tool_use_id":"toolu_01V53hNpMF7bCUCk5waNmUeL","session_id":"3e8c45fc-a757-4d77-9a55-f32a41bfdb65","uuid":"6f28b11e-cb04-494f-b8bc-d3544b6775b9","timestamp":"2026-03-21T10:49:17.819Z"}
