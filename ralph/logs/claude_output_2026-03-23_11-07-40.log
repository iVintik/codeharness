{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Np4JJF3YDH4Fg1offccdAq","type":"tool_result","content":"     1в†’import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n     2в†’import { mkdtempSync, rmSync, mkdirSync, writeFileSync, existsSync, readdirSync } from 'node:fs';\n     3в†’import { tmpdir } from 'node:os';\n     4в†’import { join } from 'node:path';\n     5в†’\n     6в†’// Mock child_process\n     7в†’vi.mock('node:child_process', () => ({\n     8в†’  execFileSync: vi.fn(),\n     9в†’}));\n    10в†’\n    11в†’// Mock docker module\n    12в†’vi.mock('../../../lib/docker.js', () => ({\n    13в†’  isDockerAvailable: vi.fn(() => true),\n    14в†’}));\n    15в†’\n    16в†’// Mock state module\n    17в†’vi.mock('../../../lib/state.js', () => ({\n    18в†’  readStateWithBody: vi.fn(() => ({\n    19в†’    state: {\n    20в†’      harness_version: '0.1.0',\n    21в†’      initialized: true,\n    22в†’      stack: 'nodejs',\n    23в†’      enforcement: { frontend: true, database: true, api: true },\n    24в†’      coverage: { target: 90, baseline: null, current: null, tool: 'c8' },\n    25в†’      session_flags: { logs_queried: false, tests_passed: false, coverage_met: false, verification_run: false },\n    26в†’      verification_log: [],\n    27в†’    },\n    28в†’    body: '\\n# Codeharness State\\n',\n    29в†’  })),\n    30в†’  writeState: vi.fn(),\n    31в†’}));\n    32в†’\n    33в†’// Mock stack-detect module\n    34в†’vi.mock('../../../lib/stack-detect.js', () => ({\n    35в†’  detectStack: vi.fn(() => 'nodejs'),\n    36в†’}));\n    37в†’\n    38в†’import { execFileSync } from 'node:child_process';\n    39в†’import { isDockerAvailable } from '../../../lib/docker.js';\n    40в†’import { detectStack } from '../../../lib/stack-detect.js';\n    41в†’import { readStateWithBody, writeState } from '../../../lib/state.js';\n    42в†’import {\n    43в†’  isValidStoryKey,\n    44в†’  computeDistHash,\n    45в†’  buildVerifyImage,\n    46в†’  detectProjectType,\n    47в†’  prepareVerifyWorkspace,\n    48в†’  checkVerifyEnv,\n    49в†’  cleanupVerifyEnv,\n    50в†’  cleanupStaleContainers,\n    51в†’} from '../env.js';\n    52в†’\n    53в†’const mockExecFileSync = vi.mocked(execFileSync);\n    54в†’const mockIsDockerAvailable = vi.mocked(isDockerAvailable);\n    55в†’const mockDetectStack = vi.mocked(detectStack);\n    56в†’const mockReadStateWithBody = vi.mocked(readStateWithBody);\n    57в†’const mockWriteState = vi.mocked(writeState);\n    58в†’\n    59в†’let testDir: string;\n    60в†’\n    61в†’beforeEach(() => {\n    62в†’  vi.clearAllMocks();\n    63в†’  testDir = mkdtempSync(join(tmpdir(), 'ch-verify-env-test-'));\n    64в†’  // Create templates/Dockerfile.verify so buildVerifyImage can find it\n    65в†’  mkdirSync(join(testDir, 'templates'), { recursive: true });\n    66в†’  writeFileSync(join(testDir, 'templates', 'Dockerfile.verify'), 'FROM node:20-slim\\nARG TARBALL=package.tgz\\nCOPY ${TARBALL} /tmp/\\n');\n    67в†’  writeFileSync(join(testDir, 'templates', 'Dockerfile.verify.generic'), 'FROM node:20-slim\\nRUN apt-get update\\n');\n    68в†’  // Reset default mock behaviors after clearAllMocks\n    69в†’  mockIsDockerAvailable.mockReturnValue(true);\n    70в†’  mockDetectStack.mockReturnValue('nodejs');\n    71в†’});\n    72в†’\n    73в†’afterEach(() => {\n    74в†’  rmSync(testDir, { recursive: true, force: true });\n    75в†’});\n    76в†’\n    77в†’// в”Ђв”Ђв”Ђ isValidStoryKey в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n    78в†’\n    79в†’describe('isValidStoryKey', () => {\n    80в†’  it('accepts valid story keys', () => {\n    81в†’    expect(isValidStoryKey('13-1-verification-dockerfile-generator')).toBe(true);\n    82в†’    expect(isValidStoryKey('story_key_123')).toBe(true);\n    83в†’    expect(isValidStoryKey('abc')).toBe(true);\n    84в†’  });\n    85в†’\n    86в†’  it('rejects empty string', () => {\n    87в†’    expect(isValidStoryKey('')).toBe(false);\n    88в†’  });\n    89в†’\n    90в†’  it('rejects path traversal', () => {\n    91в†’    expect(isValidStoryKey('../etc/passwd')).toBe(false);\n    92в†’    expect(isValidStoryKey('foo/../bar')).toBe(false);\n    93в†’  });\n    94в†’\n    95в†’  it('rejects forward slashes', () => {\n    96в†’    expect(isValidStoryKey('foo/bar')).toBe(false);\n    97в†’  });\n    98в†’\n    99в†’  it('rejects backslashes', () => {\n   100в†’    expect(isValidStoryKey('foo\\\\bar')).toBe(false);"}]},"parent_tool_use_id":"toolu_01Kg9tLGsBN5iJa4HVEh4QKa","session_id":"51b9d113-d480-4846-9e18-693f5f89566d","uuid":"379a9a68-30ae-420f-bb74-2dcf1defb5b0","timestamp":"2026-03-23T07:16:25.649Z"}
