riteFileSync(join(testDir, 'package.json'), '{}');\n   435→    await initProject({\n   436→      projectDir: testDir,\n   437→      frontend: true,\n   438→      database: true,\n   439→      api: true,\n   440→      observability: true,\n   441→      observabilityBackend: 'elk',\n   442→      otelEndpoint: 'http://remote:4318',\n   443→    });\n   444→    const state = readState(testDir);\n   445→    expect(state.otlp?.backend).toBe('elk');\n   446→    expect(state.otlp?.mode).toBe('remote-direct');\n   447→  });\n   448→\n   449→  it('defaults to victoria when no --observability-backend flag', async () => {\n   450→    writeFileSync(join(testDir, 'package.json'), '{}');\n   451→    await initProject({\n   452→      projectDir: testDir,\n   453→      frontend: true,\n   454→      database: true,\n   455→      api: true,\n   456→      observability: true,\n   457→    });\n   458→    const state = readState(testDir);\n   459→    expect(state.otlp?.backend).toBe('victoria');\n   460→  });\n   461→\n   462→  it('rejects invalid --observability-backend value', async () => {\n   463→    writeFileSync(join(testDir, 'package.json'), '{}');\n   464→    const result = await initProject({\n   465→      projectDir: testDir,\n   466→      frontend: true,\n   467→      database: true,\n   468→      api: true,\n   469→      observability: true,\n   470→      observabilityBackend: 'foobar' as 'victoria',\n   471→    });\n   472→    expect(result.success).toBe(true);\n   473→    if (result.success) {\n   474→      expect(result.data.status).toBe('fail');\n   475→      expect(result.data.error).toContain('Invalid --observability-backend');\n   476→      expect(result.data.error).toContain('foobar');\n   477→    }\n   478→  });\n   479→});\n   480→\n   481→describe('initProject — unexpected errors', () => {\n   482→  it('returns fail instead of throwing on unexpected error', async () => {\n   483→    // Force an unexpected error by making detectStacks throw\n   484→    mockDetectStacks.mockImplementation(() => { throw new Error('kaboom'); });\n   485→    writeFileSync(join(testDir, 'package.json'), '{}');\n   486→    const result = await initProject({\n   487→      projectDir: testDir,\n   488→      frontend: true,\n   489→      database: true,\n   490→      api: true,\n   491→      observability: false,\n   492→    });\n   493→    expect(result.success).toBe(false);\n   494→    if (!result.success) {\n   495→      expect(result.error).toContain('kaboom');\n   496→    }\n   497→  });\n   498→});\n   499→\n   500→describe('initProject — multi-stack orchestration', () => {\n   501→  const defaultOpts = {\n   502→    projectDir: '', // set in beforeEach via testDir\n   503→    frontend: true,\n   504→    database: true,\n   505→    api: true,\n   506→    observability: true,\n   507→  };\n   508→\n   509→  function makeOpts(overrides: Partial<typeof defaultOpts> = {}) {\n   510→    return { ...defaultOpts, projectDir: testDir, ...overrides };\n   511→  }\n   512→\n   513→  it('calls getCoverageTool() once per detected stack and stores tools map (Task 6)', async () => {\n   514→    writeFileSync(join(testDir, 'package.json'), '{}');\n   515→    writeFileSync(join(testDir, 'Cargo.toml'), '[package]\\nname = \"test\"');\n   516→    mockDetectStacks.mockReturnValue([\n   517→      { stack: 'nodejs', dir: '.' },\n   518→      { stack: 'rust', dir: '.' },\n   519→    ]);\n   520→    mockGetCoverageTool.mockClear();\n   521→\n   522→    await initProject(makeOpts({ observability: false }));\n   523→\n   524→    // getCoverageTool called for each stack in the loop + once for primary stack backward compat\n   525→    const calls = mockGetCoverageTool.mock.calls.map(c => c[0]);\n   526→    expect(calls).toContain('nodejs');\n   527→    expect(calls).toContain('rust');\n   528→\n   529→    // Verify per-stack tools map is persisted in state\n   530→    const state = readState(testDir);\n   531→    expect(state.coverage.tools).toBeDefined();\n   532→    expect(state.coverage.tools!['nodejs']).toBe('c8');\n   533→    expect(state.coverage.tools!['rust']).toBe('cargo-tarpaulin');\n   534→  });\n   535→\n   536→  it('calls instrumentProject() once per detected stack with correct dir (Task 7)', async () => {\n   537→    writeFileSync(join(testDir, 'package.json'), '{}');\n   538→    writeFileSync(join(testDir, 'Cargo.toml'), '[package]\\nname = \"test\"');\n   539→    mockDetectStacks.mockReturnValue([\n   540→      { stack: 'nodejs', dir: '.' },\n   541→      { stack: 'rust', dir: 'services/backend' },\n   542→    ]);\n   543→    mockInstrumentProject.mockClear();\n   544→\n   545→    await initProject(makeOpts({ observability: true }));\n   546→\n   547→    expect(mockInstrumentProject).toHaveBeenCalledTimes(2);\n   548→    // First call: nodejs at project root\n   549→    expect(mockInstrumentProject.mock.calls[0][0]).toBe(testDir);\n   550→    expect(mockInstrumentProject.mock.calls[0][1]).toBe('nodejs');\n   551→    // Second call: rust at subdirectory\n   552→    expect(mockInstrumentProject.mock.calls[1][0]).toBe(join(testDir, 'services/backend'));\n   553→    expect(mockInstrumentProject.mock.calls[1][1]).toBe('rust');\n   554→  });\n   555→\n   556→  it('info output includes all detected stacks label (Task 8)', async () => {\n   557→    writeFileSync(join(testDir, 'package.json'), '{}');\n   558→    writeFileSync(join(testDir, 'Cargo.toml'), '[package]\\nname = \"test\"');\n   559→    mockDetectStacks.mockReturnValue([\n   560→      { stack: 'nodejs', dir: '.' },\n   561→      { stack: 'rust', dir: '.' },\n   562→    ]);\n   563→\n   564→    await initProject(makeOpts({ observability: false }));\n   565→\n   566→    const logCalls = (console.log as ReturnType<typeof vi.fn>).mock.calls.map(\n   567→      (c: unknown[]) => String(c[0])\n   568→    );\n   569→    const stackLine = logCalls.find((l: string) => l.includes('Stack detected:'));\n   570→    expect(stackLine).toBeDefined();\n   571→    expect(stackLine).toContain('Node.js (package.json)');\n   572→    expect(stackLine).toContain('Rust (Cargo.toml)');\n   573→  });\n   574→\n   575→  it('state file has stacks array and app_type from primary stack (Task 9)', async () => {\n   576→    writeFileSync(join(testDir, 'package.json'), '{}');\n   577→    writeFileSync(join(testDir, 'Cargo.toml'), '[package]\\nname = \"test\"');\n   578→    mockDetectStacks.mockReturnValue([\n   579→      { stack: 'nodejs', dir: '.' },\n   580→      { stack: 'rust', dir: '.' },\n   581→    ]);\n   582→\n   583→    await initProject(makeOpts({ observability: false }));\n   584→\n   585→    const state = readState(testDir);\n   586→    expect(state.stacks).toEqual(['nodejs', 'rust']);\n   587→    expect(state.app_type).toBeDefined();\n   588→    // Primary stack coverage tool should be set for backward compat\n   589→    expect(state.coverage.tool).toBe('c8'); // nodejs primary\n   590→  });\n   591→\n   592→  it('single-stack backward compat — single-stack project still works identically (Task 10)', async () => {\n   593→    writeFileSync(join(testDir, 'package.json'), '{}');\n   594→    mockDetectStacks.mockReturnValue([{ stack: 'nodejs', dir: '.' }]);\n   595→    mockInstrumentProject.mockClear();\n   596→\n   597→    const result = await initProject(makeOpts({ observability: true }));\n   598→\n   599→    expect(result.success).toBe(true);\n   600→    if (result.success) {\n   601→      expect(result.data.stack).toBe('nodejs');\n   602→      expect(result.data.stacks).toEqual(['nodejs']);\n   603→    }\n   604→\n   605→    const state = readState(testDir);\n   606→    expect(state.stack).toBe('nodejs');\n   607→    expect(state.stacks).toEqual(['nodejs']);\n   608→    expect(state.coverage.tool).toBe('c8');\n   609→\n   610→    // instrumentProject called exactly once for single stack\n   611→    expect(mockInstrumentProject).toHaveBeenCalledTimes(1);\n   612→    expect(mockInstrumentProject.mock.calls[0][1]).toBe('nodejs');\n   613→  });\n   