2\t      const health: BarrelDriverHealth = {\n493\t        available: true,\n494\t        authenticated: true,\n495\t        version: '1.0',\n496\t      };\n497\t      const caps: BarrelDriverCapabilities = {\n498\t        supportsPlugins: true,\n499\t        supportsStreaming: true,\n500\t        costReporting: true,\n501\t      };\n502\t      const cat: BarrelErrorCategory = 'RATE_LIMIT';\n503\t      const tr: BarrelTestResults = { passed: 1, failed: 0, coverage: null };\n504\t      const ac: BarrelACStatus = {\n505\t        id: '1',\n506\t        description: 'd',\n507\t        status: 'passed',\n508\t      };\n509\t      const contract: BarrelOutputContract = {\n510\t        version: 1,\n511\t        taskName: 't',\n512\t        storyId: 's',\n513\t        driver: 'd',\n514\t        model: 'm',\n515\t        timestamp: 'ts',\n516\t        cost_usd: null,\n517\t        duration_ms: 0,\n518\t        changedFiles: [],\n519\t        testResults: tr,\n520\t        output: '',\n521\t        acceptanceCriteria: [ac],\n522\t      };\n523\t      const opts: BarrelDispatchOpts = {\n524\t        prompt: 'p',\n525\t        model: 'm',\n526\t        cwd: '/',\n527\t        sourceAccess: true,\n528\t        outputContract: contract,\n529\t      };\n530\t      const driver: BarrelAgentDriver = {\n531\t        name: 'barrel',\n532\t        defaultModel: 'model',\n533\t        capabilities: caps,\n534\t        async healthCheck() {\n535\t          return health;\n536\t        },\n537\t        async *dispatch(_o: BarrelDispatchOpts) {\n538\t          yield { type: 'result' as const, cost: 0, sessionId: '' };\n539\t        },\n540\t        getLastCost: () => null,\n541\t      };\n542\t\n543\t      expect(health.available).toBe(true);\n544\t      expect(caps.supportsPlugins).toBe(true);\n545\t      expect(cat).toBe('RATE_LIMIT');\n546\t      expect(opts.prompt).toBe('p');\n547\t      expect(contract.version).toBe(1);\n548\t      expect(driver.name).toBe('barrel');\n549\t    });\n5