me).toBe('implement');\n585\t    expect(writtenState.tasks_completed[0].story_key).toBe('5-1-foo');\n586\t  });\n587\t\n588\t  it('cleans up workspace on dispatch error when source_access is false', async () => {\n589\t    const mockWorkspace = {\n590\t      dir: '/tmp/test',\n591\t      storyFilesDir: '/tmp/test/story-files',\n592\t      verdictDir: '/tmp/test/verdict',\n593\t      toDispatchOptions: () => ({ cwd: '/tmp/test' }),\n594\t      cleanup: vi.fn().mockResolvedValue(undefined),\n595\t    };\n596\t    mockCreateIsolatedWorkspace.mockResolvedValue(mockWorkspace);\n597\t    mockDriverDispatch.mockImplementation(() => makeDriverStreamError(new Error('dispatch failed')));\n598\t"}]},"parent_tool_use_id":"toolu_01SkXPMmo5ukZsEWidXQjyr7","session_id":"d2473842-56c4-49f2-ab43-68fabe9113bb","uuid":"51d7160a-5820-4d7c-9f2b-b0ef3b6e5424","timestamp":"2026-04-03T10:58:31.824Z"}
