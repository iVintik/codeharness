urns results', () => {\n   282→    // All tools already installed\n   283→    mockExecFileSync.mockReturnValue(Buffer.from('tool 1.0.0'));\n   284→\n   285→    const results = installAllDependencies({});\n   286→    expect(results).toHaveLength(DEPENDENCY_REGISTRY.length);\n   287→    expect(results.every(r => r.status === 'already-installed')).toBe(true);\n   288→  });\n   289→\n   290→  it('does not throw when all deps fail (none are critical)', () => {\n   291→    mockExecFileSync.mockImplementation(() => {\n   292→      throw new Error('command failed');\n   293→    });\n   294→\n   295→    const results = installAllDependencies({});\n   296→    expect(results.every(r => r.status === 'failed')).toBe(true);\n   297→  });\n   298→\n   299→  it('throws CriticalDependencyError when a critical dep fails to install', () => {\n   300→    // Temporarily mutate the first registry entry to be critical\n   301→    const registry = DEPENDENCY_REGISTRY as unknown as Array<{ critical: boolean }>;\n   302→    const originalCritical = registry[0].critical;\n   303→    registry[0].critical = true;\n   304→\n   305→    try {\n   306→      // All commands fail — first dep (showboat) is now critical\n   307→      mockExecFileSync.mockImplementation(() => {\n   308→        throw new Error('command failed');\n   309→      });\n   310→\n   311→      expect(() => installAllDependencies({})).toThrow(CriticalDependencyError);\n   312→      expect(() => installAllDependencies({})).toThrow(/Showboat/);\n   313→    } finally {\n   314→      // Restore original value\n   315→      registry[0].critical = originalCritical;\n   316→    }\n   317→  });\n   318→\n   319→  it('continues when non-critical dep fails', () => {\n   320→    mockExecFileSync.mockImplementation((cmd, args) => {\n   321→      const cmdStr = typeof cmd === 'string' ? cmd : cmd.toString();\n   322→      const argsArr = Array.isArray(args) ? args.map(String) : [];\n   323→\n   324→      // showboat check and install both fail\n   325→      if (cmdStr === 'showboat') throw new Error('not found');\n   326→      // agent-browser check and install both fail\n   327→      if (cmdStr === 'agent-browser') throw new Error('not found');\n   328→      // npm install commands fail (for agent-browser and bats)\n   329→      if (cmdStr === 'npm') throw new Error('not found');\n   330→      // semgrep check and install both fail\n   331→      if (cmdStr === 'semgrep') throw new Error('not found');\n   332→      // bats check fails, brew fails (npm already covered above)\n   333→      if (cmdStr === 'bats') throw new Error('not found');\n   334→      if (cmdStr === 'brew') throw new Error('not found');\n   335→      // pip/pipx for showboat/semgrep fail, for beads we don't reach (already installed)\n   336→      if ((cmdStr === 'pip' || cmdStr === 'pipx') && argsArr.some(a => a.includes('showboat') || a.includes('semgrep'))) {\n   337→        throw new Error('not found');\n   338→      }\n   339→      // beads check succeeds\n   340→      if (cmdStr === 'bd') {\n   341→        return Buffer.from('bd 1.0.0');\n   342→      }\n   343→      throw new Error('unexpected');\n   344→    });\n   345→\n   346→    // Should not throw because showboat, agent-browser, semgrep, and bats are non-critical,\n   347→    // and beads is already installed\n   348→    const results = installAllDependencies({});\n   349→    const failed = results.filter(r => r.status === 'failed');\n   350→    expect(failed.length).toBeGreaterThanOrEqual(1);\n   351→    const beadsResult = results.find(r => r.name === 'beads');\n   352→    expect(beadsResult?.status).toBe('already-installed');\n   353→  });\n   354→\n   355→  it('prints OK messages for installed dependencies (non-json mode)', () => {\n   356→    const logSpy = vi.spyOn(console, 'log');\n   357→    mockExecFileSync.mockReturnValue(Buffer.from('tool 1.0.0'));\n   358→\n   359→    installAllDependencies({ json: false });\n   360→\n   361→    const calls = logSpy.mock.calls.