{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019BAt9fmifpF7tGbp6S6Fj5","type":"tool_result","content":"     1→/**\n     2→ * Docker container cleanup utilities.\n     3→ *\n     4→ * NOTE: Primary cleanup logic lives in src/modules/infra/container-cleanup.ts.\n     5→ * These stubs exist to satisfy the domain directory structure.\n     6→ * TODO: Consolidate cleanup logic here if container-cleanup.ts is refactored.\n     7→ */\n     8→\n     9→import { isDockerAvailable } from './health.js';\n    10→\n    11→/**\n    12→ * Cleans up orphaned containers left behind by previous codeharness runs.\n    13→ * Returns the number of containers removed.\n    14→ */\n    15→export function cleanupOrphanedContainers(): number {\n    16→  if (!isDockerAvailable()) {\n    17→    return 0;\n    18→  }\n    19→  // Cleanup logic currently lives in src/modules/infra/container-cleanup.ts\n    20→  // This is a placeholder for future consolidation\n    21→  return 0;\n    22→}\n    23→\n    24→/**\n    25→ * Cleans up Docker artifacts created during verify-env runs.\n    26→ */\n    27→export function cleanupVerifyEnv(): void {\n    28→  // Placeholder — verify-env cleanup is handled inline in the verify module\n    29→}\n    30→"}]},"parent_tool_use_id":"toolu_01LE7RFzUgPSCiom8nKkvXNg","session_id":"174e0897-5fbc-4ae0-bbc6-8b881d5c7525","uuid":"4f9fac27-b8e7-4626-8978-22db352741de","timestamp":"2026-03-24T22:42:01.749Z"}
