{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01S1QzptRXVtixCyBxhCGvT6","type":"tool_result","content":"     1→/**\n     2→ * Ralph prompt template — generates the prompt that instructs each\n     3→ * Claude Code iteration to run /harness-run for sprint execution.\n     4→ */\n     5→\n     6→export interface RalphPromptConfig {\n     7→  projectDir: string;\n     8→  sprintStatusPath: string;\n     9→  retryCount?: number;\n    10→  currentStoryKey?: string;\n    11→  flaggedStories?: string[];\n    12→}\n    13→\n    14→const PROMPT_TEMPLATE = `You are an autonomous coding agent executing a sprint for the codeharness project.\n    15→\n    16→## Your Mission\n    17→\n    18→Run the \\`/harness-run\\` command to execute the next story in the sprint.\n    19→\n    20→## Instructions\n    21→\n    22→1. **Run \\`/harness-run\\`** — this is the sprint execution skill that:\n    23→   - Reads sprint-status.yaml at \\`{{sprintStatusPath}}\\` to find the next story\n    24→   - Picks the first story with status NOT \\`done\\` (handles \\`backlog\\`, \\`ready-for-dev\\`, \\`in-progress\\`, \\`review\\`, and \\`verified\\`)\n    25→   - Executes the appropriate BMAD workflow for the story's current status\n    26→   - Updates sprint-status.yaml when the story is complete\n    27→\n    28→2. **Follow all BMAD workflows** — the /harness-run skill handles this, but if prompted:\n    29→   - Use \\`/bmad-dev-story\\` for implementation\n    30→   - Use code-review workflow for quality checks\n    31→   - Ensure tests pass and coverage meets targets\n    32→\n    33→3. **Update sprint-status.yaml** — after each story completes, the skill updates\n    34→   the story status to \\`done\\` in \\`{{sprintStatusPath}}\\`.\n    35→\n    36→4. **Do not skip verification** — every story must pass verification gates\n    37→   (tests, coverage, showboat proof) before being marked done.\n    38→\n    39→## Verification Gates\n    40→\n    41→After completing a story, run \\`codeharness verify --story <id>\\` to verify.\n    42→If verification fails, fix the issues and re-verify. The story is not done\n    43→until verification passes.\n    44→\n    45→## Project Context\n    46→\n    47→- **Project directory:** \\`{{projectDir}}\\`\n    48→- **Sprint status:** \\`{{sprintStatusPath}}\\`\n    49→\n    50→## Important\n    51→\n    52→- Do NOT implement your own task-picking logic. Let /harness-run handle it.\n    53→- Do NOT modify sprint-status.yaml directly. Let the skill manage it.\n    54→- Focus on one story per session. Ralph will spawn a new session for the next story.\n    55→`;\n    56→\n    57→/**\n    58→ * Generates the prompt content for a Ralph iteration.\n    59→ * Interpolates project-specific paths into the template.\n    60→ * Optionally includes retry context and flagged story information.\n    61→ */\n    62→export function generateRalphPrompt(config: RalphPromptConfig): string {\n    63→  let prompt = PROMPT_TEMPLATE\n    64→    .replace(/\\{\\{projectDir\\}\\}/g, config.projectDir)\n    65→    .replace(/\\{\\{sprintStatusPath\\}\\}/g, config.sprintStatusPath);\n    66→\n    67→  // Add retry context if retrying a story\n    68→  if (config.retryCount && config.retryCount > 0 && config.currentStoryKey) {\n    69→    prompt += `\\n## Retry Context\\n\\n`;\n    70→    prompt += `This is retry attempt **${config.retryCount}** for story \\`${config.currentStoryKey}\\`. `;\n    71→    prompt += `Previous attempts did not complete verification. Focus on fixing the remaining issues.\\n`;\n    72→  }\n    73→\n    74→  // Add flagged stories if any\n    75→  if (config.flaggedStories && config.flaggedStories.length > 0) {\n    76→    prompt += `\\n## Flagged Stories (Skip These)\\n\\n`;\n    77→    prompt += `The following stories have exceeded the retry limit and should be skipped:\\n`;\n    78→    for (const story of config.flaggedStories) {\n    79→      prompt += `- \\`${story}\\`\\n`;\n    80→    }\n    81→  }\n    82→\n    83→  return prompt;\n    84→}\n    85→"}]},"parent_tool_use_id":"toolu_0184tJvxCPux1RS3fH2NtyBW","session_id":"01503c00-15e6-46f1-b837-b4628ff69656","uuid":"f62b4a34-dec1-4afd-b17d-a859b8ddb1b7","timestamp":"2026-03-24T11:47:28.860Z"}
