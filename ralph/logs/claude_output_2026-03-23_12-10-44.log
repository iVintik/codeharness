{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ee56aK63NDZ3wrFNx5EymL","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→import { mkdtempSync, rmSync, existsSync, writeFileSync } from 'node:fs';\n     3→import { tmpdir } from 'node:os';\n     4→import { join } from 'node:path';\n     5→\n     6→vi.mock('../../../lib/templates.js', () => ({\n     7→  generateFile: vi.fn((_path: string, _content: string) => {\n     8→    // Simulate file creation for test assertions\n     9→    const { mkdirSync, writeFileSync } = require('node:fs');\n    10→    const { dirname } = require('node:path');\n    11→    mkdirSync(dirname(_path), { recursive: true });\n    12→    writeFileSync(_path, _content);\n    13→  }),\n    14→}));\n    15→\n    16→vi.mock('../../../templates/readme.js', () => ({\n    17→  readmeTemplate: vi.fn(() => '# Test README\\n'),\n    18→}));\n    19→\n    20→import {\n    21→  getProjectName,\n    22→  getStackLabel,\n    23→  getCoverageTool,\n    24→  generateAgentsMdContent,\n    25→  generateDocsIndexContent,\n    26→  scaffoldDocs,\n    27→} from '../docs-scaffold.js';\n    28→\n    29→let testDir: string;\n    30→\n    31→beforeEach(() => {\n    32→  testDir = mkdtempSync(join(tmpdir(), 'ch-docs-test-'));\n    33→  vi.restoreAllMocks();\n    34→  vi.spyOn(console, 'log').mockImplementation(() => {});\n    35→});\n    36→\n    37→afterEach(() => {\n    38→  rmSync(testDir, { recursive: true, force: true });\n    39→});\n    40→\n    41→import { afterEach } from 'vitest';\n    42→\n    43→describe('getProjectName', () => {\n    44→  it('returns name from package.json', () => {\n    45→    writeFileSync(join(testDir, 'package.json'), JSON.stringify({ name: 'my-project' }));\n    46→    expect(getProjectName(testDir)).toBe('my-project');\n    47→  });\n    48→\n    49→  it('falls back to basename when no package.json', () => {\n    50→    const name = getProjectName(testDir);\n    51→    expect(typeof name).toBe('string');\n    52→    expect(name.length).toBeGreaterThan(0);\n    53→  });\n    54→\n    55→  it('falls back to basename when package.json has no name', () => {\n    56→    writeFileSync(join(testDir, 'package.json'), '{}');\n    57→    const name = getProjectName(testDir);\n    58→    expect(typeof name).toBe('string');\n    59→  });\n    60→\n    61→  it('returns name from Cargo.toml [package] section when no package.json', () => {\n    62→    writeFileSync(join(testDir, 'Cargo.toml'), '[package]\\nname = \"myapp\"\\nversion = \"0.1.0\"\\n');\n    63→    expect(getProjectName(testDir)).toBe('myapp');\n    64→  });\n    65→\n    66→  it('returns package.json name over Cargo.toml name (precedence)', () => {\n    67→    writeFileSync(join(testDir, 'package.json'), JSON.stringify({ name: 'npm-name' }));\n    68→    writeFileSync(join(testDir, 'Cargo.toml'), '[package]\\nname = \"rust-name\"\\nversion = \"0.1.0\"\\n');\n    69→    expect(getProjectName(testDir)).toBe('npm-name');\n    70→  });\n    71→\n    72→  it('falls back to basename when Cargo.toml has name only in [dependencies]', () => {\n    73→    writeFileSync(\n    74→      join(testDir, 'Cargo.toml'),\n    75→      '[dependencies]\\nname = \"dep-name\"\\nversion = \"0.1.0\"\\n',\n    76→    );\n    77→    const name = getProjectName(testDir);\n    78→    // Should NOT return 'dep-name' — no [package] section\n    79→    expect(name).not.toBe('dep-name');\n    80→    expect(typeof name).toBe('string');\n    81→    expect(name.length).toBeGreaterThan(0);\n    82→  });\n    83→\n    84→  it('falls back to basename when Cargo.toml is malformed', () => {\n    85→    writeFileSync(join(testDir, 'Cargo.toml'), 'this is not valid toml!!!');\n    86→    const name = getProjectName(testDir);\n    87→    expect(typeof name).toBe('string');\n    88→    expect(name.length).toBeGreaterThan(0);\n    89→  });\n    90→});\n    91→\n    92→describe('getStackLabel', () => {\n    93→  it('returns Node.js label for nodejs stack', () => {\n    94→    expect(getStackLabel('nodejs')).toBe('Node.js (package.json)');\n    95→  });\n    96→\n    97→  it('returns Python label for python stack', () => {\n    98→    expect(getStackLabel('python')).toBe('Python');\n    99→  });\n   100→\n   101→  it('returns Unknown for null stack', () => {\n   102→    expect(getStackLabel(null)).toBe('Unknown');\n   103→  });\n   104→\n   105→  it('returns Rust label for rust stack', () => {\n   106→    expect(getStackLabel('rust')).toBe('Rust (Cargo.toml)');\n   107→  });\n   108→});\n   109→\n   110→describe('getCoverageTool', () => {\n   111→  it('returns c8 for nodejs', () => {\n   112→    expect(getCoverageTool('nodejs')).toBe('c8');\n   113→  });\n   114→\n   115→  it('returns coverage.py for python', () => {\n   116→    expect(getCoverageTool('python')).toBe('coverage.py');\n   117→  });\n   118→\n   119→  it('returns c8 for null', () => {\n   120→    expect(getCoverageTool(null)).toBe('c8');\n   121→  });\n   122→\n   123→  it('returns cargo-tarpaulin for rust', () => {\n   124→    expect(getCoverageTool('rust')).toBe('cargo-tarpaulin');\n   125→  });\n   126→});\n   127→\n   128→describe('generateAgentsMdContent', () => {\n   129→  it('includes project name', () => {\n   130→    const content = generateAgentsMdContent(testDir, 'nodejs');\n   131→    expect(content).toContain('# ');\n   132→  });\n   133→\n   134→  it('includes Node.js commands for nodejs stack', () => {\n   135→    const content = generateAgentsMdContent(testDir, 'nodejs');\n   136→    expect(content).toContain('npm install');\n   137→    expect(content).toContain('npm test');\n   138→  });\n   139→\n   140→  it('includes Python commands for python stack', () => {\n   141→    const content = generateAgentsMdContent(testDir, 'python');\n   142→    expect(content).toContain('pip install');\n   143→    expect(content).toContain('pytest');\n   144→  });\n   145→\n   146→  it('includes generic message for unknown stack', () => {\n   147→    const content = generateAgentsMdContent(testDir, null);\n   148→    expect(content).toContain('No recognized stack');\n   149→  });\n   150→\n   151→  it('includes Rust commands for rust stack', () => {\n   152→    const content = generateAgentsMdContent(testDir, 'rust');\n   153→    expect(content).toContain('cargo build');\n   154→    expect(content).toContain('cargo test');\n   155→    expect(content).toContain('cargo tarpaulin');\n   156→  });\n   157→\n   158→  it('labels Rust stack correctly', () => {\n   159→    const content = generateAgentsMdContent(testDir, 'rust');\n   160→    expect(content).toContain('Rust');\n   161→  });\n   162→});\n   163→\n   164→describe('generateDocsIndexContent', () => {\n   165→  it('includes documentation sections', () => {\n   166→    const content = generateDocsIndexContent();\n   167→    expect(content).toContain('Planning Artifacts');\n   168→    expect(content).toContain('Execution');\n   169→    expect(content).toContain('Quality');\n   170→  });\n   171→});\n   172→\n   173→describe('scaffoldDocs', () => {\n   174→  it('creates AGENTS.md when it does not exist', async () => {\n   175→    const result = await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: false });\n   176→    expect(result.success).toBe(true);\n   177→    if (result.success) {\n   178→      expect(result.data.agents_md).toBe('created');\n   179→    }\n   180→  });\n   181→\n   182→  it('reports exists when AGENTS.md already exists', async () => {\n   183→    writeFileSync(join(testDir, 'AGENTS.md'), '# existing');\n   184→    const result = await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: false });\n   185→    expect(result.success).toBe(true);\n   186→    if (result.success) {\n   187→      expect(result.data.agents_md).toBe('exists');\n   188→    }\n   189→  });\n   190→\n   191→  it('creates docs scaffold when docs/ does not exist', async () => {\n   192→    const result = await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: false });\n   193→    expect(result.success).toBe(true);\n   194→    if (result.success) {\n   195→      expect(result.data.docs_scaffold).toBe('created');\n   196→    }\n   197→  });\n   198→\n   199→  it('creates README.md when it does not exist', async () => {\n   200→    const result = await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: false });\n   201→    expect(result.success).toBe(true);\n   202→    if (result.success) {\n   203→      expect(result.data.readme).toBe('created');\n   204→    }\n   205→  });\n   206→\n   207→  it('reports exists when README.md already exists', async () => {\n   208→    writeFileSync(join(testDir, 'README.md'), '# existing');\n   209→    const result = await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: false });\n   210→    expect(result.success).toBe(true);\n   211→    if (result.success) {\n   212→      expect(result.data.readme).toBe('exists');\n   213→    }\n   214→  });\n   215→\n   216→  it('suppresses console output in json mode', async () => {\n   217→    const spy = vi.spyOn(console, 'log');\n   218→    await scaffoldDocs({ projectDir: testDir, stack: 'nodejs', isJson: true });\n   219→    // In json mode, no [OK]/[INFO] messages should be printed\n   220→    const calls = spy.mock.calls.map(c => c[0] as string);\n   221→    const outputCalls = calls.filter(c => c && (c.startsWith('[OK]') || c.startsWith('[INFO]')));\n   222→    expect(outputCalls).toHaveLength(0);\n   223→  });\n   224→});\n   225→"}]},"parent_tool_use_id":"toolu_01Pjqm6RwzFUa1tNdjiqKz4j","session_id":"9c50fb69-0476-4a5d-8998-78fcdfa47c24","uuid":"b003b258-36fb-4432-8b0f-76aebb94377b","timestamp":"2026-03-23T08:18:17.850Z"}
