352→      - File List includes every new/modified/deleted file (relative paths)\n   353→      - Dev Agent Record contains implementation notes\n   354→      - Change Log includes summary of changes\n   355→      - Only permitted story sections were modified\n   356→    </action>\n   357→\n   358→    <!-- Mark story ready for review - sprint status conditional -->\n   359→    <check if=\"{sprint_status} file exists AND {{current_sprint_status}} != 'no-sprint-tracking'\">\n   360→      <action>Load the FULL file: {sprint_status}</action>\n   361→      <action>Find development_status key matching {{story_key}}</action>\n   362→      <action>Verify current status is \"in-progress\" (expected previous state)</action>\n   363→      <action>Update development_status[{{story_key}}] = \"review\"</action>\n   364→      <action>Save file, preserving ALL comments and structure including STATUS DEFINITIONS</action>\n   365→      <output>✅ Story status updated to \"review\" in sprint-status.yaml</output>\n   366→    </check>\n   367→\n   368→    <check if=\"{sprint_status} file does NOT exist OR {{current_sprint_status}} == 'no-sprint-tracking'\">\n   369→      <output>ℹ️ Story status updated to \"review\" in story file (no sprint tracking configured)</output>\n   370→    </check>\n   371→\n   372→    <check if=\"story key not found in sprint status\">\n   373→      <output>⚠️ Story file updated, but sprint-status update failed: {{story_key}} not found\n   374→\n   375→        Story status is set to \"review\" in file, but sprint-status.yaml may be out of sync.\n   376→      </output>\n   377→    </check>\n   378→\n   379→    <!-- Final validation gates -->\n   380→    <action if=\"any task is incomplete\">HALT - Complete remaining tasks before marking ready for review</action>\n   381→    <action if=\"regression failures exist\">HALT - Fix regression issues before completing</action>\n   382→    <action if=\"File List is incomplete\">HALT - Update File List with all changed file