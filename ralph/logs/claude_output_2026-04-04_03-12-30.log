{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015m2uxnJPC3J2RjPYmqPp7J","type":"tool_result","content":"1\t/**\n2\t * Telemetry Writer.\n3\t *\n4\t * Writes structured NDJSON telemetry entries after each story completes.\n5\t * Entries are appended to `.codeharness/telemetry.jsonl` for later analysis\n6\t * by epic retros — no per-session LLM cost.\n7\t *\n8\t * @see Story 16-3: Telemetry Writer\n9\t */\n10\t\n11\timport { appendFileSync, existsSync, mkdirSync, readFileSync } from 'node:fs';\n12\timport { join } from 'node:path';\n13\t\n14\timport type { ACStatus, TestResults } from './agents/types.js';\n15\timport type { TaskContext, NullTaskResult } from './null-task-registry.js';\n16\t\n17\t// --- Interfaces ---\n18\t\n19\t/**\n20\t * Re-export TestResults as TestResultsSummary for backward compatibility.\n21\t * Telemetry entries use the same shape as the agent driver's TestResults.\n22\t */\n23\texport type TestResultsSummary = TestResults;\n24\t\n25\t/**\n26\t * Acceptance criteria result stored in telemetry.\n27\t */\n28\texport interface ACResult {\n29\t  readonly id: string;\n30\t  readonly description: string;\n31\t  readonly status: string;\n32\t}\n33\t\n34\t/**\n35\t * A single telemetry entry written as one NDJSON line.\n36\t */\n37\texport interface TelemetryEntry {\n38\t  version: 1;\n39\t  timestamp: string;\n40\t  storyKey: string;\n41\t  epicId: string;\n42\t  duration_ms: number;\n43\t  cost_usd: number | null;\n44\t  attempts: number | null;\n45\t  acResults: ACResult[] | null;\n46\t  filesChanged: string[];\n47\t  testResults: TestResultsSummary | null;\n48\t  errors: string[];\n49\t}\n50\t\n51\t// --- Constants ---\n52\t\n53\tconst TELEMETRY_DIR = '.codeharness';\n54\tconst TELEMETRY_FILE = 'telemetry.jsonl';\n55\t\n56\t// --- Functions ---\n57\t\n58\t/**\n59\t * Extract epicId from a storyKey.\n60\t * Pattern: `{epicNum}-{storyNum}-{slug}` -> `{epicNum}`.\n61\t * Sentinel `__run__` -> `\"unknown\"`.\n62\t */\n63\tfunction extractEpicId(storyKey: string): string {\n64\t  if (storyKey === '__run__') return 'unknown';\n65\t  const dash = storyKey.indexOf('-');\n66\t  if (dash === -1) return storyKey;\n67\t  return storyKey.slice(0, dash);\n68\t}\n69\t\n70\t/**\n71\t * Write a telemetry entry after a story completes.\n72\t *\n73\t * Appends one NDJSON line to `.codeharness/telemetry.jsonl`.\n74\t * Creates the `.codeharness/` directory if it does not exist.\n75\t */\n76\texport async function writeTelemetryEntry(ctx: TaskContext): Promise<NullTaskResult> {\n77\t  const epicId = extractEpicId(ctx.storyKey);\n78\t  const contract = ctx.outputContract;\n79\t\n80\t  const entry: TelemetryEntry = {"}]},"parent_tool_use_id":"toolu_012S3gEG5fgffqjQviRFDsvE","session_id":"d383a9e0-3bc4-4a94-aaff-6965a5cc223b","uuid":"bfab3384-2c0b-4592-84c3-51501a8bf1ec","timestamp":"2026-04-03T23:27:43.784Z"}
