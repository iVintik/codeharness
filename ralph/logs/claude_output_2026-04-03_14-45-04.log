rse.mockReturnValue({\n2096\t      development_status: {\n2097\t        '5-1-a': 'ready-for-dev',\n2098\t        '5-2-b': 'ready-for-dev',\n2099\t        '5-3-c': 'ready-for-dev',\n2100\t        '5-4-d': 'ready-for-dev',\n2101\t        '5-5-e': 'ready-for-dev',\n2102\t      },\n2103\t    });\n2104\t\n2105\t    mockReadWorkflowState.mockReturnValue(\n2106\t      makeDefaultState({\n2107\t        phase: 'executing',\n2108\t        started: '2026-04-03T00:00:00Z',\n2109\t        tasks_completed: [\n2110\t          { task_name: 'implement', story_key: '5-1-a', completed_at: '2026-04-03T00:00:00Z' },\n2111\t          { task_name: 'implement', story_key: '5-2-b', completed_at: '2026-04-03T00:01:00Z' },\n2112\t          { task_name: 'implement', story_key: '5-3-c', completed_at: '2026-04-03T00:02:00Z' },\n2113\t        ],\n2114\t      }),\n2115\t    );\n2116\t\n2117\t    const config = makeConfig({\n2118\t      workflow: {\n2119\t        tasks: { implement: makeTask() },\n2120\t        flow: ['implement'],\n2121\t      },\n2122\t    });\n2123\t\n2124\t    const result = await executeWorkflow(config);\n2125\t\n2126\t    // Only 2 dispatches for 5-4-d and 5-5-e\n2127\t    expect(mockDriverDispatch).toHaveBeenCalledTimes(2);\n2128\t    expect(result.tasksCompleted).toBe(2);\n2129\t  });\n2130\t\n2131\t  it('skips all per-story tasks and proceeds to per-run verify (AC #3)', async () => {\n2132\t    // All per-story implement tasks done, verify not done\n2133\t    mockReadWorkflowState.mockReturnValue(\n2134\t      makeDefaultState({\n2135\t        phase: 'executing',\n2136\t        started: '2026-04-03T00:00:00Z',\n2137\t        tasks_completed: [\n2138\t          { task_name: 'implement', story_key: '5-1-foo', completed_at: '2026-04-03T00:00:00Z' },\n2139\t          { task_name: 'implement', story_key: '5-2-bar', completed_at: '2026-04-03T00:01:00Z' },\n2140\t        ],\n2141\t      }),\n2142\t    );\n2143\t\n2144\t    const config = makeConfig({\n2145\t      workflow: {\n2146\t        tasks: {\n2147\t          implement: makeTask(),\n2148\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n2149\t        },\n2150\t        flow: ['implement', 'verify'],\n2151\t      },\n2152\t    });\n2153\t\n2154\t    const result = await executeWorkflow(config);\n2155\t\n2156\t    // Only 1 dispatch for verify (implement skipped for both stories)\n2157\t    expect(mockDriverDispatch).toHaveBeenCalledTimes(1);\n2158\t    expect(result.tasksCompleted).toBe(1);\n2159\t  });\n2160\t\n2161\t  it('phase: completed returns early with tasksCompleted: 0 (AC #6)', async () => {\n2162\t    mockReadWorkflowState.mockReturnValue(\n2163\t      makeDefaultState({\n2164\t        phase: 'completed',\n2165\t        started: '2026-04-03T00:00:00Z',\n2166\t      }),\n2167\t    );\n2168\t\n2169\t    const config = makeConfig();\n2170\t    const result = await executeWorkflow(config);\n2171\t\n2172\t    expect(result.success).toBe(true);\n2173\t    expect(result.tasksCompleted).toBe(0);\n2174\t    expect(result.storiesProcessed).toBe(0);\n2175\t    expect(result.errors).toEqual([]);\n2176\t    expect(result.durationMs).toBe(0);\n2177\t    // Should not dispatch anything or write state\n2178\t    expect(mockDriverDispatch).not.toHaveBeenCalled();\n2179\t    expect(mockWriteWorkflowState).not.toHaveBeenCalled();\n2180\t  });\n2181\t\n2182\t  it('tuple matching: (\"implement\", \"3-1-foo\") does NOT skip (\"verify\", \"3-1-foo\") (AC #7)', async () => {\n2183\t    // Only implement for 5-1-foo is done. verify for 5-1-foo should still execute.\n2184\t    mockParse.mockReturnValue({\n2185\t      development_status: { '5-1-foo': 'ready-for-dev' },\n2186\t    });\n2187\t\n2188\t    mockReadWorkflowState.mockReturnValue(\n2189\t      makeDefaultState({\n2190\t        phase: 'executing',\n2191\t        started: '2026-04-03T00:00:00Z',\n2192\t        tasks_completed: [\n2193\t          { task_name: 'implement', story_key: '5-1-foo', completed_at: '2026-04-03T00: