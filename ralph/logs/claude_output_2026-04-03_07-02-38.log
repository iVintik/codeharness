{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UHNtRcv2uAhHL6MsxRUKmS","type":"tool_result","content":"1\timport { existsSync } from 'node:fs';\n2\timport { join } from 'node:path';\n3\timport { Command } from 'commander';\n4\timport { fail, info, ok } from '../lib/output.js';\n5\timport { isDockerAvailable } from '../lib/docker/index.js';\n6\timport { cleanupContainers } from '../modules/infra/index.js';\n7\timport { readSprintStatusFromState, reconcileState } from '../modules/sprint/index.js';\n8\timport { countStories, formatElapsed } from '../lib/run-helpers.js';\n9\timport { parseWorkflow, resolveWorkflow } from '../lib/workflow-parser.js';\n10\timport { resolveAgent, compileSubagentDefinition } from '../lib/agent-resolver.js';\n11\timport { executeWorkflow } from '../lib/workflow-engine.js';\n12\timport { readWorkflowState, writeWorkflowState } from '../lib/workflow-state.js';\n13\timport type { EngineConfig } from '../lib/workflow-engine.js';\n14\timport type { SubagentDefinition } from '../lib/agent-resolver.js';\n15\t\n16\t/** Resolves the plugin directory path (.claude/ in project root). */\n17\texport function resolvePluginDir(): string {\n18\t  return join(process.cwd(), '.claude');\n19\t}\n20\t\n21\t// Re-export helpers that tests import from run.ts\n22\texport { countStories } from '../lib/run-helpers.js';\n23\t\n24\texport function registerRunCommand(program: Command): void {\n25\t  program\n26\t    .command('run')\n27\t    .description('Execute the autonomous coding loop')\n28\t    .option('--max-iterations <n>', 'Maximum loop iterations', '50')\n29\t    .option('--timeout <seconds>', 'Total loop timeout in seconds', '43200')\n30\t    .option('--iteration-timeout <minutes>', 'Per-iteration timeout in minutes', '30')\n31\t    .option('--quiet', 'Suppress terminal output (background mode)', false)\n32\t    .option('--calls <n>', 'Max API calls per hour', '100')\n33\t    .option('--max-story-retries <n>', 'Max retries per story before flagging', '10')\n34\t    .option('--reset', 'Clear retry counters, flagged stories, and circuit breaker before starting', false)\n35\t    .option('--resume', 'Resume from last checkpoint (engine resumes by default)', false)\n36\t    .action(async (options, cmd) => {\n37\t      const globalOpts = cmd.optsWithGlobals();\n38\t      const isJson = !!globalOpts.json;\n39\t      const outputOpts = { json: isJson };\n40\t\n41\t      // 1. Resolve plugin directory\n42\t      const pluginDir = resolvePluginDir();\n43\t      if (!existsSync(pluginDir)) {\n44\t        fail('Plugin directory not found — run codeharness init first', outputOpts);\n45\t        process.exitCode = 1;\n46\t        return;\n47\t      }\n48\t\n49\t      // 1b. Reconcile state (best-effort — failures warn but don't abort)\n50\t      const reconciliation = reconcileState();\n51\t      if (reconciliation.success && reconciliation.data.corrections.length > 0) {\n52\t        for (const correction of reconciliation.data.corrections) {\n53\t          info(`[INFO] Reconciled: ${correction}`, outputOpts);\n54\t        }\n55\t      } else if (!reconciliation.success) {\n56\t        info(`[WARN] State reconciliation failed: ${reconciliation.error}`, outputOpts);\n57\t      }\n58\t\n59\t      // 1c. Docker pre-flight: fail fast if Docker unavailable\n60\t      if (!isDockerAvailable()) {\n61\t        fail('[FAIL] Docker not available — install Docker or start the daemon', outputOpts);\n62\t        process.exitCode = 1;\n63\t        return;\n64\t      }\n65\t      // 1d. Orphan container cleanup (best-effort — failures warn but don't abort)\n66\t      const cleanup = cleanupContainers();\n67\t      if (cleanup.success && cleanup.data.containersRemoved > 0) {\n68\t        info(`[INFO] Cleaned up ${cleanup.data.containersRemoved} orphaned container(s): ${cleanup.data.names.join(', ')}`, outputOpts);\n69\t      } else if (!cleanup.success) {\n70\t        info(`[WARN] Container cleanup failed: ${cleanup.error}`, outputOpts);\n71\t      }\n72\t      // 2. Read sprint status for story count (from sprint-state.json)\n73\t      const statuses = readSprintStatusFromState();\n74\t      const counts = countStories(statuses);\n75\t\n76\t      if (counts.total === 0) {\n77\t        fail('No stories found in sprint-state.json — nothing to execute', outputOpts);\n78\t        process.exitCode = 1;\n79\t        return;\n80\t      }\n81\t\n82\t      if (counts.ready === 0) {\n83\t        fail('No stories ready for execution', outputOpts);\n84\t        process.exitCode = 1;\n85\t        return;\n86\t      }\n87\t\n88\t      info(`Starting autonomous execution — ${counts.ready} ready, ${counts.inProgress} in progress, ${counts.verified} verified, ${counts.done}/${counts.total} done`, outputOpts);\n89\t      // 3. Parse and validate numeric options\n90\t      const maxIterations = parseInt(options.maxIterations, 10);\n91\t      const timeout = parseInt(options.timeout, 10);\n92\t      const iterationTimeout = parseInt(options.iterationTimeout, 10);\n93\t      const calls = parseInt(options.calls, 10);\n94\t      const maxStoryRetries = parseInt(options.maxStoryRetries, 10);\n95\t      if (isNaN(maxIterations) || isNaN(timeout) || isNaN(iterationTimeout) || isNaN(calls) || isNaN(maxStoryRetries)) {\n96\t        fail('Invalid numeric option — --max-iterations, --timeout, --iteration-timeout, --calls, and --max-story-retries must be numbers', outputOpts);\n97\t        process.exitCode = 1;\n98\t        return;\n99\t      }\n100\t\n101\t      // 4. Resolve workflow (embedded -> user patch -> project patch)\n102\t      const projectDir = process.cwd();\n103\t\n104\t      let parsedWorkflow;\n105\t      try {\n106\t        parsedWorkflow = resolveWorkflow({ cwd: projectDir });\n107\t      } catch (err: unknown) {\n108\t        // Fallback: try direct file parsing for backward compatibility\n109\t        const projectWorkflowPath = join(projectDir, '.codeharness', 'workflows', 'default.yaml');\n110\t        const templateWorkflowPath = join(projectDir, 'templates', 'workflows', 'default.yaml');\n111\t        const workflowPath = existsSync(projectWorkflowPath) ? projectWorkflowPath : templateWorkflowPath;\n112\t        try {\n113\t          parsedWorkflow = parseWorkflow(workflowPath);\n114\t        } catch (fallbackErr: unknown) {\n115\t          const msg = err instanceof Error ? err.message : String(err);\n116\t          fail(`Failed to resolve workflow: ${msg}`, outputOpts);\n117\t          process.exitCode = 1;\n118\t          return;\n119\t        }\n120\t      }"}]},"parent_tool_use_id":"toolu_01ChyoLDPrvpbR13hYNAz6e8","session_id":"c2800ecc-75a3-43b2-b3d8-396855aa3c3c","uuid":"19fe8999-5056-42e6-8509-3433c9090b29","timestamp":"2026-04-03T03:04:25.696Z"}
