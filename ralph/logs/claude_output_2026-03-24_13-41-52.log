nc(join(testDir, 'requirements.txt'), '', 'utf-8');\n    46→    expect(detectStack(testDir)).toBe('nodejs');\n    47→  });\n    48→\n    49→  it('returns null when stacks only exist in subdirectories (root-only compat)', () => {\n    50→    mkdirSync(join(testDir, 'backend'), { recursive: true });\n    51→    writeFileSync(join(testDir, 'backend', 'Cargo.toml'), '[package]\\nname = \"api\"\\n');\n    52→    const result = detectStack(testDir);\n    53→    expect(result).toBeNull();\n    54→  });\n    55→});\n    56→\n    57→describe('detectStacks', () => {\n    58→  // AC1: dual root stacks\n    59→  it('detects multiple stacks at root (package.json + Cargo.toml)', () => {\n    60→    writeFileSync(join(testDir, 'package.json'), '{}', 'utf-8');\n    61→    writeFileSync(join(testDir, 'Cargo.toml'), '[package]\\nname = \"foo\"\\n');\n    62→    const result = detectStacks(testDir);\n    63→    expect(result).toEqual([\n    64→      { stack: 'nodejs', dir: '.' },\n    65→      { stack: 'rust', dir: '.' },\n    66→    ]);\n    67→  });\n    68→\n    69→  it('detects all three stacks at root', () => {\n    70→    writeFileSync(join(testDir, 'package.json'), '{}', 'utf-8');\n    71→    writeFileSync(join(testDir, 'requirements.txt'), '', 'utf-8');\n    72→    writeFileSync(join(testDir, 'Cargo.toml'), '[package]\\nname = \"foo\"\\n');\n    73→    const result = detectStacks(testDir);\n    74→    expect(result).toEqual([\n    75→      { stack: 'nodejs', dir: '.' },\n    76→      { stack: 'python', dir: '.' },\n    77→      { stack: 'rust', dir: '.' },\n    78→    ]);\n    79→  });\n    80→\n    81→  // AC2: monorepo layout\n    82→  it('detects stacks in subdirectories (monorepo layout)', () => {\n    83→    mkdirSync(join(testDir, 'frontend'), { recursive: true });\n    84→    mkdirSync(join(testDir, 'backend'), { recursive: true });\n    85→    writeFileSync(join(testDir, 'frontend', 'package.json'), '{}', 'utf-8');\n    86→    writeFileSync(join(testDir, 'backend', 'Cargo.toml'), '[package]\\nname = \"api\"\\n');\n    87→    const result = detectStacks(testDir);\n    88→    expect(result).toEqual([\n    89→      { stack: 'rust', dir: 'backend' },\n    90→      { stack: 'nodejs', dir: 'frontend' },\n    91→    ]);\n    92→  });\n    93→\n    94→  // AC3: single-stack compat\n    95→  it('returns single entry for single-stack project', () => {\n    96→    writeFileSync(join(testDir, 'package.json'), '{}', 'utf-8');\n    97→    const result = detectStacks(testDir);\n    98→    expect(result).toEqual([{ stack: 'nodejs', dir: '.' }]);\n    99→  });\n   100→\n   101→  // AC4: empty directory\n   102→  it('returns empty array for empty directory', () => {\n   103→    const result = detectStacks(testDir);\n   104→    expect(result).toEqual([]);\n   105→  });\n   106→\n   107→  // AC5: skip list enforcement\n   108→  it('skips node_modules during subdirectory scan', () => {\n   109→    mkdirSync(join(testDir, 'node_modules', 'some-package'), { recursive: true });\n   110→    writeFileSync(join(testDir, 'node_modules', 'some-package', 'Cargo.toml'), '[package]\\nname = \"fake\"\\n');\n   111→    const result = detectStacks(testDir);\n   112→    expect(result).toEqual([]);\n   113→  });\n   114→\n   115→  it('skips .git directory during subdirectory scan', () => {\n   116→    mkdirSync(join(testDir, '.git', 'hooks'), { recursive: true });\n   117→    writeFileSync(join(testDir, '.git', 'package.json'), '{}', 'utf-8');\n   118→    const result = detectStacks(testDir);\n   119→    expect(result).toEqual([]);\n   120→  });\n   121→\n   122→  it('skips target directory during subdirectory scan', () => {\n   123→    mkdirSync(join(testDir, 'target', 'debug'), { recursive: true });\n   124→    writeFileSync(join(testDir, 'target', 'Cargo.toml'), '[package]\\nname = \"fake\"\\n');\n   125→    const result = detectStacks(testDir);\n   126→    expect(result).toEqual([]);\n   127→  });\n   128→\n   129→  it('skips __pycache__ directory during subdire