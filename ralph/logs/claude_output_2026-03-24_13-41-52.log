n    88→    observabilityCount,\n    89→    otherCount,\n    90→    grepRatio,\n    91→    acsMissingDockerExec,\n    92→  };\n    93→}\n    94→\n    95→/** Checks if [FAIL] appears outside code blocks and inline code. */\n    96→function hasFailVerdict(section: string): boolean {\n    97→  return section.replace(/```[\\s\\S]*?```/g, '').replace(/`[^`]+`/g, '').includes('[FAIL]');\n    98→}\n    99→\n   100→/** Validates proof quality. `passed` is true when `pending === 0 && verified > 0`. */\n   101→export function validateProofQuality(proofPath: string): ProofQuality {\n   102→  const emptyResult: ProofQuality = {\n   103→    verified: 0, pending: 0, escalated: 0, total: 0, passed: false,\n   104→    grepSrcCount: 0, dockerExecCount: 0, observabilityCount: 0, otherCount: 0,\n   105→    blackBoxPass: false,\n   106→  };\n   107→\n   108→  if (!existsSync(proofPath)) {\n   109→    return emptyResult;\n   110→  }\n   111→\n   112→  const content = readFileSync(proofPath, 'utf-8');\n   113→\n   114→  // Compute black-box enforcement metrics once\n   115→  // Skip enforcement for unit-testable proofs — they use vitest/node, not docker exec\n   116→  const bbTierMatch = /\\*\\*Tier:\\*\\*\\s*(unit-testable|black-box)/i.exec(content);\n   117→  const bbIsUnitTestable = bbTierMatch ? bbTierMatch[1].toLowerCase() === 'unit-testable' : false;\n   118→  const bbEnforcement = bbIsUnitTestable\n   119→    ? { blackBoxPass: true, grepSrcCount: 0, dockerExecCount: 0, observabilityCount: 0, otherCount: 0, grepRatio: 0, acsMissingDockerExec: [] as number[] }\n   120→    : checkBlackBoxEnforcement(content);\n   121→\n   122→  /** Helper: merge base counts with black-box metrics */\n   123→  function buildResult(base: {\n   124→    verified: number; pending: number; escalated: number; total: number;\n   125→  }): ProofQuality {\n   126→    const basePassed = base.pending === 0 && base.verified > 0;\n   127→    return {\n   128→      ...base,\n   129→      passed: basePassed && bbEnf