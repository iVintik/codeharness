 completed_at: '2026-04-03T00:00:00.000Z',\n250\t          session_id: sessionId,\n251\t        },\n252\t      ],\n253\t    }),\n254\t  );\n255\t\n256\t  // Driver mock: returns an async iterable of StreamEvents\n257\t  mockDriverDispatch.mockImplementation(() => {\n258\t    return (async function* () {\n259\t      yield { type: 'text', text: 'Done' };\n260\t      yield { type: 'result', cost: 0.05, sessionId: 'sess-abc-123' };\n261\t    })();\n262\t  });\n263\t\n264\t  mockGetDriver.mockReturnValue({\n265\t    name: 'claude-code',\n266\t    defaultModel: 'claude-sonnet-4-20250514',\n267\t    capabilities: { supportsPlugins: true, supportsStreaming: true, costReporting: true },\n268\t    healthCheck: vi.fn().mockResolvedValue({ available: true, authenticated: true, version: '1.0.0' }),\n269\t    dispatch: mockDriverDispatch,\n270\t    getLastCost: vi.fn().mockReturnValue(null),\n271\t  });\n272\t\n273\t  mockResolveModel.mockReturnValue('claude-sonnet-4-20250514');\n274\t\n275\t  // Keep legacy mock for backward compat in any test that still references it\n276\t  mockDispatchAgent.mockResolvedValue({\n277\t    sessionId: 'sess-abc-123',\n278\t    success: true,\n279\t    durationMs: 1000,\n280\t    output: 'Done',\n281\t  });\n282\t\n283\t  // Default: sprint-status.yaml exists with two stories\n284\t  mockExistsSync.mockImplementation((path: string) => {\n285\t    if (path === '/project/sprint-status.yaml') return true;\n286\t    return false;\n287\t  });\n288\t\n289\t  mockReadFileSync.mockReturnValue('dummy yaml');\n290\t  mockParse.mockReturnValue({\n291\t    development_status: {\n292\t      'epic-5': 'backlog',\n293\t      '5-1-foo': 'ready-for-dev',\n294\t      '5-2-bar': 'backlog',\n295\t    },\n296\t  });\n297\t}\n298\t\n299\t// --- Tests ---\n300\t\n301\tdescribe('loadWorkItems', () => {\n302\t  beforeEach(() => {\n303\t    vi.clearAllMocks();\n304\t  });\n305\t\n306\t  it('loads stories from sprint-status.yaml excluding epics and retrospectives', () => {\n307\t    mockExistsSync.mockReturnValue(true);\n308\t    mockReadFileSync.mockReturnValue('yaml content');\n309\t    mockParse.mockReturnValue({\n310\t      development_status: {\n311\t        'epic-5': 'backlog',\n312\t        '5-1-foo': 'ready-for-dev',\n313\t        '5-2-bar': 'backlog',\n314\t        '5-3-baz': 'done',\n315\t        'epic-5-retrospective': 'backlog',\n316\t      },\n317\t    });\n318\t\n319\t    const items = loadWorkItems('/path/sprint-status.yaml');\n320\t\n321\t    expect(items).toEqual([\n322\t      { key: '5-1-foo', source: 'sprint' },\n323\t      { key: '5-2-bar', source: 'sprint' },\n324\t    ]);\n325\t  });\n326\t\n327\t  it('returns empty array when sprint-status.yaml does not exist and no issues.yaml', () => {\n328\t    mockExistsSync.mockReturnValue(false);\n329\t\n330\t    const items = loadWorkItems('/nonexistent/sprint-status.yaml');\n331\t    expect(items).toEqual([]);\n332\t  });\n333\t\n334\t  it('returns stories only when issues.yaml does not exist (AC #6)', () => {\n335\t    mockExistsSync.mockImplementation((path: string) => {\n336\t      if (path === '/path/sprint-status.yaml') return true;\n337\t      return false;\n338\t    });\n339\t    mockReadFileSync.mockReturnValue('yaml');\n340\t    mockParse.mockReturnValue({\n341\t      development_status: {\n342\t        '3-1-foo': 'ready-for-dev',\n343\t      },\n344\t    });\n345\t\n346\t    const items = loadWorkItems('/path/sprint-status.yaml', '/path/issues.yaml');\n347\t\n348\t    expect(items).toEqual([{ key: '3-1-foo', source: 'sprint' }]);\n349\t  });\n350\t\n351\t  it('loads both stories and issues when issues.yaml exists (AC #5)', () => {\n352\t    mockExistsSync.mockReturnValue(true);\n353\t    mockReadFileSync.mockReturnValue('yaml');\n354\t    mockParse\n355\t      .mockReturnValueOnce({\n356\t        development_status: {\n357\t          '3-1-foo': 'ready-for-dev',\n358\t        },\n359\t      })\n360\t      .mockReturnValueOnce({\n361\t        issues: [\n362\t          { id: 'issue-001', title: 'Fix docker timeout', status: 'ready-for-dev' },\n363\t          { id: 'issue-002', title: 'Already done', status: 'done' },\n364\t        ],\n365\t      });\n366\t\n367\t    const items = loadWorkItems('/path/sprint-status.yaml', '/path/issues.yaml');\n368\t\n369\t    expect(items).toEqual([\n370\t      { key: '3-1-foo', source: 'sprint' },\n371\t      { key: 'issue-001', title: 'Fix docker timeout', source: 'issues' },\n372\t    ]);\n373\t  });\n374\t\n375\t  it('handles invalid YAML in sprint-status.yaml gracefully', () => {\n376\t    mockExistsSync.mockReturnValue(true);\n377\t    mockReadFileSync.mockReturnValue('yaml');\n378\t    mockParse.mockImplementation(() => {\n379\t      throw new Error('bad yaml');\n380\t    });\n381\t\n382\t    const items = loadWorkItems('/path/sprint-status.yaml');\n383\t    expect(items).toEqual([]);\n384\t    expect(mockWarn).toHaveBeenCalled();\n385\t  });\n386\t\n387\t  it('handles unreadable sprint-status.yaml file gracefully', () => {\n388\t    mockExistsSync.mockReturnValue(true);\n389\t    mockReadFileSync.mockImplementation(() => {\n390\t      throw new Error('EACCES: permission denied');\n391\t    });\n392\t\n393\t    const items = loadWorkItems('/path/sprint-status.yaml');\n394\t    expect(items).toEqual([]);\n395\t    expect(mockWarn).toHaveBeenCalledWith(\n396\t      expect.stringContaining('could not read sprint-status.yaml'),\n397\t    );\n398\t  });\n399\t"}]},"parent_tool_use_id":"toolu_01SkXPMmo5ukZsEWidXQjyr7","session_id":"d2473842-56c4-49f2-ab43-68fabe9113bb","uuid":"e622b974-e0d3-4f36-bf4e-9a1d36e9b1cb","timestamp":"2026-04-03T10:58:27.812Z"}
