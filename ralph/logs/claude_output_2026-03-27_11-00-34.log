{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ULkSD3ZZCyurEg6DPYryRh","type":"tool_result","content":"     1→/**\n     2→ * Project initialization orchestrator.\n     3→ * Composes sub-steps: stack detection, deps, Docker, BMAD, beads, state, docs, OTLP.\n     4→ */\n     5→\n     6→import { existsSync } from 'node:fs';\n     7→import { basename, join } from 'node:path';\n     8→import { ok as okOutput, fail as failOutput, info, warn, jsonOutput } from '../../lib/output.js';\n     9→import { detectStacks, detectAppType } from '../../lib/stacks/index.js';\n    10→import { readState, writeState, getDefaultState, getStatePath } from '../../lib/state.js';\n    11→import type { HarnessState } from '../../lib/state.js';\n    12→import { instrumentProject } from '../../lib/observability/index.js';\n    13→import type { Result } from '../../types/result.js';\n    14→import { ok, fail, isOk } from '../../types/result.js';\n    15→import type { InitOptions, InitResult } from './types.js';\n    16→import { checkDocker, setupDocker } from './docker-setup.js';\n    17→import { installDeps, verifyDeps } from './deps-install.js';\n    18→import { setupBmad, verifyBmadOnRerun } from './bmad-setup.js';\n    19→import { initializeBeads } from './beads-init.js';\n    20→import { scaffoldDocs, getCoverageTool, getStackLabel } from './docs-scaffold.js';\n    21→import { generateDockerfileTemplate } from './dockerfile-template.js';\n    22→\n    23→declare const __PKG_VERSION__: string;\n    24→const HARNESS_VERSION = typeof __PKG_VERSION__ !== 'undefined' ? __PKG_VERSION__ : '0.0.0-dev';\n    25→\n    26→/** Helper: build a fail-status InitResult for early returns */\n    27→function failResult(opts: InitOptions, error: string): InitResult {\n    28→  return {\n    29→    status: 'fail', stack: null, stacks: [], error,\n    30→    enforcement: { frontend: opts.frontend, database: opts.database, api: opts.api },\n    31→    documentation: { agents_md: 'skipped', docs_scaffold: 'skipped', readme: 'skipped' },\n    32→  };\n    33→}\n    34→\n    35→/** Output error and set exit code for validation/critical failures */\n    36→function emitError(error: string, isJson: boolean): void {\n    37→  if (isJson) { jsonOutput({ status: 'fail', error }); } else { failOutput(error); }\n    38→  process.exitCode = 1;\n    39→}\n    40→\n    41→/** Main project initialization orchestrator. Never throws — returns fail() on unexpected errors. */\n    42→export async function initProject(opts: InitOptions): Promise<Result<InitResult>> {\n    43→  try {\n    44→    return await initProjectInner(opts);\n    45→  } catch (err) {\n    46→    const message = err instanceof Error ? err.message : String(err);\n    47→    return fail(`Unexpected init error: ${message}`);\n    48→  }\n    49→}\n    50→\n    51→async function initProjectInner(opts: InitOptions): Promise<Result<InitResult>> {\n    52→  const { projectDir, json: isJson = false } = opts;\n    53→  const result: InitResult = {\n    54→    status: 'ok', stack: null, stacks: [],\n    55→    enforcement: { frontend: opts.frontend, database: opts.database, api: opts.api },\n    56→    documentation: { agents_md: 'skipped', docs_scaffold: 'skipped', readme: 'skipped' },\n    57→  };\n    58→\n    59→  // --- Idempotent re-run check ---\n    60→  const rerunResult = handleRerun(opts, result);\n    61→  if (rerunResult !== null) return rerunResult;\n    62→\n    63→  // --- Observability backend validation ---\n    64→  const validBackends = ['victoria', 'elk', 'none'] as const;\n    65→  if (opts.observabilityBackend !== undefined && !validBackends.includes(opts.observabilityBackend)) {\n    66→    const msg = `Invalid --observability-backend '${opts.observabilityBackend}'. Must be one of: ${validBackends.join(', ')}`;\n    67→    emitError(msg, isJson); return ok(failResult(opts, msg));\n    68→  }\n    69→\n    70→  // --- Remote endpoint URL validation ---\n    71→  const urlError = validateRemoteUrls(opts);\n    72→  if (urlError !== null) { emitError(urlError, isJson); return ok(failResult(opts, urlError)); }\n    73→\n    74→  // --- Stack detection ---\n    75→  // Call detectStacks() once; derive primary root stack from it to avoid double filesystem scan\n    76→  const allStacks = detectStacks(projectDir);\n    77→  const rootDetection = allStacks.find(s => s.dir === '.');\n    78→  const stack = rootDetection ? rootDetection.stack : null;\n    79→  if (!stack && !isJson) warn('No recognized stack detected');\n    80→  result.stack = stack;\n    81→  result.stacks = [...new Set(allStacks.map(s => s.stack))];\n    82→  const appType = detectAppType(projectDir, stack);\n    83→  result.app_type = appType;\n    84→  if (!isJson) {\n    85→    if (result.stacks.length > 0) {\n    86→      info(`Stack detected: ${getStackLabel(result.stacks)}`);\n    87→    } else if (stack) {\n    88→      info(`Stack detected: ${getStackLabel(stack)}`);\n    89→    }\n    90→    info(`App type: ${appType}`);\n    91→  }\n    92→\n    93→  // --- Dockerfile template generation ---\n    94→  const dfResult = generateDockerfileTemplate(projectDir, allStacks);\n    95→  if (isOk(dfResult)) {\n    96→    result.dockerfile = { generated: true, stack: dfResult.data.stack, stacks: dfResult.data.stacks };\n    97→    if (!isJson) info(`Generated Dockerfile for ${dfResult.data.stacks.join('+') || dfResult.data.stack} project.`);\n    98→  } else {\n    99→    if (!isJson) info('Dockerfile already exists -- skipping template generation.');\n   100→  }\n   101→\n   102→  // --- Docker check ---\n   103→  const dockerCheck = checkDocker({ observability: opts.observability, otelEndpoint: opts.otelEndpoint, logsUrl: opts.logsUrl, opensearchUrl: opts.opensearchUrl, isJson });\n   104→  if (!isOk(dockerCheck)) return fail(dockerCheck.error);\n   105→  const { available: dockerAvailable, criticalFailure, dockerResult: criticalDockerResult } = dockerCheck.data;\n   106→  if (criticalFailure) {\n   107→    result.status = 'fail'; result.error = 'Docker not installed'; result.docker = criticalDockerResult;\n   108→    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); }\n   109→    else { failOutput('Docker not installed'); info('\\u2192 Install Docker: https://docs.docker.com/engine/install/'); info('\\u2192 Or skip observability: codeharness init --no-observability'); }\n   110→    process.exitCode = 1;\n   111→    return ok(result);\n   112→  }\n   113→\n   114→  // --- Dependency install ---\n   115→  const depResult = installDeps({ isJson });\n   116→  if (!isOk(depResult)) {\n   117→    result.status = 'fail'; result.error = depResult.error;\n   118→    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); } else { info('Critical dependency failed — aborting init'); }\n   119→    process.exitCode = 1;\n   120→    return ok(result);\n   121→  }\n   122→  result.dependencies = depResult.data;\n   123→\n   124→  // --- Beads initialization ---\n   125→  result.beads = initializeBeads(projectDir, isJson);\n   126→\n   127→  // --- BMAD installation ---\n   128→  const bmadResult = setupBmad({ projectDir, isJson });\n   129→  if (isOk(bmadResult)) result.bmad = bmadResult.data;\n   130→\n   131→  // --- State file creation ---\n   132→  let state: HarnessState = getDefaultState(stack);\n   133→  state.harness_version = HARNESS_VERSION;\n   134→  state.initialized = true;\n   135→  state.app_type = appType;\n   136→  state.enforcement = { frontend: opts.frontend, database: opts.database, api: opts.api };\n   137→  // Per-stack coverage detection: build tools map keyed by stack name, primary stack's tool for backward compat\n   138→  const coverageTools: Record<string, string> = {};\n   139→  for (const detection of allStacks) {\n   140→    coverageTools[detection.stack] = getCoverageTool(detection.stack);\n   141→  }\n   142→  state.coverage.tool = getCoverageTool(stack);\n   143→  state.coverage.tools = coverageTools;\n   144→  // Persist all detected stacks (not just the primary root stack)\n   145→  state.stacks = result.stacks as import('../../lib/stacks/index.js').StackName[];\n   146→  writeState(state, projectDir);\n   147→  if (!isJson) okOutput('State file: .claude/codeharness.local.md created');\n   148→\n   149→  // --- Documentation scaffold ---\n   150→  const docsResult = await scaffoldDocs({ projectDir, stack, stacks: allStacks, isJson });\n   151→  if (isOk(docsResult)) result.documentation = docsResult.data;\n   152→\n   153→  // --- Store observability backend choice ---\n   154→  const obsBackend = opts.observabilityBackend ?? 'victoria';\n   155→  if (obsBackend === 'none') {\n   156→    // 'none' backend: disable OTLP and skip Docker, similar to --no-observability but persisted\n   157→    state.otlp = { enabled: false, endpoint: '', service_name: basename(projectDir), mode: 'local-shared', backend: 'none' };\n   158→    writeState(state, projectDir);\n   159→    result.otlp = { status: 'skipped', packages_installed: false, start_script_patched: false, env_vars_configured: false };\n   160→    if (!isJson) info('Observability: disabled (--observability-backend none)');\n   161→    // Skip enforcement summary for 'none' — jump to end\n   162→    if (!isJson) {\n   163→      const e = state.enforcement;\n   164→      const fmt = (v: boolean): string => v ? 'ON' : 'OFF';\n   165→      okOutput(`Enforcement: frontend:${fmt(e.frontend)} database:${fmt(e.database)} api:${fmt(e.api)} observability:OFF`);\n   166→      info('Harness initialized. Run: codeharness bridge --epics <path>');\n   167→    }\n   168→    if (isJson) jsonOutput(result as unknown as Record<string, unknown>);\n   169→    return ok(result);\n   170→  }\n   171→\n   172→  // --- OTLP instrumentation ---\n   173→  if (!opts.observability) {\n   174→    result.otlp = { status: 'skipped', packages_installed: false, start_script_patched: false, env_vars_configured: false };\n   175→    if (!isJson) info('OTLP: skipped (--no-observability)');\n   176→  } else {\n   177→    // Per-stack OTLP instrumentation: instrument each detected stack in its directory\n   178→    for (const detection of allStacks) {\n   179→      const stackDir = detection.dir === '.' ? projectDir : join(projectDir, detection.dir);\n   180→      const stackOtlp = instrumentProject(stackDir, detection.stack, { json: isJson, appType });\n   181→      // Primary (root) stack's result goes to result.otlp for backward compat\n   182→      if (detection.dir === '.' && detection.stack === stack) {\n   183→        result.otlp = stackOtlp;\n   184→      }\n   185→    }\n   186→    // Fallback: if primary stack wasn't in allStacks (shouldn't happen), use single-stack call\n   187→    if (!result.otlp) {\n   188→      result.otlp = instrumentProject(projectDir, stack, { json: isJson, appType });\n   189→    }\n   190→  }\n   191→\n   192→  // Re-read state to pick up otlp changes written by instrumentProject\n   193→  try { const u = readState(projectDir); if (u.otlp) state.otlp = u.otlp; } catch { /* IGNORE: state re-read may fail during init */ }\n   194→  if (!state.otlp) {\n   195→    state.otlp = { enabled: true, endpoint: 'http://localhost:4318', service_name: basename(projectDir), mode: 'local-shared' };\n   196→  }\n   197→  state.otlp.backend = obsBackend;\n   198→  writeState(state, projectDir);\n   199→\n   200→  // --- Docker stack setup ---\n   201→  const dockerSetup = setupDocker({\n   202→    observability: opts.observability, otelEndpoint: opts.otelEndpoint,\n   203→    opensearchUrl: opts.opensearchUrl,\n   204→    logsUrl: opts.logsUrl, metricsUrl: opts.metricsUrl, tracesUrl: opts.tracesUrl,\n   205→    isJson, dockerAvailable, appType, state, projectDir,\n   206→  });\n   207→  if (isOk(dockerSetup)) result.docker = dockerSetup.data.docker;\n   208→\n   209→  // --- Enforcement summary ---\n   210→  if (!isJson) {\n   211→    const e = state.enforcement;\n   212→    const fmt = (v: boolean): string => v ? 'ON' : 'OFF';\n   213→    okOutput(`Enforcement: frontend:${fmt(e.frontend)} database:${fmt(e.database)} api:${fmt(e.api)} observability:ON`);\n   214→    info('Harness initialized. Run: codeharness bridge --epics <path>');\n   215→  }\n   216→  if (isJson) jsonOutput(result as unknown as Record<string, unknown>);\n   217→\n   218→  return ok(result);\n   219→}\n   220→\n   221→function handleRerun(opts: InitOptions, result: InitResult): Result<InitResult> | null {\n   222→  const { projectDir, json: isJson = false } = opts;\n   223→  if (!existsSync(getStatePath(projectDir))) return null;\n   224→\n   225→  try {\n   226→    const existingState = readState(projectDir);\n   227→    const legacyObsDisabled = (existingState.enforcement as Record<string, unknown>).observability === false;\n   228→    if (!existingState.initialized || legacyObsDisabled) {\n   229→      if (legacyObsDisabled && !isJson) info('Observability upgraded from disabled to enabled');\n   230→      return null;\n   231→    }\n   232→    result.stack = existingState.stack;\n   233→    result.stacks = existingState.stacks ?? [];\n   234→    result.enforcement = existingState.enforcement;\n   235→    result.documentation = { agents_md: 'exists', docs_scaffold: 'exists', readme: 'exists' };\n   236→    result.dependencies = verifyDeps(isJson);\n   237→    result.docker = existingState.docker\n   238→      ? { compose_file: existingState.docker.compose_file, stack_running: existingState.docker.stack_running, services: [], ports: existingState.docker.ports }\n   239→      : null;\n   240→    const bmadResult = verifyBmadOnRerun(projectDir, isJson);\n   241→    if (bmadResult) result.bmad = bmadResult;\n   242→    if (isJson) { jsonOutput(result as unknown as Record<string, unknown>); }\n   243→    else { info('Harness already initialized — verifying configuration'); okOutput('Configuration verified'); }\n   244→    return ok(result);\n   245→  } catch {\n   246→    // IGNORE: re-init check may fail, non-fatal\n   247→    return null;\n   248→  }\n   249→}\n   250→\n   251→/** Returns error message string if validation fails, null if OK */\n   252→function validateRemoteUrls(opts: InitOptions): string | null {\n   253→  const remoteUrls = [opts.otelEndpoint, opts.opensearchUrl, opts.logsUrl, opts.metricsUrl, opts.tracesUrl].filter(Boolean) as string[];\n   254→  for (const url of remoteUrls) {\n   255→    if (!/^https?:\\/\\//i.test(url)) return `Invalid URL: '${url}' \\u2014 must start with http:// or https://`;\n   256→  }\n   257→  if (opts.otelEndpoint && (opts.logsUrl || opts.metricsUrl || opts.tracesUrl)) {\n   258→    return 'Cannot combine --otel-endpoint with --logs-url/--metrics-url/--traces-url';\n   259→  }\n   260→  const hasAny = opts.logsUrl || opts.metricsUrl || opts.tracesUrl;\n   261→  if (hasAny && !(opts.logsUrl && opts.metricsUrl && opts.tracesUrl)) {\n   262→    return 'When using remote backends, all three are required: --logs-url, --metrics-url, --traces-url';\n   263→  }\n   264→  return null;\n   265→}\n   266→"}]},"parent_tool_use_id":"toolu_01MwzbgNwEhenGxNXV9UQBeX","session_id":"507a8d0b-20bb-4c55-954f-5f817ca0f972","uuid":"8d87c972-642f-4a54-92b7-5fc734813d3b","timestamp":"2026-03-27T07:03:58.103Z"}
