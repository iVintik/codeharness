{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FZHpBC6tpbrgeE88tdjg2c","type":"tool_result","content":"     1→/**\n     2→ * Story file acceptance criteria parser.\n     3→ * Reads story markdown files and extracts numbered ACs with type classification.\n     4→ */\n     5→\n     6→import { existsSync, readFileSync } from 'node:fs';\n     7→import { warn } from '../../lib/output.js';\n     8→import type { ParsedAC, Verifiability, VerificationStrategy, ObservabilityGapResult, ObservabilityGapEntry } from './types.js';\n     9→\n    10→// ─── Keywords for Classification ────────────────────────────────────────────\n    11→\n    12→const UI_KEYWORDS = [\n    13→  'agent-browser',\n    14→  'screenshot',\n    15→  'navigate',\n    16→  'click',\n    17→  'form',\n    18→  'ui verification',\n    19→  'ui acceptance',\n    20→];\n    21→\n    22→const API_KEYWORDS = [\n    23→  'http',\n    24→  'api',\n    25→  'endpoint',\n    26→  'curl',\n    27→  'rest',\n    28→  'response bod',\n    29→];\n    30→\n    31→const DB_KEYWORDS = [\n    32→  'database',\n    33→  'db state',\n    34→  'db mcp',\n    35→  'query',\n    36→  'sql',\n    37→  'table',\n    38→];\n    39→\n    40→// ─── Integration Keywords ───────────────────────────────────────────────────\n    41→\n    42→export const INTEGRATION_KEYWORDS = [\n    43→  'external system',\n    44→  'real infrastructure',\n    45→  'manual verification',\n    46→];\n    47→\n    48→// Keywords that indicate true escalation (cannot be automated at all)\n    49→const ESCALATE_KEYWORDS = [\n    50→  'physical hardware',\n    51→  'manual human',\n    52→  'visual inspection by human',\n    53→  'paid external service',\n    54→];\n    55→\n    56→// ─── Verifiability Classification ───────────────────────────────────────────\n    57→\n    58→/**\n    59→ * Classifies whether an AC can be verified in a CLI subprocess or requires\n    60→ * integration testing. Checks description against integration keywords\n    61→ * (case-insensitive). Falls back to 'cli-verifiable'.\n    62→ */\n    63→export function classifyVerifiability(description: string): Verifiability {\n    64→  const lower = description.toLowerCase();\n    65→\n    66→  for (const kw of INTEGRATION_KEYWORDS) {\n    67→    if (lower.includes(kw)) return 'integration-required';\n    68→  }\n    69→\n    70→  return 'cli-verifiable';\n    71→}\n    72→\n    73→// ─── Verification Strategy ─────────────────────────────────────────────────\n    74→\n    75→/**\n    76→ * Determines the best verification strategy for an AC.\n    77→ *\n    78→ * Docker is the DEFAULT — it's the safest approach because it runs in an\n    79→ * isolated container that can't corrupt the host environment.\n    80→ *\n    81→ * cli-direct is the fallback when Docker is unavailable (checked at runtime).\n    82→ * escalate is the last resort for things that truly can't be automated.\n    83→ */\n    84→export function classifyStrategy(description: string): VerificationStrategy {\n    85→  const lower = description.toLowerCase();\n    86→\n    87→  // Check for true escalation first (very rare)\n    88→  for (const kw of ESCALATE_KEYWORDS) {\n    89→    if (lower.includes(kw)) return 'escalate';\n    90→  }\n    91→\n    92→  // Default: Docker for everything\n    93→  return 'docker';\n    94→}\n    95→\n    96→// ─── Verification Tag Parsing ───────────────────────────────────────────────\n    97→\n    98→const VERIFICATION_TAG_PATTERN = /<!--\\s*verification:\\s*(cli-verifiable|integration-required)\\s*-->/;\n    99→\n   100→/**\n   101→ * Parses a `<!-- verification: cli-verifiable|integration-required -->` HTML\n   102→ * comment tag from a string. Returns the tag value if found, or null.\n   103→ */\n   104→export function parseVerificationTag(text: string): Verifiability | null {\n   105→  const match = VERIFICATION_TAG_PATTERN.exec(text);\n   106→  return match ? (match[1] as Verifiability) : null;\n   107→}\n   108→\n   109→// ─── Classification ─────────────────────────────────────────────────────────\n   110→\n   111→/**\n   112→ * Classifies an AC description by keywords.\n   113→ * Checks UI, API, DB keywords (case-insensitive). Falls back to 'general'.\n   114→ */\n   115→export function classifyAC(description: string): 'ui' | 'api' | 'db' | 'general' {\n   116→  const lower = description.toLowerCase();\n   117→\n   118→  for (const kw of UI_KEYWORDS) {\n   119→    if (lower.includes(kw)) return 'ui';\n   120→  }\n   121→  for (const kw of API_KEYWORDS) {\n   122→    if (lower.includes(kw)) return 'api';\n   123→  }\n   124→  for (const kw of DB_KEYWORDS) {\n   125→    if (lower.includes(kw)) return 'db';\n   126→  }\n   127→\n   128→  return 'general';\n   129→}\n   130→\n   131→// ─── Parser ─────────────────────────────────────────────────────────────────\n   132→\n   133→/**\n   134→ * Reads a story markdown file and extracts numbered acceptance criteria.\n   135→ * Finds the `## Acceptance Criteria` section, then parses numbered items.\n   136→ *\n   137→ * @throws Error if file not found (with actionable message)\n   138→ * @returns ParsedAC[] — empty array if no AC section found (with warning)\n   139→ */\n   140→export function parseStoryACs(storyFilePath: string): ParsedAC[] {\n   141→  if (!existsSync(storyFilePath)) {\n   142→    throw new Error(\n   143→      `Story file not found: ${storyFilePath}. Ensure the story file exists at the expected path.`,\n   144→    );\n   145→  }\n   146→\n   147→  const content = readFileSync(storyFilePath, 'utf-8');\n   148→  const lines = content.split('\\n');\n   149→\n   150→  // Find the AC section\n   151→  let acSectionStart = -1;\n   152→  for (let i = 0; i < lines.length; i++) {\n   153→    if (/^##\\s+Acceptance\\s+Criteria/i.test(lines[i])) {\n   154→      acSectionStart = i + 1;\n   155→      break;\n   156→    }\n   157→  }\n   158→\n   159→  if (acSectionStart === -1) {\n   160→    warn('No \"## Acceptance Criteria\" section found in story file');\n   161→    return [];\n   162→  }\n   163→\n   164→  // Find section end (next ## heading or end of file)\n   165→  let acSectionEnd = lines.length;\n   166→  for (let i = acSectionStart; i < lines.length; i++) {\n   167→    if (/^##\\s+/.test(lines[i]) && i !== acSectionStart - 1) {\n   168→      acSectionEnd = i;\n   169→      break;\n   170→    }\n   171→  }\n   172→\n   173→  const acSection = lines.slice(acSectionStart, acSectionEnd).join('\\n');\n   174→\n   175→  // Parse numbered ACs\n   176→  const acPattern = /^\\s*(\\d+)\\.\\s+/;\n   177→  const acs: ParsedAC[] = [];\n   178→  const acLines = acSection.split('\\n');\n   179→\n   180→  let currentId: string | null = null;\n   181→  let currentDesc: string[] = [];\n   182→\n   183→  const flushCurrent = (): void => {\n   184→    if (currentId !== null && currentDesc.length > 0) {\n   185→      const description = currentDesc.join(' ').trim();\n   186→      if (description) {\n   187→        const tag = parseVerificationTag(description);\n   188→        const verifiability = tag ?? classifyVerifiability(description);\n   189→        const strategy = classifyStrategy(description);\n   190→        acs.push({\n   191→          id: currentId,\n   192→          description,\n   193→          type: classifyAC(description),\n   194→          verifiability,\n   195→          strategy,\n   196→        });\n   197→      } else {\n   198→        warn(`Skipping malformed AC #${currentId}: empty description`);\n   199→      }\n   200→    }\n   201→  };\n   202→\n   203→  for (const line of acLines) {\n   204→    const match = acPattern.exec(line);\n   205→    if (match) {\n   206→      flushCurrent();\n   207→      currentId = match[1];\n   208→      currentDesc = [line.replace(acPattern, '').trim()];\n   209→    } else if (currentId !== null && line.trim()) {\n   210→      currentDesc.push(line.trim());\n   211→    }\n   212→  }\n   213→\n   214→  // Flush last AC\n   215→  flushCurrent();\n   216→\n   217→  return acs;\n   218→}\n   219→\n   220→// ─── Observability Gap Parser ────────────────────────────────────────────\n   221→\n   222→const AC_HEADING_PATTERN = /^##\\s+AC\\s+(\\d+)/i;\n   223→const OBSERVABILITY_GAP_TAG = '[OBSERVABILITY GAP]';\n   224→\n   225→/**\n   226→ * Parses proof content for `[OBSERVABILITY GAP]` tags.\n   227→ * Scans each AC section (delimited by `## AC N:` headings) for the gap tag.\n   228→ *\n   229→ * @param proofContent - Raw markdown content of the proof document\n   230→ * @returns Per-AC gap presence and aggregate counts\n   231→ */\n   232→export function parseObservabilityGaps(proofContent: string): ObservabilityGapResult {\n   233→  const lines = proofContent.split('\\n');\n   234→  const entries: ObservabilityGapEntry[] = [];\n   235→\n   236→  let currentAcId: string | null = null;\n   237→  let currentSectionLines: string[] = [];\n   238→\n   239→  const flushSection = (): void => {\n   240→    if (currentAcId !== null) {\n   241→      const sectionText = currentSectionLines.join('\\n');\n   242→      const hasGap = sectionText.includes(OBSERVABILITY_GAP_TAG);\n   243→      const gapNote = hasGap\n   244→        ? 'No log events detected for this user interaction'\n   245→        : undefined;\n   246→      entries.push({ acId: currentAcId, hasGap, gapNote });\n   247→    }\n   248→  };\n   249→\n   250→  for (const line of lines) {\n   251→    const match = AC_HEADING_PATTERN.exec(line);\n   252→    if (match) {\n   253→      flushSection();\n   254→      currentAcId = match[1];\n   255→      currentSectionLines = [line];\n   256→    } else if (currentAcId !== null) {\n   257→      currentSectionLines.push(line);\n   258→    }\n   259→  }\n   260→\n   261→  // Flush last section\n   262→  flushSection();\n   263→\n   264→  const totalACs = entries.length;\n   265→  const gapCount = entries.filter(e => e.hasGap).length;\n   266→  const coveredCount = totalACs - gapCount;\n   267→\n   268→  return { entries, totalACs, gapCount, coveredCount };\n   269→}\n   270→"}]},"parent_tool_use_id":null,"session_id":"3fcb2b1c-e710-401b-91ab-b64a3e9a3996","uuid":"47abc90f-bbd6-41d6-ba75-c4979ddd9eb7","timestamp":"2026-03-25T07:10:36.365Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ivintik/dev/personal/codeharness/src/modules/verify/parser.ts","content":"/**\n * Story file acceptance criteria parser.\n * Reads story markdown files and extracts numbered ACs with type classification.\n */\n\nimport { existsSync, readFileSync } from 'node:fs';\nimport { warn } from '../../lib/output.js';\nimport type { ParsedAC, Verifiability, VerificationStrategy, ObservabilityGapResult, ObservabilityGapEntry } from './types.js';\n\n// ─── Keywords for Classification ────────────────────────────────────────────\n\nconst UI_KEYWORDS = [\n  'agent-browser',\n  'screenshot',\n  'navigate',\n  'click',\n  'form',\n  'ui verification',\n  'ui acceptance',\n];\n\nconst API_KEYWORDS = [\n  'http',\n  'api',\n  'endpoint',\n  'curl',\n  'rest',\n  'response bod',\n];\n\nconst DB_KEYWORDS = [\n  'database',\n  'db state',\n  'db mcp',\n  'query',\n  'sql',\n  'table',\n];\n\n// ─── Integration Keywords ───────────────────────────────────────────────────\n\nexport const INTEGRATION_KEYWORDS = [\n  'external system',\n  'real infrastructure',\n  'manual verification',\n];\n\n// Keywords that indicate true escalation (cannot be automated at all)\nconst ESCALATE_KEYWORDS = [\n  'physical hardware',\n  'manual human',\n  'visual inspection by human',\n  'paid external service',\n];\n\n// ─── Verifiability Classification ───────────────────────────────────────────\n\n/**\n * Classifies whether an AC can be verified in a CLI subprocess or requires\n * integration testing. Checks description against integration keywords\n * (case-insensitive). Falls back to 'cli-verifiable'.\n */\nexport function classifyVerifiability(description: string): Verifiability {\n  const lower = description.toLowerCase();\n\n  for (const kw of INTEGRATION_KEYWORDS) {\n    if (lower.includes(kw)) return 'integration-required';\n  }\n\n  return 'cli-verifiable';\n}\n\n// ─── Verification Strategy ─────────────────────────────────────────────────\n\n/**\n * Determines the best verification strategy for an AC.\n *\n * Docker is the DEFAULT — it's the safest approach because it runs in an\n * isolated container that can't corrupt the host environment.\n *\n * cli-direct is the fallback when Docker is unavailable (checked at runtime).\n * escalate is the last resort for things that truly can't be automated.\n */\nexport function classifyStrategy(description: string): VerificationStrategy {\n  const lower = description.toLowerCase();\n\n  // Check for true escalation first (very rare)\n  for (const kw of ESCALATE_KEYWORDS) {\n    if (lower.includes(kw)) return 'escalate';\n  }\n\n  // Default: Docker for everything\n  return 'docker';\n}\n\n// ─── Verification Tag Parsing ───────────────────────────────────────────────\n\nconst VERIFICATION_TAG_PATTERN = /<!--\\s*verification:\\s*(cli-verifiable|integration-required)\\s*-->/;\n\n/**\n * Parses a `<!-- verification: cli-verifiable|integration-required -->` HTML\n * comment tag from a string. Returns the tag value if found, or null.\n */\nexport function parseVerificationTag(text: string): Verifiability | null {\n  const match = VERIFICATION_TAG_PATTERN.exec(text);\n  return match ? (match[1] as Verifiability) : null;\n}\n\n// ─── Classification ─────────────────────────────────────────────────────────\n\n/**\n * Classifies an AC description by keywords.\n * Checks UI, API, DB keywords (case-insensitive). Falls back to 'general'.\n */\nexport function classifyAC(description: string): 'ui' | 'api' | 'db' | 'general' {\n  const lower = description.toLowerCase();\n\n  for (const kw of UI_KEYWORDS) {\n    if (lower.includes(kw)) return 'ui';\n  }\n  for (const kw of API_KEYWORDS) {\n    if (lower.includes(kw)) return 'api';\n  }\n  for (const kw of DB_KEYWORDS) {\n    if (lower.includes(kw)) return 'db';\n  }\n\n  return 'general';\n}\n\n// ─── Parser ─────────────────────────────────────────────────────────────────\n\n/**\n * Reads a story markdown file and extracts numbered acceptance criteria.\n * Finds the `## Acceptance Criteria` section, then parses numbered items.\n *\n * @throws Error if file not found (with actionable message)\n * @returns ParsedAC[] — empty array if no AC section found (with warning)\n */\nexport function parseStoryACs(storyFilePath: string): ParsedAC[] {\n  if (!existsSync(storyFilePath)) {\n    throw new Error(\n      `Story file not found: ${storyFilePath}. Ensure the story file exists at the expected path.`,\n    );\n  }\n\n  const content = readFileSync(storyFilePath, 'utf-8');\n  const lines = content.split('\\n');\n\n  // Find the AC section\n  let acSectionStart = -1;\n  for (let i = 0; i < lines.length; i++) {\n    if (/^##\\s+Acceptance\\s+Criteria/i.test(lines[i])) {\n      acSectionStart = i + 1;\n      break;\n    }\n  }\n\n  if (acSectionStart === -1) {\n    warn('No \"## Acceptance Criteria\" section found in story file');\n    return [];\n  }\n\n  // Find section end (next ## heading or end of file)\n  let acSectionEnd = lines.length;\n  for (let i = acSectionStart; i < lines.length; i++) {\n    if (/^##\\s+/.test(lines[i]) && i !== acSectionStart - 1) {\n      acSectionEnd = i;\n      break;\n    }\n  }\n\n  const acSection = lines.slice(acSectionStart, acSectionEnd).join('\\n');\n\n  // Parse numbered ACs\n  const acPattern = /^\\s*(\\d+)\\.\\s+/;\n  const acs: ParsedAC[] = [];\n  const acLines = acSection.split('\\n');\n\n  let currentId: string | null = null;\n  let currentDesc: string[] = [];\n\n  const flushCurrent = (): void => {\n    if (currentId !== null && currentDesc.length > 0) {\n      const description = currentDesc.join(' ').trim();\n      if (description) {\n        const tag = parseVerificationTag(description);\n        const verifiability = tag ?? classifyVerifiability(description);\n        const strategy = classifyStrategy(description);\n        acs.push({\n          id: currentId,\n          description,\n          type: classifyAC(description),\n          verifiability,\n          strategy,\n        });\n      } else {\n        warn(`Skipping malformed AC #${currentId}: empty description`);\n      }\n    }\n  };\n\n  for (const line of acLines) {\n    const match = acPattern.exec(line);\n    if (match) {\n      flushCurrent();\n      currentId = match[1];\n      currentDesc = [line.replace(acPattern, '').trim()];\n    } else if (currentId !== null && line.trim()) {\n      currentDesc.push(line.trim());\n    }\n  }\n\n  // Flush last AC\n  flushCurrent();\n\n  return acs;\n}\n\n// ─── Observability Gap Parser ────────────────────────────────────────────\n\nconst AC_HEADING_PATTERN = /^##\\s+AC\\s+(\\d+)/i;\nconst OBSERVABILITY_GAP_TAG = '[OBSERVABILITY GAP]';\n\n/**\n * Parses proof content for `[OBSERVABILITY GAP]` tags.\n * Scans each AC section (delimited by `## AC N:` headings) for the gap tag.\n *\n * @param proofContent - Raw markdown content of the proof document\n * @returns Per-AC gap presence and aggregate counts\n */\nexport function parseObservabilityGaps(proofContent: string): ObservabilityGapResult {\n  const lines = proofContent.split('\\n');\n  const entries: ObservabilityGapEntry[] = [];\n\n  let currentAcId: string | null = null;\n  let currentSectionLines: string[] = [];\n\n  const flushSection = (): void => {\n    if (currentAcId !== null) {\n      const sectionText = currentSectionLines.join('\\n');\n      const hasGap = sectionText.includes(OBSERVABILITY_GAP_TAG);\n      const gapNote = hasGap\n        ? 'No log events detected for this user interaction'\n        : undefined;\n      entries.push({ acId: currentAcId, hasGap, gapNote });\n    }\n  };\n\n  for (const line of lines) {\n    const match = AC_HEADING_PATTERN.exec(line);\n    if (match) {\n      flushSection();\n      currentAcId = match[1];\n      currentSectionLines = [line];\n    } else if (currentAcId !== null) {\n      currentSectionLines.push(line);\n    }\n  }\n\n  // Flush last section\n  flushSection();\n\n  const totalACs = entries.length;\n  const gapCount = entries.filter(e => e.hasGap).length;\n  const coveredCount = totalACs - gapCount;\n\n  return { entries, totalACs, gapCount, coveredCount };\n}\n","numLines":270,"startLine":1,"totalLines":270}}}
