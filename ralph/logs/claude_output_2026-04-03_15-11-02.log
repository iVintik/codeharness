{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RdrpFjYauxg4SSJDRwbKpv","type":"tool_result","content":"1\timport { describe, it, expect, afterEach, vi } from 'vitest';\n2\timport { render } from 'ink-testing-library';\n3\timport React from 'react';\n4\timport { startRenderer } from '../ink-renderer.js';\n5\timport type { RendererHandle } from '../ink-renderer.js';\n6\timport type { StreamEvent } from '../agents/stream-parser.js';\n7\timport {\n8\t  App,\n9\t  Header,\n10\t  Separator,\n11\t  CompletedTool,\n12\t  ActiveTool,\n13\t  LastThought,\n14\t  RetryNotice,\n15\t  StoryBreakdown,\n16\t  StoryMessageLine,\n17\t  type RendererState,\n18\t  type SprintInfo,\n19\t  type CompletedToolEntry,\n20\t  type StoryStatusEntry,\n21\t  type StoryMessage,\n22\t} from '../ink-components.js';\n23\t\n24\t// --- Helpers ---\n25\t\n26\tfunction makeState(overrides?: Partial<RendererState>): RendererState {\n27\t  return {\n28\t    sprintInfo: null,\n29\t    stories: [],\n30\t    messages: [],\n31\t    completedTools: [],\n32\t    activeTool: null,\n33\t    activeToolArgs: '',\n34\t    lastThought: null,\n35\t    retryInfo: null,\n36\t    workflowFlow: [],\n37\t    currentTaskName: null,\n38\t    taskStates: {},\n39\t    ...overrides,\n40\t  };\n41\t}\n42\t\n43\t// --- Component Tests (using ink-testing-library) ---\n44\t\n45\tdescribe('Header component', () => {\n46\t  it('renders plain text header line (no Box border, no diamond prefix)', () => {\n47\t    const info: SprintInfo = {\n48\t      storyKey: '0-5-3',\n49\t      phase: 'dev',\n50\t      done: 3,\n51\t      total: 10,\n52\t      iterationCount: 2,\n53\t      totalCost: 5.50,\n54\t    };\n55\t    const { lastFrame } = render(<Header info={info} />);\n56\t    const frame = lastFrame()!;\n57\t    // AC1: plain text header, NO Box border, NO diamond prefix\n58\t    expect(frame).toContain('codeharness run');\n59\t    expect(frame).toContain('iteration 2');\n60\t    expect(frame).toContain('$5.50