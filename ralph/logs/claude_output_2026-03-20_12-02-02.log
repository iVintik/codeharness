{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xbt3MgdbPDnSsiNZ1wj9Qj","type":"tool_result","content":"     1→/**\n     2→ * Helper functions for the run command.\n     3→ *\n     4→ * Extracted from run.ts to comply with NFR9 (max 300 lines per file).\n     5→ * Contains: elapsed time formatting, sprint status → story status mapping,\n     6→ * and ralph stderr → story message parsing.\n     7→ */\n     8→\n     9→import type { StoryStatusEntry, StoryStatusValue, StoryMessage } from './ink-components.js';\n    10→\n    11→// --- Story Counting ---\n    12→\n    13→/** Story key pattern: digit-digit-name */\n    14→const STORY_KEY_PATTERN = /^\\d+-\\d+-/;\n    15→\n    16→/**\n    17→ * Counts stories by status from sprint-status.yaml.\n    18→ */\n    19→export function countStories(statuses: Record<string, string>): {\n    20→  total: number;\n    21→  ready: number;\n    22→  done: number;\n    23→  inProgress: number;\n    24→  // eslint-disable-next-line @typescript-eslint/naming-convention\n    25→  verified: number;\n    26→} {\n    27→  let total = 0;\n    28→  let ready = 0;\n    29→  let done = 0;\n    30→  let inProgress = 0;\n    31→  // eslint-disable-next-line @typescript-eslint/naming-convention\n    32→  let verified = 0;\n    33→\n    34→  for (const [key, status] of Object.entries(statuses)) {\n    35→    if (!STORY_KEY_PATTERN.test(key)) continue;\n    36→    total++;\n    37→    if (status === 'backlog' || status === 'ready-for-dev') ready++;\n    38→    else if (status === 'done') done++;\n    39→    else if (status === 'in-progress' || status === 'review') inProgress++;\n    40→    else if (status === 'verifying') verified++;\n    41→  }\n    42→\n    43→  return { total, ready, done, inProgress, verified };\n    44→}\n    45→\n    46→// --- Spawn Args Builder ---\n    47→\n    48→/**\n    49→ * Builds the argument array for spawning Ralph.\n    50→ */\n    51→export function buildSpawnArgs(opts: {\n    52→  ralphPath: string;\n    53→  pluginDir: string;\n    54→  promptFile: string;\n    55→  maxIterations: number;\n    56→  timeout: number;\n    57→  iterationTimeout: number;\n    58→  calls: number;\n    59→  quiet: boolean;\n    60→  maxStoryRetries?: number;\n    61→  reset?: boolean;\n    62→}): string[] {\n    63→  const args = [\n    64→    opts.ralphPath,\n    65→    '--plugin-dir', opts.pluginDir,\n    66→    '--max-iterations', String(opts.maxIterations),\n    67→    '--timeout', String(opts.timeout),\n    68→    '--iteration-timeout', String(opts.iterationTimeout),\n    69→    '--calls', String(opts.calls),\n    70→    '--prompt', opts.promptFile,\n    71→  ];\n    72→\n    73→  if (opts.maxStoryRetries !== undefined) {\n    74→    args.push('--max-story-retries', String(opts.maxStoryRetries));\n    75→  }\n    76→\n    77→  if (opts.reset) {\n    78→    args.push('--reset');\n    79→  }\n    80→\n    81→  return args;\n    82→}\n    83→\n    84→// --- Elapsed Time Formatting (AC #6) ---\n    85→\n    86→/**\n    87→ * Format elapsed milliseconds as \"Xm\" or \"XhYm\".\n    88→ * Matches the UX spec format (not the DashboardFormatter \"Xm Ys\" format).\n    89→ */\n    90→export function formatElapsed(ms: number): string {\n    91→  const totalMinutes = Math.max(0, Math.floor(ms / 60_000));\n    92→  const hours = Math.floor(totalMinutes / 60);\n    93→  const minutes = totalMinutes % 60;\n    94→  if (hours > 0) {\n    95→    return `${hours}h${minutes}m`;\n    96→  }\n    97→  return `${totalMinutes}m`;\n    98→}\n    99→\n   100→// --- Sprint Status → Story Status Mapping (AC #7) ---\n   101→\n   102→/**\n   103→ * Maps a sprint-status.yaml status value to a StoryStatusValue for the Ink renderer.\n   104→ *\n   105→ * Mapping:\n   106→ *   done → done\n   107→ *   in-progress, review, verifying → in-progress\n   108→ *   backlog, ready-for-dev → pending\n   109→ *   failed → failed\n   110→ *   blocked, exhausted → blocked\n   111→ */\n   112→export function mapSprintStatus(status: string): StoryStatusValue {\n   113→  switch (status) {\n   114→    case 'done':\n   115→      return 'done';\n   116→    case 'in-progress':\n   117→    case 'review':\n   118→    case 'verifying':\n   119→      return 'in-progress';\n   120→    case 'backlog':\n   121→    case 'ready-for-dev':\n   122→      return 'pending';\n   123→    case 'failed':\n   124→      return 'failed';\n   125→    case 'blocked':\n   126→    case 'exhausted':\n   127→      return 'blocked';\n   128→    default:\n   129→      return 'pending';\n   130→  }\n   131→}\n   132→\n   133→/** Story key pattern: digit-digit-name */\n   134→const STORY_KEY_PATTERN = /^\\d+-\\d+-/;\n   135→\n   136→/**\n   137→ * Converts sprint-status.yaml entries to StoryStatusEntry[] for the Ink renderer.\n   138→ * Filters out epic keys, retrospective keys, and optional entries.\n   139→ */\n   140→export function mapSprintStatuses(statuses: Record<string, string>): StoryStatusEntry[] {\n   141→  const entries: StoryStatusEntry[] = [];\n   142→  for (const [key, status] of Object.entries(statuses)) {\n   143→    if (!STORY_KEY_PATTERN.test(key)) continue;\n   144→    if (status === 'optional') continue;\n   145→    entries.push({ key, status: mapSprintStatus(status) });\n   146→  }\n   147→  return entries;\n   148→}\n   149→\n   150→// --- Ralph Stderr → Story Messages (AC #8) ---\n   151→\n   152→/** Strip ANSI color codes */\n   153→const ANSI_ESCAPE = /\\x1b\\[[0-9;]*m/g;\n   154→\n   155→/** Strip timestamp prefix from ralph output lines */\n   156→const TIMESTAMP_PREFIX = /^\\[[\\d-]+\\s[\\d:]+\\]\\s*/;\n   157→\n   158→/** Matches: [SUCCESS] Story {key}: DONE ... */\n   159→const SUCCESS_STORY = /\\[SUCCESS\\]\\s+Story\\s+([\\w-]+):\\s+DONE(.*)/;\n   160→\n   161→/** Matches: [WARN] Story {key} exceeded retry limit ... flagging */\n   162→const WARN_STORY_RETRY = /\\[WARN\\]\\s+Story\\s+([\\w-]+)\\s+exceeded retry limit/;\n   163→\n   164→/** Matches: [WARN] Story {key} ... retry N/M */\n   165→const WARN_STORY_RETRYING = /\\[WARN\\]\\s+Story\\s+([\\w-]+)\\s+.*retry\\s+(\\d+)\\/(\\d+)/;\n   166→\n   167→/** Matches: [ERROR] ... */\n   168→const ERROR_LINE = /\\[ERROR\\]\\s+(.+)/;\n   169→\n   170→/**\n   171→ * Parse a ralph output line and return a StoryMessage if it matches\n   172→ * a story completion, failure, or warning pattern.\n   173→ * Returns null for non-matching lines.\n   174→ */\n   175→export function parseRalphMessage(rawLine: string): StoryMessage | null {\n   176→  const clean = rawLine.replace(ANSI_ESCAPE, '').replace(TIMESTAMP_PREFIX, '').trim();\n   177→  if (clean.length === 0) return null;\n   178→\n   179→  // [SUCCESS] Story {key}: DONE ...\n   180→  const success = SUCCESS_STORY.exec(clean);\n   181→  if (success) {\n   182→    const key = success[1];\n   183→    const rest = success[2].trim().replace(/^—\\s*/, '');\n   184→    return {\n   185→      type: 'ok',\n   186→      key,\n   187→      message: rest ? `DONE — ${rest}` : 'DONE',\n   188→    };\n   189→  }\n   190→\n   191→  // [WARN] Story {key} exceeded retry limit\n   192→  const retryExceeded = WARN_STORY_RETRY.exec(clean);\n   193→  if (retryExceeded) {\n   194→    return {\n   195→      type: 'fail',\n   196→      key: retryExceeded[1],\n   197→      message: 'exceeded retry limit',\n   198→    };\n   199→  }\n   200→\n   201→  // [WARN] Story {key} — retry N/M\n   202→  const retrying = WARN_STORY_RETRYING.exec(clean);\n   203→  if (retrying) {\n   204→    return {\n   205→      type: 'warn',\n   206→      key: retrying[1],\n   207→      message: `retry ${retrying[2]}/${retrying[3]}`,\n   208→    };\n   209→  }\n   210→\n   211→  // [ERROR] ... — surface as a generic error message\n   212→  const errorMatch = ERROR_LINE.exec(clean);\n   213→  if (errorMatch) {\n   214→    // Try to extract story key from error message\n   215→    const keyMatch = errorMatch[1].match(/Story\\s+([\\w-]+)/);\n   216→    if (keyMatch) {\n   217→      return {\n   218→        type: 'fail',\n   219→        key: keyMatch[1],\n   220→        message: errorMatch[1].trim(),\n   221→      };\n   222→    }\n   223→    // Generic error without a story key — skip (no key to associate)\n   224→    return null;\n   225→  }\n   226→\n   227→  return null;\n   228→}\n   229→"}]},"parent_tool_use_id":"toolu_01J5AdAMYAsRdio1YgdnbwDy","session_id":"64c1e9b9-a641-40be-ae67-07aee0c47965","uuid":"3fb757fc-75d2-4d42-a2ae-9111cde06f85","timestamp":"2026-03-20T08:09:27.476Z"}
