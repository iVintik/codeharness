\n    41→export type { DockerfileValidationResult, DockerfileGap } from './dockerfile-validator.js';\n    42→\n    43→export function getObservabilityBackend(config?: {\n    44→  opensearchUrl?: string;\n    45→  opensearch?: { logsIndex?: string; metricsIndex?: string; tracesIndex?: string };\n    46→  victoria?: { logsUrl?: string; metricsUrl?: string; tracesUrl?: string };\n    47→}): ObservabilityBackend {\n    48→  return createObservabilityBackend(config);\n    49→}\n    50→"}]},"parent_tool_use_id":"toolu_015U2Dv9GBzjkQ93L4EzWA3k","session_id":"ef2f2ce5-c013-4ad4-b6dd-a80c40f8ca85","uuid":"d8b84b04-008f-4fd8-9858-4e8812277a81","timestamp":"2026-03-21T05:19:18.882Z"}
