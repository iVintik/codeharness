{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019zM92ezDxV5n4V4jMRsy7m","type":"tool_result","content":"850\t      type: 'ok',\n851\t      key: '3-2',\n852\t      message: 'DONE — 12/12 ACs verified',\n853\t      details: [\n854\t        'Proof: verification/3-2-proof.md',\n855\t        'Duration: 18m | Cost: $4.20',\n856\t      ],\n857\t    };\n858\t    const { lastFrame } = render(<StoryMessageLine msg={msg} />);\n859\t    const frame = lastFrame()!;\n860\t    expect(frame).toContain('[OK] Story 3-2: DONE — 12/12 ACs verified');\n861\t    expect(frame).toContain('└ Proof: verification/3-2-proof.md');\n862\t    expect(frame).toContain('└ Duration: 18m | Cost: $4.20');\n863\t  });\n864\t\n865\t  it('renders story warning in spec format', () => {\n866\t    const msg: StoryMessage = {\n867\t      type: 'warn',\n868\t      key: '3-3',\n869\t      message: 'verification found 2 failing ACs → returning to dev',\n870\t      details: [\n871\t        'AC 3: bridge --dry-run output missing epic headers',\n872\t        'AC 7: bridge creates duplicate beads issues',\n873\t        'Attempt 2/10 — dev will fix and re-verify',\n874\t      ],\n875\t    };\n876\t    const { lastFrame } = render(<StoryMessageLine msg={msg} />);\n877\t    const frame = lastFrame()!;\n878\t    expect(frame).toContain('[WARN] Story 3-3: verification found 2 failing ACs');\n879\t    expect(frame).toContain('└ AC 3');\n880\t    expect(frame).toContain('└ AC 7');\n881\t    expect(frame).toContain('└ Attempt 2/10');\n882\t  });\n883\t});\n884\t\n885\t// --- Driver Name Integration Tests ---\n886\t\n887\tdescribe('driver name in update()', () => {\n888\t  let handle: RendererHandle;\n889\t\n890\t  afterEach(() => {\n891\t    handle?.cleanup();\n892\t  });\n893\t\n894\t  it('sets activeDriverName on tool-start when driverName provided', () => {\n895\t    handle = startRenderer({ sprintState: { storyKey: 'test', phase: 'dev', done: 0, total: 1 }, _forceTTY: true });\n896\t    handle.update({ type: 'tool-start', name: 'Bash', id: 't1' }, 'codex');\n897\t    // The tool-start was accepted without error — state updated internally\n898\t    // Verify by completing and checking the entry has the driver\n899\t    handle.update({ type: 'tool-complete' });\n900\t    // No crash = success; driver tracking is internal state\n901\t  });\n902\t\n903\t  it('leaves activeDriverName null when no driverName provided', () => {\n904\t    handle = startRenderer({ sprintState: { storyKey: 'test', phase: 'dev', done: 0, total: 1 }, _forceTTY: true });\n905\t    handle.update({ type: 'tool-start', name: 'Bash', id: 't1' });\n906\t    handle.update({ type: 'tool-complete' });\n907\t    // No crash = backward compat works\n908\t  });\n909\t\n910\t  it('accumulates driverCosts on result event with driverName', () => {\n911\t    handle = startRenderer({ sprintState: { storyKey: 'test', phase: 'dev', done: 0, total: 1 }, _forceTTY: true });\n912\t    handle.update({ type: 'result', cost: 1.50, sessionId: 'sess1' }, 'claude-code');\n913\t    handle.update({ type: 'result', cost: 0.75, sessionId: 'sess2' }, 'claude-code');\n914\t    handle.update({ type: 'result', cost: 0.25, sessionId: 'sess3' }, 'codex');\n915\t    // No crash = accumulation works\n916\t  });\n917\t\n918\t  it('does not accumulate driverCosts when no driverName on result', () => {\n919\t    handle = startRenderer({ sprintState: { storyKey: 'test', phase: 'dev', done: 0, total: 1 }, _forceTTY: true });\n920\t    handle.update({ type: 'result', cost: 1.50, sessionId: 'sess1' });\n921\t    // No crash = backward compat\n922\t  });\n923\t\n924\t  it('handles error-like sequence without crash (driver failure resilience)', () => {\n925\t    handle = startRenderer({ sprintState: { storyKey: 'test', phase: 'dev', done: 0, total: 1 }, _forceTTY: true });\n926\t    // Start a tool with a driver\n927\t    handle.update({ type: 'tool-start', name: 'Bash', id: 't1' }, 'codex');\n928\t    handle.update({ type: 'tool-input', partial: '{\"command\":\"exit 1\"}' });\n929\t    // Tool completes (even on error, the tool-complete event fires)\n930\t    handle.update({ type: 'tool-complete' });\n931\t    // Text event after failure\n932\t    handle.update({ type: 'text', text: 'The command failed' });\n933\t    // Start another tool with a different driver — no crash\n934\t    handle.update({ type: 'tool-start', name: 'Read', id: 't2' }, 'claude-code');\n935\t    handle.update({ type: 'tool-complete' });\n936\t    // No crash = resilience verified\n937\t  });\n938\t});\n939\t"}]},"parent_tool_use_id":"toolu_0117vDhwD8YtdmVSBCbGt4wb","session_id":"a29ee53b-c2b0-4802-9455-7215112648b1","uuid":"d8694dad-d625-4408-936f-539810d42557","timestamp":"2026-04-03T12:09:52.760Z"}
