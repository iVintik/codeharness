{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01T2Hy7APcCPqeLNx6y4JNqn","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { join } from 'node:path';\n3\timport { parse } from 'yaml';\n4\timport { warn } from './output.js';\n5\timport { DispatchError } from './agent-dispatch.js';\n6\timport type { DispatchErrorCode } from './agent-dispatch.js';\n7\t// Note: dispatchAgent is no longer imported — dispatch goes through the driver factory\n8\timport { getDriver } from './agents/drivers/factory.js';\n9\timport { resolveModel } from './agents/model-resolver.js';\n10\timport type { DispatchOpts, DriverHealth, OutputContract } from './agents/types.js';\n11\timport type { ResultEvent, ToolStartEvent } from './agents/stream-parser.js';\n12\timport type { SubagentDefinition } from './agent-resolver.js';\n13\timport type { ResolvedWorkflow, ResolvedTask, FlowStep, LoopBlock } from './workflow-parser.js';\n14\timport {\n15\t  readWorkflowState,\n16\t  writeWorkflowState,\n17\t} from './workflow-state.js';\n18\timport { buildPromptWithContractContext, writeOutputContract } from './agents/output-contract.js';\n19\timport type { WorkflowState, TaskCheckpoint } from './workflow-state.js';\n20\timport { createIsolatedWorkspace } from './source-isolation.js';\n21\timport { generateTraceId, formatTracePrompt, recordTraceId } from './trace-id.js';\n22\timport { resolveSessionId, recordSessionId } from './session-manager.js';\n23\timport type { SessionLookupKey } from './session-manager.js';\n24\timport { parseVerdict, VerdictParseError } from './verdict-parser.js';\n25\timport type { EvaluatorVerdict } from './verdict-parser.js';\n26\timport { evaluateProgress } from './circuit-breaker.js';\n27\t\n28\t// Re-export EvaluatorVerdict for downstream consumers that import from workflow-engine\n29\texport type { EvaluatorVerdict } from './verdict-parser.js';\n30\texport { parseVerdict } from './verdict-parser.js';\n31\t\n32\t// --- Interfaces ---\n33\t\n34\t/**\n35\t * Configuration for the workflow engine.\n36\t */\n37\texport interface EngineConfig {\n38\t  /** The resolved workflow with tasks and flow steps. */\n39\t  workflow: ResolvedWorkflow;\n40\t  /** Pre-compiled agent definitions keyed by agent name. */\n41\t  agents: Record<string, SubagentDefinition>;\n42\t  /** Path to sprint-status.yaml for work item discovery. */\n43\t  sprintStatusPath: string;\n44\t  /** Optional path to issues.yaml for additional work items. */\n45\t  issuesPath?: string;\n46\t  /** Unique identifier for this engine run. */\n47\t  runId: string;\n48\t  /** Project root directory. Defaults to process.cwd(). */\n49\t  projectDir?: string;\n50\t  /** Maximum loop iterations before termination. Defaults to 5. */\n51\t  maxIterations?: number;\n52\t}\n53\t\n54\t/**\n55\t * Result returned by executeWorkflow().\n56\t */\n57\texport interface EngineResult {\n58\t  /** Whether the workflow completed without errors. */\n59\t  success: boolean;\n60\t  /** Number of task dispatches completed. */\n61\t  tasksCompleted: number;\n62\t  /** Number of work items (stories/issues) processed. */\n63\t  storiesProcessed: number;\n64\t  /** Errors encountered during execution. */\n65\t  errors: EngineError[];\n66\t  /** Wall-clock duration of the entire workflow in milliseconds. */\n67\t  durationMs: number;\n68\t}\n69\t\n70\t/**\n71\t * Structured error recorded during workflow execution.\n72\t */\n73\texport interface EngineError {\n74\t  taskName: string;\n75\t  storyKey: string;\n76\t  code: string;\n77\t  message: string;\n78\t}\n79\t\n80\t/**\n81\t * A work item (story or issue) ready for execution.\n82\t */\n83\texport interface WorkItem {\n84\t  key: string;\n85\t  title?: string;\n86\t  source: 'sprint' | 'issues';\n87\t}\n88\t\n89\t// --- Constants ---\n90\t\n91\t/** Sentinel story key for per-run tasks. */\n92\texport const PER_RUN_SENTINEL = '__run__';\n93\t\n94\t/** DispatchError codes that should halt execution immediately. */\n95\tconst HALT_ERROR_CODES = new Set(['RATE_LIMIT', 'NETWORK', 'SDK_INIT']);\n96\t\n97\t/** Default maximum loop iterations before termination. */\n98\tconst DEFAULT_MAX_ITERATIONS = 5;\n99\t\n100\t// --- Crash Recovery: Task Completion Check ---\n101\t\n102\t/**\n103\t * Check whether a (taskName, storyKey) combination is already recorded\n104\t * in the workflow state's tasks_completed array.\n105\t *\n106\t * Both fields must match for the task to be considered completed.\n107\t * Used by the resume logic to skip already-completed dispatches.\n108\t */\n109\texport function isTaskCompleted(\n110\t  state: WorkflowState,\n111\t  taskName: string,\n112\t  storyKey: string,\n113\t): boolean {\n114\t  return state.tasks_completed.some(\n115\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey && !cp.error,\n116\t  );\n117\t}\n118\t\n119\t/**\n120\t * Check whether a (taskName, storyKey) combination has been completed\n121\t * enough times to cover the current iteration in a loop block.\n122\t *\n123\t * Loop tasks execute the same (taskName, storyKey) pair each iteration,\n124\t * recording a new checkpoint each time. To determine if a task is done\n125\t * for the current iteration, we count how many matching checkpoints exist\n126\t * and compare to the current iteration number.\n127\t */\n128\texport function isLoopTaskCompleted(\n129\t  state: WorkflowState,\n130\t  taskName: string,\n131\t  storyKey: string,\n132\t  iteration: number,\n133\t): boolean {\n134\t  const count = state.tasks_completed.filter(\n135\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey && !cp.error,\n136\t  ).length;\n137\t  return count >= iteration;\n138\t}\n139\t\n140\t// --- Work Item Loading ---\n141\t\n142\t/**\n143\t * Load work items from sprint-status.yaml and optionally issues.yaml.\n144\t *\n145\t * Stories are extracted from the `development_status` section of sprint-status.yaml.\n146\t * Issues are extracted from the `issues` array of issues.yaml.\n147\t *\n148\t * Only items with status `backlog` or `ready-for-dev` are included.\n149\t * Epic keys (`epic-*`) and retrospective keys (`*-retrospective`) are excluded.\n150\t *\n151\t * If issues.yaml does not exist, returns only stories (no error).\n152\t */\n153\texport function loadWorkItems(sprintStatusPath: string, issuesPath?: string): WorkItem[] {\n154\t  const items: WorkItem[] = [];\n155\t\n156\t  // --- Load stories from sprint-status.yaml ---\n157\t  if (existsSync(sprintStatusPath)) {\n158\t    let raw: string;\n159\t    try {\n160\t      raw = readFileSync(sprintStatusPath, 'utf-8');\n161\t    } catch { // IGNORE: unreadable file — warn and return empty\n162\t      warn(`workflow-engine: could not read sprint-status.yaml at ${sprintStatusPath}`);\n163\t      return items;\n164\t    }\n165\t\n166\t    let parsed: unknown;\n167\t    try {\n168\t      parsed = parse(raw);\n169\t    } catch { // IGNORE: malformed YAML — warn and return empty\n170\t      warn(`workflow-engine: invalid YAML in sprint-status.yaml at ${sprintStatusPath}`);\n171\t      return items;\n172\t    }\n173\t\n174\t    if (parsed && typeof parsed === 'object') {\n175\t      const data = parsed as Record<string, unknown>;\n176\t      const devStatus = data.development_status as Record<string, unknown> | undefined;\n177\t\n178\t      if (devStatus && typeof devStatus === 'object') {\n179\t        for (const [key, status] of Object.entries(devStatus)) {\n180\t          // Skip epic keys and retrospective keys\n181\t          if (key.startsWith('epic-')) continue;\n182\t          if (key.endsWith('-retrospective')) continue;\n183\t\n184\t          // Only include backlog or ready-for-dev\n185\t          if (status === 'backlog' || status === 'ready-for-dev') {\n186\t            items.push({ key, source: 'sprint' });\n187\t          }\n188\t        }\n189\t      }\n190\t    }\n191\t  }\n192\t\n193\t  // --- Load issues from issues.yaml ---\n194\t  if (issuesPath && existsSync(issuesPath)) {\n195\t    let raw: string;\n196\t    try {\n197\t      raw = readFileSync(issuesPath, 'utf-8');\n198\t    } catch { // IGNORE: unreadable issues file — warn and return what we have\n199\t      warn(`workflow-engine: could not read issues.yaml at ${issuesPath}`);\n200\t      return items;"}]},"parent_tool_use_id":"toolu_01SkXPMmo5ukZsEWidXQjyr7","session_id":"d2473842-56c4-49f2-ab43-68fabe9113bb","uuid":"f818b9ab-0299-45ea-a4d1-3b2d2db19157","timestamp":"2026-04-03T10:58:07.540Z"}
