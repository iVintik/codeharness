{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SXLeDgVgvcPD2sKvWkCrkz","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { resolve, join, dirname } from 'node:path';\n3\timport { fileURLToPath } from 'node:url';\n4\timport os from 'node:os';\n5\timport { parse } from 'yaml';\n6\t\n7\tconst __filename = fileURLToPath(import.meta.url);\n8\tconst __dirname = dirname(__filename);\n9\timport { validateAgentSchema } from './schema-validate.js';\n10\t\n11\t// --- Interfaces ---\n12\t\n13\t/**\n14\t * Agent config shape matching agent.schema.json, plus optional prompt_patches\n15\t * accumulated from patch files.\n16\t */\n17\texport interface ResolvedAgent {\n18\t  name: string;\n19\t  role: {\n20\t    title: string;\n21\t    purpose: string;\n22\t  };\n23\t  persona: {\n24\t    identity: string;\n25\t    communication_style: string;\n26\t    principles: string[];\n27\t  };\n28\t  personality?: {\n29\t    traits: Record<string, number>;\n30\t  };\n31\t  disallowedTools?: string[];\n32\t  prompt_patches?: {\n33\t    append?: string;\n34\t  };\n35\t}\n36\t\n37\t/**\n38\t * Compiled subagent definition ready for Agent SDK dispatch.\n39\t */\n40\texport interface SubagentDefinition {\n41\t  name: string;\n42\t  model: string;\n43\t  instructions: string;\n44\t  disallowedTools: string[];\n45\t  bare: true;\n46\t}\n47\t\n48\t/**\n49\t * Patch file structure: extends identifies base, overrides deep-merged,\n50\t * prompt_patches preserved separately.\n51\t */\n52\texport interface AgentPatch {\n53\t  extends?: string;\n54\t  overrides?: Record<string, unknown>;\n55\t  prompt_patches?: {\n56\t    append?: string;\n57\t  };\n58\t}\n59\t\n60\t// --- Error Class ---\n61\t\n62\texport class AgentResolveError extends Error {\n63\t  public readonly filePath: string;\n64\t  public readonly errors: Array<{ path: string; message: string }>;\n65\t\n66\t  constructor(\n67\t    message: string,\n68\t    filePath: string,\n69\t    errors?: Array<{ path: string; message: string }>,\n70\t  ) {\n71\t    super(message);\n72\t    this.name = 'AgentResolveError';\n73\t    this.filePath = filePath;\n74\t    this.errors = errors ?? [];\n75\t  }\n76\t}\n77\t\n78\t// --- Constants ---\n79\t\n80\tconst TEMPLATES_DIR = resolve(__dirname, '../../templates/agents');\n81\tconst DEFAULT_MODEL = 'claude-sonnet-4-20250514';\n82\t\n83\t// --- Input Validation ---\n84\t\n85\tconst SAFE_NAME_RE = /^[a-zA-Z0-9_-]+$/;\n86\t\n87\t/**\n88\t * Validate agent name to prevent path traversal and unexpected characters.\n89\t */\n90\tfunction validateName(name: string): void {\n91\t  if (!name || !SAFE_NAME_RE.test(name)) {\n92\t    throw new AgentResolveError(\n93\t      `Invalid agent name: \"${name}\" — must match ${SAFE_NAME_RE}`,\n94\t      '',\n95\t      [{ path: '', message: `Invalid agent name: ${name}` }],\n96\t    );\n97\t  }\n98\t}\n99\t\n100\t// --- Deep Merge ---\n101\t\n102\t/**\n103\t * Deep merge strategy: objects merge recursively, arrays replace, scalars replace.\n104\t */\n105\tfunction deepMerge(base: Record<string, unknown>, patch: Record<string, unknown>): Record<string, unknown> {\n106\t  const result: Record<string, unknown> = { ...base };\n107\t\n108\t  for (const key of Object.keys(patch)) {\n109\t    const baseVal = base[key];\n110\t    const patchVal = patch[key];\n111\t\n112\t    if (\n113\t      patchVal !== null &&\n114\t      typeof patchVal === 'object' &&\n115\t      !Array.isArray(patchVal) &&\n116\t      baseVal !== null &&\n117\t      typeof baseVal === 'object' &&\n118\t      !Array.isArray(baseVal)\n119\t    ) {\n120\t      result[key] = deepMerge(\n121\t        baseVal as Record<string, unknown>,\n122\t        patchVal as Record<string, unknown>,\n123\t      );\n124\t    } else {\n125\t      result[key] = patchVal;\n126\t    }\n127\t  }\n128\t\n129\t  return result;\n130\t}\n131\t\n132\t// --- Embedded Agent Loading ---\n133\t\n134\t/**\n135\t * Load an embedded agent template from templates/agents/{name}.yaml.\n136\t * Throws AgentResolveError if not found or invalid.\n137\t */\n138\texport function loadEmbeddedAgent(name: string): ResolvedAgent {\n139\t  validateName(name);\n140\t  const filePath = join(TEMPLATES_DIR, `${name}.yaml`);\n141\t\n142\t  let raw: string;\n143\t  try {\n144\t    raw = readFileSync(filePath, 'utf-8');\n145\t  } catch { // IGNORE: rethrow as AgentResolveError with context\n146\t    throw new AgentResolveError(\n147\t      `Embedded agent not found: ${name}`,\n148\t      filePath,\n149\t      [{ path: filePath, message: `File not found: ${filePath}` }],\n150\t    );\n151\t  }\n152\t\n153\t  let parsed: unknown;\n154\t  try {\n155\t    parsed = parse(raw);\n156\t  } catch (err: unknown) {\n157\t    const msg = err instanceof Error ? err.message : String(err);\n158\t    throw new AgentResolveError(\n159\t      `Invalid YAML in embedded agent ${name}: ${msg}`,\n160\t      filePath,\n161\t      [{ path: filePath, message: msg }],\n162\t    );\n163\t  }\n164\t\n165\t  const result = validateAgentSchema(parsed);\n166\t  if (!result.valid) {\n167\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n168\t    throw new AgentResolveError(\n169\t      `Schema validation failed for embedded agent ${name}: ${details}`,\n170\t      filePath,\n171\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n172\t    );\n173\t  }\n174\t\n175\t  return parsed as ResolvedAgent;\n176\t}\n177\t\n178\t// --- Patch Loading ---\n179\t\n180\t/**\n181\t * Load a patch file. Returns null if the file does not exist (silent skip).\n182\t * Throws AgentResolveError on malformed YAML.\n183\t */\n184\texport function loadPatch(filePath: string): AgentPatch | null {\n185\t  if (!existsSync(filePath)) {\n186\t    return null;\n187\t  }\n188\t\n189\t  let raw: string;\n190\t  try {\n191\t    raw = readFileSync(filePath, 'utf-8');\n192\t  } catch { // IGNORE: file unreadable — treat as missing patch\n193\t    return null;\n194\t  }\n195\t\n196\t  let parsed: unknown;\n197\t  try {\n198\t    parsed = parse(raw);\n199\t  } catch (err: unknown) {\n200\t    const msg = err instanceof Error ? err.message : String(err);\n201\t    throw new AgentResolveError(\n202\t      `Invalid YAML in patch file: ${msg}`,\n203\t      filePath,\n204\t      [{ path: filePath, message: msg }],\n205\t    );\n206\t  }\n207\t\n208\t  if (parsed === null || typeof parsed !== 'object') {\n209\t    throw new AgentResolveError(\n210\t      `Patch file is not a valid object`,\n211\t      filePath,\n212\t      [{ path: filePath, message: 'Patch must be a YAML object' }],\n213\t    );\n214\t  }\n215\t\n216\t  return parsed as AgentPatch;\n217\t}\n218\t\n219\t// --- Patch Merging ---\n220\t\n221\t/**\n222\t * Merge a patch onto a base config. Deep-merges overrides, preserves prompt_patches separately.\n223\t */\n224\texport function mergePatch(\n225\t  base: Record<string, unknown>,\n226\t  patch: AgentPatch,\n227\t): Record<string, unknown> {\n228\t  let result = { ...base };\n229\t\n230\t  if (patch.overrides) {\n231\t    result = deepMerge(result, patch.overrides);\n232\t  }\n233\t\n234\t  if (patch.prompt_patches) {\n235\t    const existing = result.prompt_patches as { append?: string } | undefined;\n236\t    const existingAppend = existing?.append ?? '';\n237\t    const newAppend = patch.prompt_patches.append ?? '';\n238\t\n239\t    if (newAppend) {\n240\t      result.prompt_patches = {\n241\t        append: existingAppend ? `${existingAppend}\\n${newAppend}` : newAppend,\n242\t      };\n243\t    }\n244\t  }\n245\t\n246\t  return result;\n247\t}\n248\t\n249\t// --- Main Resolution ---\n250\t\n251\t/**\n252\t * Resolve an agent through the embedded -> user -> project patch chain.\n253\t * For custom agents (no embedded match, found at project/user level without extends), loads directly.\n254\t */\n255\texport function resolveAgent(name: string, options?: { cwd?: string }): ResolvedAgent {\n256\t  validateName(name);\n257\t  const cwd = options?.cwd ?? process.cwd();\n258\t  const userPatchPath = join(os.homedir(), '.codeharness', 'agents', `${name}.patch.yaml`);\n259\t  const projectPatchPath = join(cwd, '.codeharness', 'agents', `${name}.patch.yaml`);\n260\t\n261\t  // Check for custom agent (project-level full config, no extends)\n262\t  const projectCustomPath = join(cwd, '.codeharness', 'agents', `${name}.yaml`);\n263\t  const userCustomPath = join(os.homedir(), '.codeharness', 'agents', `${name}.yaml`);\n264\t\n265\t  // Try custom agent at project level first, then user level\n266\t  for (const customPath of [projectCustomPath, userCustomPath]) {\n267\t    if (existsSync(customPath)) {\n268\t      const patch = loadPatch(customPath);\n269\t      if (patch && !patch.extends) {\n270\t        // This is a full custom agent, not a patch — load and validate directly\n271\t        const parsed = patch as unknown as Record<string, unknown>;\n272\t        // Strip prompt_patches before schema validation (not in schema, same as patch path)\n273\t        const { prompt_patches: customPP, ...customForValidation } = parsed as Record<string, unknown> & { prompt_patches?: unknown };\n274\t        const result = validateAgentSchema(customForValidation);\n275\t        if (!result.valid) {\n276\t          const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n277\t          throw new AgentResolveError(\n278\t            `Schema validation failed for custom agent ${name}: ${details}`,\n279\t            customPath,\n280\t            result.errors.map((e) => ({ path: e.path, message: e.message })),\n281\t          );\n282\t        }\n283\t        return (customPP ? { ...customForValidation, prompt_patches: customPP } : customForValidation) as unknown as ResolvedAgent;\n284\t      }\n285\t    }\n286\t  }\n287\t\n288\t  // Load embedded base\n289\t  const base = loadEmbeddedAgent(name);\n290\t  let merged: Record<string, unknown> = base as unknown as Record<string, unknown>;\n291\t\n292\t  // Apply user patch\n293\t  const userPatch = loadPatch(userPatchPath);\n294\t  if (userPatch) {\n295\t    merged = mergePatch(merged, userPatch);\n296\t  }\n297\t\n298\t  // Apply project patch\n299\t  const projectPatch = loadPatch(projectPatchPath);\n300\t  if (projectPatch) {\n301\t    merged = mergePatch(merged, projectPatch);\n302\t  }\n303\t\n304\t  // Validate merged result (strip prompt_patches for schema validation since it's not in schema)\n305\t  const { prompt_patches, ...forValidation } = merged as Record<string, unknown> & { prompt_patches?: unknown };\n306\t  const result = validateAgentSchema(forValidation);\n307\t  if (!result.valid) {\n308\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n309\t    const errorPath = projectPatch ? projectPatchPath : userPatch ? userPatchPath : 'merged';\n310\t    throw new AgentResolveError(\n311\t      `Schema validation failed after merging patches for ${name}: ${details}`,\n312\t      errorPath,\n313\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n314\t    );\n315\t  }\n316\t\n317\t  // Re-attach prompt_patches if present, return without mutating forValidation\n318\t  return (prompt_patches\n319\t    ? { ...forValidation, prompt_patches }\n320\t    : forValidation) as unknown as ResolvedAgent;\n321\t}\n322\t\n323\t// --- Subagent Compilation ---\n324\t\n325\t/**\n326\t * Compile a ResolvedAgent into a SubagentDefinition for Agent SDK dispatch.\n327\t */\n328\texport function compileSubagentDefinition(agent: ResolvedAgent): SubagentDefinition {\n329\t  const parts: string[] = [];\n330\t\n331\t  parts.push(`You are ${agent.persona.identity}`);\n332\t  parts.push(`Communication style: ${agent.persona.communication_style}`);\n333\t\n334\t  if (agent.persona.principles.length > 0) {\n335\t    const bullets = agent.persona.principles.map((p) => `- ${p}`).join('\\n');\n336\t    parts.push(`Principles:\\n${bullets}`);\n337\t  }\n338\t\n339\t  if (agent.prompt_patches?.append) {\n340\t    parts.push(agent.prompt_patches.append);\n341\t  }\n342\t\n343\t  return {\n344\t    name: agent.name,\n345\t    model: DEFAULT_MODEL,\n346\t    instructions: parts.join('\\n\\n'),\n347\t    disallowedTools: agent.disallowedTools ?? [],\n348\t    bare: true,\n349\t  };\n350\t}\n351\t"}]},"parent_tool_use_id":"toolu_01X7ZCkNrtprTmX6J7uq9WM7","session_id":"52ded6f4-857c-404a-a480-19bb12459ee1","uuid":"6d6d6c11-2b94-47f5-ab96-bac7a8b34fda","timestamp":"2026-04-03T00:34:00.365Z"}
