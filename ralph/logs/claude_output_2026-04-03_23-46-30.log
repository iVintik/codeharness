{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XgXkCUVbFW8q2geMDbn11X","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, type Mock } from 'vitest';\n2\timport { WorktreeManager, WorktreeError, BRANCH_PREFIX, WORKTREE_BASE } from '../worktree-manager.js';\n3\timport type { WorktreeInfo } from '../worktree-manager.js';\n4\t\n5\t// Mock child_process\n6\tvi.mock('node:child_process', () => ({\n7\t  execSync: vi.fn(),\n8\t}));\n9\t\n10\t// Mock node:fs\n11\tvi.mock('node:fs', () => ({\n12\t  existsSync: vi.fn(),\n13\t  readFileSync: vi.fn(),\n14\t  statSync: vi.fn(),\n15\t}));\n16\t\n17\timport { execSync } from 'node:child_process';\n18\timport { existsSync, readFileSync, statSync } from 'node:fs';\n19\t\n20\tconst mockExecSync = execSync as Mock;\n21\tconst mockExistsSync = existsSync as Mock;\n22\tconst mockReadFileSync = readFileSync as Mock;\n23\tconst mockStatSync = statSync as Mock;\n24\t\n25\tdescribe('worktree-manager', () => {\n26\t  let manager: WorktreeManager;\n27\t\n28\t  beforeEach(() => {\n29\t    vi.clearAllMocks();\n30\t    manager = new WorktreeManager('main', '/repo');\n31\t    // Default: no stale state exists\n32\t    mockExistsSync.mockReturnValue(false);\n33\t    // Default: no existing branches\n34\t    mockExecSync.mockReturnValue(Buffer.from(''));\n35\t    // Default: statSync returns a fixed birthtime\n36\t    mockStatSync.mockReturnValue({ birthtime: new Date('2026-01-15T10:00:00Z') });\n37\t  });\n38\t\n39\t  describe('WorktreeError', () => {\n40\t    it('includes stderr in the error (AC #11)', () => {\n41\t      const err = new WorktreeError('something failed', 'fatal: not a git repo');\n42\t      expect(err).toBeInstanceOf(Error);\n43\t      expect(err.name).toBe('WorktreeError');\n44\t      expect(err.message).toBe('something failed');\n45\t      expect(err.stderr).toBe('fatal: not a git repo');\n46\t    });\n47\t  });\n48\t\n49\t  describe('constants', () => {\n50\t    it('branch prefix uses codeharness/ namespace (NFR12)', () => {\n51\t      expect(BRANCH_PREFIX).toBe('codeharness/epic-');\n52\t      expect(BRANCH_PREFIX.startsWith('codeharness/')).toBe(true);\n53\t    });\n54\t\n55\t    it('worktree base is in /tmp', () => {\n56\t      expect(WORKTREE_BASE).toBe('/tmp/codeharness-wt-epic-');\n57\t    });\n58\t  });\n59\t\n60\t  describe('createWorktree', () => {\n61\t    it('creates branch and worktree, returns path (AC #1, #2)', () => {\n62\t      // No stale state\n63\t      mockExecSync.mockImplementation((cmd: string) => {\n64\t        if (cmd.includes('branch --list')) return Buffer.from('');\n65\t        return Buffer.from('');\n66\t      });\n67\t\n68\t      const path = manager.createWorktree('17', 'worktree-manager');\n69\t\n70\t      expect(path).toBe('/tmp/codeharness-wt-epic-17');\n71\t\n72\t      // Verify git commands were called\n73\t      const calls = mockExecSync.mock.calls.map((c: unknown[]) => c[0] as string);\n74\t      expect(calls).toContainEqual(\n75\t        expect.stringContaining('git branch codeharness/epic-17-worktree-manager main'),\n76\t      );\n77\t      expect(calls).toContainEqual(\n78\t        expect.stringContaining('git worktree add /tmp/codeharness-wt-epic-17 codeharness/epic-17-worktree-manager'),\n79\t      );\n80\t    });\n81\t\n82\t    it('uses codeharness/ prefix for branch names (AC #11, NFR12)', () => {\n83\t      mockExecSync.mockReturnValue(Buffer.from(''));\n84\t\n85\t      manager.createWorktree('42', 'my-epic');\n86\t\n87\t      const calls = mockExecSync.mock.calls.map((c: unknown[]) => c[0] as string);\n88\t      const branchCmd = calls.find((c) => c.includes('git branch codeharness/'));\n89\t      expect(branchCmd).toContain('codeharness/epic-42-my-epic');\n90\t    });\n91\t\n92\t    it('sanitizes slug to [a-z0-9-] (edge case)', () => {\n93\t      mockExecSync.mockReturnValue(Buffer.from(''));\n94\t\n95\t      manager.createWorktree('1', 'My Epic With CAPS & Symbols!');\n96\t\n97\t      const calls = mockExecSync.mock.calls.map((c: unknown[]) => c[0] as string);\n98\t      const branchCmd = calls.find((c) => c.startsWith('git branch codeharness/'));\n99\t      expect(branchCmd).toContain('codeharness/epic-1-my-epic-with-caps-symbols');\n100\t    });\n101\t\n102\t    it('cleans up stale branch before re-creating (AC #9)', () => {\n103\t      // Simulate stale branch existing\n104\t      let callCount = 0;\n105\t      mockExecSync.mockImplementation((cmd: string) => {\n106\t        if (cmd.includes('branch --list')) {\n107\t          // First call during cleanup: stale branch exists\n108\t          if (callCount === 0) {\n109\t            callCount++;\n110\t            return Buffer.from('  codeharness/epic-17-old-slug\\n');\n111\t          }\n112\t          return Buffer.from('');\n113\t        }\n114\t        return Buffer.from('');\n115\t      });\n116\t\n117\t      const path = manager.createWorktree('17', 'new-slug');\n118\t      expect(path).toBe('/tmp/codeharness-wt-epic-17');\n119\t\n120\t      // Should have cleaned up the stale branch\n121\t      const calls = mockExecSync.mock.calls.map((c: unknown[]) => c[0] as string);\n122\t      expect(calls).toContainEqual(\n123\t        expect.stringContaining('git branch -D codeharness/epic-17-old-slug'),\n124\t      );\n125\t    });\n126\t\n127\t    it('cleans up stale worktree directory before re-creating (AC #9)', () => {\n128\t      // Simulate worktree directory existing on disk\n129\t      mockExistsSync.mockImplementation((p: string) => {\n130\t        return p === '/tmp/codeharness-wt-epic-17';\n131\t      });\n132\t      mockExecSync.mockReturnValue(Buffer.from(''));\n133\t\n134\t      const path = manager.createWorktree('17', 'slug');\n135\t      expect(path).toBe('/tmp/codeharness-wt-epic-17');\n136\t\n137\t      // Should have tried to remove the stale worktree\n138\t      const calls = mockExecSync.mock.calls.map((c: unknown[]) => c[0] as string);\n139\t      expect(calls).toContainEqual(\n140\t        expect.stringContaining('git worktree remove /tmp/codeharness-wt-epic-17 --force'),\n141\t      );\n142\t    });\n143\t\n144\t    it('throws WorktreeError with stderr on git failure (AC #10)', () => {\n145\t      const gitError = new Error('Command failed');\n146\t      (gitError as unknown as { stderr: Buffer }).stderr = Buffer.from('fatal: not a git repository');\n147\t      mockExecSync.mockImplementation((cmd: string) => {\n148\t        if (cmd.includes('branch --list')) return Buffer.from('');\n149\t        if (cmd.startsWith('git branch codeharness/')) throw gitError;\n150\t        return Buffer.from('');\n151\t      });\n152\t\n153\t      expect(() => manager.createWorktree('17', 'slug')).toThrow(WorktreeError);\n154\t      try {\n155\t        manager.createWorktree('17', 'slug');\n156\t      } catch (err) {\n157\t        expect(err).toBeInstanceOf(WorktreeError);\n158\t        expect((err as WorktreeError).stderr).toContain('fatal: not a git repository');\n159\t        expect((err as WorktreeError).message).toContain('fatal: not a git repository');\n160\t      }\n161\t    });\n162\t\n163\t    it('cleans up partial state on failure — branch created but worktree fails (AC #10)', () => {\n164\t      let branchCreated = false;\n165\t      mockExecSync.mockImplementation((cmd: string) => {\n166\t        if (cmd.includes('branch --list')) return Buffer.from('');\n167\t        if (cmd.startsWith('git branch codeharness/') && !cmd.includes('-D')) {\n168\t          branchCreated = true;\n169\t          return Buffer.from('');\n170\t        }\n171\t        if (cmd.startsWith('git worktree add') && branchCreated) {\n172\t          const err = new Error('disk full');\n173\t          (err as unknown as { stderr: Buffer }).stderr = Buffer.from('error: disk full');\n174\t          throw err;\n175\t        }\n176\t        // Cleanup calls should succeed\n177\t        return Buffer.from('');\n178\t      });\n179\t\n180\t      expect(() => manager.createWorktree('17', 'slug')).toThrow(WorktreeError);\n181\t\n182\t      // Verify cleanup was attempted — branch -D should have been called\n183\t      const calls = mockExecSync.mock.calls.map((c: unknown[]) => c[0] as string);\n184\t      expect(calls).toContainEqual(\n185\t        expect.stringContaining('git branch -D codeharness/epic-17-slug'),\n186\t      );\n187\t    });\n188\t\n189\t    it('all error messages include stderr from git (AC #11)', () => {\n190\t      const gitError = new Error('fail');\n191\t      (gitError as unknown as { stderr: Buffer }).stderr = Buffer.from('stderr content here');\n192\t      mockExecSync.mockImplementation((cmd: string) => {\n193\t        if (cmd.includes('branch --list')) return Buffer.from('');\n194\t        if (cmd.startsWith('git branch codeharness/')) throw gitError;\n195\t        return Buffer.from('');\n196\t      });\n197\t\n198\t      try {\n199\t        manager.createWorktree('1', 'x');\n200\t      } catch (err) {\n201\t        expect(err).toBeInstanceOf(WorktreeError);\n202\t        expect((err as WorktreeError).stderr).toBe('stderr content here');\n203\t      }\n204\t    });\n205\t  });\n206\t\n207\t  describe('cleanupWorktree', () => {\n208\t    it('removes worktree and branch (AC #4)', () => {\n209\t      mockExecSync.mockImplementation((cmd: string) => {\n210\t        if (cmd.includes('branch --list')) {\n211\t          return Buffer.from('  codeharness/epic-17-my-slug\\n');\n212\t        }\n213\t        return Buffer.from('');\n214\t      });\n215\t\n216\t      manager.cleanupWorktree('17');\n217\t\n218\t      const calls = mockExecSync.mock.calls.map((c: unknown[]) => c[0] as string);\n219\t      expect(calls).toContainEqual(\n220\t        expect.stringContaining('git worktree remove /tmp/codeharness-wt-epic-17 --force'),\n221\t      );\n222\t      expect(calls).toContainEqual(\n223\t        expect.stringContaining('git branch -D codeharness/epic-17-my-slug'),\n224\t      );\n225\t    });\n226\t\n227\t    it('is idempotent — no error when nothing exists (AC #5)', () => {\n228\t      // All git commands fail (nothing exists)\n229\t      mockExecSync.mockImplementation(() => {\n230\t        const err = new Error('not found');\n231\t        (err as unknown as { stderr: Buffer }).stderr = Buffer.from('error: not found');\n232\t        throw err;\n233\t      });\n234\t\n235\t      // Should not throw\n236\t      expect(() => manager.cleanupWorktree('99')).not.toThrow();\n237\t    });\n238\t\n239\t    it('completes even if only branch exists (no worktree)', () => {\n240\t      mockExecSync.mockImplementation((cmd: string) => {\n241\t        if (cmd.includes('worktree remove')) {\n242\t          const err = new Error('no worktree');\n243\t          (err as unknown as { stderr: Buffer }).stderr = Buffer.from('');\n244\t          throw err;\n245\t        }\n246\t        if (cmd.includes('branch --list')) {\n247\t          return Buffer.from('  codeharness/epic-5-slug\\n');\n248\t        }\n249\t        return Buffer.from('');\n250\t      });\n251\t\n252\t      expect(() => manager.cleanupWorktree('5')).not.toThrow();\n253\t    });\n254\t  });\n255\t\n256\t  describe('listWorktrees', () => {\n257\t    it('returns only codeharness-prefixed worktrees (AC #6)', () => {\n258\t      const porcelain = [\n259\t        'worktree /repo',\n260\t        'HEAD abc123',\n261\t        'branch refs/heads/main',\n262\t        '',\n263\t        'worktree /tmp/codeharness-wt-epic-17',\n264\t        'HEAD def456',\n265\t        'branch refs/heads/codeharness/epic-17-worktree-manager',\n266\t        '',\n267\t        'worktree /tmp/other-worktree',\n268\t        'HEAD 789abc',\n269\t        'branch refs/heads/feature/something',\n270\t        '',\n271\t        'worktree /tmp/codeharness-wt-epic-18',\n272\t        'HEAD aaa111',\n273\t        'branch refs/heads/codeharness/epic-18-lane-pool',\n274\t        '',\n275\t      ].join('\\n');\n276\t\n277\t      mockExecSync.mockReturnValue(Buffer.from(porcelain));\n278\t\n279\t      const result = manager.listWorktrees();\n280\t\n281\t      expect(result).toHaveLength(2);\n282\t      expect(result[0].epicId).toBe('17');\n283\t      expect(result[0].path).toBe('/tmp/codeharness-wt-epic-17');\n284\t      expect(result[0].branch).toBe('codeharness/epic-17-worktree-manager');\n285\t      expect(result[1].epicId).toBe('18');\n286\t      expect(result[1].path).toBe('/tmp/codeharness-wt-epic-18');\n287\t      expect(result[1].branch).toBe('codeharness/epic-18-lane-pool');\n288\t    });\n289\t\n290\t    it('returns WorktreeInfo with all required fields (AC #6)', () => {\n291\t      const porcelain = [\n292\t        'worktree /tmp/codeharness-wt-epic-5',\n293\t        'HEAD abc123',\n294\t        'branch refs/heads/codeharness/epic-5-slug',\n295\t        '',\n296\t      ].join('\\n');\n297\t      mockExecSync.mockReturnValue(Buffer.from(porcelain));\n298\t      const fixedDate = new Date('2026-03-20T14:00:00Z');\n299\t      mockStatSync.mockReturnValue({ birthtime: fixedDate });\n300\t\n301\t      const result = manager.listWorktrees();\n302\t\n303\t      expect(result).toHaveLength(1);\n304\t      const wt = result[0];\n305\t      expect(wt).toHaveProperty('epicId', '5');\n306\t      expect(wt).toHaveProperty('path', '/tmp/codeharness-wt-epic-5');\n307\t      expect(wt).toHaveProperty('branch', 'codeharness/epic-5-slug');\n308\t      expect(wt).toHaveProperty('createdAt');\n309\t      expect(wt.createdAt).toEqual(fixedDate);\n310\t    });\n311\t\n312\t    it('uses current time as createdAt fallback when statSync fails', () => {\n313\t      const porcelain = [\n314\t        'worktree /tmp/codeharness-wt-epic-5',\n315\t        'HEAD abc123',\n316\t        'branch refs/heads/codeharness/epic-5-slug',\n317\t        '',\n318\t      ].join('\\n');\n319\t      mockExecSync.mockReturnValue(Buffer.from(porcelain));\n320\t      mockStatSync.mockImplementation(() => { throw new Error('ENOENT'); });\n321\t\n322\t      const before = new Date();\n323\t      const result = manager.listWorktrees();\n324\t      const after = new Date();\n325\t\n326\t      expect(result).toHaveLength(1);\n327\t      expect(result[0].createdAt.getTime()).toBeGreaterThanOrEqual(before.getTime());\n328\t      expect(result[0].createdAt.getTime()).toBeLessThanOrEqual(after.getTime());\n329\t    });\n330\t\n331\t    it('returns empty array when no codeharness worktrees exist (AC #7)', () => {\n332\t      const porcelain = [\n333\t        'worktree /repo',\n334\t        'HEAD abc123',\n335\t        'branch refs/heads/main',\n336\t        '',\n337\t      ].join('\\n');\n338\t      mockExecSync.mockReturnValue(Buffer.from(porcelain));\n339\t\n340\t      const result = manager.listWorktrees();\n341\t      expect(result).toEqual([]);\n342\t    });\n343\t\n344\t    it('returns empty array when git worktree list fails', () => {\n345\t      mockExecSync.mockImplementation(() => {\n346\t        throw new Error('not a git repo');\n347\t      });\n348\t\n349\t      const result = manager.listWorktrees();\n350\t      expect(result).toEqual([]);\n351\t    });\n352\t\n353\t    it('sorts results by epicId numerically', () => {\n354\t      const porcelain = [\n355\t        'worktree /tmp/codeharness-wt-epic-20',\n356\t        'HEAD aaa',\n357\t        'branch refs/heads/codeharness/epic-20-z',\n358\t        '',\n359\t        'worktree /tmp/codeharness-wt-epic-3',\n360\t        'HEAD bbb',\n361\t        'branch refs/heads/codeharness/epic-3-a',\n362\t        '',\n363\t        'worktree /tmp/codeharness-wt-epic-10',\n364\t        'HEAD ccc',\n365\t        'branch refs/heads/codeharness/epic-10-m',\n366\t        '',\n367\t      ].join('\\n');\n368\t      mockExecSync.mockReturnValue(Buffer.from(porcelain));\n369\t\n370\t      const result = manager.listWorktrees();\n371\t      expect(result.map((r) => r.epicId)).toEqual(['3', '10', '20']);\n372\t    });\n373\t  });\n374\t\n375\t  describe('detectOrphans', () => {\n376\t    it('identifies worktrees without lane-state.json as orphaned (AC #8)', () => {\n377\t      const porcelain = [\n378\t        'worktree /tmp/codeharness-wt-epic-17',\n379\t        'HEAD abc123',\n380\t        'branch refs/heads/codeharness/epic-17-slug',\n381\t        '',\n382\t      ].join('\\n');\n383\t      mockExecSync.mockReturnValue(Buffer.from(porcelain));\n384\t      // lane-state.json does not exist\n385\t      mockExistsSync.mockReturnValue(false);\n386\t\n387\t      const orphans = manager.detectOrphans();\n388\t\n389\t      expect(orphans).toHaveLength(1);\n390\t      expect(orphans[0].epicId).toBe('17');\n391\t    });\n392\t\n393\t    it('identifies worktrees with no PID in lane-state.json as orphaned (AC #8)', () => {\n394\t      const porcelain = [\n395\t        'worktree /tmp/codeharness-wt-epic-17',\n396\t        'HEAD abc123',\n397\t        'branch refs/heads/codeharness/epic-17-slug',\n398\t        '',\n399\t      ].join('\\n');\n400\t      mockExecSync.mockReturnValue(Buffer.from(porcelain));\n401\t      mockExistsSync.mockReturnValue(true);\n402\t      mockReadFileSync.mockReturnValue(JSON.stringify({})); // No pid field\n403\t\n404\t      const orphans = manager.detectOrphans();\n405\t      expect(orphans).toHaveLength(1);\n406\t    });\n407\t\n408\t    it('identifies worktrees with dead PID as orphaned (AC #8)', () => {\n409\t      const porcelain = [\n410\t        'worktree /tmp/codeharness-wt-epic-17',\n411\t        'HEAD abc123',\n412\t        'branch refs/heads/codeharness/epic-17-slug',\n413\t        '',\n414\t      ].join('\\n');\n415\t      mockExecSync.mockReturnValue(Buffer.from(porcelain));\n416\t      mockExistsSync.mockReturnValue(true);\n417\t      mockReadFileSync.mockReturnValue(JSON.stringify({ pid: 999999999 }));\n418\t      // process.kill(999999999, 0) will throw because PID doesn't exist\n419\t      const killSpy = vi.spyOn(process, 'kill').mockImplementation(() => {\n420\t        throw new Error('ESRCH');\n421\t      });\n422\t\n423\t      const 