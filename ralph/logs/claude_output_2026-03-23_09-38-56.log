    \"currentPhase\": null,\n   293→    \"lastAction\": null,\n   294→    \"acProgress\": null\n   295→  },\n   296→  \"actionItems\": [\n   297→    {\n   298→      \"id\": \"migrated-1\",\n   299→      \"story\": \"8-1-rust-stack-and-app-type-detection\",\n   300→      \"description\": \"**Code quality concern:** Cargo.toml parsing uses simple string `includes()` matching, not a proper TOML parser. Per NFR4, but a dependency name in a comment or `[dev-dependencies]` would false-positive (e.g., `# we considered using axum` triggers server detection).\",\n   301→      \"source\": \"retro\",\n   302→      \"resolved\": false\n   303→    },\n   304→    {\n   305→      \"id\": \"migrated-2\",\n   306→      \"story\": \"8-1-rust-stack-and-app-type-detection\",\n   307→      \"description\": \"**Observation:** Existing test for \\\"unrecognized stack\\\" was using `'rust'` as unrecognized — changed to `'java'`.\",\n   308→      \"source\": \"retro\",\n   309→      \"resolved\": false\n   310→    },\n   311→    {\n   312→      \"id\": \"migrated-3\",\n   313→      \"story\": \"8-1-rust-stack-and-app-type-detection\",\n   314→      \"description\": \"**Observation:** AC4 maps library crates to `generic` AppType rather than new `'library'` type — deliberate design choice but means library crates are indistinguishable from unknown projects.\",\n   315→      \"source\": \"retro\",\n   316→      \"resolved\": false\n   317→    },\n   318→    {\n   319→      \"id\": \"migrated-4\",\n   320→      \"story\": \"8-1-rust-stack-and-app-type-detection\",\n   321→      \"description\": \"**HIGH fixed:** `[dev-dependencies]`/`[build-dependencies]` deps incorrectly matched as production deps — false positive agent/server detection. Added `getCargoDepsSection()` to extract only `[dependencies]` section.\",\n   322→      \"source\": \"retro\",\n   323→      \"resolved\": false\n   324→    },\n   325→    {\n   326→      \"id\": \"migrated-5\",\n   327→      \"story\": \"8-1-rust-stack-and-app-type-detection\",\n   328→      \"description\": \"**HIGH fixed:** Substring false positives on crate names (`anthropic` matching `anthropic-sdk`, `rocket` matching `sprocket`). Added `hasCargoDep()` with word-boundary regex.\",\n   329→      \"source\": \"retro\",\n   330→      \"resolved\": false\n   331→    },\n   332→    {\n   333→      \"id\": \"migrated-6\",\n   334→      \"story\": \"8-1-rust-stack-and-app-type-detection\",\n   335→      \"description\": \"**MEDIUM fixed:** `[[bin]]` and `[lib]` matched inside TOML comments. Used line-anchored regexes.\",\n   336→      \"source\": \"retro\",\n   337→      \"resolved\": false\n   338→    },\n   339→    {\n   340→      \"id\": \"migrated-7\",\n   341→      \"story\": \"8-1-rust-stack-and-app-type-detection\",\n   342→      \"description\": \"**MEDIUM fixed:** Missing test coverage for 3 of 5 web frameworks (rocket, tide, warp).\",\n   343→      \"source\": \"retro\",\n   344→      \"resolved\": false\n   345→    },\n   346→    {\n   347→      \"id\": \"migrated-8\",\n   348→      \"story\": \"8-1-rust-stack-and-app-type-detection\",\n   349→      \"description\": \"**MEDIUM fixed:** Missing test for `[lib]` + `[[bin]]` dual-crate pattern.\",\n   350→      \"source\": \"retro\",\n   351→      \"resolved\": false\n   352→    },\n   353→    {\n   354→      \"id\": \"migrated-9\",\n   355→      \"story\": \"8-1-rust-stack-and-app-type-detection\",\n   356→      \"description\": \"**LOW unfixed:** `getCargoDepsSection()` does not handle `[dependencies.foo]` inline subsection TOML style. Acceptable per NFR4.\",\n   357→      \"source\": \"retro\",\n   358→      \"resolved\": false\n   359→    },\n   360→    {\n   361→      \"id\": \"migrated-10\",\n   362→      \"story\": \"8-1-rust-stack-and-app-type-detection\",\n   363→      \"description\": \"**Coverage:** 97.02% overall, all 123 files above 80% floor. No integration test for detectStack→detectAppType end-to-end (acceptable — unit tested independently).\",\n  