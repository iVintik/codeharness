{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012cysEkhRfKH3scBZyr7qQC","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach } from 'vitest';\n2\timport fs from 'node:fs';\n3\timport path from 'node:path';\n4\t\n5\t// --- Mock the Agent SDK ---\n6\t\n7\tconst { mockQuery } = vi.hoisted(() => ({\n8\t  mockQuery: vi.fn(),\n9\t}));\n10\t\n11\tvi.mock('@anthropic-ai/claude-agent-sdk', () => ({\n12\t  query: mockQuery,\n13\t}));\n14\t\n15\timport {\n16\t  dispatchAgent,\n17\t  DispatchError,\n18\t} from '../agent-dispatch.js';\n19\timport type {\n20\t  DispatchOptions,\n21\t  DispatchResult,\n22\t  DispatchErrorCode,\n23\t} from '../agent-dispatch.js';\n24\timport type { SubagentDefinition } from '../agent-resolver.js';\n25\t\n26\t// --- Helpers ---\n27\t\n28\tfunction makeDefinition(overrides?: Partial<SubagentDefinition>): SubagentDefinition {\n29\t  return {\n30\t    name: 'test-agent',\n31\t    model: 'claude-sonnet-4-20250514',\n32\t    instructions: 'You are a test agent.',\n33\t    disallowedTools: [],\n34\t    bare: true,\n35\t    ...overrides,\n36\t  };\n37\t}\n38\t\n39\t/**\n40\t * Create an async generator that yields the given messages.\n41\t */\n42\tasync function* fakeStream(messages: Array<Record<string, unknown>>) {\n43\t  for (const msg of messages) {\n44\t    yield msg;\n45\t  }\n46\t}\n47\t\n48\tfunction makeSuccessResult(overrides?: Record<string, unknown>) {\n49\t  return {\n50\t    type: 'result',\n51\t    subtype: 'success',\n52\t    result: 'Agent completed the task.',\n53\t    session_id: 'sess-abc-123',\n54\t    duration_ms: 1234,\n55\t    duration_api_ms: 1000,\n56\t    is_error: false,\n57\t    num_turns: 3,\n58\t    total_cost_usd: 0.05,\n59\t    usage: { input_tokens: 100, output_tokens: 200 },\n60\t    modelUsage: {},\n61\t    permission_denials: [],\n62\t    uuid: 'uuid-123',\n63\t    ...overrides,\n64\t  };\n65\t}\n66\t\n67\tfunction makeErrorResult(overrides?: Record<string, unknown>) {\n68\t  return {\n69\t    type: 'result',\n70\t    subtype: 'error_during_execution',\n71\t    session_id: 'sess-err-456',\n72\t    duration_ms: 500,\n73\t    duration_api_ms: 400,\n74\t    is_error: true,\n75\t    num_turns: 1,\n76\t    stop_reason: null,\n77\t    total_cost_usd: 0.01,\n78\t    usage: { input_tokens: 50, output_tokens: 10 },\n79\t    modelUsage: {},\n80\t    permission_denials: [],\n81\t    errors: ['Something went wrong'],\n82\t    uuid: 'uuid-456',\n83\t    ...overrides,\n84\t  };\n85\t}\n86\t\n87\t// --- Tests ---\n88\t\n89\tdescribe('agent-dispatch', () => {\n90\t  beforeEach(() => {\n91\t    vi.clearAllMocks();\n92\t  });\n93\t\n94\t  describe('successful dispatch', () => {\n95\t    it('returns correct DispatchResult shape (AC #2)', async () => {\n96\t      mockQuery.mockReturnValue(fakeStream([makeSuccessResult()]));\n97\t\n98\t      const result = await dispatchAgent(makeDefinition(), 'Do the thing');\n99\t\n100\t      expect(result).toEqual(\n101\t        expect.objectContaining({\n102\t          sessionId: 'sess-abc-123',\n103\t          success: true,\n104\t          output: 'Agent completed the task.',\n105\t        }),\n106\t      );\n107\t      expect(typeof result.durationMs).toBe('number');\n108\t      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n109\t    });\n110\t\n111\t    it('durationMs is a positive number (AC #3)', async () => {\n112\t      mockQuery.mockReturnValue(fakeStream([makeSuccessResult()]));\n113\t\n114\t      const result = await dispatchAgent(makeDefinition(), 'Do the thing');\n115\t\n116\t      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n117\t      expect(Number.isFinite(result.durationMs)).toBe(true);\n118\t    });\n119\t\n120\t    it('returns success: false for error result subtype', async () => {\n121\t      mockQuery.mockReturnValue(fakeStream([makeErrorResult()]));\n122\t\n123\t      const result = await dispatchAgent(makeDefinition(), 'Do the thing');\n124\t\n125\t      expect(result.success).toBe(false);\n126\t      expect(result.sessionId).toBe('sess-err-456');\n127\t    });\n128\t\n129\t    it('captures session_id from intermediate messages', async () => {\n130\t      mockQuery.mockReturnValue(\n131\t        fakeStream([\n132\t          { type: 'system', session_id: 'sess-early', tools: [] },\n133\t          makeSuccessResult({ session_id: 'sess-final' }),\n134\t        ]),\n135\t      );\n136\t\n137\t      const result = await dispatchAgent(makeDefinition(), 'Do the thing');\n138\t\n139\t      expect(result.sessionId).toBe('sess-final');\n140\t    });\n141\t  });\n142\t\n143\t  describe('SDK call parameters', () => {\n144\t    it('passes prompt to query() (AC #1)', async () => {\n145\t      mockQuery.mockReturnValue(fakeStream([makeSuccessResult()]));\n146\t\n147\t      await dispatchAgent(makeDefinition(), 'Build a widget');\n148\t\n149\t      expect(mockQuery).toHaveBeenCalledTimes(1);\n150\t      const call = mockQuery.mock.calls[0][0];\n151\t      expect(call.prompt).toBe('Build a widget');\n152\t    });\n153\t\n154\t    it('passes model from definition to options (AC #1)', async () => {\n155\t      mockQuery.mockReturnValue(fakeStream([makeSuccessResult()]));\n156\t\n157\t      await dispatchAgent(\n158\t        makeDefinition({ model: 'claude-opus-4-20250514' }),\n159\t        'Do the thing',\n160\t      );\n161\t\n162\t      const call = mockQuery.mock.calls[0][0];\n163\t      expect(call.options.model).toBe('claude-opus-4-20250514');\n164\t    });\n165\t\n166\t    it('passes systemPrompt from definition instructions (AC #1)', async () => {\n167\t      mockQuery.mockReturnValue(fakeStream([makeSuccessResult()]));\n168\t\n169\t      await dispatchAgent(\n170\t        makeDefinition({ instructions: 'You are an expert coder.' }),\n171\t        'Do the thing',\n172\t      );\n173\t\n174\t      const call = mockQuery.mock.calls[0][0];\n175\t      expect(call.options.systemPrompt).toBe('You are an expert coder.');\n176\t    });\n177\t\n178\t    it('passes disallowedTools from definition (AC #1)', async () => {\n179\t      mockQuery.mockReturnValue(fakeStream([makeSuccessResult()]));\n180\t\n181\t      await dispatchAgent(\n182\t        makeDefinition({ disallowedTools: ['Edit', 'Write'] }),\n183\t        'Do the thing',\n184\t      );\n185\t\n186\t      const call = mockQuery.mock.calls[0][0];\n187\t      expect(call.options.disallowedTools).toEqual(['Edit', 'Write']);\n188\t    });\n189\t\n190\t    it('passes cwd from options (AC #9)', async () => {\n191\t      mockQuery.mockReturnValue(fakeStream([makeSuccessResult()]));\n192\t\n193\t      await dispatchAgent(makeDefinition(), 'Do the thing', {\n194\t        cwd: '/some/path',\n195\t      });\n196\t\n197\t      const call = mockQuery.mock.calls[0][0];\n198\t      expect(call.options.cwd).toBe('/some/path');\n199\t    });\n200\t\n201\t    it('does not pass cwd when not provided', async () => {\n202\t      mockQuery.mockReturnValue(fakeStream([makeSuccessResult()]));\n203\t\n204\t      await dispatchAgent(makeDefinition(), 'Do the thing');\n205\t\n206\t      const call = mockQuery.mock.calls[0][0];\n207\t      expect(call.options.cwd).toBeUndefined();\n208\t    });\n209\t\n210\t    it('passes appendSystemPrompt by appending to instructions', async () => {\n211\t      mockQuery.mockReturnValue(fakeStream([makeSuccessResult()]));\n212\t\n213\t      await dispatchAgent(\n214\t        makeDefinition({ instructions: 'Base instructions.' }),\n215\t        'Do the thing',\n216\t        { appendSystemPrompt: 'TRACE-ID: abc-123' },\n217\t      );\n218\t\n219\t      const call = mockQuery.mock.calls[0][0];\n220\t      expect(call.options.systemPrompt).toBe(\n221\t        'Base instructions.\\n\\nTRACE-ID: abc-123',\n222\t      );\n223\t    });\n224\t\n225\t    it('does not modify systemPrompt when appendSystemPrompt is not provided', async () => {\n226\t      mockQuery.mockReturnValue(fakeStream([makeSuccessResult()]));\n227\t\n228\t      await dispatchAgent(\n229\t        makeDefinition({ instructions: 'Base instructions.' }),\n230\t        'Do the thing',\n231\t      );\n232\t\n233\t      const call = mockQuery.mock.calls[0][0];\n234\t      expect(call.options.systemPrompt).toBe('Base instructions.');\n235\t    });\n236\t\n237\t    it('passes resume from sessionId option (forward-compat for story 4-2)', async () => {\n238\t      mockQuery.mockReturnValue(fakeStream([makeSuccessResult()]));\n239\t\n240\t      await dispatchAgent(makeDefinition(), 'Continue', {\n241\t        sessionId: 'sess-resume-789',\n242\t      });\n243\t\n244\t      const call = mockQuery.mock.calls[0][0];\n245\t      expect(call.options.resume).toBe('sess-resume-789');\n246\t    });\n247\t  });\n248\t\n249\t  describe('error classification', () => {\n250\t    it('classifies HTTP 429 as RATE_LIMIT (AC #5)', async () => {\n251\t      const sdkError = Object.assign(new Error('Rate limit exceeded'), {\n252\t        status: 429,\n253\t      });\n254\t      mockQuery.mockImplementation(() => {\n255\t        throw sdkError;\n256\t      });\n257\t\n258\t      await expect(\n259\t        dispatchAgent(makeDefinition({ name: 'rate-test' }), 'Go'),\n260\t      ).rejects.toThrow(DispatchError);\n261\t\n262\t      try {\n263\t        await dispatchAgent(makeDefinition({ name: 'rate-test' }), 'Go');\n264\t      } catch (err) {\n265\t        const e = err as DispatchError;\n266\t        expect(e.code).toBe('RATE_LIMIT');\n267\t        expect(e.agentName).toBe('rate-test');\n268\t        expect(e.cause).toBe(sdkError);\n269\t      }\n270\t    });\n271\t\n272\t    it('classifies \"rate limit\" in message as RATE_LIMIT (AC #5)', async () => {\n273\t      mockQuery.mockImplementation(() => {\n274\t        throw new Error('You have been rate limited, please slow down');\n275\t      });\n276\t\n277\t      try {\n278\t        await dispatchAgent(makeDefinition({ name: 'rl-msg' }), 'Go');\n279\t      } catch (err) {\n280\t        const e = err as DispatchError;\n281\t        expect(e.code).toBe('RATE_LIMIT');\n282\t        expect(e.agentName).toBe('rl-msg');\n283\t      }\n284\t    });\n285\t\n286\t    it('classifies ECONNREFUSED as NETWORK (AC #6)', async () => {\n287\t      mockQuery.mockImplementation(() => {\n288\t        throw Object.assign(new Error('connect ECONNREFUSED'), {\n289\t          code: 'ECONNREFUSED',\n290\t        });\n291\t      });\n292\t\n293\t      try {\n294\t        await dispatchAgent(makeDefinition({ name: 'net-test' }), 'Go');\n295\t      } catch (err) {\n296\t        const e = err as DispatchError;\n297\t        expect(e.code).toBe('NETWORK');\n298\t        expect(e.agentName).toBe('net-test');\n299\t      }\n300\t    });\n301\t\n302\t    it('classifies ETIMEDOUT as NETWORK (AC #6)', async () => {\n303\t      mockQuery.mockImplementation(() => {\n304\t        throw Object.assign(new Error('request timed out'), {\n305\t          code: 'ETIMEDOUT',\n306\t        });\n307\t      });\n308\t\n309\t      try {\n310\t        await dispatchAgent(makeDefinition({ name: 'timeout-test' }), 'Go');\n311\t      } catch (err) {\n312\t        const e = err as DispatchError;\n313\t        expect(e.code).toBe('NETWORK');\n314\t      }\n315\t    });\n316\t\n317\t    it('classifies ENOTFOUND as NETWORK (AC #6)', async () => {\n318\t      mockQuery.mockImplementation(() => {\n319\t        throw Object.assign(new Error('getaddrinfo ENOTFOUND'), {\n320\t          code: 'ENOTFOUND',\n321\t        });\n322\t      });\n323\t\n324\t      try {\n325\t        await dispatchAgent(makeDefinition({ name: 'dns-test' }), 'Go');\n326\t      } catch (err) {\n327\t        const e = err as DispatchError;\n328\t        expect(e.code).toBe('NETWORK');\n329\t      }\n330\t    });\n331\t\n332\t    it('classifies \"claude binary not found\" as SDK_INIT (AC #7)', async () => {\n333\t      mockQuery.mockImplementation(() => {\n334\t        throw new Error('claude binary not found in PATH');\n335\t      });\n336\t\n337\t      try {\n338\t        await dispatchAgent(makeDefinition({ name: 'init-test' }), 'Go');\n339\t      } catch (err) {\n340\t        const e = err as DispatchError;\n341\t        expect(e.code).toBe('SDK_INIT');\n342\t        expect(e.agentName).toBe('init-test');\n343\t      }\n344\t    });\n345\t\n346\t    it('classifies SDK constructor failure as SDK_INIT (AC #7)', async () => {\n347\t      mockQuery.mockImplementation(() => {\n348\t        throw new Error('SDK initialization failed: cannot initialize runtime');\n349\t      });\n350\t\n351\t      try {\n352\t        await dispatchAgent(makeDefinition({ name: 'sdk-fail' }), 'Go');\n353\t      } catch (err) {\n354\t        const e = err as DispatchError;\n355\t        expect(e.code).toBe('SDK_INIT');\n356\t      }\n357\t    });\n358\t\n359\t    it('classifies unknown errors as UNKNOWN (AC #8)', async () => {\n360\t      mockQuery.mockImplementation(() => {\n361\t        throw new Error('Something completely unexpected');\n362\t      });\n363\t\n364\t      try {\n365\t        await dispatchAgent(makeDefinition({ name: 'unknown-test' }), 'Go');\n366\t      } catch (err) {\n367\t        const e = err as DispatchError;\n368\t        expect(e.code).toBe('UNKNOWN');\n369\t        expect(e.agentName).toBe('unknown-test');\n370\t        expect(e.message).toContain('Something completely unexpected');\n371\t        expect(e.cause).toBeInstanceOf(Error);\n372\t      }\n373\t    });\n374\t\n375\t    it('classifies non-Error throws as UNKNOWN (AC #8)', async () => {\n376\t      mockQuery.mockImplementation(() => {\n377\t        throw 'string error'; // eslint-disable-line no-throw-literal\n378\t      });\n379\t\n380\t      try {\n381\t        await dispatchAgent(makeDefinition({ name: 'str-err' }), 'Go');\n382\t      } catch (err) {\n383\t        const e = err as DispatchError;\n384\t        expect(e.code).toBe('UNKNOWN');\n385\t        expect(e.cause).toBe('string error');\n386\t      }\n387\t    });\n388\t\n389\t    it('DispatchError has correct name and structure', () => {\n390\t      const err = new DispatchError('test msg', 'NETWORK', 'my-agent', new Error('orig'));\n391\t      expect(err.name).toBe('DispatchError');\n392\t      expect(err.message).toBe('test msg');\n393\t      expect(err.code).toBe('NETWORK');\n394\t      expect(err.agentName).toBe('my-agent');\n395\t      expect(err.cause).toBeInstanceOf(Error);\n396\t      expect(err).toBeInstanceOf(Error);\n397\t      expect(err).toBeInstanceOf(DispatchError);\n398\t    });\n399\t  });\n400\t\n401\t  describe('no child_process usage (AC #4, NFR11)', () => {\n402\t    it('agent-dispatch.ts does not import child_process', () => {\n403\t      const sourcePath = path.resolve(__dirname, '../agent-dispatch.ts');\n404\t      const source = fs.readFileSync(sourcePath, 'utf-8');\n405\t      expect(source).not.toContain('child_process');\n406\t      expect(source).not.toContain('execFileSync');\n407\t      expect(source).not.toContain('spawn');\n408\t      expect(source).not.toContain('exec(');\n409\t    });\n410\t  });\n411\t\n412\t  describe('error during stream consumption', () => {\n413\t    it('classifies errors thrown during async iteration', async () => {\n414\t      async function* throwingStream() {\n415\t        yield { type: 'system', session_id: 'sess-mid', tools: [] };\n416\t        throw Object.assign(new Error('connection reset'), {\n417\t          code: 'ECONNRESET',\n418\t        });\n419\t      }\n420\t\n421\t      mockQuery.mockReturnValue(throwingStream());\n422\t\n423\t      try {\n424\t        await dispatchAgent(makeDefinition({ name: 'mid-err' }), 'Go');\n425\t      } catch (err) {\n426\t        const e = err as DispatchError;\n427\t        expect(e.code).toBe('NETWORK');\n428\t        expect(e.agentName).toBe('mid-err');\n429\t      }\n430\t    });\n431\t  });\n432\t});\n433\t"}]},"parent_tool_use_id":"toolu_01DmodJessUS9Zyp4CtHWrwe","session_id":"84c2a87f-6818-4ede-b88c-dde16fd6e99b","uuid":"4ce71eb6-3f68-4f06-baec-87da37483be5","timestamp":"2026-04-02T19:49:05.355Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01A37wx7idBzCQ5ava9XNV7L","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { resolve, join } from 'node:path';\n3\timport os from 'node:os';\n4\timport { parse } from 'yaml';\n5\timport { validateAgentSchema } from './schema-validate.js';\n6\t\n7\t// --- Interfaces ---\n8\t\n9\t/**\n10\t * Agent config shape matching agent.schema.json, plus optional prompt_patches\n11\t * accumulated from patch files.\n12\t */\n13\texport interface ResolvedAgent {\n14\t  name: string;\n15\t  role: {\n16\t    title: string;\n17\t    purpose: string;\n18\t  };\n19\t  persona: {\n20\t    identity: string;\n21\t    communication_style: string;\n22\t    principles: string[];\n23\t  };\n24\t  personality?: {\n25\t    traits: Record<string, number>;\n26\t  };\n27\t  disallowedTools?: string[];\n28\t  prompt_patches?: {\n29\t    append?: string;\n30\t  };\n31\t}\n32\t\n33\t/**\n34\t * Compiled subagent definition ready for Agent SDK dispatch.\n35\t */\n36\texport interface SubagentDefinition {\n37\t  name: string;\n38\t  model: string;\n39\t  instructions: string;\n40\t  disallowedTools: string[];\n41\t  bare: true;\n42\t}\n43\t\n44\t/**\n45\t * Patch file structure: extends identifies base, overrides deep-merged,\n46\t * prompt_patches preserved separately.\n47\t */\n48\texport interface AgentPatch {\n49\t  extends?: string;\n50\t  overrides?: Record<string, unknown>;\n51\t  prompt_patches?: {\n52\t    append?: string;\n53\t  };\n54\t}\n55\t\n56\t// --- Error Class ---\n57\t\n58\texport class AgentResolveError extends Error {\n59\t  public readonly filePath: string;\n60\t  public readonly errors: Array<{ path: string; message: string }>;\n61\t\n62\t  constructor(\n63\t    message: string,\n64\t    filePath: string,\n65\t    errors?: Array<{ path: string; message: string }>,\n66\t  ) {\n67\t    super(message);\n68\t    this.name = 'AgentResolveError';\n69\t    this.filePath = filePath;\n70\t    this.errors = errors ?? [];\n71\t  }\n72\t}\n73\t\n74\t// --- Constants ---\n75\t\n76\tconst TEMPLATES_DIR = resolve(__dirname, '../../templates/agents');\n77\tconst DEFAULT_MODEL = 'claude-sonnet-4-20250514';\n78\t\n79\t// --- Input Validation ---\n80\t\n81\tconst SAFE_NAME_RE = /^[a-zA-Z0-9_-]+$/;\n82\t\n83\t/**\n84\t * Validate agent name to prevent path traversal and unexpected characters.\n85\t */\n86\tfunction validateName(name: string): void {\n87\t  if (!name || !SAFE_NAME_RE.test(name)) {\n88\t    throw new AgentResolveError(\n89\t      `Invalid agent name: \"${name}\" — must match ${SAFE_NAME_RE}`,\n90\t      '',\n91\t      [{ path: '', message: `Invalid agent name: ${name}` }],\n92\t    );\n93\t  }\n94\t}\n95\t\n96\t// --- Deep Merge ---\n97\t\n98\t/**\n99\t * Deep merge strategy: objects merge recursively, arrays replace, scalars replace.\n100\t */\n101\tfunction deepMerge(base: Record<string, unknown>, patch: Record<string, unknown>): Record<string, unknown> {\n102\t  const result: Record<string, unknown> = { ...base };\n103\t\n104\t  for (const key of Object.keys(patch)) {\n105\t    const baseVal = base[key];\n106\t    const patchVal = patch[key];\n107\t\n108\t    if (\n109\t      patchVal !== null &&\n110\t      typeof patchVal === 'object' &&\n111\t      !Array.isArray(patchVal) &&\n112\t      baseVal !== null &&\n113\t      typeof baseVal === 'object' &&\n114\t      !Array.isArray(baseVal)\n115\t    ) {\n116\t      result[key] = deepMerge(\n117\t        baseVal as Record<string, unknown>,\n118\t        patchVal as Record<string, unknown>,\n119\t      );\n120\t    } else {\n121\t      result[key] = patchVal;\n122\t    }\n123\t  }\n124\t\n125\t  return result;\n126\t}\n127\t\n128\t// --- Embedded Agent Loading ---\n129\t\n130\t/**\n131\t * Load an embedded agent template from templates/agents/{name}.yaml.\n132\t * Throws AgentResolveError if not found or invalid.\n133\t */\n134\texport function loadEmbeddedAgent(name: string): ResolvedAgent {\n135\t  validateName(name);\n136\t  const filePath = join(TEMPLATES_DIR, `${name}.yaml`);\n137\t\n138\t  let raw: string;\n139\t  try {\n140\t    raw = readFileSync(filePath, 'utf-8');\n141\t  } catch { // IGNORE: rethrow as AgentResolveError with context\n142\t    throw new AgentResolveError(\n143\t      `Embedded agent not found: ${name}`,\n144\t      filePath,\n145\t      [{ path: filePath, message: `File not found: ${filePath}` }],\n146\t    );\n147\t  }\n148\t\n149\t  let parsed: unknown;\n150\t  try {\n151\t    parsed = parse(raw);\n152\t  } catch (err: unknown) {\n153\t    const msg = err instanceof Error ? err.message : String(err);\n154\t    throw new AgentResolveError(\n155\t      `Invalid YAML in embedded agent ${name}: ${msg}`,\n156\t      filePath,\n157\t      [{ path: filePath, message: msg }],\n158\t    );\n159\t  }\n160\t\n161\t  const result = validateAgentSchema(parsed);\n162\t  if (!result.valid) {\n163\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n164\t    throw new AgentResolveError(\n165\t      `Schema validation failed for embedded agent ${name}: ${details}`,\n166\t      filePath,\n167\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n168\t    );\n169\t  }\n170\t\n171\t  return parsed as ResolvedAgent;\n172\t}\n173\t\n174\t// --- Patch Loading ---\n175\t\n176\t/**\n177\t * Load a patch file. Returns null if the file does not exist (silent skip).\n178\t * Throws AgentResolveError on malformed YAML.\n179\t */\n180\texport function loadPatch(filePath: string): AgentPatch | null {\n181\t  if (!existsSync(filePath)) {\n182\t    return null;\n183\t  }\n184\t\n185\t  let raw: string;\n186\t  try {\n187\t    raw = readFileSync(filePath, 'utf-8');\n188\t  } catch { // IGNORE: file unreadable — treat as missing patch\n189\t    return null;\n190\t  }\n191\t\n192\t  let parsed: unknown;\n193\t  try {\n194\t    parsed = parse(raw);\n195\t  } catch (err: unknown) {\n196\t    const msg = err instanceof Error ? err.message : String(err);\n197\t    throw new AgentResolveError(\n198\t      `Invalid YAML in patch file: ${msg}`,\n199\t      filePath,\n200\t      [{ path: filePath, message: msg }],\n201\t    );\n202\t  }\n203\t\n204\t  if (parsed === null || typeof parsed !== 'object') {\n205\t    throw new AgentResolveError(\n206\t      `Patch file is not a valid object`,\n207\t      filePath,\n208\t      [{ path: filePath, message: 'Patch must be a YAML object' }],\n209\t    );\n210\t  }\n211\t\n212\t  return parsed as AgentPatch;\n213\t}\n214\t\n215\t// --- Patch Merging ---\n216\t\n217\t/**\n218\t * Merge a patch onto a base config. Deep-merges overrides, preserves prompt_patches separately.\n219\t */\n220\texport function mergePatch(\n221\t  base: Record<string, unknown>,\n222\t  patch: AgentPatch,\n223\t): Record<string, unknown> {\n224\t  let result = { ...base };\n225\t\n226\t  if (patch.overrides) {\n227\t    result = deepMerge(result, patch.overrides);\n228\t  }\n229\t\n230\t  if (patch.prompt_patches) {\n231\t    const existing = result.prompt_patches as { append?: string } | undefined;\n232\t    const existingAppend = existing?.append ?? '';\n233\t    const newAppend = patch.prompt_patches.append ?? '';\n234\t\n235\t    if (newAppend) {\n236\t      result.prompt_patches = {\n237\t        append: existingAppend ? `${existingAppend}\\n${newAppend}` : newAppend,\n238\t      };\n239\t    }\n240\t  }\n241\t\n242\t  return result;\n243\t}\n244\t\n245\t// --- Main Resolution ---\n246\t\n247\t/**\n248\t * Resolve an agent through the embedded -> user -> project patch chain.\n249\t * For custom agents (no embedded match, found at project/user level without extends), loads directly.\n250\t */\n251\texport function resolveAgent(name: string, options?: { cwd?: string }): ResolvedAgent {\n252\t  validateName(name);\n253\t  const cwd = options?.cwd ?? process.cwd();\n254\t  const userPatchPath = join(os.homedir(), '.codeharness', 'agents', `${name}.patch.yaml`);\n255\t  const projectPatchPath = join(cwd, '.codeharness', 'agents', `${name}.patch.yaml`);\n256\t\n257\t  // Check for custom agent (project-level full config, no extends)\n258\t  const projectCustomPath = join(cwd, '.codeharness', 'agents', `${name}.yaml`);\n259\t  const userCustomPath = join(os.homedir(), '.codeharness', 'agents', `${name}.yaml`);\n260\t\n261\t  // Try custom agent at project level first, then user level\n262\t  for (const customPath of [projectCustomPath, userCustomPath]) {\n263\t    if (existsSync(customPath)) {\n264\t      const patch = loadPatch(customPath);\n265\t      if (patch && !patch.extends) {\n266\t        // This is a full custom agent, not a patch — load and validate directly\n267\t        const parsed = patch as unknown as Record<string, unknown>;\n268\t        // Strip prompt_patches before schema validation (not in schema, same as patch path)\n269\t        const { prompt_patches: customPP, ...customForValidation } = parsed as Record<string, unknown> & { prompt_patches?: unknown };\n270\t        const result = validateAgentSchema(customForValidation);\n271\t        if (!result.valid) {\n272\t          const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n273\t          throw new AgentResolveError(\n274\t            `Schema validation failed for custom agent ${name}: ${details}`,\n275\t            customPath,\n276\t            result.errors.map((e) => ({ path: e.path, message: e.message })),\n277\t          );\n278\t        }\n279\t        return (customPP ? { ...customForValidation, prompt_patches: customPP } : customForValidation) as unknown as ResolvedAgent;\n280\t      }\n281\t    }\n282\t  }\n283\t\n284\t  // Load embedded base\n285\t  const base = loadEmbeddedAgent(name);\n286\t  let merged: Record<string, unknown> = base as unknown as Record<string, unknown>;\n287\t\n288\t  // Apply user patch\n289\t  const userPatch = loadPatch(userPatchPath);\n290\t  if (userPatch) {\n291\t    merged = mergePatch(merged, userPatch);\n292\t  }\n293\t\n294\t  // Apply project patch\n295\t  const projectPatch = loadPatch(projectPatchPath);\n296\t  if (projectPatch) {\n297\t    merged = mergePatch(merged, projectPatch);\n298\t  }\n299\t\n300\t  // Validate merged result (strip prompt_patches for schema validation since it's not in schema)\n301\t  const { prompt_patches, ...forValidation } = merged as Record<string, unknown> & { prompt_patches?: unknown };\n302\t  const result = validateAgentSchema(forValidation);\n303\t  if (!result.valid) {\n304\t    const details = result.errors.map((e) => `${e.path}: ${e.message}`).join('; ');\n305\t    const errorPath = projectPatch ? projectPatchPath : userPatch ? userPatchPath : 'merged';\n306\t    throw new AgentResolveError(\n307\t      `Schema validation failed after merging patches for ${name}: ${details}`,\n308\t      errorPath,\n309\t      result.errors.map((e) => ({ path: e.path, message: e.message })),\n310\t    );\n311\t  }\n312\t\n313\t  // Re-attach prompt_patches if present, return without mutating forValidation\n314\t  return (prompt_patches\n315\t    ? { ...forValidation, prompt_patches }\n316\t    : forValidation) as unknown as ResolvedAgent;\n317\t}\n318\t\n319\t// --- Subagent Compilation ---\n320\t\n321\t/**\n322\t * Compile a ResolvedAgent into a SubagentDefinition for Agent SDK dispatch.\n323\t */\n324\texport function compileSubagentDefinition(agent: ResolvedAgent): SubagentDefinition {\n325\t  const parts: string[] = [];\n326\t\n327\t  parts.push(`You are ${agent.persona.identity}`);\n328\t  parts.push(`Communication style: ${agent.persona.communication_style}`);\n329\t\n330\t  if (agent.persona.principles.length > 0) {\n331\t    const bullets = agent.persona.principles.map((p) => `- ${p}`).join('\\n');\n332\t    parts.push(`Principles:\\n${bullets}`);\n333\t  }\n334\t\n335\t  if (agent.prompt_patches?.append) {\n336\t    parts.push(agent.prompt_patches.append);\n337\t  }\n338\t\n339\t  return {\n340\t    name: agent.name,\n341\t    model: DEFAULT_MODEL,\n342\t    instructions: parts.join('\\n\\n'),\n343\t    disallowedTools: agent.disallowedTools ?? [],\n344\t    bare: true,\n345\t  };\n346\t}\n347\t"}]},"parent_tool_use_id":"toolu_01DmodJessUS9Zyp4CtHWrwe","session_id":"84c2a87f-6818-4ede-b88c-dde16fd6e99b","uuid":"87b5de1f-23d1-4b1f-aad6-c94bda0ff4f0","timestamp":"2026-04-02T19:49:05.687Z"}
