{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014p1qZfxHPZtVp2uYfLjaBr","type":"tool_result","content":"1\t/**\n2\t * Null Task Handler Registry.\n3\t *\n4\t * Provides a registry pattern for tasks with `agent: null` that execute\n5\t * directly in the engine without LLM dispatch. Handlers are registered at\n6\t * module initialization time. The engine calls `getNullTask(name)` to look\n7\t * up a handler and execute it inline.\n8\t *\n9\t * @see Story 16-2: Engine-Handled Null Tasks\n10\t */\n11\t\n12\timport type { OutputContract } from './agents/types.js';\n13\timport { writeTelemetryEntry } from './telemetry-writer.js';\n14\t\n15\t// --- Interfaces ---\n16\t\n17\t/**\n18\t * Context passed to a null task handler.\n19\t */\n20\texport interface TaskContext {\n21\t  /** Story key (e.g., \"16-2-engine-handled-null-tasks\") or \"__run__\" for per-run. */\n22\t  storyKey: string;\n23\t  /** Task name (e.g., \"telemetry\"). */\n24\t  taskName: string;\n25\t  /** Accumulated cost from previous tasks (USD). */\n26\t  cost: number;\n27\t  /** Elapsed time since workflow start (ms). */\n28\t  durationMs: number;\n29\t  /** Previous task's output contract, or null if first task. */\n30\t  outputContract: OutputContract | null;\n31\t  /** Project root directory. */\n32\t  projectDir: string;\n33\t}\n34\t\n35\t/**\n36\t * Result returned by a null task handler.\n37\t */\n38\texport interface NullTaskResult {\n39\t  /** Whether the handler completed successfully. */\n40\t  success: boolean;\n41\t  /** Optional text output for logging. */\n42\t  output?: string;\n43\t}\n44\t\n45\t/**\n46\t * A null task handler function.\n47\t */\n48\texport type NullTaskHandler = (ctx: TaskContext) => Promise<NullTaskResult>;\n49\t\n50\t// --- Registry ---\n51\t\n52\tconst registry = new Map<string, NullTaskHandler>();\n53\t\n54\t/**\n55\t * Register a null task handler.\n56\t *\n57\t * @param name  The task name to register (must match the task key in workflow YAML).\n58\t * @param handler  The handler function to execute when this task is reached.\n59\t */\n60\texport function registerNullTask(name: string, handler: NullTaskHandler): void {\n61\t  registry.set(name, handler);\n62\t}\n63\t\n64\t/**\n65\t * Look up a registered null task handler.\n66\t *\n67\t * @param name  The task name to look up.\n68\t * @returns The handler function, or `undefined` if no handler is registered.\n69\t */\n70\texport function getNullTask(name: string): NullTaskHandler | undefined {\n71\t  return registry.get(name);\n72\t}\n73\t\n74\t/**\n75\t * List all registered null task handler names.\n76\t * Used for error messages when an unknown null task is encountered.\n77\t */\n78\texport function listNullTasks(): string[] {\n79\t  return [...registry.keys()];\n80\t}\n81\t\n82\t/**\n83\t * Clear all registered handlers. Intended for test cleanup only.\n84\t * Does NOT re-register built-in handlers — callers must re-register\n85\t * any handlers they need after clearing.\n86\t */\n87\texport function clearNullTaskRegistry(): void {\n88\t  registry.clear();\n89\t}\n90\t\n91\t// --- Built-in Handlers ---\n92\t\n93\t/**\n94\t * Telemetry handler — writes structured NDJSON after each story completes.\n95\t * @see Story 16-3: Telemetry Writer\n96\t */\n97\tregisterNullTask('telemetry', writeTelemetryEntry);\n98\t"}]},"parent_tool_use_id":"toolu_01M4NenhzW72RWGSvvu339mv","session_id":"187035da-d60e-40cf-8aef-09e6134be246","uuid":"9a084082-1e90-4a61-bdc8-3ddcf2d1cd7b","timestamp":"2026-04-03T19:32:33.288Z"}
