{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LRdFRyFRLBPZLmREDs6Py4","type":"tool_result","content":"     1→/**\n     2→ * Node.js stack provider — encapsulates all Node.js-specific behavior.\n     3→ * Implements every StackProvider method for the nodejs stack.\n     4→ *\n     5→ * Story 10-2: full implementation replacing stubs from story 10-1.\n     6→ */\n     7→\n     8→import { execFileSync } from 'node:child_process';\n     9→import { existsSync, readFileSync, writeFileSync } from 'node:fs';\n    10→import { join } from 'node:path';\n    11→\n    12→import { renderTemplateFile } from '../templates.js';\n    13→import type {\n    14→  AppType,\n    15→  CoverageToolInfo,\n    16→  CoverageToolName,\n    17→  OtlpResult,\n    18→  StackProvider,\n    19→  TestCounts,\n    20→} from './types.js';\n    21→import { readJsonSafe, getNodeDeps } from './utils.js';\n    22→\n    23→/** Dependency names that signal an AI/agent project. */\n    24→const AGENT_DEPS = [\n    25→  'anthropic',\n    26→  '@anthropic-ai/sdk',\n    27→  'openai',\n    28→  'langchain',\n    29→  '@langchain/core',\n    30→  'llamaindex',\n    31→];\n    32→\n    33→/** Dependency names that signal a web frontend project. */\n    34→const WEB_FRAMEWORK_DEPS = [\n    35→  'react',\n    36→  'vue',\n    37→  'svelte',\n    38→  'angular',\n    39→  '@angular/core',\n    40→  'next',\n    41→  'nuxt',\n    42→  'vite',\n    43→  'webpack',\n    44→];\n    45→\n    46→/** OTLP packages required for Node.js instrumentation. */\n    47→const NODE_OTLP_PACKAGES = [\n    48→  '@opentelemetry/auto-instrumentations-node',\n    49→  '@opentelemetry/sdk-node',\n    50→  '@opentelemetry/exporter-trace-otlp-http',\n    51→  '@opentelemetry/exporter-metrics-otlp-http',\n    52→];\n    53→\n    54→const NODE_REQUIRE_FLAG = '--require @opentelemetry/auto-instrumentations-node/register';\n    55→\n    56→export class NodejsProvider implements StackProvider {\n    57→  readonly name = 'nodejs' as const;\n    58→  readonly markers = ['package.json'];\n    59→  readonly displayName = 'Node.js (package.json)';\n    60→\n    61→  // ── Task 1: detectAppType ──────────────────────────────────────────────\n    62→\n    63→  detectAppType(dir: string): AppType {\n    64→    const pkg = readJsonSafe(join(dir, 'package.json'));\n    65→    if (!pkg) return 'generic';\n    66→\n    67→    const deps = getNodeDeps(pkg);\n    68→\n    69→    // Priority 1: Agent detection\n    70→    if (AGENT_DEPS.some((d) => deps.has(d))) {\n    71→      return 'agent';\n    72→    }\n    73→\n    74→    // Priority 2: Web detection\n    75→    if (WEB_FRAMEWORK_DEPS.some((d) => deps.has(d))) {\n    76→      return 'web';\n    77→    }\n    78→    if (\n    79→      existsSync(join(dir, 'index.html')) ||\n    80→      existsSync(join(dir, 'public', 'index.html')) ||\n    81→      existsSync(join(dir, 'src', 'index.html'))\n    82→    ) {\n    83→      return 'web';\n    84→    }\n    85→\n    86→    // Priority 3: CLI detection\n    87→    const bin = pkg['bin'];\n    88→    const scripts = pkg['scripts'] as Record<string, string> | undefined;\n    89→    const hasStart = scripts?.['start'] !== undefined;\n    90→    if (bin && !hasStart) {\n    91→      return 'cli';\n    92→    }\n    93→\n    94→    // Priority 4: Server detection\n    95→    if (hasStart) {\n    96→      return 'server';\n    97→    }\n    98→\n    99→    return 'generic';\n   100→  }\n   101→\n   102→  // ── Task 2: getCoverageTool ────────────────────────────────────────────\n   103→\n   104→  getCoverageTool(): CoverageToolName {\n   105→    return 'c8';\n   106→  }\n   107→\n   108→  // ── Task 3: detectCoverageConfig ───────────────────────────────────────\n   109→\n   110→  detectCoverageConfig(dir: string): CoverageToolInfo {\n   111→    // Check for Vitest config files\n   112→    const vitestConfigTs = join(dir, 'vitest.config.ts');\n   113→    const vitestConfigJs = join(dir, 'vitest.config.js');\n   114→    const hasVitestConfig = existsSync(vitestConfigTs) || existsSync(vitestConfigJs);\n   115→\n   116→    // Check package.json devDependencies\n   117→    const pkg = readJsonSafe(join(dir, 'package.json'));\n   118→    let hasVitestCoverageV8 = false;\n   119→    let hasVitestCoverageIstanbul = false;\n   120→    let hasC8 = false;\n   121→    let hasJest = false;\n   122→\n   123→    if (pkg) {\n   124→      const allDeps = getNodeDeps(pkg);\n   125→      hasVitestCoverageV8 = allDeps.has('@vitest/coverage-v8');\n   126→      hasVitestCoverageIstanbul = allDeps.has('@vitest/coverage-istanbul');\n   127→      hasC8 = allDeps.has('c8');\n   128→      hasJest = allDeps.has('jest');\n   129→    }\n   130→\n   131→    // Vitest detection\n   132→    if (hasVitestConfig || hasVitestCoverageV8 || hasVitestCoverageIstanbul) {\n   133→      const configFile = existsSync(vitestConfigTs)\n   134→        ? vitestConfigTs\n   135→        : existsSync(vitestConfigJs)\n   136→          ? vitestConfigJs\n   137→          : undefined;\n   138→      return { tool: 'c8', configFile };\n   139→    }\n   140→\n   141→    // Standalone c8\n   142→    if (hasC8) {\n   143→      return { tool: 'c8' };\n   144→    }\n   145→\n   146→    // Jest (uses c8/istanbul underneath)\n   147→    if (hasJest) {\n   148→      return { tool: 'c8' };\n   149→    }\n   150→\n   151→    return { tool: 'none' };\n   152→  }\n   153→\n   154→  // ── Task 4: getOtlpPackages ────────────────────────────────────────────\n   155→\n   156→  getOtlpPackages(): string[] {\n   157→    return [...NODE_OTLP_PACKAGES];\n   158→  }\n   159→\n   160→  // ── Task 5: installOtlp ───────────────────────────────────────────────\n   161→\n   162→  installOtlp(dir: string): OtlpResult {\n   163→    try {\n   164→      execFileSync('npm', ['install', ...NODE_OTLP_PACKAGES], {\n   165→        cwd: dir,\n   166→        stdio: 'pipe',\n   167→        timeout: 300_000,\n   168→      });\n   169→      return {\n   170→        success: true,\n   171→        packagesInstalled: [...NODE_OTLP_PACKAGES],\n   172→      };\n   173→    } catch (err) {\n   174→      const message = err instanceof Error ? err.message : 'Unknown error';\n   175→      return {\n   176→        success: false,\n   177→        packagesInstalled: [],\n   178→        error: `Failed to install Node.js OTLP packages: ${message.length > 200 ? message.slice(0, 200) + '... (truncated)' : message}`,\n   179→      };\n   180→    }\n   181→  }\n   182→\n   183→  // ── Task 6: patchStartScript ──────────────────────────────────────────\n   184→\n   185→  patchStartScript(dir: string): boolean {\n   186→    const pkgPath = join(dir, 'package.json');\n   187→    if (!existsSync(pkgPath)) return false;\n   188→\n   189→    let raw: string;\n   190→    let pkg: Record<string, unknown>;\n   191→    try {\n   192→      raw = readFileSync(pkgPath, 'utf-8');\n   193→      pkg = JSON.parse(raw) as Record<string, unknown>;\n   194→    } catch {\n   195→      // IGNORE: package.json may not exist or be malformed\n   196→      return false;\n   197→    }\n   198→\n   199→    const scripts = pkg['scripts'] as Record<string, string> | undefined;\n   200→    if (!scripts) return false;\n   201→\n   202→    const targetKey = scripts['start'] ? 'start' : scripts['dev'] ? 'dev' : null;\n   203→    if (!targetKey) return false;\n   204→\n   205→    const instrumentedKey = `${targetKey}:instrumented`;\n   206→\n   207→    // Already patched\n   208→    if (scripts[instrumentedKey]?.includes(NODE_REQUIRE_FLAG)) {\n   209→      return false;\n   210→    }\n   211→\n   212→    scripts[instrumentedKey] = `NODE_OPTIONS='${NODE_REQUIRE_FLAG}' ${scripts[targetKey]}`;\n   213→\n   214→    writeFileSync(pkgPath, JSON.stringify(pkg, null, 2) + '\\n', 'utf-8');\n   215→    return true;\n   216→  }\n   217→\n   218→  // ── Task 7: getDockerfileTemplate ─────────────────────────────────────\n   219→\n   220→  getDockerfileTemplate(): string {\n   221→    return renderTemplateFile('templates/dockerfiles/Dockerfile.nodejs');\n   222→  }\n   223→\n   224→  // ── Task 8: getDockerBuildStage ───────────────────────────────────────\n   225→\n   226→  getDockerBuildStage(): string {\n   227→    return `# === Build stage: nodejs ===\n   228→FROM node:22-slim AS build-nodejs\n   229→WORKDIR /build\n   230→COPY package*.json ./\n   231→RUN npm ci --production\n   232→COPY . .\n   233→`;\n   234→  }\n   235→\n   236→  // ── Task 9: getRuntimeCopyDirectives ──────────────────────────────────\n   237→\n   238→  getRuntimeCopyDirectives(): string {\n   239→    return [\n   240→      'COPY --from=build-nodejs /build/node_modules ./node_modules',\n   241→      'COPY --from=build-nodejs /build/ ./app/',\n   242→    ].join('\\n');\n   243→  }\n   244→\n   245→  // ── Task 10: getBuildCommands ──────────────────────────────────────────\n   246→\n   247→  getBuildCommands(): string[] {\n   248→    return ['npm install', 'npm run build'];\n   249→  }\n   250→\n   251→  // ── Task 11: getTestCommands ──────────────────────────────────────────\n   252→\n   253→  getTestCommands(): string[] {\n   254→    return ['npm test'];\n   255→  }\n   256→\n   257→  // ── Task 12: getSemgrepLanguages ──────────────────────────────────────\n   258→\n   259→  getSemgrepLanguages(): string[] {\n   260→    return ['javascript', 'typescript'];\n   261→  }\n   262→\n   263→  // ── Task 13: parseTestOutput ──────────────────────────────────────────\n   264→\n   265→  parseTestOutput(output: string): TestCounts {\n   266→    // Vitest format: \"Tests  12 passed | 3 failed | 1 skipped\"\n   267→    // Each segment (passed/failed/skipped) is optional except passed which triggers the match.\n   268→    const vitestMatch = /Tests\\s+(\\d+)\\s+passed(?:\\s*\\|\\s*(\\d+)\\s+failed)?(?:\\s*\\|\\s*(\\d+)\\s+skipped)?/i.exec(output);\n   269→    if (vitestMatch) {\n   270→      const passed = parseInt(vitestMatch[1], 10);\n   271→      const failed = vitestMatch[2] ? parseInt(vitestMatch[2], 10) : 0;\n   272→      const skipped = vitestMatch[3] ? parseInt(vitestMatch[3], 10) : 0;\n   273→      return { passed, failed, skipped, total: passed + failed + skipped };\n   274→    }\n   275→\n   276→    // Jest format: \"Tests:  3 failed, 12 passed, 2 skipped, 17 total\"\n   277→    // Extract each field independently since ordering can vary.\n   278→    const jestPassedMatch = /Tests:.*?(\\d+)\\s+passed/i.exec(output);\n   279→    if (jestPassedMatch) {\n   280→      const passed = parseInt(jestPassedMatch[1], 10);\n   281→      const failedMatch = /Tests:.*?(\\d+)\\s+failed/i.exec(output);\n   282→      const skippedMatch = /Tests:.*?(\\d+)\\s+skipped/i.exec(output);\n   283→      const totalMatch = /Tests:.*?(\\d+)\\s+total/i.exec(output);\n   284→      const failed = failedMatch ? parseInt(failedMatch[1], 10) : 0;\n   285→      const skipped = skippedMatch ? parseInt(skippedMatch[1], 10) : 0;\n   286→      const total = totalMatch ? parseInt(totalMatch[1], 10) : passed + failed + skipped;\n   287→      return { passed, failed, skipped, total };\n   288→    }\n   289→\n   290→    return { passed: 0, failed: 0, skipped: 0, total: 0 };\n   291→  }\n   292→\n   293→  // ── Task 14: parseCoverageReport ──────────────────────────────────────\n   294→\n   295→  parseCoverageReport(dir: string): number {\n   296→    const candidates = [\n   297→      join(dir, 'coverage', 'coverage-summary.json'),\n   298→      join(dir, 'src', 'coverage', 'coverage-summary.json'),\n   299→    ];\n   300→\n   301→    let reportPath: string | null = null;\n   302→    for (const p of candidates) {\n   303→      if (existsSync(p)) {\n   304→        reportPath = p;\n   305→        break;\n   306→      }\n   307→    }\n   308→\n   309→    if (!reportPath) return 0;\n   310→\n   311→    try {\n   312→      const report = JSON.parse(readFileSync(reportPath, 'utf-8')) as {\n   313→        total?: {\n   314→          statements?: { pct?: number };\n   315→        };\n   316→      };\n   317→      return report.total?.statements?.pct ?? 0;\n   318→    } catch {\n   319→      // IGNORE: coverage report may be malformed\n   320→      return 0;\n   321→    }\n   322→  }\n   323→\n   324→  // ── Task 15: getProjectName ───────────────────────────────────────────\n   325→\n   326→  // ── getVerifyDockerfileSection ──────────────────────────────────────\n   327→\n   328→  getVerifyDockerfileSection(_projectDir: string): string {\n   329→    return [\n   330→      '# --- Node.js tooling ---',\n   331→      'RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \\\\',\n   332→      '    && apt-get install -y --no-install-recommends nodejs \\\\',\n   333→      '    && rm -rf /var/lib/apt/lists/*',\n   334→      'RUN npm install -g showboat @anthropic-ai/claude-code',\n   335→    ].join('\\n');\n   336→  }\n   337→\n   338→  getProjectName(dir: string): string | null {\n   339→    const pkg = readJsonSafe(join(dir, 'package.json'));\n   340→    if (pkg && typeof pkg.name === 'string') {\n   341→      return pkg.name;\n   342→    }\n   343→    return null;\n   344→  }\n   345→}\n   346→"}]},"parent_tool_use_id":"toolu_01L5LiJHunZnUnw7ysWAKpUU","session_id":"7c5953f4-1d55-4aa9-825f-60bc73601e00","uuid":"88eb5879-9a29-40cf-8c53-a6d134cc95da","timestamp":"2026-03-25T02:03:49.613Z"}
