ctStack, detectStacks } from '../../../lib/stacks/index.js';\n    47→import { readStateWithBody, writeState } from '../../../lib/state.js';\n    48→import {\n    49→  isValidStoryKey,\n    50→  computeDistHash,\n    51→  buildVerifyImage,\n    52→  detectProjectType,\n    53→  prepareVerifyWorkspace,\n    54→  checkVerifyEnv,\n    55→  cleanupVerifyEnv,\n    56→  cleanupStaleContainers,\n    57→} from '../env.js';\n    58→\n    59→const mockExecFileSync = vi.mocked(execFileSync);\n    60→const mockIsDockerAvailable = vi.mocked(isDockerAvailable);\n    61→const mockDetectStack = vi.mocked(detectStack);\n    62→const mockDetectStacks = vi.mocked(detectStacks);\n    63→const mockReadStateWithBody = vi.mocked(readStateWithBody);\n    64→const mockWriteState = vi.mocked(writeState);\n    65→\n    66→let testDir: string;\n    67→\n    68→beforeEach(() => {\n    69→  vi.clearAllMocks();\n    70→  testDir = mkdtempSync(join(tmpdir(), 'ch-verify-env-test-'));\n    71→  // Create templates/Dockerfile.verify so buildVerifyImage can find it\n    72→  mkdirSync(join(testDir, 'templates'), { recursive: true });\n    73→  writeFileSync(join(testDir, 'templates', 'Dockerfile.verify'), 'FROM node:20-slim\\nARG TARBALL=package.tgz\\nCOPY ${TARBALL} /tmp/\\n');\n    74→  writeFileSync(join(testDir, 'templates', 'Dockerfile.verify.generic'), 'FROM node:20-slim\\nRUN apt-get update\\n');\n    75→  // Reset default mock behaviors after clearAllMocks\n    76→  mockIsDockerAvailable.mockReturnValue(true);\n    77→  mockDetectStack.mockReturnValue('nodejs');\n    78→  mockDetectStacks.mockReturnValue([{ stack: 'nodejs', dir: '.' }]);\n    79→});\n    80→\n    81→afterEach(() => {\n    82→  rmSync(testDir, { recursive: true, force: true });\n    83→});\n    84→\n    85→// ─── isValidStoryKey ────────────────────────────────────────────────────────\n    86→\n    87→describe('isValidStoryKey', () => {\n    88→  it('accepts valid story keys', () => {\n    89→    expect(isValidStoryKey('13-1-ver