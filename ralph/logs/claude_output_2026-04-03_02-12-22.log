48\t    expect(getFailedItems(verdict, items)).toEqual([]);\n1249\t  });\n1250\t\n1251\t  it('returns all items when verdict is fail (conservative)', () => {\n1252\t    const verdict: EvaluatorVerdict = {\n1253\t      verdict: 'fail',\n1254\t      score: { passed: 1, failed: 1, unknown: 0, total: 2 },\n1255\t      findings: [],\n1256\t    };\n1257\t    expect(getFailedItems(verdict, items)).toEqual(items);\n1258\t  });\n1259\t});\n1260\t\n1261\tdescribe('loop block execution', () => {\n1262\t  beforeEach(() => {\n1263\t    vi.clearAllMocks();\n1264\t    setupDefaultMocks();\n1265\t  });\n1266\t\n1267\t  function makePassVerdict(): string {\n1268\t    return JSON.stringify({\n1269\t      verdict: 'pass',\n1270\t      score: { passed: 2, failed: 0, unknown: 0, total: 2 },\n1271\t      findings: [],\n1272\t    });\n1273\t  }\n1274\t\n1275\t  function makeFailVerdict(): string {\n1276\t    return JSON.stringify({\n1277\t      verdict: 'fail',\n1278\t      score: { passed: 1, failed: 1, unknown: 0, total: 2 },\n1279\t      findings: [\n1280\t        {\n1281\t          ac: 1,\n1282\t          description: 'Tests pass',\n1283\t          status: 'fail',\n1284\t          evidence: { commands_run: ['npm test'], output_observed: 'FAIL', reasoning: 'Test suite failed' },\n1285\t        },\n1286\t        {\n1287\t          ac: 2,\n1288\t          description: 'Build succeeds',\n1289\t          status: 'pass',\n1290\t          evidence: { commands_run: ['npm run build'], output_observed: 'OK', reasoning: 'Build fine' },\n1291\t        },\n1292\t      ],\n1293\t    });\n1294\t  }\n1295\t\n1296\t  it('terminates loop when verdict is pass (AC #2)', async () => {\n1297\t    mockDispatchAgent.mockImplementation(\n1298\t      async (_def: SubagentDefinition, prompt: string) => {\n1299\t        if (prompt.includes('Execute task')) {\n1300\t          return { sessionId: 'sess-v', success: true, durationMs: 100, output: makePassVerdict() };\n1301\t        }\n1302\t        return { sessionId: 'sess-r', success: true, durationMs: 100, output: 'ok' };\n1303\t      },\n1304\t    );\n1305\t\n1306\t    mockParse.mockReturnValue({\n1307\t      development_status: { '3-1-foo': 'ready-for-dev' },\n1308\t    });\n1309\t\n1310\t    const config = makeConfig({\n1311\t      workflow: {\n1312\t        tasks: {\n1313\t          retry: makeTask({ scope: 'per-story' }),\n1314\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n1315\t        },\n1316\t        flow: [{ loop: ['retry', 'verify'] }],\n1317\t      },\n1318\t    });\n1319\t\n1320\t    const result = await executeWorkflow(config);\n1321\t\n1322\t    expect(result.success).toBe(true);\n1323\t    expect(result.tasksCompleted).toBe(2); // 1 retry + 1 verify\n1324\t  });\n1325\t\n1326\t  it('terminates loop when maxIterations reached (AC #3)', async () => {\n1327\t    // Verify always fails\n1328\t    mockDispatchAgent.mockImplementation(\n1329\t      async (_def: SubagentDefinition, prompt: string) => {\n1330\t        if (prompt.includes('Execute task')) {\n1331\t          return { sessionId: 'sess-v', success: true, durationMs: 100, output: makeFailVerdict() };\n1332\t        }\n1333\t        return { sessionId: 'sess-r', success: true, durationMs: 100, output: 'ok' };\n1334\t      },\n1335\t    );\n1336\t\n1337\t    mockParse.mockReturnValue({\n1338\t      development_status: { '3-1-foo': 'ready-for-dev' },\n1339\t    });\n1340\t\n1341\t    const config = makeConfig({\n1342\t      workflow: {\n1343\t        tasks: {\n1344\t          retry: makeTask({ scope: 'per-story' }),\n1345\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n1346\t        },\n1347\t        flow: [{ loop: ['retry', 'verify'] }],\n1348\t      },\n1349\t      maxIterations: 3,\n1350\t    });\n1351\t\n1352\t    const result = await executeWorkflow(config);\n1353\t\n1354\t    expect(result.success).toBe(false);\n1355\t    // 3 iterations × 2 tasks per iteration = 6\n1356\t    expect(mockDispatchAgent).toHaveBeenCalledTimes(6);\n1357\t\n1358\t    // State should have phase=max-iterations\n1359\t    const lastWriteCall = mockWriteWorkflowState.mock.calls[mockWriteWorkflowState.mock.calls.length - 1];\n1360\t    const finalState = lastWriteCall[0] as WorkflowState;\n1361\t    expect(finalState.phase).toBe('max-iterations');\n1362\t  });\n1363\t\n1364\t  it('terminates loop when circuit_breaker.triggered is true (AC #4)', async () => {\n1365\t    let dispatchCount = 0;\n1366\t    mockDispatchAgent.mockImplementation(\n1367\t      async (_def: SubagentDefinition, prompt: string) => {\n1368\t        dispatchCount++;\n1369\t        if (prompt.includes('Execute task')) {\n1370\t          return { sessionId: 'sess-v', success: true, durationMs: 100, output: makeFailVerdict() };\n1371\t        }\n1372\t        return { sessionId: 'sess-r', success: true, durationMs: 100, output: 'ok' };\n1373\t      },\n1374\t    );\n1375\t\n1376\t    // After first iteration, trigger circuit breaker\n1377\t    mockWriteWorkflowState.mockImplementation((state: WorkflowState) => {\n1378\t      // After 2 dispatches (retry + verify), trigger the circuit breaker\n1379\t      if (dispatchCount >= 2) {\n1380\t        state.circuit_breaker = { triggered: true, reason: 'score plateau', score_history: [50, 50] };\n1381\t      }\n1382\t    });\n1383\t\n1384\t    mockParse.mockReturnValue({\n1385\t      development_status: { '3-1-foo': 'ready-for-dev' },\n1386\t    });\n1387\t\n1388\t    const config = makeConfig({\n1389\t      workflow: {\n1390\t        tasks: {\n1391\t          retry: makeTask({ scope: 'per-story' }),\n1392\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n1393\t        },\n1394\t        flow: [{ loop: ['retry', 'verify'] }],\n1395\t      },\n1396\t    });\n1397\t\n1398\t    const result = await executeWorkflow(config);\n1399\t\n1400\t    expect(result.success).toBe(false);\n1401\t  });\n1402\t\n1403\t  it('injects findings into retry prompt for failed