teWithOtlp('nodejs');\n   395→    mockExecFileSync.mockReturnValue(Buffer.from(''));\n   396→\n   397→    configureWeb(testDir, 'nodejs');\n   398→\n   399→    expect(existsSync(join(testDir, 'otel-web-init.js'))).toBe(true);"}]},"parent_tool_use_id":"toolu_01DTMuMyoP8q2RZCktE73dhu","session_id":"ccb5b6c6-90ec-46ee-9865-cad53e4d258b","uuid":"69fe6176-e017-4475-aa1f-fc73e8fde2f9","timestamp":"2026-03-23T07:55:42.473Z"}
