{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HmKavUmR1Qr4ckcBCwPhbh","type":"tool_result","content":"     1→import { Command } from 'commander';\n     2→import { join } from 'node:path';\n     3→import { ok, fail, info, warn, jsonOutput } from '../lib/output.js';\n     4→import {\n     5→  scanCodebase,\n     6→  analyzeCoverageGaps,\n     7→  auditDocumentation,\n     8→} from '../lib/scanner.js';\n     9→import type {\n    10→  ScanResult,\n    11→  CoverageGapReport,\n    12→  DocAuditResult,\n    13→} from '../lib/scanner.js';\n    14→import {\n    15→  generateOnboardingEpic,\n    16→  writeOnboardingEpic,\n    17→  formatEpicSummary,\n    18→  promptApproval,\n    19→  importOnboardingEpic,\n    20→} from '../lib/epic-generator.js';\n    21→import type { OnboardingEpic } from '../lib/epic-generator.js';\n    22→import { listIssues, createIssue } from '../lib/beads.js';\n    23→import {\n    24→  runPreconditions,\n    25→  filterTrackedGaps,\n    26→  findVerificationGaps,\n    27→  findPerFileCoverageGaps,\n    28→  findObservabilityGaps,\n    29→  getOnboardingProgress,\n    30→} from '../lib/onboard-checks.js';\n    31→import { saveScanCache, loadValidCache } from '../lib/scan-cache.js';\n    32→import { appendOnboardingEpicToSprint } from '../lib/beads-sync.js';\n    33→\n    34→// ─── Shared state for passing results between phases ─────────────────────────\n    35→\n    36→let lastScanResult: ScanResult | null = null;\n    37→let lastCoverageResult: CoverageGapReport | null = null;\n    38→let lastAuditResult: DocAuditResult | null = null;\n    39→\n    40→export function getLastScanResult(): ScanResult | null {\n    41→  return lastScanResult;\n    42→}\n    43→\n    44→export function getLastCoverageResult(): CoverageGapReport | null {\n    45→  return lastCoverageResult;\n    46→}\n    47→\n    48→export function getLastAuditResult(): DocAuditResult | null {\n    49→  return lastAuditResult;\n    50→}\n    51→\n    52→export function resetLastScanResult(): void {\n    53→  lastScanResult = null;\n    54→  lastCoverageResult = null;\n    55→  lastAuditResult = null;\n    56→}\n    57→\n    58→// ─── Command Registration ────────────────────────────────────────────────────\n    59→\n    60→export function registerOnboardCommand(program: Command): void {\n    61→  const onboard = program\n    62→    .command('onboard')\n    63→    .description('Onboard an existing codebase into the harness')\n    64→    .option('--min-module-size <n>', 'Minimum files to count as a module', '3')\n    65→    .option('--full', 'Show all gaps regardless of existing beads issues')\n    66→    .option('--force-scan', 'Ignore cached scan and perform a fresh scan');\n    67→\n    68→  // Subcommand: scan\n    69→  onboard\n    70→    .command('scan')\n    71→    .description('Scan codebase for modules and artifacts')\n    72→    .action((_, cmd) => {\n    73→      const opts = cmd.optsWithGlobals();\n    74→      const isJson = opts.json === true;\n    75→      const minModuleSize = parseInt(opts.minModuleSize ?? '3', 10);\n    76→\n    77→      const preconditions = runPreconditions();\n    78→      if (!preconditions.canProceed) {\n    79→        if (isJson) {\n    80→          jsonOutput({ status: 'fail', message: 'Harness not initialized \\u2014 run codeharness init first' });\n    81→        } else {\n    82→          fail('Harness not initialized \\u2014 run codeharness init first');\n    83→        }\n    84→        process.exitCode = 1;\n    85→        return;\n    86→      }\n    87→      if (!isJson) {\n    88→        for (const w of preconditions.warnings) {\n    89→          warn(w);\n    90→        }\n    91→      }\n    92→\n    93→      const result = runScan(minModuleSize);\n    94→\n    95→      // Save scan to cache (coverage and audit not yet run)\n    96→      saveScanCache({\n    97→        timestamp: new Date().toISOString(),\n    98→        scan: result,\n    99→        coverage: null,\n   100→        audit: null,\n   101→      });\n   102→\n   103→      if (isJson) {\n   104→        jsonOutput({ preconditions: { initialized: preconditions.initialized, bmad: preconditions.bmad, hooks: preconditions.hooks }, scan: result });\n   105→      } else {\n   106→        printScanOutput(result);\n   107→      }\n   108→    });\n   109→\n   110→  // Subcommand: coverage\n   111→  onboard\n   112→    .command('coverage')\n   113→    .description('Analyze per-module coverage gaps')\n   114→    .action((_, cmd) => {\n   115→      const opts = cmd.optsWithGlobals();\n   116→      const isJson = opts.json === true;\n   117→      const forceScan = opts.forceScan === true;\n   118→      const minModuleSize = parseInt(opts.minModuleSize ?? '3', 10);\n   119→\n   120→      const preconditions = runPreconditions();\n   121→      if (!preconditions.canProceed) {\n   122→        if (isJson) {\n   123→          jsonOutput({ status: 'fail', message: 'Harness not initialized \\u2014 run codeharness init first' });\n   124→        } else {\n   125→          fail('Harness not initialized \\u2014 run codeharness init first');\n   126→        }\n   127→        process.exitCode = 1;\n   128→        return;\n   129→      }\n   130→      for (const w of preconditions.warnings) {\n   131→        warn(w);\n   132→      }\n   133→\n   134→      // Try cached scan first\n   135→      let scan: ScanResult;\n   136→      if (lastScanResult) {\n   137→        scan = lastScanResult;\n   138→      } else {\n   139→        const cache = loadValidCache(process.cwd(), { forceScan });\n   140→        if (cache) {\n   141→          info(`Using cached scan from ${new Date(cache.timestamp).toLocaleString()}`);\n   142→          scan = cache.scan;\n   143→          lastScanResult = scan;\n   144→        } else {\n   145→          scan = runScan(minModuleSize);\n   146→        }\n   147→      }\n   148→      const result = runCoverageAnalysis(scan);\n   149→\n   150→      if (isJson) {\n   151→        jsonOutput({ preconditions: { initialized: preconditions.initialized, bmad: preconditions.bmad, hooks: preconditions.hooks }, coverage: result });\n   152→      } else {\n   153→        printCoverageOutput(result);\n   154→      }\n   155→    });\n   156→\n   157→  // Subcommand: audit\n   158→  onboard\n   159→    .command('audit')\n   160→    .description('Audit project documentation')\n   161→    .action((_, cmd) => {\n   162→      const opts = cmd.optsWithGlobals();\n   163→      const isJson = opts.json === true;\n   164→\n   165→      const preconditions = runPreconditions();\n   166→      if (!preconditions.canProceed) {\n   167→        if (isJson) {\n   168→          jsonOutput({ status: 'fail', message: 'Harness not initialized \\u2014 run codeharness init first' });\n   169→        } else {\n   170→          fail('Harness not initialized \\u2014 run codeharness init first');\n   171→        }\n   172→        process.exitCode = 1;\n   173→        return;\n   174→      }\n   175→      for (const w of preconditions.warnings) {\n   176→        warn(w);\n   177→      }\n   178→\n   179→      const result = runAudit();\n   180→\n   181→      if (isJson) {\n   182→        jsonOutput({ preconditions: { initialized: preconditions.initialized, bmad: preconditions.bmad, hooks: preconditions.hooks }, audit: result });\n   183→      } else {\n   184→        printAuditOutput(result);\n   185→      }\n   186→    });\n   187→\n   188→  // Subcommand: epic\n   189→  onboard\n   190→    .command('epic')\n   191→    .description('Generate onboarding epic from scan findings')\n   192→    .option('--auto-approve', 'Skip interactive prompt and import directly')\n   193→    .action(async (epicOpts, cmd) => {\n   194→      const opts = cmd.optsWithGlobals();\n   195→      const isJson = opts.json === true;\n   196→      const autoApprove = epicOpts.autoApprove === true;\n   197→      const isFull = opts.full === true;\n   198→      const forceScan = opts.forceScan === true;\n   199→      const minModuleSize = parseInt(opts.minModuleSize ?? '3', 10);\n   200→\n   201→      const preconditions = runPreconditions();\n   202→      if (!preconditions.canProceed) {\n   203→        if (isJson) {\n   204→          jsonOutput({ status: 'fail', message: 'Harness not initialized \\u2014 run codeharness init first' });\n   205→        } else {\n   206→          fail('Harness not initialized \\u2014 run codeharness init first');\n   207→        }\n   208→        process.exitCode = 1;\n   209→        return;\n   210→      }\n   211→      for (const w of preconditions.warnings) {\n   212→        warn(w);\n   213→      }\n   214→\n   215→      // Ensure scan results are available — try cache first\n   216→      let scan: ScanResult;\n   217→      let coverage: CoverageGapReport;\n   218→      let audit: DocAuditResult;\n   219→\n   220→      if (lastScanResult) {\n   221→        scan = lastScanResult;\n   222→      } else {\n   223→        const cache = loadValidCache(process.cwd(), { forceScan });\n   224→        if (cache) {\n   225→          info(`Using cached scan from ${new Date(cache.timestamp).toLocaleString()}`);\n   226→          scan = cache.scan;\n   227→          lastScanResult = scan;\n   228→          if (cache.coverage) {\n   229→            lastCoverageResult = cache.coverage;\n   230→          }\n   231→          if (cache.audit) {\n   232→            lastAuditResult = cache.audit;\n   233→          }\n   234→        } else {\n   235→          scan = runScan(minModuleSize);\n   236→        }\n   237→      }\n   238→      coverage = lastCoverageResult ?? runCoverageAnalysis(scan);\n   239→      audit = lastAuditResult ?? runAudit();\n   240→\n   241→      const epicPath = join(process.cwd(), 'ralph', 'onboarding-epic.md');\n   242→      const epic = generateOnboardingEpic(scan, coverage, audit);\n   243→\n   244→      // Merge extended gap detectors (story 8-3)\n   245→      mergeExtendedGaps(epic);\n   246→\n   247→      // Gap filtering: skip already-tracked gaps unless --full\n   248→      if (!isFull) {\n   249→        applyGapFiltering(epic);\n   250→      }\n   251→\n   252→      writeOnboardingEpic(epic, epicPath);\n   253→\n   254→      if (isJson) {\n   255→        // JSON mode: read-only, no prompt, no import (AC #7 for --json)\n   256→        jsonOutput({\n   257→          preconditions: { initialized: preconditions.initialized, bmad: preconditions.bmad, hooks: preconditions.hooks },\n   258→          epic,\n   259→          import_status: { stories_created: 0, stories_existing: 0 },\n   260→        });\n   261→        return;\n   262→      }\n   263→\n   264→      // Print summary\n   265→      printEpicOutput(epic);\n   266→\n   267→      // Approval flow\n   268→      let approved: boolean;\n   269→      if (autoApprove) {\n   270→        approved = true;\n   271→      } else {\n   272→        approved = await promptApproval();\n   273→      }\n   274→\n   275→      if (approved) {\n   276→        const results = importOnboardingEpic(epicPath, { listIssues, createIssue });\n   277→        const created = results.filter(r => r.status === 'created').length;\n   278→        ok(`Onboarding: ${created} stories imported into beads`);\n   279→\n   280→        // Append to sprint-status.yaml so harness-run can execute them\n   281→        const sprintResult = appendOnboardingEpicToSprint(\n   282→          epic.stories.map(s => ({ title: s.title })),\n   283→        );\n   284→        if (sprintResult.epicNumber >= 0) {\n   285→          ok(`Onboarding epic ${sprintResult.epicNumber} added to sprint-status.yaml (${sprintResult.storyKeys.length} stories)`);\n   286→        }\n   287→\n   288→        info('Ready to run: codeharness run');\n   289→      } else {\n   290→        info('Plan saved to ralph/onboarding-epic.md \\u2014 edit and re-run when ready');\n   291→      }\n   292→    });\n   293→\n   294→  // Default action: run all phases including epic generation\n   295→  onboard.action(async (opts, cmd) => {\n   296→    const globalOpts = cmd.optsWithGlobals();\n   297→    const isJson = opts.json === true || globalOpts.json === true;\n   298→    const isFull = opts.full === true || globalOpts.full === true;\n   299→    const forceScan = opts.forceScan === true || globalOpts.forceScan === true;\n   300→    const minModuleSize = parseInt(opts.minModuleSize ?? '3', 10);\n   301→\n   302→    const preconditions = runPreconditions();\n   303→    if (!preconditions.canProceed) {\n   304→      if (isJson) {\n   305→        jsonOutput({ status: 'fail', message: 'Harness not initialized \\u2014 run codeharness init first' });\n   306→      } else {\n   307→        fail('Harness not initialized \\u2014 run codeharness init first');\n   308→      }\n   309→      process.exitCode = 1;\n   310→      return;\n   311→    }\n   312→    for (const w of preconditions.warnings) {\n   313→      warn(w);\n   314→    }\n   315→\n   316→    // Check onboarding progress\n   317→    const progress = getOnboardingProgress({ listIssues });\n   318→    if (progress) {\n   319→      if (progress.remaining === 0 && !isFull && !forceScan) {\n   320→        ok('Onboarding complete \\u2014 all gaps resolved');\n   321→        return;\n   322→      }\n   323→      info(`Onboarding progress: ${progress.resolved}/${progress.total} gaps resolved (${progress.remaining} remaining)`);\n   324→    }\n   325→\n   326→    // Phase 1: Scan\n   327→    const scan = runScan(minModuleSize);\n   328→\n   329→    // Phase 2: Coverage\n   330→    const coverage = runCoverageAnalysis(scan);\n   331→\n   332→    // Phase 3: Audit\n   333→    const audit = runAudit();\n   334→\n   335→    // Save complete cache entry\n   336→    saveScanCache({\n   337→      timestamp: new Date().toISOString(),\n   338→      scan,\n   339→      coverage,\n   340→      audit,\n   341→    });\n   342→\n   343→    // Phase 4: Epic generation\n   344→    const epicPath = join(process.cwd(), 'ralph', 'onboarding-epic.md');\n   345→    const epic = generateOnboardingEpic(scan, coverage, audit);\n   346→\n   347→    // Merge extended gap detectors (story 8-3)\n   348→    mergeExtendedGaps(epic);\n   349→\n   350→    // Gap filtering: skip already-tracked gaps unless --full\n   351→    if (!isFull) {\n   352→      applyGapFiltering(epic);\n   353→    }\n   354→\n   355→    writeOnboardingEpic(epic, epicPath);\n   356→\n   357→    if (isJson) {\n   358→      jsonOutput({\n   359→        preconditions: { initialized: preconditions.initialized, bmad: preconditions.bmad, hooks: preconditions.hooks },\n   360→        scan,\n   361→        coverage,\n   362→        audit,\n   363→        epic,\n   364→      });\n   365→    } else {\n   366→      printScanOutput(scan);\n   367→      printCoverageOutput(coverage);\n   368→      printAuditOutput(audit);\n   369→      printEpicOutput(epic);\n   370→\n   371→      // Prompt for approval in combined mode\n   372→      const approved = await promptApproval();\n   373→      if (approved) {\n   374→        const results = importOnboardingEpic(epicPath, { listIssues, createIssue });\n   375→        const created = results.filter(r => r.status === 'created').length;\n   376→        ok(`Onboarding: ${created} stories imported into beads`);\n   377→\n   378→        // Append to sprint-status.yaml so harness-run can execute them\n   379→        const sprintResult = appendOnboardingEpicToSprint(\n   380→          epic.stories.map(s => ({ title: s.title })),\n   381→        );\n   382→        if (sprintResult.epicNumber >= 0) {\n   383→          ok(`Onboarding epic ${sprintResult.epicNumber} added to sprint-status.yaml (${sprintResult.storyKeys.length} stories)`);\n   384→        }\n   385→\n   386→        info('Ready to run: codeharness run');\n   387→      } else {\n   388→        info('Plan saved to ralph/onboarding-epic.md \\u2014 edit and re-run when ready');\n   389→      }\n   390→    }\n   391→  });\n   392→}\n   393→\n   394→// ─── Gap Filtering Helper ────────────────────────────────────────────────────\n   395→\n   396→function applyGapFiltering(epic: OnboardingEpic): void {\n   397→  const { untracked, trackedCount } = filterTrackedGaps(epic.stories, { listIssues });\n   398→  if (trackedCount > 0) {\n   399→    info(`${trackedCount} previously tracked gaps already in beads`);\n   400→  }\n   401→  epic.stories = untracked;\n   402→  rebuildEpicSummary(epic);\n   403→}\n   404→\n   405→function mergeExtendedGaps(epic: OnboardingEpic): void {\n   406→  const verificationGaps = findVerificationGaps();\n   407→  const perFileCoverageGaps = findPerFileCoverageGaps(80);\n   408→  const observabilityGaps = findObservabilityGaps();\n   409→\n   410→  epic.stories.push(...verificationGaps, ...perFileCoverageGaps, ...observabilityGaps);\n   411→  rebuildEpicSummary(epic);\n   412→}\n   413→\n   414→function rebuildEpicSummary(epic: OnboardingEpic): void {\n   415→  const coverageStories = epic.stories.filter(s => s.type === 'coverage').length;\n   416→  const docStories = epic.stories.filter(\n   417→    s => s.type === 'agents-md' || s.type === 'architecture' || s.type === 'doc-freshness',\n   418→  ).length;\n   419→  const verificationStories = epic.stories.filter(s => s.type === 'verification').length;\n   420→  const observabilityStories = epic.stories.filter(s => s.type === 'observability').length;\n   421→  epic.summary = {\n   422→    totalStories: epic.stories.length,\n   423→    coverageStories,\n   424→    docStories,\n   425→    verificationStories,\n   426→    observabilityStories,\n   427→  };\n   428→}\n   429→\n   430→// ─── Phase Implementations ───────────────────────────────────────────────────\n   431→\n   432→function runScan(minModuleSize: number): ScanResult {\n   433→  const result = scanCodebase(process.cwd(), { minModuleSize });\n   434→  lastScanResult = result;\n   435→  return result;\n   436→}\n   437→\n   438→function runCoverageAnalysis(scan: ScanResult): CoverageGapReport {\n   439→  const result = analyzeCoverageGaps(scan.modules);\n   440→  lastCoverageResult = result;\n   441→  return result;\n   442→}\n   443→\n   444→function runAudit(): DocAuditResult {\n   445→  const result = auditDocumentation();\n   446→  lastAuditResult = result;\n   447→  return result;\n   448→}\n   449→\n   450→// ─── Output Formatting ──────────────────────────────────────────────────────\n   451→\n   452→function printScanOutput(result: ScanResult): void {\n   453→  info(`Scan: ${result.totalSourceFiles} source files across ${result.modules.length} modules`);\n   454→  for (const mod of result.modules) {\n   455→    info(`  ${mod.path}: ${mod.sourceFiles} source, ${mod.testFiles} test`);\n   456→  }\n   457→}\n   458→\n   459→function printCoverageOutput(result: CoverageGapReport): void {\n   460→  info(`Coverage: ${result.overall}% overall (${result.uncoveredFiles} files uncovered)`);\n   461→  for (const mod of result.modules) {\n   462→    if (mod.uncoveredFileCount > 0) {\n   463→      info(`  ${mod.path}: ${mod.coveragePercent}% (${mod.uncoveredFileCount} uncovered)`);\n   464→    }\n   465→  }\n   466→}\n   467→\n   468→function printAuditOutput(result: DocAuditResult): void {\n   469→  info(`Docs: ${result.summary}`);\n   470→}\n   471→\n   472→function printEpicOutput(epic: OnboardingEpic): void {\n   473→  info(formatEpicSummary(epic));\n   474→  for (const story of epic.stories) {\n   475→    info(`  ${story.key}: ${story.title}`);\n   476→  }\n   477→}\n   478→"}]},"parent_tool_use_id":"toolu_01AdMUjsSRd2zQjpuDrBr3HX","session_id":"e1f3df9b-d919-466e-880e-1001c8652ee8","uuid":"fd1efcc3-5bf0-489c-bedd-c8947aadb350","timestamp":"2026-03-20T08:40:42.725Z"}
