{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011kEpnFaEozSNbNpvGYQt96","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import {\n     3→  parseRetroSections,\n     4→  normalizeText,\n     5→  wordOverlap,\n     6→  isDuplicate,\n     7→} from '../retro-parser.js';\n     8→\n     9→// ─── parseRetroSections ─────────────────────────────────────────────────\n    10→\n    11→describe('parseRetroSections', () => {\n    12→  it('parses Fix Now items from retro content', () => {\n    13→    const content = `\n    14→## 6. Action Items\n    15→\n    16→### Fix Now (Before Next Session)\n    17→- Fix bare catch blocks in registry.ts (line 73)\n    18→- Update init-project to persist multi-stacks\n    19→`;\n    20→    const items = parseRetroSections(content);\n    21→    const fixNow = items.filter(i => i.section === 'fix-now');\n    22→    expect(fixNow).toHaveLength(2);\n    23→    expect(fixNow[0].text).toBe('Fix bare catch blocks in registry.ts (line 73)');\n    24→    expect(fixNow[1].text).toBe('Update init-project to persist multi-stacks');\n    25→  });\n    26→\n    27→  it('parses Fix Soon items from retro content', () => {\n    28→    const content = `\n    29→## 6. Action Items\n    30→\n    31→### Fix Soon (Next Sprint)\n    32→1. Add element type checking to isValidState()\n    33→2. Unit test recoverCorruptedState() recovery paths\n    34→`;\n    35→    const items = parseRetroSections(content);\n    36→    const fixSoon = items.filter(i => i.section === 'fix-soon');\n    37→    expect(fixSoon).toHaveLength(2);\n    38→    expect(fixSoon[0].text).toBe('Add element type checking to isValidState()');\n    39→    expect(fixSoon[1].text).toBe('Unit test recoverCorruptedState() recovery paths');\n    40→  });\n    41→\n    42→  it('parses Backlog items from retro content', () => {\n    43→    const content = `\n    44→## 6. Action Items\n    45→\n    46→### Backlog (Track But Not Urgent)\n    47→- Remove StackDetection type duplication\n    48→- Address pre-existing TS compilation errors\n    49→`;\n    50→    const items = parseRetroSections(content);\n    51→    const backlog = items.filter(i => i.section === 'backlog');\n    52→    expect(backlog).toHaveLength(2);\n    53→    expect(backlog[0].text).toBe('Remove StackDetection type duplication');\n    54→  });\n    55→\n    56→  it('handles varying header formats (with/without parenthetical suffixes)', () => {\n    57→    const content = `\n    58→## 6. Action Items\n    59→\n    60→#### Fix Now\n    61→- Item A\n    62→\n    63→### Fix Soon (Next Sprint / Next Session)\n    64→- Item B\n    65→\n    66→### Backlog (Escalated Priority)\n    67→- Item C\n    68→`;\n    69→    const items = parseRetroSections(content);\n    70→    expect(items).toHaveLength(3);\n    71→    expect(items[0]).toEqual({ section: 'fix-now', text: 'Item A' });\n    72→    expect(items[1]).toEqual({ section: 'fix-soon', text: 'Item B' });\n    73→    expect(items[2]).toEqual({ section: 'backlog', text: 'Item C' });\n    74→  });\n    75→\n    76→  it('parses all sections together from a complete retro', () => {\n    77→    const content = `\n    78→## 6. Action Items\n    79→\n    80→### Fix Now (Before Next Session)\n    81→- Fix bare catch blocks in registry.ts (line 73)\n    82→- Update init-project to persist multi-stacks\n    83→\n    84→### Fix Soon (Next Sprint)\n    85→1. Add element type checking to isValidState()\n    86→\n    87→### Backlog (Track But Not Urgent)\n    88→- Remove StackDetection type duplication\n    89→`;\n    90→    const items = parseRetroSections(content);\n    91→    expect(items).toHaveLength(4);\n    92→    expect(items.filter(i => i.section === 'fix-now')).toHaveLength(2);\n    93→    expect(items.filter(i => i.section === 'fix-soon')).toHaveLength(1);\n    94→    expect(items.filter(i => i.section === 'backlog')).toHaveLength(1);\n    95→  });\n    96→\n    97→  it('returns empty array when no action items section exists', () => {\n    98→    const content = `# Retrospective\\n\\n## What Went Well\\n- Everything.\\n`;\n    99→    expect(parseRetroSections(content)).toEqual([]);\n   100→  });\n   101→\n   102→  it('returns empty array for empty content', () => {\n   103→    expect(parseRetroSections('')).toEqual([]);\n   104→  });\n   105→\n   106→  it('stops parsing at the next ## section', () => {\n   107→    const content = `\n   108→## 6. Action Items\n   109→\n   110→### Fix Now\n   111→- Item A\n   112→\n   113→## 7. Next Steps\n   114→\n   115→### Fix Now\n   116→- Should not be parsed\n   117→`;\n   118→    const items = parseRetroSections(content);\n   119→    expect(items).toHaveLength(1);\n   120→    expect(items[0].text).toBe('Item A');\n   121→  });\n   122→});\n   123→\n   124→// ─── normalizeText ──────────────────────────────────────────────────────\n   125→\n   126→describe('normalizeText', () => {\n   127→  it('lowercases and splits into words', () => {\n   128→    expect(normalizeText('Fix Bare Catch')).toEqual(['fix', 'bare', 'catch']);\n   129→  });\n   130→\n   131→  it('removes punctuation', () => {\n   132→    expect(normalizeText('registry.ts (line 73)')).toEqual(['registryts', 'line', '73']);\n   133→  });\n   134→\n   135→  it('returns empty array for empty string', () => {\n   136→    expect(normalizeText('')).toEqual([]);\n   137→  });\n   138→\n   139→  it('handles strings with only punctuation', () => {\n   140→    expect(normalizeText('...')).toEqual([]);\n   141→  });\n   142→});\n   143→\n   144→// ─── wordOverlap ────────────────────────────────────────────────────────\n   145→\n   146→describe('wordOverlap', () => {\n   147→  it('returns 1 for identical word arrays', () => {\n   148→    expect(wordOverlap(['fix', 'catch'], ['fix', 'catch'])).toBe(1);\n   149→  });\n   150→\n   151→  it('returns 0 for no overlap', () => {\n   152→    expect(wordOverlap(['foo', 'bar'], ['baz', 'qux'])).toBe(0);\n   153→  });\n   154→\n   155→  it('returns 0 when either array is empty', () => {\n   156→    expect(wordOverlap([], ['a'])).toBe(0);\n   157→    expect(wordOverlap(['a'], [])).toBe(0);\n   158→  });\n   159→\n   160→  it('uses min denominator for partial overlap', () => {\n   161→    // a=[fix, catch, blocks], b=[fix, catch] -> intersection=2, min=2 -> 1.0\n   162→    expect(wordOverlap(['fix', 'catch', 'blocks'], ['fix', 'catch'])).toBe(1);\n   163→  });\n   164→\n   165→  it('computes fractional overlap correctly', () => {\n   166→    // a=[a, b, c, d], b=[a, b, x, y] -> intersection=2, min=4 -> 0.5\n   167→    expect(wordOverlap(['a', 'b', 'c', 'd'], ['a', 'b', 'x', 'y'])).toBe(0.5);\n   168→  });\n   169→});\n   170→\n   171→// ─── isDuplicate ────────────────────────────────────────────────────────\n   172→\n   173→describe('isDuplicate', () => {\n   174→  it('detects exact match (100% overlap)', () => {\n   175→    const result = isDuplicate('Fix bare catch blocks', ['fix bare catch blocks']);\n   176→    expect(result.duplicate).toBe(true);\n   177→    expect(result.matchedTitle).toBe('fix bare catch blocks');\n   178→  });\n   179→\n   180→  it('detects slight variation (85%+ overlap)', () => {\n   181→    // \"Fix bare catch blocks in registry\" vs \"fix bare catch blocks in registryts\"\n   182→    // Both normalize similarly; enough overlap\n   183→    const result = isDuplicate(\n   184→      'Fix bare catch blocks in registry',\n   185→      ['fix bare catch blocks in registry ts'],\n   186→    );\n   187→    expect(result.duplicate).toBe(true);\n   188→  });\n   189→\n   190→  it('rejects clearly different items (< 80% overlap)', () => {\n   191→    const result = isDuplicate(\n   192→      'Add unit tests for scanner module',\n   193→      ['Fix bare catch blocks in registry'],\n   194→    );\n   195→    expect(result.duplicate).toBe(false);\n   196→  });\n   197→\n   198→  it('returns false for empty existing titles', () => {\n   199→    const result = isDuplicate('Some item', []);\n   200→    expect(result.duplicate).toBe(false);\n   201→  });\n   202→\n   203→  it('supports custom threshold', () => {\n   204→    const result = isDuplicate(\n   205→      'Fix catch blocks',\n   206→      ['fix catch blocks extra words here'],\n   207→      0.5,\n   208→    );\n   209→    expect(result.duplicate).toBe(true);\n   210→  });\n   211→});\n   212→"}]},"parent_tool_use_id":"toolu_01QdekhbhdCn1yMfA8HwX61q","session_id":"84a01a9c-e466-45b4-91ef-8201b3712d8d","uuid":"db6bd6d3-b285-41f5-b3c2-227d5f6ffc45","timestamp":"2026-03-24T21:56:59.050Z"}
