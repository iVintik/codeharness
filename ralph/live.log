{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CvuCts78wTjEwqqKLghtRX","type":"tool_result","content":"     1→import { describe, it, expect, beforeAll } from 'vitest';\n     2→import { readFileSync, existsSync } from 'node:fs';\n     3→import { resolve } from 'node:path';\n     4→\n     5→const ROOT = resolve(__dirname, '..', '..', '..', '..');\n     6→\n     7→/**\n     8→ * Extract a section from markdown content between a start heading and the next heading at or above\n     9→ * the given delimiter level. Throws if the start heading is not found, preventing silent empty-string\n    10→ * fallbacks that make assertions vacuous.\n    11→ */\n    12→function extractSection(content: string, startHeading: string, nextHeadingPrefix: string): string {\n    13→  const parts = content.split(startHeading);\n    14→  if (parts.length < 2) {\n    15→    throw new Error(`Section heading \"${startHeading}\" not found in content`);\n    16→  }\n    17→  const afterHeading = parts[1];\n    18→  const nextIdx = afterHeading.indexOf(nextHeadingPrefix);\n    19→  return nextIdx === -1 ? afterHeading : afterHeading.slice(0, nextIdx);\n    20→}\n    21→\n    22→const FOUR_TIERS = ['test-provable', 'runtime-provable', 'environment-provable', 'escalate'] as const;\n    23→const LEGACY_TERMS = ['cli-verifiable', 'integration-required', 'unit-testable', 'black-box'] as const;\n    24→\n    25→let knowledgeDoc: string;\n    26→let devEnforcement: string;\n    27→let reviewEnforcement: string;\n    28→let storyVerification: string;\n    29→\n    30→const DOC_PATHS = {\n    31→  knowledge: resolve(ROOT, 'knowledge/verification-patterns.md'),\n    32→  devEnforcement: resolve(ROOT, 'patches/dev/enforcement.md'),\n    33→  reviewEnforcement: resolve(ROOT, 'patches/review/enforcement.md'),\n    34→  storyVerification: resolve(ROOT, 'patches/verify/story-verification.md'),\n    35→} as const;\n    36→\n    37→beforeAll(() => {\n    38→  for (const [key, path] of Object.entries(DOC_PATHS)) {\n    39→    if (!existsSync(path)) {\n    40→      throw new Error(`Required doc file missing: ${key} at ${path}`);\n    41→    }\n    42→  }\n    43→  knowledgeDoc = readFileSync(DOC_PATHS.knowledge, 'utf-8');\n    44→  devEnforcement = readFileSync(DOC_PATHS.devEnforcement, 'utf-8');\n    45→  reviewEnforcement = readFileSync(DOC_PATHS.reviewEnforcement, 'utf-8');\n    46→  storyVerification = readFileSync(DOC_PATHS.storyVerification, 'utf-8');\n    47→});\n    48→\n    49→// ─── AC1: knowledge/verification-patterns.md has Verification Tier Guide ─────\n    50→\n    51→describe('knowledge/verification-patterns.md — Verification Tier Guide (AC1)', () => {\n    52→  it('contains a \"Verification Tier Guide\" section', () => {\n    53→    expect(knowledgeDoc).toContain('## Verification Tier Guide');\n    54→  });\n    55→\n    56→  it.each(FOUR_TIERS)('lists tier `%s` with criteria and examples', (tier) => {\n    57→    expect(knowledgeDoc).toContain(`### \\`${tier}\\``);\n    58→  });\n    59→\n    60→  it('includes decision criteria for each tier', () => {\n    61→    expect(knowledgeDoc).toContain('Decision criteria:');\n    62→  });\n    63→\n    64→  it('includes examples for each tier', () => {\n    65→    expect(knowledgeDoc).toContain('Examples:');\n    66→  });\n    67→});\n    68→\n    69→// ─── AC2: knowledge/verification-patterns.md has NO legacy tier names ────────\n    70→\n    71→describe('knowledge/verification-patterns.md — no legacy terms (AC2)', () => {\n    72→  it.each(LEGACY_TERMS)('does NOT contain legacy term \"%s\"', (term) => {\n    73→    expect(knowledgeDoc).not.toContain(term);\n    74→  });\n    75→});\n    76→\n    77→// ─── AC3: patches/dev/enforcement.md — renamed section ──────────────────────\n    78→\n    79→describe('patches/dev/enforcement.md — tier-aware language (AC3)', () => {\n    80→  it('contains \"Verification Tier Awareness\" section (renamed from \"Black-Box Thinking\")', () => {\n    81→    expect(devEnforcement).toContain('### Verification Tier Awareness');\n    82→  });\n    83→\n    84→  it.each(FOUR_TIERS)('references `%s` development guidance', (tier) => {\n    85→    expect(devEnforcement).toContain(`\\`${tier}\\``);\n    86→  });\n    87→});\n    88→\n    89→// ─── AC4: patches/dev/enforcement.md has NO black-box ───────────────────────\n    90→\n    91→describe('patches/dev/enforcement.md — no legacy terms (AC4)', () => {\n    92→  it('does NOT contain \"black-box\" as a verification strategy name', () => {\n    93→    expect(devEnforcement).not.toContain('black-box');\n    94→  });\n    95→\n    96→  it('does NOT contain \"Black-Box Thinking\" section heading', () => {\n    97→    expect(devEnforcement).not.toContain('Black-Box Thinking');\n    98→  });\n    99→\n   100→  it.each(LEGACY_TERMS)('does NOT contain legacy term \"%s\"', (term) => {\n   101→    expect(devEnforcement).not.toContain(term);\n   102→  });\n   103→});\n   104→\n   105→// ─── AC5: patches/review/enforcement.md uses four-tier vocabulary ────────────\n   106→\n   107→describe('patches/review/enforcement.md — four-tier vocabulary (AC5)', () => {\n   108→  it.each(FOUR_TIERS)('references tier `%s`', (tier) => {\n   109→    expect(reviewEnforcement).toContain(tier);\n   110→  });\n   111→\n   112→  it.each(LEGACY_TERMS)('does NOT contain legacy term \"%s\"', (term) => {\n   113→    expect(reviewEnforcement).not.toContain(term);\n   114→  });\n   115→});\n   116→\n   117→// ─── AC6: patches/review/enforcement.md — tier-appropriate evidence ─────────\n   118→\n   119→describe('patches/review/enforcement.md — tier-appropriate evidence (AC6)', () => {\n   120→  it('test-provable stories do NOT require docker exec evidence', () => {\n   121→    const testProvableSection = extractSection(reviewEnforcement, '#### `test-provable`', '####');\n   122→    expect(testProvableSection).toContain('`docker exec` evidence is NOT required');\n   123→  });\n   124→\n   125→  it('runtime-provable sto