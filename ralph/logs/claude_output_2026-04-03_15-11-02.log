{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01Dyrxnc1XJeZEsDTUkkgeEL","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Ddjt34QzGPDCompXSGPXu6","name":"Write","input":{"file_path":"/Users/ivintik/dev/personal/codeharness/src/lib/ink-workflow.tsx","content":"/**\n * WorkflowGraph — Ink component that renders a schematic workflow graph.\n *\n * Displays tasks as nodes connected by arrows, with status indicators\n * (pending, active, done, failed). Loop blocks are rendered with an\n * iteration counter and visual grouping.\n *\n * This is a pure presentational component — no side effects, no state hooks.\n */\n\nimport React from 'react';\nimport { Text, Box } from 'ink';\nimport type { FlowStep, LoopBlock } from './workflow-parser.js';\nimport type { TaskNodeState } from './ink-components.js';\n\nexport interface WorkflowGraphProps {\n  flow: FlowStep[];\n  currentTask: string | null;\n  taskStates: Record<string, TaskNodeState>;\n}\n\nfunction isLoopBlock(step: FlowStep): step is LoopBlock {\n  return typeof step === 'object' && step !== null && 'loop' in step;\n}\n\n/** Render a single task name with its status indicator. */\nfunction TaskNode({ name, status }: { name: string; status: TaskNodeState | undefined }) {\n  const s = status ?? 'pending';\n  switch (s) {\n    case 'done':\n      return <Text color=\"green\">{name} ✓</Text>;\n    case 'active':\n      return <Text color=\"cyan\">◆ {name}</Text>;\n    case 'failed':\n      return <Text color=\"red\">{name} ✗</Text>;\n    case 'pending':\n    default:\n      return <Text dimColor>{name}</Text>;\n  }\n}\n\n/** Count completed iterations for a loop block based on task states. */\nfunction loopIteration(tasks: string[], taskStates: Record<string, TaskNodeState>): number {\n  // Count how many times all tasks in the loop have completed.\n  // A simple heuristic: if all tasks are done, iteration is 1.\n  // The actual iteration count needs to come from the engine state.\n  // For now, we derive it from whether the loop tasks have been started.\n  // The iteration count will be properly wired when the engine integration lands.\n  let iteration = 0;\n  const allDone = tasks.every(t => taskStates[t] === 'done');\n  const anyActive = tasks.some(t => taskStates[t] === 'active');\n  const anyStarted = tasks.some(t => taskStates[t] !== 'pending' && taskStates[t] !== undefined);\n  if (allDone) {\n    iteration = 1;\n  } else if (anyActive || anyStarted) {\n    iteration = 1;\n  }\n  // Note: Proper multi-iteration counting requires engine-provided data.\n  // This will be wired in the engine integration story.\n  return iteration;\n}\n\nexport function WorkflowGraph({ flow, currentTask, taskStates }: WorkflowGraphProps) {\n  if (flow.length === 0 || Object.keys(taskStates).length === 0) {\n    return null;\n  }\n\n  const elements: React.ReactNode[] = [];\n\n  for (let i = 0; i < flow.length; i++) {\n    const step = flow[i];\n\n    if (i > 0) {\n      elements.push(<Text key={`arrow-${i}`}>{' → '}</Text>);\n    }\n\n    if (isLoopBlock(step)) {\n      const iteration = loopIteration(step.loop, taskStates);\n      const loopNodes: React.ReactNode[] = [];\n      for (let j = 0; j < step.loop.length; j++) {\n        if (j > 0) {\n          loopNodes.push(<Text key={`loop-arrow-${i}-${j}`}>{' → '}</Text>);\n        }\n        loopNodes.push(\n          <TaskNode key={`loop-task-${i}-${j}`} name={step.loop[j]} status={taskStates[step.loop[j]]} />\n        );\n      }\n      elements.push(\n        <Text key={`loop-${i}`}>\n          <Text>loop({iteration})[ </Text>\n          {loopNodes}\n          <Text> ]</Text>\n        </Text>\n      );\n    } else {\n      elements.push(\n        <TaskNode key={`task-${i}`} name={step} status={taskStates[step]} />\n      );\n    }\n  }\n\n  return (\n    <Box flexDirection=\"column\">\n      <Text>{'━'.repeat(Math.min(process.stdout.columns || 60, 50))}</Text>\n      <Text>  {elements}</Text>\n      <Text>{'━'.repeat(Math.min(process.stdout.columns || 60, 50))}</Text>\n    </Box>\n  );\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":422,"cache_read_input_tokens":29675,"cache_creation":{"ephemeral_5m_input_tokens":422,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01FmqjNRa8DGzh51kkVTD2Pe","session_id":"1d40f54a-b143-44f0-8247-609f8fc4c105","uuid":"d974b7a4-f008-40be-9137-a1149251ed9b"}
