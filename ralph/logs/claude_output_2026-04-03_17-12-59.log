{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ed2o8cHwBuVry9mikXjYeU","type":"tool_result","content":"1\t/**\n2\t * codeharness drivers — Query the driver capability matrix.\n3\t *\n4\t * Outputs a JSON object with each registered driver's default model,\n5\t * capabilities, and a human-readable description.\n6\t *\n7\t * @see architecture-multi-framework.md — FR37: queryable driver capabilities\n8\t */\n9\t\n10\timport { Command } from 'commander';\n11\timport { jsonOutput } from '../lib/output.js';\n12\timport { listDrivers, getDriver, registerDriver } from '../lib/agents/drivers/factory.js';\n13\timport { ClaudeCodeDriver } from '../lib/agents/drivers/claude-code.js';\n14\timport { CodexDriver } from '../lib/agents/drivers/codex.js';\n15\timport { OpenCodeDriver } from '../lib/agents/drivers/opencode.js';\n16\t\n17\t/** Static description map — avoids changing the AgentDriver interface for display concerns. */\n18\tconst DRIVER_DESCRIPTIONS: Record<string, string> = {\n19\t  'claude-code': 'Anthropic Claude via Agent SDK (in-process)',\n20\t  codex: 'OpenAI Codex via CLI',\n21\t  opencode: 'OpenCode via CLI',\n22\t};\n23\t\n24\t/**\n25\t * Ensure all built-in drivers are registered.\n26\t * Safe to call multiple times — skips already-registered drivers.\n27\t */\n28\tfunction ensureDriversRegistered(): void {\n29\t  const registered = new Set(listDrivers());\n30\t  if (!registered.has('claude-code')) registerDriver(new ClaudeCodeDriver());\n31\t  if (!registered.has('codex')) registerDriver(new CodexDriver());\n32\t  if (!registered.has('opencode')) registerDriver(new OpenCodeDriver());\n33\t}\n34\t\n35\texport function registerDriversCommand(program: Command): void {\n36\t  program\n37\t    .command('drivers')\n38\t    .description('List registered drivers and their capabilities')\n39\t    .action((_options, cmd) => {\n40\t      const globalOpts = cmd.optsWithGlobals();\n41\t      const isJson = !!globalOpts.json;\n42\t\n43\t      ensureDriversRegistered();\n44\t\n45\t      const result: Record<string, unknown> = {};\n46\t      for (const name of listDrivers()) {\n47\t        const driver = getDriver(name);\n48\t        result[name] = {\n49\t          defaultModel: driver.defaultModel,\n50\t          capabilities: { ...driver.capabilities },\n51\t          description: DRIVER_DESCRIPTIONS[name] ?? name,\n52\t        };\n53\t      }\n54\t\n55\t      if (isJson) {\n56\t        jsonOutput(result);\n57\t      } else {\n58\t        console.log(JSON.stringify(result, null, 2));\n59\t      }\n60\t    });\n61\t}\n62\t"}]},"parent_tool_use_id":"toolu_016pZ4BCqGaGnHMSNGWJzsLu","session_id":"cf16e575-8267-4c58-a992-20b07458710f","uuid":"2bdbeee5-6065-4064-9848-0ebb06d8c66a","timestamp":"2026-04-03T13:37:33.091Z"}
