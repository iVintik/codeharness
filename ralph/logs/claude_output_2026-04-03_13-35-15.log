ync () => {\n    const workflow: ResolvedWorkflow = {\n      tasks: { implement: makeTask({ driver: 'claude-code' }) },\n      flow: ['implement'],\n    };\n\n    const hangingDriver = {\n      name: 'claude-code',\n      defaultModel: 'test-model',\n      capabilities: { supportsPlugins: false, supportsStreaming: true, costReporting: true },\n      // Resolves after 200ms — longer than the 50ms timeout we'll pass\n      healthCheck: vi.fn().mockImplementation(() => new Promise((resolve) => {\n        setTimeout(() => resolve(makeHealthy()), 200);\n      })),\n      dispatch: vi.fn(),\n      getLastCost: vi.fn().mockReturnValue(null),\n    };\n    mockGetDriver.mockReturnValue(hangingDriver);\n\n    // Use a very short timeout (50ms) to test the timeout path without fake timers\n    await expect(checkDriverHealth(workflow, 50)).rejects.toThrow('Driver health check timed out');\n  });"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":412,"cache_read_input_tokens":51935,"cache_creation":{"ephemeral_5m_input_tokens":412,"ephemeral_1h_input_tokens":0},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01J1hA6EdKQNp4qhAx3VLe1g","session_id":"b101ea9e-2f9e-4377-9c5a-f109fa318b32","uuid":"8f136c6a-ac92-485a-b99c-6b1a789c3982"}
