{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SFfUSUSZZ4wwHNUbicgXqj","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { render } from 'ink-testing-library';\n3\timport React from 'react';\n4\timport { WorkflowGraph, formatCost, formatElapsed } from '../ink-workflow.js';\n5\timport type { TaskNodeState, TaskNodeMeta } from '../ink-components.js';\n6\timport type { FlowStep } from '../workflow-parser.js';\n7\t\n8\t/** Spinner frames used by TaskNode for active state. */\n9\tconst SPINNER_FRAMES = ['ã ', 'ã ', 'ã ¿', 'ã ¡', 'ã ¥', 'ã Ç', 'ã Î', 'ã Ï', 'ã ', 'ã '];\n10\t\n11\tdescribe('WorkflowGraph component', () => {\n12\t  it('renders sequential flow as task1 ã task2 ã task3', () => {\n13\t    const flow: FlowStep[] = ['create-story', 'implement', 'verify'];\n14\t    const taskStates: Record<string, TaskNodeState> = {\n15\t      'create-story': 'done',\n16\t      'implement': 'active',\n17\t      'verify': 'pending',\n18\t    };\n19\t    const { lastFrame } = render(\n20\t      <WorkflowGraph flow={flow} currentTask=\"implement\" taskStates={taskStates} />\n21\t    );\n22\t    const frame = lastFrame()!;\n23\t    expect(frame).toContain('create-story');\n24\t    expect(frame).toContain('ã');\n25\t    expect(frame).toContain('implement');\n26\t    expect(frame).toContain('verify');\n27\t  });\n28\t\n29\t  it('renders loop block as loop(N)[ task1 ã task2 ]', () => {\n30\t    const flow: FlowStep[] = ['create-story', { loop: ['implement', 'verify'] }];\n31\t    const taskStates: Record<string, TaskNodeState> = {\n32\t      'create-story': 'done',\n33\t      'implement': 'active',\n34\t      'verify': 'pending',\n35\t    };\n36\t    const { lastFrame } = render(\n37\t      <WorkflowGraph flow={flow} currentTask=\"implement\" taskStates={taskStates} />\n38\t    );\n39\t    const frame = lastFrame()!;\n40\t    expect(frame).toContain('loop(');\n41\t    expect(frame).toContain('[ ');\n42\t    expect(frame).toContain('implement');\n43\t    expect(frame).toContain('verify');\n44\t    expect(frame).toContain(' ]');\n45\t  });\n46\t\n47\t  it('renders pending tasks with dim text (no status symbols)', () => {\n48\t    const flow: FlowStep[] = ['task1'];\n49\t    const taskStates: Record<string, TaskNodeState> = { 'task1': 'pending' };\n50\t    const { lastFrame } = render(\n51\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} />\n52\t    );\n53\t    const frame = lastFrame()!;\n54\t    expect(frame).toContain('task1');\n55\t    // Pending should NOT have status symbols\n56\t    expect(frame).not.toContain('ã');\n57\t    expect(frame).not.toContain('ã');\n58\t    // Should not contain any spinner frame\n59\t    for (const sf of SPINNER_FRAMES) {\n60\t      expect(frame).not.toContain(sf);\n61\t    }\n62\t  });\n63\t\n64\t  it('renders active task with spinner indicator in cyan', () => {\n65\t    const flow: FlowStep[] = ['task1'];\n66\t    const taskStates: Record<string, TaskNodeState> = { 'task1': 'active' };\n67\t    const { lastFrame } = render(\n68\t      <WorkflowGraph flow={flow} currentTask=\"task1\" taskStates={taskStates} />\n69\t    );\n70\t    const frame = lastFrame()!;\n71\t    // Should contain one of the spinner frames\n72\t    const hasSpinner = SPINNER_FRAMES.some(sf => frame.includes(sf));\n73\t    expect(hasSpinner).toBe(true);\n74\t    expect(frame).toContain('task1');\n75\t  });\n76\t\n77\t  it('renders completed task with ã', () => {\n78\t    const flow: FlowStep[] = ['task1'];\n79\t    const taskStates: Record<string, TaskNodeState> = { 'task1': 'done' };\n80\t    const { lastFrame } = render(\n81\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} />\n82\t    );\n83\t    const frame = lastFrame()!;\n84\t    expect(frame).toContain('ã');\n85\t    expect(frame).toContain('task1');\n86\t  });\n87\t\n88\t  it('renders failed task with ã', () => {\n89\t    const flow: FlowStep[] = ['task1'];\n90\t    const taskStates: Record<string, TaskNodeState> = { 'task1': 'failed' };\n91\t    const { lastFrame } = render(\n92\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} />\n93\t    );\n94\t    const frame = lastFrame()!;\n95\t    expect(frame).toContain('ã');\n96\t    expect(frame).toContain('task1');\n97\t  });\n98\t\n99\t  it('returns null for empty flow', () => {\n100\t    const { lastFrame } = render(\n101\t      <WorkflowGraph flow={[]} currentTask={null} taskStates={{ task1: 'pending' }} />\n102\t    );\n103\t    expect(lastFrame()).toBe('');\n104\t  });\n105\t\n106\t  it('returns null for empty taskStates', () => {\n107\t    const { lastFrame } = render(\n108\t      <WorkflowGraph flow={['task1']} currentTask={null} taskStates={{}} />\n109\t    );\n110\t    expect(lastFrame()).toBe('');\n111\t  });\n112\t\n113\t  it('renders loop block with iteration 0 when all tasks are pending', () => {\n114\t    const flow: FlowStep[] = [{ loop: ['implement', 'verify'] }];\n115\t    const taskStates: Record<string, TaskNodeState> = {\n116\t      'implement': 'pending',\n117\t      'verify': 'pending',\n118\t    };\n119\t    const { lastFrame } = render(\n120\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} />\n121\t    );\n122\t    const frame = lastFrame()!;\n123\t    expect(frame).toContain('loop(0)');\n124\t    expect(frame).toContain('implement');\n125\t    expect(frame).toContain('verify');\n126\t  });\n127\t\n128\t  it('renders loop block with iteration 1 when a task is done', () => {\n129\t    const flow: FlowStep[] = [{ loop: ['implement', 'verify'] }];\n130\t    const taskStates: Record<string, TaskNodeState> = {\n131\t      'implement': 'done',\n132\t      'verify': 'pending',\n133\t    };\n134\t    const { lastFrame } = render(\n135\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} />\n136\t    );\n137\t    const frame = lastFrame()!;\n138\t    expect(frame).toContain('loop(1)');\n139\t  });\n140\t\n141\t  it('renders loop block with iteration 1 when a task has failed', () => {\n142\t    const flow: FlowStep[] = [{ loop: ['implement', 'verify'] }];\n143\t    const taskStates: Record<string, TaskNodeState> = {\n144\t      'implement': 'failed',\n145\t      'verify': 'pending',\n146\t    };\n147\t    const { lastFrame } = render(\n148\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} />\n149\t    );\n150\t    const frame = lastFrame()!;\n151\t    expect(frame).toContain('loop(1)');\n152\t  });\n153\t\n154\t  it('renders mixed flow with sequential and loop steps', () => {\n155\t    const flow: FlowStep[] = ['create-story', { loop: ['implement', 'verify'] }, 'deploy'];\n156\t    const taskStates: Record<string, TaskNodeState> = {\n157\t      'create-story': 'done',\n158\t      'implement': 'done',\n159\t      'verify': 'active',\n160\t      'deploy': 'pending',\n161\t    };\n162\t    const { lastFrame } = render(\n163\t      <WorkflowGraph flow={flow} currentTask=\"verify\" taskStates={taskStates} />\n164\t    );\n165\t    const frame = lastFrame()!;\n166\t    expect(frame).toContain('create-story');\n167\t    expect(frame).toContain('ã');\n168\t    expect(frame).toContain('loop(');\n169\t    expect(frame).toContain('implement');\n170\t    expect(frame).toContain('verify');\n171\t    expect(frame).toContain('deploy');\n172\t    // Separator lines\n173\t    expect(frame).toContain('ã');\n174\t  });\n175\t\n176\t  // --- Driver label tests (AC #5) ---\n177\t\n178\t  it('renders driver label below task name when taskMeta is provided', () => {\n179\t    const flow: FlowStep[] = ['implement', 'verify'];\n180\t    const taskStates: Record<string, TaskNodeState> = {\n181\t      'implement': 'done',\n182\t      'verify': 'active',\n183\t    };\n184\t    const taskMeta: Record<string, TaskNodeMeta> = {\n185\t      'implement': { driver: 'claude-code' },\n186\t      'verify': { driver: 'codex' },\n187\t    };\n188\t    const { lastFrame } = render(\n189\t      <WorkflowGraph flow={flow} currentTask=\"verify\" taskStates={taskStates} taskMeta={taskMeta} />\n190\t    );\n191\t    const frame = lastFrame()!;\n192\t    expect(frame).toContain('claude-code');\n193\t    expect(frame).toContain('codex');\n194\t  });\n195\t\n196\t  // --- Cost/time tests (AC #6, #7) ---\n197\t\n198\t  it('renders cost and elapsed time for completed tasks', () => {\n199\t    const flow: FlowStep[] = ['implement'];\n200\t    const taskStates: Record<string, TaskNodeState> = {\n201\t      'implement': 'done',\n202\t    };\n203\t    const taskMeta: Record<string, TaskNodeMeta> = {\n204\t      'implement': { driver: 'claude-code', costUsd: 0.42, elapsedMs: 240000 },\n205\t    };\n206\t    const { lastFrame } = render(\n207\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} taskMeta={taskMeta} />\n208\t    );\n209\t    const frame = lastFrame()!;\n210\t    expect(frame).toContain('$0.42');\n211\t    expect(frame).toContain('4m');\n212\t  });\n213\t\n214\t  it('renders ... for null cost and normal elapsed time', () => {\n215\t    const flow: FlowStep[] = ['implement'];\n216\t    const taskStates: Record<string, TaskNodeState> = {\n217\t      'implement': 'done',\n218\t    };\n219\t    const taskMeta: Record<string, TaskNodeMeta> = {\n220\t      'implement': { driver: 'codex', costUsd: null, elapsedMs: 120000 },\n221\t    };\n222\t    const { lastFrame } = render(\n223\t      <WorkflowGraph flow={flow} currentTask={null} taskStates={taskStates} taskMeta={taskMeta} />\n224\t    );\n225\t    const frame = lastFrame()!;\n226\t    expect(frame).toContain('...');\n227\t    expect(frame).toContain('2m');\n228\t    // Should NOT show $0.00\n229\t    expect(frame).not.toContain('$0.00');\n230\t  });\n231\t\n232\t  it('does not render cost row for non-completed tasks', () => {\n233\t    const flow: FlowStep[] = ['implement'];\n234\t    const taskStates: Record<string, TaskNodeS