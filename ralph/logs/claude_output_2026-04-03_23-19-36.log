{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0199PoMofUNPMfWnW5bMpJyn","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, type Mock } from 'vitest';\n2\timport { WorktreeManager, WorktreeError, BRANCH_PREFIX, WORKTREE_BASE } from '../worktree-manager.js';\n3\timport type { WorktreeInfo } from '../worktree-manager.js';\n4\t\n5\t// Mock child_process\n6\tvi.mock('node:child_process', () => ({\n7\t  execSync: vi.fn(),\n8\t}));\n9\t\n10\t// Mock node:fs\n11\tvi.mock('node:fs', () => ({\n12\t  existsSync: vi.fn(),\n13\t  readFileSync: vi.fn(),\n14\t}));\n15\t\n16\timport { execSync } from 'node:child_process';\n17\timport { existsSync, readFileSync } from 'node:fs';\n18\t\n19\tconst mockExecSync = execSync as Mock;\n20\tconst mockExistsSync = existsSync as Mock;\n21\tconst mockReadFileSync = readFileSync as Mock;\n22\t\n23\tdescribe('worktree-manager', () => {\n24\t  let manager: WorktreeManager;\n25\t\n26\t  beforeEach(() => {\n27\t    vi.clearAllMocks();\n28\t    manager = new WorktreeManager('main', '/repo');\n29\t    // Default: no stale state exists\n30\t    mockExistsSync.mockReturnValue(false);\n31\t    // Default: no existing branches\n32\t    mockExecSync.mockReturnValue(Buffer.from(''));\n33\t  });\n34\t\n35\t  describe('WorktreeError', () => {\n36\t    it('includes stderr in the error (AC #11)', () => {\n37\t      const err = new WorktreeError('something failed', 'fatal: not a git repo');\n38\t      expect(err).toBeInstanceOf(Error);\n39\t      expect(err.name).toBe('WorktreeError');\n40\t      expect(err.message).toBe('something failed');\n41\t      expect(err.stderr).toBe('fatal: not a git repo');\n42\t    });\n43\t  });\n44\t\n45\t  describe('constants', () => {\n46\t    it('branch prefix uses codeharness/ namespace (NFR12)', () => {\n47\t      expect(BRANCH_PREFIX).toBe('codeharness/epic-');\n48\t      expect(BRANCH_PREFIX.startsWith('codeharness/')).toBe(true);\n49\t    });\n50\t\n51\t    it('worktree base is in /tmp', () => {\n52\t      expect(WORKTREE_BASE).toBe('/tmp/codeharness-wt-epic-');\n53\t    });\n54\t  });\n55\t\n56\t  describe('createWorktree', () => {\n57\t    it('creates branch and worktree, returns path (AC #1, #2)', () => {\n58\t      // No stale state\n59\t      mockExecSync.mockImplementation((cmd: string) => {\n60\t        if (cmd.includes('branch --list')) return Buffer.from('');\n61\t        return Buffer.from('');\n62\t      });\n63\t\n64\t      const path = manager.createWorktree('17', 'worktree-manager');\n65\t\n66\t      expect(path).toBe('/tmp/codeharness-wt-epic-17');\n67\t\n68\t      // Verify git commands were called\n69\t      const calls = mockExecSync.mock.calls.map((c: unknown[]) => c[0] as string);\n70\t      expect(calls).toContainEqual(\n71\t        expect.stringContaining('git branch codeharness/epic-17-worktree-manager main'),\n72\t      );\n73\t      expect(calls).toContainEqual(\n74\t        expect.stringContaining('git worktree add /tmp/codeharness-wt-epic-17 codeharness/epic-17-worktree-manager'),\n75\t      );\n76\t    });\n77\t\n78\t    it('uses codeharness/ prefix for branch names (AC #11, NFR12)', () => {\n79\t      mockExecSync.mockReturnValue(Buffer.from(''));\n80\t\n81\t      manager.createWorktree('42', 'my-epic');\n82\t\n83\t      const calls = mockExecSync.mock.calls.map((c: unknown[]) => c[0] as string);\n84\t      const branchCmd = calls.find((c) => c.includes('git branch codeharness/'));\n85\t      expect(branchCmd).toContain('codeharness/epic-42-my-epic');\n86\t    });\n87\t\n88\t    it('sanitizes slug to [a-z0-9-] (edge case)', () => {\n89\t      mockExecSync.mockReturnValue(Buffer.from(''));\n90\t\n91\t      manager.createWorktree('1', 'My Epic With CAPS & Symbols!');\n92\t\n93\t      const calls = mockExecSync.mock.calls.map((c: unknown[]) => c[0] as string);\n94\t      const branchCmd = calls.find((c) => c.startsWith('git branch codeharness/'));\n95\t      expect(branchCmd).toContain('codeharness/epic-1-my-epic-with-caps-symbols');\n96\t    });\n97\t\n98\t    it('cleans up stale branch before re-creating (AC #9)', () => {\n99\t      // Simulate stale branch existing\n100\t      let callCount = 0;\n101\t      mockExecSync.mockImplementation((cmd: string) => {\n102\t        if (cmd.includes('branch --list')) {\n103\t          // First call during cleanup: stale branch exists\n104\t          if (callCount === 0) {\n105\t            callCount++;\n106\t            return Buffer.from('  codeharness/epic-17-old-slug\\n');\n107\t          }\n108\t          return Buffer.from('');\n109\t        }\n110\t        return Buffer.from('');\n111\t      });\n112\t\n113\t      const path = manager.createWorktree('17', 'new-slug');\n114\t      expect(path).toBe('/tmp/codeharness-wt-epic-17');\n115\t\n116\t      // Should have cleaned up the stale branch\n117\t      const calls = mockExecSync.mock.calls.map((c: unknown[]) => c[0] as string);\n118\t      expect(calls).toContainEqual(\n119\t        expect.stringContaining('git branch -D codeharness/epic-17-old-slug'),\n120\t      );\n121\t    });\n122\t\n123\t    it('cleans up stale worktree directory before re-creating (AC #9)', () => {\n124\t      // Simulate worktree directory existing on disk\n125\t      mockExistsSync.mockImplementation((p: string) => {\n126\t        return p === '/tmp/codeharness-wt-epic-17';\n127\t      });\n128\t      mockExecSync.mockReturnValue(Buffer.from(''));\n129\t\n130\t      const path = manager.createWorktree('17', 'slug');\n131\t      expect(path).toBe('/tmp/codeharness-wt-epic-17');\n132\t\n133\t      // Should have tried to remove the stale worktree\n134\t      const calls = mockExecSync.mock.calls.map((c: unknown[]) => c[0] as string);\n135\t      expect(calls).toContainEqual(\n136\t        expect.stringContaining('git worktree remove /tmp/codeharness-wt-epic-17 --force'),\n137\t      );\n138\t    });\n139\t\n140\t    it('throws WorktreeError with stderr on git failure (AC #10)', () => {\n141\t      const gitError = new Error('Command failed');\n142\t      (gitError as unknown as { stderr: Buffer }).stderr = Buffer.from('fatal: not a git repository');\n143\t      mockExecSync.mockImplementation((cmd: string) => {\n144\t        if (cmd.includes('branch --list')) return Buffer.from('');\n145\t        if (cmd.startsWith('git branch codeharness/')) throw gitError;\n146\t        return Buffer.from('');\n147\t      });\n148\t\n149\t      expect(() => manager.createWorktree('17', 'slug')).toThrow(WorktreeError);\n150\t      try {\n151\t        manager.createWorktree('17', 'slug');\n152\t      } catch (err) {\n153\t        expect(err).toBeInstanceOf(WorktreeError);\n154\t        expect((err as WorktreeError).stderr).toContain('fatal: not a git repository');\n155\t        expect((err as WorktreeError).message).toContain('fatal: not a git repository');\n156\t      }\n157\t    });\n158\t\n159\t    it('cleans up partial state on failure — branch created but worktree fails (AC #10)', () => {\n160\t      let branchCreated = false;\n161\t      mockExecSync.mockImplementation((cmd: string) => {\n162\t        if (cmd.includes('branch --list')) return Buffer.from('');\n163\t        if (cmd.startsWith('git branch codeharness/') && !cmd.includes('-D')) {\n164\t          branchCreated = true;\n165\t          return Buffer.from('');\n166\t        }\n167\t        if (cmd.startsWith('git worktree add') && branchCreated) {\n168\t          const err = new Error('disk full');\n169\t          (err as unknown as { stderr: Buffer }).stderr = Buffer.from('error: disk full');\n170\t          throw err;\n171\t        }\n172\t        // Cleanup calls should succeed\n173\t        return Buffer.from('');\n174\t      });\n175\t\n176\t      expect(() => manager.createWorktree('17', 'slug')).toThrow(WorktreeError);\n177\t\n178\t      // Verify cleanup was attempted — branch -D should have been called\n179\t      const calls = mockExecSync.mock.calls.map((c: unknown[]) => c[0] as string);\n180\t      expect(calls).toContainEqual(\n181\t        expect.stringContaining('git branch -D codeharness/epic-17-slug'),\n182\t      );\n183\t    });\n184\t\n185\t    it('all error messages include stderr from git (AC #11)', () => {\n186\t      const gitError = new Error('fail');\n187\t      (gitError as unknown as { stderr: Buffer }).stderr = Buffer.from('stderr content here');\n188\t      mockExecSync.mockImplementation((cmd: string) => {\n189\t        if (cmd.includes('branch --list')) return Buffer.from('');\n190\t        if (cmd.startsWith('git branch codeharness/')) throw gitError;\n191\t        return Buffer.from('');\n192\t      });\n193\t\n194\t      try {\n195\t        manager.createWorktree('1', 'x');\n196\t      } catch (err) {\n197\t        expect(err).toBeInstanceOf(WorktreeError);\n198\t        expect((err as WorktreeError).stderr).toBe('stderr content here');\n199\t      }\n200\t    });\n201\t  });\n202\t\n203\t  describe('cleanupWorktree', () => {\n204\t    it('removes worktree and branch (AC #4)', () => {\n205\t      mockExecSync.mockImplementation((cmd: string) => {\n206\t        if (cmd.includes('branch --list')) {\n207\t          return Buffer.from('  codeharness/epic-17-my-slug\\n');\n208\t        }\n209\t        return Buffer.from('');\n210\t      });\n211\t\n212\t      manager.cleanupWorktree('17');\n213\t\n214\t      const calls = mockExecSync.mock.calls.map((c: unknown[]) => c[0] as string);\n215\t      expect(calls).toContainEqual(\n216\t        expect.stringContaining('git worktree remove /tmp/codeharness-wt-epic-17 --force'),\n217\t      );\n218\t      expect(calls).toContainEqual(\n219\t        expect.stringContaining('git branch -D codeharness/epic-17-my-slug'),\n220\t      );\n221\t    });\n222\t\n223\t    it('is idempotent — no error when nothing exists (AC #5)', () => {\n224\t      // All git commands fail (nothing exists)\n225\t      mockExecSync.mockImplementation(() => {\n226\t        const err = new Error('not found');\n227\t        (err as unknown as { stderr: Buffer }).stderr = Buffer.from('error: not found');\n228\t        throw err;\n229\t      });\n230\t\n231\t      // Should not throw\n232\t      expect(() => manager.cleanupWorktree('99')).not.toThrow();\n233\t    });\n234\t\n235\t    it('completes even if only branch exists (no worktree)', () => {\n236\t      mockExecSync.mockImplementation((cmd: string) => {\n237\t        if (cmd.includes('worktree remove')) {\n238\t          const err = new Error('no worktree');\n239\t          (err as unknown as { stderr: Buffer }).stderr = Buffer.from('');\n240\t          throw err;\n241\t        }\n242\t        if (cmd.includes('branch --list')) {\n243\t          return Buffer.from('  codeharness/epic-5-slug\\n');\n244\t        }\n245\t        return Buffer.from('');\n246\t      });\n247\t\n248\t      expect(() => manager.cleanupWorktree('5')).not.toThrow();\n249\t    });\n250\t  });\n251\t\n252\t  describe('listWorktrees', () => {\n253\t    it('returns only codeharness-prefixed worktrees (AC #6)', () => {\n254\t      const porcelain = [\n255\t        'worktree /repo',\n256\t        'HEAD abc123',\n257\t        'branch refs/heads/main',\n258\t        '',\n259\t        'worktree /tmp/codeharness-wt-epic-17',\n260\t        'HEAD def456',\n261\t        'branch refs/heads/codeharness/epic-17-worktree-manager',\n262\t        '',\n263\t        'worktree /tmp/other-worktree',\n264\t        'HEAD 789abc',\n265\t        'branch refs/heads/feature/something',\n266\t        '',\n267\t        'worktree /tmp/codeharness-wt-epic-18',\n268\t        'HEAD aaa111',\n269\t        'branch refs/heads/codeharness/epic-18-lane-pool',\n270\t        '',\n271\t      ].join('\\n');\n272\t\n273\t      mockExecSync.mockReturnValue(Buffer.from(porcelain));\n274\t\n275\t      const result = manager.listWorktrees();\n276\t\n277\t      expect(result).toHaveLength(2);\n278\t      expect(result[0].epicId).toBe('17');\n279\t      expect(result[0].path).toBe('/tmp/codeharness-wt-epic-17');\n280\t      expect(result[0].branch).toBe('codeharness/epic-17-worktree-manager');\n281\t      expect(result[1].epicId).toBe('18');\n282\t      expect(result[1].path).toBe('/tmp/codeharness-wt-epic-18');\n283\t      expect(result[1].branch).toBe('codeharness/epic-18-lane-pool');\n284\t    });\n285\t\n286\t    it('returns WorktreeInfo with all required fields (AC #6)', () => {\n287\t      const porcelain = [\n288\t        'worktree /tmp/codeharness-wt-epic-5',\n289\t        'HEAD abc123',\n290\t        'branch refs/heads/codeharness/epic-5-slug',\n291\t        '',\n292\t      ].join('\\n');\n293\t      mockExecSync.mockReturnValue(Buffer.from(porcelain));\n294\t\n295\t      const result = manager.listWorktrees();\n296\t\n297\t      expect(result).toHaveLength(1);\n298\t      const wt = result[0];\n299\t      expect(wt).toHaveProperty('epicId', '5');\n300\t      expect(wt).toHaveProperty('path', '/tmp/codeharness-wt-epic-5');\n301\t      expect(wt).toHaveProperty('branch', 'codeharness/epic-5-slug');\n302\t      expect(wt).toHaveProperty('createdAt');\n303\t      expect(wt.createdAt).toBeInstanceOf(Date);\n304\t    });\n305\t\n306\t    it('returns empty array when no codeharness worktrees exist (AC #7)', () => {\n307\t      const porcelain = [\n308\t        'worktree /repo',\n309\t        'HEAD abc123',\n310\t        'branch refs/heads/main',\n311\t        '',\n312\t      ].join('\\n');\n313\t      mockExecSync.mockReturnValue(Buffer.from(porcelain));\n314\t\n315\t      const result = manager.listWorktrees();\n316\t      expect(result).toEqual([]);\n317\t    });\n318\t\n319\t    it('returns empty array when git worktree list fails', () => {\n320\t      mockExecSync.mockImplementation(() => {\n321\t        throw new Error('not a git repo');\n322\t      });\n323\t\n324\t      const result = manager.listWorktrees();\n325\t      expect(result).toEqual([]);\n326\t    });\n327\t\n328\t    it('sorts results by epicId numerically', () => {\n329\t      const porcelain = [\n330\t        'worktree /tmp/codeharness-wt-epic-20',\n331\t        'HEAD aaa',\n332\t        'branch refs/heads/codeharness/epic-20-z',\n333\t        '',\n334\t        'worktree /tmp/codeharness-wt-epic-3',\n335\t        'HEAD bbb',\n336\t        'branch refs/heads/codeharness/epic-3-a',\n337\t        '',\n338\t        'worktree /tmp/codeharness-wt-epic-10',\n339\t        'HEAD ccc',\n340\t        'branch refs/heads/codeharness/epic-10-m',\n341\t        '',\n342\t      ].join('\\n');\n343\t      mockExecSync.mockReturnValue(Buffer.from(porcelain));\n344\t\n345\t      const result = manager.listWorktrees();\n346\t      expect(result.map((r) => r.epicId)).toEqual(['3', '10', '20']);\n347\t    });\n348\t  });\n349\t\n350\t  describe('detectOrphans', () => {\n351\t    it('identifies worktrees without lane-state.json as orphaned (AC #8)', () => {\n352\t      const porcelain = [\n353\t        'worktree /tmp/codeharness-wt-epic-17',\n354\t        'HEAD abc123',\n355\t        'branch refs/heads/codeharness/epic-17-slug',\n356\t        '',\n357\t      ].join('\\n');\n358\t      mockExecSync.mockReturnValue(Buffer.from(porcelain));\n359\t      // lane-state.json does not exist\n360\t      mockExistsSync.mockReturnValue(false);\n361\t\n362\t      const orphans = manager.detectOrphans();\n363\t\n364\t      expect(orphans).toHaveLength(1);\n365\t      expect(orphans[0].epicId).toBe('17');\n366\t    });\n367\t\n368\t    it('identifies worktrees with no PID in lane-state.json as orphaned (AC #8)', () => {\n369\t      const porcelain = [\n370\t        'worktree /tmp/codeharness-wt-epic-17',\n371\t        'HEAD abc123',\n372\t        'branch refs/heads/codeharness/epic-17-slug',\n373\t        '',\n374\t      ].join('\\n');\n375\t      mockExecSync.mockReturnValue(Buffer.from(porcelain));\n376\t      mockExistsSync.mockReturnValue(true);\n377\t      mockReadFileSync.mockReturnValue(JSON.stringify({})); // No pid field\n378\t\n379\t      const orphans = manager.detectOrphans();\n380\t      expect(orphans).toHaveLength(1);\n381\t    });\n382\t\n383\t    it('identifies worktrees with dead PID as orphaned (AC #8)', () => {\n384\t      const porcelain = [\n385\t        'worktree /tmp/codeharness-wt-epic-17',\n386\t        'HEAD abc123',\n387\t        'branch refs/heads/codeharness/epic-17-slug',\n388\t        '',\n389\t      ].join('\\n');\n390\t      mockExecSync.mockReturnValue(Buffer.from(porcelain));\n391\t      mockExistsSync.mockReturnValue(true);\n392\t      mockReadFileSync.mockReturnValue(JSON.stringify({ pid: 999999999 }));\n393\t      // process.kill(999999999, 0) will throw because PID doesn't exist\n394\t      const killSpy = vi.spyOn(process, 'kill').mockImplementation(() => {\n395\t        throw new Error('ESRCH');\n396\t      });\n397\t\n398\t      const orphans = manager.detectOrphans();\n399\t      expect(orphans).toHaveLength(1);\n400\t\n401\t      killSpy.mockRestore();\n402\t    });\n403\t\n404\t    it('does NOT mark worktree as orphaned if PID is alive (AC #8)', () => {\n405\t      const porcelain = [\n406\t        'worktree /tmp/codeharness-wt-epic-17',\n407\t        'HEAD abc123',\n408\t        'branch refs/heads/codeharness/epic-17-slug',\n409\t        '',\n410\t      ].join('\\n');\n411\t      mockExecSync.mockReturnValue(Buffer.from(porcelain));\n412\t      mockExistsSync.mockReturnValue(true);\n413\t      mockReadFileSync.mockReturnValue(JSON.stringify({ pid: process.pid }));\n414\t      // process.kill(process.pid, 0) succeeds — current process is alive\n415\t      const killSpy = vi.spyOn(process, 'kill').mockReturnValue(true);\n416\t\n417\t      const orphans = manager.detectOrphans();\n418\t      expect(orphans).toHaveLength(0);\n419\t\n420\t      killSpy.mockRestore();\n421\t    });\n422\t\n423\t    it('returns empty array when no worktrees exist', () => {\n424\t      mockExecSync.mockReturnValue(Buffer.from(''));\n425\t\n426\t      const orphans = manager.detectOrphans();\n427\t      expect(orphans).toEqual([]);\n428\t    });\n429\t  });\n430\t\n431\t  describe('constructor defaults', () => {\n432\t    it('defaults mainBranch to main', () => {\n433\t      const mgr = new WorktreeManager();\n434\t      mockExecSync.mockReturnValue(Buffer.from(''));\n435\t\n436\t      mgr.createWorktree('1', 'test');\n437\t\n438\t      const calls = mockExecSync.mock.calls.map((c: unknown[]) => c[0] as string);\n439\t      const branchCmd = calls.find((c) => c.startsWith('git branch codeharness/'));\n440\t      expect(branchCmd).toContain(' main');\n441\t    });\n442\t  });\n443\t});\n444\t"}]},"parent_tool_use_id":"toolu_01M4NenhzW72RWGSvvu339mv","session_id":"187035da-d60e-40cf-8aef-09e6134be246","uuid":"41917a50-8706-4489-abac-6f535819ff7a","timestamp":"2026-04-03T19:32:21.968Z"}
