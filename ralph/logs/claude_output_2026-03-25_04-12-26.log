{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014A4dZn4GRq9r8wigKiKBWS","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n     2→import { captureGitDiff, captureStateDelta, capturePartialStderr, captureTimeoutReport, findLatestTimeoutReport } from '../timeout.js';\n     3→\n     4→// Mock node:child_process\n     5→vi.mock('node:child_process', () => ({\n     6→  execSync: vi.fn(),\n     7→}));\n     8→\n     9→// Mock node:fs\n    10→vi.mock('node:fs', () => ({\n    11→  readFileSync: vi.fn(),\n    12→  writeFileSync: vi.fn(),\n    13→  existsSync: vi.fn(),\n    14→  mkdirSync: vi.fn(),\n    15→  readdirSync: vi.fn(),\n    16→}));\n    17→\n    18→import { execSync } from 'node:child_process';\n    19→import { readFileSync, writeFileSync, existsSync, mkdirSync, readdirSync } from 'node:fs';\n    20→\n    21→const mockedExecSync = vi.mocked(execSync);\n    22→const mockedReadFileSync = vi.mocked(readFileSync);\n    23→const mockedWriteFileSync = vi.mocked(writeFileSync);\n    24→const mockedExistsSync = vi.mocked(existsSync);\n    25→const mockedMkdirSync = vi.mocked(mkdirSync);\n    26→const mockedReaddirSync = vi.mocked(readdirSync);\n    27→\n    28→beforeEach(() => {\n    29→  vi.clearAllMocks();\n    30→});\n    31→\n    32→afterEach(() => {\n    33→  vi.restoreAllMocks();\n    34→});\n    35→\n    36→describe('captureGitDiff', () => {\n    37→  it('returns diff summary when git is available', () => {\n    38→    mockedExecSync\n    39→      .mockReturnValueOnce(' src/foo.ts | 5 ++---\\n 1 file changed')\n    40→      .mockReturnValueOnce(' src/bar.ts | 2 ++\\n 1 file changed');\n    41→\n    42→    const result = captureGitDiff();\n    43→    expect(result.success).toBe(true);\n    44→    if (!result.success) return;\n    45→    expect(result.data).toContain('Unstaged:');\n    46→    expect(result.data).toContain('src/foo.ts');\n    47→    expect(result.data).toContain('Staged:');\n    48→    expect(result.data).toContain('src/bar.ts');\n    49→  });\n    50→\n    51→  it('returns \"No changes detected\" when both diffs are empty', () => {\n    52→    mockedExecSync\n    53→      .mockReturnValueOnce('')\n    54→      .mockReturnValueOnce('');\n    55→\n    56→    const result = captureGitDiff();\n    57→    expect(result.success).toBe(true);\n    58→    if (!result.success) return;\n    59→    expect(result.data).toBe('No changes detected');\n    60→  });\n    61→\n    62→  it('returns fail() when git is not available', () => {\n    63→    mockedExecSync.mockImplementation(() => {\n    64→      throw new Error('git: command not found');\n    65→    });\n    66→\n    67→    const result = captureGitDiff();\n    68→    expect(result.success).toBe(false);\n    69→    if (result.success) return;\n    70→    expect(result.error).toContain('Failed to capture git diff');\n    71→    expect(result.error).toContain('git: command not found');\n    72→  });\n    73→\n    74→  it('uses 5-second timeout for git commands', () => {\n    75→    mockedExecSync.mockReturnValue('');\n    76→\n    77→    captureGitDiff();\n    78→\n    79→    expect(mockedExecSync).toHaveBeenCalledWith(\n    80→      'git diff --stat',\n    81→      expect.objectContaining({ timeout: 5000 }),\n    82→    );\n    83→    expect(mockedExecSync).toHaveBeenCalledWith(\n    84→      'git diff --cached --stat',\n    85→      expect.objectContaining({ timeout: 5000 }),\n    86→    );\n    87→  });\n    88→\n    89→  it('handles git command timeout (mock execSync to simulate hang)', () => {\n    90→    mockedExecSync.mockImplementation(() => {\n    91→      const err = new Error('TIMEOUT');\n    92→      (err as NodeJS.ErrnoException).code = 'ETIMEDOUT';\n    93→      throw err;\n    94→    });\n    95→\n    96→    const result = captureGitDiff();\n    97→    expect(result.success).toBe(false);\n    98→    if (result.success) return;\n    99→    expect(result.error).toContain('Failed to capture git diff');\n   100→  });\n   101→});\n   102→\n   103→describe('captureStateDelta', () => {\n   104→  it('correctly identifies changed story statuses', () => {\n   105→    mockedExistsSync.mockReturnValue(true);\n   106→    mockedReadFileSync\n   107→      .mockReturnValueOnce(JSON.stringify({\n   108→        stories: {\n   109→          '1-1-auth': { status: 'in-progress' },\n   110→          '1-2-login': { status: 'backlog' },\n   111→        },\n   112→      }))\n   113→      .mockReturnValueOnce(JSON.stringify({\n   114→        stories: {\n   115→          '1-1-auth': { status: 'done' },\n   116→          '1-2-login': { status: 'backlog' },\n   117→        },\n   118→      }));\n   119→\n   120→    const result = captureStateDelta('/tmp/before.json', '/tmp/after.json');\n   121→    expect(result.success).toBe(true);\n   122→    if (!result.success) return;\n   123→    expect(result.data).toContain('1-1-auth: in-progress');\n   124→    expect(result.data).toContain('done');\n   125→    expect(result.data).not.toContain('1-2-login');\n   126→  });\n   127→\n   128→  it('returns \"No state changes\" when states are identical', () => {\n   129→    mockedExistsSync.mockReturnValue(true);\n   130→    const state = JSON.stringify({ stories: { '1-1-a': { status: 'done' } } });\n   131→    mockedReadFileSync\n   132→      .mockReturnValueOnce(state)\n   133→      .mockReturnValueOnce(state);\n   134→\n   135→    const result = captureStateDelta('/tmp/before.json', '/tmp/after.json');\n   136→    expect(result.success).toBe(true);\n   137→    if (!result.success) return;\n   138→    expect(result.data).toBe('No state changes');\n   139→  });\n   140→\n   141→  it('returns fail() on missing before file', () => {\n   142→    mockedExistsSync.mockReturnValueOnce(false);\n   143→\n   144→    const result = captureStateDelta('/tmp/missing.json', '/tmp/after.json');\n   145→    expect(result.success).toBe(false);\n   146→    if (result.success) return;\n   