{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AS3189R3ZtbdDSunT97yHn","type":"tool_result","content":"     1→import { execFileSync } from 'node:child_process';\n     2→import { writeFileSync } from 'node:fs';\n     3→import { getComposeFilePath, getOtelConfigPath, ensureStackDir } from '../stack-path.js';\n     4→import { dockerComposeTemplate, dockerComposeCollectorOnlyTemplate } from '../../templates/docker-compose.js';\n     5→import { otelCollectorConfigTemplate, otelCollectorRemoteTemplate } from '../../templates/otel-config.js';\n     6→import type { DockerServiceStatus, DockerStartResult } from './health.js';\n     7→\n     8→export function isStackRunning(composeFile: string): boolean {\n     9→  try {\n    10→    const output = execFileSync('docker', ['compose', '-f', composeFile, 'ps', '--format', 'json'], {\n    11→      stdio: 'pipe',\n    12→      timeout: 15_000,\n    13→    });\n    14→    const text = output.toString().trim();\n    15→    if (!text) return false;\n    16→\n    17→    // docker compose ps --format json outputs one JSON object per line\n    18→    const lines = text.split('\\n').filter(l => l.trim());\n    19→    for (const line of lines) {\n    20→      const svc = JSON.parse(line) as { State?: string };\n    21→      if (svc.State !== 'running') return false;\n    22→    }\n    23→    return lines.length > 0;\n    24→  } catch {\n    25→    // IGNORE: docker compose check failed, stack not running\n    26→    return false;\n    27→  }\n    28→}\n    29→\n    30→export function isSharedStackRunning(): boolean {\n    31→  try {\n    32→    const composeFile = getComposeFilePath();\n    33→    const output = execFileSync('docker', ['compose', '-p', 'codeharness-shared', '-f', composeFile, 'ps', '--format', 'json'], {\n    34→      stdio: 'pipe',\n    35→      timeout: 15_000,\n    36→    });\n    37→    const text = output.toString().trim();\n    38→    if (!text) return false;\n    39→\n    40→    const lines = text.split('\\n').filter(l => l.trim());\n    41→    for (const line of lines) {\n    42→      const svc = JSON.parse(line) as { State?: string };\n    43→      if (svc.State !== 'running') return false;\n    44→    }\n    45→    return lines.length > 0;\n    46→  } catch {\n    47→    // IGNORE: docker compose check failed, shared stack not running\n    48→    return false;\n    49→  }\n    50→}\n    51→\n    52→export function startStack(composeFile: string): DockerStartResult {\n    53→  try {\n    54→    execFileSync('docker', ['compose', '-f', composeFile, 'up', '-d'], {\n    55→      stdio: 'pipe',\n    56→      timeout: 30_000,\n    57→    });\n    58→\n    59→    const services = getRunningServices(composeFile);\n    60→    return {\n    61→      started: true,\n    62→      services,\n    63→    };\n    64→  } catch (err) {\n    65→    const message = err instanceof Error ? err.message : String(err);\n    66→    return {\n    67→      started: false,\n    68→      services: [],\n    69→      error: message,\n    70→    };\n    71→  }\n    72→}\n    73→\n    74→export function startSharedStack(): DockerStartResult {\n    75→  try {\n    76→    ensureStackDir();\n    77→\n    78→    const composeFile = getComposeFilePath();\n    79→    const otelConfigFile = getOtelConfigPath();\n    80→\n    81→    const composeContent = dockerComposeTemplate({ shared: true });\n    82→    writeFileSync(composeFile, composeContent, 'utf-8');\n    83→\n    84→    const otelContent = otelCollectorConfigTemplate();\n    85→    writeFileSync(otelConfigFile, otelContent, 'utf-8');\n    86→\n    87→    execFileSync('docker', ['compose', '-p', 'codeharness-shared', '-f', composeFile, 'up', '-d'], {\n    88→      stdio: 'pipe',\n    89→      timeout: 30_000,\n    90→    });\n    91→\n    92→    const services = getRunningServices(composeFile, 'codeharness-shared');\n    93→    return {\n    94→      started: true,\n    95→      services,\n    96→    };\n    97→  } catch (err) {\n    98→    const message = err instanceof Error ? err.message : String(err);\n    99→    return {\n   100→      started: false,\n   101→      services: [],\n   102→      error: message,\n   103→    };\n   104→  }\n   105→}\n   106→\n   107→export function stopStack(composeFile: string): void {\n   108→  execFileSync('docker', ['compose', '-f', composeFile, 'down', '-v'], {\n   109→    stdio: 'pipe',\n   110→    timeout: 30_000,\n   111→  });\n   112→}\n   113→\n   114→export function stopSharedStack(): void {\n   115→  const composeFile = getComposeFilePath();\n   116→  execFileSync('docker', ['compose', '-p', 'codeharness-shared', '-f', composeFile, 'down'], {\n   117→    stdio: 'pipe',\n   118→    timeout: 30_000,\n   119→  });\n   120→}\n   121→\n   122→export function startCollectorOnly(logsUrl: string, metricsUrl: string, tracesUrl: string): DockerStartResult {\n   123→  try {\n   124→    ensureStackDir();\n   125→\n   126→    const composeFile = getComposeFilePath();\n   127→    const otelConfigFile = getOtelConfigPath();\n   128→\n   129→    const composeContent = dockerComposeCollectorOnlyTemplate();\n   130→    writeFileSync(composeFile, composeContent, 'utf-8');\n   131→\n   132→    const otelContent = otelCollectorRemoteTemplate({ logsUrl, metricsUrl, tracesUrl });\n   133→    writeFileSync(otelConfigFile, otelContent, 'utf-8');\n   134→\n   135→    execFileSync('docker', ['compose', '-p', 'codeharness-collector', '-f', composeFile, 'up', '-d'], {\n   136→      stdio: 'pipe',\n   137→      timeout: 30_000,\n   138→    });\n   139→\n   140→    const services = getRunningServices(composeFile, 'codeharness-collector');\n   141→    return {\n   142→      started: true,\n   143→      services,\n   144→    };\n   145→  } catch (err) {\n   146→    const message = err instanceof Error ? err.message : String(err);\n   147→    return {\n   148→      started: false,\n   149→      services: [],\n   150→      error: message,\n   151→    };\n   152→  }\n   153→}\n   154→\n   155→export function isCollectorRunning(): boolean {\n   156→  try {\n   157→    const composeFile = getComposeFilePath();\n   158→    const output = execFileSync('docker', ['compose', '-p', 'codeharness-collector', '-f', composeFile, 'ps', '--format', 'json'], {\n   159→      stdio: 'pipe',\n   160→      timeout: 15_000,\n   161→    });\n   162→    const text = output.toString().trim();\n   163→    if (!text) return false;\n   164→\n   165→    const lines = text.split('\\n').filter(l => l.trim());\n   166→    for (const line of lines) {\n   167→      const svc = JSON.parse(line) as { State?: string };\n   168→      if (svc.State !== 'running') return false;\n   169→    }\n   170→    return lines.length > 0;\n   171→  } catch {\n   172→    // IGNORE: collector status check failed, not running\n   173→    return false;\n   174→  }\n   175→}\n   176→\n   177→export function stopCollectorOnly(): void {\n   178→  const composeFile = getComposeFilePath();\n   179→  execFileSync('docker', ['compose', '-p', 'codeharness-collector', '-f', composeFile, 'down'], {\n   180→    stdio: 'pipe',\n   181→    timeout: 30_000,\n   182→  });\n   183→}\n   184→\n   185→function getRunningServices(composeFile: string, projectName?: string): DockerServiceStatus[] {\n   186→  try {\n   187→    const args = projectName\n   188→      ? ['compose', '-p', projectName, '-f', composeFile, 'ps', '--format', 'json']\n   189→      : ['compose', '-f', composeFile, 'ps', '--format', 'json'];\n   190→\n   191→    const output = execFileSync('docker', args, {\n   192→      stdio: 'pipe',\n   193→      timeout: 15_000,\n   194→    });\n   195→    const text = output.toString().trim();\n   196→    if (!text) return [];\n   197→\n   198→    const lines = text.split('\\n').filter(l => l.trim());\n   199→    const services: DockerServiceStatus[] = [];\n   200→    for (const line of lines) {\n   201→      const svc = JSON.parse(line) as { Service?: string; State?: string; Publishers?: Array<{ PublishedPort?: number }> };\n   202→      const ports = (svc.Publishers ?? [])\n   203→        .filter(p => p.PublishedPort && p.PublishedPort > 0)\n   204→        .map(p => String(p.PublishedPort));\n   205→      services.push({\n   206→        name: svc.Service ?? 'unknown',\n   207→        status: svc.State ?? 'unknown',\n   208→        port: ports.join(','),\n   209→      });\n   210→    }\n   211→    return services;\n   212→  } catch {\n   213→    // IGNORE: docker compose ps failed, return empty service list\n   214→    return [];\n   215→  }\n   216→}\n   217→"}]},"parent_tool_use_id":"toolu_01ARb5KJHwvTVWjSi4hskh96","session_id":"7c5953f4-1d55-4aa9-825f-60bc73601e00","uuid":"57571933-5824-43e7-b4ac-fc4c69931968","timestamp":"2026-03-25T01:50:27.912Z"}
