{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LQVMkqSCNhFQtFaHXP8Ydy","type":"tool_result","content":"1\timport { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n2\timport { join } from 'node:path';\n3\timport { parse, stringify } from 'yaml';\n4\timport { warn } from './output.js';\n5\timport { detectStack, detectStacks, type StackName } from './stacks/index.js';\n6\t\n7\texport interface HarnessState {\n8\t  harness_version: string;\n9\t  initialized: boolean;\n10\t  stack: string | null;\n11\t  stacks: StackName[];\n12\t  app_type?: 'server' | 'cli' | 'web' | 'agent' | 'generic';\n13\t  enforcement: {\n14\t    frontend: boolean;\n15\t    database: boolean;\n16\t    api: boolean;\n17\t  };\n18\t  coverage: {\n19\t    target: number;\n20\t    baseline: number | null;\n21\t    current: number | null;\n22\t    tool: 'c8' | 'coverage.py' | 'cargo-tarpaulin' | 'unknown';\n23\t    /** Per-stack coverage tools map (stack name -> tool) for multi-stack projects */\n24\t    tools?: Record<string, string>;\n25\t  };\n26\t  session_flags: {\n27\t    logs_queried: boolean;\n28\t    tests_passed: boolean;\n29\t    coverage_met: boolean;\n30\t    verification_run: boolean;\n31\t  };\n32\t  verification_log: string[];\n33\t  otlp?: {\n34\t    enabled: boolean;\n35\t    endpoint: string;\n36\t    service_name: string;\n37\t    mode: 'local-shared' | 'remote-direct' | 'remote-routed';\n38\t    backend?: 'victoria' | 'elk' | 'none';\n39\t    node_require?: string;\n40\t    python_wrapper?: string;\n41\t    cli_env_vars?: Record<string, string>;\n42\t    web_snippet_path?: string;\n43\t    resource_attributes?: string;\n44\t    agent_sdk?: string;\n45\t    rust_env_hint?: string;\n46\t  };\n47\t  retro_issue_targets?: Array<{ repo: string; labels: string[] }>;\n48\t  docker?: {\n49\t    compose_file: string;\n50\t    stack_running: boolean;\n51\t    remote_endpoints?: {\n52\t      logs_url?: string;\n53\t      metrics_url?: string;\n54\t      traces_url?: string;\n55\t    };\n56\t    ports: {\n57\t      logs: number;\n58\t      metrics: number;\n59\t      traces: number;\n60\t      otel_grpc: number;\n61\t      otel_http: number;\n62\t    };\n63\t  };\n64\t}\n65\t\n66\tfunction migrateState(state: HarnessState): HarnessState {\n67\t  const raw = state as unknown as Record<string, unknown>;\n68\t  // Backfill otlp.backend for pre-backend-choice states\n69\t  if (state.otlp && !state.otlp.backend) {\n70\t    state.otlp.backend = 'victoria';\n71\t  }\n72\t\n73\t  // New format: stacks array already present\n74\t  if (Array.isArray(raw.stacks) && raw.stacks.length > 0) {\n75\t    state.stacks = raw.stacks as StackName[];\n76\t    state.stack = state.stacks[0] ?? null;\n77\t    return state;\n78\t  }\n79\t\n80\t  // Old format: has stack string but no stacks array\n81\t  if (typeof raw.stack === 'string' && raw.stack) {\n82\t    state.stacks = [raw.stack as StackName];\n83\t    return state;\n84\t  }\n85\t\n86\t  // Neither present\n87\t  state.stacks = [];\n88\t  state.stack = null;\n89\t  return state;\n90\t}\n91\t\n92\tconst STATE_DIR = '.claude';\n93\tconst STATE_FILE = 'codeharness.local.md';\n94\tconst DEFAULT_BODY = '\\n# Codeharness State\\n\\nThis file is managed by the codeharness CLI. Do not edit manually.\\n';\n95\t\n96\t/** Default coverage tool names keyed by stack. */\n97\tconst COVERAGE_TOOL_DEFAULTS: Record<string, HarnessState['coverage']['tool']> = {\n98\t  python: 'coverage.py',\n99\t  rust: 'cargo-tarpaulin',\n100\t};\n101\t\n102\texport function getDefaultCoverageTool(stack?: string | null): HarnessState['coverage']['tool'] {\n103\t  if (stack && COVERAGE_TOOL_DEFAULTS[stack]) return COVERAGE_TOOL_DEFAULTS[stack];\n104\t  return 'c8';\n105\t}\n106\t\n107\texport function getDefaultState(stack?: string | null): HarnessState {\n108\t  return {\n109\t    harness_version: '0.1.0',\n110\t    initialized: false,\n111\t    stack: stack ?? null,\n112\t    stacks: stack ? [stack as StackName] : [],\n113\t    enforcement: {\n114\t      frontend: true,\n115\t      database: true,\n116\t      api: true,\n117\t    },\n118\t    coverage: {\n119\t      target: 90,\n120\t      baseline: null,\n121\t      current: null,\n122\t      tool: getDefaultCoverageTool(stack),\n123\t    },\n124\t    session_flags: {\n125\t      logs_queried: false,\n126\t      tests_passed: false,\n127\t      coverage_met: false,\n128\t      verification_run: false,\n129\t    },\n130\t    verification_log: [],\n131\t  };\n132\t}\n133\t\n134\texport function getStatePath(dir: string): string {\n135\t  return join(dir, STATE_DIR, STATE_FILE);\n136\t}\n137\t\n138\texport function writeState(state: HarnessState, dir?: string, body?: string): void {\n139\t  const baseDir = dir ?? process.cwd();\n140\t  const claudeDir = join(baseDir, STATE_DIR);\n141\t  mkdirSync(claudeDir, { recursive: true });\n142\t\n143\t  // Sync stack from stacks[0] for backward compat (shallow copy to avoid mutating caller's object)\n144\t  const toWrite = { ...state };\n145\t  if (toWrite.stacks && toWrite.stacks.length > 0) {\n146\t    toWrite.stack = toWrite.stacks[0];\n147\t  }\n148\t\n149\t  const yamlContent = stringify(toWrite, { nullStr: 'null' });\n150\t  const markdownBody = body ?? DEFAULT_BODY;\n151\t  const fileContent = `---\\n${yamlContent}---\\n${markdownBody}`;\n152\t\n153\t  writeFileSync(join(claudeDir, STATE_FILE), fileContent, 'utf-8');\n154\t}\n155\t\n156\texport function readState(dir?: string): HarnessState {\n157\t  const baseDir = dir ?? process.cwd();\n158\t  const filePath = getStatePath(baseDir);\n159\t\n160\t  if (!existsSync(filePath)) {\n161\t    throw new StateFileNotFoundError();\n162\t  }\n163\t\n164\t  const raw = readFileSync(filePath, 'utf-8');\n165\t  const parts = raw.split('---');\n166\t\n167\t  // parts[0] is empty (before first ---), parts[1] is YAML, rest is body\n168\t  if (parts.length < 3) {\n169\t    return recoverCorruptedState(baseDir);\n170\t  }\n171\t\n172\t  try {\n173\t    const state = parse(parts[1]) as HarnessState;\n174\t    if (!isValidState(state)) {\n175\t      return recoverCorruptedState(baseDir);\n176\t    }\n177\t    return migrateState(state);\n178\t  } catch {\n179\t    // IGNORE: corrupted state file, recover gracefully\n180\t    return recoverCorruptedState(baseDir);\n181\t  }\n182\t}\n183\t\n184\texport function readStateWithBody(dir?: string): { state: HarnessState; body: string } {\n185\t  const baseDir = dir ?? process.cwd();\n186\t  const filePath = getStatePath(baseDir);\n187\t\n188\t  if (!existsSync(filePath)) {\n189\t    throw new StateFileNotFoundError();\n190\t  }\n191\t\n192\t  const raw = readFileSync(filePath, 'utf-8');\n193\t  const parts = raw.split('---');\n194\t\n195\t  if (parts.length < 3) {\n196\t    const state = recoverCorruptedState(baseDir);\n197\t    return { state, body: DEFAULT_BODY };\n198\t  }\n199\t\n200\t  try {\n201\t    const state = parse(parts[1]) as HarnessState;\n202\t    if (!isValidState(state)) {\n203\t      const recovered = recoverCorruptedState(baseDir);\n204\t      return { state: recovered, body: DEFAULT_BODY };\n205\t    }\n206\t    // Everything after the second --- is the body\n207\t    const body = parts.slice(2).join('---');\n208\t    return { state: migrateState(state), body: body || DEFAULT_BODY };\n209\t  } catch {\n210\t    // IGNORE: corrupted state YAML, recover with defaults\n211\t    const state = recoverCorruptedState(baseDir);\n212\t    return { state, body: DEFAULT_BODY };\n213\t  }\n214\t}\n215\t\n216\tfunction isValidState(state: unknown): state is HarnessState {\n217\t  if (!state || typeof state !== 'object') return false;\n218\t  const s = state as Record<string, unknown>;\n219\t  if (typeof s.harness_version !== 'string') return false;\n220\t  if (typeof s.initialized !== 'boolean') return false;\n221\t  if (s.stack !== null && typeof s.stack !== 'string') return false;\n222\t  if (!s.enforcement || typeof s.enforcement !== 'object') return false;\n223\t  if (!s.coverage || typeof s.coverage !== 'object') return false;\n224\t  if (!s.session_flags || typeof s.session_flags !== 'object') return false;\n225\t  if (!Array.isArray(s.verification_log)) return false;\n226\t  // Accept old format (no stacks) and new format (stacks is array of strings)\n227\t  if (s.stacks !== undefined && !Array.isArray(s.stacks)) return false;\n228\t  if (Array.isArray(s.stacks) && s.stacks.some((v: unknown) => typeof v !== 'string')) return false;\n229\t  return true;\n230\t}\n231\t\n232\tfunction recoverCorruptedState(dir: string): HarnessState {\n233\t  warn('State file corrupted — recreating from detected config');\n234\t  const stack = detectStack(dir);\n235\t  const allStacks = detectStacks(dir);\n236\t  const state = getDefaultState(stack);\n237\t  // Dedupe: detectStacks may return same stack from multiple dirs\n238\t  const uniqueStackNames = [...new Set(allStacks.map(s => s.stack))];\n239\t  state.stacks = uniqueStackNames;\n240\t  // Sync stack from stacks[0] if stacks were detected but root stack was null\n241\t  if (state.stack === null && uniqueStackNames.length > 0) {\n242\t    state.stack = uniqueStackNames[0];\n243\t  }\n244\t  writeState(state, dir);\n245\t  return state;\n246\t}\n247\t\n248\texport class StateFileNotFoundError extends Error {\n249\t  constructor() {\n250\t    super('No state file found. Run \\'codeharness init\\' first.');\n251\t    this.name = 'StateFileNotFoundError';\n252\t  }\n253\t}\n254\t\n255\tconst DANGEROUS_KEYS = new Set(['__proto__', 'constructor', 'prototype']);\n256\t\n257\tfunction validateKeyPath(keyPath: string): void {\n258\t  const keys = keyPath.split('.');\n259\t  for (const key of keys) {\n260\t    if (DANGEROUS_KEYS.has(key)) {\n261\t      throw new Error(`Invalid key path: '${key}' is not allowed`);\n262\t    }\n263\t  }\n264\t}\n265\t\n266\texport function getNestedValue(obj: Record<string, unknown>, keyPath: string): unknown {\n267\t  validateKeyPath(keyPath);\n268\t  const keys = keyPath.split('.');\n269\t  let current: unknown = obj;\n270\t  for (const key of keys) {\n271\t    if (current === null || current === undefined || typeof current !== 'object') {\n272\t      return undefined;\n273\t    }\n274\t    current = (current as Record<string, unknown>)[key];\n275\t  }\n276\t  return current;\n277\t}\n278\t\n279\texport function setNestedValue(obj: Record<string, unknown>, keyPath: string, value: unknown): void {\n280\t  validateKeyPath(keyPath);\n281\t  const keys = keyPath.split('.');\n282\t  let current: Record<string, unknown> = obj;\n283\t  for (let i = 0; i < keys.length - 1; i++) {\n284\t    const key = keys[i];\n285\t    if (current[key] === undefined || current[key] === null || typeof current[key] !== 'object') {\n286\t      current[key] = {};\n287\t    }\n288\t    current = current[key] as Record<string, unknown>;\n289\t  }\n290\t  current[keys[keys.length - 1]] = value;\n291\t}\n292\t\n293\texport function parseValue(raw: string): unknown {\n294\t  if (raw === 'true') return true;\n295\t  if (raw === 'false') return false;\n296\t  if (raw === 'null') return null;\n297\t  const n = Number(raw);\n298\t  return !Number.isNaN(n) && raw.trim() !== '' ? n : raw;\n299\t}\n300\t"}]},"parent_tool_use_id":"toolu_01JWPSfMd9pChrXHMHYJCdbA","session_id":"aeb5b1ee-06a7-4bdc-8279-6cd22d306d14","uuid":"23c3da10-8715-47bd-a970-38a7c5a7ed2f","timestamp":"2026-04-02T10:51:32.361Z"}
