{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LLzcTpQZ8f8C7fCjVNWJRE","type":"tool_result","content":"1\timport { Command } from 'commander';\n2\timport { existsSync, readFileSync } from 'node:fs';\n3\timport { join } from 'node:path';\n4\timport { ok, fail, info, warn, jsonOutput } from '../lib/output.js';\n5\timport { parseRetroActionItems, classifyFinding, parseRetroSections, isDuplicate, derivePriority } from '../lib/retro-parser.js';\n6\timport { createIssue, readIssues } from '../lib/issue-tracker.js';\n7\timport { isGhAvailable, findExistingGhIssue, ghIssueCreate, ensureLabels, getRepoFromRemote } from '../lib/github.js';\n8\timport { readState, StateFileNotFoundError } from '../lib/state.js';\n9\timport type { Classification } from '../lib/retro-parser.js';\n10\timport type { RetroIssueTarget } from '../lib/github.js';\n11\timport type { Issue } from '../lib/issue-tracker.js';\n12\t\n13\tconst STORY_DIR = '_bmad-output/implementation-artifacts';\n14\t\n15\t/** Maximum length for issue titles derived from action item descriptions. */\n16\tconst MAX_TITLE_LENGTH = 120;\n17\t\n18\tinterface ImportedIssue {\n19\t  number: string;\n20\t  title: string;\n21\t  gapId: string;\n22\t  classification: string;\n23\t  created: boolean;\n24\t  status: string;\n25\t  notes: string;\n26\t}\n27\t\n28\tinterface LocalImportResult {\n29\t  imported: number;\n30\t  skipped: number;\n31\t  duplicates: number;\n32\t  issues: Array<{ id: string; title: string; source: string; priority: string }>;\n33\t}\n34\t\n35\tinterface GitHubResult {\n36\t  created: number;\n37\t  skipped: number;\n38\t  errors: number;\n39\t}\n40\t\n41\tfunction classificationToString(c: Classification): string {\n42\t  if (c.type === 'tool') {\n43\t    return `tool:${c.name}`;\n44\t  }\n45\t  return c.type;\n46\t}\n47\t\n48\texport function registerRetroImportCommand(program: Command): void {\n49\t  program\n50\t    .command('retro-import')\n51\t    .description('Import retrospective action items as GitHub issues')\n52\t    .requiredOption('--epic <n>', 'Epic number to import action items from')\n53\t    .action((opts, cmd) => {\n54\t      const globalOpts = cmd.optsWithGlobals();\n55\t      const isJson = globalOpts.json === true;\n56\t      const root = process.cwd();\n57\t\n58\t      // Validate epic number\n59\t      const epicNum = parseInt(opts.epic, 10);\n60\t      if (isNaN(epicNum) || epicNum < 1) {\n61\t        fail(`Invalid epic number: ${opts.epic}`, { json: isJson });\n62\t        process.exitCode = 1;\n63\t        return;\n64\t      }\n65\t\n66\t      // Read retro file\n67\t      const retroFile = `epic-${epicNum}-retrospective.md`;\n68\t      const retroPath = join(root, STORY_DIR, retroFile);\n69\t\n70\t      if (!existsSync(retroPath)) {\n71\t        fail(`Retro file not found: ${retroFile}`, { json: isJson });\n72\t        process.exitCode = 1;\n73\t        return;\n74\t      }\n75\t\n76\t      let content: string;\n77\t      try {\n78\t        content = readFileSync(retroPath, 'utf-8');\n79\t      } catch (err: unknown) {\n80\t        const message = err instanceof Error ? err.message : String(err);\n81\t        fail(`Failed to read retro file: ${message}`, { json: isJson });\n82\t        process.exitCode = 1;\n83\t        return;\n84\t      }\n85\t\n86\t      // ─── Local issues.yaml import ──────────────────────────────────────\n87\t      const localResult = importToIssuesYaml(content, epicNum, root, isJson);\n88\t\n89\t      // Parse table-based action items for GitHub phase\n90\t      const items = parseRetroActionItems(content);\n91\t\n92\t      // If both parsers found nothing, report and exit\n93\t      if (items.length === 0 && localResult.imported === 0 && localResult.skipped === 0 && localResult.duplicates === 0) {\n94\t        if (isJson) {\n95\t          jsonOutput({ imported: 0, skipped: 0, duplicates: 0, issues: [] });\n96\t        } else {\n97\t          info('No action items found in retro file');\n98\t        }\n99\t        return;\n100\t      }\n101\t\n102\t      const issues: ImportedIssue[] = [];\n103\t\n104\t      for (const item of items) {\n105\t        const classification = classifyFinding(item);\n106\t        const gapId = `[gap:retro:epic-${epicNum}-item-${item.number}]`;\n107\t\n108\t        // Truncate title to reasonable length\n109\t        const title =\n110\t          item.description.length > MAX_TITLE_LENGTH\n111\t            ? item.description.slice(0, MAX_TITLE_LENGTH - 3) + '...'\n112\t            : item.description;\n113\t\n114\t        const issueRecord: ImportedIssue = {\n115\t          number: item.number,\n116\t          title,\n117\t          gapId,\n118\t          classification: classificationToString(classification),\n119\t          created: false,\n120\t          status: item.status,\n121\t          notes: item.notes,\n122\t        };\n123\t\n124\t        issues.push(issueRecord);\n125\t\n126\t        if (!isJson) {\n127\t          info(`Parsed: ${title}`);\n128\t        }\n129\t      }\n130\t\n131\t      // ─── GitHub Issue Creation Phase ────────────────────────────────────\n132\t      const githubResult = createGitHubIssues(issues, epicNum, isJson);\n133\t\n134\t      if (isJson) {\n135\t        jsonOutput({\n136\t          imported: localResult.imported,\n137\t          skipped: localResult.skipped,\n138\t          duplicates: localResult.duplicates,\n139\t          issues: localResult.issues as unknown as Record<string, unknown>[],\n140\t          github: githubResult as unknown as Record<string, unknown>,\n141\t        });\n142\t      }\n143\t    });\n144\t}\n145\t\n146\t/**\n147\t * Import retro action items into `.codeharness/issues.yaml`.\n148\t * Tries section-based parsing first, falls back to table-based parsing.\n149\t */\n150\tfunction importToIssuesYaml(\n151\t  content: string,\n152\t  epicNum: number,\n153\t  dir: string,\n154\t  isJson: boolean,\n155\t): LocalImportResult {\n156\t  const source = `retro-epic-${epicNum}`;\n157\t  const result: LocalImportResult = { imported: 0, skipped: 0, duplicates: 0, issues: [] };\n158\t\n159\t  // Read existing issue titles for dedup\n160\t  const existingIssues = readIssues(dir);\n161\t  const existingTitles = existingIssues.issues.map(i => i.title);\n162\t\n163\t  // Strategy: try section-based first, fall back to table-based\n164\t  const sectionItems = parseRetroSections(content);\n165\t  const actionableSections = sectionItems.filter(i => i.section !== 'backlog');\n166\t  const backlogSections = sectionItems.filter(i => i.section === 'backlog');\n167\t\n168\t  if (actionableSections.length > 0 || backlogSections.length > 0) {\n169\t    // Section-based format found\n170\t    for (const item of backlogSections) {\n171\t      result.skipped++;\n172\t      if (!isJson) {\n173\t        info(`Skipped (backlog — non-actionable): ${item.text}`);\n174\t      }\n175\t    }\n176\t\n177\t    for (const item of actionableSections) {\n178\t      const priority = item.section === 'fix-now' ? 'high' : 'medium';\n179\t\n180\t      // Check for duplicates\n181\t      const dupCheck = isDuplicate(item.text, existingTitles);\n182\t      if (dupCheck.duplicate) {\n183\t        result.duplicates++;\n184\t        if (!isJson) {\n185\t          info(`Skipped (duplicate of \"${dupCheck.matchedTitle}\"): ${item.text}`);\n186\t        }\n187\t        continue;\n188\t      }\n189\t\n190\t      const issue = createIssue(item.text, { priority, source }, dir);\n191\t      existingTitles.push(issue.title);\n192\t      result.imported++;\n193\t      result.issues.push({ id: issue.id, title: issue.title, source: issue.source, priority: issue.priority });\n194\t\n195\t      if (!isJson) {\n196\t        ok(`Imported [${issue.id}] (${priority}): ${item.text}`);\n197\t      }\n198\t    }\n199\t\n200\t    return result;\n201\t  }\n202\t\n203\t  // Fall back to table-based parsing\n204\t  const tableItems = parseRetroActionItems(content);\n205\t\n206\t  if (tableItems.length === 0) {\n207\t    return result;\n208\t  }\n209\t\n210\t  for (const item of tableItems) {\n211\t    const priorityNum = derivePriority(item);\n212\t    const priority = priorityNum === 1 ? 'high' : 'medium';\n213\t\n214\t    // Check for duplicates\n215\t    const dupCheck = isDuplicate(item.description, existingTitles);\n216\t    if (dupCheck.duplicate) {\n217\t      result.duplicates++;\n218\t      if (!isJson) {\n219\t        info(`Skipped (duplicate of \"${dupCheck.matchedTitle}\"): ${item.description}`);\n220\t      }\n221\t      continue;\n222\t    }\n223\t\n224\t    const issue = createIssue(item.description, { priority, source }, dir);\n225\t    existingTitles.push(issue.title);\n226\t    result.imported++;\n227\t    result.issues.push({ id: issue.id, title: issue.title, source: issue.source, priority: issue.priority });\n228\t\n229\t    if (!isJson) {\n230\t      ok(`Imported [${issue.id}] (${priority}): ${item.description}`);\n231\t    }\n232\t  }\n233\t\n234\t  return result;\n235\t}\n236\t\n237\t/**\n238\t * Resolves the target repo for a classification based on retro_issue_targets config.\n239\t */\n240\tfunction resolveTargetRepo(\n241\t  classification: string,\n242\t  targets: RetroIssueTarget[],\n243\t): RetroIssueTarget | undefined {\n244\t  if (targets.length === 0) return undefined;\n245\t\n246\t  if (classification === 'harness') {\n247\t    // Prefer explicit codeharness repo, then first non-auto, then auto as fallback\n248\t    const explicit = targets.find(t => t.repo === 'iVintik/codeharness');\n249\t    if (explicit) return explicit;\n250\t    const nonAuto = targets.find(t => t.repo !== 'auto');\n251\t    if (nonAuto) return nonAuto;\n252\t    return targets[0];\n253\t  }\n254\t\n255\t  // project or tool:* → prefer auto, else first target\n256\t  const auto = targets.find(t => t.repo === 'auto');\n257\t  if (auto) return auto;\n258\t  return targets[0];\n259\t}\n260\t\n261\t/**\n262\t * Builds the GitHub issue body with retro context and gap-id for dedup.\n263\t */\n264\tfunction buildGitHubIssueBody(\n265\t  item: ImportedIssue,\n266\t  epicNum: number,\n267\t  projectName: string,\n268\t): string {\n269\t  return `## Retro Action Item ${item.number} — Epic ${epicNum}\n270\t\n271\t**Source project:** ${projectName}\n272\t**Classification:** ${item.classification}\n273\t**Original status:** ${item.status}\n274\t**Notes:** ${item.notes}\n275\t\n276\t${item.title}\n277\t\n278\t<!-- gap-id: ${item.gapId} -->`;\n279\t}\n280\t\n281\t/**\n282\t * GitHub issue creation phase.\n283\t */\n284\tfunction createGitHubIssues(\n285\t  issues: ImportedIssue[],\n286\t  epicNum: number,\n287\t  isJson: boolean,\n288\t): GitHubResult | undefined {\n289\t  // Read state to check for retro_issue_targets\n290\t  let targets: RetroIssueTarget[] | undefined;\n291\t  try {\n292\t    const state = readState();\n293\t    targets = state.retro_issue_targets;\n294\t  } catch (err: unknown) {\n295\t    if (err instanceof StateFileNotFoundError) {\n296\t      if (!isJson) {\n297\t        info('No state file found — skipping GitHub issues');\n298\t      }\n299\t      return undefined;\n300\t    }\n301\t    // Other state errors — skip GitHub phase gracefully\n302\t    if (!isJson) {\n303\t      info('Could not read state file — skipping GitHub issues');\n304\t    }\n305\t    return undefined;\n306\t  }\n307\t\n308\t  if (!targets || targets.length === 0) {\n309\t    if (!isJson) {\n310\t      info('No retro_issue_targets configured — skipping GitHub issues');\n311\t    }\n312\t    return undefined;\n313\t  }\n314\t\n315\t  // Check gh CLI availability\n316\t  if (!isGhAvailable()) {\n317\t    if (!isJson) {\n318\t      warn('gh CLI not available — skipping GitHub issue creation');\n319\t    }\n320\t    return undefined;\n321\t  }\n322\t\n323\t  // Resolve \"auto\" repos\n324\t  const resolvedAutoRepo = getRepoFromRemote();\n325\t\n326\t  const result: GitHubResult = { created: 0, skipped: 0, errors: 0 };\n327\t\n328\t  // Detect project name from git remote\n329\t  const projectName = resolvedAutoRepo ?? 'unknown';\n330\t\n331\t  for (const item of issues) {\n332\t    const target = resolveTargetRepo(item.classification, targets);\n333\t    if (!target) continue;\n334\t\n335\t    // Resolve actual repo name\n336\t    const repo = target.repo === 'auto' ? resolvedAutoRepo : target.repo;\n337\t    if (!repo) {\n338\t      if (!isJson) {\n339\t        warn(`Cannot resolve repo for ${item.number} — git remote not detected`);\n340\t      }\n341\t      result.errors++;\n342\t      continue;\n343\t    }\n344\t\n345\t    try {\n346\t      // Check for existing issue (dedup)\n347\t      const existing = findExistingGhIssue(repo, item.gapId);\n348\t      if (existing) {\n349\t        if (!isJson) {\n350\t          info(`GitHub issue exists: ${repo}#${existing.number}`);\n351\t        }\n352\t        result.skipped++;\n353\t        continue;\n354\t      }\n355\t\n356\t      // Ensure labels exist\n357\t      ensureLabels(repo, target.labels);\n358\t\n359\t      // Create the issue\n360\t      const body = buildGitHubIssueBody(item, epicNum, projectName);\n361\t      const created = ghIssueCreate(repo, item.title, body, target.labels);\n362\t      if (!isJson) {\n363\t        ok(`GitHub issue created: ${repo}#${created.number}`);\n364\t      }\n365\t      result.created++;\n366\t    } catch (err: unknown) {\n367\t      const message = err instanceof Error ? err.message : String(err);\n368\t      if (!isJson) {\n369\t        fail(`GitHub issue failed for ${item.number}: ${message}`);\n370\t      }\n371\t      result.errors++;\n372\t    }\n373\t  }\n374\t\n375\t  return result;\n376\t}\n377\t"}]},"parent_tool_use_id":"toolu_01RQfCFNpbMDVkdeQs35oAee","session_id":"3f15b50c-2c9b-40fa-9e63-9fad2199af43","uuid":"eafbff4a-31e7-4c0d-8416-bca305742415","timestamp":"2026-04-03T02:22:43.432Z"}
