{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GUqR9uGXT4g3WGV5AcFZg4","type":"tool_result","content":"     1→import { Command } from 'commander';\n     2→import { ok, fail, info, jsonOutput } from '../lib/output.js';\n     3→import { listIssues, updateIssue, closeIssue } from '../lib/beads.js';\n     4→import {\n     5→  syncAll,\n     6→  syncStoryFileToBeads,\n     7→  syncBeadsToStoryFile,\n     8→} from '../lib/sync/index.js';\n     9→import type { SyncDirection, SyncResult } from '../lib/sync/index.js';\n    10→\n    11→export interface SyncCommandResult {\n    12→  status: 'ok' | 'fail';\n    13→  synced: number;\n    14→  already_in_sync: number;\n    15→  errors: number;\n    16→  results: SyncResult[];\n    17→}\n    18→\n    19→const VALID_DIRECTIONS = new Set(['beads-to-files', 'files-to-beads', 'bidirectional']);\n    20→\n    21→export function registerSyncCommand(program: Command): void {\n    22→  program\n    23→    .command('sync')\n    24→    .description('Synchronize beads issue statuses with story files and sprint-status.yaml')\n    25→    .option('--direction <dir>', 'Sync direction: beads-to-files, files-to-beads, or bidirectional', 'bidirectional')\n    26→    .option('--story <key>', 'Sync only a single story by key')\n    27→    .action((opts, cmd) => {\n    28→      const globalOpts = cmd.optsWithGlobals() as { json?: boolean };\n    29→      const isJson = globalOpts.json ?? false;\n    30→      const direction = opts.direction as string;\n    31→      const storyKey = opts.story as string | undefined;\n    32→\n    33→      // Validate direction\n    34→      if (!VALID_DIRECTIONS.has(direction)) {\n    35→        fail(`Invalid direction: ${direction}. Must be one of: beads-to-files, files-to-beads, bidirectional`, { json: isJson });\n    36→        process.exitCode = 2;\n    37→        return;\n    38→      }\n    39→\n    40→      const beadsFns = {\n    41→        listIssues,\n    42→        updateIssue,\n    43→        closeIssue,\n    44→      };\n    45→\n    46→      let results: SyncResult[];\n    47→\n    48→      try {\n    49→        if (storyKey) {\n    50→          // Single story sync\n    51→          let result: SyncResult;\n    52→          if (direction === 'files-to-beads') {\n    53→            result = syncStoryFileToBeads(storyKey, beadsFns);\n    54→          } else {\n    55→            // For beads-to-files and bidirectional, find the beads issue by story key\n    56→            const issues = listIssues();\n    57→            const matchingIssue = issues.find(i => {\n    58→              const desc = i.description;\n    59→              if (!desc) return false;\n    60→              return desc.includes(storyKey);\n    61→            });\n    62→            if (!matchingIssue) {\n    63→              fail(`No beads issue found for story: ${storyKey}`, { json: isJson });\n    64→              process.exitCode = 1;\n    65→              return;\n    66→            }\n    67→            result = syncBeadsToStoryFile(matchingIssue.id, { listIssues: () => issues });\n    68→          }\n    69→          results = [result];\n    70→        } else {\n    71→          // Sync all\n    72→          results = syncAll(direction as SyncDirection, beadsFns);\n    73→        }\n    74→      } catch (err) {\n    75→        const message = err instanceof Error ? err.message : String(err);\n    76→        fail(`Sync failed: ${message}`, { json: isJson });\n    77→        process.exitCode = 1;\n    78→        return;\n    79→      }\n    80→\n    81→      const syncedCount = results.filter(r => r.synced).length;\n    82→      const alreadyInSync = results.filter(r => !r.synced && !r.error).length;\n    83→      const errorCount = results.filter(r => !!r.error).length;\n    84→\n    85→      if (isJson) {\n    86→        const commandResult: SyncCommandResult = {\n    87→          status: errorCount > 0 && syncedCount === 0 ? 'fail' : 'ok',\n    88→          synced: syncedCount,\n    89→          already_in_sync: alreadyInSync,\n    90→          errors: errorCount,\n    91→          results,\n    92→        };\n    93→        jsonOutput(commandResult as unknown as Record<string, unknown>);\n    94→      } else {\n    95→        // Print per-story results\n    96→        for (const r of results) {\n    97→          if (r.synced) {\n    98→            ok(`${r.storyKey}: ${r.previousStatus} -> ${r.newStatus}`);\n    99→          } else if (r.error) {\n   100→            fail(`${r.storyKey || r.beadsId}: ${r.error}`);\n   101→          } else {\n   102→            info(`${r.storyKey}: already in sync (${r.previousStatus})`);\n   103→          }\n   104→        }\n   105→\n   106→        // Print summary\n   107→        ok(`Sync: ${syncedCount} stories synced, ${alreadyInSync} already in sync, ${errorCount} errors`);\n   108→      }\n   109→\n   110→      process.exitCode = 0;\n   111→    });\n   112→}\n   113→"}]},"parent_tool_use_id":"toolu_01KNQnUKBFtzFzrosUg6K7qd","session_id":"7d2c764f-deb1-4354-ad31-e0a846d19ae3","uuid":"174a4c1a-54ac-4bb5-b8f3-e813f8be5bf1","timestamp":"2026-03-25T00:18:23.612Z"}
