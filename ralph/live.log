{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CcXH4omZ6dLVqZZkD37GWA","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';\n     2→import { mkdtempSync, rmSync, writeFileSync, mkdirSync, readFileSync } from 'node:fs';\n     3→import { tmpdir } from 'node:os';\n     4→import { join } from 'node:path';\n     5→import {\n     6→  detectCoverageTool,\n     7→  getTestCommand,\n     8→  runCoverage,\n     9→  checkOnlyCoverage,\n    10→  evaluateCoverage,\n    11→  updateCoverageState,\n    12→  formatCoverageOutput,\n    13→  parseTestCounts,\n    14→  parseCoverageReport,\n    15→  printCoverageOutput,\n    16→  checkPerFileCoverage,\n    17→} from '../coverage.js';\n    18→import type { CoverageResult, CoverageEvaluation } from '../coverage.js';\n    19→import { writeState, getDefaultState, readStateWithBody } from '../state.js';\n    20→\n    21→let testDir: string;\n    22→\n    23→beforeEach(() => {\n    24→  testDir = mkdtempSync(join(tmpdir(), 'ch-coverage-test-'));\n    25→});\n    26→\n    27→afterEach(() => {\n    28→  rmSync(testDir, { recursive: true, force: true });\n    29→});\n    30→\n    31→// ─── detectCoverageTool ──────────────────────────────────────────────────────\n    32→\n    33→describe('detectCoverageTool', () => {\n    34→  it('detects c8 from vitest config file', () => {\n    35→    writeFileSync(join(testDir, 'package.json'), JSON.stringify({ name: 'test' }));\n    36→    writeFileSync(join(testDir, 'vitest.config.ts'), 'export default {}');\n    37→\n    38→    const result = detectCoverageTool(testDir);\n    39→    expect(result.tool).toBe('c8');\n    40→    expect(result.reportFormat).toBe('vitest-json');\n    41→  });\n    42→\n    43→  it('detects c8 from @vitest/coverage-v8 in devDependencies', () => {\n    44→    writeFileSync(\n    45→      join(testDir, 'package.json'),\n    46→      JSON.stringify({\n    47→        name: 'test',\n    48→        devDependencies: { '@vitest/coverage-v8': '^1.0.0' },\n    49→      }),\n    50→    );\n    51→\n    52→    const result = detectCoverageTool(testDir);\n    53→    expect(result.tool).toBe('c8');\n    54→  });\n    55→\n    56→  it('detects c8 from @vitest/coverage-istanbul in devDependencies', () => {\n    57→    writeFileSync(\n    58→      join(testDir, 'package.json'),\n    59→      JSON.stringify({\n    60→        name: 'test',\n    61→        devDependencies: { '@vitest/coverage-istanbul': '^1.0.0' },\n    62→      }),\n    63→    );\n    64→\n    65→    const result = detectCoverageTool(testDir);\n    66→    expect(result.tool).toBe('c8');\n    67→  });\n    68→\n    69→  it('detects c8 from c8 in devDependencies', () => {\n    70→    writeFileSync(\n    71→      join(testDir, 'package.json'),\n    72→      JSON.stringify({\n    73→        name: 'test',\n    74→        devDependencies: { c8: '^7.0.0' },\n    75→      }),\n    76→    );\n    77→\n    78→    const result = detectCoverageTool(testDir);\n    79→    expect(result.tool).toBe('c8');\n    80→  });\n    81→\n    82→  it('detects jest coverage for jest projects', () => {\n    83→    writeFileSync(\n    84→      join(testDir, 'package.json'),\n    85→      JSON.stringify({\n    86→        name: 'test',\n    87→        devDependencies: { jest: '^29.0.0' },\n    88→      }),\n    89→    );\n    90→\n    91→    const result = detectCoverageTool(testDir);\n    92→    expect(result.tool).toBe('c8');\n    93→    expect(result.runCommand).toContain('jest');\n    94→    expect(result.runCommand).toContain('--coverage');\n    95→  });\n    96→\n    97→  it('detects coverage.py from requirements.txt', () => {\n    98→    writeFileSync(join(testDir, 'requirements.txt'), 'coverage==7.0\\npytest==8.0\\n');\n    99→\n   100→    const result = detectCoverageTool(testDir);\n   101→    expect(result.tool).toBe('coverage.py');\n   102→    expect(result.runCommand).toContain('coverage run');\n   103→    expect(result.reportFormat).toBe('coverage-py-json');\n   104→  });\n   105→\n   106→  it('detects coverage.py from pytest-cov in requirements.txt', () => {\n   107→    writeFileSync(join(testDir, 'requirements.txt'), 'pytest-cov==4.0\\n');\n   108→\n   109→    const result = detectCoverageTool(testDir);\n   110→    expect(result.tool).toBe('coverage.py');\n   111→  });\n   112→\n   113→  it('detects coverage.py from pyproject.toml', () => {\n   114→    writeFileSync(join(testDir, 'pyproject.toml'), '[tool.pytest]\\ncoverage = true\\n');\n   115→\n   116→    const result = detectCoverageTool(testDir);\n   117→    expect(result.tool).toBe('coverage.py');\n   118→  });\n   119→\n   120→  it('returns unknown when no indicators found', () => {\n   121→    writeFileSync(join(testDir, 'package.json'), JSON.stringify({ name: 'bare-project' }));\n   122→\n   123→    const result = detectCoverageTool(testDir);\n   124→    expect(result.tool).toBe('unknown');\n   125→    expect(result.runCommand).toBe('');\n   126→  });\n   127→\n   128→  it('returns unknown for unrecognized stack', () => {\n   129→    // No package.json, no requirements.txt — no stack detected\n   130→    const result = detectCoverageTool(testDir);\n   131→    expect(result.tool).toBe('unknown');\n   132→  });\n   133→\n   134→  it('prefers test:coverage script when available', () => {\n   135→    writeFileSync(\n   136→      join(testDir, 'package.json'),\n   137→      JSON.stringify({\n   138→        name: 'test',\n   139→        scripts: { 'test:coverage': 'vitest run --coverage' },\n   140→        devDependencies: { '@vitest/coverage-v8': '^1.0.0' },\n   141→      }),\n   142→    );\n   143→\n   144→    const result = detectCoverageTool(testDir);\n   145→    expect(result.runCommand).toBe('npm run test:coverage');\n   146→  });\n   147→\n   148→  it('reads state file hint but re-detects when project config disagrees', () => {\n   149→    // Create state with c8 hint\n   150→    const state = getDefaultState('nodejs');\n   151→    state.coverage.tool = 'c8';\n   152→    writeState(state, testDir);\n   153→\n   154→    // But project has no vitest/c8\n   155→    writeFileSync(join(testDir, 'package.json'), JSON.stringify({ name: 'bare' }));\n   156→\n   157→    const result = detectCoverageTool(testDir);\n   158→    expect(result.tool).toBe('unknown'); // Re-detected as unknown\n   159→  });\n   160→\n   161→  it('handles malformed package.json gracefully', () => {\n   162→    writeFileSync(join(testDir, 'package.json'), '{invalid json');\n   163→    const result = detectCoverageTool(testDir);\n   164→    expect(result.tool).toBe('unknown');\n   165→  });\n   166→});\n   167→\n   168→// ─── getTestCommand ──────────────────────────────────────────────────────────\n   169→\n   170→describe('getTestCommand', () => {\n   171→  it('returns the run command from detectCoverageTool', () => {\n   172→    writeFileSync(\n   173→      join(testDir, 'package.json'),\n   174→      JSON.stringify({\n   175→        name: 'test',\n   176→        devDependencies: { '@vitest/coverage-v8': '^1.0.0' },\n   177→      }),\n   178→    );\n   179→\n   180→    const cmd = getTestCommand(testDir);\n   181→    expect(cmd).toContain('vitest');\n   182→  });\n   183→\n   184→  it('returns empty string when no tool detected', () => {\n   185→    const cmd = getTestCommand(testDir);\n   186→    expect(cmd).toBe('');\n   187→  });\n   188→});\n   189→\n   190→// ─── parseTestCounts ─────────────────────────────────────────────────────────\n   191→\n   192→describe('parseTestCounts', () => {\n   193→  it('parses Vitest output — passed only', () => {\n   194→    const output = 'Tests  42 passed';\n   195→    const { passCount, failCount } = parseTestCounts(output);\n   196→    expect(passCount).toBe(42);\n   197→    expect(failCount).toBe(0);\n   198→  });\n   199→\n   200→  it('parses Vitest output — passed and failed', () => {\n   201→    const output = 'Tests  10 passed | 3 failed';\n   202→    const { passCount, failCount } = parseTestCounts(output);\n   203→    expect(passCount).toBe(10);\n   204→    expect(failCount).toBe(3);\n   205→  });\n   206→\n   207→  it('parses Jest output — passed only', () => {\n   208→    const output = 'Tests:  12 passed, 12 total';\n   209→    const { passCount, failCount } = parseTestCounts(output);\n   210→    expect(passCount).toBe(12);\n   211→    expect(failCount).toBe(0);\n   212→  });\n   213→\n   214→  it('parses Jest output — passed and failed', () => {\n   215→    const output = 'Tests:  3 failed, 12 passed, 15 total';\n   216→    const { passCount, failCount } = parseTestCounts(output);\n   217→    expect(passCount).toBe(12);\n   218→    expect(failCount).toBe(3);\n   219→  });\n   220→\n   221→  it('parses pytest output — passed only', () => {\n   222→    const output = '12 passed in 0.5s';\n   223→    const { passCount, failCount } = parseTestCounts(output);\n   224→    expect(passCount).toBe(12);\n   225→    expect(failCount).toBe(0);\n   226→  });\n   227→\n   228→  it('parses pytest output — passed and failed', () => {\n   229→    const output = '10 passed, 2 failed';\n   230→    const { passCount, failCount } = parseTestCounts(output);\n   231→    expect(passCount).toBe(10);\n   232→    expect(failCount).toBe(2);\n   233→  });\n   234→\n   235→  it('returns zeros for unrecognized output', () => {\n   236→    const output = 'no test results here';\n   237→    const { passCount, failCount } = parseTestCounts(output);\n   238→    expect(passCount).toBe(0);\n   239→    expect(failCount).toBe(0);\n   240→  });\n   241→});\n   242→\n   243→// ─── parseCoverageReport ─────────────────────────────────────────────────────\n   244→\n   245→describe('parseCoverageReport', () => {\n   246→  it('parses vitest-json coverage report', () => {\n   247→    const coverageDir = join(testDir, 'coverage');\n   248→    mkdirSync(coverageDir, { recursive: true });\n   249→    writeFileSync(\n   250→      join(coverageDir, 'coverage-summary.json'),\n   251→      JSON.stringify({\n   252→        total: {\n   253→          statements: { total: 100, covered: 95, skipped: 0, pct: 95.83 },\n   254→          lines: { total: 100, covered: 95, skipped: 0, pct: 95 },\n   255→          branches: { total: 40, covered: 38, skipped: 0, pct: 95 },\n   256→          functions: { total: 30, covered: 28, skipped: 0, pct: 93.33 },\n   257→        },\n   258→      }),\n   259→    );\n   260→\n   261→    const pct = parseCoverageReport(testDir, 'vitest-json');\n   262→    expect(pct).toBe(95.83);\n   263→  });\n   264→\n   265→  it('parses coverage-py-json coverage report', () => {\n   266→    writeFileSync(\n   267→      join(testDir, 'coverage.json'),\n   268→      JSON.stringify({\n   269→        totals: {\n   270→          covered_lines: 95,\n   271→          num_statements: 100,\n   272→          percent_covered: 95.0,\n   273→        },\n   274→      }),\n   275→    );\n   276→\n   277→    const pct = parseCoverageReport(testDir, 'coverage-py-json');\n   278→    expect(pct).toBe(95.0);\n   279→  });\n   280→\n   281→  it('returns 0 when vitest coverage report missing', () => {\n   282→    const pct = parseCoverageReport(testDir, 'vitest-json');\n   283→    expect(pct).toBe(0);\n   284→  });\n   285→\n   286→  it('returns 0 when python coverage report missing', () => {\n   287→    const pct = parseCoverageReport(testDir, 'coverage-py-json');\n   288→    expect(pct).toBe(0);\n   289→  });\n   290→\n   291→  it('returns 0 for unknown format', () => {\n   292→    const pct = parseCoverageReport(testDir, 'unknown-format');\n   293→    expect(pct).toBe(0);\n   294→  });\n   295→\n   296→  it('returns 0 when coverage report is malformed JSON', () => {\n   297→    const coverageDir = join(testDir, 'coverage');\n   298→    mkdirSync(coverageDir, { recursive: true });\n   299→    writeFileSync(join(coverageDir, 'coverage-summary.json'), '{invalid');\n   300→    const pct = parseCoverageReport(testDir, 'vitest-json');\n   301→    expect(pct).toBe(0);\n   302→  });\n   303→\n   304→  it('returns 0 when python coverage report is malformed', () => {\n   305→    writeFileSync(join(testDir, 'coverage.json'), '{invalid');\n   306→    const pct = parseCoverageReport(testDir, 'coverage-py-json');\n   307→    expect(pct).toBe(0);\n   308→  });\n   309→});\n   310→\n   311→// ─── runCoverage ─────────────────────────────────────────────────────────────\n   312→\n   313→describe('runCoverage', () => {\n   314→  it('returns failure result when no coverage tool detected', () => {\n   315→    const result = runCoverage(testDir);\n   316→    expect(result.success).toBe(false);\n   317→    expect(result.testsPassed).toBe(false);\n   318→    expect(result.rawOutput).toContain('No coverage tool detected');\n   319→  });\n   320→});\n   321→\n   322→// ─── checkOnlyCoverage ───────────────────────────────────────────────────────\n   323→\n   324→describe('checkOnlyCoverage', () => {\n   325→  it('reads existing coverage report without running tests', () => {\n   326→    // Set up a Node.js project with coverage data\n   327→    writeFileSync(\n   328→      join(testDir, 'package.json'),\n   329→      JSON.stringify({\n   330→        name: 'test',\n   331→        devDependencies: { '@vitest/coverage-v8': '^1.0.0' },\n   332→      }),\n   333→    );\n   334→    const coverageDir = join(testDir, 'coverage');\n   335→    mkdirSync(coverageDir, { recursive: true });\n   336→    writeFileSync(\n   337→      join(coverageDir, 'coverage-summary.json'),\n   338→      JSON.stringify({\n   339→        total: {\n   340→          statements: { pct: 88.5 },\n   341→        },\n   342→      }),\n   343→    );\n   344→\n   345→    const result = checkOnlyCoverage(testDir);\n   346→    expect(result.success).toBe(true);\n   347→    expect(result.testsPassed).toBe(true);\n   348→    expect(result.coveragePercent).toBe(88.5);\n   349→    expect(result.rawOutput).toContain('Check-only');\n   350→  });\n   351→\n   352→  it('returns failure when no tool detected', () => {\n   353→    const result = checkOnlyCoverage(testDir);\n   354→    expect(result.success).toBe(false);\n   355→  });\n   356→\n   357→  it('preserves tests_passed=false from state file', () => {\n   358→    // Set up project with coverage data\n   359→    writeFileSync(\n   360→      join(testDir, 'package.json'),\n   361→      JSON.stringify({\n   362→        name: 'test',\n   363→        devDependencies: { '@vitest/coverage-v8': '^1.0.0' },\n   364→      }),\n   365→    );\n   366→    const coverageDir = join(testDir, 'coverage');\n   367→    mkdirSync(coverageDir, { recursive: true });\n   368→    writeFileSync(\n   369→      join(coverageDir, 'coverage-summary.json'),\n   370→      JSON.stringify({ total: { statements: { pct: 90 } } }),\n   371→    );\n   372→\n   373→    // Set up state with tests_passed=false (from a previous failed run)\n   374→    const state = getDefaultState('nodejs');\n   375→    state.session_flags.tests_passed = false;\n   376→    writeState(state, testDir);\n   377→\n   378→    const result = checkOnlyCoverage(testDir);\n   379→    expect(result.success).toBe(true);\n   380→    expect(result.testsPassed).toBe(false); // Should preserve state, not assume true\n   381→    expect(result.coveragePercent).toBe(90);\n   382→  });\n   383→\n   384→  it('defaults testsPassed to true when no state file exists', () => {\n   385→    writeFileSync(\n   386→      join(testDir, 'package.json'),\n   387→      JSON.stringify({\n   388→        name: 'test',\n   389→        devDependencies: { '@vitest/coverage-v8': '^1.0.0' },\n   390→      }),\n   391→    );\n   392→    const coverageDir = join(testDir, 'coverage');\n   393→    mkdirSync(coverageDir, { recursive: true });\n   394→    writeFileSync(\n   395→      join(coverageDir, 'coverage-summary.json'),\n   396→      JSON.stringify({ total: { statements: { pct: 100 } } }),\n   397→    );\n   398→\n   399→    const result = checkOnlyCoverage(testDir);\n   400→    expect(result.testsPassed).toBe(true);\n   401→  });\n   402→});\n   403→\n   404→// ─── evaluateCoverage ────────────────────────────────────────────────────────\n   405→\n   406→describe('evaluateCoverage', () => {\n   407→  it('returns met=true when coverage meets target', () => {\n   408→    const state = getDefaultState('nodejs');\n   409→    state.coverage.target = 100;\n   410→    state.coverage.baseline = 95;\n   411→    writeState(state, testDir);\n   412→\n   413→    const result: CoverageResult = {\n   414→      success: true,\n   415→      testsPassed: true,\n   416→      passCount: 10,\n   417→      failCount: 0,\n   418→      coveragePercent: 100,\n   419→      rawOutput: '',\n   420→    };\n   421→\n   422→    const evaluation = evaluateCoverage(result, testDir);\n   423→    expect(evaluation.met).toBe(true);\n   424→    expect(evaluation.target).toBe(100);\n   425→    expect(evaluation.actual).toBe(100);\n   426→    expect(evaluation.delta).toBe(5);\n   427→    expect(evaluation.baseline).toBe(95);\n   428→  });\n   429→\n   430→  it('returns met=false when coverage below target', () => {\n   431→    const state = getDefaultState('nodejs');\n   432→    state.coverage.target = 100;\n   433→    state.coverage.baseline = 90;\n   434→    writeState(state, testDir);\n   435→\n   436→    const result: CoverageResult = {\n   437→      success: true,\n   438→      testsPassed: true,\n   439→      passCount: 10,\n   440→      failCount: 0,\n   441→      coveragePercent: 87,\n   442→      rawOutput: '',\n   443→    };\n   444→\n   445→    const evaluation = evaluateCoverage(result, testDir);\n   446→    expect(evaluation.met).toBe(false);\n   447→    expect(evaluation.actual).toBe(87);\n   448→    expect(evaluation.delta).toBe(-3);\n   449→  });\n   450→\n   451→  it('sets baseline to current on first run (null baseline)', () => {\n   452→    const state = getDefaultState('nodejs');\n   453→    state.coverage.baseline = null;\n   454→    writeState(state, testDir);\n   455→\n   456→    const result: CoverageResult = {\n   457→      success: true,\n   458→      testsPassed: true,\n   459→      passCount: 10,\n   460→      failCount: 0,\n   461→      coveragePercent: 75,\n   462→      rawOutput: '',\n   463→    };\n   464→\n   465→    const evaluation = evaluateCoverage(result, testDir);\n   466→    expect(evaluation.baseline).toBe(75);\n   467→    expect(evaluation.delta).toBeNull();\n   468→  });\n   469→\n   470→  it('calculates positive delta correctly', () => {\n   471→    const state = getDefaultState('nodejs');\n   472→    state.coverage.baseline = 90;\n   473→    writeState(state, testDir);\n   474→\n   475→    const result: CoverageResult = {\n   476→      success: true,\n   477→      testsPassed: true,\n   478→      passCount: 10,\n   479→      failCount: 0,\n   480→      coveragePercent: 100,\n   481→      rawOutput: '',\n   482→    };\n   483→\n   484→    const evaluation = evaluateCoverage(result, testDir);\n   485→    expect(evaluation.delta).toBe(10);\n   486→  });\n   487→\n   488→  it('uses default target of 90 when no state file', () => {\n   489→    const result: CoverageResult = {\n   490→      success: true,\n   491→      testsPassed: true,\n   492→      passCount: 5,\n   493→      failCount: 0,\n   494→      coveragePercent: 85,\n   495→      rawOutput: '',\n   496→    };\n   497→\n   498→    const evaluation = evaluateCoverage(result, testDir);\n   499→    expect(evaluation.target).toBe(90);\n   500→    expect(evaluation.met).toBe(false);\n   501→  });\n   502→});\n   503→\n   504→// ─── updateCoverageState ─────────────────────────────────────────────────────\n   505→\n   506→describe('updateCoverageState', () => {\n   507→  it('sets tests_passed and coverage_met flags', () => {\n   508→    const state = getDefaultState('nodejs');\n   509→    writeState(state, testDir);\n   510→\n   511→    const result: CoverageResult = {\n   512→      success: true,\n   513→      testsPassed: true,\n   514→      passCount: 10,\n   515→      failCount: 0,\n   516→      coveragePercent: 100,\n   517→      rawOutput: '',\n   518→    };\n   519→    const evaluation: CoverageEvaluation = {\n   520→      met: true,\n   521→      target: 100,\n   522→      actual: 100,\n   523→      delta: 5,\n   524→      baseline: 95,\n   525→    };\n   526→\n   527→    updateCoverageState(result, evaluation, testDir);\n   528→\n   529→    const { state: updated } = readStateWithBody(testDir);\n   530→    expect(updated.session_flags.tests_passed).toBe(true);\n   531→    expect(updated.session_flags.coverage_met).toBe(true);\n   532→    expect(updated.coverage.current).toBe(100);\n   533→  });\n   534→\n   535→  it('sets flags to false when tests fail', () => {\n   536→    const state = getDefaultState('nodejs');\n   537→    writeState(state, testDir);\n   538→\n   539→    const result: CoverageResult = {\n   540→      success: true,\n   541→      testsPassed: false,\n   542→      passCount: 5,\n   543→      failCount: 3,\n   544→      coveragePercent: 80,\n   545→      rawOutput: '',\n   546→    };\n   547→    const evaluation: CoverageEvaluation = {\n   548→      met: false,\n   549→      target: 100,\n   550→      actual: 80,\n   551→      delta: null,\n   552→      baseline: 80,\n   553→    };\n   554→\n   555→    updateCoverageState(result, evaluation, testDir);\n   556→\n   557→    const { state: updated } = readStateWithBody(testDir);\n   558→    expect(updated.session_flags.tests_passed).toBe(false);\n   559→    expect(updated.session_flags.coverage_met).toBe(false);\n   560→    expect(updated.coverage.current).toBe(80);\n   561→  });\n   562→\n   563→  it('sets baseline on first run when it was null', () => {\n   564→    const state = getDefaultState('nodejs');\n   565→    state.coverage.baseline = null;\n   566→    writeState(state, testDir);\n   567→\n   568→    const result: CoverageResult = {\n   569→      success: true,\n   570→      testsPassed: true,\n   571→      passCount: 10,\n   572→      failCount: 0,\n   573→      coveragePercent: 75,\n   574→      rawOutput: '',\n   575→    };\n   576→    const evaluation: CoverageEvaluation = {\n   577→      met: false,\n   578→      target: 100,\n   579→      actual: 75,\n   580→      delta: null,\n   581→      baseline: 75,\n   582→    };\n   583→\n   584→    updateCoverageState(result, evaluation, testDir);\n   585→\n   586→    const { state: updated } = readStateWithBody(testDir);\n   587→    expect(updated.coverage.baseline).toBe(75);\n   588→  });\n   589→\n   590→  it('does not overwrite existing baseline', () => {\n   591→    const state = getDefaultState('nodejs');\n   592→    state.coverage.baseline = 50;\n   593→    writeState(state, testDir);\n   594→\n   595→    const result: CoverageResult = {\n   596→      success: true,\n   597→      testsPassed: true,\n   598→      passCount: 10,\n   599→      failCount: 0,\n   600→      coveragePercent: 90,\n   601→      rawOutput: '',\n   602→    };\n   603→    const evaluation: CoverageEvaluation = {\n   604→      met: false,\n   605→      target: 100,\n   606→      actual: 90,\n   607→      delta: 40,\n   608→      baseline: 50,\n   609→    };\n   610→\n   611→    updateCoverageState(result, evaluation, testDir);\n   612→\n   613→    const { state: updated } = readStateWithBody(testDir);\n   614→    expect(updated.coverage.baseline).toBe(50);\n   615→  });\n   616→});\n   617→\n   618→// ─── formatCoverageOutput ────────────────────────────────────────────────────\n   619→\n   620→describe('formatCoverageOutput', () => {\n   621→  it('formats passing coverage', () => {\n   622→    const evaluation: CoverageEvaluation = {\n   623→      met: true,\n   624→      target: 100,\n   625→      actual: 100,\n   626→      delta: null,\n   627→      baseline: 100,\n   628→    };\n   629→\n   630→    const lines = formatCoverageOutput(evaluation);\n   631→    expect(lines).toEqual(['[OK] Coverage: 100%']);\n   632→  });\n   633→\n   634→  it('formats faili