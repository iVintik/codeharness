{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018CeVkeJ8tSgrdVBAYCSTKn","type":"tool_result","content":"1\t/**\n2\t * Pre-flight capability conflict detection and routing hints.\n3\t *\n4\t * Pure query functions — no side effects, no thrown errors.\n5\t * Called during workflow startup to warn about misconfigurations\n6\t * and suggest cheaper driver alternatives.\n7\t *\n8\t * @see architecture-multi-framework.md — FR36, FR37, FR38\n9\t */\n10\t\n11\timport type { ResolvedWorkflow } from '../workflow-parser.js';\n12\timport type { CapabilityWarning, DriverCapabilities } from './types.js';\n13\timport { getDriver, suggestCheaperDriver } from './drivers/factory.js';\n14\t\n15\t/**\n16\t * Check all tasks in a workflow for capability conflicts and cost routing hints.\n17\t *\n18\t * Returns an array of CapabilityWarning objects. Each warning is advisory —\n19\t * the caller decides whether to log, display, or ignore them.\n20\t *\n21\t * Conflict detection:\n22\t * - task.plugins.length > 0 && !driver.capabilities.supportsPlugins → warning\n23\t *\n24\t * Cost routing:\n25\t * - If driver.costTier > 2 * cheapestCapable.costTier → advisory\n26\t *\n27\t * @param workflow - The resolved workflow to check.\n28\t * @returns Array of capability warnings (empty if no issues found).\n29\t */\n30\texport function checkCapabilityConflicts(workflow: ResolvedWorkflow): CapabilityWarning[] {\n31\t  const warnings: CapabilityWarning[] = [];\n32\t\n33\t  for (const [taskName, task] of Object.entries(workflow.tasks)) {\n34\t    const driverName = task.driver ?? 'claude-code';\n35\t\n36\t    let driver;\n37\t    try {\n38\t      driver = getDriver(driverName);\n39\t    } catch { // IGNORE: driver not found — skip (health check catches this separately)\n40\t      continue;\n41\t    }\n42\t\n43\t    // Check: plugins required but driver doesn't support them\n44\t    const hasPlugins = task.plugins && task.plugins.length > 0;\n45\t    if (hasPlugins && !driver.capabilities.supportsPlugins) {\n46\t      warnings.push({\n47\t        taskName,\n48\t        driverName,\n49\t        capability: 'supportsPlugins',\n50\t        message: `Task \"${taskName}\" requires plugins but driver \"${driverName}\" does not support plugins (supportsPlugins: false)`,\n51\t      });\n52\t    }\n53\t\n54\t    // Determine required capabilities from task configuration\n55\t    const requiredCaps: Partial<DriverCapabilities> = {\n56\t      ...(hasPlugins ? { supportsPlugins: true } : {}),\n57\t    };\n58\t\n59\t    // Cost routing hint\n60\t    const cheaper = suggestCheaperDriver(driverName, requiredCaps);\n61\t    if (cheaper) {\n62\t      const cheaperDriver = getDriver(cheaper);\n63\t      // Only emit advisory if current driver costs >2x the cheapest capable\n64\t      if (driver.capabilities.costTier > 2 * cheaperDriver.capabilities.costTier) {\n65\t        warnings.push({\n66\t          taskName,\n67\t          driverName,\n68\t          capability: 'costTier',\n69\t          message: `Advisory: task \"${taskName}\" uses ${driverName} — ${cheaper} could handle this task at lower cost`,\n70\t        });\n71\t      }\n72\t    }\n73\t  }\n74\t\n75\t  return warnings;\n76\t}\n77\t"}]},"parent_tool_use_id":"toolu_01WL7MCsNF3La2JHGCjnTeXK","session_id":"cf16e575-8267-4c58-a992-20b07458710f","uuid":"b5693dd2-a947-4a19-b3ea-7efe6c1e268d","timestamp":"2026-04-03T13:32:49.400Z"}
