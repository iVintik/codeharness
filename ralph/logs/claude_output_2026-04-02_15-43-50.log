{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MQx4rYQst3rymL2sDtv4if","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach, afterEach } from 'vitest';\n2\timport { mkdtempSync, rmSync, writeFileSync, mkdirSync } from 'node:fs';\n3\timport { tmpdir } from 'node:os';\n4\timport { join } from 'node:path';\n5\timport {\n6\t  parseWorkflow,\n7\t  WorkflowParseError,\n8\t  type ResolvedWorkflow,\n9\t  type ResolvedTask,\n10\t  type LoopBlock,\n11\t  type FlowStep,\n12\t} from '../workflow-parser.js';\n13\t\n14\tlet testDir: string;\n15\t\n16\tbeforeEach(() => {\n17\t  testDir = mkdtempSync(join(tmpdir(), 'ch-wfparser-test-'));\n18\t});\n19\t\n20\tafterEach(() => {\n21\t  rmSync(testDir, { recursive: true, force: true });\n22\t});\n23\t\n24\tfunction writeYaml(filename: string, content: string): string {\n25\t  const filePath = join(testDir, filename);\n26\t  writeFileSync(filePath, content, 'utf-8');\n27\t  return filePath;\n28\t}\n29\t\n30\t// --- Helpers: YAML content ---\n31\t\n32\tconst minimalYaml = `\n33\ttasks:\n34\t  implement:\n35\t    agent: dev\n36\tflow:\n37\t  - implement\n38\t`;\n39\t\n40\tconst fullYaml = `\n41\ttasks:\n42\t  implement:\n43\t    agent: dev\n44\t    scope: per-story\n45\t    session: fresh\n46\t    source_access: true\n47\t    prompt_template: \"Implement story {{story_key}}\"\n48\t    input_contract:\n49\t      type: object\n50\t    output_contract:\n51\t      type: object\n52\t    max_budget_usd: 5.0\n53\t  verify:\n54\t    agent: evaluator\n55\t    scope: per-run\n56\t    session: continue\n57\t    source_access: false\n58\tflow:\n59\t  - implement\n60\t  - verify\n61\t`;\n62\t\n63\tconst loopYaml = `\n64\ttasks:\n65\t  implement:\n66\t    agent: dev\n67\t  verify:\n68\t    agent: evaluator\n69\t  retry:\n70\t    agent: dev\n71\tflow:\n72\t  - implement\n73\t  - verify\n74\t  - loop:\n75\t      - retry\n76\t      - verify\n77\t`;\n78\t\n79\tconst emptyYaml = `\n80\ttasks: {}\n81\tflow: []\n82\t`;\n83\t\n84\t// --- Tests ---\n85\t\n86\tdescribe('parseWorkflow', () => {\n87\t  describe('valid workflows (AC #1)', () => {\n88\t    it('parses a minimal valid workflow and returns ResolvedWorkflow', () => {\n89\t      const filePath = writeYaml('minimal.yaml', minimalYaml);\n90\t      const result = parseWorkflow(filePath);\n91\t\n92\t      expect(result.tasks).toBeDefined();\n93\t      expect(result.flow).toBeDefined();\n94\t      expect(result.tasks.implement).toBeDefined();\n95\t      expect(result.tasks.implement.agent).toBe('dev');\n96\t      expect(result.flow).toEqual(['implement']);\n97\t    });\n98\t\n99\t    it('parses a full workflow with all optional fields (AC #1)', () => {\n100\t      const filePath = writeYaml('full.yaml', fullYaml);\n101\t      const result = parseWorkflow(filePath);\n102\t\n103\t      expect(result.tasks.implement.agent).toBe('dev');\n104\t      expect(result.tasks.implement.scope).toBe('per-story');\n105\t      expect(result.tasks.implement.session).toBe('fresh');\n106\t      expect(result.tasks.implement.source_access).toBe(true);\n107\t      expect(result.tasks.implement.prompt_template).toBe('Implement story {{story_key}}');\n108\t      expect(result.tasks.implement.input_contract).toEqual({ type: 'object' });\n109\t      expect(result.tasks.implement.output_contract).toEqual({ type: 'object' });\n110\t      expect(result.tasks.implement.max_budget_usd).toBe(5.0);\n111\t\n112\t      expect(result.tasks.verify.agent).toBe('evaluator');\n113\t      expect(result.tasks.verify.scope).toBe('per-run');\n114\t      expect(result.tasks.verify.session).toBe('continue');\n115\t      expect(result.tasks.verify.source_access).toBe(false);\n116\t    });\n117\t\n118\t    it('applies defaults when optional fields are omitted (AC #1)', () => {\n119\t      const filePath = writeYaml('defaults.yaml', minimalYaml);\n120\t      const result = parseWorkflow(filePath);\n121\t      const task = result.tasks.implement;\n122\t\n123\t      expect(task.scope).toBe('per-story');\n124\t      expect(task.session).toBe('fresh');\n125\t      expect(task.source_access).toBe(true);\n126\t      expect(task.prompt_template).toBeUndefined();\n127\t      expect(task.input_contract).toBeUndefined();\n128\t      expect(task.output_contract).toBeUndefined();\n129\t      expect(task.max_budget_usd).toBeUndefined();\n130\t    });\n131\t\n132\t    it('parses empty tasks and flow as valid degenerate case', () => {\n133\t      const filePath = writeYaml('empty.yaml', emptyYaml);\n134\t      const result = parseWorkflow(filePath);\n135\t\n136\t      expect(result.tasks).toEqual({});\n137\t      expect(result.flow).toEqual([]);\n138\t    });\n139\t  });\n140\t\n141\t  describe('invalid YAML syntax (AC #2)', () => {\n142\t    it('throws WorkflowParseError for bad YAML', () => {\n143\t      const filePath = writeYaml('bad.yaml', '{{{{not yaml at all');\n144\t\n145\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n146\t      try {\n147\t        parseWorkflow(filePath);\n148\t      } catch (err) {\n149\t        expect(err).toBeInstanceOf(WorkflowParseError);\n150\t        const pe = err as WorkflowParseError;\n151\t        expect(pe.message).toContain('Invalid YAML syntax');\n152\t        expect(pe.errors.length).toBeGreaterThan(0);\n153\t      }\n154\t    });\n155\t\n156\t    it('throws WorkflowParseError for unclosed quotes in YAML', () => {\n157\t      const badYaml = `\n158\ttasks:\n159\t  implement:\n160\t    agent: \"dev\n161\tflow:\n162\t  - implement\n163\t`;\n164\t      const filePath = writeYaml('unclosed.yaml', badYaml);\n165\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n166\t    });\n167\t  });\n168\t\n169\t  describe('schema validation failures (AC #3)', () => {\n170\t    it('throws WorkflowParseError when tasks is missing', () => {\n171\t      const yaml = 'flow:\\n  - implement\\n';\n172\t      const filePath = writeYaml('no-tasks.yaml', yaml);\n173\t\n174\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n175\t      try {\n176\t        parseWorkflow(filePath);\n177\t      } catch (err) {\n178\t        const pe = err as WorkflowParseError;\n179\t        expect(pe.message).toContain('Schema validation failed');\n180\t        expect(pe.errors.length).toBeGreaterThan(0);\n181\t        expect(pe.errors.some((e) => e.message.includes('tasks'))).toBe(true);\n182\t      }\n183\t    });\n184\t\n185\t    it('throws WorkflowParseError for empty file (null YAML)', () => {\n186\t      const filePath = writeYaml('empty-file.yaml', '');\n187\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n188\t      try {\n189\t        parseWorkflow(filePath);\n190\t      } catch (err) {\n191\t        const pe = err as WorkflowParseError;\n192\t        expect(pe.message).toContain('Schema validation failed');\n193\t      }\n194\t    });\n195\t\n196\t    it('throws WorkflowParseError for scalar YAML content', () => {\n197\t      const filePath = writeYaml('scalar.yaml', '42');\n198\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n199\t      try {\n200\t        parseWorkflow(filePath);\n201\t      } catch (err) {\n202\t        const pe = err as WorkflowParseError;\n203\t        expect(pe.message).toContain('Schema validation failed');\n204\t      }\n205\t    });\n206\t\n207\t    it('throws WorkflowParseError for invalid scope enum value', () => {\n208\t      const yaml = `\n209\ttasks:\n210\t  implement:\n211\t    agent: dev\n212\t    scope: invalid-scope\n213\tflow:\n214\t  - implement\n215\t`;\n216\t      const filePath = writeYaml('bad-scope.yaml', yaml);\n217\t\n218\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n219\t      try {\n220\t        parseWorkflow(filePath);\n221\t      } catch (err) {\n222\t        const pe = err as WorkflowParseError;\n223\t        expect(pe.message).toContain('Schema validation failed');\n224\t        expect(pe.errors.some((e) => e.path.includes('scope'))).toBe(true);\n225\t      }\n226\t    });\n227\t  });\n228\t\n229\t  describe('dangling task references (AC #4)', () => {\n230\t    it('throws WorkflowParseError when flow references non-existent task', () => {\n231\t      const yaml = `\n232\ttasks:\n233\t  implement:\n234\t    agent: dev\n235\tflow:\n236\t  - implement\n237\t  - nonexistent\n238\t`;\n239\t      const filePath = writeYaml('dangling.yaml', yaml);\n240\t\n241\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n242\t      try {\n243\t        parseWorkflow(filePath);\n244\t      } catch (err) {\n245\t        const pe = err as WorkflowParseError;\n246\t        expect(pe.message).toContain('Dangling task references');\n247\t        expect(pe.errors.some((e) => e.message.includes('nonexistent'))).toBe(true);\n248\t      }\n249\t    });\n250\t\n251\t    it('throws WorkflowParseError when loop references non-existent task', () => {\n252\t      const yaml = `\n253\ttasks:\n254\t  implement:\n255\t    agent: dev\n256\tflow:\n257\t  - implement\n258\t  - loop:\n259\t      - ghost_task\n260\t`;\n261\t      const filePath = writeYaml('dangling-loop.yaml', yaml);\n262\t\n263\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n264\t      try {\n265\t        parseWorkflow(filePath);\n266\t      } catch (err) {\n267\t        const pe = err as WorkflowParseError;\n268\t        expect(pe.message).toContain('Dangling task references');\n269\t        expect(pe.errors.some((e) => e.message.includes('ghost_task'))).toBe(true);\n270\t        expect(pe.errors.some((e) => e.path.includes('loop'))).toBe(true);\n271\t      }\n272\t    });\n273\t  });\n274\t\n275\t  describe('loop blocks (AC #5)', () => {\n276\t    it('resolves loop block with valid task references', () => {\n277\t      const filePath = writeYaml('loop.yaml', loopYaml);\n278\t      const result = parseWorkflow(filePath);\n279\t\n280\t      expect(result.flow).toHaveLength(3);\n281\t      expect(result.flow[0]).toBe('implement');\n282\t      expect(result.flow[1]).toBe('verify');\n283\t\n284\t      const loopStep = result.flow[2] as LoopBlock;\n285\t      expect(loopStep).toHaveProperty('loop');\n286\t      expect(loopStep.loop).toEqual(['retry', 'verify']);\n287\t    });\n288\t  });\n289\t\n290\t  describe('performance (AC #6)', () => {\n291\t    it('parses a typical workflow in under 500ms', () => {\n292\t      const filePath = writeYaml('perf.yaml', fullYaml);\n293\t\n294\t      const start = performance.now();\n295\t      parseWorkflow(filePath);\n296\t      const elapsed = performance.now() - start;\n297\t\n298\t      expect(elapsed).toBeLessThan(500);\n299\t    });\n300\t  });\n301\t\n302\t  describe('file not found (AC #7)', () => {\n303\t    it('throws WorkflowParseError for non-existent file', () => {\n304\t      const fakePath = join(testDir, 'does-not-exist.yaml');\n305\t\n306\t      expect(() => parseWorkflow(fakePath)).toThrow(WorkflowParseError);\n307\t      try {\n308\t        parseWorkflow(fakePath);\n309\t      } catch (err) {\n310\t        const pe = err as WorkflowParseError;\n311\t        expect(pe.message).toContain('File not found');\n312\t        expect(pe.errors.length).toBeGreaterThan(0);\n313\t      }\n314\t    });\n315\t\n316\t    it('throws WorkflowParseError when path is a directory', () => {\n317\t      const dirPath = join(testDir, 'subdir');\n318\t      mkdirSync(dirPath);\n319\t\n320\t      expect(() => parseWorkflow(dirPath)).toThrow(WorkflowParseError);\n321\t      try {\n322\t        parseWorkflow(dirPath);\n323\t      } catch (err) {\n324\t        const pe = err as WorkflowParseError;\n325\t        expect(pe.message).toContain('Path is a directory');\n326\t      }\n327\t    });\n328\t  });\n329\t\n330\t  describe('typed interfaces (AC #8)', () => {\n331\t    it('ResolvedWorkflow has correct structure', () => {\n332\t      const filePath = writeYaml('typed.yaml', fullYaml);\n333\t      const result: ResolvedWorkflow = parseWorkflow(filePath);\n334\t\n335\t      // tasks is Record<string, ResolvedTask>\n336\t      const taskKeys = Object.keys(result.tasks);\n337\t      expect(taskKeys).toContain('implement');\n338\t      expect(taskKeys).toContain('verify');\n339\t\n340\t      // flow is FlowStep[]\n341\t      expect(Array.isArray(result.flow)).toBe(true);\n342\t\n343\t      // Each task has ResolvedTask properties\n344\t      const task: ResolvedTask = result.tasks.implement;\n345\t      expect(typeof task.agent).toBe('string');\n346\t      expect(typeof task.scope).toBe('string');\n347\t      expect(typeof task.session).toBe('string');\n348\t      expect(typeof task.source_access).toBe('boolean');\n349\t    });\n350\t\n351\t    it('FlowStep is a union of string | LoopBlock', () => {\n352\t      const filePath = writeYaml('flow-types.yaml', loopYaml);\n353\t      const result = parseWorkflow(filePath);\n354\t\n355\t      // String flow step\n356\t      const stringStep: FlowStep = result.flow[0];\n357\t      expect(typeof stringStep).toBe('string');\n358\t\n359\t      // LoopBlock flow step\n360\t      const loopStep: FlowStep = result.flow[2];\n361\t      expect(typeof loopStep).toBe('object');\n362\t      expect((loopStep as LoopBlock).loop).toBeDefined();\n363\t    });\n364\t  });\n365\t\n366\t  describe('WorkflowParseError structure (AC #8)', () => {\n367\t    it('extends Error and has name and errors array', () => {\n368\t      const err = new WorkflowParseError('test error', [\n369\t        { path: '/tasks', message: 'missing' },\n370\t      ]);\n371\t\n372\t      expect(err).toBeInstanceOf(Error);\n373\t      expect(err.name).toBe('WorkflowParseError');\n374\t      expect(err.message).toBe('test error');\n375\t      expect(err.errors).toHaveLength(1);\n376\t      expect(err.errors[0]).toEqual({ path: '/tasks', message: 'missing' });\n377\t    });\n378\t\n379\t    it('defaults errors to empty array when not provided', () => {\n380\t      const err = new WorkflowParseError('test error');\n381\t      expect(err.errors).toEqual([]);\n382\t    });\n383\t  });\n384\t});\n385\t"}]},"parent_tool_use_id":"toolu_01VGSj6rHvizz2esfbdaxjc5","session_id":"655665ef-6468-4ba6-a46a-b395b1530cdd","uuid":"953251f2-0f23-4fd4-96d7-0fe604627f53","timestamp":"2026-04-02T11:49:45.529Z"}
