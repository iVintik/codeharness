/proof.md')).toBe(false);\n   554→  });\n   555→\n   556→  it('returns false for skeleton without showboat blocks in any AC section', () => {\n   557→    const path = join(testDir, 'proof.md');\n   558→    writeFileSync(path, '# Proof\\n\\n## AC 1: PENDING\\n\\n<!-- No evidence -->');\n   559→    expect(proofHasContent(path)).toBe(false);\n   560→  });\n   561→\n   562→  it('returns true when all AC sections have showboat exec blocks', () => {\n   563→    const path = join(testDir, 'proof.md');\n   564→    writeFileSync(path, '# Proof\\n\\n## AC 1: PASS\\n\\n<!-- showboat exec: npm test -->\\n```\\nok\\n```\\n<!-- /showboat exec -->');\n   565→    expect(proofHasContent(path)).toBe(true);\n   566→  });\n   567→\n   568→  it('returns true when all AC sections have showboat image blocks', () => {\n   569→    const path = join(testDir, 'proof.md');\n   570→    writeFileSync(path, '# Proof\\n\\n## AC 1: PASS\\n\\n<!-- showboat image: screenshots/test.png -->');\n   571→    expect(proofHasContent(path)).toBe(true);\n   572→  });\n   573→\n   574→  it('returns false when file has no AC sections', () => {\n   575→    const path = join(testDir, 'proof.md');\n   576→    writeFileSync(path, '# Proof\\n\\nNo AC sections');\n   577→    expect(proofHasContent(path)).toBe(false);\n   578→  });\n   579→});\n   580→\n   581→describe('validateProofQuality — no-space AC header format', () => {\n   582→  it('parses ## ACN: headers (no space between AC and number)', () => {\n   583→    const path = join(testDir, 'proof.md');\n   584→    writeFileSync(path, [\n   585→      '## AC1: Binary available',\n   586→      '',\n   587→      '```bash',\n   588→      'codeharness --version',\n   589→      '```',\n   590→      '',\n   591→      '```output',\n   592→      '0.10.0',\n   593→      '```',\n   594→      '',\n   595→      '## AC2: Commands listed',\n   596→      '',\n   597→      '```bash',\n   598→      'codeharness --help',\n   599→      '```',\n   600→      '',\n   601→      '```outpu