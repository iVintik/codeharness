{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01185RBiXWJ8F74LxaSXwvxb","type":"tool_result","content":"1\t/**\n2\t * Epic Completion Detection.\n3\t *\n4\t * Pure logic module that detects when all stories in an epic reach\n5\t * \"done\" status and provides a state machine for epic lifecycle\n6\t * transitions: in-progress → completing → merging → validating → done.\n7\t *\n8\t * @see Story 19-1: Epic Completion Detection\n9\t */\n10\t\n11\timport type { SprintState } from '../types/state.js';\n12\t\n13\t// --- Types ---\n14\t\n15\t/**\n16\t * All possible epic lifecycle statuses.\n17\t * Narrows the broad `string` type from EpicState.status.\n18\t */\n19\texport type EpicLifecycleStatus =\n20\t  | 'in-progress'\n21\t  | 'completing'\n22\t  | 'merging'\n23\t  | 'validating'\n24\t  | 'done'\n25\t  | 'failed';\n26\t\n27\t// --- Error ---\n28\t\n29\t/**\n30\t * Error thrown for invalid epic operations:\n31\t * - Epic not found in state\n32\t * - Invalid state transition\n33\t */\n34\texport class EpicCompletionError extends Error {\n35\t  constructor(message: string) {\n36\t    super(message);\n37\t    this.name = 'EpicCompletionError';\n38\t  }\n39\t}\n40\t\n41\t// --- State Machine ---\n42\t\n43\t/**\n44\t * Valid epic state transitions.\n45\t *\n46\t * Happy path: in-progress → completing → merging → validating → done\n47\t * Failure:    completing|merging|validating → failed\n48\t */\n49\texport const VALID_TRANSITIONS: Record<string, EpicLifecycleStatus[]> = {\n50\t  'in-progress': ['completing'],\n51\t  'completing': ['merging', 'failed'],\n52\t  'merging': ['validating', 'failed'],\n53\t  'validating': ['done', 'failed'],\n54\t};\n55\t\n56\t// --- Functions ---\n57\t\n58\t/**\n59\t * Get all story keys belonging to a given epic.\n60\t *\n61\t * Stories are matched by the numeric prefix before the first dash.\n62\t * E.g., epicId \"19\" matches \"19-1-foo\" and \"19-2-bar\" but not \"1-9-baz\".\n63\t */\n64\texport function getEpicStories(state: SprintState, epicId: string): string[] {\n65\t  return Object.keys(state.stories).filter((key) => {\n66\t    const dash = key.indexOf('-');\n67\t    if (dash === -1) return false;\n68\t    return key.slice(0, dash) === epicId;\n69\t  });\n70\t}\n71\t\n72\t/**\n73\t * Check whether all stories in an epic have status \"done\".\n74\t *\n75\t * Returns false for epics with zero stories (never considered complete).\n76\t * Throws EpicCompletionError if the epic does not exist in state.\n77\t */\n78\texport function checkEpicCompletion(state: SprintState, epicId: string): boolean {\n79\t  if (!state.epics[`epic-${epicId}`]) {\n80\t    throw new EpicCompletionError(`Epic epic-${epicId} not found in state`);\n81\t  }\n82\t  const stories = getEpicStories(state, epicId);\n83\t  if (stories.length === 0) return false;\n84\t  return stories.every((key) => state.stories[key]?.status === 'done');\n85\t}\n86\t\n87\t/**\n88\t * Transition an epic to a new lifecycle status (immutable).\n89\t *\n90\t * Validates that:\n91\t * 1. The epic exists in state\n92\t * 2. The transition is allowed by the state machine\n93\t *\n94\t * When transitioning to \"completing\", updates storiesDone to the\n95\t * count of stories with status \"done\".\n96\t *\n97\t * Returns a new SprintState — does not mutate the input.\n98\t */\n99\texport function transitionEpicState(\n100\t  state: SprintState,\n101\t  epicId: string,\n102\t  targetStatus: EpicLifecycleStatus,\n103\t): SprintState {\n104\t  const epicKey = `epic-${epicId}`;\n105\t  const epic = state.epics[epicKey];\n106\t  if (!epic) throw new EpicCompletionError(`Epic ${epicKey} not found in state`);\n107\t\n108\t  const currentStatus = epic.status as EpicLifecycleStatus;\n109\t  const allowed = VALID_TRANSITIONS[currentStatus];\n110\t  if (!allowed?.includes(targetStatus)) {\n111\t    throw new EpicCompletionError(\n112\t      `Invalid transition: ${currentStatus} → ${targetStatus}`,\n113\t    );\n114\t  }\n115\t\n116\t  const storiesDone = targetStatus === 'completing'\n117\t    ? getEpicStories(state, epicId).filter((k) => state.stories[k]?.status === 'done').length\n118\t    : epic.storiesDone;\n119\t\n120\t  return {\n121\t    ...state,\n122\t    epics: {\n123\t      ...state.epics,\n124\t      [epicKey]: { ...epic, status: targetStatus, storiesDone },\n125\t    },\n126\t  };\n127\t}\n128\t"}]},"parent_tool_use_id":"toolu_01KxDszVE1hewisgsfsHW1D6","session_id":"cb820906-0735-4f53-a851-3960824caad6","uuid":"dc73ba02-45b8-4d17-abdb-a395f6b8987d","timestamp":"2026-04-03T22:59:48.793Z"}
