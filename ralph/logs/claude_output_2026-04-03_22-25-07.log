itest/coverage-v8': '^1.0.0' },\n51\t      }),\n52\t    );\n53\t\n54\t    const result = detectCoverageTool(testDir);\n55\t    expect(result.tool).toBe('c8');\n56\t  });\n57\t\n58\t  it('detects c8 from @vitest/coverage-istanbul in devDependencies', () => {\n59\t    writeFileSync(\n60\t      join(testDir, 'package.json'),\n61\t      JSON.stringify({\n62\t        name: 'test',\n63\t        devDependencies: { '@vitest/coverage-istanbul': '^1.0.0' },\n64\t      }),\n65\t    );\n66\t\n67\t    const result = detectCoverageTool(testDir);\n68\t    expect(result.tool).toBe('c8');\n69\t  });\n70\t\n71\t  it('detects c8 from c8 in devDependencies', () => {\n72\t    writeFileSync(\n73\t      join(testDir, 'package.json'),\n74\t      JSON.stringify({\n75\t        name: 'test',\n76\t        devDependencies: { c8: '^7.0.0' },\n77\t      }),\n78\t    );\n79\t\n80\t    const result = detectCoverageTool(testDir);"}]},"parent_tool_use_id":"toolu_01Hody5ZigZ3cTLmGuBw8VE3","session_id":"b6bb3bfc-8778-4f16-a616-88028acc2431","uuid":"b3274eff-33ec-4b9b-81f5-847a7722cdaa","timestamp":"2026-04-03T18:31:47.058Z"}
