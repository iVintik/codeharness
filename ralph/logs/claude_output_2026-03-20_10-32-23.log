{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SJsDqgCPRoc31RziHkmk7i","type":"tool_result","content":"     1→/**\n     2→ * Standalone runtime validator — validates telemetry outside Docker verification.\n     3→ * Implements Story 2.3: run tests with OTLP, query backend, report module coverage.\n     4→ */\n     5→\n     6→import { execSync } from 'node:child_process';\n     7→import { readdirSync, statSync } from 'node:fs';\n     8→import { join } from 'node:path';\n     9→import { ok, fail } from '../../types/result.js';\n    10→import type { Result } from '../../types/result.js';\n    11→import type {\n    12→  RuntimeValidationConfig,\n    13→  RuntimeValidationResult,\n    14→  ModuleTelemetryEntry,\n    15→  TelemetryEvent,\n    16→} from './types.js';\n    17→\n    18→const DEFAULT_CONFIG: RuntimeValidationConfig = {\n    19→  testCommand: 'npm test',\n    20→  otlpEndpoint: 'http://localhost:4318',\n    21→  queryEndpoint: 'http://localhost:9428',\n    22→  timeoutMs: 120_000,\n    23→};\n    24→\n    25→const HEALTH_TIMEOUT_MS = 3_000;\n    26→/** Run tests with OTLP enabled, query backend for events, compute module coverage. */\n    27→export async function validateRuntime(\n    28→  projectDir: string,\n    29→  config?: Partial<RuntimeValidationConfig>,\n    30→): Promise<Result<RuntimeValidationResult>> {\n    31→  if (!projectDir || typeof projectDir !== 'string') {\n    32→    return fail('projectDir is required and must be a non-empty string');\n    33→  }\n    34→\n    35→  const cfg: RuntimeValidationConfig = { ...DEFAULT_CONFIG, ...config };\n    36→\n    37→  // Step 1: Check backend health\n    38→  const healthy = await checkBackendHealth(cfg.queryEndpoint);\n    39→  if (!healthy) {\n    40→    const modules = discoverModules(projectDir);\n    41→    const entries: ModuleTelemetryEntry[] = modules.map((m) => ({\n    42→      moduleName: m,\n    43→      telemetryDetected: false,\n    44→      eventCount: 0,\n    45→    }));\n    46→    return ok({\n    47→      entries,\n    48→      totalModules: modules.length,\n    49→      modulesWithTelemetry: 0,\n    50→      coveragePercent: 0,\n    51→      skipped: true,\n    52→      skipReason: 'runtime validation skipped -- observability stack not available',\n    53→    });\n    54→  }\n    55→\n    56→  // Step 2: Record start time and run tests\n    57→  const startTime = new Date().toISOString();\n    58→  try {\n    59→    execSync(cfg.testCommand, {\n    60→      cwd: projectDir,\n    61→      timeout: cfg.timeoutMs,\n    62→      env: {\n    63→        ...process.env,\n    64→        OTEL_EXPORTER_OTLP_ENDPOINT: cfg.otlpEndpoint,\n    65→      },\n    66→      stdio: 'pipe',\n    67→    });\n    68→  } catch (err: unknown) {\n    69→    const msg = err instanceof Error ? err.message : String(err);\n    70→    return fail(`Test command failed: ${msg}`);\n    71→  }\n    72→  const endTime = new Date().toISOString();\n    73→\n    74→  // Step 3: Query telemetry events\n    75→  const eventsResult = await queryTelemetryEvents(cfg.queryEndpoint, startTime, endTime);\n    76→  if (!eventsResult.success) {\n    77→    return fail(eventsResult.error);\n    78→  }\n    79→\n    80→  // Step 4: Map events to modules and compute coverage\n    81→  const modules = discoverModules(projectDir);\n    82→  const entries = mapEventsToModules(eventsResult.data, projectDir, modules);\n    83→  const modulesWithTelemetry = entries.filter((e) => e.telemetryDetected).length;\n    84→  const totalModules = entries.length;\n    85→  const coveragePercent = totalModules === 0 ? 0 : (modulesWithTelemetry / totalModules) * 100;\n    86→\n    87→  return ok({\n    88→    entries,\n    89→    totalModules,\n    90→    modulesWithTelemetry,\n    91→    coveragePercent,\n    92→    skipped: false,\n    93→  });\n    94→}\n    95→\n    96→/** Check if the observability backend is reachable (2xx within 3s). */\n    97→export async function checkBackendHealth(queryEndpoint: string): Promise<boolean> {\n    98→  try {\n    99→    const response = await fetch(`${queryEndpoint}/health`, {\n   100→      signal: AbortSignal.timeout(HEALTH_TIMEOUT_MS),\n   101→    });\n   102→    return response.ok;\n   103→  } catch {\n   104→    return false;\n   105→  }\n   106→}\n   107→\n   108→/** Query VictoriaLogs for telemetry events within a time window. */\n   109→export async function queryTelemetryEvents(\n   110→  queryEndpoint: string,\n   111→  startTime: string,\n   112→  endTime: string,\n   113→): Promise<Result<TelemetryEvent[]>> {\n   114→  const url = new URL('/select/logsql/query', queryEndpoint);\n   115→  url.searchParams.set('query', '_stream_id:*');\n   116→  url.searchParams.set('start', startTime);\n   117→  url.searchParams.set('end', endTime);\n   118→  url.searchParams.set('limit', '1000');\n   119→\n   120→  try {\n   121→    const response = await fetch(url.toString(), {\n   122→      signal: AbortSignal.timeout(HEALTH_TIMEOUT_MS),\n   123→    });\n   124→    if (!response.ok) {\n   125→      return fail(`VictoriaLogs returned ${response.status}`);\n   126→    }\n   127→    const text = await response.text();\n   128→    const events = parseLogEvents(text);\n   129→    return ok(events);\n   130→  } catch (err: unknown) {\n   131→    const msg = err instanceof Error ? err.message : String(err);\n   132→    return fail(`Failed to query telemetry events: ${msg}`);\n   133→  }\n   134→}\n   135→\n   136→/** Map telemetry events to project modules by matching source paths. */\n   137→export function mapEventsToModules(\n   138→  events: TelemetryEvent[],\n   139→  _projectDir: string,\n   140→  modules?: string[],\n   141→): ModuleTelemetryEntry[] {\n   142→  const moduleList = modules ?? [];\n   143→  const moduleCounts = new Map<string, number>();\n   144→  for (const mod of moduleList) {\n   145→    moduleCounts.set(mod, 0);\n   146→  }\n   147→\n   148→  for (const event of events) {\n   149→    for (const mod of moduleList) {\n   150→      if (event.source.includes(mod) || event.message.includes(mod)) {\n   151→        moduleCounts.set(mod, (moduleCounts.get(mod) ?? 0) + 1);\n   152→      }\n   153→    }\n   154→  }\n   155→\n   156→  return moduleList.map((mod) => {\n   157→    const count = moduleCounts.get(mod) ?? 0;\n   158→    return {\n   159→      moduleName: mod,\n   160→      telemetryDetected: count > 0,\n   161→      eventCount: count,\n   162→    };\n   163→  });\n   164→}\n   165→\n   166→/** Discover top-level module directories under src/ */\n   167→function discoverModules(projectDir: string): string[] {\n   168→  const srcDir = join(projectDir, 'src');\n   169→  try {\n   170→    return readdirSync(srcDir).filter((name) => {\n   171→      try {\n   172→        return statSync(join(srcDir, name)).isDirectory();\n   173→      } catch {\n   174→        return false;\n   175→      }\n   176→    });\n   177→  } catch {\n   178→    return [];\n   179→  }\n   180→}\n   181→\n   182→/** Parse newline-delimited JSON from VictoriaLogs into TelemetryEvent[] */\n   183→function parseLogEvents(text: string): TelemetryEvent[] {\n   184→  if (!text.trim()) return [];\n   185→  const lines = text.trim().split('\\n');\n   186→  const events: TelemetryEvent[] = [];\n   187→  for (const line of lines) {\n   188→    try {\n   189→      const raw = JSON.parse(line) as Record<string, unknown>;\n   190→      events.push({\n   191→        timestamp: String(raw._time ?? raw.timestamp ?? ''),\n   192→        message: String(raw._msg ?? raw.message ?? ''),\n   193→        source: String(raw.source ?? raw._source ?? raw.service ?? ''),\n   194→      });\n   195→    } catch {\n   196→      // skip malformed lines\n   197→    }\n   198→  }\n   199→  return events;\n   200→}\n   201→"}]},"parent_tool_use_id":"toolu_01X8HPzdvjqKbRcjmtsWDTRD","session_id":"c5eaf6a6-ac7c-4707-b82c-6220d711aa9c","uuid":"7606bc9d-31b3-4dc2-8b60-57f6d1f8f8c1","timestamp":"2026-03-20T06:44:46.559Z"}
