{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WRgghcuDQjXqgsfVtF39rb","type":"tool_result","content":"800\t\n801\t  it('applies replace sections as full replacement (not deep merge)', () => {\n802\t    const patchDir = join(testDir, '.codeharness', 'workflows');\n803\t    mkdirSync(patchDir, { recursive: true });\n804\t\n805\t    const patchContent = `\n806\textends: embedded://default\n807\treplace:\n808\t  flow:\n809\t    - implement\n810\t    - verify\n811\t`;\n812\t    writeFileSync(join(patchDir, 'default.patch.yaml'), patchContent, 'utf-8');\n813\t\n814\t    const result = resolveWorkflow({ cwd: testDir });\n815\t\n816\t    // flow fully replaced — no loop block from embedded default\n817\t    expect(result.flow).toEqual(['implement', 'verify']);\n818\t  });\n819\t\n820\t  it('applies user patch before project patch (ordering)', () => {\n821\t    // Create user-level patch\n822\t    const userPatchDir = join(os.homedir(), '.codeharness', 'workflows');\n823\t    const userPatchPath = join(userPatchDir, 'default.patch.yaml');\n824\t    let userPatchExisted = false;\n825\t    let originalUserPatch: string | undefined;\n826\t\n827\t    try {\n828\t      originalUserPatch = readFileSync(userPatchPath, 'utf-8');\n829\t      userPatchExisted = true;\n830\t    } catch { /* no existing patch */ }\n831\t\n832\t    try {\n833\t      mkdirSync(userPatchDir, { recursive: true });\n834\t      writeFileSync(userPatchPath, `\n835\textends: embedded://default\n836\toverrides:\n837\t  tasks:\n838\t    implement:\n839\t      session: continue\n840\t      max_budget_usd: 3.0\n841\t`, 'utf-8');\n842\t\n843\t      // Create project-level patch that overrides the user patch\n844\t      const projectPatchDir = join(testDir, '.codeharness', 'workflows');\n845\t      mkdirSync(projectPatchDir, { recursive: true });\n846\t      writeFileSync(join(projectPatchDir, 'default.patch.yaml'), `\n847\textends: embedded://default\n848\toverrides:\n849\t  tasks:\n850\t    implement:\n851\t      max_budget_usd: 7.0\n852\t`, 'utf-8');\n853\t\n854\t      const result = resolveWorkflow({ cwd: testDir });\n855\t\n856\t      // User patch: session=continue, max_budget_usd=3.0\n857\t      // Project patch overrides: max_budget_usd=7.0\n858\t      expect(result.tasks.implement.session).toBe('continue');\n859\t      expect(result.tasks.implement.max_budget_usd).toBe(7.0);\n860\t    } finally {\n861\t      // Cleanup user patch\n862\t      if (userPatchExisted && originalUserPatch !== undefined) {\n863\t        writeFileSync(userPatchPath, originalUserPatch, 'utf-8');\n864\t      } else {\n865\t        try { rmSync(userPatchPath); } catch { /* ignore */ }\n866\t      }\n867\t    }\n868\t  });\n869\t\n870\t  it('throws WorkflowParseError for malformed YAML patch', () => {\n871\t    const patchDir = join(testDir, '.codeharness', 'workflows');\n872\t    mkdirSync(patchDir, { recursive: true });\n873\t    writeFileSync(join(patchDir, 'default.patch.yaml'), '{{{{not yaml', 'utf-8');\n874\t\n875\t    expect(() => resolveWorkflow({ cwd: testDir })).toThrow(WorkflowParseError);\n876\t    try {\n877\t      resolveWorkflow({ cwd: testDir });\n878\t    } catch (err) {\n879\t      const pe = err as WorkflowParseError;\n880\t      expect(pe.message).toContain('Invalid YAML');\n881\t    }\n882\t  });\n883\t\n884\t  it('throws WorkflowParseError when merged result fails schema validation', () => {\n885\t    const patchDir = join(testDir, '.codeharness', 'workflows');\n886\t    mkdirSync(patchDir, { recursive: true });\n887\t\n888\t    // Replace tasks with invalid structure (agent missing)\n889\t    const patchContent = `\n890\textends: embedded://default\n891\treplace:\n892\t  tasks:\n893\t    broken:\n894\t      scope: per-story\n895\t`;\n896\t    writeFileSync(join(patchDir, 'default.patch.yaml'), patchContent, 'utf-8');\n897\t\n898\t    expect(() => resolveWorkflow({ cwd: testDir })).toThrow(WorkflowParseError);\n899\t    try {\n900\t      resolveWorkflow({ cwd: testDir });\n901\t    } catch (err) {\n902\t      const pe = err as WorkflowParseError;\n903\t      expect(pe.message).toContain('Schema validation failed');\n904\t    }\n905\t  });\n906\t\n907\t  it('throws WorkflowParseError when merged result has dangling task refs in flow', () => {\n908\t    const patchDir = join(testDir, '.codeharness', 'workflows');\n909\t    mkdirSync(patchDir, { recursive: true });\n910\t\n911\t    // Replace flow with ref to non-existent task, but keep tasks valid\n912\t    const patchContent = `\n913\textends: embedded://default\n914\treplace:\n915\t  flow:\n916\t    - implement\n917\t    - nonexistent_task\n918\t`;\n919\t    writeFileSync(join(patchDir, 'default.patch.yaml'), patchContent, 'utf-8');\n920\t\n921\t    expect(() => resolveWorkflow({ cwd: testDir })).toThrow(WorkflowParseError);\n922\t    try {\n923\t      resolveWorkflow({ cwd: testDir });\n924\t    } catch (err) {\n925\t      const pe = err as WorkflowParseError;\n926\t      expect(pe.message).toContain('Referential integrity errors');\n927\t      expect(pe.errors.some((e) => e.message.includes('nonexistent_task'))).toBe(true);\n928\t    }\n929\t  });\n930\t\n931\t  it('silently skips missing patch files', () => {\n932\t    // testDir has no .codeharness directory\n933\t    const result = resolveWorkflow({ cwd: testDir });\n934\t    // Should not throw, should return embedded workflow\n935\t    expect(result.tasks.implement).toBeDefined();\n936\t  });\n937\t\n938\t  it('uses cwd option to find project patches', () => {\n939\t    const projectA = join(testDir, 'project-a');\n940\t    const patchDir = join(projectA, '.codeharness', 'workflows');\n941\t    mkdirSync(patchDir, { recursive: true });\n942\t\n943\t    writeFileSync(join(patchDir, 'default.patch.yaml'), `\n944\textends: embedded://default\n945\toverrides:\n946\t  tasks:\n947\t    implement:\n948\t      max_budget_usd: 99.0\n949\t`, 'utf-8');\n950\t\n951\t    const result = resolveWorkflow({ cwd: projectA });\n952\t    expect(result.tasks.implement.max_budget_usd).toBe(99.0);\n953\t  });\n954\t\n955\t  it('throws WorkflowParseError for non-existent embedded workflow name', () => {\n956\t    expect(() => resolveWorkflow({ cwd: testDir, name: 'nonexistent-workflow' })).toThrow(WorkflowParseError);\n957\t    try {\n958\t      resolveWorkflow({ cwd: testDir, name: 'nonexistent-workflow' });\n959\t    } catch (err) {\n960\t      const pe = err as WorkflowParseError;\n961\t      expect(pe.message).toContain('Embedded workflow not found: nonexistent-workflow');\n962\t    }\n963\t  });\n964\t\n965\t  it('loads full custom workflow at project level when no extends', () => {\n966\t    const customDir = join(testDir, '.codeharness', 'workflows');\n967\t    mkdirSync(customDir, { recursive: true });\n968\t\n969\t    // Full custom workflow (not a patch)\n970\t    writeFileSync(join(customDir, 'default.yaml'), `\n971\ttasks:\n972\t  custom-task:\n973\t    agent: dev\n974\tflow:\n975\t  - custom-task\n976\t`, 'utf-8');\n977\t\n978\t    const result = resolveWorkflow({ cwd: testDir });\n979\t    expect(result.tasks['custom-task']).toBeDefined();\n980\t    expect(result.tasks['custom-task'].agent).toBe('dev');\n981\t  });\n982\t\n983\t  // --- Story 9.2: Custom Workflow Creation ---\n984\t\n985\t  describe('custom workflow by name (Story 9.2)', () => {\n986\t    it('loads a custom workflow from .codeharness/workflows/{name}.yaml by name', () => {\n987\t      const customDir = join(testDir, '.codeharness', 'workflows');\n988\t      mkdirSync(customDir, { recursive: true });\n989\t\n990\t      writeFileSync(join(customDir, 'my-workflow.yaml'), `\n991\ttasks:\n992\t  deploy:\n993\t    agent: dev\n994\tflow:\n995\t  - deploy\n996\t`, 'utf-8');\n997\t\n998\t      const result = resolveWorkflow({ cwd: testDir, name: 'my-workflow' });\n999\t      expect(result.tasks.deploy).toBeDefined();\n1000\t      expect(result.tasks.deploy.agent).toBe('dev');\n1001\t      expect(result.flow).toEqual(['deploy']);\n1002\t    });\n1003\t\n1004\t    it('custom workflow fails schema validation — throws WorkflowParseError', () => {\n1005\t      const customDir = join(testDir, '.codeharness', 'workflows');\n1006\t      mkdirSync(customDir, { recursive: true });\n1007\t\n1008\t      // Missing tasks key entirely\n1009\t      writeFileSync(join(customDir, 'bad-schema.yaml'), `\n1010\tflow:\n1011\t  - deploy\n1012\t`, 'utf-8');\n1013\t\n1014\t      expect(() => resolveWorkflow({ cwd: testDir, name: 'bad-schema' })).toThrow(WorkflowParseError);\n1015\t      try {\n1016\t        resolveWorkflow({ cwd: testDir, name: 'bad-schema' });\n1017\t      } catch (err) {\n1018\t        const pe = err as WorkflowParseError;\n1019\t        expect(pe.message).toContain('Schema validation failed');\n1020\t        expect(pe.errors.length).toBeGreaterThan(0);\n1021\t      }\n1022\t    });\n1023\t\n1024\t    it('custom workflow passes schema but has dangling flow refs — throws WorkflowParseError', () => {\n1025\t      const customDir = join(testDir, '.codeharness', 'workflows');\n1026\t      mkdirSync(customDir, { recursive: true });\n1027\t\n1028\t      writeFileSync(join(customDir, 'dangling.yaml'), `\n1029\ttasks:\n1030\t  deploy:\n1031\t    agent: dev\n1032\tflow:\n1033\t  - deploy\n1034\t  - nonexistent\n1035\t`, 'utf-8');\n1036\t\n1037\t      expect(() => resolveWorkflow({ cwd: testDir, name: 'dangling' })).toThrow(WorkflowParseError);\n1038\t      try {\n1039\t        resolveWorkflow({ cwd: testDir, name: 'dangling' });\n1040\t      } catch (err) {\n1041\t        const pe = err as WorkflowParseError;\n1042\t        expect(pe.message).toContain('Referential integrity errors');\n1043\t        expect(pe.errors.some((e) => e.message.includes('nonexistent'))).toBe(true);\n1044\t      }\n1045\t    });\n1046\t\n1047\t    it('resolveWorkflow({ name: \"nonexistent\" }) with no matching file throws clear error', () => {\n1048\t      expect(() => resolveWorkflow({ cwd: testDir, name: 'nonexistent' })).toThrow(WorkflowParseError);\n1049\t      try {\n1050\t        resolveWorkflow({ cwd: testDir, name: 'nonexistent' });\n1051\t      } catch (err) {\n1052\t        const pe = err as WorkflowParseError;\n1053\t        expect(pe.message).toContain('Embedded workflow not found: nonexistent');\n1054\t      }\n1055\t    });\n1056\t\n1057\t    it('resolveWorkflow() with no name defaults to \"default\" — backward-compatible', () => {\n1058\t      const result = resolveWorkflow({ cwd: testDir });\n1059\t      // Should load embedded default without error\n1060\t      expect(result.tasks).toBeDefined();\n1061\t      expect(result.tasks.implement).toBeDefined();\n1062\t      expect(result.flow.length).toBeGreaterThan(0);\n1063\t    });\n1064\t\n1065\t    it('custom workflow with extends key is NOT treated as full custom (falls to patch resolution)', () => {\n1066\t      const customDir = join(testDir, '.codeharness', 'workflows');\n1067\t      mkdirSync(customDir, { recursive: true });\n1068\t\n1069\t      // This has extends, so it should be treated as a patch-like file, not a full custom workflow\n1070\t      // Since the name is 'ci' and there is no embedded 'ci' template, this should throw\n1071\t      writeFileSync(join(customDir, 'ci.yaml'), `\n1072\textends: embedded://default\n1073\toverrides:\n1074\t  tasks:\n1075\t    implement:\n1076\t      session: continue\n1077\t`, 'utf-8');\n1078\t\n1079\t      // With extends, it's not treated as a full custom workflow.\n1080\t      // It tries to load embedded 'ci' template which doesn't exist => error\n1081\t      expect(() => resolveWorkflow({ cwd: testDir, name: 'ci' })).toThrow(WorkflowParseError);\n1082\t      try {\n1083\t        resolveWorkflow({ cwd: testDir, name: 'ci' });\n1084\t      } catch (err) {\n1085\t        const pe = err as WorkflowParseError;\n1086\t        expect(pe.message).toContain('Embedded workflow not found: ci');\n1087\t      }\n1088\t    });\n1089\t\n1090\t    it('custom workflow alongside patch file: patch is ignored for full custom workflows', () => {\n1091\t      const customDir = join(testDir, '.codeharness', 'workflows');\n1092\t      mkdirSync(customDir, { recursive: true });\n1093\t\n1094\t      // Full custom workflow (no extends)\n1095\t      writeFileSync(join(customDir, 'ci.yaml'), `\n1096\ttasks:\n1097\t  build:\n1098\t    agent: qa\n1099\tflow:\n1100\t  - build\n1101\t`, 'utf-8');\n1102\t\n1103\t      // Patch file that would change agent — should be ignored\n1104\t      writeFileSync(join(customDir, 'ci.patch.yaml'), `\n1105\textends: embedded://default\n1106\toverrides:\n1107\t  tasks:\n1108\t    build:\n1109\t      agent: architect\n1110\t`, 'utf-8');\n1111\t\n1112\t      const result = resolveWorkflow({ cwd: testDir, name: 'ci' });\n1113\t      expect(result.tasks.build.agent).toBe('qa'); // Not patched\n1114\t    });\n1115\t\n1116\t    it('custom workflow with valid agent names resolves agent field correctly', () => {\n1117\t      const customDir = join(testDir, '.codeharness', 'workflows');\n1118\t      mkdirSync(customDir, { recursive: true });\n1119\t\n1120\t      writeFileSync(join(customDir, 'multi-agent.yaml'), `\n1121\ttasks:\n1122\t  build:\n1123\t    agent: dev\n1124\t  test:\n1125\t    agent: qa\n1126\t  deploy:\n1127\t    agent: architect\n1128\tflow:\n1129\t  - build\n1130\t  - test\n1131\t  - deploy\n1132\t`, 'utf-8');\n1133\t\n1134\t      const result = resolveWorkflow({ cwd: testDir, name: 'multi-agent' });\n1135\t      expect(result.tasks.build.agent).toBe('dev');\n1136\t      expect(result.tasks.test.agent).toBe('qa');\n1137\t      expect(result.tasks.deploy.agent).toBe('architect');\n1138\t    });\n1139\t  });\n1140\t});\n1141\t\n1142\t// --- Referential Integrity Validation Tests (Story 11-2) ---\n1143\t\n1144\tdescribe('referential integrity validation', () => {\n1145\t  function mockDriver(name: string): AgentDriver {\n1146\t    return {\n1147\t      name,\n1148\t      defaultModel: 'test-model',\n1149\t      capabilities: { streaming: false, tools: false, subagents: false, computerUse: false },\n1150\t      async healthCheck() { return { status: 'healthy' as const, driver: name }; },\n1151\t      async *dispatch() { /* empty */ },\n1152\t      getLastCost() { return null; },\n1153\t    };\n1154\t  }\n1155\t\n1156\t  afterEach(() => {\n1157\t    resetDrivers();\n1158\t  });\n1159\t\n1160\t  describe('driver validation (AC #1, #4)', () => {\n1161\t    it('workflow with driver: claude-code passes when driver is registered (AC #4)', () => {\n1162\t      registerDriver(mockDriver('claude-code'));\n1163\t\n1164\t      const yaml = `\n1165\ttasks:\n1166\t  implement:\n1167\t    agent: dev\n1168\t    driver: claude-code\n1169\tflow:\n1170\t  - implement\n1171\t`;\n1172\t      const filePath = writeYaml('valid-driver.yaml', yaml);\n1173\t      const result = parseWorkflow(filePath);\n1174\t      expect(result.tasks.implement.driver).toBe('claude-code');\n1175\t    });\n1176\t\n1177\t    it('workflow with driver: nonexistent throws WorkflowParseError with helpful message (AC #1)', () => {\n1178\t      registerDriver(mockDriver('claude-code'));\n1179\t\n1180\t      const yaml = `\n1181\ttasks:\n1182\t  implement:\n1183\t    agent: dev\n1184\t    driver: codex\n1185\tflow:\n1186\t  - implement\n1187\t`;\n1188\t      const filePath = writeYaml('invalid-driver.yaml', yaml);\n1189\t\n1190\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n1191\t      try {\n1192\t        parseWorkflow(filePath);\n1193\t      } catch (err) {\n1194\t        const pe = err as WorkflowParseError;\n1195\t        expect(pe.message).toContain('Referential integrity errors');\n1196\t        expect(pe.errors.some((e) => e.path === '/tasks/implement/driver')).toBe(true);\n1197\t        expect(pe.errors.some((e) => e.message.includes('codex'))).toBe(true);\n1198\t        expect(pe.errors.some((e) => e.message.includes('implement'))).toBe(true);\n1199\t        expect(pe.errors.some((e) => e.message.includes('claude-code'))).toBe(true);"}]},"parent_tool_use_id":"toolu_01U85MaKaYFD6RV3D181SmSg","session_id":"4b1f7711-6ed7-4488-a0af-b261e761b450","uuid":"569d1ae8-bfbe-4fe0-8a2d-b27f7a24b50a","timestamp":"2026-04-03T08:37:14.020Z"}
