{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0116cqUjmkbuMhVkFdBog73t","type":"tool_result","content":"1\t/**\n2\t * Tests for storyFlow execution in the workflow engine.\n3\t *\n4\t * Story 16-6: Story Flow Execution\n5\t *\n6\t * Verifies that the engine reads `storyFlow` instead of `flow` to drive\n7\t * per-story execution, preserves loop semantics, handles null tasks after\n8\t * loops, derives workflow_name from storyFlow, and maintains backward\n9\t * compatibility with legacy `flow:` workflows.\n10\t */\n11\timport { describe, it, expect, vi, beforeEach } from 'vitest';\n12\t\n13\t// --- Hoisted Mocks ---\n14\t\n15\tconst {\n16\t  mockReadWorkflowState,\n17\t  mockWriteWorkflowState,\n18\t  mockWarn,\n19\t  mockReadFileSync,\n20\t  mockExistsSync,\n21\t  mockParse,\n22\t  mockGetDriver,\n23\t  mockResolveModel,\n24\t  mockDriverDispatch,\n25\t  mockBuildPromptWithContractContext,\n26\t  mockWriteOutputContract,\n27\t  mockGenerateTraceId,\n28\t  mockFormatTracePrompt,\n29\t  mockRecordTraceId,\n30\t  mockResolveSessionId,\n31\t  mockRecordSessionId,\n32\t  mockCreateIsolatedWorkspace,\n33\t  mockGetNullTask,\n34\t  mockListNullTasks,\n35\t  mockReadStateWithBody,\n36\t  mockWriteState,\n37\t} = vi.hoisted(() => ({\n38\t  mockReadWorkflowState: vi.fn(),\n39\t  mockWriteWorkflowState: vi.fn(),\n40\t  mockWarn: vi.fn(),\n41\t  mockReadFileSync: vi.fn(),\n42\t  mockExistsSync: vi.fn(),\n43\t  mockParse: vi.fn(),\n44\t  mockGetDriver: vi.fn(),\n45\t  mockResolveModel: vi.fn(),\n46\t  mockDriverDispatch: vi.fn(),\n47\t  mockBuildPromptWithContractContext: vi.fn(),\n48\t  mockWriteOutputContract: vi.fn(),\n49\t  mockGenerateTraceId: vi.fn(),\n50\t  mockFormatTracePrompt: vi.fn(),\n51\t  mockRecordTraceId: vi.fn(),\n52\t  mockResolveSessionId: vi.fn(),\n53\t  mockRecordSessionId: vi.fn(),\n54\t  mockCreateIsolatedWorkspace: vi.fn(),\n55\t  mockGetNullTask: vi.fn(),\n56\t  mockListNullTasks: vi.fn(),\n57\t  mockReadStateWithBody: vi.fn(),\n58\t  mockWriteState: vi.fn(),\n59\t}));\n60\t\n61\tvi.mock('../agent-dispatch.js', () => ({\n62\t  dispatchAgent: vi.fn(),\n63\t  DispatchError: class DispatchError extends Error {\n64\t    public readonly code: string;\n65\t    public readonly agentName: string;\n66\t    public readonly cause: unknown;\n67\t    constructor(message: string, code: string, agentName: string, cause: unknown) {\n68\t      super(message);\n69\t      this.name = 'DispatchError';\n70\t      this.code = code;\n71\t      this.agentName = agentName;\n72\t      this.cause = cause;\n73\t    }\n74\t  },\n75\t}));\n76\t\n77\tvi.mock('../agents/drivers/factory.js', () => ({\n78\t  getDriver: mockGetDriver,\n79\t  suggestCheaperDriver: vi.fn().mockReturnValue(null),\n80\t  listDrivers: vi.fn().mockReturnValue([]),\n81\t}));\n82\t\n83\tvi.mock('../agents/capability-check.js', () => ({\n84\t  checkCapabilityConflicts: vi.fn().mockReturnValue([]),\n85\t}));\n86\t\n87\tvi.mock('../agents/model-resolver.js', () => ({\n88\t  resolveModel: mockResolveModel,\n89\t}));\n90\t\n91\tvi.mock('../workflow-state.js', () => ({\n92\t  readWorkflowState: mockReadWorkflowState,\n93\t  writeWorkflowState: mockWriteWorkflowState,\n94\t  getDefaultWorkflowState: () => ({\n95\t    workflow_name: '',\n96\t    started: '',\n97\t    iteration: 0,\n98\t    phase: 'idle',\n99\t    tasks_completed: [],\n100\t    evaluator_scores: [],\n101\t    circuit_breaker: { triggered: false, reason: null, score_history: [] },\n102\t    trace_ids: [],\n103\t  }),\n104\t}));\n105\t\n106\tvi.mock('../source-isolation.js', () => ({\n107\t  createIsolatedWorkspace: mockCreateIsolatedWorkspace,\n108\t}));\n109\t\n110\tvi.mock('../trace-id.js', () => ({\n111\t  generateTraceId: mockGenerateTraceId,\n112\t  formatTracePrompt: mockFormatTracePrompt,\n113\t  recordTraceId: mockRecordTraceId,\n114\t}));\n115\t\n116\tvi.mock('../session-manager.js', () => ({\n117\t  resolveSessionId: mockResolveSessionId,\n118\t  recordSessionId: mockRecordSessionId,\n119\t}));\n120\t\n121\tvi.mock('../output.js', () => ({\n122\t  warn: mockWarn,\n123\t}));\n124\t\n125\tvi.mock('../agents/output-contract.js', () => ({\n126\t  buildPromptWithContractContext: mockBuildPromptWithContractContext,\n127\t  writeOutputContract: mockWriteOutputContract,\n128\t}));\n129\t\n130\tvi.mock('node:fs', () => ({\n131\t  readFileSync: mockReadFileSync,\n132\t  existsSync: mockExistsSync,\n133\t}));\n134\t\n135\tvi.mock('yaml', () => ({\n136\t  parse: mockParse,\n137\t}));\n138\t\n139\tvi.mock('../null-task-registry.js', () => ({\n140\t  getNullTask: mockGetNullTask,\n141\t  listNullTasks: mockListNullTasks,\n142\t}));\n143\t\n144\tvi.mock('../../commands/state.js', () => ({\n145\t  readStateWithBody: mockReadStateWithBody,\n146\t  writeState: mockWriteState,\n147\t}));\n148\t\n149\tvi.mock('../circuit-breaker.js', () => ({\n150\t  evaluateProgress: vi.fn().mockReturnValue({ halt: false }),\n151\t}));\n152\t\n153\timport { executeWorkflow } from '../workflow-engine.js';\n154\timport type { EngineConfig } from '../workflow-engine.js';\n155\timport type { WorkflowState } from '../workflow-state.js';\n156\timport type { ResolvedWorkflow, ResolvedTask, ExecutionConfig } from '../workflow-parser.js';\n157\timport type { SubagentDefinition } from '../agent-resolver.js';\n158\t\n159\t// --- Helpers ---\n160\t\n161\tfunction makeDefaultState(overrides?: Partial<WorkflowState>): WorkflowState {\n162\t  return {\n163\t    workflow_name: '',\n164\t    started: '2026-04-03T00:00:00.000Z',\n165\t    iteration: 0,\n166\t    phase: 'idle',\n167\t    tasks_completed: [],\n168\t    evaluator_scores: [],\n169\t    circuit_breaker: { triggered: false, reason: null, score_history: [] },\n170\t    trace_ids: [],\n171\t    ...overrides,\n172\t  };\n173\t}\n174\t\n175\tfunction makeDefinition(overrides?: Partial<SubagentDefinition>): SubagentDefinition {\n176\t  return {\n177\t    name: 'test-agent',\n178\t    model: 'claude-sonnet-4-20250514',\n179\t    instructions: 'You are a test agent.',\n180\t    disallowedTools: [],\n181\t    bare: true,\n182\t    ...overrides,\n183\t  };\n184\t}\n185\t\n186\tfunction makeTask(overrides?: Partial<ResolvedTask>): ResolvedTask {\n187\t  return {\n188\t    agent: 'dev',\n189\t    scope: 'per-story',\n190\t    session: 'fresh',\n191\t    source_access: true,\n192\t    ...overrides,\n193\t  };\n194\t}\n195\t\n196\tconst defaultExecution: ExecutionConfig = {\n197\t  max_parallel: 1,\n198\t  isolation: 'none',\n199\t  merge_strategy: 'merge-commit',\n200\t  epic_strategy: 'sequential',\n201\t  story_strategy: 'sequential',\n202\t};\n203\t\n204\tfunction makeWorkflow(partial: {\n205\t  tasks: Record<string, ResolvedTask>;\n206\t  flow: (string | { loop: string[] })[];\n207\t  storyFlow?: (string | { loop: string[] })[];\n208\t}): ResolvedWorkflow {\n209\t  return {\n210\t    tasks: partial.tasks,\n211\t    flow: partial.flow,\n212\t    execution: defaultExecution,\n213\t    storyFlow: partial.storyFlow ?? partial.flow,\n214\t    epicFlow: [],\n215\t  };\n216\t}\n217\t\n218\tfunction makeConfig(overrides?: Partial<EngineConfig>): EngineConfig {\n219\t  return {\n220\t    workflow: makeWorkflow({\n221\t      tasks: {\n222\t        implement: makeTask(),\n223\t        verify: makeTask({ scope: 'per-run', source_access: false }),\n224\t      },\n225\t      flow: ['implement', 'verify'],\n226\t    }),\n227\t    agents: {\n228\t      dev: makeDefinition(),\n229\t    },\n230\t    sprintStatusPath: '/project/sprint-status.yaml',\n231\t    runId: 'run-001',\n232\t    projectDir: '/project',\n233\t    ...overrides,\n234\t  };\n235\t}\n236\t\n237\tfunction setupDefaultMocks() {\n238\t  mockReadWorkflowState.mockReturnValue(makeDefaultState());\n239\t  mockWriteWorkflowState.mockImplementation(() => {});\n240\t  mockBuildPromptWithContractContext.mockImplementation((basePrompt: string) => basePrompt);\n241\t  mockWriteOutputContract.mockImplementation(() => {});\n242\t  mockGenerateTraceId.mockReturnValue('ch-run-001-0-implement');\n243\t  mockFormatTracePrompt.mockReturnValue('[TRACE] trace_id=ch-run-001-0-implement');\n244\t  mockRecordTraceId.mockImplementation((_traceId: string, state: WorkflowState) => ({\n245\t    ...state,\n246\t    trace_ids: [...(state.trace_ids ?? []), _traceId],\n247\t  }));\n248\t  mockResolveSessionId.mockReturnValue(undefined);\n249\t  mockRecordSessionId.mockImplementation(\n250\t    (key: { taskName: string; storyKey: string }, sessionId: string, state: WorkflowState) => ({\n251\t      ...state,\n252\t      tasks_completed: [\n253\t        ...state.tasks_completed,\n254\t        {\n255\t          task_name: key.taskName,\n256\t          story_key: key.storyKey,\n257\t          completed_at: '2026-04-03T00:00:00.000Z',\n258\t          session_id: sessionId,\n259\t        },\n260\t      ],\n261\t    }),\n262\t  );\n263\t  mockDriverDispatch.mockImplementation(() => {\n264\t    return (async function* () {\n265\t      yield { type: 'text' as const, text: 'Done' };\n266\t      yield { type: 'result' as const, cost: 0.05, sessionId: 'sess-abc-123' };\n267\t    })();\n268\t  });\n269\t  mockGetDriver.mockReturnValue({\n270\t    name: 'claude-code',\n271\t    defaultModel: 'claude-sonnet-4-20250514',\n272\t    capabilities: { supportsPlugins: true, supportsStreaming: true, costReporting: true, costTier: 3 },\n273\t    healthCheck: vi.fn().mockResolvedValue({ available: true, authenticated: true, version: '1.0.0' }),\n274\t    dispatch: mockDriverDispatch,\n275\t    getLastCost: vi.fn().mockReturnValue(null),\n276\t  });\n277\t  mockResolveModel.mockReturnValue('claude-sonnet-4-20250514');\n278\t  mockExistsSync.mockImplementation((path: string) => {\n279\t    if (path === '/project/sprint-status.yaml') return true;\n280\t    return false;\n281\t  });\n282\t  mockReadFileSync.mockReturnValue('dummy yaml');\n283\t  mockParse.mockReturnValue({\n284\t    development_status: {\n285\t      'story-1': 'ready-for-dev',\n286\t    },\n287\t  });\n288\t  mockGetNullTask.mockImplementation((name: string) => {\n289\t    if (name === 'telemetry') {\n290\t      return async () => ({ success: true, output: 'telemetry collected' });\n291\t    }\n292\t    return undefined;\n293\t  });\n294\t  mockListNullTasks.mockReturnValue(['telemetry']);\n295\t  mockReadStateWithBody.mockReturnValue({\n296\t    state: {\n297\t      harness_version: '0.1.0',\n298\t      initialized: true,\n299\t      stack: 'node',\n300\t      stacks: ['node'],\n301\t      enforcement: { frontend: true, database: true, api: true },\n302\t      coverage: { target: 80, baseline: null, current: null, tool: 'c8' },\n303\t      session_flags: { logs_queried: false, tests_passed: false, coverage_met: false, verification_run: false },\n304\t      verification_log: [],\n305\t    },\n306\t    body: '\\n# Codeharness State\\n',\n307\t  });\n308\t}\n309\t\n310\t// --- Tests ---\n311\t\n312\tdescribe('Story Flow Execution (Story 16-6)', () => {\n313\t  beforeEach(() => {\n314\t    vi.clearAllMocks();\n315\t    setupDefaultMocks();\n316\t  });\n317\t\n318\t  describe('AC #1: storyFlow executes steps in order', () => {\n319\t    it('executes storyFlow steps sequentially (implement, verify, telemetry)', async () => {\n320\t      const executionOrder: string[] = [];\n321\t\n322\t      mockGetNullTask.mockImplementation((name: string) => {\n323\t        if (name === 'telemetry') {\n324\t          return async () => {\n325\t            executionOrder.push('telemetry');\n326\t            return { success: true, output: 'ok' };\n327\t          };\n328\t        }\n329\t        return undefined;\n330\t      });\n331\t\n332\t      mockDriverDispatch.mockImplementation(() => {\n333\t        return (async function* () {\n334\t          executionOrder.push('agent-task');\n335\t          yield { type: 'text' as const, text: 'Done' };\n336\t          yield { type: 'result' as const, cost: 0.05, sessionId: 'sess-1' };\n337\t        })();\n338\t      });\n339\t\n340\t      const config = makeConfig({\n341\t        workflow: makeWorkflow({\n342\t          tasks: {\n343\t            implement: makeTask(),\n344\t            verify: makeTask({ scope: 'per-run' }),\n345\t            telemetry: makeTask({ agent: null, scope: 'per-run' }),\n346\t          },\n347\t          flow: ['implement', 'verify', 'telemetry'],\n348\t        }),\n349\t      });\n350\t\n351\t      const result = await executeWorkflow(config);\n352\t\n353\t      expect(result.success).toBe(true);\n354\t      expect(result.tasksCompleted).toBe(3);\n355\t      // Agent tasks run in order, followed by null task\n356\t      expect(executionOrder).toEqual(['agent-task', 'agent-task', 'telemetry']);\n357\t    });\n358\t  });\n359\t\n360\t  describe('AC #2: telemetry null task executes after loop completes', () => {\n361\t    it('runs telemetry after loop exits early on pass', async () => {\n362\t      const executionOrder: string[] = [];\n363\t\n364\t      mockGetNullTask.mockImplementation((name: string) => {\n365\t        if (name === 'telemetry') {\n366\t          return async () => {\n367\t            executionOrder.push('telemetry');\n368\t            return { success: true, output: 'ok' };\n369\t          };\n370\t        }\n371\t        return undefined;\n372\t      });\n373\t\n374\t      // Make implement and verify tasks dispatch through the driver\n375\t      let callCount = 0;\n376\t      mockDriverDispatch.mockImplementation(() => {\n377\t        callCount++;\n378\t        return (async function* () {\n379\t          executionOrder.push(`driver-call-${callCount}`);\n380\t          yield { type: 'text' as const, text: 'Done' };\n381\t          yield { type: 'result' as const, cost: 0.01, sessionId: `sess-${callCount}` };\n382\t        })();\n383\t      });\n384\t\n385\t      // Use simple flow: implement then telemetry (no loop, to verify post-task ordering)\n386\t      const config = makeConfig({\n387\t        workflow: makeWorkflow({\n388\t          tasks: {\n389\t            implement: makeTask({ scope: 'per-run' }),\n390\t            telemetry: makeTask({ agent: null, scope: 'per-run' }),\n391\t          },\n392\t          flow: ['implement', 'telemetry'],\n393\t        }),\n394\t      });\n395\t\n396\t      const result = await executeWorkflow(config);\n397\t\n398\t      expect(result.success).toBe(true);\n399\t      expect(executionOrder).toEqual(['driver-call-1', 'telemetry']);\n400\t    });\n401\t\n402\t    it('does NOT run telemetry when loop triggers circuit-breaker halt', async () => {\n403\t      // Import evaluateProgress to control it\n404\t      const { evaluateProgress } = await import('../circuit-breaker.js');\n405\t      const mockEvaluateProgress = vi.mocked(evaluateProgress);\n406\t\n407\t      // Circuit breaker triggers halt on first evaluation\n408\t      mockEvaluateProgress.mockReturnValue({ halt: true, reason: 'test-cb-halt' });\n409\t\n410\t      const telemetryHandler = vi.fn().mockResolvedValue({ success: true, output: 'ok' });\n411\t      mockGetNullTask.mockImplementation((name: string) => {\n412\t        if (name === 'telemetry') return telemetryHandler;\n413\t        return undefined;\n414\t      });\n415\t\n416\t      mockDriverDispatch.mockImplementation(() => {\n417\t        return (async function* () {\n418\t          yield { type: 'text' as const, text: 'Done' };\n419\t          yield {\n420\t            type: 'result' as const,\n421\t            cost: 0.01,\n422\t            sessionId: 'sess-1',\n423\t            subagentResult: JSON.stringify({ verdict: 'fail' }),\n424\t          };\n425\t        })();\n426\t      });\n427\t\n428\t      const config = makeConfig({\n429\t        workflow: makeWorkflow({\n430\t          tasks: {\n431\t            implement: makeTask(),\n432\t            verify: makeTask({ scope: 'per-run' }),\n433\t            telemetry: makeTask({ agent: null, scope: 'per-run' }),\n434\t          },\n435\t          flow: [\n436\t            'implement',\n437\t            { loop: ['implement', 'verify'] },\n438\t            'telemetry',\n439\t          ],\n440\t        }),\n441\t      });\n442\t\n443\t      const result = await executeWorkflow(config);\n444\t\n445\t      // Telemetry should NOT run because circuit-breaker halted the engine\n446\t      expect(telemetryHandler).not.toHaveBeenCalled();\n447\t      // Engine reports halted state\n448\t      expect(result.success).toBe(false);\n449\t    });\n450\t  });\n451\t\n452\t  describe('AC #3: loop semantics preserved under storyFlow', () => {\n453\t    it('executes loop block within storyFlow with max iterations respected', async () => {\n454\t      const { evaluateProgress } = await import('../circuit-breaker.js');\n455\t      const mockEvaluateProgress = vi.mocked(evaluateProgress);\n456\t      mockEvaluateProgress.mockReturnValue({ halt: false });\n457\t\n458\t      let dispatchCount = 0;\n459\t      mockDriverDispatch.mockImplementation(() => {\n460\t        dispatchCount++;\n461\t        return (async function* () {\n462\t          yield { type: 'text' as const, text: 'Done' };\n463\t          yield {\n464\t            type: 'result' as const,\n465\t            cost: 0.01,\n466\t            sessionId: `sess-${dispatchCount}`,\n467\t            subagentResult: JSON.stringify({ verdict: 'fail' }),\n468\t          };\n469\t        })();\n470\t      });\n471\t\n472\t      const config = makeConfig({\n473\t        workflow: makeWorkflow({\n474\t          tasks: {\n475\t            implement: makeTask({ scope: 'per-run' }),\n476\t            retry: makeTask(),\n477\t            verify: makeTask({ scope: 'per-run' }),\n478\t          },\n479\t          flow: [\n480\t            'implement',\n481\t            { loop: ['retry', 'verify'] },\n482\t          ],\n483\t        }),\n484\t      });\n485\t\n486\t      const result = await executeWorkflow(config);\n487\t\n488\t      // The loop should have executed — dispatch should be called more than once\n489\t      expect(dispatchCount).toBeGreaterThan(1);\n490\t      // Engine should complete (possibly with max-iterations)\n491\t      expect(result).toBeDefined();\n492\t    });\n493\t  });\n494\t\n495\t  describe('AC #4: backward compatibility with legacy flow', () => {\n496\t    it('workflow with only flow (no story_flow) works identically', async () => {\n497\t      // This test verifies that makeWorkflow sets storyFlow = flow,\n498\t      // matching the behavior of resolveHierarchicalFlow for legacy workflows\n499\t      const config = makeConfig({\n500\t        workflow: makeWorkflow({\n501\t          tasks: {\n502\t            implement: makeTask({ scope: 'per-run' }),\n503\t          },\n504\t          flow: ['implement'],\n505\t        }),\n506\t      });\n507\t\n508\t      // storyFlow should equal flow\n509\t      expect(config.workflow.storyFlow).toEqual(config.workflow.flow);\n510\t\n511\t      const result = await executeWorkflow(config);\n512\t\n513\t      expect(result.success).toBe(true);\n514\t      expect(result.tasksCompleted).toBe(1);\n515\t    });\n516\t\n517\t    it('ResolvedWorkflow.flow field remains populated', () => {\n518\t      const workflow = makeWorkflow({\n519\t        tasks: { implement: makeTask() },\n520\t        flow: ['implement'],\n521\t      });\n522\t\n523\t      expect(workflow.flow).toEqual(['implement']);\n524\t      expect(workflow.storyFlow).toEqual(['implement']);\n525\t    });\n526\t  });\n527\t\n528\t  describe('AC #5: engine reads storyFlow from resolved workflow', () => {\n529\t    it('uses storyFlow (not flow) when they differ', async () => {\n530\t      const executionOrder: string[] = [];\n531\t\n532\t      mockGetNullTask.mockImplementation((name: string) => {\n533\t        if (name === 'telemetry') {\n534\t          return async () => {\n535\t            executionOrder.push('telemetry');\n536\t            return { success: true, output: 'ok' };\n537\t          };\n538\t        }\n539\t        return undefined;\n540\t      });\n541\t\n542\t      mockDriverDispatch.mockImplementation(() => {\n543\t        return (async function* () {\n544\t          executionOrder.push('driver');\n545\t          yield { type: 'text' as const, text: 'Done' };\n546\t          yield { type: 'result' as const, cost: 0.01, sessionId: 'sess-1' };\n547\t        })();\n548\t      });\n549\t\n550\t      // Simulate a case where storyFlow differs from flow\n551\t      // (this would happen with story_flow: in YAML resolved differently)\n552\t      const config = makeConfig({\n553\t        workflow: makeWorkflow({\n554\t          tasks: {\n555\t            implement: makeTask({ scope: 'per-run' }),\n556\t            verify: makeTask({ scope: 'per-run' }),\n557\t            telemetry: makeTask({ agent: null, scope: 'per-run' }),\n558\t          },\n559\t          flow: ['implement'],\n560\t          storyFlow: ['implement', 'telemetry'],\n561\t        }),\n562\t      });\n563\t\n564\t      const result = await executeWorkflow(config);\n565\t\n566\t      expect(result.success).toBe(true);\n567\t      // Engine should execute storyFlow (implement + telemetry), not flow (just implement)\n568\t      expect(executionOrder).toEqual(['driver', 'telemetry']);\n569\t      expect(result.tasksCompleted).toBe(2);\n570\t    });\n571\t  });\n572\t\n573\t  describe('AC #6: workflow_name derived from storyFlow', () => {\n574\t    it('derives workflow_name from storyFlow steps, not flow', async () => {\n575\t      const config = makeConfig({\n576\t        workflow: makeWorkflow({\n577\t          tasks: {\n578\t            implement: makeTask({ scope: 'per-run' }),\n579\t            verify: makeTask({ scope: 'per-run' }),\n580\t            telemetry: makeTask({ agent: null, scope: 'per-run' }),\n581\t          },\n582\t          flow: ['implement'],\n583\t          storyFlow: ['implement', 'verify', 'telemetry'],\n584\t        }),\n585\t      });\n586\t\n587\t      await executeWorkflow(config);\n588\t\n589\t      // writeWorkflowState is called with state that has workflow_name derived from storyFlow\n590\t      const stateWrites = mockWriteWorkflowState.mock.calls;\n591\t      const firstWrite = stateWrites[0]?.[0] as WorkflowState | undefined;\n592\t      expect(firstWrite).toBeDefined();\n593\t      // storyFlow has implement, verify, telemetry (all strings) -> \"implement -> verify -> telemetry\"\n594\t      expect(firstWrite!.workflow_name).toBe('implement -> verify -> telemetry');\n595\t    });\n596\t\n597\t    it('workflow_name filters out loop blocks (only string steps)', async () => {\n598\t      const config = makeConfig({\n599\t        workflow: makeWorkflow({\n600\t          tasks: {\n601\t            implement: makeTask({ scope: 'per-run' }),\n602\t            verify: makeTask({ scope: 'per-run' }),\n603\t            retry: makeTask(),\n604\t          },\n605\t          flow: ['implement', { loop: ['retry', 'verify'] }],\n606\t        }),\n607\t      });\n608\t\n609\t      await executeWorkflow(config);\n610\t\n611\t      const stateWrites = mockWriteWorkflowState.mock.calls;\n612\t      const firstWrite = stateWrites[0]?.[0] as WorkflowState | undefined;\n613\t      expect(firstWrite).toBeDefined();\n614\t      // Only 'implement' is a string step; loop block is filtered out\n615\t      expect(firstWrite!.workflow_name).toBe('implement');\n616\t    });\n617\t  });\n618\t\n619\t  describe('storyFlow with multiple per-story tasks', () => {\n620\t    it('iterates all work items for each per-story task in storyFlow', async () => {\n621\t      const dispatched: Array<{ task: string; story: string }> = [];\n622\t\n623\t      mockParse.mockReturnValue({\n624\t        development_status: {\n625\t          'story-1': 'ready-for-dev',\n626\t          'story-2': 'ready-for-dev',\n627\t        },\n628\t      });\n629\t\n630\t      let dispatchIdx = 0;\n631\t      mockDriverDispatch.mockImplementation(() => {\n632\t        dispatchIdx++;\n633\t        return (async function* () {\n634\t          yield { type: 'text' as const, text: 'Done' };\n635\t          yield { type: 'result' as const, cost: 0.01, sessionId: `sess-${dispatchIdx}` };\n636\t        })();\n637\t      });\n638\t\n639\t      const config = makeConfig({\n640\t        workflow: makeWorkflow({\n641\t          tasks: {\n642\t            implement: makeTask({ scope: 'per-story' }),\n643\t            verify: makeTask({ scope: 'per-story' }),\n644\t          },\n645\t          flow: ['implement', 'verify'],\n646\t        }),\n647\t      });\n648\t\n649\t      const result = await executeWorkflow(config);\n650\t\n651\t      expect(result.success).toBe(true);\n652\t      // 2 stories * 2 tasks = 4 total dispatches\n653\t      expect(result.tasksCompleted).toBe(4);\n654\t    });\n655\t  });\n656\t\n657\t  describe('empty storyFlow', () => {\n658\t    it('completes immediately with no steps', async () => {\n659\t      const config = makeConfig({\n660\t        workflow: {\n661\t          tasks: {},\n662\t          flow: [],\n663\t          storyFlow: [],\n664\t          epicFlow: [],\n665\t          execution: defaultExecution,\n666\t        },\n667\t      });\n668\t\n669\t      const result = await executeWorkflow(config);\n670\t\n671\t      expect(result.success).toBe(true);\n672\t      expect(result.tasksCompleted).toBe(0);\n673\t    });\n674\t  });\n675\t});\n676\t"}]},"parent_tool_use_id":"toolu_01QNNr4yQoQQfPTTg7FsQuMG","session_id":"e648a229-0e5b-4ea4-9861-593afdfcccd5","uuid":"4b5d711a-7546-4316-8c1c-df08a51f21fa","timestamp":"2026-04-03T19:01:50.269Z"}
