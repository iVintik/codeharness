l: '', cwd: '', sourceAccess: true }),\n      );\n\n      expect(mockSpawn).toHaveBeenCalledWith(\n        'codex',\n        ['hello'],\n        { stdio: ['ignore', 'pipe', 'pipe'] },\n      );\n    });\n  });\n\n  describe('barrel export (AC #9)', () => {"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1004,"cache_read_input_tokens":53750,"cache_creation":{"ephemeral_5m_input_tokens":1004,"ephemeral_1h_input_tokens":0},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01JbXzRAzkG8BRgjQTeRY35M","session_id":"576f74f4-0d7f-4316-a569-4c3ab5c122fd","uuid":"d04cbdc0-2bf8-445c-8797-13630297f3ed"}
