{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NaJVxjspvk7raEbVRHxSKG","type":"tool_result","content":"1\t/**\n2\t * Telemetry Writer.\n3\t *\n4\t * Writes structured NDJSON telemetry entries after each story completes.\n5\t * Entries are appended to `.codeharness/telemetry.jsonl` for later analysis\n6\t * by epic retros — no per-session LLM cost.\n7\t *\n8\t * @see Story 16-3: Telemetry Writer\n9\t */\n10\t\n11\timport { appendFileSync, existsSync, mkdirSync, readFileSync } from 'node:fs';\n12\timport { join } from 'node:path';\n13\t\n14\timport type { ACStatus, TestResults } from './agents/types.js';\n15\timport type { TaskContext, NullTaskResult } from './null-task-registry.js';\n16\t\n17\t// --- Interfaces ---\n18\t\n19\t/**\n20\t * Summary of test results stored in telemetry.\n21\t */\n22\texport interface TestResultsSummary {\n23\t  readonly passed: number;\n24\t  readonly failed: number;\n25\t  readonly coverage: number | null;\n26\t}\n27\t\n28\t/**\n29\t * Acceptance criteria result stored in telemetry.\n30\t */\n31\texport interface ACResult {\n32\t  readonly id: string;\n33\t  readonly description: string;\n34\t  readonly status: string;\n35\t}\n36\t\n37\t/**\n38\t * A single telemetry entry written as one NDJSON line.\n39\t */\n40\texport interface TelemetryEntry {\n41\t  version: 1;\n42\t  timestamp: string;\n43\t  storyKey: string;\n44\t  epicId: string;\n45\t  duration_ms: number;\n46\t  cost_usd: number | null;\n47\t  attempts: number | null;\n48\t  acResults: ACResult[] | null;\n49\t  filesChanged: string[];\n50\t  testResults: TestResultsSummary | null;\n51\t  errors: string[];\n52\t}\n53\t\n54\t// --- Constants ---\n55\t\n56\tconst TELEMETRY_DIR = '.codeharness';\n57\tconst TELEMETRY_FILE = 'telemetry.jsonl';\n58\t\n59\t// --- Functions ---\n60\t\n61\t/**\n62\t * Extract epicId from a storyKey.\n63\t * Pattern: `{epicNum}-{storyNum}-{slug}` -> `{epicNum}`.\n64\t * Sentinel `__run__` -> `\"unknown\"`.\n65\t */\n66\tfunction extractEpicId(storyKey: string): string {\n67\t  if (storyKey === '__run__') return 'unknown';\n68\t  const dash = storyKey.indexOf('-');\n69\t  if (dash === -1) return storyKey;\n70\t  return storyKey.slice(0, dash);\n71\t}\n72\t\n73\t/**\n74\t * Write a telemetry entry after a story completes.\n75\t *\n76\t * Appends one NDJSON line to `.codeharness/telemetry.jsonl`.\n77\t * Creates the `.codeharness/` directory if it does not exist.\n78\t */\n79\texport async function writeTelemetryEntry(ctx: TaskContext): Promise<NullTaskResult> {\n80\t  const epicId = extractEpicId(ctx.storyKey);\n81\t  const contract = ctx.outputContract;\n82\t\n83\t  const entry: TelemetryEntry = {\n84\t    version: 1,\n85\t    timestamp: new Date().toISOString(),\n86\t    storyKey: ctx.storyKey,\n87\t    epicId,\n88\t    duration_ms: ctx.durationMs,\n89\t    cost_usd: ctx.cost ?? null,\n90\t    attempts: null,\n91\t    acResults: contract?.acceptanceCriteria\n92\t      ? (contract.acceptanceCriteria as readonly ACStatus[]).map((ac) => ({\n93\t          id: ac.id,\n94\t          description: ac.description,\n95\t          status: ac.status,\n96\t        }))\n97\t      : null,\n98\t    filesChanged: contract?.changedFiles ? [...contract.changedFiles] : [],\n99\t    testResults: contract?.testResults\n100\t      ? {\n101\t          passed: contract.testResults.passed,\n102\t          failed: contract.testResults.failed,\n103\t          coverage: contract.testResults.coverage,\n104\t        }\n105\t      : null,\n106\t    errors: [],\n107\t  };\n108\t\n109\t  const dir = join(ctx.projectDir, TELEMETRY_DIR);\n110\t  mkdirSync(dir, { recursive: true });\n111\t  appendFileSync(join(dir, TELEMETRY_FILE), JSON.stringify(entry) + '\\n');\n112\t\n113\t  return { success: true, output: `telemetry: entry written for ${ctx.storyKey}` };\n114\t}\n115\t\n116\t/**\n117\t * Read telemetry entries for a specific epic.\n118\t *\n119\t * Returns entries whose `epicId` matches, in insertion order.\n120\t * Returns `[]` if the file does not exist.\n121\t * Skips corrupted (non-JSON) lines silently.\n122\t */\n123\texport function readTelemetryForEpic(epicId: string, projectDir?: string): TelemetryEntry[] {\n124\t  const dir = projectDir ?? process.cwd();\n125\t  const filePath = join(dir, TELEMETRY_DIR, TELEMETRY_FILE);\n126\t\n127\t  if (!existsSync(filePath)) return [];\n128\t\n129\t  const content = readFileSync(filePath, 'utf-8');\n130\t  const lines = content.split('\\n').filter((line) => line.trim() !== '');\n131\t  const entries: TelemetryEntry[] = [];\n132\t\n133\t  for (const line of lines) {\n134\t    try {\n135\t      const parsed = JSON.parse(line) as TelemetryEntry;\n136\t      if (parsed.epicId === epicId) {\n137\t        entries.push(parsed);\n138\t      }\n139\t    } catch {\n140\t      // Skip corrupted lines\n141\t    }\n142\t  }\n143\t\n144\t  return entries;\n145\t}\n146\t"}]},"parent_tool_use_id":"toolu_01EThU22wRDbXmvukgem8PY8","session_id":"3330d992-072a-4898-af8b-5f3f7e12cbac","uuid":"3f3805a8-cad9-40dd-b88f-78388359f99b","timestamp":"2026-04-03T17:45:17.470Z"}
