ect(mockInstrumentProject).toHaveBeenCalledTimes(1);\n   578→    expect(mockInstrumentProject.mock.calls[0][1]).toBe('nodejs');\n   579→  });\n   580→\n   581→  it('OTLP result.otlp comes from root detection, not first matching stack name', async () => {\n   582→    writeFileSync(join(testDir, 'package.json'), '{}');\n   583→    // Subdirectory detection appears first but root detection appears second\n   584→    mockDetectStacks.mockReturnValue([\n   585→      { stack: 'nodejs', dir: 'packages/app' },\n   586→      { stack: 'nodejs', dir: '.' },\n   587→    ]);\n   588→    const rootOtlp = { status: 'configured' as const, packages_installed: true, start_script_patched: true, env_vars_configured: true };\n   589→    const subOtlp = { status: 'configured' as const, packages_installed: false, start_script_patched: false, env_vars_configured: false };\n   590→    mockInstrumentProject.mockClear();\n   591→    mockInstrumentProject.mockReturnValueOnce(subOtlp).mockReturnValueOnce(rootOtlp);\n   592→\n   593→    const result = await initProject(makeOpts({ observability: true }));\n   594→\n   595→    expect(result.success).toBe(true);\n   596→    if (result.success) {\n   597→      // result.otlp should be from the root detection (dir === '.'), not the subdirectory\n   598→      expect(result.data.otlp).toEqual(rootOtlp);\n   599→    }\n   600→  });\n   601→});\n   602→"}]},"parent_tool_use_id":"toolu_013rWcam9ZLGWy8y97T6yhWS","session_id":"790cd04c-5c91-45bb-998d-78a56b65af9a","uuid":"df3d2241-9b2d-477b-a23d-cd41734d0568","timestamp":"2026-03-24T23:17:12.569Z"}
