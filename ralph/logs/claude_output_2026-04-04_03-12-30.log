{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01X5GvpPj6DhKpDF4Mu6jACR","type":"tool_result","content":"1\t/**\n2\t * Worktree Manager.\n3\t *\n4\t * Handles git worktree lifecycle for parallel epic execution:\n5\t * create, cleanup, list, and orphan detection. Each epic gets\n6\t * its own git worktree on a dedicated branch under the\n7\t * `codeharness/` namespace.\n8\t *\n9\t * @see Story 17-1: Worktree Manager\n10\t * @see Story 18-2: Merge Agent for Conflict Resolution (onConflict callback)\n11\t */\n12\t\n13\timport { execSync } from 'node:child_process';\n14\timport { existsSync, readFileSync, statSync } from 'node:fs';\n15\timport { join } from 'node:path';\n16\t\n17\timport type { ConflictResolutionResult } from './merge-agent.js';\n18\timport { validateMerge } from './cross-worktree-validator.js';\n19\t\n20\t/**\n21\t * Partial conflict context that mergeWorktree can fill from its own state.\n22\t * The onConflict callback receives this and enriches it with driver/descriptions\n23\t * before calling the merge agent.\n24\t */\n25\texport interface MergeConflictInfo {\n26\t  readonly epicId: string;\n27\t  readonly branch: string;\n28\t  readonly conflicts: string[];\n29\t  readonly cwd: string;\n30\t  readonly testCommand: string;\n31\t}\n32\t\n33\t// --- Constants ---\n34\t\n35\t/** Branch prefix for all codeharness worktree branches. */\n36\texport const BRANCH_PREFIX = 'codeharness/epic-';\n37\t\n38\t/** Base path for worktree directories in /tmp. */\n39\texport const WORKTREE_BASE = '/tmp/codeharness-wt-epic-';\n40\t\n41\t// --- Interfaces ---\n42\t\n43\t/**\n44\t * Information about a codeharness worktree.\n45\t */\n46\texport interface WorktreeInfo {\n47\t  /** Epic identifier extracted from the branch name. */\n48\t  readonly epicId: string;\n49\t  /** Absolute path to the worktree directory. */\n50\t  readonly path: string;\n51\t  /** Full branch name (e.g., `codeharness/epic-17-worktree-manager`). */\n52\t  readonly branch: string;\n53\t  /** Timestamp when the worktree was created. */\n54\t  readonly createdAt: Date;\n55\t}\n56\t\n57\t// --- Error Class ---\n58\t\n59\t/**\n60\t * Error thrown by worktree operations. Includes stderr from git commands.\n61\t */\n62\texport class WorktreeError extends Error {\n63\t  /** Raw stderr output from the failed git command. */\n64\t  readonly stderr: string;\n65\t\n66\t  constructor(message: string, stderr: string) {\n67\t    super(message);\n68\t    this.name = 'WorktreeError';\n69\t    this.stderr = stderr;\n70\t  }\n71\t}\n72\t\n73\t// --- Merge Types ---\n74\t\n75\t/**\n76\t * Strategy used when merging an epic branch into main.\n77\t */\n78\texport type MergeStrategy = 'rebase' | 'merge-commit';\n79\t\n80\t/**"}]},"parent_tool_use_id":"toolu_012S3gEG5fgffqjQviRFDsvE","session_id":"d383a9e0-3bc4-4a94-aaff-6965a5cc223b","uuid":"0f3a8ce9-178c-4c9b-b81a-e9878277b4a2","timestamp":"2026-04-03T23:27:43.476Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ts8B7k7XB9jYtvKa5eALLC","type":"tool_result","content":"1\t/**\n2\t * Cross-Worktree Validator.\n3\t *\n4\t * Encapsulates the test-run-after-merge logic extracted from\n5\t * worktree-manager.ts and merge-agent.ts. Both modules delegate\n6\t * to validateMerge() instead of maintaining their own runTestSuite\n7\t * and parseTestOutput implementations.\n8\t *\n9\t * @see Story 18-3: Cross-Worktree Test Validation\n10\t */\n11\t\n12\timport { exec } from 'node:child_process';\n13\timport { appendFileSync, mkdirSync } from 'node:fs';\n14\timport { join } from 'node:path';\n15\timport { promisify } from 'node:util';\n16\t\n17\timport type { TelemetryEntry } from './telemetry-writer.js';\n18\t\n19\tconst execAsync = promisify(exec);\n20\t\n21\t/** 10 MB — generous buffer for verbose test + coverage output. */\n22\tconst MAX_BUFFER = 10 * 1024 * 1024;\n23\t\n24\t// --- Interfaces ---\n25\t\n26\t/**\n27\t * Options for running post-merge test validation.\n28\t */\n29\texport interface ValidateMergeOptions {\n30\t  /** Command to run for test validation. */\n31\t  readonly testCommand: string;\n32\t  /** Working directory to run the test command in. */\n33\t  readonly cwd: string;\n34\t  /** Epic identifier for telemetry. */\n35\t  readonly epicId: string;\n36\t  /** Optional story key override for telemetry (defaults to `merge-{epicId}`). */\n37\t  readonly storyKey?: string;\n38\t  /** Whether to write a telemetry entry after the test suite completes. */\n39\t  readonly writeTelemetry: boolean;\n40\t}\n41\t\n42\t/**\n43\t * Result of a post-merge test validation.\n44\t */\n45\texport interface ValidationResult {\n46\t  /** Whether all tests passed (passed > 0 and failed === 0). */\n47\t  readonly valid: boolean;\n48\t  /** Parsed test results: pass/fail counts and coverage (null if not reported). */\n49\t  readonly testResults: { passed: number; failed: number; coverage: number | null };\n50\t  /** Raw test command stdout+stderr for retry context. */\n51\t  readonly output: string;\n52\t  /** Wall-clock duration of the test run in milliseconds. */\n53\t  readonly durationMs: number;\n54\t}\n55\t\n56\t// --- Constants ---\n57\t\n58\tconst TELEMETRY_DIR = '.codeharness';\n59\tconst TELEMETRY_FILE = 'telemetry.jsonl';\n60\tconst TEST_TIMEOUT_MS = 300_000; // 5 minutes\n61\t\n62\t// --- Test Output Parsing ---\n63\t\n64\t/**\n65\t * Parse test output to extract pass/fail counts and optional coverage.\n66\t * Supports vitest/jest output patterns.\n67\t */\n68\texport function parseTestOutput(stdout: string): { passed: number; failed: number; coverage: number | null } {\n69\t  let passed = 0;\n70\t  let failed = 0;\n71\t  let coverage: number | null = null;\n72\t\n73\t  const passMatch = stdout.match(/(\\d+)\\s+passed/);\n74\t  const failMatch = stdout.match(/(\\d+)\\s+failed/);\n75\t  if (passMatch) passed = parseInt(passMatch[1], 10);\n76\t  if (failMatch) failed = parseInt(failMatch[1], 10);\n77\t\n78\t  const covMatch = stdout.match(/All files[^|]*\\|\\s*([\\d.]+)/);\n79\t  if (covMatch) coverage = parseFloat(covMatch[1]);\n80\t"}]},"parent_tool_use_id":"toolu_012S3gEG5fgffqjQviRFDsvE","session_id":"d383a9e0-3bc4-4a94-aaff-6965a5cc223b","uuid":"cddc7871-2d16-438c-a34c-2d90ad17e57e","timestamp":"2026-04-03T23:27:43.475Z"}
