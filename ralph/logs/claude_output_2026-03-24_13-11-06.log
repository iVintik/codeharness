{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0114teU9H3nsJe4BcorezMWn","type":"tool_result","content":"     1→import { existsSync, readFileSync, readdirSync } from 'node:fs';\n     2→import { join } from 'node:path';\n     3→import { warn } from './output.js';\n     4→\n     5→// Re-export canonical types from stacks/types.ts for backward compatibility.\n     6→// Existing consumers that `import { StackName, AppType } from './stack-detect.js'` continue to work.\n     7→export type { StackName, AppType } from './stacks/types.js';\n     8→\n     9→export interface StackDetection {\n    10→  stack: StackName;\n    11→  dir: string;\n    12→}\n    13→\n    14→/** Directories to skip during subdirectory scanning. */\n    15→const SKIP_DIRS = new Set([\n    16→  'node_modules',\n    17→  '.git',\n    18→  'target',\n    19→  '__pycache__',\n    20→  'dist',\n    21→  'build',\n    22→  'coverage',\n    23→  '.venv',\n    24→  'venv',\n    25→  '.tox',\n    26→  '.mypy_cache',\n    27→  '.cache',\n    28→]);\n    29→\n    30→/** Stack markers in priority order (nodejs > python > rust). */\n    31→const STACK_MARKERS: Array<{ stack: StackName; files: string[] }> = [\n    32→  { stack: 'nodejs', files: ['package.json'] },\n    33→  { stack: 'python', files: ['requirements.txt', 'pyproject.toml', 'setup.py'] },\n    34→  { stack: 'rust', files: ['Cargo.toml'] },\n    35→];\n    36→\n    37→/**\n    38→ * Detect all stacks present in a directory, checking root and one level of subdirectories.\n    39→ * Root stacks appear first (in priority order: nodejs > python > rust),\n    40→ * then subdirectory stacks sorted alphabetically by directory name.\n    41→ */\n    42→export function detectStacks(dir: string = process.cwd()): StackDetection[] {\n    43→  const results: StackDetection[] = [];\n    44→\n    45→  // Root scan — check all markers, no early return\n    46→  for (const marker of STACK_MARKERS) {\n    47→    for (const file of marker.files) {\n    48→      if (existsSync(join(dir, file))) {\n    49→        results.push({ stack: marker.stack, dir: '.' });\n    50→        break; // Only add each stack once for root\n    51→      }\n    52→    }\n    53→  }\n    54→\n    55→  // Subdirectory scan — one level deep\n    56→  let entries: import('node:fs').Dirent[];\n    57→  try {\n    58→    entries = readdirSync(dir, { withFileTypes: true });\n    59→  } catch {\n    60→    entries = [];\n    61→  }\n    62→\n    63→  const subdirs = entries\n    64→    .filter((e) => e.isDirectory() && !SKIP_DIRS.has(e.name))\n    65→    .map((e) => e.name)\n    66→    .sort();\n    67→\n    68→  for (const subdir of subdirs) {\n    69→    const subdirPath = join(dir, subdir);\n    70→    for (const marker of STACK_MARKERS) {\n    71→      for (const file of marker.files) {\n    72→        if (existsSync(join(subdirPath, file))) {\n    73→          results.push({ stack: marker.stack, dir: subdir });\n    74→          break; // Only add each stack once per subdir\n    75→        }\n    76→      }\n    77→    }\n    78→  }\n    79→\n    80→  return results;\n    81→}\n    82→\n    83→/**\n    84→ * Compat wrapper: returns the first detected ROOT stack name, or null.\n    85→ * Preserves the original single-stack, root-only API for existing callers.\n    86→ * Only considers root-level markers (dir === '.'), never subdirectory detections,\n    87→ * so callers like init-project and state that operate on the root directory\n    88→ * are not surprised by a stack detected in a subdirectory.\n    89→ */\n    90→export function detectStack(dir: string = process.cwd()): string | null {\n    91→  const stacks = detectStacks(dir);\n    92→  const rootStack = stacks.find((s) => s.dir === '.');\n    93→  if (rootStack) return rootStack.stack;\n    94→  warn('No recognized stack detected');\n    95→  return null;\n    96→}\n    97→\n    98→const AGENT_DEPS_NODE = ['anthropic', '@anthropic-ai/sdk', 'openai', 'langchain', '@langchain/core', 'llamaindex'];\n    99→const AGENT_DEPS_PYTHON = ['anthropic', 'openai', 'langchain', 'llama-index', 'traceloop-sdk'];\n   100→const WEB_FRAMEWORK_DEPS = ['react', 'vue', 'svelte', 'angular', '@angular/core', 'next', 'nuxt', 'vite', 'webpack'];\n   101→const PYTHON_WEB_FRAMEWORKS = ['flask', 'django', 'fastapi', 'streamlit'];\n   102→const RUST_WEB_FRAMEWORKS = ['actix-web', 'axum', 'rocket', 'tide', 'warp'];\n   103→const RUST_AGENT_DEPS = ['async-openai', 'anthropic', 'llm-chain'];\n   104→\n   105→function readJsonSafe(path: string): Record<string, unknown> | null {\n   106→  try {\n   107→    if (!existsSync(path)) return null;\n   108→    return JSON.parse(readFileSync(path, 'utf-8')) as Record<string, unknown>;\n   109→  } catch {\n   110→    return null;\n   111→  }\n   112→}\n   113→\n   114→function readTextSafe(path: string): string | null {\n   115→  try {\n   116→    if (!existsSync(path)) return null;\n   117→    return readFileSync(path, 'utf-8');\n   118→  } catch {\n   119→    return null;\n   120→  }\n   121→}\n   122→\n   123→function getNodeDeps(pkg: Record<string, unknown>): Set<string> {\n   124→  const deps = new Set<string>();\n   125→  for (const field of ['dependencies', 'devDependencies']) {\n   126→    const section = pkg[field] as Record<string, string> | undefined;\n   127→    if (section && typeof section === 'object') {\n   128→      for (const key of Object.keys(section)) {\n   129→        deps.add(key);\n   130→      }\n   131→    }\n   132→  }\n   133→  return deps;\n   134→}\n   135→\n   136→function hasPythonDep(content: string, dep: string): boolean {\n   137→  // Match dep name as a standalone package, not as a substring of another package.\n   138→  // Handles requirements.txt lines like \"openai>=1.0\", pyproject.toml entries like '\"openai\"',\n   139→  // and extras like \"openai[all]\". Uses word boundary or common delimiters to avoid\n   140→  // matching \"not-openai\" or \"myopenai\".\n   141→  const escaped = dep.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n   142→  const pattern = new RegExp(`(?:^|[\\\\s\"',])${escaped}(?:[\\\\[>=<~!;\\\\s\"',]|$)`, 'm');\n   143→  return pattern.test(content);\n   144→}\n   145→\n   146→/**\n   147→ * Extract the [dependencies] section from Cargo.toml content.\n   148→ * Stops at the next section header (e.g., [dev-dependencies], [build-dependencies]).\n   149→ * Returns empty string if no [dependencies] section found.\n   150→ */\n   151→function getCargoDepsSection(content: string): string {\n   152→  const match = content.match(/^\\[dependencies\\]\\s*$/m);\n   153→  if (!match || match.index === undefined) return '';\n   154→  const start = match.index + match[0].length;\n   155→  // Find next section header\n   156→  const nextSection = content.slice(start).search(/^\\[/m);\n   157→  return nextSection === -1 ? content.slice(start) : content.slice(start, start + nextSection);\n   158→}\n   159→\n   160→/**\n   161→ * Check if a Cargo.toml [dependencies] section contains a specific crate.\n   162→ * Uses word-boundary matching to avoid substring false positives\n   163→ * (e.g., \"anthropic-sdk\" should not match \"anthropic\").\n   164→ */\n   165→function hasCargoDep(depsSection: string, dep: string): boolean {\n   166→  const escaped = dep.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n   167→  const pattern = new RegExp(`(?:^|\\\\s)${escaped}(?:\\\\s*=|\\\\s*\\\\{)`, 'm');\n   168→  return pattern.test(depsSection);\n   169→}\n   170→\n   171→function getPythonDepsContent(dir: string): string {\n   172→  const files = ['requirements.txt', 'pyproject.toml', 'setup.py'];\n   173→  const parts: string[] = [];\n   174→  for (const file of files) {\n   175→    const content = readTextSafe(join(dir, file));\n   176→    if (content) parts.push(content);\n   177→  }\n   178→  return parts.join('\\n');\n   179→}\n   180→\n   181→export function detectAppType(dir: string, stack: string | null): AppType {\n   182→  if (stack === 'nodejs') {\n   183→    const pkg = readJsonSafe(join(dir, 'package.json'));\n   184→    if (!pkg) return 'generic';\n   185→\n   186→    const deps = getNodeDeps(pkg);\n   187→\n   188→    // Priority 1: Agent detection\n   189→    if (AGENT_DEPS_NODE.some(d => deps.has(d))) {\n   190→      return 'agent';\n   191→    }\n   192→\n   193→    // Priority 2: Web detection\n   194→    if (WEB_FRAMEWORK_DEPS.some(d => deps.has(d))) {\n   195→      return 'web';\n   196→    }\n   197→    if (\n   198→      existsSync(join(dir, 'index.html')) ||\n   199→      existsSync(join(dir, 'public', 'index.html')) ||\n   200→      existsSync(join(dir, 'src', 'index.html'))\n   201→    ) {\n   202→      return 'web';\n   203→    }\n   204→\n   205→    // Priority 3: CLI detection\n   206→    const bin = pkg['bin'];\n   207→    const scripts = pkg['scripts'] as Record<string, string> | undefined;\n   208→    const hasStart = scripts?.['start'] !== undefined;\n   209→    if (bin && !hasStart) {\n   210→      return 'cli';\n   211→    }\n   212→\n   213→    // Priority 4: Server detection\n   214→    if (hasStart) {\n   215→      return 'server';\n   216→    }\n   217→\n   218→    return 'generic';\n   219→  }\n   220→\n   221→  if (stack === 'python') {\n   222→    const content = getPythonDepsContent(dir);\n   223→\n   224→    // Priority 1: Agent detection\n   225→    if (AGENT_DEPS_PYTHON.some(d => hasPythonDep(content, d))) {\n   226→      return 'agent';\n   227→    }\n   228→\n   229→    // Priority 2: Web detection (framework + templates/static dirs)\n   230→    const hasWebFramework = PYTHON_WEB_FRAMEWORKS.some(d => hasPythonDep(content, d));\n   231→    if (hasWebFramework) {\n   232→      const hasTemplates = existsSync(join(dir, 'templates'));\n   233→      const hasStatic = existsSync(join(dir, 'static'));\n   234→      if (hasTemplates || hasStatic) {\n   235→        return 'web';\n   236→      }\n   237→      // Bare Flask/Django/FastAPI without templates => server\n   238→      return 'server';\n   239→    }\n   240→\n   241→    // Priority 4: Server detection (has main entry point)\n   242→    if (\n   243→      existsSync(join(dir, 'app.py')) ||\n   244→      existsSync(join(dir, 'main.py')) ||\n   245→      existsSync(join(dir, 'manage.py'))\n   246→    ) {\n   247→      return 'server';\n   248→    }\n   249→\n   250→    return 'generic';\n   251→  }\n   252→\n   253→  if (stack === 'rust') {\n   254→    const cargoContent = readTextSafe(join(dir, 'Cargo.toml'));\n   255→    if (!cargoContent) return 'generic';\n   256→\n   257→    const depsSection = getCargoDepsSection(cargoContent);\n   258→\n   259→    // Priority 1: Agent detection (only in [dependencies], not [dev-dependencies])\n   260→    if (RUST_AGENT_DEPS.some(d => hasCargoDep(depsSection, d))) {\n   261→      return 'agent';\n   262→    }\n   263→\n   264→    // Priority 2: Server detection (web framework in [dependencies])\n   265→    if (RUST_WEB_FRAMEWORKS.some(d => hasCargoDep(depsSection, d))) {\n   266→      return 'server';\n   267→    }\n   268→\n   269→    // Priority 3: CLI detection ([[bin]] section present)\n   270→    if (/^\\[\\[bin\\]\\]\\s*$/m.test(cargoContent)) {\n   271→      return 'cli';\n   272→    }\n   273→\n   274→    // Priority 4: Library detection ([lib] section present, no [[bin]])\n   275→    if (/^\\[lib\\]\\s*$/m.test(cargoContent)) {\n   276→      return 'generic';\n   277→    }\n   278→\n   279→    return 'generic';\n   280→  }\n   281→\n   282→  return 'generic';\n   283→}\n   284→"}]},"parent_tool_use_id":"toolu_01KYHNjFyPBqtp8DZjE8JmLf","session_id":"1d547185-a995-481d-9659-9279ed70f717","uuid":"1ded4557-339a-4b78-a4ea-75db70b0306b","timestamp":"2026-03-24T09:12:25.313Z"}
