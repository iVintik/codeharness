art, end);\n173\t\n174\t      if (section.includes('[ESCALATE]')) {\n175\t        escalated++;\n176\t        continue;\n177\t      }\n178\t\n179\t      if (hasFailVerdict(section)) {\n180\t        pending++;\n181\t        continue;\n182\t      }\n183\t\n184\t      const hasEvidence =\n185\t        section.includes('<!-- /showboat exec -->') ||\n186\t        section.includes('<!-- showboat image:') ||\n187\t        /```(?:bash|shell)\\n[\\s\\S]*?```\\n+```output\\n/m.test(section);\n188\t\n189\t      if (hasEvidence) {\n190\t        verified++;\n191\t      } else {\n192\t        pending++;\n193\t      }\n194\t    }\n195\t  } else {\n196\t    // Format 2: showboat native — inline --- ACN: markers\n197\t    const inlineAcPattern = /--- AC ?(\\d+):/g;\n198\t    const inlineMatches = [...content.matchAll(inlineAcPattern)];\n199\t    const acNumbers = new Set(inlineMatches.map(m => m[1]));\n200\t\n201\t    if (acNumbers.size === 0) {\n202\t      // Format 3: narrative proofs with === AC N: markers\n203\t      const narrativeAcPattern = /=== AC ?(\\d+):/g;\n204\t      const narrativeMatches = [...content.matchAll(narrativeAcPattern)];\n205\t      const narrativeAcNumbers = new Set(narrativeMatches.map(m => m[1]));\n206\t\n207\t      if (narrativeAcNumbers.size === 0) {\n208\t        // Format 4: bullet-list AC summaries\n209\t        const bulletAcPattern = /^- AC ?(\\d+)[^:\\n]*:/gm;\n210\t        const bulletMatches = [...content.matchAll(bulletAcPattern)];\n211\t        const bulletAcNumbers = new Set(bulletMatches.map(m => m[1]));\n212\t\n213\t        if (bulletAcNumbers.size === 0) {\n214\t          return buildResult({ verified: 0, pending: 0, escalated: 0, total: 0 });\n215\t        }\n216\t\n217\t        let bVerified = 0;\n218\t        let bPending = 0;\n219\t        let bEscalated = 0;\n220\t\n221\t        for (const acNum of bulletAcNumbers) {\n222\t          const bulletPattern = new RegExp(`^- AC ?${acNum}[^:\\\\n]*:(.*)$`, 'm');\n223\t          const bulletMa