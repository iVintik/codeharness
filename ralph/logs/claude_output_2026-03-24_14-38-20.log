{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RvNEWTttEbb11czeEF1krs","type":"tool_result","content":"     1→/**\n     2→ * Migration from old scattered state files to unified sprint-state.json.\n     3→ * Runs once when sprint-state.json does not exist and old files are found.\n     4→ */\n     5→\n     6→import { readFileSync, existsSync } from 'node:fs';\n     7→import { join } from 'node:path';\n     8→import { ok, fail } from '../../types/result.js';\n     9→import type { Result } from '../../types/result.js';\n    10→import type { SprintState, SprintStateV1, StoryState, StoryStatus, ActionItem, SessionState } from '../../types/state.js';\n    11→import { defaultState, writeStateAtomic, computeSprintCounts } from './state.js';\n    12→\n    13→const OLD_FILES = {\n    14→  storyRetries: 'ralph/.story_retries',\n    15→  flaggedStories: 'ralph/.flagged_stories',\n    16→  ralphStatus: 'ralph/status.json',\n    17→  sprintStatusYaml: '_bmad-output/implementation-artifacts/sprint-status.yaml',\n    18→  sessionIssues: '_bmad-output/implementation-artifacts/.session-issues.md',\n    19→} as const;\n    20→\n    21→function resolve(relative: string): string {\n    22→  return join(process.cwd(), relative);\n    23→}\n    24→\n    25→function readIfExists(relative: string): string | null {\n    26→  const p = resolve(relative);\n    27→  if (!existsSync(p)) return null;\n    28→  try { return readFileSync(p, 'utf-8'); } catch { return null; }\n    29→}\n    30→\n    31→/** Return a fresh empty StoryState */\n    32→function emptyStory(): StoryState {\n    33→  return {\n    34→    status: 'backlog', attempts: 0, lastAttempt: null,\n    35→    lastError: null, proofPath: null, acResults: null,\n    36→  };\n    37→}\n    38→\n    39→/** Ensure a story entry exists, then apply a partial update */\n    40→function upsertStory(\n    41→  stories: Record<string, StoryState>,\n    42→  key: string,\n    43→  patch: Partial<StoryState>,\n    44→): void {\n    45→  stories[key] = { ...(stories[key] ?? emptyStory()), ...patch };\n    46→}\n    47→\n    48→/** Parse ralph/.story_retries: \"<key> <count>\" per line */\n    49→function parseStoryRetries(content: string, stories: Record<string, StoryState>): void {\n    50→  for (const line of content.split('\\n')) {\n    51→    const trimmed = line.trim();\n    52→    if (!trimmed) continue;\n    53→    const parts = trimmed.split(/\\s+/);\n    54→    if (parts.length < 2) continue;\n    55→    const count = parseInt(parts[1], 10);\n    56→    if (!isNaN(count)) upsertStory(stories, parts[0], { attempts: count });\n    57→  }\n    58→}\n    59→\n    60→/**\n    61→ * Parse ralph/.story_retries into a Record<string, number> for v2 retries field.\n    62→ * Format: \"<key> <count>\" per line (space-separated).\n    63→ */\n    64→export function parseStoryRetriesRecord(content: string): Record<string, number> {\n    65→  const result: Record<string, number> = {};\n    66→  for (const line of content.split('\\n')) {\n    67→    const trimmed = line.trim();\n    68→    if (!trimmed) continue;\n    69→    const parts = trimmed.split(/\\s+/);\n    70→    if (parts.length < 2) continue;\n    71→    const count = parseInt(parts[1], 10);\n    72→    if (!isNaN(count)) result[parts[0]] = count;\n    73→  }\n    74→  return result;\n    75→}\n    76→\n    77→/**\n    78→ * Parse ralph/.flagged_stories into a string[] for v2 flagged field.\n    79→ * Format: one key per line.\n    80→ */\n    81→export function parseFlaggedStoriesList(content: string): string[] {\n    82→  return content\n    83→    .split('\\n')\n    84→    .map(l => l.trim())\n    85→    .filter(l => l !== '');\n    86→}\n    87→\n    88→/** Parse ralph/.flagged_stories: one key per line */\n    89→function parseFlaggedStories(content: string, stories: Record<string, StoryState>): void {\n    90→  for (const line of content.split('\\n')) {\n    91→    const key = line.trim();\n    92→    if (key) upsertStory(stories, key, { status: 'blocked' });\n    93→  }\n    94→}\n    95→\n    96→/** Map YAML status strings to StoryStatus */\n    97→function mapYamlStatus(value: string): StoryStatus | null {\n    98→  const mapping: Record<string, StoryStatus> = {\n    99→    done: 'done', backlog: 'backlog', verifying: 'verifying',\n   100→    'in-progress': 'in-progress', 'ready-for-dev': 'ready',\n   101→    blocked: 'blocked', failed: 'failed', review: 'review', ready: 'ready',\n   102→  };\n   103→  return mapping[value.trim().toLowerCase()] ?? null;\n   104→}\n   105→\n   106→/**\n   107→ * Parse sprint-status.yaml (flat key: value).\n   108→ * Story lines like \"  1-1-result-type: done\" become entries.\n   109→ * Epic lines like \"  epic-1: done\" are skipped.\n   110→ */\n   111→function parseSprintStatusYaml(content: string, stories: Record<string, StoryState>): void {\n   112→  for (const line of content.split('\\n')) {\n   113→    const trimmed = line.trim();\n   114→    if (!trimmed || trimmed.startsWith('#')) continue;\n   115→    const match = trimmed.match(/^([a-zA-Z0-9_-]+):\\s*(.+)$/);\n   116→    if (!match) continue;\n   117→    const key = match[1];\n   118→    if (key === 'development_status' || key.startsWith('epic-')) continue;\n   119→    const status = mapYamlStatus(match[2]);\n   120→    if (status) upsertStory(stories, key, { status });\n   121→  }\n   122→}\n   123→\n   124→interface RalphStatusJson {\n   125→  loop_count?: number;\n   126→  stories_total?: number;\n   127→  stories_completed?: number;\n   128→  elapsed_seconds?: number;\n   129→  status?: string;\n   130→}\n   131→\n   132→/** Parse ralph/status.json into run section */\n   133→function parseRalphStatus(content: string): SprintState['run'] | null {\n   134→  try {\n   135→    const data = JSON.parse(content) as RalphStatusJson;\n   136→    return {\n   137→      active: data.status === 'running', startedAt: null,\n   138→      iteration: data.loop_count ?? 0, cost: 0, completed: [], failed: [],\n   139→      currentStory: null, currentPhase: null, lastAction: null, acProgress: null,\n   140→    };\n   141→  } catch { return null; }\n   142→}\n   143→\n   144→/** Parse ralph/status.json into SessionState for v2 */\n   145→function parseRalphStatusToSession(content: string): SessionState | null {\n   146→  try {\n   147→    const data = JSON.parse(content) as RalphStatusJson;\n   148→    return {\n   149→      active: data.status === 'running',\n   150→      startedAt: null,\n   151→      iteration: data.loop_count ?? 0,\n   152→      elapsedSeconds: data.elapsed_seconds ?? 0,\n   153→    };\n   154→  } catch { return null; }\n   155→}\n   156→\n   157→/** Parse .session-issues.md for action items (best effort) */\n   158→function parseSessionIssues(content: string): ActionItem[] {\n   159→  const items: ActionItem[] = [];\n   160→  let currentStory = '';\n   161→  let itemId = 0;\n   162→  for (const line of content.split('\\n')) {\n   163→    const headerMatch = line.match(/^###\\s+([a-zA-Z0-9_-]+)\\s*[—-]/);\n   164→    if (headerMatch) { currentStory = headerMatch[1]; continue; }\n   165→    const bulletMatch = line.match(/^-\\s+(.+)/);\n   166→    if (bulletMatch && currentStory) {\n   167→      itemId++;\n   168→      items.push({\n   169→        id: `migrated-${itemId}`, story: currentStory,\n   170→        description: bulletMatch[1], source: 'retro', resolved: false,\n   171→      });\n   172→    }\n   173→  }\n   174→  return items;\n   175→}\n   176→\n   177→/**\n   178→ * Migrate a v1 state to v2 by reading external files and merging into unified schema.\n   179→ * Does NOT delete source files (.story_retries, .flagged_stories).\n   180→ */\n   181→export function migrateV1ToV2(v1: SprintStateV1): SprintState {\n   182→  const defaults = defaultState();\n   183→\n   184→  // Read retries from external file\n   185→  const retriesContent = readIfExists(OLD_FILES.storyRetries);\n   186→  const retries = retriesContent ? parseStoryRetriesRecord(retriesContent) : {};\n   187→\n   188→  // Read flagged stories from external file\n   189→  const flaggedContent = readIfExists(OLD_FILES.flaggedStories);\n   190→  const flagged = flaggedContent ? parseFlaggedStoriesList(flaggedContent) : [];\n   191→\n   192→  // Read session info from ralph/status.json\n   193→  const statusContent = readIfExists(OLD_FILES.ralphStatus);\n   194→  const session = statusContent\n   195→    ? (parseRalphStatusToSession(statusContent) ?? defaults.session)\n   196→    : defaults.session;\n   197→\n   198→  return {\n   199→    version: 2,\n   200→    sprint: v1.sprint,\n   201→    stories: v1.stories,\n   202→    retries,\n   203→    flagged,\n   204→    epics: {},\n   205→    session,\n   206→    observability: defaults.observability,\n   207→    run: {\n   208→      ...defaults.run,\n   209→      ...v1.run,\n   210→    },\n   211→    actionItems: v1.actionItems,\n   212→  };\n   213→}\n   214→\n   215→/**\n   216→ * Migrate from old format files to SprintState.\n   217→ * Returns fail() if no old files exist (caller should use default).\n   218→ */\n   219→export function migrateFromOldFormat(): Result<SprintState> {\n   220→  const hasAnyOldFile = Object.values(OLD_FILES).some((rel) => existsSync(resolve(rel)));\n   221→  if (!hasAnyOldFile) return fail('No old format files found for migration');\n   222→\n   223→  try {\n   224→    const stories: Record<string, StoryState> = {};\n   225→    let run = defaultState().run;\n   226→    let actionItems: ActionItem[] = [];\n   227→\n   228→    const yamlContent = readIfExists(OLD_FILES.sprintStatusYaml);\n   229→    if (yamlContent) parseSprintStatusYaml(yamlContent, stories);\n   230→\n   231→    const retriesContent = readIfExists(OLD_FILES.storyRetries);\n   232→    if (retriesContent) parseStoryRetries(retriesContent, stories);\n   233→\n   234→    const flaggedContent = readIfExists(OLD_FILES.flaggedStories);\n   235→    if (flaggedContent) parseFlaggedStories(flaggedContent, stories);\n   236→\n   237→    const statusContent = readIfExists(OLD_FILES.ralphStatus);\n   238→    let session = defaultState().session;\n   239→    if (statusContent) {\n   240→      const parsed = parseRalphStatus(statusContent);\n   241→      if (parsed) run = parsed;\n   242→      const parsedSession = parseRalphStatusToSession(statusContent);\n   243→      if (parsedSession) session = parsedSession;\n   244→    }\n   245→\n   246→    const issuesContent = readIfExists(OLD_FILES.sessionIssues);\n   247→    if (issuesContent) actionItems = parseSessionIssues(issuesContent);\n   248→\n   249→    const sprint = computeSprintCounts(stories);\n   250→\n   251→    // Parse retries and flagged for v2 fields\n   252→    const retries = retriesContent ? parseStoryRetriesRecord(retriesContent) : {};\n   253→    const flagged = flaggedContent ? parseFlaggedStoriesList(flaggedContent) : [];\n   254→\n   255→    const migrated: SprintState = {\n   256→      version: 2,\n   257→      sprint,\n   258→      stories,\n   259→      retries,\n   260→      flagged,\n   261→      epics: {},\n   262→      session,\n   263→      observability: defaultState().observability,\n   264→      run,\n   265→      actionItems,\n   266→    };\n   267→\n   268→    const writeResult = writeStateAtomic(migrated);\n   269→    if (!writeResult.success) return fail(writeResult.error);\n   270→    return ok(migrated);\n   271→  } catch (err: unknown) {\n   272→    const msg = err instanceof Error ? err.message : String(err);\n   273→    return fail(`Migration failed: ${msg}`);\n   274→  }\n   275→}\n   276→"}]},"parent_tool_use_id":"toolu_01CfvkxunN8dwVBkgTqCVyZN","session_id":"0e449f80-823c-4489-a784-b43b6c7039d6","uuid":"914228b4-0480-4f64-8689-bc4edd793b87","timestamp":"2026-03-24T10:39:29.913Z"}
