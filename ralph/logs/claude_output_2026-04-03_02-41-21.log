{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019fA5vySV48TsTWrmo8Bx68","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { parse } from 'yaml';\n3\timport { warn } from './output.js';\n4\timport { dispatchAgent, DispatchError } from './agent-dispatch.js';\n5\timport type { DispatchOptions, DispatchResult } from './agent-dispatch.js';\n6\timport type { SubagentDefinition } from './agent-resolver.js';\n7\timport type { ResolvedWorkflow, ResolvedTask, FlowStep, LoopBlock } from './workflow-parser.js';\n8\timport {\n9\t  readWorkflowState,\n10\t  writeWorkflowState,\n11\t} from './workflow-state.js';\n12\timport type { WorkflowState, TaskCheckpoint } from './workflow-state.js';\n13\timport { createIsolatedWorkspace } from './source-isolation.js';\n14\timport { generateTraceId, formatTracePrompt, recordTraceId } from './trace-id.js';\n15\timport { resolveSessionId, recordSessionId } from './session-manager.js';\n16\timport type { SessionLookupKey } from './session-manager.js';\n17\t\n18\t// --- Interfaces ---\n19\t\n20\t/**\n21\t * Configuration for the workflow engine.\n22\t */\n23\texport interface EngineConfig {\n24\t  /** The resolved workflow with tasks and flow steps. */\n25\t  workflow: ResolvedWorkflow;\n26\t  /** Pre-compiled agent definitions keyed by agent name. */\n27\t  agents: Record<string, SubagentDefinition>;\n28\t  /** Path to sprint-status.yaml for work item discovery. */\n29\t  sprintStatusPath: string;\n30\t  /** Optional path to issues.yaml for additional work items. */\n31\t  issuesPath?: string;\n32\t  /** Unique identifier for this engine run. */\n33\t  runId: string;\n34\t  /** Project root directory. Defaults to process.cwd(). */\n35\t  projectDir?: string;\n36\t  /** Maximum loop iterations before termination. Defaults to 5. */\n37\t  maxIterations?: number;\n38\t}\n39\t\n40\t/**\n41\t * Evaluator verdict returned by a verify task (AD5).\n42\t */\n43\texport interface EvaluatorVerdict {\n44\t  verdict: 'pass' | 'fail';\n45\t  score: {\n46\t    passed: number;\n47\t    failed: number;\n48\t    unknown: number;\n49\t    total: number;\n50\t  };\n51\t  findings: Array<{\n52\t    ac: number;\n53\t    description: string;\n54\t    status: 'pass' | 'fail' | 'unknown';\n55\t    evidence: {\n56\t      commands_run: string[];\n57\t      output_observed: string;\n58\t      reasoning: string;\n59\t    };\n60\t  }>;\n61\t  evaluator_trace_id?: string;\n62\t  duration_seconds?: number;\n63\t}\n64\t\n65\t/**\n66\t * Result returned by executeWorkflow().\n67\t */\n68\texport interface EngineResult {\n69\t  /** Whether the workflow completed without errors. */\n70\t  success: boolean;\n71\t  /** Number of task dispatches completed. */\n72\t  tasksCompleted: number;\n73\t  /** Number of work items (stories/issues) processed. */\n74\t  storiesProcessed: number;\n75\t  /** Errors encountered during execution. */\n76\t  errors: EngineError[];\n77\t  /** Wall-clock duration of the entire workflow in milliseconds. */\n78\t  durationMs: number;\n79\t}\n80\t\n81\t/**\n82\t * Structured error recorded during workflow execution.\n83\t */\n84\texport interface EngineError {\n85\t  taskName: string;\n86\t  storyKey: string;\n87\t  code: string;\n88\t  message: string;\n89\t}\n90\t\n91\t/**\n92\t * A work item (story or issue) ready for execution.\n93\t */\n94\texport interface WorkItem {\n95\t  key: string;\n96\t  title?: string;\n97\t  source: 'sprint' | 'issues';\n98\t}\n99\t\n100\t// --- Constants ---\n101\t\n102\t/** Sentinel story key for per-run tasks. */\n103\texport const PER_RUN_SENTINEL = '__run__';\n104\t\n105\t/** DispatchError codes that should halt execution immediately. */\n106\tconst HALT_ERROR_CODES = new Set(['RATE_LIMIT', 'NETWORK', 'SDK_INIT']);\n107\t\n108\t/** Default maximum loop iterations before termination. */\n109\tconst DEFAULT_MAX_ITERATIONS = 5;\n110\t\n111\t// --- Crash Recovery: Task Completion Check ---\n112\t\n113\t/**\n114\t * Check whether a (taskName, storyKey) combination is already recorded\n115\t * in the workflow state's tasks_completed array.\n116\t *\n117\t * Both fields must match for the task to be considered completed.\n118\t * Used by the resume logic to skip already-completed dispatches.\n119\t */\n120\texport function isTaskCompleted(\n121\t  state: WorkflowState,\n122\t  taskName: string,\n123\t  storyKey: string,\n124\t): boolean {\n125\t  return state.tasks_completed.some(\n126\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey,\n127\t  );\n128\t}\n129\t\n130\t/**\n131\t * Check whether a (taskName, storyKey) combination has been completed\n132\t * enough times to cover the current iteration in a loop block.\n133\t *\n134\t * Loop tasks execute the same (taskName, storyKey) pair each iteration,\n135\t * recording a new checkpoint each time. To determine if a task is done\n136\t * for the current iteration, we count how many matching checkpoints exist\n137\t * and compare to the current iteration number.\n138\t */\n139\texport function isLoopTaskCompleted(\n140\t  state: WorkflowState,\n141\t  taskName: string,\n142\t  storyKey: string,\n143\t  iteration: number,\n144\t): boolean {\n145\t  const count = state.tasks_completed.filter(\n146\t    (cp) => cp.task_name === taskName && cp.story_key === storyKey,\n147\t  ).length;\n148\t  return count >= iteration;\n149\t}\n150\t\n151\t// --- Work Item Loading ---\n152\t\n153\t/**\n154\t * Load work items from sprint-status.yaml and optionally issues.yaml.\n155\t *\n156\t * Stories are extracted from the `development_status` section of sprint-status.yaml.\n157\t * Issues are extracted from the `issues` array of issues.yaml.\n158\t *\n159\t * Only items with status `backlog` or `ready-for-dev` are included.\n160\t * Epic keys (`epic-*`) and retrospective keys (`*-retrospective`) are excluded.\n161\t *\n162\t * If issues.yaml does not exist, returns only stories (no error).\n163\t */\n164\texport function loadWorkItems(sprintStatusPath: string, issuesPath?: string): WorkItem[] {\n165\t  const items: WorkItem[] = [];\n166\t\n167\t  // --- Load stories from sprint-status.yaml ---\n168\t  if (existsSync(sprintStatusPath)) {\n169\t    let raw: string;\n170\t    try {\n171\t      raw = readFileSync(sprintStatusPath, 'utf-8');\n172\t    } catch { // IGNORE: unreadable file — warn and return empty\n173\t      warn(`workflow-engine: could not read sprint-status.yaml at ${sprintStatusPath}`);\n174\t      return items;\n175\t    }\n176\t\n177\t    let parsed: unknown;\n178\t    try {\n179\t      parsed = parse(raw);\n180\t    } catch { // IGNORE: malformed YAML — warn and return empty\n181\t      warn(`workflow-engine: invalid YAML in sprint-status.yaml at ${sprintStatusPath}`);\n182\t      return items;\n183\t    }\n184\t\n185\t    if (parsed && typeof parsed === 'object') {\n186\t      const data = parsed as Record<string, unknown>;\n187\t      const devStatus = data.development_status as Record<string, unknown> | undefined;\n188\t\n189\t      if (devStatus && typeof devStatus === 'object') {\n190\t        for (const [key, status] of Object.entries(devStatus)) {\n191\t          // Skip epic keys and retrospective keys\n192\t          if (key.startsWith('epic-')) continue;\n193\t          if (key.endsWith('-retrospective')) continue;\n194\t\n195\t          // Only include backlog or ready-for-dev\n196\t          if (status === 'backlog' || status === 'ready-for-dev') {\n197\t            items.push({ key, source: 'sprint' });\n198\t          }\n199\t        }\n200\t      }\n201\t    }\n202\t  }\n203\t\n204\t  // --- Load issues from issues.yaml ---\n205\t  if (issuesPath && existsSync(issuesPath)) {\n206\t    let raw: string;\n207\t    try {\n208\t      raw = readFileSync(issuesPath, 'utf-8');\n209\t    } catch { // IGNORE: unreadable issues file — warn and return what we have\n210\t      warn(`workflow-engine: could not read issues.yaml at ${issuesPath}`);\n211\t      return items;\n212\t    }\n213\t\n214\t    let parsed: unknown;\n215\t    try {\n216\t      parsed = parse(raw);\n217\t    } catch { // IGNORE: malformed issues YAML — warn and return what we have\n218\t      warn(`workflow-engine: invalid YAML in issues.yaml at ${issuesPath}`);\n219\t      return items;\n220\t    }\n221\t\n222\t    if (parsed && typeof parsed === 'object') {\n223\t      const data = parsed as Record<string, unknown>;\n224\t      const issuesList = data.issues as Array<Record<string, unknown>> | undefined;\n225\t\n226\t      if (Array.isArray(issuesList)) {\n227\t        for (const issue of issuesList) {\n228\t          if (issue && typeof issue === 'object') {\n229\t            const status = issue.status as string | undefined;\n230\t            if (status === 'backlog' || status === 'ready-for-dev') {\n231\t              items.push({\n232\t                key: issue.id as string,\n233\t                title: issue.title as string | undefined,\n234\t                source: 'issues',\n235\t              });\n236\t            }\n237\t          }\n238\t        }\n239\t      }\n240\t    }\n241\t  }\n242\t\n243\t  return items;\n244\t}\n245\t\n246\t// --- Single Task Dispatch ---\n247\t\n248\t/**\n249\t * Dispatch a single task for a specific work item (or per-run sentinel).\n250\t *\n251\t * Handles: trace ID generation, session resolution, source isolation,\n252\t * agent dispatch, state checkpointing, and cleanup.\n253\t *\n254\t * Returns the updated workflow state after recording the dispatch.\n255\t */\n256\texport async function dispatchTask(\n257\t  task: ResolvedTask,\n258\t  taskName: string,\n259\t  storyKey: string,\n260\t  definition: SubagentDefinition,\n261\t  state: WorkflowState,\n262\t  config: EngineConfig,\n263\t  customPrompt?: string,\n264\t): Promise<WorkflowState> {\n265\t  const { updatedState } = await dispatchTaskWithResult(\n266\t    task, taskName, storyKey, definition, state, config, customPrompt,\n267\t  );\n268\t  return updatedState;\n269\t}\n270\t\n271\t// --- Flow Step Type Guard ---\n272\t\n273\tfunction isLoopBlock(step: FlowStep): step is LoopBlock {\n274\t  return typeof step === 'object' && step !== null && 'loop' in step;\n275\t}\n276\t\n277\t// --- Core Dispatch (shared by dispatchTask and loop block execution) ---\n278\t\n279\t/**\n280\t * Dispatch a task and return both the updated state and the raw dispatch output.\n281\t * This is the single implementation of task dispatch logic. Both `dispatchTask()`\n282\t * and loop block execution delegate here.\n283\t */\n284\tasync function dispatchTaskWithResult(\n285\t  task: ResolvedTask,\n286\t  taskName: string,\n287\t  storyKey: string,\n288\t  definition: SubagentDefinition,\n289\t  state: WorkflowState,\n290\t  config: EngineConfig,\n291\t  customPrompt?: string,\n292\t): Promise<{ updatedState: WorkflowState; output: string }> {\n293\t  const projectDir = config.projectDir ?? process.cwd();\n294\t\n295\t  // 1. Generate trace ID\n296\t  const traceId = generateTraceId(config.runId, state.iteration, taskName);\n297\t\n298\t  // 2. Format trace prompt\n299\t  const tracePrompt = formatTracePrompt(traceId);\n300\t\n301\t  // 3. Resolve session ID\n302\t  const sessionKey: SessionLookupKey = { taskName, storyKey };\n303\t  const sessionId = resolveSessionId(task.session, sessionKey, state);\n304\t\n305\t  // 4. Build dispatch options based on source_access\n306\t  let dispatchOptions: DispatchOptions;\n307\t  let workspace: Awaited<ReturnType<typeof createIsolatedWorkspace>> | null = null;\n308\t\n309\t  if (task.source_access === false) {\n310\t    workspace = await createIsolatedWorkspace({ runId: config.runId, storyFiles: [] });\n311\t    dispatchOptions = {\n312\t      ...workspace.toDispatchOptions(),\n313\t      sessionId,\n314\t      appendSystemPrompt: tracePrompt,\n315\t    };\n316\t  } else {\n317\t    dispatchOptions = {\n318\t      cwd: projectDir,\n319\t      sessionId,\n320\t      appendSystemPrompt: tracePrompt,\n321\t    };\n322\t  }\n323\t\n324\t  // 5. Construct prompt\n325\t  const prompt = customPrompt\n326\t    ?? (storyKey === PER_RUN_SENTINEL\n327\t      ? `Execute task \"${taskName}\" for the current run.`\n328\t      : `Implement story ${storyKey}`);\n329\t\n330\t  // 6. Dispatch agent\n331\t  let result: DispatchResult;\n332\t  try {\n333\t    result = await dispatchAgent(definition, prompt, dispatchOptions);\n334\t  } finally {\n335\t    // Cleanup workspace regardless of dispatch success/failure\n336\t    if (workspace) {\n337\t      await workspace.cleanup();\n338\t    }\n339\t  }\n340\t\n341\t  // 7. Record session ID (if dispatch returned one)\n342\t  let updatedState = state;\n343\t  if (result.sessionId) {\n344\t    updatedState = recordSessionId(sessionKey, result.sessionId, updatedState);\n345\t  } else {\n346\t    // Append checkpoint manually when no session ID is returned\n347\t    const checkpoint: TaskCheckpoint = {\n348\t      task_name: taskName,\n349\t      story_key: storyKey,\n350\t      completed_at: new Date().toISOString(),\n351\t    };\n352\t    updatedState = {\n353\t      ...updatedState,\n354\t      tasks_completed: [...updatedState.tasks_completed, checkpoint],\n355\t    };\n356\t  }\n357\t\n358\t  // 8. Record trace ID\n359\t  updatedState = recordTraceId(traceId, updatedState);\n360\t\n361\t  // 9. Write state to disk\n362\t  writeWorkflowState(updatedState, projectDir);\n363\t\n364\t  return { updatedState, output: result.output };\n365\t}\n366\t\n367\t// --- Verdict Parsing (Task 2) ---\n368\t\n369\t/**\n370\t * Attempt to parse a DispatchResult.output string as an EvaluatorVerdict.\n371\t * Returns null if parsing fails or required fields are missing.\n372\t */\n373\texport function parseVerdict(output: string): EvaluatorVerdict | null {\n374\t  let parsed: unknown;\n375\t  try {\n376\t    parsed = JSON.parse(output);\n377\t  } catch { // IGNORE: invalid JSON means no verdict — return null\n378\t    return null;\n379\t  }\n380\t\n381\t  if (!parsed || typeof parsed !== 'object') return null;\n382\t\n383\t  const obj = parsed as Record<string, unknown>;\n384\t\n385\t  // Validate required top-level fields\n386\t  if (obj.verdict !== 'pass' && obj.verdict !== 'fail') return null;\n387\t  if (!obj.score || typeof obj.score !== 'object') return null;\n388\t  if (!Array.isArray(obj.findings)) return null;\n389\t\n390\t  const score = obj.score as Record<string, unknown>;\n391\t  if (typeof score.passed !== 'number') return null;\n392\t  if (typeof score.failed !== 'number') return null;\n393\t  if (typeof score.unknown !== 'number') return null;\n394\t  if (typeof score.total !== 'number') return null;\n395\t\n396\t  return parsed as EvaluatorVerdict;\n397\t}\n398\t\n399\t// --- Retry Prompt Construction (Task 3) ---\n400\t\n401\t/**\n402\t * Build a retry prompt with evaluator findings injected.\n403\t * Includes only failed/unknown findings.\n404\t */\n405\texport function buildRetryPrompt(storyKey: string, findings: EvaluatorVerdict['findings']): string {\n406\t  const failedFindings = findings.filter(\n407\t    (f) => f.status === 'fail' || f.status === 'unknown',\n408\t  );\n409\t\n410\t  if (failedFindings.length === 0) {\n411\t    return `Implement story ${storyKey}`;\n412\t  }\n413\t\n414\t  const formattedFindings = failedFindings\n415\t    .map((f) => {\n416\t      const status = f.status.toUpperCase();\n417\t      let entry = `AC #${f.ac} (${status}): ${f.description}`;\n418\t      if (f.evidence?.reasoning) {\n419\t        entry += `\\n  Evidence: ${f.evidence.reasoning}`;\n420\t      }\n421\t      return entry;\n422\t    })\n423\t    .join('\\n\\n');\n424\t\n425\t  return `Retry story ${storyKey}. Previous evaluator findings:\\n\\n${formattedFindings}\\n\\nFocus on fixing the failed criteria above.`;\n426\t}\n427\t\n428\t// --- Failed Story Filtering (Task 4) ---\n429\t\n430\t/**\n431\t * Determine which work items failed based on evaluator findings.\n432\t * If verdict is null (parse failure), returns all items (conservative fallback).\n433\t */\n434\texport function getFailedItems(\n435\t  verdict: EvaluatorVerdict | null,\n436\t  allItems: WorkItem[],\n437\t): WorkItem[] {\n438\t  if (!verdict) return allItems;\n439\t\n440\t  // If verdict passed, no items need retry\n441\t  if (verdict.verdict === 'pass') return [];\n442\t\n443\t  // All items are retried on failure — per-story filtering based on individual\n444\t  // story results is not possible with the current verdict shape (verdict is per-run).\n445\t  // The findings track ACs, not stories. Conservative: retry all on failure.\n446\t  return allItems;\n447\t}\n448\t\n449\t// --- Loop Block Execution (Task 5) ---\n450\t\n451\t/**\n452\t * Result of loop block execution.\n453\t */\n454\tinterface LoopBlockResult {\n455\t  state: WorkflowState;\n456\t  errors: EngineError[];\n457\t  tasksCompleted: number;\n458\t  halted: boolean;\n459\t}\n460\t\n461\t/**\n462\t * Execute a loop block: iterate tasks until pass, max iterations, or circuit breaker.\n463\t */\n464\texport async function executeLoopBlock(\n465\t  loopBlock: LoopBlock,\n466\t  state: WorkflowState,\n467\t  config: EngineConfig,\n468\t  workItems: WorkItem[],\n469\t): Promise<LoopBlockResult> {\n470\t  const projectDir = config.projectDir ?? process.cwd();\n471\t  const maxIterations = config.maxIterations ?? DEFAULT_MAX_ITERATIONS;\n472\t  const errors: EngineError[] = [];\n473\t  let tasksCompleted = 0;\n474\t  let currentState = state;\n475\t  let lastVerdict: EvaluatorVerdict | null = null;\n476\t\n477\t  // Handle empty loop block\n478\t  if (loopBlock.loop.length === 0) {\n479\t    return { state: currentState, errors, tasksCompleted, halted: false };\n480\t  }\n481\t\n482\t  while (true) {\n483\t    // 1. Determine whether to increment iteration or resume a partial one.\n484\t    //    On fresh start (iteration === 0), always increment.\n485\t    //    On resume (iteration > 0), check if the current iteration is fully done.\n486\t    const nextIteration = currentState.iteration + 1;\n487\t    const allCurrentIterationDone = currentState.iteration > 0 && loopBlock.loop.every((tn) => {\n488\t      const t = config.workflow.tasks[tn];\n489\t      if (!t) return true; // missing task = skip = \"done\"\n490\t      if (t.scope === 'per-story') {\n491\t        return workItems.every((item) =>\n492\t          isLoopTaskCompleted(currentState, tn, item.key, currentState.iteration));\n493\t      }\n494\t      return isLoopTaskCompleted(currentState, tn, PER_RUN_SENTINEL, currentState.iteration);\n495\t    });\n496\t\n497\t    if (currentState.iteration === 0 || allCurrentIterationDone) {\n498\t      // Fresh start or current iteration fully done — advance\n499\t      currentState = {\n500\t        ...currentState,\n501\t        iteration: nextIteration,\n502\t      };\n503\t      writeWorkflowState(currentState, projectDir);\n504\t    }\n505\t    // else: resuming a partially completed iteration — keep current iteration\n506\t\n507\t    let haltedInLoop = false;\n508\t\n509\t    // 2. Execute each task in the loop\n510\t    for (const taskName of loopBlock.loop) {\n511\t      const task = config.workflow.tasks[taskName];\n512\t      if (!task) {\n513\t        warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n514\t        continue;\n515\t      }\n516\t\n517\t      const definition = config.agents[task.agent];\n518\t      if (!definition) {\n519\t        warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n520\t        continue;\n521\t      }\n522\t\n523\t      if (task.scope === 'per-story') {\n524\t        // Determine which items to dispatch for\n525\t        const itemsToRetry = lastVerdict ? getFailedItems(lastVerdict, workItems) : workItems;\n526\t\n527\t        for (const item of itemsToRetry) {\n528\t          // Skip if already completed for this iteration (crash recovery — AC #4)\n529\t          if (isLoopTaskCompleted(currentState, taskName, item.key, currentState.iteration)) {\n530\t            warn(`workflow-engine: skipping completed task ${taskName} for ${item.key}`);\n531\t            continue;\n532\t          }\n533\t\n534\t          // Build prompt: inject findings if we have a previous verdict\n535\t          const prompt = lastVerdict\n536\t            ? buildRetryPrompt(item.key, lastVerdict.findings)\n537\t            : undefined;\n538\t\n539\t          try {\n540\t            currentState = await dispatchTask(\n541\t              task, taskName, item.key, definition, currentState, config, prompt,\n542\t            );\n543\t            tasksCompleted++;\n544\t          } catch (err: unknown) {\n545\t            const engineError = handleDispatchError(err, taskName, item.key);\n546\t            errors.push(engineError);\n547\t            currentState = recordErrorInState(currentState, taskName, item.key, engineError);\n548\t            writeWorkflowState(currentState, projectDir);\n549\t\n550\t            if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n551\t              haltedInLoop = true;\n552\t              break;\n553\t            }\n554\t            continue;\n555\t          }\n556\t        }\n557\t\n558\t        if (haltedInLoop) break;\n559\t      } else {\n560\t        // per-run task (e.g., verify)\n561\t        // Skip if already completed for this iteration (crash recovery — AC #4)\n562\t        if (isLoopTaskCompleted(currentState, taskName, PER_RUN_SENTINEL, currentState.iteration)) {\n563\t          warn(`workflow-engine: skipping completed task ${taskName} for ${PER_RUN_SENTINEL}`);\n564\t          continue;\n565\t        }\n566\t\n567\t        try {\n568\t          // We need the dispatch result output to parse verdict\n569\t          // dispatchTask doesn't return the DispatchResult directly, so we\n570\t          // intercept via a wrapper that captures the output\n571\t          const dispatchResult = await dispatchTaskWithResult(\n572\t            task, taskName, PER_RUN_SENTINEL, definition, currentState, config,\n573\t          );\n574\t          currentState = dispatchResult.updatedState;\n575\t          tasksCompleted++;\n576\t\n577\t          // Attempt to parse verdict from output\n578\t          const verdict = parseVerdict(dispatchResult.output);\n579\t          lastVerdict = verdict;\n580\t\n581\t          // Record score in state\n582\t          if (verdict) {\n583\t            const score = {\n584\t              iteration: currentState.iteration,\n585\t              passed: verdict.score.passed,\n586\t              failed: verdict.score.failed,\n587\t              unknown: verdict.score.unknown,\n588\t              total: verdict.score.total,\n589\t              timestamp: new Date().toISOString(),\n590\t            };\n591\t            currentState = {\n592\t              ...currentState,\n593\t              evaluator_scores: [...currentState.evaluator_scores, score],\n594\t            };\n595\t          } else {\n596\t            // Parse failure: record all-UNKNOWN score\n597\t            const totalItems = workItems.length;\n598\t            const score = {\n599\t              iteration: currentState.iteration,\n600\t              passed: 0,\n601\t              failed: 0,\n602\t              unknown: totalItems,\n603\t              total: totalItems,\n604\t              timestamp: new Date().toISOString(),\n605\t            };\n606\t            currentState = {\n607\t              ...currentState,\n608\t              evaluator_scores: [...currentState.evaluator_scores, score],\n609\t            };\n610\t          }\n611\t          writeWorkflowState(currentState, projectDir);\n612\t        } catch (err: unknown) {\n613\t          const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n614\t          errors.push(engineError);\n615\t          currentState = recordErrorInState(currentState, taskName, PER_RUN_SENTINEL, engineError);\n616\t          writeWorkflowState(currentState, projectDir);\n617\t\n618\t          // Clear stale verdict so next iteration retries all items\n619\t          lastVerdict = null;\n620\t\n621\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n622\t            haltedInLoop = true;\n623\t            break;\n624\t          }\n625\t          continue;\n626\t        }\n627\t      }\n628\t    }\n629\t\n630\t    if (haltedInLoop) {\n631\t      return { state: currentState, errors, tasksCompleted, halted: true };\n632\t    }\n633\t\n634\t    // 3. Check termination conditions\n635\t    if (lastVerdict?.verdict === 'pass') {\n636\t      // Success: loop passes\n637\t      return { state: currentState, errors, tasksCompleted, halted: false };\n638\t    }\n639\t\n640\t    if (currentState.iteration >= maxIterations) {\n641\t      currentState = { ...currentState, phase: 'max-iterations' };\n642\t      writeWorkflowState(currentState, projectDir);\n643\t      return { state: currentState, errors, tasksCompleted, halted: false };\n644\t    }\n645\t\n646\t    if (currentState.circuit_breaker.triggered) {\n647\t      currentState = { ...currentState, phase: 'circuit-breaker' };\n648\t      writeWorkflowState(currentState, projectDir);\n649\t      return { state: currentState, errors, tasksCompleted, halted: false };\n650\t    }\n651\t  }\n652\t}\n653\t\n654\t\n655\t// --- Main Execution ---\n656\t\n657\t/**\n658\t * Execute a workflow sequentially: iterate through flow steps, dispatch tasks\n659\t * per-story or per-run, checkpoint state after each dispatch.\n660\t *\n661\t * Loop blocks execute iteratively until pass, max-iterations, or circuit-breaker.\n662\t *\n663\t * Returns an EngineResult summarizing the execution.\n664\t */\n665\texport async function executeWorkflow(config: EngineConfig): Promise<EngineResult> {\n666\t  const startMs = Date.now();\n667\t  const projectDir = config.projectDir ?? process.cwd();\n668\t  const errors: EngineError[] = [];\n669\t  let tasksCompleted = 0;\n670\t  const processedStories = new Set<string>();\n671\t\n672\t  // 1. Read or initialize workflow state\n673\t  let state = readWorkflowState(projectDir);\n674\t\n675\t  // Early exit: workflow already completed (AC #6)\n676\t  if (state.phase === 'completed') {\n677\t    return {\n678\t      success: true,\n679\t      tasksCompleted: 0,\n680\t      storiesProcessed: 0,\n681\t      errors: [],\n682\t      durationMs: 0,\n683\t    };\n684\t  }\n685\t\n686\t  state = {\n687\t    ...state,\n688\t    phase: 'executing',\n689\t    started: state.started || new Date().toISOString(),\n690\t    workflow_name: config.workflow.flow.filter((s) => typeof s === 'string').join(' -> '),\n691\t  };\n692\t  writeWorkflowState(state, projectDir);\n693\t\n694\t  // 2. Load work items\n695\t  const workItems = loadWorkItems(config.sprintStatusPath, config.issuesPath);\n696\t\n697\t  // 3. Iterate through flow steps\n698\t  let halted = false;\n699\t  for (const step of config.workflow.flow) {\n700\t    if (halted) break;\n701\t\n702\t    // Execute loop blocks\n703\t    if (isLoopBlock(step)) {\n704\t      const loopResult = await executeLoopBlock(step, state, config, workItems);\n705\t      state = loopResult.state;\n706\t      errors.push(...loopResult.errors);\n707\t      tasksCompleted += loopResult.tasksCompleted;\n708\t\n709\t      // Track processed stories from loop\n710\t      for (const item of workItems) {\n711\t        processedStories.add(item.key);\n712\t      }\n713\t\n714\t      if (loopResult.halted) {\n715\t        halted = true;\n716\t      }\n717\t\n718\t      // If loop ended with max-iterations or circuit-breaker, treat as failure\n719\t      if (state.phase === 'max-iterations' || state.phase === 'circuit-breaker') {\n720\t        halted = true;\n721\t      }\n722\t      continue;\n723\t    }\n724\t\n725\t    // step is a string task name\n726\t    const taskName = step;\n727\t    const task = config.workflow.tasks[taskName];\n728\t\n729\t    if (!task) {\n730\t      warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n731\t      continue;\n732\t    }\n733\t\n734\t    // Look up the agent definition\n735\t    const definition = config.agents[task.agent];\n736\t    if (!definition) {\n737\t      warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n738\t      continue;\n739\t    }\n740\t\n741\t    if (task.scope === 'per-run') {\n742\t      // Skip if already completed (crash recovery — AC #3)\n743\t      if (isTaskCompleted(state, taskName, PER_RUN_SENTINEL)) {\n744\t        warn(`workflow-engine: skipping completed task ${taskName} for ${PER_RUN_SENTINEL}`);\n745\t        continue;\n746\t      }\n747\t\n748\t      // Per-run: dispatch once with sentinel key\n749\t      try {\n750\t        state = await dispatchTask(task, taskName, PER_RUN_SENTINEL, definition, state, config);\n751\t        tasksCompleted++;\n752\t      } catch (err: unknown) {\n753\t        const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n754\t        errors.push(engineError);\n755\t\n756\t        // Record error checkpoint in state (AC #13)\n757\t        state = recordErrorInState(state, taskName, PER_RUN_SENTINEL, engineError);\n758\t        writeWorkflowState(state, projectDir);\n759\t\n760\t        // Halt on critical errors\n761\t        if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n762\t          halted = true;\n763\t        }\n764\t      }\n765\t    } else {\n766\t      // Per-story: dispatch once per work item\n767\t      for (const item of workItems) {\n768\t        processedStories.add(item.key);\n769\t\n770\t        // Skip if already completed (crash recovery — AC #1, #2, #7)\n771\t        if (isTaskCompleted(state, taskName, item.key)) {\n772\t          warn(`workflow-engine: skipping completed task ${taskName} for ${item.key}`);\n773\t          continue;\n774\t        }\n775\t\n776\t        try {\n777\t          state = await dispatchTask(task, taskName, item.key, definition, state, config);\n778\t          tasksCompleted++;\n779\t        } catch (err: unknown) {\n780\t          const engineError = handleDispatchError(err, taskName, item.key);\n781\t          errors.push(engineError);\n782\t\n783\t          // Record error checkpoint in state (AC #13)\n784\t          state = recordErrorInState(state, taskName, item.key, engineError);\n785\t          writeWorkflowState(state, projectDir);\n786\t\n787\t          // Halt on critical errors, continue on UNKNOWN\n788\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n789\t            halted = true;\n790\t            break;\n791\t          }\n792\t          // UNKNOWN errors: record and continue to next story\n793\t          continue;\n794\t        }\n795\t      }\n796\t    }\n797\t  }\n798\t\n799\t  // 4. Set final phase if no errors and phase not already set by loop termination\n800\t  if (errors.length === 0 && state.phase !== 'max-iterations' && state.phase !== 'circuit-breaker') {\n801\t    state = { ...state, phase: 'completed' };\n802\t    writeWorkflowState(state, projectDir);\n803\t  }\n804\t\n805\t  // 5. Return result\n806\t  const loopTerminated = state.phase === 'max-iterations' || state.phase === 'circuit-breaker';\n807\t  return {\n808\t    success: errors.length === 0 && !loopTerminated,\n809\t    tasksCompleted,\n810\t    storiesProcessed: processedStories.size,\n811\t    errors,\n812\t    durationMs: Date.now() - startMs,\n813\t  };\n814\t}\n815\t\n816\t// --- Error Handling ---\n817\t\n818\t/**\n819\t * Record a dispatch error in workflow state: set phase to \"error\" and append\n820\t * a TaskCheckpoint with the error details (AC #13).\n821\t */\n822\tfunction recordErrorInState(\n823\t  state: WorkflowState,\n824\t  taskName: string,\n825\t  storyKey: string,\n826\t  error: EngineError,\n827\t): WorkflowState {\n828\t  const errorCheckpoint: TaskCheckpoint = {\n829\t    task_name: taskName,\n830\t    story_key: storyKey,\n831\t    completed_at: new Date().toISOString(),\n832\t  };\n833\t  return {\n834\t    ...state,\n835\t    phase: 'error',\n836\t    tasks_completed: [...state.tasks_completed, errorCheckpoint],\n837\t  };\n838\t}\n839\t\n840\tfunction handleDispatchError(err: unknown, taskName: string, storyKey: string): EngineError {\n841\t  if (err instanceof DispatchError) {\n842\t    return {\n843\t      taskName,\n844\t      storyKey,\n845\t      code: err.code,\n846\t      message: err.message,\n847\t    };\n848\t  }\n849\t\n850\t  const message = err instanceof Error ? err.message : String(err);\n851\t  return {\n852\t    taskName,\n853\t    storyKey,\n854\t    code: 'UNKNOWN',\n855\t    message,\n856\t  };\n857\t}\n858\t"}]},"parent_tool_use_id":"toolu_01GD3dd86R9DYmBSHRKfrVV3","session_id":"8b4a1da7-9e18-4302-ad13-ce7f0aff0314","uuid":"bdf871f0-74eb-4be8-947c-87a4aa3b311f","timestamp":"2026-04-02T22:53:23.965Z"}
