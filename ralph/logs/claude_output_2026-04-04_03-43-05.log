{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RjzQokJSQLYUVoFKGnPo8h","type":"tool_result","content":"1\t/**\n2\t * Ink Terminal Renderer — live terminal UI for Claude activity display.\n3\t * Exports startRenderer() which returns a RendererHandle for feeding events.\n4\t */\n5\t\n6\timport React from 'react';\n7\timport { render as inkRender } from 'ink';\n8\timport type { StreamEvent } from './agents/stream-parser.js';\n9\timport {\n10\t  App,\n11\t  type SprintInfo,\n12\t  type CompletedToolEntry,\n13\t  type RetryInfo,\n14\t  type RendererState,\n15\t  type StoryStatusEntry,\n16\t  type StoryMessage,\n17\t  type TaskNodeState,\n18\t  type TaskNodeMeta,\n19\t} from './ink-components.js';\n20\timport type { FlowStep } from './workflow-parser.js';\n21\t\n22\t// --- Public Types ---\n23\t\n24\texport interface RendererOptions {\n25\t  quiet?: boolean;\n26\t  sprintState?: SprintInfo;\n27\t  /** @internal Force TTY mode for testing. Not part of the public API. */\n28\t  _forceTTY?: boolean;\n29\t}\n30\t\n31\texport interface RendererHandle {\n32\t  update(event: StreamEvent, driverName?: string): void;\n33\t  updateSprintState(state: SprintInfo | undefined): void;\n34\t  updateStories(stories: StoryStatusEntry[]): void;\n35\t  addMessage(msg: StoryMessage): void;\n36\t  updateWorkflowState(flow: FlowStep[], currentTask: string | null, taskStates: Record<string, TaskNodeState>, taskMeta?: Record<string, TaskNodeMeta>): void;\n37\t  cleanup(): void;\n38\t  /** @internal Expose state for testing. Not part of the public API. */\n39\t  _getState?(): RendererState;\n40\t}\n41\t\n42\t// --- No-op handle for quiet mode ---\n43\t\n44\tconst noopHandle: RendererHandle = {\n45\t  update(_event: StreamEvent, _driverName?: string) {},\n46\t  updateSprintState() {},\n47\t  updateStories() {},\n48\t  addMessage() {},\n49\t  updateWorkflowState() {},\n50\t  cleanup() {},\n51\t};\n52\t\n53\t/** Maximum number of completed tools to retain in the display list. */\n54\tconst MAX_COMPLETED_TOOLS = 50;\n55\t\n56\t// --- Controller ---\n57\t\n58\t/**\n59\t * Start the Ink terminal renderer.\n60\t *\n61\t * If `quiet` is true or stdout is not a TTY, returns a no-op handle\n62\t * (no Ink instance created).\n63\t * Otherwise, mounts the component tree and returns a handle for feeding events.\n64\t */\n65\texport function startRenderer(options?: RendererOptions): RendererHandle {\n66\t  if (options?.quiet || (!process.stdout.isTTY && !options?._forceTTY)) {\n67\t    return noopHandle;\n68\t  }\n69\t\n70\t  // Mutable state that drives re-renders\n71\t  let state: RendererState = {\n72\t    sprintInfo: options?.sprintState ?? null,\n73\t    stories: [],\n74\t    messages: [],\n75\t    completedTools: [],\n76\t    activeTool: null,\n77\t    activeToolArgs: '',\n78\t    lastThought: null,\n79\t    retryInfo: null,\n80\t    workflowFlow: [],"}]},"parent_tool_use_id":"toolu_01AgQJFigSq3KJGDuPKevuMV","session_id":"568bb8a3-7cec-4d55-8fe6-c91654e95e9c","uuid":"67f9534a-2351-4da3-b5d0-cd1815dacc5e","timestamp":"2026-04-03T23:46:23.816Z"}
