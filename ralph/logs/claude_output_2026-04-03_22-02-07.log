{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WikfcksmAmwnY5xraDFKRY","type":"tool_result","content":"1\t/**\n2\t * AgentDriver abstraction types.\n3\t *\n4\t * Defines the contract that all agent drivers (Claude Code, Codex, OpenCode)\n5\t * must implement. See architecture-multi-framework.md Decision 1.\n6\t */\n7\t\n8\timport type { Readable } from 'node:stream';\n9\timport type { StreamEvent } from './stream-parser.js';\n10\t\n11\t// --- New Types (Epic 10) ---\n12\t\n13\t/**\n14\t * Health status returned by a driver's healthCheck().\n15\t */\n16\texport interface DriverHealth {\n17\t  readonly available: boolean;\n18\t  readonly authenticated: boolean;\n19\t  readonly version: string | null;\n20\t  readonly error?: string;\n21\t}\n22\t\n23\t/**\n24\t * Capability flags for a driver. Extensible — new boolean fields\n25\t * can be added without breaking existing drivers.\n26\t */\n27\texport interface DriverCapabilities {\n28\t  readonly supportsPlugins: boolean;\n29\t  readonly supportsStreaming: boolean;\n30\t  readonly costReporting: boolean;\n31\t  readonly costTier: number;\n32\t}\n33\t\n34\t/**\n35\t * A capability conflict or routing hint warning.\n36\t * Pure data — no side effects. Used by checkCapabilityConflicts().\n37\t */\n38\texport interface CapabilityWarning {\n39\t  readonly taskName: string;\n40\t  readonly driverName: string;\n41\t  readonly capability: string;\n42\t  readonly message: string;\n43\t}\n44\t\n45\t/**\n46\t * Error classification categories for driver errors.\n47\t * Drivers must NOT invent new categories.\n48\t *\n49\t * Classification priority:\n50\t * 1. HTTP 429 or \"rate limit\" in message -> RATE_LIMIT\n51\t * 2. ECONNREFUSED, ETIMEDOUT, ENOTFOUND -> NETWORK\n52\t * 3. HTTP 401/403 or \"unauthorized\"/\"forbidden\" -> AUTH\n53\t * 4. Process killed by timeout -> TIMEOUT\n54\t * 5. Everything else -> UNKNOWN\n55\t */\n56\texport type ErrorCategory = 'RATE_LIMIT' | 'NETWORK' | 'AUTH' | 'TIMEOUT' | 'UNKNOWN';\n57\t\n58\t/**\n59\t * Test results summary for an output contract.\n60\t */\n61\texport interface TestResults {\n62\t  readonly passed: number;\n63\t  readonly failed: number;\n64\t  readonly coverage: number | null;\n65\t}\n66\t\n67\t/**\n68\t * Acceptance criteria status entry.\n69\t */\n70\texport interface ACStatus {\n71\t  readonly id: string;\n72\t  readonly description: string;\n73\t  readonly status: string;\n74\t}\n75\t\n76\t/**\n77\t * Structured output contract produced by a dispatch.\n78\t */\n79\texport interface OutputContract {\n80\t  readonly version: number;\n81\t  readonly taskName: string;\n82\t  readonly storyId: string;\n83\t  readonly driver: string;\n84\t  readonly model: string;\n85\t  readonly timestamp: string;\n86\t  readonly cost_usd: number | null;\n87\t  readonly duration_ms: number;\n88\t  readonly changedFiles: readonly string[];\n89\t  readonly testResults: TestResults | null;\n90\t  readonly output: string;\n91\t  readonly acceptanceCriteria: readonly ACStatus[];\n92\t}\n93\t\n94\t/**\n95\t * Options for dispatching a task to a driver.\n96\t */\n97\texport interface DispatchOpts {\n98\t  readonly prompt: string;\n99\t  readonly model: string;\n100\t  readonly cwd: string;"}]},"parent_tool_use_id":"toolu_01DT9KbpB83SszJuvqgvyL6D","session_id":"9476bbd2-ee0a-4a5e-ac2a-0ed5228c47bf","uuid":"2150561b-1341-4f35-9ab1-31fbd7c6d434","timestamp":"2026-04-03T18:03:56.578Z"}
