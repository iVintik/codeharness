{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NrmSs6fjYVP2Ji1NYBvwfJ","type":"tool_result","content":"     1→/**\n     2→ * Migration from old scattered state files to unified sprint-state.json.\n     3→ * Runs once when sprint-state.json does not exist and old files are found.\n     4→ */\n     5→\n     6→import { readFileSync, existsSync } from 'node:fs';\n     7→import { join } from 'node:path';\n     8→import { ok, fail } from '../../types/result.js';\n     9→import type { Result } from '../../types/result.js';\n    10→import type { SprintState, SprintStateV1, StoryState, StoryStatus, ActionItem, SessionState } from '../../types/state.js';\n    11→import { defaultState, writeStateAtomic, computeSprintCounts } from './state.js';\n    12→\n    13→const OLD_FILES = {\n    14→  storyRetries: 'ralph/.story_retries',\n    15→  flaggedStories: 'ralph/.flagged_stories',\n    16→  ralphStatus: 'ralph/status.json',\n    17→  sprintStatusYaml: '_bmad-output/implementation-artifacts/sprint-status.yaml',\n    18→  sessionIssues: '_bmad-output/implementation-artifacts/.session-issues.md',\n    19→} as const;\n    20→\n    21→function resolve(relative: string): string {\n    22→  return join(process.cwd(), relative);\n    23→}\n    24→\n    25→function readIfExists(relative: string): string | null {\n    26→  const p = resolve(relative);\n    27→  if (!existsSync(p)) return null;\n    28→  try { return readFileSync(p, 'utf-8'); } catch { return null; }\n    29→}\n    30→\n    31→/** Return a fresh empty StoryState */\n    32→function emptyStory(): StoryState {\n    33→  return {\n    34→    status: 'backlog', attempts: 0, lastAttempt: null,\n    35→    lastError: null, proofPath: null, acResults: null,\n    36→  };\n    37→}\n    38→\n    39→/** Ensure a story entry exists, then apply a partial update */\n    40→function upsertStory(\n    41→  stories: Record<string, StoryState>,\n    42→  key: string,\n    43→  patch: Partial<StoryState>,\n    44→): void {\n    45→  stories[key] = { ...(stories[key] ?? emptyStory()), ...patch };\n    46→}\n    47→\n    48→/** Parse ralph/.story_retries: \"<key> <count>\" per line */\n    49→function parseStoryRetries(content: string, stories: Record<string, StoryState>): void {\n    50→  for (const line of content.split('\\n')) {\n    51→    const trimmed = line.trim();\n    52→    if (!trimmed) continue;\n    53→    const parts = trimmed.split(/\\s+/);\n    54→    if (parts.length < 2) continue;\n    55→    const count = parseInt(parts[1], 10);\n    56→    if (!isNaN(count)) upsertStory(stories, parts[0], { attempts: count });\n    57→  }\n    58→}\n    59→\n    60→/**\n    61→ * Parse ralph/.story_retries into a Record<string, number> for v2 retries field.\n    62→ * Format: \"<key> <count>\" per line (space-separated).\n    63→ */\n    64→export function parseStoryRetriesRecord(content: string): Record<string, number> {\n    65→  const result: Record<string, number> = {};\n    66→  for (const line of content.split('\\n')) {\n    67→    const trimmed = line.trim();\n    68→    if (!trimmed) continue;\n    69→    const parts = trimmed.split(/\\s+/);\n    70→    if (parts.length < 2) continue;\n    71→    const count = parseInt(parts[1], 10);\n    72→    if (!isNaN(count) && count >= 0) result[parts[0]] = count;\n    73→  }\n    74→  return result;\n    75→}\n    76→\n    77→/**\n    78→ * Parse ralph/.flagged_stories into a string[] for v2 flagged field.\n    79→ * Format: one key per line.\n    80→ */\n    81→export function parseFlaggedStoriesList(content: string): string[] {\n    82→  const seen = new Set<string>();\n    83→  const result: string[] = [];\n    84→  for (const line of content.split('\\n')) {\n    85→    const trimmed = line.trim();\n    86→    if (trimmed !== '' && !seen.has(trimmed)) {\n    87→      seen.add(trimmed);\n    88→      result.push(trimmed);\n    89→    }\n    90→  }\n    91→  return result;\n    92→}\n    93→\n    94→/** Parse ralph/.flagged_stories: one key per line */\n    95→function parseFlaggedStories(content: string, stories: Record<string, StoryState>): void {\n    96→  for (const line of content.split('\\n')) {\n    97→    const key = line.trim();\n    98→    if (key) upsertStory(stories, key, { status: 'blocked' });\n    99→  }\n   100→}\n   101→\n   102→/** Map YAML status strings to StoryStatus */\n   103→function mapYamlStatus(value: string): StoryStatus | null {\n   104→  const mapping: Record<string, StoryStatus> = {\n   105→    done: 'done', backlog: 'backlog', verifying: 'verifying',\n   106→    'in-progress': 'in-progress', 'ready-for-dev': 'ready',\n   107→    blocked: 'blocked', failed: 'failed', review: 'review', ready: 'ready',\n   108→  };\n   109→  return mapping[value.trim().toLowerCase()] ?? null;\n   110→}\n   111→\n   112→/**\n   113→ * Parse sprint-status.yaml (flat key: value).\n   114→ * Story lines like \"  1-1-result-type: done\" become entries.\n   115→ * Epic lines like \"  epic-1: done\" are skipped.\n   116→ */\n   117→function parseSprintStatusYaml(content: string, stories: Record<string, StoryState>): void {\n   118→  for (const line of content.split('\\n')) {\n   119→    const trimmed = line.trim();\n   120→    if (!trimmed || trimmed.startsWith('#')) continue;\n   121→    const match = trimmed.match(/^([a-zA-Z0-9_-]+):\\s*(.+)$/);\n   122→    if (!match) continue;\n   123→    const key = match[1];\n   124→    if (key === 'development_status' || key.startsWith('epic-')) continue;\n   125→    const status = mapYamlStatus(match[2]);\n   126→    if (status) upsertStory(stories, key, { status });\n   127→  }\n   128→}\n   129→\n   130→interface RalphStatusJson {\n   131→  loop_count?: number;\n   132→  stories_total?: number;\n   133→  stories_completed?: number;\n   134→  elapsed_seconds?: number;\n   135→  status?: string;\n   136→}\n   137→\n   138→/** Parse ralph/status.json into run section */\n   139→function parseRalphStatus(content: string): SprintState['run'] | null {\n   140→  try {\n   141→    const data = JSON.parse(content) as RalphStatusJson;\n   142→    return {\n   143→      active: data.status === 'running', startedAt: null,\n   144→      iteration: data.loop_count ?? 0, cost: 0, completed: [], failed: [],\n   145→      currentStory: null, currentPhase: null, lastAction: null, acProgress: null,\n   146→    };\n   147→  } catch { return null; }\n   148→}\n   149→\n   150→/** Parse ralph/status.json into SessionState for v2 */\n   151→function parseRalphStatusToSession(content: string): SessionState | null {\n   152→  try {\n   153→    const data = JSON.parse(content) as RalphStatusJson;\n   154→    return {\n   155→      active: data.status === 'running',\n   156→      startedAt: null,\n   157→      iteration: data.loop_count ?? 0,\n   158→      elapsedSeconds: data.elapsed_seconds ?? 0,\n   159→    };\n   160→  } catch { return null; }\n   161→}\n   162→\n   163→/** Parse .session-issues.md for action items (best effort) */\n   164→function parseSessionIssues(content: string): ActionItem[] {\n   165→  const items: ActionItem[] = [];\n   166→  let currentStory = '';\n   167→  let itemId = 0;\n   168→  for (const line of content.split('\\n')) {\n   169→    const headerMatch = line.match(/^###\\s+([a-zA-Z0-9_-]+)\\s*[—-]/);\n   170→    if (headerMatch) { currentStory = headerMatch[1]; continue; }\n   171→    const bulletMatch = line.match(/^-\\s+(.+)/);\n   172→    if (bulletMatch && currentStory) {\n   173→      itemId++;\n   174→      items.push({\n   175→        id: `migrated-${itemId}`, story: currentStory,\n   176→        description: bulletMatch[1], source: 'retro', resolved: false,\n   177→      });\n   178→    }\n   179→  }\n   180→  return items;\n   181→}\n   182→\n   183→/**\n   184→ * Migrate a v1 state to v2 by reading external files and merging into unified schema.\n   185→ * Does NOT delete source files (.story_retries, .flagged_stories).\n   186→ */\n   187→export function migrateV1ToV2(v1: SprintStateV1): SprintState {\n   188→  const defaults = defaultState();\n   189→\n   190→  // Read retries from external file\n   191→  const retriesContent = readIfExists(OLD_FILES.storyRetries);\n   192→  const retries = retriesContent ? parseStoryRetriesRecord(retriesContent) : {};\n   193→\n   194→  // Read flagged stories from external file\n   195→  const flaggedContent = readIfExists(OLD_FILES.flaggedStories);\n   196→  const flagged = flaggedContent ? parseFlaggedStoriesList(flaggedContent) : [];\n   197→\n   198→  // Read session info from ralph/status.json\n   199→  const statusContent = readIfExists(OLD_FILES.ralphStatus);\n   200→  const session = statusContent\n   201→    ? (parseRalphStatusToSession(statusContent) ?? defaults.session)\n   202→    : defaults.session;\n   203→\n   204→  return {\n   205→    version: 2,\n   206→    sprint: v1.sprint,\n   207→    stories: v1.stories,\n   208→    retries,\n   209→    flagged,\n   210→    epics: {},\n   211→    session,\n   212→    observability: defaults.observability,\n   213→    run: {\n   214→      ...defaults.run,\n   215→      ...v1.run,\n   216→    },\n   217→    actionItems: v1.actionItems,\n   218→  };\n   219→}\n   220→\n   221→/**\n   222→ * Migrate from old format files to SprintState.\n   223→ * Returns fail() if no old files exist (caller should use default).\n   224→ */\n   225→export function migrateFromOldFormat(): Result<SprintState> {\n   226→  const hasAnyOldFile = Object.values(OLD_FILES).some((rel) => existsSync(resolve(rel)));\n   227→  if (!hasAnyOldFile) return fail('No old format files found for migration');\n   228→\n   229→  try {\n   230→    const stories: Record<string, StoryState> = {};\n   231→    let run = defaultState().run;\n   232→    let actionItems: ActionItem[] = [];\n   233→\n   234→    const yamlContent = readIfExists(OLD_FILES.sprintStatusYaml);\n   235→    if (yamlContent) parseSprintStatusYaml(yamlContent, stories);\n   236→\n   237→    const retriesContent = readIfExists(OLD_FILES.storyRetries);\n   238→    if (retriesContent) parseStoryRetries(retriesContent, stories);\n   239→\n   240→    const flaggedContent = readIfExists(OLD_FILES.flaggedStories);\n   241→    if (flaggedContent) parseFlaggedStories(flaggedContent, stories);\n   242→\n   243→    const statusContent = readIfExists(OLD_FILES.ralphStatus);\n   244→    let session = defaultState().session;\n   245→    if (statusContent) {\n   246→      const parsed = parseRalphStatus(statusContent);\n   247→      if (parsed) run = parsed;\n   248→      const parsedSession = parseRalphStatusToSession(statusContent);\n   249→      if (parsedSession) session = parsedSession;\n   250→    }\n   251→\n   252→    const issuesContent = readIfExists(OLD_FILES.sessionIssues);\n   253→    if (issuesContent) actionItems = parseSessionIssues(issuesContent);\n   254→\n   255→    const sprint = computeSprintCounts(stories);\n   256→\n   257→    // Parse retries and flagged for v2 fields\n   258→    const retries = retriesContent ? parseStoryRetriesRecord(retriesContent) : {};\n   259→    const flagged = flaggedContent ? parseFlaggedStoriesList(flaggedContent) : [];\n   260→\n   261→    const migrated: SprintState = {\n   262→      version: 2,\n   263→      sprint,\n   264→      stories,\n   265→      retries,\n   266→      flagged,\n   267→      epics: {},\n   268→      session,\n   269→      observability: defaultState().observability,\n   270→      run,\n   271→      actionItems,\n   272→    };\n   273→\n   274→    const writeResult = writeStateAtomic(migrated);\n   275→    if (!writeResult.success) return fail(writeResult.error);\n   276→    return ok(migrated);\n   277→  } catch (err: unknown) {\n   278→    const msg = err instanceof Error ? err.message : String(err);\n   279→    return fail(`Migration failed: ${msg}`);\n   280→  }\n   281→}\n   282→"}]},"parent_tool_use_id":null,"session_id":"0e449f80-823c-4489-a784-b43b6c7039d6","uuid":"624be410-3f82-4b4b-98df-fe097d053f6d","timestamp":"2026-03-24T10:51:42.111Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ivintik/dev/personal/codeharness/src/modules/sprint/migration.ts","content":"/**\n * Migration from old scattered state files to unified sprint-state.json.\n * Runs once when sprint-state.json does not exist and old files are found.\n */\n\nimport { readFileSync, existsSync } from 'node:fs';\nimport { join } from 'node:path';\nimport { ok, fail } from '../../types/result.js';\nimport type { Result } from '../../types/result.js';\nimport type { SprintState, SprintStateV1, StoryState, StoryStatus, ActionItem, SessionState } from '../../types/state.js';\nimport { defaultState, writeStateAtomic, computeSprintCounts } from './state.js';\n\nconst OLD_FILES = {\n  storyRetries: 'ralph/.story_retries',\n  flaggedStories: 'ralph/.flagged_stories',\n  ralphStatus: 'ralph/status.json',\n  sprintStatusYaml: '_bmad-output/implementation-artifacts/sprint-status.yaml',\n  sessionIssues: '_bmad-output/implementation-artifacts/.session-issues.md',\n} as const;\n\nfunction resolve(relative: string): string {\n  return join(process.cwd(), relative);\n}\n\nfunction readIfExists(relative: string): string | null {\n  const p = resolve(relative);\n  if (!existsSync(p)) return null;\n  try { return readFileSync(p, 'utf-8'); } catch { return null; }\n}\n\n/** Return a fresh empty StoryState */\nfunction emptyStory(): StoryState {\n  return {\n    status: 'backlog', attempts: 0, lastAttempt: null,\n    lastError: null, proofPath: null, acResults: null,\n  };\n}\n\n/** Ensure a story entry exists, then apply a partial update */\nfunction upsertStory(\n  stories: Record<string, StoryState>,\n  key: string,\n  patch: Partial<StoryState>,\n): void {\n  stories[key] = { ...(stories[key] ?? emptyStory()), ...patch };\n}\n\n/** Parse ralph/.story_retries: \"<key> <count>\" per line */\nfunction parseStoryRetries(content: string, stories: Record<string, StoryState>): void {\n  for (const line of content.split('\\n')) {\n    const trimmed = line.trim();\n    if (!trimmed) continue;\n    const parts = trimmed.split(/\\s+/);\n    if (parts.length < 2) continue;\n    const count = parseInt(parts[1], 10);\n    if (!isNaN(count)) upsertStory(stories, parts[0], { attempts: count });\n  }\n}\n\n/**\n * Parse ralph/.story_retries into a Record<string, number> for v2 retries field.\n * Format: \"<key> <count>\" per line (space-separated).\n */\nexport function parseStoryRetriesRecord(content: string): Record<string, number> {\n  const result: Record<string, number> = {};\n  for (const line of content.split('\\n')) {\n    const trimmed = line.trim();\n    if (!trimmed) continue;\n    const parts = trimmed.split(/\\s+/);\n    if (parts.length < 2) continue;\n    const count = parseInt(parts[1], 10);\n    if (!isNaN(count) && count >= 0) result[parts[0]] = count;\n  }\n  return result;\n}\n\n/**\n * Parse ralph/.flagged_stories into a string[] for v2 flagged field.\n * Format: one key per line.\n */\nexport function parseFlaggedStoriesList(content: string): string[] {\n  const seen = new Set<string>();\n  const result: string[] = [];\n  for (const line of content.split('\\n')) {\n    const trimmed = line.trim();\n    if (trimmed !== '' && !seen.has(trimmed)) {\n      seen.add(trimmed);\n      result.push(trimmed);\n    }\n  }\n  return result;\n}\n\n/** Parse ralph/.flagged_stories: one key per line */\nfunction parseFlaggedStories(content: string, stories: Record<string, StoryState>): void {\n  for (const line of content.split('\\n')) {\n    const key = line.trim();\n    if (key) upsertStory(stories, key, { status: 'blocked' });\n  }\n}\n\n/** Map YAML status strings to StoryStatus */\nfunction mapYamlStatus(value: string): StoryStatus | null {\n  const mapping: Record<string, StoryStatus> = {\n    done: 'done', backlog: 'backlog', verifying: 'verifying',\n    'in-progress': 'in-progress', 'ready-for-dev': 'ready',\n    blocked: 'blocked', failed: 'failed', review: 'review', ready: 'ready',\n  };\n  return mapping[value.trim().toLowerCase()] ?? null;\n}\n\n/**\n * Parse sprint-status.yaml (flat key: value).\n * Story lines like \"  1-1-result-type: done\" become entries.\n * Epic lines like \"  epic-1: done\" are skipped.\n */\nfunction parseSprintStatusYaml(content: string, stories: Record<string, StoryState>): void {\n  for (const line of content.split('\\n')) {\n    const trimmed = line.trim();\n    if (!trimmed || trimmed.startsWith('#')) continue;\n    const match = trimmed.match(/^([a-zA-Z0-9_-]+):\\s*(.+)$/);\n    if (!match) continue;\n    const key = match[1];\n    if (key === 'development_status' || key.startsWith('epic-')) continue;\n    const status = mapYamlStatus(match[2]);\n    if (status) upsertStory(stories, key, { status });\n  }\n}\n\ninterface RalphStatusJson {\n  loop_count?: number;\n  stories_total?: number;\n  stories_completed?: number;\n  elapsed_seconds?: number;\n  status?: string;\n}\n\n/** Parse ralph/status.json into run section */\nfunction parseRalphStatus(content: string): SprintState['run'] | null {\n  try {\n    const data = JSON.parse(content) as RalphStatusJson;\n    return {\n      active: data.status === 'running', startedAt: null,\n      iteration: data.loop_count ?? 0, cost: 0, completed: [], failed: [],\n      currentStory: null, currentPhase: null, lastAction: null, acProgress: null,\n    };\n  } catch { return null; }\n}\n\n/** Parse ralph/status.json into SessionState for v2 */\nfunction parseRalphStatusToSession(content: string): SessionState | null {\n  try {\n    const data = JSON.parse(content) as RalphStatusJson;\n    return {\n      active: data.status === 'running',\n      startedAt: null,\n      iteration: data.loop_count ?? 0,\n      elapsedSeconds: data.elapsed_seconds ?? 0,\n    };\n  } catch { return null; }\n}\n\n/** Parse .session-issues.md for action items (best effort) */\nfunction parseSessionIssues(content: string): ActionItem[] {\n  const items: ActionItem[] = [];\n  let currentStory = '';\n  let itemId = 0;\n  for (const line of content.split('\\n')) {\n    const headerMatch = line.match(/^###\\s+([a-zA-Z0-9_-]+)\\s*[—-]/);\n    if (headerMatch) { currentStory = headerMatch[1]; continue; }\n    const bulletMatch = line.match(/^-\\s+(.+)/);\n    if (bulletMatch && currentStory) {\n      itemId++;\n      items.push({\n        id: `migrated-${itemId}`, story: currentStory,\n        description: bulletMatch[1], source: 'retro', resolved: false,\n      });\n    }\n  }\n  return items;\n}\n\n/**\n * Migrate a v1 state to v2 by reading external files and merging into unified schema.\n * Does NOT delete source files (.story_retries, .flagged_stories).\n */\nexport function migrateV1ToV2(v1: SprintStateV1): SprintState {\n  const defaults = defaultState();\n\n  // Read retries from external file\n  const retriesContent = readIfExists(OLD_FILES.storyRetries);\n  const retries = retriesContent ? parseStoryRetriesRecord(retriesContent) : {};\n\n  // Read flagged stories from external file\n  const flaggedContent = readIfExists(OLD_FILES.flaggedStories);\n  const flagged = flaggedContent ? parseFlaggedStoriesList(flaggedContent) : [];\n\n  // Read session info from ralph/status.json\n  const statusContent = readIfExists(OLD_FILES.ralphStatus);\n  const session = statusContent\n    ? (parseRalphStatusToSession(statusContent) ?? defaults.session)\n    : defaults.session;\n\n  return {\n    version: 2,\n    sprint: v1.sprint,\n    stories: v1.stories,\n    retries,\n    flagged,\n    epics: {},\n    session,\n    observability: defaults.observability,\n    run: {\n      ...defaults.run,\n      ...v1.run,\n    },\n    actionItems: v1.actionItems,\n  };\n}\n\n/**\n * Migrate from old format files to SprintState.\n * Returns fail() if no old files exist (caller should use default).\n */\nexport function migrateFromOldFormat(): Result<SprintState> {\n  const hasAnyOldFile = Object.values(OLD_FILES).some((rel) => existsSync(resolve(rel)));\n  if (!hasAnyOldFile) return fail('No old format files found for migration');\n\n  try {\n    const stories: Record<string, StoryState> = {};\n    let run = defaultState().run;\n    let actionItems: ActionItem[] = [];\n\n    const yamlContent = readIfExists(OLD_FILES.sprintStatusYaml);\n    if (yamlContent) parseSprintStatusYaml(yamlContent, stories);\n\n    const retriesContent = readIfExists(OLD_FILES.storyRetries);\n    if (retriesContent) parseStoryRetries(retriesContent, stories);\n\n    const flaggedContent = readIfExists(OLD_FILES.flaggedStories);\n    if (flaggedContent) parseFlaggedStories(flaggedContent, stories);\n\n    const statusContent = readIfExists(OLD_FILES.ralphStatus);\n    let session = defaultState().session;\n    if (statusContent) {\n      const parsed = parseRalphStatus(statusContent);\n      if (parsed) run = parsed;\n      const parsedSession = parseRalphStatusToSession(statusContent);\n      if (parsedSession) session = parsedSession;\n    }\n\n    const issuesContent = readIfExists(OLD_FILES.sessionIssues);\n    if (issuesContent) actionItems = parseSessionIssues(issuesContent);\n\n    const sprint = computeSprintCounts(stories);\n\n    // Parse retries and flagged for v2 fields\n    const retries = retriesContent ? parseStoryRetriesRecord(retriesContent) : {};\n    const flagged = flaggedContent ? parseFlaggedStoriesList(flaggedContent) : [];\n\n    const migrated: SprintState = {\n      version: 2,\n      sprint,\n      stories,\n      retries,\n      flagged,\n      epics: {},\n      session,\n      observability: defaultState().observability,\n      run,\n      actionItems,\n    };\n\n    const writeResult = writeStateAtomic(migrated);\n    if (!writeResult.success) return fail(writeResult.error);\n    return ok(migrated);\n  } catch (err: unknown) {\n    const msg = err instanceof Error ? err.message : String(err);\n    return fail(`Migration failed: ${msg}`);\n  }\n}\n","numLines":282,"startLine":1,"totalLines":282}}}
