       pid: 12345,\n    39→        stdin: null,\n    40→        stdout: stdoutEmitter,\n    41→        stderr: stderrEmitter,\n    42→      };\n    43→    }),\n    44→    getChildOnHandlers: () => handlers,\n    45→    existsSyncMock: vi.fn(realFn),\n    46→    readSprintStatusMock: vi.fn(() => ({}) as Record<string, string>),\n    47→    realExistsSync: realFn as (path: string) => boolean,\n    48→    getStdoutEmitter: () => stdoutEmitter,\n    49→    getStderrEmitter: () => stderrEmitter,\n    50→    startRendererMock: vi.fn(() => ({\n    51→      update: rendererUpdateMock,\n    52→      updateSprintState: rendererUpdateSprintStateMock,\n    53→      cleanup: rendererCleanupMock,\n    54→    })),\n    55→    rendererUpdateMock,\n    56→    rendererUpdateSprintStateMock,\n    57→    rendererCleanupMock,\n    58→    parseStreamLineMock: vi.fn(() => null),\n    59→    getSprintStateMock: vi.fn(() => ({ success: false, error: 'no state' })),\n    60→  };\n    61→});\n    62→\n    63→vi.mock('node:child_process', () => ({ spawn: spawnMock }));\n    64→\n    65→vi.mock('node:fs', async (importOriginal) => {\n    66→  const actual = await importOriginal<typeof import('node:fs')>();\n    67→  return { ...actual, existsSync: existsSyncMock };\n    68→});\n    69→\n    70→vi.mock('../../lib/beads-sync.js', () => ({\n    71→  readSprintStatus: (...args: unknown[]) => readSprintStatusMock(...args),\n    72→}));\n    73→\n    74→vi.mock('../../templates/ralph-prompt.js', () => ({\n    75→  generateRalphPrompt: vi.fn(() => 'mock prompt content'),\n    76→}));\n    77→\n    78→vi.mock('../../lib/stream-parser.js', () => ({\n    79→  parseStreamLine: (...args: unknown[]) => parseStreamLineMock(...args),\n    80→}));\n    81→\n    82→vi.mock('../../lib/ink-renderer.js', () => ({\n    83→  startRenderer: (...args: unknown[]) => startRendererMock(...args),\n    84→}));\n    85→\n    86→vi.mock('../../modules/sprint/index.js', () => ({\n    87→  getSprintState: (...args: unknown[]) => getSprintStateMock(...args),\n    88→}));\n    89→\n    90→describe('run command', () => {\n    91→  let tmpDir: string;\n    92→\n    93→  beforeEach(() => {\n    94→    tmpDir = mkdtempSync(join(tmpdir(), 'run-test-'));\n    95→    spawnMock.mockClear();\n    96→    existsSyncMock.mockReset();\n    97→    existsSyncMock.mockImplementation((p: unknown) => realExistsSync(String(p)));\n    98→    readSprintStatusMock.mockReset();\n    99→    readSprintStatusMock.mockReturnValue({});\n   100→    startRendererMock.mockClear();\n   101→    rendererUpdateMock.mockClear();\n   102→    rendererUpdateSprintStateMock.mockClear();\n   103→    rendererCleanupMock.mockClear();\n   104→    parseStreamLineMock.mockClear();\n   105→    parseStreamLineMock.mockReturnValue(null);\n   106→    getSprintStateMock.mockClear();\n   107→    getSprintStateMock.mockReturnValue({ success: false, error: 'no state' });\n   108→    process.exitCode = undefined;\n   109→  });\n   110→\n   111→  afterEach(() => {\n   112→    rmSync(tmpDir, { recursive: true, force: true });\n   113→    vi.restoreAllMocks();\n   114→    process.exitCode = undefined;\n   115→  });\n   116→\n   117→  // Helper to control existsSync per path pattern\n   118→  function mockPaths(overrides: Record<string, boolean>) {\n   119→    existsSyncMock.mockImplementation((p: unknown) => {\n   120→      const path = String(p);\n   121→      for (const [pattern, value] of Object.entries(overrides)) {\n   122→        if (path.includes(pattern)) return value;\n   123→      }\n   124→      return realExistsSync(path);\n   125→    });\n   126→  }\n   127→\n   128→  // Helper to invoke the run command via Commander\n   129→  async function runCommand(args: string[] = []) {\n   130→    const { registerRunCommand } = await import('../run.js');\n   131→    const program = new Command();\n   132→    program.exitOverride();\n   133→    program.option('--json', 'JSON output');\n   134→    registerRunCommand(program);\n   135→    await program.parseAsync(['node', 'codeharness', 'run', ...args]);\n   136→  }\n   137→\n   138→  describe('resolveRalphPath', () => {\n   139→    it('returns a path ending with ralph/ralph.sh', () => {\n   140→      expect(resolveRalphPath()).toMatch(/ralph[/\\\\]ralph\\.sh$/);\n   141→    });\n   142→\n   143→    it('resolves to a path within the project', () => {\n   144→      expect(resolveRalphPath()).toContain('ralph');\n   145→    });\n   146→  });\n   147→\n   148→  describe('resolvePluginDir', () => {\n   149→    it('returns cwd/.claude', () => {\n   150→      expect(resolvePluginDir()).toBe(join(process.cwd(), '.claude'));\n   151→    });\n   152→  });\n   153→\n   154→  describe('countStories', () => {\n   155→    it('counts stories by status correctly', () => {\n   156→      const counts = countStories({\n   157→        'epic-5': 'in-progress',\n   158→        '5-1-ralph-loop': 'ready-for-dev',\n   159→        '5-2-verification': 'backlog',\n   160→        '5-3-tracking': 'done',\n   161→        '5-4-another': 'in-progress',\n   162→        'epic-5-retrospective': 'optional',\n   163→      });\n   164→      expect(counts).toEqual({ total: 4, ready: 2, done: 1, inProgress: 1, verified: 0 });\n   165→    });\n   166→\n   167→    it('ignores epic keys and retrospective keys', () => {\n   168→      const counts = countStories({\n   169→        'epic-1': 'done', 'epic-1-retrospective': 'done',\n   170→        '1-1-story-one': 'done', '1-2-story-two': 'done',\n   171→      });\n   172→      expect(counts.total).toBe(2);\n   173→      expect(counts.done).toBe(2);\n   174→    });\n   175→\n   176→    it('returns zeros for empty statuses', () => {\n   177→      expect(countStories({})).toEqual({ total: 0, ready: 0, done: 0, inProgress: 0, verified: 0 });\n   178→    });\n   179→\n   180→    it('counts review status as inProgress', () => {\n   181→      expect(countStories({ '1-1-story': 'review' }).inProgress).toBe(1);\n   182→    });\n   183→\n   184→    it('counts verifying status separately', () => {\n   185→      const counts = countStories({\n   186→        '1-1-story': 'verifying',\n   187→        '1-2-story': 'verifying',\n   188→        '1-3-story': 'done',\n   189→      });\n   190→      expect(counts).toEqual({ total: 3, ready: 0, done: 1, inProgress: 0, verified: 2 });\n   191→    });\n   192→  });\n   193→\n   194→  describe('buildSpawnArgs', () => {\n   195→    const baseOpts = {\n   196→      ralphPath: '/path/to/ralph.sh',\n   197→      pluginDir: '/path/to/.claude',\n   198→      promptFile: '/path/to/prompt.md',\n   199→      maxIterations: 50,\n   200→      timeout: 14400,\n   201→      iterationTimeout: 15,\n   202→      calls: 100,\n   203→      quiet: false,\n   204→    };\n   205→\n   206→    it('builds basic argument array', () => {\n   207→      const args = buildSpawnArgs(baseOpts);\n   208→      expect(args).toContain('/path/to/ralph.sh');\n   209→      expect(args).toContain('--plugin-dir');\n   210→      expect(args).toContain('50');\n   211→    });\n   212→\n   213→    it('never includes --live flag (removed)', () => {\n   214→      expect(buildSpawnArgs(baseOpts)).not.toContain('--live');\n   215→      expect(buildSpawnArgs({ ...baseOpts, quiet: true })).not.toContain('--live');\n   216→    });\n   217→\n   218→    it('includes --max-story-retries when provided', () => {\n   219→      const args = buildSpawnArgs({ ...baseOpts, maxStoryRetries: 5 });\n   220→      expect(args).toContain('--max-story-retries');\n   221→      expect(args).toContain('5');\n   222→    });\n   223→\n   224→    it('does not include --max-story-retries when undefined', () => {\n   225→      expect(buildSpawnArgs(baseOpts)).not.toContain('--max-story-retries');\n   226→    });\n   227→  });\n   228→\n   229→  describe('action handler', () => {\n   230→    it('fails when ralph script not found', async () => {\n   231→      mockPaths({ 'ralph.sh': false });\n   232→      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n   233→\n   234→      await runCommand();\n   235→\n   236→      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Ralph loop not found'));\n   237→      expect(process.exitCode).toBe(1);\n   238→    });\n   239→\n   240→    it('fails when plugin directory not found', async () => {\n   241→      mockPaths({ 'ralph.sh': true, '.claude': false });\n   242→      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n   243→\n   244→      await runCommand();\n   245→\n   246→      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Plugin directory not found'));\n   247→      expect(process.exitCode).toBe(1);\n   248→    });\n   249→\n   250→    it('fails when no stories in sprint-status.yaml', async () => {\n   251→      mockPaths({ 'ralph.sh': true, '.claude': true });\n   252→      readSprintStatusMock.mockReturnValue({});\n   253→      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n   254→\n   255→      await runCommand();\n   256→\n   257→      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('No stories found'));\n   258→      expect(process.exitCode).toBe(1);\n   259→    });\n   260→\n   261→    it('fails with invalid numeric options', async () => {\n   262→      mockPaths({ 'ralph.sh': true, '.claude': true });\n   263→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   264→      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n   265→\n   266→      await runCommand(['--max-iterations', 'abc']);\n   267→\n   268→      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Invalid numeric option'));\n   269→      expect(process.exitCode).toBe(1);\n   270→    });\n   271→\n   272→    it('spawns ralph and propagates exit code 0', async () => {\n   273→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   274→      mockPaths({ 'ralph.sh': true, '.claude': true, '.flagged_stories': false });\n   275→      readSprintStatusMock.mockReturnValue({ '1-1-do-stuff': 'backlog' });\n   276→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   277→\n   278→      const p = runCommand();\n   279→      await vi.waitFor(() => expect(spawnMock).toHaveBeenCalled());\n   280→      getChildOnHandlers()['close'](0);\n   281→      await p;\n   282→\n   283→      expect(spawnMock).toHaveBeenCalledWith('bash', expect.any(Array), expect.objectContaining({\n   284→        cwd: tmpDir,\n   285→      }));\n   286→      expect(process.exitCode).toBe(0);\n   287→    });\n   288→\n   289→    it('propagates non-zero exit code from ralph', async () => {\n   290→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   291→      mockPaths({ 'ralph.sh': true, '.claude': true, '.flagged_stories': false });\n   292→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   293→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   294→\n   295→      const p = runCommand();\n   296→      await vi.waitFor(() => expect(spawnMock).toHaveBeenCalled());\n   297→      getChildOnHandlers()['close'](42);\n   298→      await p;\n   299→\n   300→      expect(process.exitCode).toBe(42);\n   301→    });\n   302→\n   303→    it('handles spawn error gracefully', async () => {\n   304→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   305→      mockPaths({ 'ralph.sh': true, '.claude': true, '.flagged_stories': false });\n   306→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   307→      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n   308→\n   309→      const p = runCommand();\n   310→      await vi.waitFor(() => expect(spawnMock).toHaveBeenCalled());\n   311→      getChildOnHandlers()['error'](new Error('ENOENT: bash not found'));\n   312→      await p;\n   313→\n   314→      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Failed to start Ralph'));\n   315→      expect(process.exitCode).toBe(1);\n   316→    });\n   317→\n   318→    it('outputs JSON with status.json present', async () => {\n   319→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   320→      mkdirSync(join(tmpDir, 'ralph'), { recursive: true });\n   321→      writeFileSync(join(tmpDir, 'ralph', 'status.json'), JSON.stringify({\n   322→        status: 'completed', loop_count: 5, elapsed_seconds: 120,\n   323→        flagged_stories: [], exit_reason: 'all_done',\n   324→      }));\n   325→      mockPaths({ 'ralph.sh': true, '.claude': true, '.flagged_stories': false });\n   326→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'done' });\n   327→      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n   328→\n   329→      const p = runCommand(['--json']);\n   330→      await vi.waitFor(() => expect(spawnMock).toHaveBeenCalled());\n   331→      getChildOnHandlers()['close'](0);\n   332→      await p;\n   333→\n   334→      // Find the final JSON output (has storiesCompleted, not the info() call)\n   335→      const jsonCall = consoleSpy.mock.calls.find(\n   336→        call => typeof call[0] === 'string' && call[0].includes('\"storiesCompleted\"')\n   337→      );\n   338→      expect(jsonCall).toBeDefined();\n   339→      const output = JSON.parse(jsonCall![0] as string);\n   340→      expect(output.status).toBe('completed');\n   341→      expect(output.iterations).toBe(5);\n   342→      expect(output.storiesCompleted).toBe(1);\n   343→      expect(output.exitReason).toBe('all_done');\n   344→    });\n   345→\n   346→    it('outputs JSON fallback when status.json missing', async () => {\n   347→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   348→      mockPaths({ 'ralph.sh': true, '.claude': true, '.flagged_stories': false, 'status.json': false });\n   349→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   350→      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n   351→\n   352→   