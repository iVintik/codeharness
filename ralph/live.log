{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QPEt5KsiFXULLP65XsUeqZ","type":"tool_result","content":"     1→/**\n     2→ * Sprint state consistency validator — verifies sprint-state.json integrity\n     3→ * after long runs. All functions return Result<T>, never throw.\n     4→ */\n     5→\n     6→import { readFileSync, existsSync } from 'node:fs';\n     7→import { ok, fail } from '../../types/result.js';\n     8→import type { Result } from '../../types/result.js';\n     9→import type { SprintState, StoryStatus } from '../../types/state.js';\n    10→\n    11→/** Valid story status values */\n    12→const VALID_STATUSES: ReadonlySet<string> = new Set<StoryStatus>([\n    13→  'backlog',\n    14→  'ready',\n    15→  'in-progress',\n    16→  'review',\n    17→  'verifying',\n    18→  'done',\n    19→  'failed',\n    20→  'blocked',\n    21→]);\n    22→\n    23→/** A single validation issue found in the state */\n    24→export interface ValidationIssue {\n    25→  readonly storyKey: string;\n    26→  readonly field: string;\n    27→  readonly message: string;\n    28→}\n    29→\n    30→/** Report from validateStateConsistency */\n    31→export interface ValidationReport {\n    32→  readonly totalStories: number;\n    33→  readonly validCount: number;\n    34→  readonly invalidCount: number;\n    35→  readonly missingKeys: ReadonlyArray<string>;\n    36→  readonly issues: ReadonlyArray<ValidationIssue>;\n    37→}\n    38→\n    39→/** Threshold in ms — lastError older than this relative to lastAttempt is stale */\n    40→const STALE_THRESHOLD_MS = 24 * 60 * 60 * 1000; // 24 hours\n    41→\n    42→/**\n    43→ * Parse sprint-status.yaml and extract story keys.\n    44→ * Minimal parser: looks for top-level keys ending with ':'\n    45→ * that have a 'status:' child property.\n    46→ */\n    47→export function parseSprintStatusKeys(content: string): Result<string[]> {\n    48→  try {\n    49→    const keys: string[] = [];\n    50→    const lines = content.split('\\n');\n    51→\n    52→    for (let i = 0; i < lines.length; i++) {\n    53→      const line = lines[i];\n    54→      // Match top-level keys (no leading whitespace, ends with colon)\n    55→      const match = line.match(/^([a-zA-Z0-9][a-zA-Z0-9._-]*):$/);\n    56→      if (match) {\n    57→        keys.push(match[1]);\n    58→      }\n    59→    }\n    60→\n    61→    return ok(keys);\n    62→  } catch (err: unknown) {\n    63→    const msg = err instanceof Error ? err.message : String(err);\n    64→    return fail(`Failed to parse sprint-status.yaml: ${msg}`);\n    65→  }\n    66→}\n    67→\n    68→/**\n    69→ * Parse a sprint-state.json file and return the SprintState.\n    70→ */\n    71→export function parseStateFile(statePath: string): Result<SprintState> {\n    72→  try {\n    73→    if (!existsSync(statePath)) {\n    74→      return fail(`State file not found: ${statePath}`);\n    75→    }\n    76→\n    77→    const raw = readFileSync(statePath, 'utf-8');\n    78→    const parsed = JSON.parse(raw) as SprintState;\n    79→    return ok(parsed);\n    80→  } catch (err: unknown) {\n    81→    const msg = err instanceof Error ? err.message : String(err);\n    82→    return fail(`Failed to parse state file: ${msg}`);\n    83→  }\n    84→}\n    85→\n    86→/**\n    87→ * Validate sprint-state.json consistency against sprint-status.yaml.\n    88→ *\n    89→ * Checks:\n    90→ * - Every story in sprint-status.yaml has a sprint-state.json entry\n    91→ * - All status values are valid enum members\n    92→ * - All attempt counts are non-negative integers\n    93→ * - lastError is non-stale (timestamp within last attempt window)\n    94→ */\n    95→export function validateStateConsistency(\n    96→  statePath: string,\n    97→  sprintStatusPath: string,\n    98→): Result<ValidationReport> {\n    99→  try {\n   100→    // Read and parse state file\n   101→    const stateResult = parseStateFile(statePath);\n   102→    if (!stateResult.success) {\n   103→      return fail(stateResult.error);\n   104→    }\n   105→    const state = stateResult.data;\n   106→\n   107→    // Read and parse sprint-status.yaml\n   108→    if (!existsSync(sprintStatusPath)) {\n   109→      return fail(`Sprint status file not found: ${sprintStatusPath}`);\n   110→    }\n   111→\n   112→    const statusContent = readFileSync(sprintStatusPath, 'utf-8');\n   113→    const keysResult = parseSprintStatusKeys(statusContent);\n   114→    if (!keysResult.success) {\n   115→      return fail(keysResult.error);\n   116→    }\n   117→    const expectedKeys = keysResult.data;\n   118→\n   119→    const issues: ValidationIssue[] = [];\n   120→    const missingKeys: string[] = [];\n   121→\n   122→    // Check: every story in sprint-status.yaml has a sprint-state.json entry\n   123→    for (const key of expectedKeys) {\n   124→      if (!(key in state.stories)) {\n   125→        missingKeys.push(key);\n   126→        issues.push({\n   127→          storyKey: key,\n   128→          field: 'entry',\n   129→          message: `Story \"${key}\" in sprint-status.yaml has no entry in sprint-state.json`,\n   130→        });\n   131→      }\n   132→    }\n   133→\n   134→    // Check: sprint.total matches actual story count in state\n   135→    const actualStoryCount = Object.keys(state.stories).length;\n   136→    if (state.sprint.total !== actualStoryCount) {\n   137→      issues.push({\n   138→        storyKey: '_sprint',\n   139→        field: 'sprint.total',\n   140→        message: `sprint.total is ${state.sprint.total} but state has ${actualStoryCount} stories`,\n   141→      });\n   142→    }\n   143→\n   144→    // Check: stories in state that are not in sprint-status.yaml\n   145→    for (const key of Object.keys(state.stories)) {\n   146→      if (!expectedKeys.includes(key)) {\n   147→        issues.push({\n   148→          storyKey: key,\n   149→          field: 'entry',\n   150→          message: `Story \"${key}\" in sprint-state.json has no entry in sprint-status.yaml`,\n   151→        });\n   152→      }\n   153→    }\n   154→\n   155→    // Validate each story in state\n   156→    for (const [key, story] of Object.entries(state.stories)) {\n   157→      // Check: valid status\n   158→      if (!VALID_STATUSES.has(story.status)) {\n   159→        issues.push({\n   160→          storyKey: key,\n   161→          field: 'status',\n   162→          message: `Invalid status \"${story.status}\" (expected one of: ${[...VALID_STATUSES].join(', ')})`,\n   163→        });\n   164→      }\n   165→\n   166→      // Check: non-negative integer attempts\n   167→      if (\n   168→        typeof story.attempts !== 'number' ||\n   169→        !Number.isInteger(story.attempts) ||\n   170→        story.attempts < 0\n   171→      ) {\n   172→        issues.push({\n   173→          storyKey: key,\n   174→          field: 'attempts',\n   175→          message: `Invalid attempts value \"${story.attempts}\" (must be non-negative integer)`,\n   176→        });\n   177→      }\n   178→\n   179→      // Check: lastError staleness\n   180→      if (story.lastError !== null && story.lastAttempt !== null) {\n   181→        const attemptTime = new Date(story.lastAttempt).getTime();\n   182→        const now = Date.now();\n   183→        if (!isNaN(attemptTime) && now - attemptTime > STALE_THRESHOLD_MS) {\n   184→          issues.push({\n   185→            storyKey: key,\n   186→            field: 'lastError',\n   187→            message: `Stale lastError: lastAttempt was \"${story.lastAttempt}\" (>24h ago)`,\n   188→          });\n   189→        }\n   190→      }\n   191→    }\n   192→\n   193→    // Total = union of sprint-status keys and state keys\n   194→    const allKeys = new Set([...expectedKeys, ...Object.keys(state.stories)]);\n   195→    const totalStories = allKeys.size;\n   196→    const invalidCount = new Set(issues.map((i) => i.storyKey)).size;\n   197→    const validCount = totalStories - invalidCount;\n   198→\n   199→    return ok({\n   200→      totalStories,\n   201→      validCount,\n   202→      invalidCount,\n   203→      missingKeys,\n   204→      issues,\n   205→    });\n   206→  } catch (err: unknown) {\n   207→    const msg = err instanceof Error ? err.message : String(err);\n   208→    return fail(`Validation failed: ${msg}`);\n   209→  }\n   210→}\n   211→"}]},"parent_tool_use_id":"toolu_011K77Q1Nc8EiPZnCgrdVKHN","session_id":"01503c00-15e6-46f1-b837-b4628ff69656","uuid":"4c0611e4-6e94-4055-84dd-46b701237bb6","timestamp":"2026-03-24T11:33:11.846Z"}
