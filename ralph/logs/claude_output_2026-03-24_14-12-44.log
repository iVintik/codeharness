{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UCjraS5FdADyButfpEDq9w","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { generateReport, getStoryDrillDown } from '../reporter.js';\n     3→import type { SprintState, StoryState, AcResult } from '../../../types/state.js';\n     4→\n     5→const S_DEFAULTS: StoryState = {\n     6→  status: 'backlog', attempts: 0, lastAttempt: null,\n     7→  lastError: null, proofPath: null, acResults: null,\n     8→};\n     9→\n    10→function s(overrides?: Partial<StoryState>): StoryState {\n    11→  return { ...S_DEFAULTS, ...overrides };\n    12→}\n    13→\n    14→function makeState(overrides?: Partial<SprintState>): SprintState {\n    15→  return {\n    16→    version: 1,\n    17→    sprint: { total: 0, done: 0, failed: 0, blocked: 0, inProgress: null },\n    18→    stories: {},\n    19→    run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [] },\n    20→    actionItems: [],\n    21→    ...overrides,\n    22→  };\n    23→}\n    24→\n    25→const NOW = new Date('2026-03-18T12:00:00Z');\n    26→\n    27→describe('generateReport', () => {\n    28→  it('returns valid report with zero counts for empty state', () => {\n    29→    const result = generateReport(makeState(), NOW);\n    30→    expect(result.success).toBe(true);\n    31→    if (!result.success) return;\n    32→    expect(result.data.total).toBe(0);\n    33→    expect(result.data.done).toBe(0);\n    34→    expect(result.data.failed).toBe(0);\n    35→    expect(result.data.blocked).toBe(0);\n    36→    expect(result.data.inProgress).toBeNull();\n    37→    expect(result.data.storyStatuses).toEqual([]);\n    38→    expect(result.data.epicsTotal).toBe(0);\n    39→    expect(result.data.epicsDone).toBe(0);\n    40→    expect(result.data.sprintPercent).toBe(0);\n    41→    expect(result.data.activeRun).toBeNull();\n    42→    expect(result.data.lastRun).toBeNull();\n    43→    expect(result.data.failedDetails).toEqual([]);\n    44→    expect(result.data.actionItemsLabeled).toEqual([]);\n    45→  });\n    46→\n    47→  it('includes current story, iteration, cost, elapsed for active run', () => {\n    48→    const state = makeState({\n    49→      sprint: { total: 3, done: 1, failed: 0, blocked: 0, inProgress: '2-3-status' },\n    50→      stories: {\n    51→        '2-1-done': s({ status: 'done', attempts: 1 }),\n    52→        '2-2-wip': s({ status: 'in-progress', attempts: 2 }),\n    53→        '2-3-status': s(),\n    54→      },\n    55→      run: { active: true, startedAt: '2026-03-18T09:46:00Z', iteration: 7, cost: 23.40, completed: ['2-1-done'], failed: [] },\n    56→    });\n    57→    const result = generateReport(state, NOW);\n    58→    expect(result.success).toBe(true);\n    59→    if (!result.success) return;\n    60→    expect(result.data.activeRun).not.toBeNull();\n    61→    expect(result.data.activeRun!.iterations).toBe(7);\n    62→    expect(result.data.activeRun!.cost).toBe(23.40);\n    63→    expect(result.data.activeRun!.duration).toBe('2h14m');\n    64→    expect(result.data.inProgress).toBe('2-3-status');\n    65→    expect(result.data.lastRun).toBeNull();\n    66→  });\n    67→\n    68→  it('includes done, failed, blocked, skipped counts for completed run', () => {\n    69→    const state = makeState({\n    70→      sprint: { total: 5, done: 2, failed: 1, blocked: 1, inProgress: null },\n    71→      stories: {\n    72→        '1-1-a': s({ status: 'done', attempts: 1 }),\n    73→        '1-2-b': s({ status: 'done', attempts: 1 }),\n    74→        '2-1-c': s({ status: 'failed', attempts: 3, lastError: 'boom', acResults: [{ id: 'AC4', verdict: 'fail' }] }),\n    75→        '2-2-d': s({ status: 'blocked', attempts: 10, lastError: 'retry-exhausted' }),\n    76→        '3-1-e': s(),\n    77→      },\n    78→      run: { active: false, startedAt: '2026-03-18T09:46:00Z', iteration: 7, cost: 23.40, completed: ['1-1-a', '1-2-b'], failed: ['2-1-c'] },\n    79→    });\n    80→    const result = generateReport(state, NOW);\n    81→    expect(result.success).toBe(true);\n    82→    if (!result.success) return;\n    83→    expect(result.data.lastRun).not.toBeNull();\n    84→    expect(result.data.lastRun!.completed).toEqual(['1-1-a', '1-2-b']);\n    85→    expect(result.data.lastRun!.failed).toEqual(['2-1-c']);\n    86→    expect(result.data.lastRun!.blocked).toEqual(['2-2-d']);\n    87→    expect(result.data.done).toBe(2);\n    88→    expect(result.data.failed).toBe(1);\n    89→    expect(result.data.blocked).toBe(1);\n    90→    expect(result.data.activeRun).toBeNull();\n    91→  });\n    92→\n    93→  it('shows story key, AC number, and one-line error for failed stories', () => {\n    94→    const acResults: AcResult[] = [{ id: 'AC1', verdict: 'pass' }, { id: 'AC4', verdict: 'fail' }];\n    95→    const state = makeState({\n    96→      stories: { '2-3-status': s({ status: 'failed', attempts: 3, lastError: 'exit 1', acResults }) },\n    97→    });\n    98→    const result = generateReport(state, NOW);\n    99→    expect(result.success).toBe(true);\n   100→    if (!result.success) return;\n   101→    expect(result.data.failedDetails).toHaveLength(1);\n   102→    const fd = result.data.failedDetails[0];\n   103→    expect(fd.key).toBe('2-3-status');\n   104→    expect(fd.acNumber).toBe(4);\n   105→    expect(fd.errorLine).toBe('exit 1');\n   106→    expect(fd.attempts).toBe(3);\n   107→    expect(fd.maxAttempts).toBe(10);\n   108→  });\n   109→\n   110→  it('labels action items as NEW or CARRIED', () => {\n   111→    const state = makeState({\n   112→      run: { active: false, startedAt: '2026-03-18T09:00:00Z', iteration: 3, cost: 10, completed: ['1-1-a'], failed: ['2-1-b'] },\n   113→      actionItems: [\n   114→        { id: 'ai-1', story: '1-1-a', description: 'Fix test', source: 'verification', resolved: false },\n   115→        { id: 'ai-2', story: '2-1-b', description: 'Edge case', source: 'verification', resolved: false },\n   116→        { id: 'ai-3', story: '0-1-old', description: 'Old', source: 'verification', resolved: false },\n   117→        { id: 'ai-4', story: '1-1-a', description: 'Note', source: 'manual', resolved: false },\n   118→      ],\n   119→    });\n   120→    const result = generateReport(state, NOW);\n   121→    expect(result.success).toBe(true);\n   122→    if (!result.success) return;\n   123→    const labels = result.data.actionItemsLabeled;\n   124→    expect(labels).toHaveLength(4);\n   125→    expect(labels[0].label).toBe('NEW');   // verification + in run\n   126→    expect(labels[1].label).toBe('NEW');   // verification + in run\n   127→    expect(labels[2].label).toBe('CARRIED'); // verification but NOT in run\n   128→    expect(labels[3].label).toBe('CARRIED'); // manual source\n   129→  });\n   130→\n   131→  it('groups stories by epic prefix and counts completed epics', () => {\n   132→    const state = makeState({\n   133→      stories: {\n   134→        '1-1-a': s({ status: 'done' }), '1-2-b': s({ status: 'done' }),\n   135→        '2-1-c': s({ status: 'done' }), '2-2-d': s({ status: 'in-progress' }),\n   136→        '3-1-e': s(),\n   137→      },\n   138→    });\n   139→    const result = generateReport(state, NOW);\n   140→    expect(result.success).toBe(true);\n   141→    if (!result.success) return;\n   142→    expect(result.data.epicsTotal).toBe(3);\n   143→    expect(result.data.epicsDone).toBe(1); // only epic 1 fully done\n   144→    expect(result.data.sprintPercent).toBe(60); // 3/5\n   145→  });\n   146→\n   147→  it('returns fail() on malformed state (not throw)', () => {\n   148→    const result = generateReport(null as unknown as SprintState, NOW);\n   149→    expect(result.success).toBe(false);\n   150→    if (!result.success) expect(result.error).toContain('Failed to generate report');\n   151→  });\n   152→\n   153→  it('handles failed story with no acResults gracefully', () => {\n   154→    const state = makeState({\n   155→      stories: { '1-1-a': s({ status: 'failed', attempts: 2, lastError: 'some error' }) },\n   156→    });\n   157→    const result = generateReport(state, NOW);\n   158→    expect(result.success).toBe(true);\n   159→    if (!result.success) return;\n   160→    expect(result.data.failedDetails).toHaveLength(1);\n   161→    expect(result.data.failedDetails[0].acNumber).toBeNull();\n   162→    expect(result.data.failedDetails[0].errorLine).toBe('some error');\n   163→  });\n   164→\n   165→  it('handles failed story with no lastError', () => {\n   166→    const state = makeState({\n   167→      stories: { '1-1-a': s({ status: 'failed', attempts: 1 }) },\n   168→    });\n   169→    const result = generateReport(state, NOW);\n   170→    expect(result.success).toBe(true);\n   171→    if (!result.success) return;\n   172→    expect(result.data.failedDetails[0].errorLine).toBe('unknown error');\n   173→  });\n   174→\n   175→  it('JSON output includes all fields', () => {\n   176→    const state = makeState({\n   177→      sprint: { total: 2, done: 1, failed: 0, blocked: 0, inProgress: null },\n   178→      stories: { '1-1-a': s({ status: 'done', attempts: 1 }), '2-1-b': s() },\n   179→      run: { active: false, startedAt: '2026-03-18T10:00:00Z', iteration: 3, cost: 5.50, completed: ['1-1-a'], failed: [] },\n   180→    });\n   181→    const result = generateReport(state, NOW);\n   182→    expect(result.success).toBe(true);\n   183→    if (!result.success) return;\n   184→    const data = result.data;\n   185→    for (const field of ['total', 'done', 'failed', 'blocked', 'inProgress', 'storyStatuses',\n   186→      'epicsTotal', 'epicsDone', 'sprintPercent', 'activeRun', 'lastRun', 'failedDetails', 'actionItemsLabeled']) {\n   187→      expect(data).toHaveProperty(field);\n   188→    }\n   189→    const json = JSON.parse(JSON.stringify(data));\n   190→    expect(json.total).toBe(2);\n   191→    expect(json.done).toBe(1);\n   192→    expect(json.lastRun.cost).toBe(5.50);\n   193→    expect(json.storyStatuses).toHaveLength(2);\n   194→  });\n   195→\n   196→  it('computes duration correctly for short runs', () => {\n   197→    const state = makeState({\n   198→      run: { active: true, startedAt: '2026-03-18T11:55:00Z', iteration: 1, cost: 0.5, completed: [], failed: [] },\n   199→    });\n   200→    const result = generateReport(state, NOW);\n   201→    expect(result.success).toBe(true);\n   202→    if (!result.success) return;\n   203→    expect(result.data.activeRun!.duration).toBe('5m');\n   204→  });\n   205→\n   206→  it('clamps negative elapsed duration to 0m', () => {\n   207→    const state = makeState({\n   208→      run: { active: true, startedAt: '2026-03-18T13:00:00Z', iteration: 1, cost: 0.5, completed: [], failed: [] },\n   209→    });\n   210→    // NOW is 12:00, startedAt is 13:00 — clock skew\n   211→    const result = generateReport(state, NOW);\n   212→    expect(result.success).toBe(true);\n   213→    if (!result.success) return;\n   214→    expect(result.data.activeRun!.duration).toBe('0m');\n   215→  });\n   216→\n   217→  it('returns lastRun as null when no startedAt is set', () => {\n   218→    const result = generateReport(makeState(), NOW);\n   219→    expect(result.success).toBe(true);\n   220→    if (!result.success) return;\n   221→    expect(result.data.lastRun).toBeNull();\n   222→  });\n   223→\n   224→  it('populates skipped with retry-exhausted blocked stories', () => {\n   225→    const state = makeState({\n   226→      stories: {\n   227→        '1-1-a': s({ status: 'blocked', attempts: 10 }),\n   228→        '1-2-b': s({ status: 'blocked', attempts: 3 }),\n   229→        '2-1-c': s({ status: 'done', attempts: 1 }),\n   230→      },\n   231→      run: { active: false, startedAt: '2026-03-18T10:00:00Z', iteration: 5, cost: 10, completed: ['2-1-c'], failed: [] },\n   232→    });\n   233→    const result = generateReport(state, NOW);\n   234→    expect(result.success).toBe(true);\n   235→    if (!result.success) return;\n   236→    expect(result.data.lastRun).not.toBeNull();\n   237→    expect(result.data.lastRun!.blocked).toContain('1-1-a');\n   238→    expect(result.data.lastRun!.blocked).toContain('1-2-b');\n   239→    expect(result.data.lastRun!.skipped).toEqual(['1-1-a']);\n   240→    expect(result.data.lastRun!.skipped).not.toContain('1-2-b');\n   241→  });\n   242→});\n   243→\n   244→describe('getStoryDrillDown', () => {\n   245→  it('returns all AC verdicts: pass, fail, escalate, pending', () => {\n   246→    const acResults: AcResult[] = [\n   247→      { id: 'AC1', verdict: 'pass' },\n   248→      { id: 'AC2', verdict: 'fail' },\n   249→      { id: 'AC3', verdict: 'escalate' },\n   250→      { id: 'AC4', verdict: 'pending' },"}]},"parent_tool_use_id":"toolu_01EPL4eJAP5W5qUxFXY5uuFc","session_id":"6707468c-554d-4568-9ea5-0d04d4a85f59","uuid":"1b9d8b4b-9a17-4f61-8a87-2892a1eb9e9c","timestamp":"2026-03-24T10:24:13.728Z"}
