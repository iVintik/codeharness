{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01A8GV9xui5knf4q9rxQNenf","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import {\n     3→  TIER_HIERARCHY,\n     4→  maxTier,\n     5→  LEGACY_TIER_MAP,\n     6→} from '../types.js';\n     7→import type { VerificationTier } from '../types.js';\n     8→\n     9→// ─── VerificationTier type ──────────────────────────────────────────────────\n    10→\n    11→describe('VerificationTier type', () => {\n    12→  it('TIER_HIERARCHY contains exactly the four tiers', () => {\n    13→    expect(TIER_HIERARCHY).toEqual([\n    14→      'test-provable',\n    15→      'runtime-provable',\n    16→      'environment-provable',\n    17→      'escalate',\n    18→    ]);\n    19→  });\n    20→\n    21→  it('TIER_HIERARCHY has length 4', () => {\n    22→    expect(TIER_HIERARCHY).toHaveLength(4);\n    23→  });\n    24→\n    25→  it('TIER_HIERARCHY is an array (readonly at type level via as const)', () => {\n    26→    expect(Array.isArray(TIER_HIERARCHY)).toBe(true);\n    27→  });\n    28→});\n    29→\n    30→// ─── maxTier ────────────────────────────────────────────────────────────────\n    31→\n    32→describe('maxTier', () => {\n    33→  it('returns test-provable for empty array (AC6)', () => {\n    34→    expect(maxTier([])).toBe('test-provable');\n    35→  });\n    36→\n    37→  it('returns test-provable for single test-provable (AC4)', () => {\n    38→    expect(maxTier(['test-provable'])).toBe('test-provable');\n    39→  });\n    40→\n    41→  it('returns runtime-provable for [test-provable, runtime-provable] (AC3)', () => {\n    42→    expect(maxTier(['test-provable', 'runtime-provable'])).toBe('runtime-provable');\n    43→  });\n    44→\n    45→  it('returns environment-provable for [test-provable, environment-provable, runtime-provable] (AC5)', () => {\n    46→    expect(maxTier(['test-provable', 'environment-provable', 'runtime-provable'])).toBe('environment-provable');\n    47→  });\n    48→\n    49→  it('returns escalate when escalate is present', () => {\n    50→    expect(maxTier(['test-provable', 'escalate'])).toBe('escalate');\n    51→  });\n    52→\n    53→  it('returns escalate for all four tiers', () => {\n    54→    expect(maxTier(['test-provable', 'runtime-provable', 'environment-provable', 'escalate'])).toBe('escalate');\n    55→  });\n    56→\n    57→  it('returns the single tier when array has one element', () => {\n    58→    const tiers: VerificationTier[] = ['runtime-provable'];\n    59→    expect(maxTier(tiers)).toBe('runtime-provable');\n    60→  });\n    61→\n    62→  it('returns environment-provable for [environment-provable, runtime-provable]', () => {\n    63→    expect(maxTier(['environment-provable', 'runtime-provable'])).toBe('environment-provable');\n    64→  });\n    65→\n    66→  it('handles duplicates correctly', () => {\n    67→    expect(maxTier(['test-provable', 'test-provable', 'test-provable'])).toBe('test-provable');\n    68→  });\n    69→\n    70→  it('handles duplicates with higher tier', () => {\n    71→    expect(maxTier(['runtime-provable', 'runtime-provable', 'test-provable'])).toBe('runtime-provable');\n    72→  });\n    73→\n    74→  it('is order-independent', () => {\n    75→    const a = maxTier(['escalate', 'test-provable', 'runtime-provable']);\n    76→    const b = maxTier(['test-provable', 'runtime-provable', 'escalate']);\n    77→    const c = maxTier(['runtime-provable', 'escalate', 'test-provable']);\n    78→    expect(a).toBe('escalate');\n    79→    expect(b).toBe('escalate');\n    80→    expect(c).toBe('escalate');\n    81→  });\n    82→});\n    83→\n    84→// ─── LEGACY_TIER_MAP ────────────────────────────────────────────────────────\n    85→\n    86→describe('LEGACY_TIER_MAP', () => {\n    87→  it('maps cli-verifiable to test-provable (AC7)', () => {\n    88→    expect(LEGACY_TIER_MAP['cli-verifiable']).toBe('test-provable');\n    89→  });\n    90→\n    91→  it('maps integration-required to environment-provable (AC7)', () => {\n    92→    expect(LEGACY_TIER_MAP['integration-required']).toBe('environment-provable');\n    93→  });\n    94→\n    95→  it('maps unit-testable to test-provable (AC7)', () => {\n    96→    expect(LEGACY_TIER_MAP['unit-testable']).toBe('test-provable');\n    97→  });\n    98→\n    99→  it('has exactly 4 entries', () => {\n   100→    expect(Object.keys(LEGACY_TIER_MAP)).toHaveLength(4);\n   101→  });\n   102→\n   103→  it('maps black-box to environment-provable', () => {\n   104→    expect(LEGACY_TIER_MAP['black-box']).toBe('environment-provable');\n   105→  });\n   106→\n   107→  it('returns undefined for unknown keys', () => {\n   108→    expect(LEGACY_TIER_MAP['nonexistent']).toBeUndefined();\n   109→  });\n   110→\n   111→  it('all values are valid VerificationTier values', () => {\n   112→    for (const value of Object.values(LEGACY_TIER_MAP)) {\n   113→      expect(TIER_HIERARCHY).toContain(value);\n   114→    }\n   115→  });\n   116→});\n   117→\n   118→// ─── TIER_HIERARCHY ordering ────────────────────────────────────────────────\n   119→\n   120→describe('TIER_HIERARCHY ordering', () => {\n   121→  it('test-provable has lowest index (0)', () => {\n   122→    expect(TIER_HIERARCHY.indexOf('test-provable')).toBe(0);\n   123→  });\n   124→\n   125→  it('runtime-provable has index 1', () => {\n   126→    expect(TIER_HIERARCHY.indexOf('runtime-provable')).toBe(1);\n   127→  });\n   128→\n   129→  it('environment-provable has index 2', () => {\n   130→    expect(TIER_HIERARCHY.indexOf('environment-provable')).toBe(2);\n   131→  });\n   132→\n   133→  it('escalate has highest index (3)', () => {\n   134→    expect(TIER_HIERARCHY.indexOf('escalate')).toBe(3);\n   135→  });\n   136→});\n   137→\n   138→// ─── Module exports ─────────────────────────────────────────────────────────\n   139→\n   140→describe('module exports from index', () => {\n   141→  it('re-exports VerificationTier utilities from barrel', async () => {\n   142→    const barrel = await import('../index.js');\n   143→    expect(barrel.TIER_HIERARCHY).toBeDefined();\n   144→    expect(barrel.maxTier).toBeDefined();\n   145→    expect(barrel.LEGACY_TIER_MAP).toBeDefined();\n   146→  });\n   147→});\n   148→"}]},"parent_tool_use_id":"toolu_01WTx8j9hk9cZfjCVrJFg5MD","session_id":"f9b706e3-1764-4868-a4a5-c90b37d26d0d","uuid":"d1054f63-2b1a-40d8-94c2-01dd5cb435ac","timestamp":"2026-03-27T12:04:28.203Z"}
