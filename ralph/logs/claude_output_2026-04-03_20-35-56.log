  mockGetDriver.mockReturnValue(failingDriver);\n413\t\n414\t    const config: EngineConfig = {\n415\t      workflow: {\n416\t        tasks: { implement: makeTask({ driver: 'claude-code' }) },\n417\t        flow: ['implement'],\n418\t      },\n419\t      agents: { dev: { name: 'dev', model: 'test', instructions: '', disallowedTools: [], bare: true } },\n420\t      sprintStatusPath: '/tmp/sprint-status.yaml',\n421\t      runId: 'test-run',\n422\t      projectDir: '/tmp/test',\n423\t    };\n424\t\n425\t    const result = await executeWorkflow(config);\n426\t\n427\t    expect(result.success).toBe(false);\n428\t    expect(result.tasksCompleted).toBe(0);\n429\t    expect(result.storiesProcessed).toBe(0);\n430\t    expect(result.errors).toHaveLength(1);\n431\t    expect(result.errors[0].code).toBe('HEALTH_CHECK');\n432\t    expect(result.errors[0].message).toContain('CLI not found');\n433\t\n434\t    // Verify state was written as 'failed'\n435\t    const writeStateCalls = mockWriteWorkflowState.mock.calls;\n436\t    const lastState = writeStateCalls[writeStateCalls.length - 1][0];\n437\t    expect(lastState.phase).toBe('failed');\n438\t  });\n439\t\n440\t  it('proceeds normally when all health checks pass', async () => {\n441\t    mockReadWorkflowState.mockReturnValue({\n442\t      workflow_name: '',\n443\t      started: '',\n444\t      iteration: 0,\n445\t      phase: 'idle',\n446\t      tasks_completed: [],\n447\t      evaluator_scores: [],\n448\t      circuit_breaker: { triggered: false, reason: null, score_history: [] },\n449\t      trace_ids: [],\n450\t    });\n451\t\n452\t    const healthyDriver = makeMockDriver('claude-code', makeHealthy());\n453\t    // Make dispatch return a valid stream for actual task execution\n454\t    healthyDriver.dispatch.mockReturnValue((async function* () {\n455\t      yield { type: 'text' as const, text: 'done' };\n456\t      yield { type: 'result' as const, cost: 0.01, sessionId: 'sess-1' };\n457\t    })());\n458\t    mockGetDriver.mockReturnValue(healthyDriver);\n459\t    mockResolveModel.mockReturnValue('test-model');\n460\t    mockGenerateTraceId.mockReturnValue('trace-1');\n461\t    mockFormatTracePrompt.mockReturnValue('');\n462\t    mockResolveSessionId.mockReturnValue(null);\n463\t    mockRecordTraceId.mockImplementation((_, s) => s);\n464\t    mockRecordSessionId.mockImplementation((_, __, s) => s);\n465\t\n466\t    // No work items (empty sprint status)\n467\t    mockExistsSync.mockReturnValue(false);\n468\t\n469\t    const config: EngineConfig = {\n470\t      workflow: {\n471\t        tasks: { implement: makeTask({ driver: 'claude-code', scope: 'per-run' }) },\n472\t        flow: ['implement'],\n473\t      },\n474\t      agents: { dev: { name: 'dev', model: 'test', instructions: '', disallowedTools: [], bare: true } },\n475\t      sprintStatusPath: '/tmp/sprint-status.yaml',\n476\t      runId: 'test-run',\n477\t      projectDir: '/tmp/test',\n478\t    };\n479\t\n480\t    const result = await executeWorkflow(config);\n481\t\n482\t    // Health check should have been called\n483\t    expect(healthyDriver.healthCheck).toHaveBeenCalledOnce();\n484\t    // Workflow should have proceeded (dispatch was called for per-run task)\n485\t    expect(healthyDriver.dispatch).toHaveBeenCalled();\n486\t    expect(result.success).toBe(true);\n487\t  });\n488\t});\n489\t"}]},"parent_tool_use_id":"toolu_01EPUyrKtMjV9xapMgmPR8xK","session_id":"9c9fe147-c536-4d36-9f64-8249f0c68839","uuid":"2fa174ca-e71d-489c-b826-0b59ee0edbf2","timestamp":"2026-04-03T16:45:01.635Z"}
