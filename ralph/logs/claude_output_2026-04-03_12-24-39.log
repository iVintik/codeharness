{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Huu5mSytJ9DwBD5A2eQCcV","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport fs from 'node:fs';\n3\timport path from 'node:path';\n4\timport YAML from 'yaml';\n5\timport { validateAgentSchema } from '../schema-validate.js';\n6\t\n7\tconst TEMPLATES_DIR = path.resolve(__dirname, '../../../templates/agents');\n8\t\n9\tconst EXPECTED_AGENTS = [\n10\t  'dev',\n11\t  'qa',\n12\t  'architect',\n13\t  'pm',\n14\t  'sm',\n15\t  'analyst',\n16\t  'ux-designer',\n17\t  'tech-writer',\n18\t  'evaluator',\n19\t];\n20\t\n21\t/** Cache parsed agents to avoid redundant fs reads across test groups */\n22\tconst agentCache = new Map<string, Record<string, unknown>>();\n23\t\n24\tfunction loadAgent(name: string): Record<string, unknown> {\n25\t  const cached = agentCache.get(name);\n26\t  if (cached) return cached;\n27\t  const filePath = path.join(TEMPLATES_DIR, `${name}.yaml`);\n28\t  const content = fs.readFileSync(filePath, 'utf-8');\n29\t  const parsed = YAML.parse(content) as Record<string, unknown>;\n30\t  agentCache.set(name, parsed);"}]},"parent_tool_use_id":"toolu_01FmCyPivNsxxfc9yDSTFKdg","session_id":"4b1f7711-6ed7-4488-a0af-b261e761b450","uuid":"fc9eade6-38c5-4c99-8712-dd70dd4e7598","timestamp":"2026-04-03T08:27:13.718Z"}
