{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BijmGktivBio6FsQjm4myB","type":"tool_result","content":"1\t{\n2\t  \"name\": \"codeharness\",\n3\t  \"version\": \"0.26.5\",\n4\t  \"type\": \"module\",\n5\t  \"description\": \"CLI for codeharness — makes autonomous coding agents produce software that actually works\",\n6\t  \"bin\": {\n7\t    \"codeharness\": \"dist/index.js\"\n8\t  },\n9\t  \"files\": [\n10\t    \"dist\",\n11\t    \"bin\",\n12\t    \"patches\",\n13\t    \"templates/Dockerfile.verify\",\n14\t    \"templates/Dockerfile.verify.rust\",\n15\t    \"templates/Dockerfile.verify.generic\",\n16\t    \"templates/dockerfiles/\",\n17\t    \"templates/compose/\",\n18\t    \"templates/prompts/\",\n19\t    \"templates/docs/\",\n20\t    \"templates/otlp/\",\n21\t    \"templates/workflows/\"\n22\t  ],\n23\t  \"repository\": {\n24\t    \"type\": \"git\",\n25\t    \"url\": \"https://github.com/iVintik/codeharness.git\"\n26\t  },\n27\t  \"license\": \"MIT\",\n28\t  \"engines\": {\n29\t    \"node\": \">=18\"\n30\t  },\n31\t  \"scripts\": {\n32\t    \"build\": \"tsup\",\n33\t    \"test\": \"bats tests/\",\n34\t    \"test:unit\": \"vitest run\",\n35\t    \"test:coverage\": \"vitest run --coverage\",\n36\t    \"lint\": \"eslint src/\",\n37\t    \"lint:sizes\": \"bash scripts/check-file-sizes.sh\"\n38\t  },\n39\t  \"dependencies\": {\n40\t    \"@inkjs/ui\": \"^2.0.0\",\n41\t    \"ajv\": \"^8.18.0\",\n42\t    \"commander\": \"^14.0.3\",\n43\t    \"ink\": \"^6.8.0\",\n44\t    \"react\": \"^19.2.4\",\n45\t    \"yaml\": \"^2.8.2\"\n46\t  },\n47\t  \"devDependencies\": {\n48\t    \"@eslint/js\": \"^10.0.1\",\n49\t    \"@opentelemetry/auto-instrumentations-node\": \"^0.71.0\",\n50\t    \"@opentelemetry/exporter-logs-otlp-http\": \"^0.213.0\",\n51\t    \"@opentelemetry/exporter-metrics-otlp-http\": \"^0.213.0\",\n52\t    \"@opentelemetry/exporter-trace-otlp-http\": \"^0.213.0\",\n53\t    \"@types/node\": \"^25.5.0\",\n54\t    \"@types/react\": \"^19.2.14\