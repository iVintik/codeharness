{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011cAhbdQbdeQFF6TAgFApQh","type":"tool_result","content":"1\timport { describe, it, expect, beforeAll } from 'vitest';\n2\timport { existsSync, readFileSync } from 'node:fs';\n3\timport { resolve } from 'node:path';\n4\timport { parseWorkflow, type ResolvedWorkflow, type LoopBlock } from '../workflow-parser.js';\n5\t\n6\tconst defaultWorkflowPath = resolve(__dirname, '../../../templates/workflows/default.yaml');\n7\t\n8\tdescribe('default embedded workflow', () => {\n9\t  describe('file existence (AC #1)', () => {\n10\t    it('templates/workflows/default.yaml exists on disk', () => {\n11\t      expect(existsSync(defaultWorkflowPath)).toBe(true);\n12\t    });\n13\t\n14\t    it('contains tasks and flow top-level keys', () => {\n15\t      const raw = readFileSync(defaultWorkflowPath, 'utf-8');\n16\t      expect(raw).toContain('tasks:');\n17\t      expect(raw).toContain('flow:');\n18\t    });\n19\t  });\n20\t\n21\t  describe('schema validation via parseWorkflow (AC #4)', () => {\n22\t    it('passes schema validation and returns a ResolvedWorkflow', () => {\n23\t      const result = parseWorkflow(defaultWorkflowPath);\n24\t      expect(result).toBeDefined();\n25\t      expect(result.tasks).toBeDefined();\n26\t      expect(result.flow).toBeDefined();\n27\t    });\n28\t  });\n29\t\n30\t  describe('task definitions (AC #2)', () => {\n31\t    let workflow: ResolvedWorkflow;\n32\t\n33\t    beforeAll(() => {\n34\t      workflow = parseWorkflow(defaultWorkflowPath);\n35\t    });\n36\t\n37\t    it('defines exactly three tasks: implement, verify, and retry', () => {\n38\t      const taskNames = Object.keys(workflow.tasks);\n39\t      expect(taskNames).toHaveLength(3);\n40\t      expect(taskNames).toContain('implement');\n41\t      expect(taskNames).toContain('verify');\n42\t      expect(taskNames).toContain('retry');\n43\t    });\n44\t\n45\t    it('implement task has correct properties', () => {\n46\t      const task = workflow.tasks.implement;\n47\t      expect(task.agent).toBe('dev');\n48\t      expect(task.scope).toBe('per-story');\n49\t      expect(task.session).toBe('fresh');\n50\t      expect(task.source_access).toBe(true);\n51\t    });\n52\t\n53\t    it('verify task has source_access false and scope per-run (AC #5)', () => {\n54\t      const task = workflow.tasks.verify;\n55\t      expect(task.agent).toBe('evaluator');\n56\t      expect(task.scope).toBe('per-run');\n57\t      expect(task.session).toBe('fresh');\n58\t      expect(task.source_access).toBe(false);\n59\t    });\n60\t\n61\t    it('retry task has source_access true and scope per-story (AC #6)', () => {\n62\t      const task = workflow.tasks.retry;\n63\t      expect(task.agent).toBe('dev');\n64\t      expect(task.scope).toBe('per-story');\n65\t      expect(task.session).toBe('fresh');\n66\t      expect(task.source_access).toBe(true);\n67\t    });\n68\t  });\n69\t\n70\t  describe('flow structure (AC #3)', () => {\n71\t    it('flow order is implement, verify, then loop:[retry, verify]', () => {\n72\t      const workflow = parseWorkflow(defaultWorkflowPath);\n73\t      expect(workflow.flow).toHaveLength(3);\n74\t      expect(workflow.flow[0]).toBe('implement');\n75\t      expect(workflow.flow[1]).toBe('verify');\n76\t\n77\t      const loopStep = workflow.flow[2] as LoopBlock;\n78\t      expect(loopStep).toHaveProperty('loop');\n79\t      expect(loopStep.loop).toEqual(['retry', 'verify']);\n80\t    });\n81\t  });\n82\t\n83\t  describe('npm distribution (AC #7)', () => {\n84\t    it('templates/workflows/ is included in package.json files array', () => {\n85\t      const pkgPath = resolve(__dirname, '../../../package.json');\n86\t      const pkg = JSON.parse(readFileSync(pkgPath, 'utf-8'));\n87\t      expect(pkg.files).toContain('templates/workflows/');\n88\t    });\n89\t  });\n90\t});\n91\t"}]},"parent_tool_use_id":"toolu_01CuvSVEyCsqJ3paMHDYGamx","session_id":"819d45f9-7092-4252-80a7-82eddd3933c2","uuid":"b81f749c-53ec-429d-8c1b-2cdf213e324d","timestamp":"2026-04-02T14:17:25.808Z"}
