{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JTUWjND9VvKP1GJqvmXQeA","type":"tool_result","content":"     1→import { execFileSync } from 'node:child_process';\n     2→import { readFileSync, writeFileSync, existsSync } from 'node:fs';\n     3→import { join, basename } from 'node:path';\n     4→import { ok, info } from './output.js';\n     5→import { readState, writeState, readStateWithBody } from './state.js';\n     6→import type { HarnessState } from './state.js';\n     7→import type { AppType } from './stack-detect.js';\n     8→\n     9→export interface OtlpResult {\n    10→  status: 'configured' | 'skipped' | 'failed';\n    11→  packages_installed: boolean;\n    12→  start_script_patched: boolean;\n    13→  env_vars_configured: boolean;\n    14→  error?: string;\n    15→}\n    16→\n    17→const NODE_OTLP_PACKAGES = [\n    18→  '@opentelemetry/auto-instrumentations-node',\n    19→  '@opentelemetry/sdk-node',\n    20→  '@opentelemetry/exporter-trace-otlp-http',\n    21→  '@opentelemetry/exporter-metrics-otlp-http',\n    22→];\n    23→\n    24→const PYTHON_OTLP_PACKAGES = [\n    25→  'opentelemetry-distro',\n    26→  'opentelemetry-exporter-otlp',\n    27→];\n    28→\n    29→export const WEB_OTLP_PACKAGES = [\n    30→  '@opentelemetry/sdk-trace-web',\n    31→  '@opentelemetry/instrumentation-fetch',\n    32→  '@opentelemetry/instrumentation-xml-http-request',\n    33→];\n    34→\n    35→export const AGENT_OTLP_PACKAGES_NODE = ['@traceloop/node-server-sdk'];\n    36→export const AGENT_OTLP_PACKAGES_PYTHON = ['traceloop-sdk'];\n    37→\n    38→export const NODE_REQUIRE_FLAG = '--require @opentelemetry/auto-instrumentations-node/register';\n    39→\n    40→/** Truncate error messages from execFileSync that include full stderr output */\n    41→function truncateError(message: string, maxLength = 200): string {\n    42→  if (message.length <= maxLength) return message;\n    43→  return message.slice(0, maxLength) + '... (truncated)';\n    44→}\n    45→\n    46→export function installNodeOtlp(projectDir: string): OtlpResult {\n    47→  try {\n    48→    execFileSync('npm', ['install', ...NODE_OTLP_PACKAGES], { cwd: projectDir, stdio: 'pipe', timeout: 300_000 });\n    49→    return {\n    50→      status: 'configured',\n    51→      packages_installed: true,\n    52→      start_script_patched: false,\n    53→      env_vars_configured: false,\n    54→    };\n    55→  } catch (err) {\n    56→    const message = err instanceof Error ? err.message : 'Unknown error';\n    57→    return {\n    58→      status: 'failed',\n    59→      packages_installed: false,\n    60→      start_script_patched: false,\n    61→      env_vars_configured: false,\n    62→      error: `Failed to install Node.js OTLP packages: ${truncateError(message)}`,\n    63→    };\n    64→  }\n    65→}\n    66→\n    67→export function patchNodeStartScript(projectDir: string): boolean {\n    68→  const pkgPath = join(projectDir, 'package.json');\n    69→  if (!existsSync(pkgPath)) {\n    70→    return false;\n    71→  }\n    72→\n    73→  let raw: string;\n    74→  let pkg: Record<string, unknown>;\n    75→  try {\n    76→    raw = readFileSync(pkgPath, 'utf-8');\n    77→    pkg = JSON.parse(raw) as Record<string, unknown>;\n    78→  } catch {\n    79→    // Malformed package.json — skip patching\n    80→    return false;\n    81→  }\n    82→  const scripts = pkg['scripts'] as Record<string, string> | undefined;\n    83→\n    84→  if (!scripts) {\n    85→    return false;\n    86→  }\n    87→\n    88→  const targetKey = scripts['start'] ? 'start' : scripts['dev'] ? 'dev' : null;\n    89→  if (!targetKey) {\n    90→    return false;\n    91→  }\n    92→\n    93→  const instrumentedKey = `${targetKey}:instrumented`;\n    94→\n    95→  // Check if already patched — the instrumented key already exists\n    96→  if (scripts[instrumentedKey]?.includes(NODE_REQUIRE_FLAG)) {\n    97→    return false;\n    98→  }\n    99→  scripts[instrumentedKey] = `NODE_OPTIONS='${NODE_REQUIRE_FLAG}' ${scripts[targetKey]}`;\n   100→\n   101→  writeFileSync(pkgPath, JSON.stringify(pkg, null, 2) + '\\n', 'utf-8');\n   102→  return true;\n   103→}\n   104→\n   105→export function installPythonOtlp(projectDir: string): OtlpResult {\n   106→  const installChains: { cmd: string; args: string[] }[][] = [\n   107→    // Primary: pip install both packages in one command\n   108→    [{ cmd: 'pip', args: ['install', ...PYTHON_OTLP_PACKAGES] }],\n   109→    // Fallback: pipx install each package individually (pipx only accepts one package at a time)\n   110→    PYTHON_OTLP_PACKAGES.map(pkg => ({ cmd: 'pipx', args: ['install', pkg] })),\n   111→  ];\n   112→\n   113→  for (const chain of installChains) {\n   114→    try {\n   115→      for (const step of chain) {\n   116→        execFileSync(step.cmd, step.args, { cwd: projectDir, stdio: 'pipe', timeout: 300_000 });\n   117→      }\n   118→      return {\n   119→        status: 'configured',\n   120→        packages_installed: true,\n   121→        start_script_patched: false,\n   122→        env_vars_configured: false,\n   123→      };\n   124→    } catch {\n   125→      continue;\n   126→    }\n   127→  }\n   128→\n   129→  return {\n   130→    status: 'failed',\n   131→    packages_installed: false,\n   132→    start_script_patched: false,\n   133→    env_vars_configured: false,\n   134→    error: 'Failed to install Python OTLP packages',\n   135→  };\n   136→}\n   137→\n   138→export function configureCli(projectDir: string): void {\n   139→  const { state, body } = readStateWithBody(projectDir);\n   140→\n   141→  if (!state.otlp) return;\n   142→\n   143→  state.otlp.cli_env_vars = {\n   144→    OTEL_BSP_SCHEDULE_DELAY: '100',\n   145→    OTEL_TRACES_SAMPLER: 'always_on',\n   146→    OTEL_BLRP_SCHEDULE_DELAY: '100',\n   147→  };\n   148→\n   149→  writeState(state, projectDir, body);\n   150→}\n   151→\n   152→export function configureWeb(projectDir: string, stack: string | null): void {\n   153→  if (stack === 'nodejs') {\n   154→    try {\n   155→      execFileSync('npm', ['install', ...WEB_OTLP_PACKAGES], { cwd: projectDir, stdio: 'pipe', timeout: 300_000 });\n   156→    } catch {\n   157→      // Web packages are supplementary; failure is non-fatal\n   158→    }\n   159→  }\n   160→\n   161→  // Read endpoint from state (may have been set by configureOtlpEnvVars)\n   162→  let endpoint = 'http://localhost:4318';\n   163→  try {\n   164→    const currentState = readState(projectDir);\n   165→    if (currentState.otlp?.endpoint) {\n   166→      endpoint = currentState.otlp.endpoint;\n   167→    }\n   168→  } catch {\n   169→    // State not readable — use default endpoint\n   170→  }\n   171→\n   172→  // Generate otel-web-init.js snippet\n   173→  const snippet = `// OpenTelemetry Web SDK initialization — generated by codeharness\n   174→import { WebTracerProvider } from '@opentelemetry/sdk-trace-web';\n   175→import { BatchSpanProcessor } from '@opentelemetry/sdk-trace-base';\n   176→import { OTLPTraceExporter } from '@opentelemetry/exporter-trace-otlp-http';\n   177→import { FetchInstrumentation } from '@opentelemetry/instrumentation-fetch';\n   178→import { XMLHttpRequestInstrumentation } from '@opentelemetry/instrumentation-xml-http-request';\n   179→import { registerInstrumentations } from '@opentelemetry/instrumentation';\n   180→\n   181→const exporter = new OTLPTraceExporter({\n   182→  url: '${endpoint}/v1/traces',\n   183→});\n   184→\n   185→const provider = new WebTracerProvider();\n   186→provider.addSpanProcessor(new BatchSpanProcessor(exporter));\n   187→provider.register();\n   188→\n   189→registerInstrumentations({\n   190→  instrumentations: [\n   191→    new FetchInstrumentation(),\n   192→    new XMLHttpRequestInstrumentation(),\n   193→  ],\n   194→});\n   195→`;\n   196→\n   197→  const snippetPath = join(projectDir, 'otel-web-init.js');\n   198→  writeFileSync(snippetPath, snippet, 'utf-8');\n   199→\n   200→  const { state, body } = readStateWithBody(projectDir);\n   201→  if (state.otlp) {\n   202→    state.otlp.web_snippet_path = 'otel-web-init.js';\n   203→  }\n   204→  writeState(state, projectDir, body);\n   205→}\n   206→\n   207→export function configureAgent(projectDir: string, stack: string | null): void {\n   208→  if (stack === 'nodejs') {\n   209→    try {\n   210→      execFileSync('npm', ['install', ...AGENT_OTLP_PACKAGES_NODE], { cwd: projectDir, stdio: 'pipe', timeout: 300_000 });\n   211→    } catch {\n   212→      // Agent packages are supplementary; failure is non-fatal\n   213→    }\n   214→  } else if (stack === 'python') {\n   215→    try {\n   216→      execFileSync('pip', ['install', ...AGENT_OTLP_PACKAGES_PYTHON], { cwd: projectDir, stdio: 'pipe', timeout: 300_000 });\n   217→    } catch {\n   218→      // Try pipx fallback\n   219→      try {\n   220→        for (const pkg of AGENT_OTLP_PACKAGES_PYTHON) {\n   221→          execFileSync('pipx', ['install', pkg], { cwd: projectDir, stdio: 'pipe', timeout: 300_000 });\n   222→        }\n   223→      } catch {\n   224→        // Agent packages are supplementary; failure is non-fatal\n   225→      }\n   226→    }\n   227→  }\n   228→\n   229→  const { state, body } = readStateWithBody(projectDir);\n   230→  if (state.otlp) {\n   231→    state.otlp.agent_sdk = 'traceloop';\n   232→  }\n   233→  writeState(state, projectDir, body);\n   234→}\n   235→\n   236→export function ensureServiceNameEnvVar(projectDir: string, serviceName: string): void {\n   237→  const envFilePath = join(projectDir, '.env.codeharness');\n   238→  // Sanitize service name: replace characters unsafe for env values and URLs\n   239→  const sanitized = serviceName.replace(/[^a-zA-Z0-9._-]/g, '-');\n   240→  const envLine = `OTEL_SERVICE_NAME=${sanitized}`;\n   241→\n   242→  if (existsSync(envFilePath)) {\n   243→    const content = readFileSync(envFilePath, 'utf-8');\n   244→    // Split and remove trailing empty lines from the split result\n   245→    const lines = content.split('\\n').filter((l, i, arr) => i < arr.length - 1 || l.trim() !== '');\n   246→    const idx = lines.findIndex(l => l.startsWith('OTEL_SERVICE_NAME='));\n   247→    if (idx !== -1) {\n   248→      lines[idx] = envLine;\n   249→    } else {\n   250→      lines.push(envLine);\n   251→    }\n   252→    writeFileSync(envFilePath, lines.join('\\n') + '\\n', 'utf-8');\n   253→  } else {\n   254→    writeFileSync(envFilePath, envLine + '\\n', 'utf-8');\n   255→  }\n   256→}\n   257→\n   258→export function configureOtlpEnvVars(projectDir: string, stack: string | null, opts?: { endpoint?: string; appType?: AppType }): void {\n   259→  const projectName = basename(projectDir);\n   260→\n   261→  const { state, body } = readStateWithBody(projectDir);\n   262→\n   263→  state.otlp = {\n   264→    enabled: true,\n   265→    endpoint: opts?.endpoint ?? 'http://localhost:4318',\n   266→    service_name: projectName,\n   267→    mode: state.otlp?.mode ?? 'local-shared',\n   268→    ...(stack === 'nodejs'\n   269→      ? { node_require: NODE_REQUIRE_FLAG }\n   270→      : {}),\n   271→    ...(stack === 'python'\n   272→      ? { python_wrapper: 'opentelemetry-instrument' }\n   273→      : {}),\n   274→    ...(stack === 'rust'\n   275→      ? { rust_env_hint: 'OTEL_EXPORTER_OTLP_ENDPOINT' }\n   276→      : {}),\n   277→  };\n   278→\n   279→  // Resource attributes (Task 6)\n   280→  state.otlp.resource_attributes = 'service.instance.id=$(hostname)-$$';\n   281→\n   282→  writeState(state, projectDir, body);\n   283→\n   284→  // Write OTEL_SERVICE_NAME to .env.codeharness file\n   285→  ensureServiceNameEnvVar(projectDir, projectName);\n   286→}\n   287→\n   288→export function instrumentProject(\n   289→  projectDir: string,\n   290→  stack: string | null,\n   291→  opts?: { json?: boolean; appType?: AppType },\n   292→): OtlpResult {\n   293→  const isJson = opts?.json === true;\n   294→  const appType = opts?.appType;\n   295→\n   296→  let result: OtlpResult;\n   297→\n   298→  if (stack === 'nodejs') {\n   299→    result = installNodeOtlp(projectDir);\n   300→    if (result.status === 'configured') {\n   301→      const patched = patchNodeStartScript(projectDir);\n   302→      result.start_script_patched = patched;\n   303→      if (!isJson) {\n   304→        ok('OTLP: Node.js packages installed');\n   305→        if (patched) {\n   306→          ok('OTLP: start script patched with --require flag');\n   307→        } else {\n   308→          info('OTLP: no start/dev script found or already patched');\n   309→        }\n   310→      }\n   311→    }\n   312→  } else if (stack === 'python') {\n   313→    result = installPythonOtlp(projectDir);\n   314→    if (result.status === 'configured' && !isJson) {\n   315→      ok('OTLP: Python packages installed');\n   316→      info('OTLP: wrap your command with: opentelemetry-instrument <command>');\n   317→    }\n   318→  } else if (stack === 'rust') {\n   319→    // Rust OTLP package installation is story 8-7.\n   320→    // For now, configure env vars and state hint only.\n   321→    result = {\n   322→      status: 'configured',\n   323→      packages_installed: false,\n   324→      start_script_patched: false,\n   325→      env_vars_configured: false,\n   326→    };\n   327→    if (!isJson) {\n   328→      info('OTLP: Rust — env vars configured. Run `cargo add opentelemetry opentelemetry-otlp tracing-opentelemetry tracing-subscriber` to add packages.');\n   329→    }\n   330→  } else {\n   331→    return {\n   332→      status: 'skipped',\n   333→      packages_installed: false,\n   334→      start_script_patched: false,\n   335→      env_vars_configured: false,\n   336→      error: 'Unsupported stack for OTLP instrumentation',\n   337→    };\n   338→  }\n   339→\n   340→  // Always configure OTLP env vars and state, even when package install fails.\n   341→  // The env vars and python_wrapper/node_require fields are useful regardless\n   342→  // of whether the packages are installed (the user can install them manually).\n   343→  configureOtlpEnvVars(projectDir, stack, { appType });\n   344→  result.env_vars_configured = true;\n   345→  if (!isJson) {\n   346→    ok('OTLP: environment variables configured');\n   347→  }\n   348→\n   349→  if (result.status === 'configured') {\n   350→    // Dispatch to app-type-specific configuration (Task 7)\n   351→    if (appType === 'cli') {\n   352→      configureCli(projectDir);\n   353→      if (!isJson) {\n   354→        ok('OTLP: CLI instrumentation configured (fast flush, always_on sampler)');\n   355→      }\n   356→    } else if (appType === 'web') {\n   357→      configureWeb(projectDir, stack);\n   358→      if (!isJson) {\n   359→        ok('OTLP: Web instrumentation configured (browser SDK + CORS)');\n   360→      }\n   361→    } else if (appType === 'agent') {\n   362→      configureAgent(projectDir, stack);\n   363→      if (!isJson) {\n   364→        ok('OTLP: Agent/LLM instrumentation configured (OpenLLMetry/Traceloop)');\n   365→      }\n   366→    } else if (appType === 'generic' && !isJson) {\n   367→      info('App type: generic (manual OTLP setup may be needed)');\n   368→    }\n   369→  } else if (!isJson && result.error) {\n   370→    info(`OTLP: ${result.error}`);\n   371→  }\n   372→\n   373→  return result;\n   374→}\n   375→"}]},"parent_tool_use_id":"toolu_015sdAUqgT2h4yvHQdc3eHYB","session_id":"8e4c6a49-a8f5-4820-a234-101957ee0803","uuid":"a2f6801c-738c-44ac-a4f7-be2d5500dffa","timestamp":"2026-03-23T07:37:02.462Z"}
