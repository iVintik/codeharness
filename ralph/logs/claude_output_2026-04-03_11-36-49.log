{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015529mXRz49bHR8RThNtwtE","type":"tool_result","content":"1\timport { query } from '@anthropic-ai/claude-agent-sdk';\n2\timport type { SubagentDefinition } from './agent-resolver.js';\n3\t\n4\t// --- Interfaces ---\n5\t\n6\t/**\n7\t * Options for dispatching an agent session.\n8\t */\n9\texport interface DispatchOptions {\n10\t  /** Working directory for the agent session. */\n11\t  cwd?: string;\n12\t  /** Session ID for resuming an existing session (forward-compat for story 4-2). */\n13\t  sessionId?: string;\n14\t  /** Additional text appended to the system prompt (forward-compat for story 4-3 trace IDs). */\n15\t  appendSystemPrompt?: string;\n16\t}\n17\t\n18\t/**\n19\t * Result of a successful agent dispatch.\n20\t */\n21\texport interface DispatchResult {\n22\t  /** The session ID assigned by the Agent SDK. */\n23\t  sessionId: string;\n24\t  /** Whether the session completed successfully (no errors). */\n25\t  success: boolean;\n26\t  /** Wall-clock duration in milliseconds. */\n27\t  durationMs: number;\n28\t  /** The agent's final text response. */\n29\t  output: string;\n30\t}\n31\t\n32\t// --- Error Class ---\n33\t\n34\t/** Error codes for classifying dispatch failures. */\n35\texport type DispatchErrorCode = 'RATE_LIMIT' | 'NETWORK' | 'SDK_INIT' | 'UNKNOWN';\n36\t\n37\t/**\n38\t * Structured error thrown by dispatchAgent() with a classification code.\n39\t */\n40\texport class DispatchError extends Error {\n41\t  public readonly code: DispatchErrorCode;\n42\t  public readonly agentName: string;\n43\t  public readonly cause: unknown;\n44\t\n45\t  constructor(\n46\t    message: string,\n47\t    code: DispatchErrorCode,\n48\t    agentName: string,\n49\t    cause: unknown,\n50\t  ) {\n51\t    super(message);\n52\t    this.name = 'DispatchError';\n53\t    this.code = code;\n54\t    this.agentName = agentName;\n55\t    this.cause = cause;\n56\t  }\n57\t}\n58\t\n59\t// --- Error Classification ---\n60\t\n61\tconst NETWORK_CODES = new Set([\n62\t  'ECONNREFUSED',\n63\t  'ETIMEDOUT',\n64\t  'ENOTFOUND',\n65\t  'ENETUNREACH',\n66\t  'ECONNRESET',\n67\t  'EPIPE',\n68\t]);\n69\t\n70\t/**\n71\t * Classify an error from the Agent SDK into a DispatchErrorCode.\n72\t */\n73\tfunction classifyError(err: unknown): DispatchErrorCode {\n74\t  const message = err instanceof Error ? err.message : String(err);\n75\t  const code = (err as { code?: string })?.code;\n76\t  const status = (err as { status?: number })?.status;\n77\t\n78\t  // Rate limit: HTTP 429 or message containing \"rate limit\"\n79\t  if (status === 429 || /rate.?limit/i.test(message)) {\n80\t    return 'RATE_LIMIT';\n81\t  }\n82\t\n83\t  // Network errors: known error codes or fetch-related failures\n84\t  if (code && NETWORK_CODES.has(code)) {\n85\t    return 'NETWORK';\n86\t  }\n87\t  if (/fetch|network|dns/i.test(message) && /fail|error|timeout/i.test(message)) {\n88\t    return 'NETWORK';\n89\t  }\n90\t\n91\t  // SDK init: binary not found, SDK constructor errors\n92\t  if (/not found|cannot find|no such file|ENOENT/i.test(message) && /claude|binary|executable/i.test(message)) {\n93\t    return 'SDK_INIT';\n94\t  }\n95\t  if (/sdk.*init|constructor.*fail|cannot.*initialize/i.test(message)) {\n96\t    return 'SDK_INIT';\n97\t  }\n98\t\n99\t  return 'UNKNOWN';\n100\t}\n101\t\n102\t// --- Main Dispatch Function ---\n103\t\n104\t/**\n105\t * Dispatch an agent session via the Agent SDK query() API.\n106\t *\n107\t * Starts a session with the given subagent definition and prompt,\n108\t * consumes the async generator, and returns a DispatchResult when done.\n109\t *\n110\t * Uses only the SDK — no process invocation. No retry logic. No output parsing.\n111\t */\n112\texport async function dispatchAgent(\n113\t  definition: SubagentDefinition,\n114\t  prompt: string,\n115\t  options?: DispatchOptions,\n116\t): Promise<DispatchResult> {\n117\t  const startMs = Date.now();\n118\t\n119\t  // Build system prompt — use the definition instructions,\n120\t  // optionally appending the trace ID / extra context.\n121\t  let systemPrompt: string = definition.instructions;\n122\t\n123\t  if (options?.appendSystemPrompt) {\n124\t    systemPrompt = `${definition.instructions}\\n\\n${options.appendSystemPrompt}`;\n125\t  }\n126\t\n127\t  try {\n128\t    const queryGenerator = query({\n129\t      prompt,\n130\t      options: {\n131\t        model: definition.model,\n132\t        systemPrompt,\n133\t        disallowedTools: definition.disallowedTools,\n134\t        ...(options?.cwd ? { cwd: options.cwd } : {}),\n135\t        ...(options?.sessionId ? { resume: options.sessionId } : {}),\n136\t        permissionMode: 'bypassPermissions',\n137\t        allowDangerouslySkipPermissions: true,\n138\t      },\n139\t    });\n140\t\n141\t    // Consume the async generator to completion, capturing the result message.\n142\t    let sessionId = '';\n143\t    let output = '';\n144\t    let success = false;\n145\t\n146\t    for await (const message of queryGenerator) {\n147\t      // Capture session_id from any message that has it.\n148\t      if ('session_id' in message && message.session_id) {\n149\t        sessionId = message.session_id;\n150\t      }\n151\t\n152\t      // Capture the result message (final message in the stream).\n153\t      if (message.type === 'result') {\n154\t        const resultMsg = message as {\n155\t          type: 'result';\n156\t          subtype: string;\n157\t          result?: string;\n158\t          errors?: string[];\n159\t          session_id: string;\n160\t        };\n161\t\n162\t        sessionId = resultMsg.session_id;\n163\t        success = resultMsg.subtype === 'success';\n164\t        output = resultMsg.result ?? '';\n165\t      }\n166\t    }\n167\t\n168\t    const durationMs = Date.now() - startMs;\n169\t\n170\t    return {\n171\t      sessionId,\n172\t      success,\n173\t      durationMs,\n174\t      output,\n175\t    };\n176\t  } catch (err: unknown) {\n177\t    const errorCode = classifyError(err);\n178\t    const message = err instanceof Error ? err.message : String(err);\n179\t    throw new DispatchError(\n180\t      `Agent dispatch failed for \"${definition.name}\": ${message}`,\n181\t      errorCode,\n182\t      definition.name,\n183\t      err,\n184\t    );\n185\t  }\n186\t}\n187\t"}]},"parent_tool_use_id":"toolu_011ACjM7rS7kgs6kygtQ7sim","session_id":"f83470b7-c271-483e-ae93-7fe9bce4b683","uuid":"df1f5003-b826-4b5f-9866-25099290c143","timestamp":"2026-04-03T07:38:12.420Z"}
