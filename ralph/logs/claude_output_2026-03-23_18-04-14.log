{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014BSyrZHUX5abbT2Agp5ezB","type":"tool_result","content":"     1→import { existsSync, readFileSync, readdirSync } from 'node:fs';\n     2→import { join } from 'node:path';\n     3→import { warn } from './output.js';\n     4→\n     5→export type AppType = 'server' | 'cli' | 'web' | 'agent' | 'generic';\n     6→\n     7→export interface StackDetection {\n     8→  stack: string;\n     9→  dir: string;\n    10→}\n    11→\n    12→/** Directories to skip during subdirectory scanning. */\n    13→const SKIP_DIRS = new Set([\n    14→  'node_modules',\n    15→  '.git',\n    16→  'target',\n    17→  '__pycache__',\n    18→  'dist',\n    19→  'build',\n    20→  'coverage',\n    21→]);\n    22→\n    23→/** Stack markers in priority order (nodejs > python > rust). */\n    24→const STACK_MARKERS: Array<{ stack: string; files: string[] }> = [\n    25→  { stack: 'nodejs', files: ['package.json'] },\n    26→  { stack: 'python', files: ['requirements.txt', 'pyproject.toml', 'setup.py'] },\n    27→  { stack: 'rust', files: ['Cargo.toml'] },\n    28→];\n    29→\n    30→/**\n    31→ * Detect all stacks present in a directory, checking root and one level of subdirectories.\n    32→ * Root stacks appear first (in priority order: nodejs > python > rust),\n    33→ * then subdirectory stacks sorted alphabetically by directory name.\n    34→ */\n    35→export function detectStacks(dir: string = process.cwd()): StackDetection[] {\n    36→  const results: StackDetection[] = [];\n    37→\n    38→  // Root scan — check all markers, no early return\n    39→  for (const marker of STACK_MARKERS) {\n    40→    for (const file of marker.files) {\n    41→      if (existsSync(join(dir, file))) {\n    42→        results.push({ stack: marker.stack, dir: '.' });\n    43→        break; // Only add each stack once for root\n    44→      }\n    45→    }\n    46→  }\n    47→\n    48→  // Subdirectory scan — one level deep\n    49→  let entries: import('node:fs').Dirent[];\n    50→  try {\n    51→    entries = readdirSync(dir, { withFileTypes: true });\n    52→  } catch {\n    53→    entries = [];\n    54→  }\n    55→\n    56→  const subdirs = entries\n    57→    .filter((e) => e.isDirectory() && !SKIP_DIRS.has(e.name))\n    58→    .map((e) => e.name)\n    59→    .sort();\n    60→\n    61→  for (const subdir of subdirs) {\n    62→    const subdirPath = join(dir, subdir);\n    63→    for (const marker of STACK_MARKERS) {\n    64→      for (const file of marker.files) {\n    65→        if (existsSync(join(subdirPath, file))) {\n    66→          results.push({ stack: marker.stack, dir: subdir });\n    67→          break; // Only add each stack once per subdir\n    68→        }\n    69→      }\n    70→    }\n    71→  }\n    72→\n    73→  return results;\n    74→}\n    75→\n    76→/**\n    77→ * Compat wrapper: returns the first detected stack name, or null.\n    78→ * Preserves the original single-stack API for existing callers.\n    79→ */\n    80→export function detectStack(dir: string = process.cwd()): string | null {\n    81→  const stacks = detectStacks(dir);\n    82→  if (stacks.length > 0) return stacks[0].stack;\n    83→  warn('No recognized stack detected');\n    84→  return null;\n    85→}\n    86→\n    87→const AGENT_DEPS_NODE = ['anthropic', '@anthropic-ai/sdk', 'openai', 'langchain', '@langchain/core', 'llamaindex'];\n    88→const AGENT_DEPS_PYTHON = ['anthropic', 'openai', 'langchain', 'llama-index', 'traceloop-sdk'];\n    89→const WEB_FRAMEWORK_DEPS = ['react', 'vue', 'svelte', 'angular', '@angular/core', 'next', 'nuxt', 'vite', 'webpack'];\n    90→const PYTHON_WEB_FRAMEWORKS = ['flask', 'django', 'fastapi', 'streamlit'];\n    91→const RUST_WEB_FRAMEWORKS = ['actix-web', 'axum', 'rocket', 'tide', 'warp'];\n    92→const RUST_AGENT_DEPS = ['async-openai', 'anthropic', 'llm-chain'];\n    93→\n    94→function readJsonSafe(path: string): Record<string, unknown> | null {\n    95→  try {\n    96→    if (!existsSync(path)) return null;\n    97→    return JSON.parse(readFileSync(path, 'utf-8')) as Record<string, unknown>;\n    98→  } catch {\n    99→    return null;\n   100→  }\n   101→}\n   102→\n   103→function readTextSafe(path: string): string | null {\n   104→  try {\n   105→    if (!existsSync(path)) return null;\n   106→    return readFileSync(path, 'utf-8');\n   107→  } catch {\n   108→    return null;\n   109→  }\n   110→}\n   111→\n   112→function getNodeDeps(pkg: Record<string, unknown>): Set<string> {\n   113→  const deps = new Set<string>();\n   114→  for (const field of ['dependencies', 'devDependencies']) {\n   115→    const section = pkg[field] as Record<string, string> | undefined;\n   116→    if (section && typeof section === 'object') {\n   117→      for (const key of Object.keys(section)) {\n   118→        deps.add(key);\n   119→      }\n   120→    }\n   121→  }\n   122→  return deps;\n   123→}\n   124→\n   125→function hasPythonDep(content: string, dep: string): boolean {\n   126→  // Match dep name as a standalone package, not as a substring of another package.\n   127→  // Handles requirements.txt lines like \"openai>=1.0\", pyproject.toml entries like '\"openai\"',\n   128→  // and extras like \"openai[all]\". Uses word boundary or common delimiters to avoid\n   129→  // matching \"not-openai\" or \"myopenai\".\n   130→  const escaped = dep.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n   131→  const pattern = new RegExp(`(?:^|[\\\\s\"',])${escaped}(?:[\\\\[>=<~!;\\\\s\"',]|$)`, 'm');\n   132→  return pattern.test(content);\n   133→}\n   134→\n   135→/**\n   136→ * Extract the [dependencies] section from Cargo.toml content.\n   137→ * Stops at the next section header (e.g., [dev-dependencies], [build-dependencies]).\n   138→ * Returns empty string if no [dependencies] section found.\n   139→ */\n   140→function getCargoDepsSection(content: string): string {\n   141→  const match = content.match(/^\\[dependencies\\]\\s*$/m);\n   142→  if (!match || match.index === undefined) return '';\n   143→  const start = match.index + match[0].length;\n   144→  // Find next section header\n   145→  const nextSection = content.slice(start).search(/^\\[/m);\n   146→  return nextSection === -1 ? content.slice(start) : content.slice(start, start + nextSection);\n   147→}\n   148→\n   149→/**\n   150→ * Check if a Cargo.toml [dependencies] section contains a specific crate.\n   151→ * Uses word-boundary matching to avoid substring false positives\n   152→ * (e.g., \"anthropic-sdk\" should not match \"anthropic\").\n   153→ */\n   154→function hasCargoDep(depsSection: string, dep: string): boolean {\n   155→  const escaped = dep.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n   156→  const pattern = new RegExp(`(?:^|\\\\s)${escaped}(?:\\\\s*=|\\\\s*\\\\{)`, 'm');\n   157→  return pattern.test(depsSection);\n   158→}\n   159→\n   160→function getPythonDepsContent(dir: string): string {\n   161→  const files = ['requirements.txt', 'pyproject.toml', 'setup.py'];\n   162→  const parts: string[] = [];\n   163→  for (const file of files) {\n   164→    const content = readTextSafe(join(dir, file));\n   165→    if (content) parts.push(content);\n   166→  }\n   167→  return parts.join('\\n');\n   168→}\n   169→\n   170→export function detectAppType(dir: string, stack: string | null): AppType {\n   171→  if (stack === 'nodejs') {\n   172→    const pkg = readJsonSafe(join(dir, 'package.json'));\n   173→    if (!pkg) return 'generic';\n   174→\n   175→    const deps = getNodeDeps(pkg);\n   176→\n   177→    // Priority 1: Agent detection\n   178→    if (AGENT_DEPS_NODE.some(d => deps.has(d))) {\n   179→      return 'agent';\n   180→    }\n   181→\n   182→    // Priority 2: Web detection\n   183→    if (WEB_FRAMEWORK_DEPS.some(d => deps.has(d))) {\n   184→      return 'web';\n   185→    }\n   186→    if (\n   187→      existsSync(join(dir, 'index.html')) ||\n   188→      existsSync(join(dir, 'public', 'index.html')) ||\n   189→      existsSync(join(dir, 'src', 'index.html'))\n   190→    ) {\n   191→      return 'web';\n   192→    }\n   193→\n   194→    // Priority 3: CLI detection\n   195→    const bin = pkg['bin'];\n   196→    const scripts = pkg['scripts'] as Record<string, string> | undefined;\n   197→    const hasStart = scripts?.['start'] !== undefined;\n   198→    if (bin && !hasStart) {\n   199→      return 'cli';\n   200→    }\n   201→\n   202→    // Priority 4: Server detection\n   203→    if (hasStart) {\n   204→      return 'server';\n   205→    }\n   206→\n   207→    return 'generic';\n   208→  }\n   209→\n   210→  if (stack === 'python') {\n   211→    const content = getPythonDepsContent(dir);\n   212→\n   213→    // Priority 1: Agent detection\n   214→    if (AGENT_DEPS_PYTHON.some(d => hasPythonDep(content, d))) {\n   215→      return 'agent';\n   216→    }\n   217→\n   218→    // Priority 2: Web detection (framework + templates/static dirs)\n   219→    const hasWebFramework = PYTHON_WEB_FRAMEWORKS.some(d => hasPythonDep(content, d));\n   220→    if (hasWebFramework) {\n   221→      const hasTemplates = existsSync(join(dir, 'templates'));\n   222→      const hasStatic = existsSync(join(dir, 'static'));\n   223→      if (hasTemplates || hasStatic) {\n   224→        return 'web';\n   225→      }\n   226→      // Bare Flask/Django/FastAPI without templates => server\n   227→      return 'server';\n   228→    }\n   229→\n   230→    // Priority 4: Server detection (has main entry point)\n   231→    if (\n   232→      existsSync(join(dir, 'app.py')) ||\n   233→      existsSync(join(dir, 'main.py')) ||\n   234→      existsSync(join(dir, 'manage.py'))\n   235→    ) {\n   236→      return 'server';\n   237→    }\n   238→\n   239→    return 'generic';\n   240→  }\n   241→\n   242→  if (stack === 'rust') {\n   243→    const cargoContent = readTextSafe(join(dir, 'Cargo.toml'));\n   244→    if (!cargoContent) return 'generic';\n   245→\n   246→    const depsSection = getCargoDepsSection(cargoContent);\n   247→\n   248→    // Priority 1: Agent detection (only in [dependencies], not [dev-dependencies])\n   249→    if (RUST_AGENT_DEPS.some(d => hasCargoDep(depsSection, d))) {\n   250→      return 'agent';\n   251→    }\n   252→\n   253→    // Priority 2: Server detection (web framework in [dependencies])\n   254→    if (RUST_WEB_FRAMEWORKS.some(d => hasCargoDep(depsSection, d))) {\n   255→      return 'server';\n   256→    }\n   257→\n   258→    // Priority 3: CLI detection ([[bin]] section present)\n   259→    if (/^\\[\\[bin\\]\\]\\s*$/m.test(cargoContent)) {\n   260→      return 'cli';\n   261→    }\n   262→\n   263→    // Priority 4: Library detection ([lib] section present, no [[bin]])\n   264→    if (/^\\[lib\\]\\s*$/m.test(cargoContent)) {\n   265→      return 'generic';\n   266→    }\n   267→\n   268→    return 'generic';\n   269→  }\n   270→\n   271→  return 'generic';\n   272→}\n   273→"}]},"parent_tool_use_id":"toolu_01Cxxc3JMDGP4TtKB29uGny5","session_id":"920d100a-a3f1-41ed-bf53-d85a660ba553","uuid":"74617341-b7ce-4484-a444-141a0005ad1d","timestamp":"2026-03-23T14:09:09.290Z"}
