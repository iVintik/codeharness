{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FEHTqmhT2Cff5ueDbZsPjc","type":"tool_result","content":"1\t/**\n2\t * WorkflowGraph — Ink component that renders a schematic workflow graph.\n3\t *\n4\t * Displays tasks as nodes connected by arrows, with status indicators\n5\t * (pending, active, done, failed). Loop blocks are rendered with an\n6\t * iteration counter and visual grouping.\n7\t *\n8\t * This is a pure presentational component — no side effects, no state hooks.\n9\t */\n10\t\n11\timport React from 'react';\n12\timport { Text, Box } from 'ink';\n13\timport type { FlowStep, LoopBlock } from './workflow-parser.js';\n14\timport type { TaskNodeState } from './ink-components.js';\n15\t\n16\texport interface WorkflowGraphProps {\n17\t  flow: FlowStep[];\n18\t  currentTask: string | null;\n19\t  taskStates: Record<string, TaskNodeState>;\n20\t}\n21\t\n22\tfunction isLoopBlock(step: FlowStep): step is LoopBlock {\n23\t  return typeof step === 'object' && step !== null && 'loop' in step;\n24\t}\n25\t\n26\t/** Render a single task name with its status indicator. */\n27\tfunction TaskNode({ name, status }: { name: string; status: TaskNodeState | undefined }) {\n28\t  const s = status ?? 'pending';\n29\t  switch (s) {\n30\t    case 'done':\n31\t      return <Text color=\"green\">{name} ✓</Text>;\n32\t    case 'active':\n33\t      return <Text color=\"cyan\">◆ {name}</Text>;\n34\t    case 'failed':\n35\t      return <Text color=\"red\">{name} ✗</Text>;\n36\t    case 'pending':\n37\t    default:\n38\t      return <Text dimColor>{name}</Text>;\n39\t  }\n40\t}\n41\t\n42\t/** Count completed iterations for a loop block based on task states. */\n43\tfunction loopIteration(tasks: string[], taskStates: Record<string, TaskNodeState>): number {\n44\t  // Count how many times all tasks in the loop have completed.\n45\t  // A simple heuristic: if all tasks are done, iteration is 1.\n46\t  // The actual iteration count needs to come from the engine state.\n47\t  // For now, we derive it from whether the loop tasks have been started.\n48\t  // The iteration count will be properly wired when the engine integration lands.\n49\t  let iteration = 0;\n50\t  const allDone = tasks.every(t => taskStates[t] === 'done');\n51\t  const anyActive = tasks.some(t => taskStates[t] === 'active');\n52\t  const anyStarted = tasks.some(t => taskStates[t] !== 'pending' && taskStates[t] !== undefined);\n53\t  if (allDone) {\n54\t    iteration = 1;\n55\t  } else if (anyActive || anyStarted) {\n56\t    iteration = 1;\n57\t  }\n58\t  // Note: Proper multi-iteration counting requires engine-provided data.\n59\t  // This will be wired in the engine integration story.\n60\t  return iteration;\n61\t}\n62\t\n63\texport function WorkflowGraph({ flow, currentTask, taskStates }: WorkflowGraphProps) {\n64\t  if (flow.length === 0 || Object.keys(taskStates).length === 0) {\n65\t    return null;\n66\t  }\n67\t\n68\t  const elements: React.ReactNode[] = [];\n69\t\n70\t  for (let i = 0; i < flow.length; i++) {\n71\t    const step = flow[i];\n72\t\n73\t    if (i > 0) {\n74\t      elements.push(<Text key={`arrow-${i}`}>{' → '}</Text>);\n75\t    }\n76\t\n77\t    if (isLoopBlock(step)) {\n78\t      const iteration = loopIteration(step.loop, taskStates);\n79\t      const loopNodes: React.ReactNode[] = [];\n80\t      for (let j = 0; j < step.loop.length; j++) {\n81\t        if (j > 0) {\n82\t          loopNodes.push(<Text key={`loop-arrow-${i}-${j}`}>{' → '}</Text>);\n83\t        }\n84\t        loopNodes.push(\n85\t          <TaskNode key={`loop-task-${i}-${j}`} name={step.loop[j]} status={taskStates[step.loop[j]]} />\n86\t        );\n87\t      }\n88\t      elements.push(\n89\t        <Text key={`loop-${i}`}>\n90\t          <Text>loop({iteration})[ </Text>\n91\t          {loopNodes}\n92\t          <Text> ]</Text>\n93\t        </Text>\n94\t      );\n95\t    } else {\n96\t      elements.push(\n97\t        <TaskNode key={`task-${i}`} name={step} status={taskStates[step]} />\n98\t      );\n99\t    }\n100\t  }\n101\t\n102\t  return (\n103\t    <Box flexDirection=\"column\">\n104\t      <Text>{'━'.repeat(Math.min(process.stdout.columns || 60, 50))}</Text>\n105\t      <Text>  {elements}</Text>\n106\t      <Text>{'━'.repeat(Math.min(process.stdout.columns || 60, 50))}</Text>\n107\t    </Box>\n108\t  );\n109\t}\n110\t"}]},"parent_tool_use_id":"toolu_01Xt1BTzuX3J9Jg4gSz1FeWE","session_id":"1d40f54a-b143-44f0-8247-609f8fc4c105","uuid":"e6acc1a8-52a1-40b0-9ec1-c3a67c60f6fa","timestamp":"2026-04-03T11:21:44.798Z"}
