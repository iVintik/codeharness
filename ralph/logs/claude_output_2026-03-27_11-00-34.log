{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Brksesz8WM5qwe337Avx8f","type":"tool_result","content":"     1→/**\n     2→ * Docker availability check, shared stack management, collector-only mode.\n     3→ */\n     4→\n     5→import {\n     6→  isDockerAvailable,\n     7→  isSharedStackRunning,\n     8→  startSharedStack,\n     9→  startCollectorOnly,\n    10→} from '../../lib/docker/index.js';\n    11→import { getComposeFilePath, getElkComposeFilePath } from '../../lib/stack-path.js';\n    12→import { ok as okOutput, fail as failOutput, info } from '../../lib/output.js';\n    13→import { readState, writeState } from '../../lib/state.js';\n    14→import type { HarnessState } from '../../lib/state.js';\n    15→import type { AppType } from '../../lib/stacks/index.js';\n    16→import type { Result } from '../../types/result.js';\n    17→import { ok, fail } from '../../types/result.js';\n    18→import type { InitDockerResult } from './types.js';\n    19→import { DEFAULT_PORTS } from './types.js';\n    20→\n    21→interface DockerCheckOptions {\n    22→  readonly observability: boolean;\n    23→  readonly otelEndpoint?: string;\n    24→  readonly opensearchUrl?: string;\n    25→  readonly logsUrl?: string;\n    26→  readonly isJson: boolean;\n    27→}\n    28→\n    29→export interface DockerCheckResult {\n    30→  readonly available: boolean;\n    31→  /** If observability is required but Docker is missing, this is a critical failure */\n    32→  readonly criticalFailure: boolean;\n    33→  readonly dockerResult?: InitDockerResult | null;\n    34→}\n    35→\n    36→/**\n    37→ * Check Docker availability. Returns critical failure when observability\n    38→ * is on and Docker is needed but missing.\n    39→ */\n    40→export function checkDocker(opts: DockerCheckOptions): Result<DockerCheckResult> {\n    41→  // Skip Docker check for remote-direct mode or OpenSearch\n    42→  if (opts.otelEndpoint || opts.logsUrl || opts.opensearchUrl) {\n    43→    return ok({ available: true, criticalFailure: false });\n    44→  }\n    45→\n    46→  if (!isDockerAvailable()) {\n    47→    if (opts.observability) {\n    48→      // Docker required when observability is ON\n    49→      const dockerResult: InitDockerResult = {\n    50→        compose_file: '',\n    51→        stack_running: false,\n    52→        services: [],\n    53→        ports: DEFAULT_PORTS,\n    54→      };\n    55→      return ok({ available: false, criticalFailure: true, dockerResult });\n    56→    }\n    57→    // Observability OFF — Docker absence is fine\n    58→    return ok({ available: false, criticalFailure: false });\n    59→  }\n    60→\n    61→  if (!opts.isJson) {\n    62→    okOutput('Docker: available');\n    63→  }\n    64→  return ok({ available: true, criticalFailure: false });\n    65→}\n    66→\n    67→interface DockerSetupOptions {\n    68→  readonly observability: boolean;\n    69→  readonly otelEndpoint?: string;\n    70→  readonly opensearchUrl?: string;\n    71→  readonly logsUrl?: string;\n    72→  readonly metricsUrl?: string;\n    73→  readonly tracesUrl?: string;\n    74→  readonly isJson: boolean;\n    75→  readonly dockerAvailable: boolean;\n    76→  readonly appType?: AppType;\n    77→  readonly state: HarnessState;\n    78→  readonly projectDir: string;\n    79→}\n    80→\n    81→export interface DockerSetupResult {\n    82→  readonly docker: InitDockerResult | null;\n    83→  readonly state: HarnessState;\n    84→}\n    85→\n    86→/**\n    87→ * Set up Docker stack based on the observability mode:\n    88→ * - no-observability: skip Docker entirely\n    89→ * - remote-direct: no Docker, direct OTLP export\n    90→ * - remote-routed: local OTel Collector only, remote backends\n    91→ * - local-shared: full local stack (default)\n    92→ */\n    93→export function setupDocker(opts: DockerSetupOptions): Result<DockerSetupResult> {\n    94→  try {\n    95→    let state = { ...opts.state };\n    96→\n    97→    if (!opts.observability) {\n    98→      // Observability OFF — skip Docker entirely\n    99→      writeState(state, opts.projectDir);\n   100→      if (!opts.isJson) {\n   101→        info('Observability: disabled, skipping Docker stack');\n   102→      }\n   103→      return ok({ docker: null, state });\n   104→    }\n   105→\n   106→    if (opts.opensearchUrl) {\n   107→      return handleOpenSearch(opts, state);\n   108→    }\n   109→\n   110→    if (opts.otelEndpoint) {\n   111→      return handleRemoteDirect(opts, state);\n   112→    }\n   113→\n   114→    if (opts.logsUrl && opts.metricsUrl && opts.tracesUrl) {\n   115→      return handleRemoteRouted(opts, state);\n   116→    }\n   117→\n   118→    if (opts.dockerAvailable) {\n   119→      return handleLocalShared(opts, state);\n   120→    }\n   121→\n   122→    // Docker not available — deferred observability\n   123→    const docker: InitDockerResult = {\n   124→      compose_file: '',\n   125→      stack_running: false,\n   126→      services: [],\n   127→      ports: DEFAULT_PORTS,\n   128→    };\n   129→    writeState(state, opts.projectDir);\n   130→    if (!opts.isJson) {\n   131→      info('Observability: deferred (configure Docker or remote endpoint to activate)');\n   132→    }\n   133→    return ok({ docker, state });\n   134→  } catch (err) {\n   135→    const message = err instanceof Error ? err.message : String(err);\n   136→    return fail(`Docker setup failed: ${message}`);\n   137→  }\n   138→}\n   139→\n   140→function handleOpenSearch(\n   141→  opts: DockerSetupOptions,\n   142→  state: HarnessState,\n   143→): Result<DockerSetupResult> {\n   144→  state = {\n   145→    ...state,\n   146→    otlp: {\n   147→      ...state.otlp!,\n   148→      mode: 'remote-direct' as const,\n   149→    },\n   150→    opensearch: {\n   151→      url: opts.opensearchUrl!,\n   152→    },\n   153→  } as HarnessState;\n   154→  writeState(state, opts.projectDir);\n   155→  if (!opts.isJson) {\n   156→    okOutput(`Observability: OpenSearch backend at ${opts.opensearchUrl!}`);\n   157→  }\n   158→  return ok({ docker: null, state });\n   159→}\n   160→\n   161→function handleRemoteDirect(\n   162→  opts: DockerSetupOptions,\n   163→  state: HarnessState,\n   164→): Result<DockerSetupResult> {\n   165→  state = {\n   166→    ...state,\n   167→    otlp: {\n   168→      ...state.otlp!,\n   169→      endpoint: opts.otelEndpoint!,\n   170→      mode: 'remote-direct' as const,\n   171→    },\n   172→  };\n   173→  writeState(state, opts.projectDir);\n   174→  if (!opts.isJson) {\n   175→    okOutput(`OTLP: configured for remote endpoint ${opts.otelEndpoint!}`);\n   176→  }\n   177→  return ok({ docker: null, state });\n   178→}\n   179→\n   180→function handleRemoteRouted(\n   181→  opts: DockerSetupOptions,\n   182→  state: HarnessState,\n   183→): Result<DockerSetupResult> {\n   184→  const collectorResult = startCollectorOnly(opts.logsUrl!, opts.metricsUrl!, opts.tracesUrl!);\n   185→  const sharedComposeFile = getComposeFilePath();\n   186→\n   187→  if (collectorResult.started) {\n   188→    state = {\n   189→      ...state,\n   190→      otlp: { ...state.otlp!, mode: 'remote-routed' as const },\n   191→      docker: {\n   192→        compose_file: sharedComposeFile,\n   193→        stack_running: true,\n   194→        remote_endpoints: {\n   195→          logs_url: opts.logsUrl!,\n   196→          metrics_url: opts.metricsUrl!,\n   197→          traces_url: opts.tracesUrl!,\n   198→        },\n   199→        ports: DEFAULT_PORTS,\n   200→      },\n   201→    };\n   202→    const docker: InitDockerResult = {\n   203→      compose_file: sharedComposeFile,\n   204→      stack_running: true,\n   205→      services: collectorResult.services,\n   206→      ports: DEFAULT_PORTS,\n   207→    };\n   208→    writeState(state, opts.projectDir);\n   209→    if (!opts.isJson) {\n   210→      okOutput('Observability: OTel Collector started (routing to remote backends)');\n   211→    }\n   212→    return ok({ docker, state });\n   213→  }\n   214→\n   215→  if (!opts.isJson) {\n   216→    failOutput('OTel Collector: failed to start');\n   217→    if (collectorResult.error) {\n   218→      info(`Error: ${collectorResult.error}`);\n   219→    }\n   220→  }\n   221→  const docker: InitDockerResult = {\n   222→    compose_file: sharedComposeFile,\n   223→    stack_running: false,\n   224→    services: [],\n   225→    ports: DEFAULT_PORTS,\n   226→  };\n   227→  return ok({ docker, state });\n   228→}\n   229→\n   230→function handleLocalShared(\n   231→  opts: DockerSetupOptions,\n   232→  state: HarnessState,\n   233→): Result<DockerSetupResult> {\n   234→  const backend = state.otlp?.backend ?? 'victoria';\n   235→  const sharedComposeFile = backend === 'elk' ? getElkComposeFilePath() : getComposeFilePath();\n   236→\n   237→  if (isSharedStackRunning()) {\n   238→    if (!opts.isJson) {\n   239→      okOutput('Observability stack: already running (shared)');\n   240→      if (opts.appType === 'web') {\n   241→        info('Web app detected — verify OTel Collector has CORS enabled');\n   242→      }\n   243→    }\n   244→    const docker: InitDockerResult = {\n   245→      compose_file: sharedComposeFile,\n   246→      stack_running: true,\n   247→      services: [],\n   248→      ports: DEFAULT_PORTS,\n   249→    };\n   250→    state = {\n   251→      ...state,\n   252→      otlp: { ...state.otlp!, mode: 'local-shared' as const },\n   253→      docker: {\n   254→        compose_file: sharedComposeFile,\n   255→        stack_running: true,\n   256→        ports: DEFAULT_PORTS,\n   257→      },\n   258→    };\n   259→    writeState(state, opts.projectDir);\n   260→    return ok({ docker, state });\n   261→  }\n   262→\n   263→  const startResult = startSharedStack();\n   264→  if (startResult.started) {\n   265→    if (!opts.isJson) {\n   266→      okOutput('Observability stack: started (shared at ~/.codeharness/stack/)');\n   267→    }\n   268→    const docker: InitDockerResult = {\n   269→      compose_file: sharedComposeFile,\n   270→      stack_running: true,\n   271→      services: startResult.services,\n   272→      ports: DEFAULT_PORTS,\n   273→    };\n   274→    state = {\n   275→      ...state,\n   276→      otlp: { ...state.otlp!, mode: 'local-shared' as const },\n   277→      docker: {\n   278→        compose_file: sharedComposeFile,\n   279→        stack_running: true,\n   280→        ports: DEFAULT_PORTS,\n   281→      },\n   282→    };\n   283→    writeState(state, opts.projectDir);\n   284→    return ok({ docker, state });\n   285→  }\n   286→\n   287→  if (!opts.isJson) {\n   288→    failOutput('Observability stack: failed to start');\n   289→    if (startResult.error) {\n   290→      info(`Error: ${startResult.error}`);\n   291→    }\n   292→  }\n   293→  const docker: InitDockerResult = {\n   294→    compose_file: sharedComposeFile,\n   295→    stack_running: false,\n   296→    services: [],\n   297→    ports: DEFAULT_PORTS,\n   298→  };\n   299→  return ok({ docker, state });\n   300→}\n   301→"}]},"parent_tool_use_id":"toolu_01MwzbgNwEhenGxNXV9UQBeX","session_id":"507a8d0b-20bb-4c55-954f-5f817ca0f972","uuid":"a13181c5-20c9-4865-80a9-3c21c8c41121","timestamp":"2026-03-27T07:03:58.387Z"}
