fileTemplate('/project', detections);\n    expect(r.success).toBe(true);\n    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    expect(written).toContain('FROM node:22-slim AS build-nodejs');\n    expect(written).toContain('FROM rust:1.82-slim AS build-rust');\n    // No java build stage\n    expect(written).not.toContain('build-java');\n  });\n});"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":151,"cache_read_input_tokens":56796,"cache_creation":{"ephemeral_5m_input_tokens":151,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_017jkzWrDhmfYHNpbYuB4NZk","session_id":"e8d3a9d7-303a-4d24-9a07-31410ec54173","uuid":"0cdd0c2c-ec0e-4ad6-9403-990bdd0abf38"}
