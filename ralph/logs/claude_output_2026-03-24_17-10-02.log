{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VMwRQjhjv9wEDHUQNiQEdY","type":"tool_result","content":"     1→import { execFileSync } from 'node:child_process';\n     2→import { writeFileSync } from 'node:fs';\n     3→import { getComposeFilePath, getOtelConfigPath, ensureStackDir } from '../stack-path.js';\n     4→import { dockerComposeTemplate, dockerComposeCollectorOnlyTemplate } from '../../templates/docker-compose.js';\n     5→import { otelCollectorConfigTemplate, otelCollectorRemoteTemplate } from '../../templates/otel-config.js';\n     6→import type { DockerServiceStatus, DockerStartResult } from './health.js';\n     7→\n     8→export function isStackRunning(composeFile: string): boolean {\n     9→  try {\n    10→    const output = execFileSync('docker', ['compose', '-f', composeFile, 'ps', '--format', 'json'], {\n    11→      stdio: 'pipe',\n    12→      timeout: 15_000,\n    13→    });\n    14→    const text = output.toString().trim();\n    15→    if (!text) return false;\n    16→\n    17→    // docker compose ps --format json outputs one JSON object per line\n    18→    const lines = text.split('\\n').filter(l => l.trim());\n    19→    for (const line of lines) {\n    20→      const svc = JSON.parse(line) as { State?: string };\n    21→      if (svc.State !== 'running') return false;\n    22→    }\n    23→    return lines.length > 0;\n    24→  } catch {\n    25→    return false;\n    26→  }\n    27→}\n    28→\n    29→export function isSharedStackRunning(): boolean {\n    30→  try {\n    31→    const composeFile = getComposeFilePath();\n    32→    const output = execFileSync('docker', ['compose', '-p', 'codeharness-shared', '-f', composeFile, 'ps', '--format', 'json'], {\n    33→      stdio: 'pipe',\n    34→      timeout: 15_000,\n    35→    });\n    36→    const text = output.toString().trim();\n    37→    if (!text) return false;\n    38→\n    39→    const lines = text.split('\\n').filter(l => l.trim());\n    40→    for (const line of lines) {\n    41→      const svc = JSON.parse(line) as { State?: string };\n    42→      if (svc.State !== 'running') return false;\n    43→    }\n    44→    return lines.length > 0;\n    45→  } catch {\n    46→    return false;\n    47→  }\n    48→}\n    49→\n    50→export function startStack(composeFile: string): DockerStartResult {\n    51→  try {\n    52→    execFileSync('docker', ['compose', '-f', composeFile, 'up', '-d'], {\n    53→      stdio: 'pipe',\n    54→      timeout: 30_000,\n    55→    });\n    56→\n    57→    const services = getRunningServices(composeFile);\n    58→    return {\n    59→      started: true,\n    60→      services,\n    61→    };\n    62→  } catch (err) {\n    63→    const message = err instanceof Error ? err.message : String(err);\n    64→    return {\n    65→      started: false,\n    66→      services: [],\n    67→      error: message,\n    68→    };\n    69→  }\n    70→}\n    71→\n    72→export function startSharedStack(): DockerStartResult {\n    73→  try {\n    74→    ensureStackDir();\n    75→\n    76→    const composeFile = getComposeFilePath();\n    77→    const otelConfigFile = getOtelConfigPath();\n    78→\n    79→    const composeContent = dockerComposeTemplate({ shared: true });\n    80→    writeFileSync(composeFile, composeContent, 'utf-8');\n    81→\n    82→    const otelContent = otelCollectorConfigTemplate();\n    83→    writeFileSync(otelConfigFile, otelContent, 'utf-8');\n    84→\n    85→    execFileSync('docker', ['compose', '-p', 'codeharness-shared', '-f', composeFile, 'up', '-d'], {\n    86→      stdio: 'pipe',\n    87→      timeout: 30_000,\n    88→    });\n    89→\n    90→    const services = getRunningServices(composeFile, 'codeharness-shared');\n    91→    return {\n    92→      started: true,\n    93→      services,\n    94→    };\n    95→  } catch (err) {\n    96→    const message = err instanceof Error ? err.message : String(err);\n    97→    return {\n    98→      started: false,\n    99→      services: [],\n   100→      error: message,\n   101→    };\n   102→  }\n   103→}\n   104→\n   105→export function stopStack(composeFile: string): void {\n   106→  execFileSync('docker', ['compose', '-f', composeFile, 'down', '-v'], {\n   107→    stdio: 'pipe',\n   108→    timeout: 30_000,\n   109→  });\n   110→}\n   111→\n   112→export function stopSharedStack(): void {\n   113→  const composeFile = getComposeFilePath();\n   114→  execFileSync('docker', ['compose', '-p', 'codeharness-shared', '-f', composeFile, 'down'], {\n   115→    stdio: 'pipe',\n   116→    timeout: 30_000,\n   117→  });\n   118→}\n   119→\n   120→export function startCollectorOnly(logsUrl: string, metricsUrl: string, tracesUrl: string): DockerStartResult {\n   121→  try {\n   122→    ensureStackDir();\n   123→\n   124→    const composeFile = getComposeFilePath();\n   125→    const otelConfigFile = getOtelConfigPath();\n   126→\n   127→    const composeContent = dockerComposeCollectorOnlyTemplate();\n   128→    writeFileSync(composeFile, composeContent, 'utf-8');\n   129→\n   130→    const otelContent = otelCollectorRemoteTemplate({ logsUrl, metricsUrl, tracesUrl });\n   131→    writeFileSync(otelConfigFile, otelContent, 'utf-8');\n   132→\n   133→    execFileSync('docker', ['compose', '-p', 'codeharness-collector', '-f', composeFile, 'up', '-d'], {\n   134→      stdio: 'pipe',\n   135→      timeout: 30_000,\n   136→    });\n   137→\n   138→    const services = getRunningServices(composeFile, 'codeharness-collector');\n   139→    return {\n   140→      started: true,\n   141→      services,\n   142→    };\n   143→  } catch (err) {\n   144→    const message = err instanceof Error ? err.message : String(err);\n   145→    return {\n   146→      started: false,\n   147→      services: [],\n   148→      error: message,\n   149→    };\n   150→  }\n   151→}\n   152→\n   153→export function isCollectorRunning(): boolean {\n   154→  try {\n   155→    const composeFile = getComposeFilePath();\n   156→    const output = execFileSync('docker', ['compose', '-p', 'codeharness-collector', '-f', composeFile, 'ps', '--format', 'json'], {\n   157→      stdio: 'pipe',\n   158→      timeout: 15_000,\n   159→    });\n   160→    const text = output.toString().trim();\n   161→    if (!text) return false;\n   162→\n   163→    const lines = text.split('\\n').filter(l => l.trim());\n   164→    for (const line of lines) {\n   165→      const svc = JSON.parse(line) as { State?: string };\n   166→      if (svc.State !== 'running') return false;\n   167→    }\n   168→    return lines.length > 0;\n   169→  } catch {\n   170→    return false;\n   171→  }\n   172→}\n   173→\n   174→export function stopCollectorOnly(): void {\n   175→  const composeFile = getComposeFilePath();\n   176→  execFileSync('docker', ['compose', '-p', 'codeharness-collector', '-f', composeFile, 'down'], {\n   177→    stdio: 'pipe',\n   178→    timeout: 30_000,\n   179→  });\n   180→}\n   181→\n   182→function getRunningServices(composeFile: string, projectName?: string): DockerServiceStatus[] {\n   183→  try {\n   184→    const args = projectName\n   185→      ? ['compose', '-p', projectName, '-f', composeFile, 'ps', '--format', 'json']\n   186→      : ['compose', '-f', composeFile, 'ps', '--format', 'json'];\n   187→\n   188→    const output = execFileSync('docker', args, {\n   189→      stdio: 'pipe',\n   190→      timeout: 15_000,\n   191→    });\n   192→    const text = output.toString().trim();\n   193→    if (!text) return [];\n   194→\n   195→    const lines = text.split('\\n').filter(l => l.trim());\n   196→    const services: DockerServiceStatus[] = [];\n   197→    for (const line of lines) {\n   198→      const svc = JSON.parse(line) as { Service?: string; State?: string; Publishers?: Array<{ PublishedPort?: number }> };\n   199→      const ports = (svc.Publishers ?? [])\n   200→        .filter(p => p.PublishedPort && p.PublishedPort > 0)\n   201→        .map(p => String(p.PublishedPort));\n   202→      services.push({\n   203→        name: svc.Service ?? 'unknown',\n   204→        status: svc.State ?? 'unknown',\n   205→        port: ports.join(','),\n   206→      });\n   207→    }\n   208→    return services;\n   209→  } catch {\n   210→    return [];\n   211→  }\n   212→}\n   213→"}]},"parent_tool_use_id":"toolu_01WxJciqSN2EMLLyK1wQ7yug","session_id":"6831c0a8-772d-4704-bc72-4469c7d7a986","uuid":"86269113-43c9-46a1-9360-2e89fe7d7aef","timestamp":"2026-03-24T13:13:56.628Z"}
