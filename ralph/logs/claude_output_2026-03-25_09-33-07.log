{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JL8QXrhpNcfucyaWw1pKU7","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { parse } from 'yaml';\n     3→import { dockerComposeTemplate, dockerComposeCollectorOnlyTemplate } from '../docker-compose.js';\n     4→import type { DockerComposeConfig } from '../docker-compose.js';\n     5→\n     6→describe('dockerComposeTemplate', () => {\n     7→  const defaultConfig: DockerComposeConfig = {\n     8→    shared: true,\n     9→  };\n    10→\n    11→  it('returns valid YAML', () => {\n    12→    const result = dockerComposeTemplate(defaultConfig);\n    13→    const parsed = parse(result) as Record<string, unknown>;\n    14→    expect(parsed).toBeDefined();\n    15→    expect(parsed.services).toBeDefined();\n    16→  });\n    17→\n    18→  it('includes all four required services', () => {\n    19→    const result = dockerComposeTemplate(defaultConfig);\n    20→    const parsed = parse(result) as { services: Record<string, unknown> };\n    21→    expect(Object.keys(parsed.services)).toContain('victoria-logs');\n    22→    expect(Object.keys(parsed.services)).toContain('victoria-metrics');\n    23→    expect(Object.keys(parsed.services)).toContain('victoria-traces');\n    24→    expect(Object.keys(parsed.services)).toContain('otel-collector');\n    25→  });\n    26→\n    27→  it('uses pinned image tags — no latest or missing tags', () => {\n    28→    const result = dockerComposeTemplate(defaultConfig);\n    29→    const parsed = parse(result) as { services: Record<string, { image: string }> };\n    30→    for (const [name, svc] of Object.entries(parsed.services)) {\n    31→      expect(svc.image, `${name} should have a pinned image tag`).toMatch(/:.+$/);\n    32→      expect(svc.image, `${name} should not use latest`).not.toContain(':latest');\n    33→    }\n    34→  });\n    35→\n    36→  it('uses correct image for victoria-logs', () => {\n    37→    const result = dockerComposeTemplate(defaultConfig);\n    38→    const parsed = parse(result) as { services: Record<string, { image: string }> };\n    39→    expect(parsed.services['victoria-logs'].image).toBe('victoriametrics/victoria-logs:v1.15.0-victorialogs');\n    40→  });\n    41→\n    42→  it('uses correct image for victoria-metrics', () => {\n    43→    const result = dockerComposeTemplate(defaultConfig);\n    44→    const parsed = parse(result) as { services: Record<string, { image: string }> };\n    45→    expect(parsed.services['victoria-metrics'].image).toBe('victoriametrics/victoria-metrics:v1.106.1');\n    46→  });\n    47→\n    48→  it('uses correct image for victoria-traces', () => {\n    49→    const result = dockerComposeTemplate(defaultConfig);\n    50→    const parsed = parse(result) as { services: Record<string, { image: string }> };\n    51→    expect(parsed.services['victoria-traces'].image).toBe('jaegertracing/all-in-one:1.56');\n    52→  });\n    53→\n    54→  it('uses correct image for otel-collector', () => {\n    55→    const result = dockerComposeTemplate(defaultConfig);\n    56→    const parsed = parse(result) as { services: Record<string, { image: string }> };\n    57→    expect(parsed.services['otel-collector'].image).toBe('otel/opentelemetry-collector-contrib:0.96.0');\n    58→  });\n    59→\n    60→  it('maps correct ports for victoria-logs (9428)', () => {\n    61→    const result = dockerComposeTemplate(defaultConfig);\n    62→    const parsed = parse(result) as { services: Record<string, { ports: string[] }> };\n    63→    expect(parsed.services['victoria-logs'].ports).toContain('9428:9428');\n    64→  });\n    65→\n    66→  it('maps correct ports for victoria-metrics (8428)', () => {\n    67→    const result = dockerComposeTemplate(defaultConfig);\n    68→    const parsed = parse(result) as { services: Record<string, { ports: string[] }> };\n    69→    expect(parsed.services['victoria-metrics'].ports).toContain('8428:8428');\n    70→  });\n    71→\n    72→  it('maps correct ports for victoria-traces (14268, 16686)', () => {\n    73→    const result = dockerComposeTemplate(defaultConfig);\n    74→    const parsed = parse(result) as { services: Record<string, { ports: string[] }> };\n    75→    expect(parsed.services['victoria-traces'].ports).toContain('14268:14268');\n    76→    expect(parsed.services['victoria-traces'].ports).toContain('16686:16686');\n    77→  });\n    78→\n    79→  it('maps correct ports for otel-collector (4317, 4318)', () => {\n    80→    const result = dockerComposeTemplate(defaultConfig);\n    81→    const parsed = parse(result) as { services: Record<string, { ports: string[] }> };\n    82→    expect(parsed.services['otel-collector'].ports).toContain('4317:4317');\n    83→    expect(parsed.services['otel-collector'].ports).toContain('4318:4318');\n    84→  });\n    85→\n    86→  it('otel-collector depends on backend services', () => {\n    87→    const result = dockerComposeTemplate(defaultConfig);\n    88→    const parsed = parse(result) as { services: Record<string, { depends_on: string[] }> };\n    89→    const deps = parsed.services['otel-collector'].depends_on;\n    90→    expect(deps).toContain('victoria-logs');\n    91→    expect(deps).toContain('victoria-metrics');\n    92→    expect(deps).toContain('victoria-traces');\n    93→  });\n    94→\n    95→  it('otel-collector mounts config volume', () => {\n    96→    const result = dockerComposeTemplate(defaultConfig);\n    97→    const parsed = parse(result) as { services: Record<string, { volumes: string[] }> };\n    98→    const volumes = parsed.services['otel-collector'].volumes;\n    99→    expect(volumes.some(v => v.includes('otel-collector-config.yaml'))).toBe(true);\n   100→  });\n   101→\n   102→  it('includes named volumes for data persistence', () => {\n   103→    const result = dockerComposeTemplate(defaultConfig);\n   104→    const parsed = parse(result) as { volumes: Record<string, unknown> };\n   105→    expect(parsed.volumes).toHaveProperty('victoria-logs-data');\n   106→    expect(parsed.volumes).toHaveProperty('victoria-metrics-data');\n   107→  });\n   108→\n   109→  it('uses fixed shared network name', () => {\n   110→    const result = dockerComposeTemplate(defaultConfig);\n   111→    const parsed = parse(result) as { networks: Record<string, { name: string }> };\n   112→    expect(parsed.networks.default.name).toBe('codeharness-shared-net');\n   113→  });\n   114→\n   115→  it('uses fixed codeharness-shared project name', () => {\n   116→    const result = dockerComposeTemplate({ shared: true });\n   117→    const parsed = parse(result) as { name: string };\n   118→    expect(parsed.name).toBe('codeharness-shared');\n   119→  });\n   120→\n   121→  it('all services have com.codeharness.stack=shared label', () => {\n   122→    const result = dockerComposeTemplate(defaultConfig);\n   123→    const parsed = parse(result) as { services: Record<string, { labels: Record<string, string> }> };\n   124→    for (const [name, svc] of Object.entries(parsed.services)) {\n   125→      expect(svc.labels, `${name} should have shared label`).toEqual({ 'com.codeharness.stack': 'shared' });\n   126→    }\n   127→  });\n   128→});\n   129→\n   130→describe('dockerComposeCollectorOnlyTemplate', () => {\n   131→  it('returns valid YAML', () => {\n   132→    const result = dockerComposeCollectorOnlyTemplate();\n   133→    const parsed = parse(result) as Record<string, unknown>;\n   134→    expect(parsed).toBeDefined();\n   135→    expect(parsed.services).toBeDefined();\n   136→  });\n   137→\n   138→  it('contains only otel-collector service', () => {\n   139→    const result = dockerComposeCollectorOnlyTemplate();\n   140→    const parsed = parse(result) as { services: Record<string, unknown> };\n   141→    expect(Object.keys(parsed.services)).toEqual(['otel-collector']);\n   142→  });\n   143→\n   144→  it('does NOT include victoria-logs, victoria-metrics, or victoria-traces', () => {\n   145→    const result = dockerComposeCollectorOnlyTemplate();\n   146→    const parsed = parse(result) as { services: Record<string, unknown> };\n   147→    expect(parsed.services['victoria-logs']).toBeUndefined();\n   148→    expect(parsed.services['victoria-metrics']).toBeUndefined();\n   149→    expect(parsed.services['victoria-traces']).toBeUndefined();\n   150→  });\n   151→\n   152→  it('uses codeharness-collector project name', () => {\n   153→    const result = dockerComposeCollectorOnlyTemplate();\n   154→    const parsed = parse(result) as { name: string };\n   155→    expect(parsed.name).toBe('codeharness-collector');\n   156→  });\n   157→\n   158→  it('uses codeharness-collector-net network name', () => {\n   159→    const result = dockerComposeCollectorOnlyTemplate();\n   160→    const parsed = parse(result) as { networks: Record<string, { name: string }> };\n   161→    expect(parsed.networks.default.name).toBe('codeharness-collector-net');\n   162→  });\n   163→\n   164→  it('maps correct ports for otel-collector (4317, 4318)', () => {\n   165→    const result = dockerComposeCollectorOnlyTemplate();\n   166→    const parsed = parse(result) as { services: Record<string, { ports: string[] }> };\n   167→    expect(parsed.services['otel-collector'].ports).toContain('4317:4317');\n   168→    expect(parsed.services['otel-collector'].ports).toContain('4318:4318');\n   169→  });\n   170→\n   171→  it('uses same otel-collector image as full template', () => {\n   172→    const collectorOnly = parse(dockerComposeCollectorOnlyTemplate()) as { services: Record<string, { image: string }> };\n   173→    const full = parse(dockerComposeTemplate({ shared: true })) as { services: Record<string, { image: string }> };\n   174→    expect(collectorOnly.services['otel-collector'].image).toBe(full.services['otel-collector'].image);\n   175→  });\n   176→\n   177→  it('otel-collector has collector label', () => {\n   178→    const result = dockerComposeCollect