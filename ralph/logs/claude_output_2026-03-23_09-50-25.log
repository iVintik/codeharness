t',\n    48→        devDependencies: { '@vitest/coverage-v8': '^1.0.0' },\n    49→      }),\n    50→    );\n    51→\n    52→    const result = detectCoverageTool(testDir);\n    53→    expect(result.tool).toBe('c8');\n    54→  });\n    55→\n    56→  it('detects c8 from @vitest/coverage-istanbul in devDependencies', () => {\n    57→    writeFileSync(\n    58→      join(testDir, 'package.json'),\n    59→      JSON.stringify({\n    60→        name: 'test',"}]},"parent_tool_use_id":"toolu_01L8FFCpVh7KBCcfMN3fKhC4","session_id":"900ad046-8ed4-4678-b2b2-9fd66fbde286","uuid":"962c4cc8-6a2a-4b3e-8917-1b2cd4a58cea","timestamp":"2026-03-23T05:52:31.393Z"}
