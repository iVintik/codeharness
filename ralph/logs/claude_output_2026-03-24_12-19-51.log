{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ShDbiA8cahx2XqXrqJEsvb","type":"tool_result","content":"     1→/**\n     2→ * Public API for the stacks subsystem.\n     3→ */\n     4→\n     5→// Types\n     6→export type {\n     7→  StackName,\n     8→  AppType,\n     9→  CoverageToolName,\n    10→  CoverageToolInfo,\n    11→  OtlpResult,\n    12→  TestCounts,\n    13→  StackProvider,\n    14→} from './types.js';\n    15→\n    16→// Registry\n    17→export {\n    18→  registerProvider,\n    19→  getStackProvider,\n    20→  detectStack,\n    21→  detectStacks,\n    22→  type StackDetection,\n    23→  _resetRegistry,\n    24→} from './registry.js';\n    25→\n    26→// Auto-register built-in providers\n    27→import { registerProvider } from './registry.js';\n    28→import { NodejsProvider } from './nodejs.js';\n    29→import { PythonProvider } from './python.js';\n    30→\n    31→registerProvider(new NodejsProvider());\n    32→registerProvider(new PythonProvider());\n    33→"}]},"parent_tool_use_id":"toolu_01XXdV3K3gysdv7HwBLXK2M3","session_id":"e39a20db-e648-4f8f-85ec-e4fa22cf8d05","uuid":"a8ba0a3f-7217-48b9-9f27-b2c1343af24f","timestamp":"2026-03-24T08:29:09.242Z"}
