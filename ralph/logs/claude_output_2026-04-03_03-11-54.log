{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PU7g5SsBcK1x1Azd2eMLzD","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';\n2\timport { mkdtempSync, rmSync } from 'node:fs';\n3\timport { existsSync as origExistsSync, readFileSync as origReadFileSync } from 'node:fs';\n4\timport { tmpdir } from 'node:os';\n5\timport { join } from 'node:path';\n6\timport { Command } from 'commander';\n7\timport { resolvePluginDir, countStories } from '../run.js';\n8\t\n9\t// --- Hoisted mocks ---\n10\tconst {\n11\t  getDriverMock, existsSyncMock, readSprintStatusMock,\n12\t  realExistsSync, startRendererMock, rendererCleanupMock,\n13\t  getSprintStateMock, reconcileStateMock,\n14\t  isDockerAvailableMock, cleanupContainersMock,\n15\t} = vi.hoisted(() => {\n16\t  // eslint-disable-next-line @typescript-eslint/no-require-imports\n17\t  const fs = require('node:fs');\n18\t  const realFn = fs.existsSync.bind(fs);\n19\t\n20\t  const rendererCleanupMock = vi.fn();\n21\t\n22\t  return {\n23\t    getDriverMock: vi.fn(() => { throw new Error('No agent drivers available'); }),\n24\t    existsSyncMock: vi.fn(realFn),\n25\t    readSprintStatusMock: vi.fn(() => ({}) as Record<string, string>),\n26\t    realExistsSync: realFn as (path: string) => boolean,\n27\t    startRendererMock: vi.fn(() => ({\n28\t      update: vi.fn(),\n29\t      updateSprintState: vi.fn(),\n30\t      updateStories: vi.fn(),\n31\t      addMessage: vi.fn(),\n32\t      cleanup: rendererCleanupMock,\n33\t    })),\n34\t    rendererCleanupMock,\n35\t    getSprintStateMock: vi.fn((): { success: boolean; data?: Record<string, unknown>; error?: string } => ({ success: false, error: 'no state' })),\n36\t    reconcileStateMock: vi.fn(() => ({ success: true, data: { corrections: [], stateChanged: false } })),\n37\t    isDockerAvailableMock: vi.fn(() => true),\n38\t    cleanupContainersMock: vi.fn((): { success: boolean; data?: { containersRemoved: number; names: string[] }; error?: string } => ({ success: true, data: { containersRemoved: 0, names: [] } })),\n39\t  };\n40\t});\n41\t\n42\tvi.mock('../../lib/agents/index.js', () => ({\n43\t  getDriver: (...args: unknown[]) => getDriverMock(...(args as Parameters<typeof getDriverMock>)),\n44\t}));\n45\t\n46\tvi.mock('node:fs', async (importOriginal) => {\n47\t  const actual = await importOriginal<typeof import('node:fs')>();\n48\t  return { ...actual, existsSync: existsSyncMock };\n49\t});\n50\t\n51\tvi.mock('../../lib/ink-renderer.js', () => ({\n52\t  startRenderer: (...args: unknown[]) => startRendererMock(...(args as Parameters<typeof startRendererMock>)),\n53\t}));\n54\t\n55\tvi.mock('../../modules/sprint/index.js', () => ({\n56\t  getSprintState: (...args: unknown[]) => getSprintStateMock(...(args as Parameters<typeof getSprintStateMock>)),\n57\t  readSprintStatusFromState: (...args: unknown[]) => readSprintStatusMock(...(args as Parameters<typeof readSprintStatusMock>)),\n58\t  reconcileState: (...args: unknown[]) => reconcileStateMock(...(args as Parameters<typeof reconcileStateMock>)),\n59\t  updateStoryStatus: vi.fn(() => ({ success: true, data: undefined })),\n60\t  shouldDeferPhase: vi.fn(() => false),\n61\t  getPhaseEstimate: vi.fn(() => 15),\n62\t  computeRemainingMinutes: vi.fn(() => 60),\n63\t}));\n64\t\n65\tvi.mock('../../lib/docker/index.js', () => ({\n66\t  isDockerAvailable: (...args: unknown[]) => isDockerAvailableMock(...(args as Parameters<typeof isDockerAvailableMock>)),\n67\t}));\n68\t\n69\tvi.mock('../../modules/infra/index.js', () => ({\n70\t  cleanupContainers: (...args: unknown[]) => cleanupContainersMock(...(args as Parameters<typeof cleanupContainersMock>)),\n71\t}));\n72\t\n73\t\n74\tdescribe('run command', () => {\n75\t  let tmpDir: string;\n76\t\n77\t  beforeEach(() => {\n78\t    tmpDir = mkdtempSync(join(tmpdir(), 'run-test-'));\n79\t    getDriverMock.mockClear();\n80\t    existsSyncMock.mockReset();\n81\t    existsSyncMock.mockImplementation((p: unknown) => realExistsSync(String(p)));\n82\t    readSprintStatusMock.mockReset();\n83\t    readSprintStatusMock.mockReturnValue({});\n84\t    startRendererMock.mockClear();\n85\t    rendererCleanupMock.mockClear();\n86\t    getSprintStateMock.mockClear();\n87\t    getSprintStateMock.mockReturnValue({ success: false, error: 'no state' });\n88\t    reconcileStateMock.mockClear();\n89\t    reconcileStateMock.mockReturnValue({ success: true, data: { corrections: [], stateChanged: false } });\n90\t    isDockerAvailableMock.mockClear();\n91\t    isDockerAvailableMock.mockReturnValue(true);\n92\t    cleanupContainersMock.mockClear();\n93\t    cleanupContainersMock.mockReturnValue({ success: true, data: { containersRemoved: 0, names: [] } });\n94\t    process.exitCode = undefined;\n95\t  });\n96\t\n97\t  afterEach(() => {\n98\t    rmSync(tmpDir, { recursive: true, force: true });\n99\t    vi.restoreAllMocks();\n100\t    process.exitCode = undefined;\n101\t  });\n102\t\n103\t  function mockPaths(overrides: Record<string, boolean>) {\n104\t    existsSyncMock.mockImplementation((p: unknown) => {\n105\t      const path = String(p);\n106\t      for (const [pattern, value] of Object.entries(overrides)) {\n107\t        if (path.includes(pattern)) return value;\n108\t      }\n109\t      return realExistsSync(path);\n110\t    });\n111\t  }\n112\t\n113\t  async function runCommand(args: string[] = []) {\n114\t    const { registerRunCommand } = await import('../run.js');\n115\t    const program = new Command();\n116\t    program.exitOverride();\n117\t    program.option('--json', 'JSON output');\n118\t    registerRunCommand(program);\n119\t    await program.parseAsync(['node', 'codeharness', 'run', ...args]);\n120\t  }\n121\t\n122\t  describe('resolvePluginDir', () => {\n123\t    it('returns cwd/.claude', () => {\n124\t      expect(resolvePluginDir()).toBe(join(process.cwd(), '.claude'));\n125\t    });\n126\t  });\n127\t\n128\t  describe('countStories (re-export)', () => {\n129\t    it('re-exports countStories from run-helpers.ts', () => {\n130\t      const counts = countStories({ '1-1-story': 'done', '1-2-story': 'backlog' });\n131\t      expect(counts.total).toBe(2);\n132\t      expect(counts.done).toBe(1);\n133\t    });\n134\t  });\n135\t\n136\t  describe('action handler', () => {\n137\t    it('fails when plugin directory not found', async () => {\n138\t      mockPaths({ '.claude': false });\n139\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n140\t\n141\t      await runCommand();\n142\t\n143\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Plugin directory not found'));\n144\t      expect(process.exitCode).toBe(1);\n145\t    });\n146\t\n147\t    // Run command now exits early with \"temporarily unavailable\" since Ralph was removed (Story 1.2).\n148\t    // All tests that depend on driver spawn are removed — they'll return when Epic 5 rebuilds the command.\n149\t\n150\t    it('exits with temporarily unavailable message (Ralph removed)', async () => {\n151\t      mockPaths({ '.claude': true });\n152\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n153\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n154\t\n155\t      await runCommand();\n156\t\n157\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('temporarily unavailable'));\n158\t      expect(process.exitCode).toBe(1);\n159\t    });\n160\t\n161\t    it('fails when Docker is unavailable', async () => {\n162\t      mockPaths({ '.claude': true });\n163\t      isDockerAvailableMock.mockReturnValue(false);\n164\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n165\t\n166\t      await runCommand();\n167\t\n168\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Docker not available'));\n169\t      expect(process.exitCode).toBe(1);\n170\t    });\n171\t\n172\t    it('fails when no stories found in sprint state', async () => {\n173\t      mockPaths({ '.claude': true });\n174\t      readSprintStatusMock.mockReturnValue({});\n175\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n176\t\n177\t      await runCommand();\n178\t\n179\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('No stories found'));\n180\t      expect(process.exitCode).toBe(1);\n181\t    });\n182\t\n183\t    it('logs reconciliation corrections when present', async () => {\n184\t      mockPaths({ '.claude': true });\n185\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n186\t      reconcileStateMock.mockReturnValue({\n187\t        success: true,\n188\t        data: { corrections: ['Fixed story-a status'], stateChanged: true },\n189\t      });\n190\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n191\t\n192\t      await runCommand();\n193\t\n194\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Reconciled: Fixed story-a status'));\n195\t    });\n196\t\n197\t    it('warns when state reconciliation fails', async () => {\n198\t      mockPaths({ '.claude': true });\n199\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n200\t      reconcileStateMock.mockReturnValue({ success: false, error: 'state file corrupt' });\n201\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n202\t\n203\t      await runCommand();\n204\t\n205\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('State reconciliation failed'));\n206\t    });\n207\t\n208\t    it('logs container cleanup when containers removed', async () => {\n209\t      mockPaths({ '.claude': true });\n210\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n211\t      cleanupContainersMock.mockReturnValue({\n212\t        success: true,\n213\t        data: { containersRemoved: 2, names: ['harness-a', 'harness-b'] },\n214\t      });\n215\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n216\t\n217\t      await runCommand();\n218\t\n219\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Cleaned up 2 orphaned container(s)'));\n220\t    });\n221\t\n222\t    it('warns when container cleanup fails', async () => {\n223\t      mockPaths({ '.claude': true });\n224\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n225\t      cleanupContainersMock.mockReturnValue({ success: false, error: 'docker socket error' });\n226\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n227\t\n228\t      await runCommand();\n229\t\n230\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Container cleanup failed'));\n231\t    });\n232\t\n233\t    it('fails with invalid numeric option', async () => {\n234\t      mockPaths({ '.claude': true });\n235\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n236\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n237\t\n238\t      await runCommand(['--max-iterations', 'abc']);\n239\t\n240\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Invalid numeric option'));\n241\t      expect(process.exitCode).toBe(1);\n242\t    });\n243\t  });\n244\t\n245\t  describe('run command registration', () => {\n246\t    it('registers the run command with correct options', async () => {\n247\t      const { registerRunCommand } = await import('../run.js');\n248\t      const program = new Command();\n249\t      program.option('--json', 'JSON output');\n250\t      registerRunCommand(program);\n251\t\n252\t      const runCmd = program.commands.find(c => c.name() === 'run');\n253\t      expect(runCmd).toBeDefined();\n254\t      expect(runCmd!.description()).toBe('Execute the autonomous coding loop');\n255\t\n256\t      const optionNames = runCmd!.options.map(o => o.long);\n257\t      expect(optionNames).toContain('--max