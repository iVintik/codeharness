 p;\n   508→\n   509→      expect(mockDriverInstance.parseOutput).toHaveBeenCalled();\n   510→      expect(rendererUpdateMock).toHaveBeenCalledWith(textEvent);\n   511→    });\n   512→\n   513→    it('dispatches story-complete events to renderer.addMessage', async () => {\n   514→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   515→      mockPaths({ '.claude': true });\n   516→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   517→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   518→\n   519→      const storyCompleteEvent = { type: 'story-complete' as const, key: '1-1-foo', details: 'DONE — verified' };\n   520→      mockDriverInstance.parseOutput.mockReturnValueOnce(storyCompleteEvent);\n   521→\n   522→      const p = runCommand();\n   523→      await vi.waitFor(() => expect(mockDriverInstance.spawn).toHaveBeenCalled());\n   524→\n   525→      const stderr = mockDriverInstance._getStderrEmitter();\n   526→      stderr!.emit('data', Buffer.from('[SUCCESS] Story 1-1-foo: DONE — verified\\n'));\n   527→\n   528→      mockDriverInstance._getChildOnHandlers()['close'](0);\n   529→      await p;\n   530→\n   531→      expect(rendererAddMessageMock).toHaveBeenCalledWith({\n   532→        type: 'ok',\n   533→        key: '1-1-foo',\n   534→        message: 'DONE — verified',\n   535→      });\n   536→    });\n   537→\n   538→    it('dispatches story-failed events to renderer.addMessage', async () => {\n   539→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   540→      mockPaths({ '.claude': true });\n   541→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   542→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   543→\n   544→      const storyFailedEvent = { type: 'story-failed' as const, key: '2-1-bar', reason: 'exceeded retry limit' };\n   545→      mockDriverInstance.parseOutput.mockReturnValueOnce(storyFailedEvent);\n   546→\n   547→      const p = runCommand();\n   548→      await vi.waitFor(() => expect(mockDriverInstance.spawn).toHaveBeenCalled());\n   549→\n   550→      const stderr = mockDriverInstance._getStderrEmitter();\n   551→      stderr!.emit('data', Buffer.from('[WARN] Story 2-1-bar exceeded retry limit\\n'));\n   552→\n   553→      mockDriverInstance._getChildOnHandlers()['close'](0);\n   554→      await p;\n   555→\n   556→      expect(rendererAddMessageMock).toHaveBeenCalledWith({\n   557→        type: 'fail',\n   558→        key: '2-1-bar',\n   559→        message: 'exceeded retry limit',\n   560→      });\n   561→    });\n   562→\n   563→    it('dispatches iteration events to state tracker', async () => {\n   564→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   565→      mockPaths({ '.claude': true });\n   566→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   567→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   568→\n   569→      const iterationEvent = { type: 'iteration' as const, count: 5 };\n   570→      mockDriverInstance.parseOutput.mockReturnValueOnce(iterationEvent);\n   571→\n   572→      const p = runCommand();\n   573→      await vi.waitFor(() => expect(mockDriverInstance.spawn).toHaveBeenCalled());\n   574→\n   575→      const stderr = mockDriverInstance._getStderrEmitter();\n   576→      stderr!.emit('data', Buffer.from('[LOOP] iteration 5\\n'));\n   577→\n   578→      mockDriverInstance._getChildOnHandlers()['close'](0);\n   579→      await p;\n   580→\n   581→      // Iteration events don't call renderer.update or addMessage\n   582→      // They update internal state used by the polling interval\n   583→      expect(rendererUpdateMock).not.toHaveBeenCalled();\n   584→      expect(rendererAddMessageMock).not.toHaveBeenCalled();\n   585→    });\n   586→\n   587→    it('skips null events from driver.parseOutput (unrecognized lines)', async () => {\n   588→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   589→      mockPaths({ '.claude': true });\n   590→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   591→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   592→\n   593→      mockDriverInstance.parseOutput.mockReturnValue(null);\n   594→\n   595→      const p = runCommand();\n   596→      await vi.waitFor(() => expect(mockDriverInstance.spawn).toHaveBeenCalled());\n   597→\n   598→      const stdout = mockDriverInstance._getStdoutEmitter();\n   599→      stdout!.emit('data', Buffer.from('some unrecognized line\\n'));\n   600→\n   601→      mockDriverInstance._getChildOnHandlers()['close'](0);\n   602→      await p;\n   603→\n   604→      expect(mockDriverInstance.parseOutput).toHaveBeenCalled();\n   605→      expect(rendererUpdateMock).not.toHaveBeenCalled();\n   606→    });\n   607→\n   608→    it('calls renderer.cleanup on process close', async () => {\n   609→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   610→      mockPaths({ '.claude': true });\n   611→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   612→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   613→\n   614→      const p = runCommand();\n   615→      await vi.waitFor(() => expect(mockDriverInstance.spawn).toHaveBeenCalled());\n   616→      mockDriverInstance._getChildOnHandlers()['close'](0);\n   617→      await p;\n   618→\n   619→      expect(rendererCleanupMock).toHaveBeenCalledTimes(1);\n   620→    });\n   621→\n   622→    it('calls renderer.cleanup on spawn error', async () => {\n   623→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   624→      mockPaths({ '.claude': true });\n   625→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   626→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   627→\n   628→      const p = runCommand();\n   629→      await vi.waitFor(() => expect(mockDriverInstance.spawn).toHaveBeenCalled());\n   630→      mockDriverInstance._getChildOnHandlers()['error'](new Error