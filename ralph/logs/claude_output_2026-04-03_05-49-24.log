{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018hcKQFBpdJKsijbwB4N5PH","type":"tool_result","content":"1\t/**\n2\t * Issue tracker module — CRUD operations for `.codeharness/issues.yaml`.\n3\t *\n4\t * This is the write side of the issue tracker. The read side lives in\n5\t * `workflow-engine.ts` → `loadWorkItems()`.\n6\t */\n7\t\n8\timport { existsSync, readFileSync, writeFileSync, mkdirSync } from 'node:fs';\n9\timport { join } from 'node:path';\n10\timport { parse, stringify } from 'yaml';\n11\t\n12\t// ---------------------------------------------------------------------------\n13\t// Types\n14\t// ---------------------------------------------------------------------------\n15\t\n16\texport interface Issue {\n17\t  id: string;\n18\t  title: string;\n19\t  source: string;\n20\t  priority: string;\n21\t  status: string;\n22\t  created_at: string;\n23\t}\n24\t\n25\texport interface IssuesFile {\n26\t  issues: Issue[];\n27\t}\n28\t\n29\t// ---------------------------------------------------------------------------\n30\t// Constants\n31\t// ---------------------------------------------------------------------------\n32\t\n33\texport const VALID_STATUSES: ReadonlySet<string> = new Set([\n34\t  'backlog',\n35\t  'ready',\n36\t  'in-progress',\n37\t  'review',\n38\t  'verifying',\n39\t  'done',\n40\t  'failed',\n41\t  'blocked',\n42\t]);\n43\t\n44\texport const VALID_PRIORITIES: ReadonlySet<string> = new Set([\n45\t  'low',\n46\t  'medium',\n47\t  'high',\n48\t  'critical',\n49\t]);\n50\t\n51\t// ---------------------------------------------------------------------------\n52\t// Helpers\n53\t// ---------------------------------------------------------------------------\n54\t\n55\tconst ISSUES_REL_PATH = join('.codeharness', 'issues.yaml');\n56\t\n57\tfunction issuesPath(dir: string): string {\n58\t  return join(dir, ISSUES_REL_PATH);\n59\t}\n60\t\n61\t// ---------------------------------------------------------------------------\n62\t// Core functions\n63\t// ---------------------------------------------------------------------------\n64\t\n65\t/**\n66\t * Read issues from `.codeharness/issues.yaml`.\n67\t * Returns `{ issues: [] }` if the file does not exist.\n68\t */\n69\texport function readIssues(dir: string = process.cwd()): IssuesFile {\n70\t  const filePath = issuesPath(dir);\n71\t  if (!existsSync(filePath)) {\n72\t    return { issues: [] };\n73\t  }\n74\t\n75\t  const raw = readFileSync(filePath, 'utf-8');\n76\t  const parsed = parse(raw) as Record<string, unknown> | null;\n77\t\n78\t  if (!parsed || !Array.isArray(parsed.issues)) {\n79\t    return { issues: [] };\n80\t  }\n81\t\n82\t  return { issues: parsed.issues as Issue[] };\n83\t}\n84\t\n85\t/**\n86\t * Write issues to `.codeharness/issues.yaml`.\n87\t * Creates the `.codeharness/` directory if it does not exist.\n88\t */\n89\texport function writeIssues(data: IssuesFile, dir: string = process.cwd()): void {\n90\t  const filePath = issuesPath(dir);\n91\t  const dirPath = join(dir, '.codeharness');\n92\t\n93\t  if (!existsSync(dirPath)) {\n94\t    mkdirSync(dirPath, { recursive: true });\n95\t  }\n96\t\n97\t  writeFileSync(filePath, stringify(data, { nullStr: '' }), 'utf-8');\n98\t}\n99\t\n100\t/**\n101\t * Generate the next sequential issue ID from existing issues.\n102\t * Format: `issue-NNN` (zero-padded 3 digits). Starts at `issue-001`.\n103\t */\n104\texport function nextIssueId(existing: Issue[]): string {\n105\t  let max = 0;\n106\t  for (const issue of existing) {\n107\t    const match = issue.id.match(/^issue-(\\d+)$/);\n108\t    if (match) {\n109\t      const num = parseInt(match[1], 10);\n110\t      if (num > max) max = num;\n111\t    }\n112\t  }\n113\t  return `issue-${String(max + 1).padStart(3, '0')}`;\n114\t}\n115\t\n116\t/**\n117\t * Create a new issue and persist it to `.codeharness/issues.yaml`.\n118\t */\n119\texport function createIssue(\n120\t  title: string,\n121\t  options?: { priority?: string; source?: string },\n122\t  dir?: string,\n123\t): Issue {\n124\t  const baseDir = dir ?? process.cwd();\n125\t  const data = readIssues(baseDir);\n126\t\n127\t  const issue: Issue = {\n128\t    id: nextIssueId(data.issues),\n129\t    title,\n130\t    source: options?.source ?? 'manual',\n131\t    priority: options?.priority ?? 'medium',\n132\t    status: 'backlog',\n133\t    created_at: new Date().toISOString(),\n134\t  };\n135\t\n136\t  data.issues.push(issue);\n137\t  writeIssues(data, baseDir);\n138\t\n139\t  return issue;\n140\t}\n141\t\n142\t/**\n143\t * Close an issue by setting its status to `done`.\n144\t * Throws if the issue ID is not found.\n145\t */\n146\texport function closeIssue(id: string, dir?: string): Issue {\n147\t  const baseDir = dir ?? process.cwd();\n148\t  const data = readIssues(baseDir);\n149\t\n150\t  const issue = data.issues.find((i) => i.id === id);\n151\t  if (!issue) {\n152\t    throw new Error(`Issue '${id}' not found`);\n153\t  }\n154\t\n155\t  issue.status = 'done';\n156\t  writeIssues(data, baseDir);\n157\t\n158\t  return issue;\n159\t}\n160\t"}]},"parent_tool_use_id":"toolu_01CMZbq8RrvXCKSwd18t2Hto","session_id":"2800a04b-8151-4215-bf66-1f43973b9365","uuid":"8479d651-d5ba-4e37-b38c-5b742ba64505","timestamp":"2026-04-03T02:00:56.106Z"}
