{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JPjePtFjbH6J7bQJX3iygu","type":"tool_result","content":"596\t  });\n597\t\n598\t  describe('--workflow option (Story 9.2)', () => {\n599\t    it('passes --workflow name and cwd to resolveWorkflow', async () => {\n600\t      mockPaths({ '.claude': true });\n601\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n602\t      vi.spyOn(console, 'log').mockImplementation(() => {});\n603\t\n604\t      await runCommand(['--workflow', 'my-workflow']);\n605\t\n606\t      expect(resolveWorkflowMock).toHaveBeenCalledWith(\n607\t        expect.objectContaining({ name: 'my-workflow', cwd: expect.any(String) }),\n608\t      );\n609\t    });\n610\t\n611\t    it('defaults to \"default\" when --workflow is not specified', async () => {\n612\t      mockPaths({ '.claude': true });\n613\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n614\t      vi.spyOn(console, 'log').mockImplementation(() => {});\n615\t\n616\t      await runCommand();\n617\t\n618\t      expect(resolveWorkflowMock).toHaveBeenCalledWith(\n619\t        expect.objectContaining({ name: 'default' }),\n620\t      );\n621\t    });\n622\t\n623\t    it('exits 1 with clear error when custom workflow not found (no fallback)', async () => {\n624\t      mockPaths({ '.claude': true });\n625\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n626\t      resolveWorkflowMock.mockImplementation(() => {\n627\t        throw new Error('Embedded workflow not found: my-workflow');\n628\t      });\n629\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n630\t\n631\t      await runCommand(['--workflow', 'my-workflow']);\n632\t\n633\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Failed to resolve workflow'));\n634\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('my-workflow'));\n635\t      expect(process.exitCode).toBe(1);\n636\t      // Should NOT attempt fallback for non-default workflows\n637\t      expect(parseWorkflowMock).not.toHaveBeenCalled();\n638\t    });\n639\t\n640\t    it('rejects workflow names with path traversal characters', async () => {\n641\t      mockPaths({ '.claude': true });\n642\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n643\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n644\t\n645\t      await runCommand(['--workflow', '../../../etc/passwd']);\n646\t\n647\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Invalid workflow name'));\n648\t      expect(process.exitCode).toBe(1);\n649\t      expect(resolveWorkflowMock).not.toHaveBeenCalled();\n650\t    });\n651\t\n652\t    it('rejects workflow names with slashes', async () => {\n653\t      mockPaths({ '.claude': true });\n654\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n655\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n656\t\n657\t      await runCommand(['--workflow', 'foo/bar']);\n658\t\n659\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Invalid workflow name'));\n660\t      expect(process.exitCode).toBe(1);\n661\t    });\n662\t\n663\t    it('rejects workflow names with dots', async () => {\n664\t      mockPaths({ '.claude': true });\n665\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n666\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n667\t\n668\t      await runCommand(['--workflow', 'my.workflow']);\n669\t\n670\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Invalid workflow name'));\n671\t      expect(process.exitCode).toBe(1);\n672\t    });\n673\t\n674\t    it('accepts valid workflow names with hyphens and underscores', async () => {\n675\t      mockPaths({ '.claude': true });\n676\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\