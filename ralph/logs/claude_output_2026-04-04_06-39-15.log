{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DXUi7Jt4j2ubAaDeceCNbJ","type":"tool_result","content":"1\t/**\n2\t * Ink UI components — types and layout components (Header, Separator, StoryBreakdown).\n3\t *\n4\t * Renders a UX-spec-compliant live display with plain text header,\n5\t * ━━━ separators, and labeled story breakdown sections.\n6\t * Activity components (tools, thoughts, retry) are in ink-activity-components.tsx.\n7\t * The App root component is in ink-app.tsx to avoid circular imports.\n8\t */\n9\t\n10\timport React from 'react';\n11\timport { Text, Box } from 'ink';\n12\timport type { FlowStep } from './workflow-parser.js';\n13\t\n14\t// --- Types ---\n15\t\n16\texport interface SprintInfo {\n17\t  storyKey: string;\n18\t  phase: string;\n19\t  done: number;\n20\t  total: number;\n21\t  elapsed?: string;\n22\t  iterationCount?: number;\n23\t  totalCost?: number;\n24\t  acProgress?: string;\n25\t  currentCommand?: string;\n26\t  /** Number of active lanes (multi-lane mode). */\n27\t  laneCount?: number;\n28\t  /** Total cost across all lanes (multi-lane mode). */\n29\t  laneTotalCost?: number;\n30\t}\n31\t\n32\texport interface CompletedToolEntry {\n33\t  name: string;\n34\t  args: string;\n35\t  driver?: string;\n36\t}\n37\t\n38\texport type StoryStatusValue = 'done' | 'in-progress' | 'pending' | 'failed' | 'blocked';\n39\t\n40\texport interface StoryStatusEntry {\n41\t  key: string;\n42\t  status: StoryStatusValue;\n43\t  retryCount?: number;\n44\t  maxRetries?: number;\n45\t  costByDriver?: Record<string, number>;\n46\t}\n47\t\n48\texport interface RetryInfo {\n49\t  attempt: number;\n50\t  delay: number;"}]},"parent_tool_use_id":"toolu_016YmompPGLedJ48VB5GP3sv","session_id":"7e3ded59-6184-4f8b-8f55-ba5e63dae51f","uuid":"7e0df9de-7a34-419d-9b1b-e207b9c86763","timestamp":"2026-04-04T02:42:54.863Z"}
