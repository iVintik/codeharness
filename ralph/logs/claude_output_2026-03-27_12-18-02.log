{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LLqbo6cQXxNWn4vukwgdoH","type":"tool_result","content":"     1→/**\n     2→ * Stack provider types — the canonical location for all stack-related type definitions.\n     3→ *\n     4→ * All consumers import from `src/lib/stacks/index.ts`. The legacy `stack-detect.ts`\n     5→ * module was deleted in story 10-5.\n     6→ */\n     7→\n     8→/** Supported language stacks. */\n     9→export type StackName = 'nodejs' | 'python' | 'rust';\n    10→\n    11→/** Application archetype detected from project structure and dependencies. */\n    12→export type AppType = 'server' | 'cli' | 'web' | 'agent' | 'generic';\n    13→\n    14→/** Coverage tool identifiers. */\n    15→export type CoverageToolName = 'c8' | 'nyc' | 'istanbul' | 'coverage-py' | 'tarpaulin' | 'llvm-cov' | 'none';\n    16→\n    17→/** Coverage tool configuration detected in a project. */\n    18→export interface CoverageToolInfo {\n    19→  tool: CoverageToolName;\n    20→  configFile?: string;\n    21→}\n    22→\n    23→/** Result of an OTLP instrumentation installation. */\n    24→export interface OtlpResult {\n    25→  success: boolean;\n    26→  packagesInstalled: string[];\n    27→  error?: string;\n    28→}\n    29→\n    30→/** Parsed test execution counts. */\n    31→export interface TestCounts {\n    32→  passed: number;\n    33→  failed: number;\n    34→  skipped: number;\n    35→  total: number;\n    36→}\n    37→\n    38→/**\n    39→ * The StackProvider interface encapsulates all language-specific behavior.\n    40→ * Adding a new language requires only implementing this interface in a single file.\n    41→ */\n    42→export interface StackProvider {\n    43→  /** Canonical stack identifier. */\n    44→  readonly name: StackName;\n    45→\n    46→  /** Marker files whose presence indicates this stack (e.g. `['package.json']`). */\n    47→  readonly markers: string[];\n    48→\n    49→  /** Human-readable label (e.g. `'Node.js (package.json)'`). */\n    50→  readonly displayName: string;\n    51→\n    52→  /** Detect the application archetype for a project directory. */\n    53→  detectAppType(dir: string): AppType;\n    54→\n    55→  /** Return the preferred coverage tool for this stack. */\n    56→  getCoverageTool(): CoverageToolName;\n    57→\n    58→  /** Detect existing coverage configuration in a directory. */\n    59→  detectCoverageConfig(dir: string): CoverageToolInfo;\n    60→\n    61→  /** Return the list of OTLP packages to install. */\n    62→  getOtlpPackages(): string[];\n    63→\n    64→  /** Install OTLP instrumentation into a project directory. */\n    65→  installOtlp(dir: string): OtlpResult;\n    66→\n    67→  /** Optional: patch the start script for OTLP instrumentation. */\n    68→  patchStartScript?(dir: string): boolean;\n    69→\n    70→  /** Return the Dockerfile template name for this stack. */\n    71→  getDockerfileTemplate(): string;\n    72→\n    73→  /** Return the Docker build stage snippet. */\n    74→  getDockerBuildStage(): string;\n    75→\n    76→  /** Return the runtime COPY directives for Dockerfile. */\n    77→  getRuntimeCopyDirectives(): string;\n    78→\n    79→  /** Return build commands for this stack. */\n    80→  getBuildCommands(): string[];\n    81→\n    82→  /** Return test commands for this stack. */\n    83→  getTestCommands(): string[];\n    84→\n    85→  /** Return Semgrep language identifiers for this stack. */\n    86→  getSemgrepLanguages(): string[];\n    87→\n    88→  /** Parse test runner output into counts. */\n    89→  parseTestOutput(output: string): TestCounts;\n    90→\n    91→  /** Parse a coverage report and return the coverage percentage. */\n    92→  parseCoverageReport(dir: string): number;\n    93→\n    94→  /** Extract the project name from the project directory, or null if undetermined. */\n    95→  getProjectName(dir: string): string | null;\n    96→\n    97→  /** Return Dockerfile snippet for verification environment tooling. */\n    98→  getVerifyDockerfileSection(projectDir: string): string;\n    99→}\n   100→"}]},"parent_tool_use_id":"toolu_012E2YPwx3Sod1tV3vRcBSTR","session_id":"748192fa-914a-4111-a5b7-9f2d46c0c1e7","uuid":"ca97196c-a0af-40c2-a475-22e09285ccd4","timestamp":"2026-03-27T08:24:47.276Z"}
