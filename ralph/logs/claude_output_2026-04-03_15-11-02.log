{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EY6R4oTAfuAQ6Kuhjm1Urj","type":"tool_result","content":"1\timport { describe, it, expect, afterEach, vi } from 'vitest';\n2\timport { render } from 'ink-testing-library';\n3\timport React from 'react';\n4\timport { startRenderer } from '../ink-renderer.js';\n5\timport type { RendererHandle } from '../ink-renderer.js';\n6\timport type { StreamEvent } from '../agents/stream-parser.js';\n7\timport {\n8\t  App,\n9\t  Header,\n10\t  Separator,\n11\t  CompletedTool,\n12\t  ActiveTool,\n13\t  LastThought,\n14\t  RetryNotice,\n15\t  StoryBreakdown,\n16\t  StoryMessageLine,\n17\t  type RendererState,\n18\t  type SprintInfo,\n19\t  type CompletedToolEntry,\n20\t  type StoryStatusEntry,\n21\t  type StoryMessage,\n22\t} from '../ink-components.js';\n23\t\n24\t// --- Helpers ---\n25\t\n26\tfunction makeState(overrides?: Partial<RendererState>): RendererState {\n27\t  return {\n28\t    sprintInfo: null,\n29\t    stories: [],\n30\t    messages: [],\n31\t    completedTools: [],\n32\t    activeTool: null,\n33\t    activeToolArgs: '',\n34\t    lastThought: null,\n35\t    retryInfo: null,\n36\t    ...overrides,\n37\t  };\n38\t}\n39\t\n40\t// --- Component Tests (using ink-testing-library) ---\n41\t\n42\tdescribe('Header component', () => {\n43\t  it('renders plain text header line (no Box border, no diamond prefix)', () => {\n44\t    const info: SprintInfo = {\n45\t      storyKey: '0-5-3',\n46\t      phase: 'dev',\n47\t      done: 3,\n48\t      total: 10,\n49\t      iterationCount: 2,\n50\t      totalCost: 5.50,\n51\t    };\n52\t    const { lastFrame } = render(<Header info={info} />);\n53\t    const frame = lastFrame()!;\n54\t    // AC1: plain text header, NO Box border, NO diamond prefix\n55\t    expect(frame).toContain('codeharness run');\n56\t    expect(frame).toContain('iteration 2');\n57\t    expect(frame).toContain('$5.50 spent');\n58\t    expect(frame).not.toContain('◆');\n59\t    expect(frame).not.toContain('│'); // No Ink Box border character\n60\t    // AC3: Story and Phase on separate lines\n61\t    expect(frame).toContain('Story: 0-5-3');\n62\t    expect(frame).toContain('Phase: dev');\n63\t  });\n64\t\n65\t  it('renders separator line with heavy bars', () => {\n66\t    const info: SprintInfo = {\n67\t      storyKey: '1-1',\n68\t      phase: 'dev',\n69\t      done: 0,\n70\t      total: 5,\n71\t    };\n72\t    const { lastFrame } = render(<Header info={info} />);\n73\t    const frame = lastFrame()!;\n74\t    // AC2: separator line\n75\t    expect(frame).toContain('━━━');\n76\t  });\n77\t\n78\t  it('renders nothing when info is null', () => {\n79\t    const { lastFrame } = render(<Header info={null} />);\n80\t    expect(lastFrame()).toBe('');"}]},"parent_tool_use_id":"toolu_01FmqjNRa8DGzh51kkVTD2Pe","session_id":"1d40f54a-b143-44f0-8247-609f8fc4c105","uuid":"d33dff91-1a5e-4e55-8094-807b2c28c2d6","timestamp":"2026-04-03T11:17:11.390Z"}
