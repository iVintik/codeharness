rateAgentsMdContent(opts.projectDir, stackArg);\n   255→      generateFile(agentsMdPath, content);\n   256→      agentsMd = 'created';\n   257→    } else {\n   258→      agentsMd = 'exists';\n   259→    }\n   260→\n   261→    // docs/ scaffold\n   262→    const docsDir = join(opts.projectDir, 'docs');\n   263→    if (!existsSync(docsDir)) {\n   264→      generateFile(join(docsDir, 'index.md'), generateDocsIndexContent());\n   265→      generateFile(join(docsDir, 'exec-plans', 'active', '.gitkeep'), '');\n   266→      generateFile(join(docsDir, 'exec-plans', 'completed', '.gitkeep'), '');\n   267→      generateFile(join(docsDir, 'quality', '.gitkeep'), DO_NOT_EDIT_HEADER);\n   268→      generateFile(join(docsDir, 'generated', '.gitkeep'), DO_NOT_EDIT_HEADER);\n   269→      docsScaffold = 'created';\n   270→    } else {\n   271→      docsScaffold = 'exists';\n   272→    }\n   273→\n   274→    // README.md\n   275→    const readmePath = join(opts.projectDir, 'README.md');\n   276→    if (!existsSync(readmePath)) {\n   277→      let cliHelpOutput = '';\n   278→      try {\n   279→        const { execFileSync } = await import('node:child_process');\n   280→        cliHelpOutput = execFileSync(process.execPath, [process.argv[1], '--help'], {\n   281→          stdio: 'pipe',\n   282→          timeout: 10_000,\n   283→        }).toString();\n   284→      } catch {\n   285→        cliHelpOutput = 'Run: codeharness --help';\n   286→      }\n   287→\n   288→      const readmeStack = opts.stacks && opts.stacks.length > 1\n   289→        ? opts.stacks.map(s => s.stack)\n   290→        : opts.stack;\n   291→      const readmeContent = readmeTemplate({\n   292→        projectName: getProjectName(opts.projectDir),\n   293→        stack: readmeStack,\n   294→        cliHelpOutput,\n   295→      });\n   296→      generateFile(readmePath, readmeContent);\n   297→      readme = 'created';\n   298→    } else {\n   299→      readme = 'exists';\n   300→    }\n   301→\n   302→    const result: InitDocumentationResult = { agents_md: agentsMd, docs_scaffold: docsScaffold, readme };\n   303→\n   304→    if (!opts.isJson) {\n   305→      if (result.agents_md === 'created' || result.docs_scaffold === 'created') {\n   306→        okOutput('Documentation: AGENTS.md + docs/ scaffold created');\n   307→      }\n   308→      if (result.readme === 'created') {\n   309→        okOutput('Documentation: README.md created');\n   310→      }\n   311→    }\n   312→\n   313→    return ok(result);\n   314→  } catch (err) {\n   315→    const message = err instanceof Error ? err.message : String(err);\n   316→    return fail(`Documentation scaffold failed: ${message}`);\n   317→  }\n   318→}\n   319→"}]},"parent_tool_use_id":"toolu_01KYHNjFyPBqtp8DZjE8JmLf","session_id":"1d547185-a995-481d-9659-9279ed70f717","uuid":"52a0f566-2eee-44af-83c0-20405d694d05","timestamp":"2026-03-24T09:12:25.622Z"}
