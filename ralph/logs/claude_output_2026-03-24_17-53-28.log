{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NuW59wjPjubLpqMhbEiaTP","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { selectNextStory, MAX_STORY_ATTEMPTS } from '../selector.js';\n     3→import type { SprintState, StoryState } from '../../../types/state.js';\n     4→\n     5→/** Helper: build a minimal SprintState with given stories */\n     6→function makeState(\n     7→  stories: Record<string, Partial<StoryState>>,\n     8→): SprintState {\n     9→  const full: Record<string, StoryState> = {};\n    10→  for (const [key, partial] of Object.entries(stories)) {\n    11→    full[key] = {\n    12→      status: 'backlog', attempts: 0, lastAttempt: null,\n    13→      lastError: null, proofPath: null, acResults: null,\n    14→      ...partial,\n    15→    };\n    16→  }\n    17→  return {\n    18→    version: 2,\n    19→    sprint: { total: 0, done: 0, failed: 0, blocked: 0, inProgress: null },\n    20→    stories: full,\n    21→    retries: {},\n    22→    flagged: [],\n    23→    epics: {},\n    24→    session: { active: false, startedAt: null, iteration: 0, elapsedSeconds: 0 },\n    25→    observability: { statementCoverage: null, branchCoverage: null, functionCoverage: null, lineCoverage: null },\n    26→    run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n    27→    actionItems: [],\n    28→  };\n    29→}\n    30→\n    31→/** Helper: build a bad state that throws on stories access */\n    32→function makeBadState(throwValue: unknown): SprintState {\n    33→  return {\n    34→    version: 2,\n    35→    sprint: { total: 0, done: 0, failed: 0, blocked: 0, inProgress: null },\n    36→    get stories() { throw throwValue; },\n    37→    retries: {},\n    38→    flagged: [],\n    39→    epics: {},\n    40→    session: { active: false, startedAt: null, iteration: 0, elapsedSeconds: 0 },\n    41→    observability: { statementCoverage: null, branchCoverage: null, functionCoverage: null, lineCoverage: null },\n    42→    run: { active: false, startedAt: null, iteration: 0, cost: 0, completed: [], failed: [], currentStory: null, currentPhase: null, lastAction: null, acProgress: null },\n    43→    actionItems: [],\n    44→  } as unknown as SprintState;\n    45→}\n    46→\n    47→describe('selectNextStory', () => {\n    48→  it('returns ok with null selected when stories map is empty', () => {\n    49→    const result = selectNextStory(makeState({}));\n    50→    expect(result.success).toBe(true);\n    51→    if (result.success) {\n    52→      expect(result.data.selected).toBeNull();\n    53→      expect(result.data.retryExhausted).toEqual([]);\n    54→    }\n    55→  });\n    56→\n    57→  it('returns ok with null selected when all stories are terminal', () => {\n    58→    const state = makeState({\n    59→      'story-a': { status: 'done' },\n    60→      'story-b': { status: 'failed' },\n    61→      'story-c': { status: 'blocked' },\n    62→    });\n    63→    const result = selectNextStory(state);\n    64→    expect(result.success).toBe(true);\n    65→    if (result.success) {\n    66→      expect(result.data.selected).toBeNull();\n    67→      expect(result.data.retryExhausted).toEqual([]);\n    68→    }\n    69→  });\n    70→\n    71→  it('reports retry-exhausted stories in retryExhausted array', () => {\n    72→    const state = makeState({\n    73→      'story-a': { status: 'backlog', attempts: 10 },\n    74→      'story-b': { status: 'backlog', attempts: 15 },\n    75→    });\n    76→    const result = selectNextStory(state);\n    77→    expect(result.success).toBe(true);\n    78→    if (result.success) {\n    79→      expect(result.data.selected).toBeNull();\n    80→      expect(result.data.retryExhausted).toHaveLength(2);"}]},"parent_tool_use_id":"toolu_01ApBdeVdWe8XvBt2HXWCWHK","session_id":"fecf2c57-a859-44f9-9426-67d9679