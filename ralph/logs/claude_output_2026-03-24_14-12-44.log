{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Pjt5HanVy67JDpz7zSxKHE","type":"tool_result","content":"     1→import { existsSync, readFileSync, writeFileSync } from 'node:fs';\n     2→import { join } from 'node:path';\n     3→import { warn } from './output.js';\n     4→\n     5→const RETRIES_FILE = '.story_retries';\n     6→const FLAGGED_FILE = '.flagged_stories';\n     7→\n     8→const LINE_PATTERN = /^([^=]+)=(\\d+)$/;\n     9→\n    10→export function retriesPath(dir: string): string {\n    11→  return join(dir, RETRIES_FILE);\n    12→}\n    13→\n    14→export function flaggedPath(dir: string): string {\n    15→  return join(dir, FLAGGED_FILE);\n    16→}\n    17→\n    18→/**\n    19→ * Parse `.story_retries` into a Map<storyKey, retryCount>.\n    20→ * Lines not matching `{key}={count}` are ignored with a warning.\n    21→ */\n    22→export function readRetries(dir: string): Map<string, number> {\n    23→  const filePath = retriesPath(dir);\n    24→  if (!existsSync(filePath)) {\n    25→    return new Map();\n    26→  }\n    27→\n    28→  const raw = readFileSync(filePath, 'utf-8');\n    29→  const result = new Map<string, number>();\n    30→\n    31→  for (const line of raw.split('\\n')) {\n    32→    const trimmed = line.trim();\n    33→    if (trimmed === '') continue;\n    34→\n    35→    const match = LINE_PATTERN.exec(trimmed);\n    36→    if (!match) {\n    37→      warn(`Ignoring malformed retry line: ${trimmed}`);\n    38→      continue;\n    39→    }\n    40→\n    41→    const key = match[1];\n    42→    const count = parseInt(match[2], 10);\n    43→    // Last occurrence wins (deduplication on read)\n    44→    result.set(key, count);\n    45→  }\n    46→\n    47→  return result;\n    48→}\n    49→\n    50→/**\n    51→ * Write retries map to `.story_retries` in strict `key=count` format.\n    52→ * Deduplicates by nature of Map.\n    53→ */\n    54→export function writeRetries(dir: string, retries: Map<string, number>): void {\n    55→  const filePath = retriesPath(dir);\n    56→  const lines: string[] = [];\n    57→\n    58→  for (const [key, count] of retries) {\n    59→    lines.push(`${key}=${count}`);\n    60→  }\n    61→\n    62→  writeFileSync(filePath, lines.length > 0 ? lines.join('\\n') + '\\n' : '', 'utf-8');\n    63→}\n    64→\n    65→/**\n    66→ * Get retry count for a single story. Returns 0 if not found.\n    67→ */\n    68→export function getRetryCount(dir: string, storyKey: string): number {\n    69→  const retries = readRetries(dir);\n    70→  return retries.get(storyKey) ?? 0;\n    71→}\n    72→\n    73→/**\n    74→ * Set retry count for a single story. Deduplicates automatically.\n    75→ */\n    76→export function setRetryCount(dir: string, storyKey: string, count: number): void {\n    77→  const retries = readRetries(dir);\n    78→  retries.set(storyKey, count);\n    79→  writeRetries(dir, retries);\n    80→}\n    81→\n    82→/**\n    83→ * Reset retry state. If storyKey is provided, removes only that entry.\n    84→ * Otherwise clears all entries. Also clears flagged stories accordingly.\n    85→ */\n    86→export function resetRetry(dir: string, storyKey?: string): void {\n    87→  if (storyKey) {\n    88→    const retries = readRetries(dir);\n    89→    retries.delete(storyKey);\n    90→    writeRetries(dir, retries);\n    91→    removeFlaggedStory(dir, storyKey);\n    92→  } else {\n    93→    writeRetries(dir, new Map());\n    94→    writeFlaggedStories(dir, []);\n    95→  }\n    96→}\n    97→\n    98→/**\n    99→ * Read `.flagged_stories` — one story key per line.\n   100→ */\n   101→export function readFlaggedStories(dir: string): string[] {\n   102→  const filePath = flaggedPath(dir);\n   103→  if (!existsSync(filePath)) {\n   104→    return [];\n   105→  }\n   106→\n   107→  const raw = readFileSync(filePath, 'utf-8');\n   108→  return raw\n   109→    .split('\\n')\n   110→    .map(l => l.trim())\n   111→    .filter(l => l !== '');\n   112→}\n   113→\n   114→/**\n   115→ * Write flagged stories list to file.\n   116→ */\n   117→export function writeFlaggedStories(dir: string, stories: string[]): void {\n   118→  const filePath = flaggedPath(dir);\n   119→  writeFileSync(filePath, stories.length > 0 ? stories.join('\\n') + '\\n' : '', 'utf-8');\n   120→}\n   121→\n   122→/**\n   123→ * Remove a single story from `.flagged_stories`.\n   124→ */\n   125→export function removeFlaggedStory(dir: string, key: string): void {\n   126→  const stories = readFlaggedStories(dir);\n   127→  const filtered = stories.filter(s => s !== key);\n   128→  writeFlaggedStories(dir, filtered);\n   129→}\n   130→"}]},"parent_tool_use_id":"toolu_01VDEDGGGLstVGgA3jxfk8Nj","session_id":"6707468c-554d-4568-9ea5-0d04d4a85f59","uuid":"8692a0ab-67b3-4b83-bf7f-aef77033c2f6","timestamp":"2026-03-24T10:17:32.027Z"}
