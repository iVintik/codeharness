{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WuMHrmr4F81KwunUJM8pui","type":"tool_result","content":"1\t{\n2\t  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n3\t  \"$id\": \"https://codeharness.dev/schemas/workflow.schema.json\",\n4\t  \"title\": \"Codeharness Workflow\",\n5\t  \"description\": \"Schema for codeharness workflow YAML files\",\n6\t  \"type\": \"object\",\n7\t  \"required\": [\"tasks\"],\n8\t  \"properties\": {\n9\t    \"tasks\": {\n10\t      \"type\": \"object\",\n11\t      \"description\": \"Named task definitions\",\n12\t      \"additionalProperties\": {\n13\t        \"$ref\": \"#/definitions/task\"\n14\t      }\n15\t    },\n16\t    \"flow\": {\n17\t      \"$ref\": \"#/definitions/flowArray\",\n18\t      \"description\": \"Ordered execution steps — task references or loop blocks (legacy; prefer story_flow)\"\n19\t    },\n20\t    \"story_flow\": {\n21\t      \"$ref\": \"#/definitions/flowArray\",\n22\t      \"description\": \"Story-level execution flow — task references or loop blocks\"\n23\t    },\n24\t    \"epic_flow\": {\n25\t      \"$ref\": \"#/definitions/flowArray\",\n26\t      \"description\": \"Epic-level execution flow — task references or loop blocks (supports built-in refs: merge, validate)\"\n27\t    },\n28\t    \"execution\": {\n29\t      \"$ref\": \"#/definitions/execution\",\n30\t      \"description\": \"Execution configuration for parallel and isolation settings\"\n31\t    }\n32\t  },\n33\t  \"additionalProperties\": false,\n34\t  \"definitions\": {\n35\t    \"flowArray\": {\n36\t      \"type\": \"array\",\n37\t      \"items\": {\n38\t        \"oneOf\": [\n39\t          {\n40\t            \"type\": \"string\",\n41\t            \"description\": \"Task reference by name\"\n42\t          },\n43\t          {\n44\t            \"type\": \"object\",\n45\t            \"required\": [\"loop\"],\n46\t            \"properties\": {\n47\t              \"loop\": {\n48\t                \"type\": \"array\",\n49\t                \"items\": {\n50\t                  \"type\": \"string\"\n51\t                },\n52\t                \"minItems\": 1,\n53\t                \"description\": \"Task names to repeat in a loop\"\n54\t              }\n55\t            },\n56\t            \"additionalProperties\": false,\n57\t            \"description\": \"Loop block containing task references\"\n58\t          }\n59\t        ]\n60\t      }\n61\t    },\n62\t    \"execution\": {\n63\t      \"type\": \"object\",\n64\t      \"properties\": {\n65\t        \"max_parallel\": {\n66\t          \"type\": \"integer\",\n67\t          \"default\": 1,\n68\t          \"minimum\": 1,\n69\t          \"description\": \"Maximum number of parallel executions\"\n70\t        },\n71\t        \"isolation\": {\n72\t          \"type\": \"string\",\n73\t          \"enum\": [\"worktree\", \"none\"],\n74\t          \"default\": \"none\",\n75\t          \"description\": \"Isolation strategy — worktree or none\"\n76\t        },\n77\t        \"merge_strategy\": {\n78\t          \"type\": \"string\",\n79\t          \"enum\": [\"rebase\", \"merge-commit\"],\n80\t          \"default\": \"merge-commit\",\n81\t          \"description\": \"Merge strategy for parallel work\"\n82\t        },\n83\t        \"epic_strategy\": {\n84\t          \"type\": \"string\",\n85\t          \"enum\": [\"parallel\", \"sequential\"],\n86\t          \"default\": \"sequential\",\n87\t          \"description\": \"Epic execution strategy — parallel or sequential\"\n88\t        },\n89\t        \"story_strategy\": {\n90\t          \"type\": \"string\",\n91\t          \"enum\": [\"sequential\", \"parallel\"],\n92\t          \"default\": \"sequential\",\n93\t          \"description\": \"Story execution strategy — sequential or parallel\"\n94\t        }\n95\t      },\n96\t      \"additionalProperties\": false\n97\t    },\n98\t    \"task\": {\n99\t      \"type\": \"object\",\n100\t      \"required\": [\"agent\"],\n101\t      \"properties\": {\n102\t        \"agent\": {\n103\t          \"oneOf\": [\n104\t            { \"type\": \"string\" },\n105\t            { \"type\": \"null\" }\n106\t          ],\n107\t          \"description\": \"Agent identifier for this task (null for engine-handled tasks)\"\n108\t        },\n109\t        \"scope\": {\n110\t          \"type\": \"string\",\n111\t          \"enum\": [\"per-story\", \"per-run\", \"per-epic\"],\n112\t          \"default\": \"per-story\",\n113\t          \"description\": \"Execution scope — per-story, per-run, or per-epic\"\n114\t        },\n115\t        \"session\": {\n116\t          \"type\": \"string\",\n117\t          \"enum\": [\"fresh\", \"continue\"],\n118\t          \"default\": \"fresh\",\n119\t          \"description\": \"Session strategy — fresh or continue\"\n120\t        },\n121\t        \"source_access\": {\n122\t          \"type\": \"boolean\",\n123\t          \"default\": true,\n124\t          \"description\": \"Whether the agent has source code access\"\n125\t        },\n126\t        \"prompt_template\": {\n127\t          \"type\": \"string\",\n128\t          \"description\": \"Prompt template with {{variable}} placeholders\"\n129\t        },\n130\t        \"input_contract\": {\n131\t          \"type\": \"object\",\n132\t          \"description\": \"Input contract schema for this task\"\n133\t        },\n134\t        \"output_contract\": {\n135\t          \"type\": \"object\",\n136\t          \"description\": \"Output contract schema for this task\"\n137\t        },\n138\t        \"max_budget_usd\": {\n139\t          \"type\": \"number\",\n140\t          \"description\": \"Maximum budget in USD for this task execution\"\n141\t        },\n142\t        \"driver\": {\n143\t          \"type\": \"string\",\n144\t          \"description\": \"Agent driver framework (e.g., claude-code, codex, opencode)\"\n145\t        },\n146\t        \"model\": {\n147\t          \"type\": \"string\",\n148\t          \"description\": \"Model override for this task (falls through to resolution chain if omitted)\"\n149\t        },\n150\t        \"plugins\": {\n151\t          \"type\": \"array\",\n152\t          \"items\": { \"type\": \"string\" },\n153\t          \"description\": \"Plugin names to load in the driver session\"\n154\t        }\n155\t      },\n156\t      \"additionalProperties\": false\n157\t    }\n158\t  }\n159\t}\n160\t"}]},"parent_tool_use_id":"toolu_01EbWLuRzBfXxKEeXQE4hLnQ","session_id":"9c9fe147-c536-4d36-9f64-8249f0c68839","uuid":"ddced2bd-110b-4c6f-aa2f-1d8afe9c08b1","timestamp":"2026-04-03T16:50:48.464Z"}
