{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EewaxbCTAj9Nco2cVXeK7a","type":"tool_result","content":"     1→/**\n     2→ * Ink UI components — types and layout components (Header, Separator, StoryBreakdown).\n     3→ *\n     4→ * Renders a UX-spec-compliant live display with plain text header,\n     5→ * ━━━ separators, and labeled story breakdown sections.\n     6→ * Activity components (tools, thoughts, retry) are in ink-activity-components.tsx.\n     7→ * The App root component is in ink-app.tsx to avoid circular imports.\n     8→ */\n     9→\n    10→import React from 'react';\n    11→import { Text, Box } from 'ink';\n    12→\n    13→// --- Types ---\n    14→\n    15→export interface SprintInfo {\n    16→  storyKey: string;\n    17→  phase: string;\n    18→  done: number;\n    19→  total: number;\n    20→  elapsed?: string;\n    21→  iterationCount?: number;\n    22→  totalCost?: number;\n    23→  acProgress?: string;\n    24→  currentCommand?: string;\n    25→}\n    26→\n    27→export interface CompletedToolEntry {\n    28→  name: string;\n    29→  args: string;\n    30→}\n    31→\n    32→export type StoryStatusValue = 'done' | 'in-progress' | 'pending' | 'failed' | 'blocked';\n    33→\n    34→export interface StoryStatusEntry {\n    35→  key: string;\n    36→  status: StoryStatusValue;\n    37→  retryCount?: number;\n    38→  maxRetries?: number;\n    39→}\n    40→\n    41→export interface RetryInfo {\n    42→  attempt: number;\n    43→  delay: number;\n    44→}\n    45→\n    46→export interface StoryMessage {\n    47→  type: 'ok' | 'warn' | 'fail';\n    48→  key: string;\n    49→  message: string;\n    50→  details?: string[];\n    51→}\n    52→\n    53→export interface RendererState {\n    54→  sprintInfo: SprintInfo | null;\n    55→  stories: StoryStatusEntry[];\n    56→  messages: StoryMessage[];\n    57→  completedTools: CompletedToolEntry[];\n    58→  activeTool: { name: string } | null;\n    59→  activeToolArgs: string;\n    60→  lastThought: string | null;\n    61→  retryInfo: RetryInfo | null;\n    62→}\n    63→\n    64→// --- Layout Components ---\n    65→\n    66→/** Full-width separator using ━ characters. */\n    67→export function Separator() {\n    68→  const width = process.stdout.columns || 60;\n    69→  return <Text>{'━'.repeat(width)}</Text>;\n    70→}\n    71→\n    72→function shortKey(key: string): string {\n    73→  const m = key.match(/^(\\d+-\\d+)/);\n    74→  return m ? m[1] : key;\n    75→}\n    76→\n    77→function formatCost(cost: number): string {\n    78→  return `$${cost.toFixed(2)}`;\n    79→}\n    80→\n    81→export function Header({ info }: { info: SprintInfo | null }) {\n    82→  if (!info) return null;\n    83→\n    84→  const parts: string[] = ['codeharness run'];\n    85→  if (info.iterationCount != null) {\n    86→    parts.push(`iteration ${info.iterationCount}`);\n    87→  }\n    88→  if (info.elapsed) {\n    89→    parts.push(`${info.elapsed} elapsed`);\n    90→  }\n    91→  if (info.totalCost != null) {\n    92→    parts.push(`${formatCost(info.totalCost)} spent`);\n    93→  }\n    94→  const headerLine = parts.join(' | ');\n    95→\n    96→  let phaseLine = '';\n    97→  if (info.phase) {\n    98→    phaseLine = `Phase: ${info.phase}`;\n    99→    if (info.acProgress) {\n   100→      phaseLine += ` → AC ${info.acProgress}`;\n   101→    }\n   102→    if (info.currentCommand) {\n   103→      phaseLine += ` (${info.currentCommand})`;\n   104→    }\n   105→  }\n   106→\n   107→  return (\n   108→    <Box flexDirection=\"column\">\n   109→      <Text>{headerLine}</Text>\n   110→      <Separator />\n   111→      <Text>{`Story: ${info.storyKey || '(waiting)'}`}</Text>\n   112→      {phaseLine && <Text>{phaseLine}</Text>}\n   113→    </Box>\n   114→  );\n   115→}\n   116→\n   117→export function StoryBreakdown({ stories, sprintInfo }: { stories: StoryStatusEntry[]; sprintInfo?: SprintInfo | null }) {\n   118→  if (stories.length === 0) return null;\n   119→\n   120→  const done: StoryStatusEntry[] = [];\n   121→  const inProgress: StoryStatusEntry[] = [];\n   122→  const pending: StoryStatusEntry[] = [];\n   123→  const failed: StoryStatusEntry[] = [];\n   124→  const blocked: StoryStatusEntry[] = [];\n   125→\n   126→  for (const s of stories) {\n   127→    switch (s.status) {\n   128→      case 'done': done.push(s); break;\n   129→      case 'in-progress': inProgress.push(s); break;\n   130→      case 'pending': pending.push(s); break;\n   131→      case 'failed': failed.push(s); break;\n   132→      case 'blocked': blocked.push(s); break;\n   133→    }\n   134→  }\n   135→\n   136→  const lines: React.ReactNode[] = [];\n   137→\n   138→  if (done.length > 0) {\n   139→    const doneItems = done.map(s => `${shortKey(s.key)} ✓`).join('  ');\n   140→    lines.push(\n   141→      <Text key=\"done\"><Text color=\"green\">{'Done: '}</Text><Text color=\"green\">{doneItems}</Text></Text>\n   142→    );\n   143→  }\n   144→\n   145→  if (inProgress.length > 0) {\n   146→    for (const s of inProgress) {\n   147→      let thisText = `${shortKey(s.key)} ◆`;\n   148→      if (sprintInfo && sprintInfo.storyKey && s.key.startsWith(shortKey(sprintInfo.storyKey))) {\n   149→        if (sprintInfo.phase) thisText += ` ${sprintInfo.phase}`;\n   150→        if (sprintInfo.acProgress) thisText += ` (${sprintInfo.acProgress} ACs)`;\n   151→      }\n   152→      lines.push(\n   153→        <Text key={`this-${s.key}`}><Text color=\"cyan\">{'This: '}</Text><Text color=\"cyan\">{thisText}</Text></Text>\n   154→      );\n   155→    }\n   156→  }\n   157→\n   158→  if (pending.length > 0) {\n   159→    lines.push(\n   160→      <Text key=\"next\">\n   161→        <Text>{'Next: '}</Text><Text>{shortKey(pending[0].key)}</Text>\n   162→        {pending.length > 1 && <Text dimColor>{` (+${pending.length - 1} more)`}</Text>}\n   163→      </Text>\n   164→    );\n   165→  }\n   166→\n   167→  if (blocked.length > 0) {\n   168→    const blockedItems = blocked.map(s => {\n   169→      let item = `${shortKey(s.key)} ✕`;\n   170→      if (s.retryCount != null && s.maxRetries != null) item += ` (${s.retryCount}/${s.maxRetries})`;\n   171→      return item;\n   172→    }).join('  ');\n   173→    lines.push(\n   174→      <Text key=\"blocked\"><Text color=\"yellow\">{'Blocked: '}</Text><Text color=\"yellow\">{blockedItems}</Text></Text>\n   175→    );\n   176→  }\n   177→\n   178→  if (failed.length > 0) {\n   179→    const failedItems = failed.map(s => {\n   180→      let item = `${shortKey(s.key)} ✗`;\n   181→      if (s.retryCount != null && s.maxRetries != null) item += ` (${s.retryCount}/${s.maxRetries})`;\n   182→      return item;\n   183→    }).join('  ');\n   184→    lines.push(\n   185→      <Text key=\"failed\"><Text color=\"red\">{'Failed: '}</Text><Text color=\"red\">{failedItems}</Text></Text>\n   186→    );\n   187→  }\n   188→\n   189→  return (\n   190→    <Box flexDirection=\"column\">\n   191→      {lines}\n   192→    </Box>\n   193→  );\n   194→}\n   195→\n   196→// Re-export activity components so existing consumers don't break\n   197→export { CompletedTool, CompletedTools, ActiveTool, LastThought, RetryNotice, StoryMessageLine } from './ink-activity-components.js';\n   198→\n   199→// Re-export App from ink-app\n   200→export { App } from './ink-app.js';\n   201→"}]},"parent_tool_use_id":"toolu_01AJ1yqSdiBA5zE85QQabyAz","session_id":"3e8c45fc-a757-4d77-9a55-f32a41bfdb65","uuid":"9d9b479e-cf52-4a89-a03c-287777676a9c","timestamp":"2026-03-21T10:57:59.063Z"}
