{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015znC1F19oce12sdqfai5Kz","type":"tool_result","content":"0\timport { describe, it, expect, beforeEach, afterEach } from 'vitest';\n1\timport { mkdtempSync, rmSync, writeFileSync, readFileSync, mkdirSync } from 'node:fs';\n2\timport { tmpdir, homedir } from 'node:os';\n3\timport os from 'node:os';\n4\timport { join } from 'node:path';\n5\timport {\n6\t  parseWorkflow,\n7\t  resolveWorkflow,\n8\t  loadWorkflowPatch,\n9\t  mergeWorkflowPatch,\n10\t  WorkflowParseError,\n11\t  type ResolvedWorkflow,\n12\t  type ResolvedTask,\n13\t  type LoopBlock,\n14\t  type FlowStep,\n15\t  type WorkflowPatch,\n16\t} from '../workflow-parser.js';\n17\t\n18\tlet testDir: string;\n19\t\n20\tbeforeEach(() => {\n21\t  testDir = mkdtempSync(join(tmpdir(), 'ch-wfparser-test-'));\n22\t});\n23\t\n24\tafterEach(() => {\n25\t  rmSync(testDir, { recursive: true, force: true });\n26\t});\n27\t\n28\tfunction writeYaml(filename: string, content: string): string {\n29\t  const filePath = join(testDir, filename);\n30\t  writeFileSync(filePath, content, 'utf-8');\n31\t  return filePath;\n32\t}\n33\t\n34\t// --- Helpers: YAML content ---\n35\t\n36\tconst minimalYaml = `\n37\ttasks:\n38\t  implement:\n39\t    agent: dev\n40\tflow:\n41\t  - implement\n42\t`;\n43\t\n44\tconst fullYaml = `\n45\ttasks:\n46\t  implement:\n47\t    agent: dev\n48\t    scope: per-story\n49\t    session: fresh\n50\t    source_access: true\n51\t    prompt_template: \"Implement story {{story_key}}\"\n52\t    input_contract:\n53\t      type: object\n54\t    output_contract:\n55\t      type: object\n56\t    max_budget_usd: 5.0\n57\t  verify:\n58\t    agent: evaluator\n59\t    scope: per-run\n60\t    session: continue\n61\t    source_access: false\n62\tflow:\n63\t  - implement\n64\t  - verify\n65\t`;\n66\t\n67\tconst loopYaml = `\n68\ttasks:\n69\t  implement:\n70\t    agent: dev\n71\t  verify:\n72\t    agent: evaluator\n73\t  retry:\n74\t    agent: dev\n75\tflow:\n76\t  - implement\n77\t  - verify\n78\t  - loop:\n79\t      - retry\n80\t      - verify\n81\t`;\n82\t\n83\tconst emptyYaml = `\n84\ttasks: {}\n85\tflow: []\n86\t`;\n87\t\n88\t// --- Tests ---\n89\t\n90\tdescribe('parseWorkflow', () => {\n91\t  describe('valid workflows (AC #1)', () => {\n92\t    it('parses a minimal valid workflow and returns ResolvedWorkflow', () => {\n93\t      const filePath = writeYaml('minimal.yaml', minimalYaml);\n94\t      const result = parseWorkflow(filePath);\n95\t\n96\t      expect(result.tasks).toBeDefined();\n97\t      expect(result.flow).toBeDefined();\n98\t      expect(result.tasks.implement).toBeDefined();\n99\t      expect(result.tasks.implement.agent).toBe('dev');\n100\t      expect(result.flow).toEqual(['implement']);\n101\t    });\n102\t\n103\t    it('parses a full workflow with all optional fields (AC #1)', () => {\n104\t      const filePath = writeYaml('full.yaml', fullYaml);\n105\t      const result = parseWorkflow(filePath);\n106\t\n107\t      expect(result.tasks.implement.agent).toBe('dev');\n108\t      expect(result.tasks.implement.scope).toBe('per-story');\n109\t      expect(result.tasks.implement.session).toBe('fresh');\n110\t      expect(result.tasks.implement.source_access).toBe(true);\n111\t      expect(result.tasks.implement.prompt_template).toBe('Implement story {{story_key}}');\n112\t      expect(result.tasks.implement.input_contract).toEqual({ type: 'object' });\n113\t      expect(result.tasks.implement.output_contract).toEqual({ type: 'object' });\n114\t      expect(result.tasks.implement.max_budget_usd).toBe(5.0);\n115\t\n116\t      expect(result.tasks.verify.agent).toBe('evaluator');\n117\t      expect(result.tasks.verify.scope).toBe('per-run');\n118\t      expect(result.tasks.verify.session).toBe('continue');\n119\t      expect(result.tasks.verify.source_access).toBe(false);\n120\t    });\n121\t\n122\t    it('applies defaults when optional fields are omitted (AC #1)', () => {\n123\t      const filePath = writeYaml('defaults.yaml', minimalYaml);\n124\t      const result = parseWorkflow(filePath);\n125\t      const task = result.tasks.implement;\n126\t\n127\t      expect(task.scope).toBe('per-story');\n128\t      expect(task.session).toBe('fresh');\n129\t      expect(task.source_access).toBe(true);\n130\t      expect(task.prompt_template).toBeUndefined();\n131\t      expect(task.input_contract).toBeUndefined();\n132\t      expect(task.output_contract).toBeUndefined();\n133\t      expect(task.max_budget_usd).toBeUndefined();\n134\t    });\n135\t\n136\t    it('parses empty tasks and flow as valid degenerate case', () => {\n137\t      const filePath = writeYaml('empty.yaml', emptyYaml);\n138\t      const result = parseWorkflow(filePath);\n139\t\n140\t      expect(result.tasks).toEqual({});\n141\t      expect(result.flow).toEqual([]);\n142\t    });\n143\t  });\n144\t\n145\t  describe('invalid YAML syntax (AC #2)', () => {\n146\t    it('throws WorkflowParseError for bad YAML', () => {\n147\t      const filePath = writeYaml('bad.yaml', '{{{{not yaml at all');\n148\t\n149\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n150\t      try {\n151\t        parseWorkflow(filePath);\n152\t      } catch (err) {\n153\t        expect(err).toBeInstanceOf(WorkflowParseError);\n154\t        const pe = err as WorkflowParseError;\n155\t        expect(pe.message).toContain('Invalid YAML syntax');\n156\t        expect(pe.errors.length).toBeGreaterThan(0);\n157\t      }\n158\t    });\n159\t\n160\t    it('throws WorkflowParseError for unclosed quotes in YAML', () => {\n161\t      const badYaml = `\n162\ttasks:\n163\t  implement:\n164\t    agent: \"dev\n165\tflow:\n166\t  - implement\n167\t`;\n168\t      const filePath = writeYaml('unclosed.yaml', badYaml);\n169\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n170\t    });\n171\t  });\n172\t\n173\t  describe('schema validation failures (AC #3)', () => {\n174\t    it('throws WorkflowParseError when tasks is missing', () => {\n175\t      const yaml = 'flow:\\n  - implement\\n';\n176\t      const filePath = writeYaml('no-tasks.yaml', yaml);\n177\t\n178\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n179\t      try {\n180\t        parseWorkflow(filePath);\n181\t      } catch (err) {\n182\t        const pe = err as WorkflowParseError;\n183\t        expect(pe.message).toContain('Schema validation failed');\n184\t        expect(pe.errors.length).toBeGreaterThan(0);\n185\t        expect(pe.errors.some((e) => e.message.includes('tasks'))).toBe(true);\n186\t      }\n187\t    });\n188\t\n189\t    it('throws WorkflowParseError for empty file (null YAML)', () => {\n190\t      const filePath = writeYaml('empty-file.yaml', '');\n191\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n192\t      try {\n193\t        parseWorkflow(filePath);\n194\t      } catch (err) {\n195\t        const pe = err as WorkflowParseError;\n196\t        expect(pe.message).toContain('Schema validation failed');\n197\t      }\n198\t    });\n199\t"}]},"parent_tool_use_id":"toolu_01LQLKYZKtmy4cEq7pgn6KQD","session_id":"90f775a4-0bf0-4884-b410-4d7f1f50684d","uuid":"e4667597-7b3e-4709-845f-ad489841d431","timestamp":"2026-04-03T08:14:56.771Z"}
