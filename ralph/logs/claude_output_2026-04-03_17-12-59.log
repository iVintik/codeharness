{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DjyoQxaS66nRjFf7FJmLmj","type":"tool_result","content":"1\t/**\n2\t * Public API for the agents subsystem.\n3\t *\n4\t * Re-exports types (story 10-1), stream parser functions/types,\n5\t * and the driver factory (story 10-2).\n6\t */\n7\t\n8\t// New types (Epic 10)\n9\texport type {\n10\t  AgentDriver,\n11\t  DriverHealth,\n12\t  DriverCapabilities,\n13\t  DispatchOpts,\n14\t  ErrorCategory,\n15\t  OutputContract,\n16\t  TestResults,\n17\t  ACStatus,\n18\t} from './types.js';\n19\t\n20\t// Deprecated types — kept for backward compatibility until story 10-3\n21\t/** @deprecated Use `DispatchOpts` instead. */\n22\texport type { SpawnOpts } from './types.js';\n23\t/** @deprecated Use `AsyncIterable<StreamEvent>` from `dispatch()` instead. */\n24\texport type { AgentProcess } from './types.js';\n25\t/** @deprecated Use `StreamEvent` from `stream-parser.ts` instead. */\n26\texport type { AgentEvent } from './types.js';\n27\t\n28\t// Stream parser\n29\texport { parseStreamLine } from './stream-parser.js';\n30\texport type {\n31\t  StreamEvent,\n32\t  ToolStartEvent,\n33\t  ToolInputEvent,\n34\t  ToolCompleteEvent,\n35\t  TextEvent,\n36\t  RetryEvent,\n37\t  ResultEvent,\n38\t} from './stream-parser.js';\n39\t\n40\t// --- Driver Factory ---\n41\t\n42\texport { getDriver, registerDriver, listDrivers, resetDrivers } from './drivers/factory.js';\n43\t\n44\t// --- Model Resolution ---\n45\t\n46\texport { resolveModel } from './model-resolver.js';\n47\t\n48\t// --- Output Contract ---\n49\t\n50\texport {\n51\t  writeOutputContract,\n52\t  readOutputContract,\n53\t  formatContractAsPromptContext,\n54\t  buildPromptWithContractContext,\n55\t} from './output-contract.js';\n56\t"}]},"parent_tool_use_id":"toolu_01FEeigjd5nRWkRCota9R2KA","session_id":"cf16e575-8267-4c58-a992-20b07458710f","uuid":"343d2aab-0b9d-443b-8aa7-886400e184f1","timestamp":"2026-04-03T13:15:18.273Z"}
