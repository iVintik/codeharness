{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UKoq4PLpy4LWrdVLo8uZZn","type":"tool_result","content":"132\t\n133\texport function StoryBreakdown({ stories, sprintInfo }: { stories: StoryStatusEntry[]; sprintInfo?: SprintInfo | null }) {\n134\t  if (stories.length === 0) return null;\n135\t\n136\t  const done: StoryStatusEntry[] = [];\n137\t  const inProgress: StoryStatusEntry[] = [];\n138\t  const pending: StoryStatusEntry[] = [];\n139\t  const failed: StoryStatusEntry[] = [];\n140\t  const blocked: StoryStatusEntry[] = [];\n141\t\n142\t  for (const s of stories) {\n143\t    switch (s.status) {\n144\t      case 'done': done.push(s); break;\n145\t      case 'in-progress': inProgress.push(s); break;\n146\t      case 'pending': pending.push(s); break;\n147\t      case 'failed': failed.push(s); break;\n148\t      case 'blocked': blocked.push(s); break;\n149\t    }\n150\t  }\n151\t\n152\t  const lines: React.ReactNode[] = [];\n153\t\n154\t  if (done.length > 0) {\n155\t    const doneItems = done.map(s => `${shortKey(s.key)} ✓`).join('  ');\n156\t    lines.push(\n157\t      <Text key=\"done\"><Text color=\"green\">{'Done: '}</Text><Text color=\"green\">{doneItems}</Text></Text>\n158\t    );\n159\t  }\n160\t\n161\t  if (inProgress.length > 0) {\n162\t    for (const s of inProgress) {\n163\t      let thisText = `${shortKey(s.key)} ◆`;\n164\t      if (sprintInfo && sprintInfo.storyKey && shortKey(s.key) === shortKey(sprintInfo.storyKey)) {\n165\t        if (sprintInfo.phase) thisText += ` ${sprintInfo.phase}`;\n166\t        if (sprintInfo.acProgress) thisText += ` (${sprintInfo.acProgress} ACs)`;\n167\t      }\n168\t      lines.push(\n169\t        <Text key={`this-${s.key}`}><Text color=\"cyan\">{'This: '}</Text><Text color=\"cyan\">{thisText}</Text></Text>\n170\t      );\n171\t    }\n172\t  }\n173\t\n174\t  if (pending.length > 0) {\n175\t    lines.push(\n176\t      <Text key=\"next\">\n177\t        <Text>{'Next: '}</Text><Text>{shortKey(pending[0].key)}</Text>\n178\t        {pending.length > 1 && <Text dimColor>{` (+${pending.length - 1} more)`}</Text>}\n179\t      </Text>\n180\t    );\n181\t  }\n182\t\n183\t  if (blocked.length > 0) {\n184\t    const blockedItems = blocked.map(s => {\n185\t      let item = `${shortKey(s.key)} ✕`;\n186\t      if (s.retryCount != null && s.maxRetries != null) item += ` (${s.retryCount}/${s.maxRetries})`;\n187\t      return item;\n188\t    }).join('  ');\n189\t    lines.push(\n190\t      <Text key=\"blocked\"><Text color=\"yellow\">{'Blocked: '}</Text><Text color=\"yellow\">{blockedItems}</Text></Text>\n191\t    );\n192\t  }\n193\t\n194\t  if (failed.length > 0) {\n195\t    const failedItems = failed.map(s => {\n196\t      let item = `${shortKey(s.key)} ✗`;\n197\t      if (s.retryCount != null && s.maxRetries != null) item += ` (${s.retryCount}/${s.maxRetries})`;\n198\t      return item;\n199\t    }).join('  ');\n200\t    lines.push(\n201\t      <Text key=\"failed\"><Text color=\"red\">{'Failed: '}</Text><Text color=\"red\">{failedItems}</Text></Text>\n202\t    );\n203\t  }\n204\t\n205\t  return (\n206\t    <Box flexDirection=\"column\">\n207\t      {lines}\n208\t    </Box>\n209\t  );\n210\t}\n211\t"}]},"parent_tool_use_id":"toolu_01FRDwwzfG8xnd7jPHer3uP2","session_id":"a0646c12-93c6-41a0-9c7a-50683cae7716","uuid":"72838fe6-accf-4b82-af65-f0670708c3ca","timestamp":"2026-04-03T12:50:26.029Z"}
