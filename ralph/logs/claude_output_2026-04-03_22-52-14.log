ully done — advance\n815\t      currentState = {\n816\t        ...currentState,\n817\t        iteration: nextIteration,\n818\t      };\n819\t      writeWorkflowState(currentState, projectDir);\n820\t    }\n821\t    // else: resuming a partially completed iteration — keep current iteration\n822\t\n823\t    let haltedInLoop = false;\n824\t\n825\t    // 2. Execute each task in the loop\n826\t    for (const taskName of loopBlock.loop) {\n827\t      const task = config.workflow.tasks[taskName];\n828\t      if (!task) {\n829\t        warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n830\t        continue;\n831\t      }\n832\t\n833\t      // --- Null task path in loop ---\n834\t      if (task.agent === null) {\n835\t        if (task.scope === 'per-story') {\n836\t          const itemsToProcess = lastVerdict ? getFailedItems(lastVerdict, workItems) : workItems;\n837\t          for (const item of itemsToProcess) {\n838\t            if (isLoopTaskCompleted(currentState, taskName, item.key, currentState.iteration)) {\n839\t              warn(`workflow-engine: skipping completed task ${taskName} for ${item.key}`);\n840\t              continue;\n841\t            }\n842\t            try {\n843\t              const nullResult = await executeNullTask(\n844\t                task, taskName, item.key, currentState, config, lastOutputContract ?? undefined, accumulatedCostUsd,\n845\t              );\n846\t              currentState = nullResult.updatedState;\n847\t              lastOutputContract = nullResult.contract;\n848\t              tasksCompleted++;\n849\t            } catch (err: unknown) {\n850\t              const engineError = isEngineError(err)\n851\t                ? err\n852\t                : handleDispatchError(err, taskName, item.key);\n853\t              errors.push(engineError);\n854\t              currentState = recordErrorInState(currentState, taskName, item.key, engineError);\n855\t              writeWorkflowState(currentState, projectDir);\n856\t            }"}]},"parent_tool_use_id":"toolu_01QNNr4yQoQQfPTTg7FsQuMG","session_id":"e648a229-0e5b-4ea4-9861-593afdfcccd5","uuid":"53b21d9a-d98e-46d1-8227-da9dbfbb8154","timestamp":"2026-04-03T19:02:56.871Z"}
