\s+([\\\\w-]+)\\\\s+.*retry\\\\s+(\\\\d+)\\\\/(\\\\d+)/;\\n    31→\\n    32→/** Matches: [LOOP] iteration N */\\n    33→const LOOP_ITERATION = /\\\\[LOOP\\\\]\\\\s+iteration\\\\s+(\\\\d+)/;\\n    34→\\n    35→/** Matches: [ERROR] ... */\\n    36→const ERROR_LINE = /\\\\[ERROR\\\\]\\\\s+(.+)/;\\n    37→\\n    38→// --- StoryMessage type (local, replaces import from ink-components) ---\\n    39→\\n    40→interface StoryMessage {\\n    41→  type: 'ok' | 'fail' | 'warn';\\n    42→  key: string;\\n    \n...\n</persisted-output>","is_error":false}]},"parent_tool_use_id":null,"session_id":"2610e689-589b-4ec2-8784-d06d07275472","uuid":"d29506a0-feea-4ab1-8d82-e9e7e051a374","timestamp":"2026-03-27T15:03:01.562Z","tool_use_result":{"stdout":"{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01U7KgHGr8rzHUpgyi6HGyMj\",\"type\":\"tool_result\",\"content\":\"     1→/**\\n     2→ * RalphDriver — AgentDriver implementation for the Ralph autonomous loop.\\n     3→ *\\n     4→ * Wraps ralph.sh invocation behind the AgentDriver interface defined in types.ts.\\n     5→ * Migrates ralph-specific parsing and spawning logic from run-helpers.ts.\\n     6→ */\\n     7→\\n     8→import { spawn } from 'node:child_process';\\n     9→import { existsSync } from 'node:fs';\\n    10→import { join } from 'node:path';\\n    11→import type { AgentDriver, SpawnOpts, AgentProcess, AgentEvent } from './types.js';\\n    12→import { parseStreamLine } from './stream-parser.js';\\n    13→import { getPackageRoot } from '../templates.js';\\n    14→\\n    15→// --- Regex constants (migrated from run-helpers.ts) ---\\n    16→\\n    17→/** Strip ANSI color codes */\\n    18→const ANSI_ESCAPE = /\\\\x1b\\\\[[0-9;]*m/g;\\n    19→\\n    20→/** Strip timestamp prefix from ralph output lines */\\n    21→const TIMESTAMP_PREFIX = /^\\\\[[\\\\d-]+\\\\s[\\\\d:]+\\\\]\\\\s*/;\\n    22→\\n    23→/** Matches: [SUCCESS] Story {key}: DONE ... */\\n    24→const SUCCESS_STORY = /\\\\[SUCCESS\\\\]\\\\s+Story\\\\s+([\\\\w-]+):\\\\s+DONE(.*)/;\\n    25→\\n    26→/** Matches: [WARN] Story {key} exceeded retry limit ... flagging */\\n    27→const WARN_STORY_RETRY = /\\\\[WARN\\\\]\\\\s+Story\\\\s+([\\\\w-]+)\\\\s+exceeded retry limit/;\\n    28→\\n    29→/** Matches: [WARN] Story {key} ... retry N/M */\\n    30→const WARN_STORY_RETRYING = /\\\\[WARN\\\\]\\\\s+Story\\\\s+([\\\\w-]+)\\\\s+.*retry\\\\s+(\\\\d+)\\\\/(\\\\d+)/;\\n    31→\\n    32→/** Matches: [LOOP] iteration N */\\n    33→const LOOP_ITERATION = /\\\\[LOOP\\\\]\\\\s+iteration\\\\s+(\\\\d+)/;\\n    34→\\n    35→/** Matches: [ERROR] ... */\\n    36→const ERROR_LINE = /\\\\[ERROR\\\\]\\\\s+(.+)/;\\n    37→\\n    38→// --- StoryMessage type (local, replaces import from ink-components) ---\\n    39→\\n    40→interface StoryMessage {\\n    41→  type: 'ok' | 'fail' | 'warn';\\n    42→  key: string;\\n    43→  message: string;\\n    44→}\\n    45→\\n    46→// --- Migrated functions ---\\n    47→\\n    48→/**\\n    49→ * Parse a ralph output line and return a StoryMessage if it matches\\n    50→ * a story completion, failure, or warning pattern.\\n    51→ * Returns null for non-matching lines.\\n    52→ */\\n    53→export function parseRalphMessage(rawLine: string): StoryMessage | null {\\n    54→  const clean = rawLine.replace(ANSI_ESCAPE, '').replace(TIMESTAMP_PREFIX, '').trim();\\n    55→  if (clean.length === 0) return null;\\n    56→\\n    57→  // [SUCCESS] Story {key}: DONE ...\\n    58→  const success = SUCCESS_STORY.exec(clean);\\n    59→  if (success) {\\n    60→    const key = success[1];\\n    61→    const rest = success[2].trim().replace(/^—\\\\s*/, '');\\n    62→    return {\\n    63→      type: 'ok',\\n    64→      key,\\n    65→      message: rest ? `DONE — ${rest}` : 'DONE',\\n    66→    };\\n    67→  }\\n    68→\\n    69→  // [WARN] Story {key} exceeded retry limit\\n    70→  const retryExceeded = WARN_STORY_RETRY.exec(clean);\\n    71→  if (retryExceeded) {\\n    72→    return {\\n    73→      type: 'fail',\\n    74→      key: retryExceeded[1],\\n    75→      message: 'exceeded retry limit',\\n    76→    };\\n    77→  }\\n    78→\\n    79→  // [WARN] Story {key} — retry N/M\\n    80→  const retrying = WARN_STORY_RETRYING.exec(clean);\\n    81→  if (retrying) {\\n    82→    return {\\n    83→      type: 'warn',\\n    84→      key: retrying[1],\\n    85→      message: `retry ${retrying[2]}/${retrying[3]}`,\\n    86→    };\\n    87→  }\\n    88→\\n    89→  // [ERROR] ... — surface as a generic error message\\n    90→  const errorMatch = ERROR_LINE.exec(clean);\\n    91→  if (errorMatch) {\\n    92→    // Try to extract story key from error message\\n    93→    const keyMatch = errorMatch[1].match(/Story\\\\s+([\\\\w-]+)/);\\n    94→    if (keyMatch) {\\n    95→      return {\\n    96→        type: 'fail',\\n    97→        key: keyMatch[1],\\n    98→        message: errorMatch[1].trim(),\\n    99→      };\\n   100→    }\\n   101→    // Generic error without a story key — skip (no key to associate)\\n   102→    return null;\\n   103→  }\\n   104→\\n   105→  return null;\\n   106→}\\n   107→\\n   108→/**\\n   109→ * Parse a ralph stderr line for [LOOP] iteration messages.\\n   110→ * Returns the iteration number if found, or null otherwise.\\n   111→ */\\n   112→export function parseIterationMessage(rawLine: string): number | null {\\n   113→  const clean = rawLine.replace(ANSI_ESCAPE, '').replace(TIMESTAMP_PREFIX, '').trim();\\n   114→  if (clean.length === 0) return null;\\n   115→  const match = LOOP_ITERATION.exec(clean);\\n   116→  if (match) {\\n   117→    return parseInt(match[1], 10);\\n   118→  }\\n   119→  return null;\\n   120→}\\n   121→\\n   122→/**\\n   123→ * Builds the argument array for spawning Ralph.\\n   124→ */\\n   125→export function buildSpawnArgs(opts: {\\n   126→  ralphPath: string;\\n   127→  pluginDir: string;\\n   128→  promptFile: string;\\n   129→  maxIterations: number;\\n   130→  timeout: number;\\n   131→  iterationTimeout: number;\\n   132→  calls: number;\\n   133→  quiet: boolean;\\n   134→  maxStoryRetries?: number;\\n   135→  reset?: boolean;\\n   136→}): string[] {\\n   137→  const args = [\\n   138→    opts.ralphPath,\\n   139→    '--plugin-dir', opts.pluginDir,\\n   140→    '--max-iterations', String(opts.maxIterations),\\n   141→    '--timeout', String(opts.timeout),\\n   142→    '--iteration-timeout', String(opts.iterationTimeout),\\n   143→    '--calls', String(opts.calls),\\n   144→    '--prompt', opts.promptFile,\\n   145→  ];\\n   146→\\n   147→  // When not quiet, pass --live so ralph tees Claude's stream-json to stdout.\\n   148→  if (!opts.quiet) {\\n   149→    args.push('--live');\\n   150→  }\\n   151→\\n   152→  if (opts.maxStoryRetries !== undefined) {\\n   153→    args.push('--max-story-retries', String(opts.maxStoryRetries));\\n   154→  }\\n   155→\\n   156→  if (opts.reset) {\\n   157→    args.push('--reset');\\n   158→  }\\n   159→\\n   160→  return args;\\n   161→}\\n   162→\\n   163→/** Resolves the path to ralph/ralph.sh relative to the package root. */\\n   164→export function resolveRalphPath(): string {\\n   165→  return join(getPackageRoot(), 'ralph', 'ralph.sh');\\n   166→}\\n   167→\\n   168→// --- RalphConfig for constructor-time configuration ---\\n   169→\\n   170→/**\\n   171→ * Ralph-specific configuration passed at construction time.\\n   172→ * Keeps SpawnOpts agent-agnostic while allowing RalphDriver\\n   173→ * to accept all ralph.sh flags.\\n   174→ */\\n   175→export interface RalphConfig {\\n   176→  pluginDir: string;\\n   177→  maxIterations?: number;\\n   178→  iterationTimeout?: number;\\n   179→  calls?: number;\\n   180→  quiet?: boolean;\\n   181→  maxStoryRetries?: number;\\n   182→  reset?: boolean;\\n   183→}\\n   184→\\n   185→// --- RalphDriver class ---\\n   186→\\n   187→export class RalphDriver implements AgentDriver {\\n   188→  readonly name = 'ralph';\\n   189→  private readonly config: RalphConfig;\\n   190→\\n   191→  constructor(config?: RalphConfig) {\\n   192→    this.config = config ?? { pluginDir: join(process.cwd(), '.claude') };\\n   193→  }\\n   194→\\n   195→  spawn(opts: SpawnOpts): AgentProcess {\\n   196→    const ralphPath = resolveRalphPath();\\n   197→    if (!existsSync(ralphPath)) {\\n   198→      throw new Error(`Ralph loop not found at ${ralphPath} — reinstall codeharness`);\\n   199→    }\\n   200→\\n   201→    const args = buildSpawnArgs({\\n   202→      ralphPath,\\n   203→      pluginDir: this.config.pluginDir,\\n   204→      promptFile: opts.prompt,\\n   205→      maxIterations: this.config.maxIterations ?? 50,\\n   206→      timeout: opts.timeout,\\n   207→      iterationTimeout: this.config.iterationTimeout ?? 30,\\n   208→      calls: this.config.calls ?? 100,\\n   209→      quiet: this.config.quiet ?? false,\\n   210→      maxStoryRetries: this.config.maxStoryRetries,\\n   211→      reset: this.config.reset,\\n   212→    });\\n   213→\\n   214→    const quiet = this.config.quiet ?? false;\\n   215→    const child = spawn('bash', args, {\\n   216→      cwd: opts.workDir,\\n   217→      env: { ...process.env, ...opts.env },\\n   218→      stdio: quiet ? 'ignore' : ['inherit', 'pipe', 'pipe'],\\n   219→    });\\n   220→\\n   221→    return child as unknown as AgentProcess;\\n   222→  }\\n   223→\\n   224→  parseOutput(line: string): AgentEvent | null {\\n   225→    // 1. Try ralph stderr patterns\\n   226→    const iteration = parseIterationMessage(line);\\n   227→    if (iteration !== null) {\\n   228→      return { type: 'iteration', count: iteration };\\n   229→    }\\n   230→\\n   231→    const msg = parseRalphMessage(line);\\n   232→    if (msg) {\\n   233→      switch (msg.type) {\\n   234→        case 'ok':\\n   235→          return { type: 'story-complete', key: msg.key, details: msg.message };\\n   236→        case 'fail':\\n   237→          return { type: 'story-failed', key: msg.key, reason: msg.message };\\n   238→        case 'warn': {\\n   239→          // Parse retry N/M from message\\n   240→          const retryMatch = msg.message.match(/retry\\\\s+(\\\\d+)\\\\/(\\\\d+)/);\\n   241→          if (retryMatch) {\\n   242→            return {\\n   243→              type: 'retry',\\n   244→              attempt: parseInt(retryMatch[1], 10),\\n   245→              delay: 0,\\n   246→            };\\n   247→          }\\n   248→          // Fallback: treat as story-failed\\n   249→          return { type: 'story-failed', key: msg.key, reason: msg.message };\\n   250→        }\\n   251→      }\\n   252→    }\\n   253→\\n   254→    // 2. Fall back to stream-json parser\\n   255→    const streamEvent = parseStreamLine(line);\\n   256→    if (streamEvent) {\\n   257→      switch (streamEvent.type) {\\n   258→        case 'tool-start':\\n   259→          return { type: 'tool-start', name: streamEvent.name };\\n   260→        case 'tool-complete':\\n   261→          return { type: 'tool-complete' };\\n   262→        case 'text':\\n   263→          return { type: 'text', text: streamEvent.text };\\n   264→        case 'retry':\\n   265→          return { type: 'retry', attempt: streamEvent.attempt, delay: streamEvent.delay };\\n   266→        case 'result':\\n   267→          return { type: 'result', cost: streamEvent.cost, sessionId: streamEvent.sessionId };\\n   268→        case 'tool-input':\\n   269→          return { type: 'tool-input', partial: streamEvent.partial };\\n   270→      }\\n   271→    }\\n   272→\\n   273→    return null;\\n   274→  }\\n   275→\\n   276→  getStatusFile(): string {\\n   277→    return 'ralph/status.json';\\n   278→  }\\n   279→}\\n   280→\"}]},\"parent_tool_use_id\":\"toolu_01GTepbYbnTDehnMhc3XqM2y\",\"session_id\":\"2610e689-589b-4ec2-8784-d06d07275472\",\"uuid\":\"b771b7a3-e03f-41ac-b3b5-63ef230d83fe\",\"timestamp\":\"2026-03-27T14:55:31.508Z\"}\n{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01UKnvwbfhs9xeoGiimjsFAp\",\"type\":\"to