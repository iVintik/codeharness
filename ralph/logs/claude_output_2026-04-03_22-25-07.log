{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RmvZq4MimxJ3smLFYFoPEd","type":"tool_result","content":"1\timport { existsSync, readFileSync } from 'node:fs';\n2\timport { join } from 'node:path';\n3\timport { ok, fail as failOut, info, warn } from '../output.js';\n4\timport { readStateWithBody, writeState } from '../state.js';\n5\timport type { CoverageResult, CoverageEvaluation, FileCoverageEntry, PerFileCoverageResult } from './types.js';\n6\timport { findCoverageSummary } from './parser.js';\n7\t\n8\t// ─── Coverage Evaluation and State Updates ───────────────────────────────────\n9\t\n10\texport function evaluateCoverage(result: CoverageResult, dir?: string): CoverageEvaluation {\n11\t  const baseDir = dir ?? process.cwd();\n12\t\n13\t  let target = 90;\n14\t  let baseline: number | null = null;\n15\t\n16\t  try {\n17\t    const { state } = readStateWithBody(baseDir);\n18\t    target = state.coverage.target ?? 90;\n19\t    baseline = state.coverage.baseline;\n20\t  } catch {\n21\t    // IGNORE: no state file, use default coverage targets\n22\t  }\n23\t\n24\t  const actual = result.coveragePercent;\n25\t  const met = actual >= target;\n26\t\n27\t  // If baseline is null (first run), set it to current\n28\t  const effectiveBaseline = baseline ?? actual;\n29\t  const delta = baseline !== null ? actual - baseline : null;\n30\t\n31\t  return {\n32\t    met,\n33\t    target,\n34\t    actual,\n35\t    delta,\n36\t    baseline: effectiveBaseline,\n37\t  };\n38\t}\n39\t\n40\texport function updateCoverageState(\n41\t  result: CoverageResult,\n42\t  evaluation: CoverageEvaluation,\n43\t  dir?: string,\n44\t): void {\n45\t  const baseDir = dir ?? process.cwd();\n46\t  const { state, body } = readStateWithBody(baseDir);\n47\t\n48\t  state.session_flags.tests_passed = result.testsPassed;\n49\t  state.session_flags.coverage_met = evaluation.met;\n50\t  state.coverage.current = evaluation.actual;\n51\t\n52\t  // Set baseline on first run (when it was null)\n53\t  if (state.coverage.baseline === null) {\n54\t    state.coverage.baseline = evaluation.actual;\n55\t  }\n56\t\n57\t  writeState(state, baseDir, body);\n58\t}\n59\t\n60\t// ─── Per-file Coverage Floor Check ───────────────────────────────────────────\n61\t\n62\t/**\n63\t * Checks per-file coverage against a minimum floor.\n64\t * Reads coverage-summary.json and returns any files below the threshold.\n65\t */\n66\texport function checkPerFileCoverage(floor: number, dir?: string): PerFileCoverageResult {\n67\t  const baseDir = dir ?? process.cwd();\n68\t  const reportPath = findCoverageSummary(baseDir);\n69\t\n70\t  if (!reportPath) {\n71\t    return { floor, violations: [], totalFiles: 0 };\n72\t  }\n73\t\n74\t  let report: Record<string, { statements?: { pct?: number }; branches?: { pct?: number }; functions?: { pct?: number }; lines?: { pct?: number } }>;\n75\t  try {\n76\t    report = JSON.parse(readFileSync(reportPath, 'utf-8')) as typeof report;\n77\t  } catch {\n78\t    // IGNORE: coverage-summary.json may be malformed\n79\t    warn('Failed to parse coverage-summary.json');\n80\t    return { floor, violations: [], totalFiles: 0 };\n81\t  }\n82\t\n83\t  const violations: FileCoverageEntry[] = [];\n84\t  let totalFiles = 0;\n85\t\n86\t  for (const [key, data] of Object.entries(report)) {\n87\t    if (key === 'total') continue;\n88\t    totalFiles++;\n89\t\n90\t    const stmts = data.statements?.pct ?? 0;\n91\t    const branches = data.branches?.pct ?? 0;\n92\t    const funcs = data.functions?.pct ?? 0;\n93\t    const lines = data.lines?.pct ?? 0;\n94\t\n95\t    if (stmts < floor) {\n96\t      // Extract relative path from absolute\n97\t      const relative = key.startsWith(baseDir)\n98\t        ? key.slice(baseDir.length + 1)\n99\t        : key;\n100\t\n101\t      violations.push({\n102\t        file: relative,\n103\t        statements: stmts,\n104\t        branches,\n105\t        functions: funcs,\n106\t        lines,\n107\t      });\n108\t    }\n109\t  }\n110\t\n111\t  // Sort worst first\n112\t  violations.sort((a, b) => a.statements - b.statements);\n113\t\n114\t  return { floor, violations, totalFiles };\n115\t}\n116\t\n117\t// ─── Coverage Output Formatting ──────────────────────────────────────────────\n118\t\n119\texport function formatCoverageOutput(evaluation: CoverageEvaluation): string[] {\n120\t  const lines: string[] = [];\n121\t\n122\t  if (evaluation.met) {\n123\t    lines.push(`[OK] Coverage: ${evaluation.actual}%`);\n124\t  } else {\n125\t    lines.push(`[FAIL] Coverage: ${evaluation.actual}% (target: ${evaluation.target}%)`);\n126\t  }\n127\t\n128\t  if (evaluation.delta !== null && evaluation.baseline !== null) {\n129\t    const sign = evaluation.delta >= 0 ? '+' : '';\n130\t    const before = evaluation.actual - evaluation.delta;\n131\t    lines.push(\n132\t      `[INFO] Coverage delta: ${sign}${evaluation.delta}% (${before}% -> ${evaluation.actual}%)`,\n133\t    );\n134\t  }\n135\t\n136\t  return lines;\n137\t}\n138\t\n139\texport function printCoverageOutput(\n140\t  result: CoverageResult,\n141\t  evaluation: CoverageEvaluation,\n142\t): void {\n143\t  // Print test results\n144\t  if (result.testsPassed) {\n145\t    ok(`Tests passed: ${result.passCount} passed`);\n146\t  } else {\n147\t    failOut(`Tests failed: ${result.passCount} passed, ${result.failCount} failed`);\n148\t  }\n149\t\n150\t  // Print coverage evaluation\n151\t  if (evaluation.met) {\n152\t    ok(`Coverage: ${evaluation.actual}%`);\n153\t  } else {\n154\t    failOut(`Coverage: ${evaluation.actual}% (target: ${evaluation.target}%)`);\n155\t  }\n156\t\n157\t  // Print delta if available\n158\t  if (evaluation.delta !== null && evaluation.baseline !== null) {\n159\t    const sign = evaluation.delta >= 0 ? '+' : '';\n160\t    const before = evaluation.actual - evaluation.delta;\n161\t    info(`Coverage delta: ${sign}${evaluation.delta}% (${before}% -> ${evaluation.actual}%)`);\n162\t  }\n163\t}\n164\t"}]},"parent_tool_use_id":"toolu_01Hody5ZigZ3cTLmGuBw8VE3","session_id":"b6bb3bfc-8778-4f16-a616-88028acc2431","uuid":"7ae8ac22-3235-4357-b945-2460c75cb1d4","timestamp":"2026-04-03T18:31:26.916Z"}
