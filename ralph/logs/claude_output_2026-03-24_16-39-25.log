{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SVbzFaq1x3vfHvCEXxMv7g","type":"tool_result","content":"     1→import { existsSync, readFileSync, writeFileSync } from 'node:fs';\n     2→import { join } from 'node:path';\n     3→import { parse, stringify } from 'yaml';\n     4→import { warn } from './output.js';\n     5→import type { BeadsIssue } from './beads.js';\n     6→\n     7→// ─── Types ──────────────────────────────────────────────────────────────────\n     8→\n     9→export interface SyncResult {\n    10→  storyKey: string;\n    11→  beadsId: string;\n    12→  previousStatus: string;\n    13→  newStatus: string;\n    14→  synced: boolean;\n    15→  error?: string;\n    16→}\n    17→\n    18→export type SyncDirection = 'beads-to-files' | 'files-to-beads' | 'bidirectional';\n    19→\n    20→// ─── Status Mapping ─────────────────────────────────────────────────────────\n    21→\n    22→/**\n    23→ * Maps beads statuses to story file statuses.\n    24→ * Beads `open` -> story `in-progress` (assumes work started if issue exists).\n    25→ * Beads `closed` -> story `done`.\n    26→ */\n    27→const BEADS_TO_STORY_STATUS: Record<string, string> = {\n    28→  open: 'in-progress',\n    29→  closed: 'done',\n    30→};\n    31→\n    32→/**\n    33→ * Maps story file statuses to beads statuses.\n    34→ * `backlog`, `ready-for-dev`, `in-progress`, `review` -> beads `open`.\n    35→ * `done` -> beads `closed`.\n    36→ */\n    37→const STORY_TO_BEADS_STATUS: Record<string, string> = {\n    38→  backlog: 'open',\n    39→  'ready-for-dev': 'open',\n    40→  'in-progress': 'open',\n    41→  review: 'open',\n    42→  done: 'closed',\n    43→};\n    44→\n    45→export function beadsStatusToStoryStatus(beadsStatus: string): string | null {\n    46→  return BEADS_TO_STORY_STATUS[beadsStatus] ?? null;\n    47→}\n    48→\n    49→export function storyStatusToBeadsStatus(storyStatus: string): string | null {\n    50→  return STORY_TO_BEADS_STATUS[storyStatus] ?? null;\n    51→}\n    52→\n    53→// ─── Story File Operations ──────────────────────────────────────────────────\n    54→\n    55→/**\n    56→ * Extracts story file path from beads issue description field.\n    57→ * The bridge command sets description = story file path (e.g. `_bmad-output/implementation-artifacts/3-1-beads-installation-cli-wrapper.md`).\n    58→ * Returns null if description doesn't contain a valid path.\n    59→ */\n    60→export function resolveStoryFilePath(beadsIssue: BeadsIssue): string | null {\n    61→  const desc = beadsIssue.description;\n    62→  if (!desc || !desc.trim()) {\n    63→    return null;\n    64→  }\n    65→  const trimmed = desc.trim();\n    66→  // Must look like a relative path ending in .md\n    67→  if (!trimmed.endsWith('.md')) {\n    68→    return null;\n    69→  }\n    70→  return trimmed;\n    71→}\n    72→\n    73→/**\n    74→ * Reads the `Status:` line from a story markdown file.\n    75→ * Story file format:\n    76→ *   # Story N.M: Title\n    77→ *\n    78→ *   Status: ready-for-dev\n    79→ *\n    80→ * The Status line is found by scanning for `Status: <value>`.\n    81→ * Returns null if file doesn't exist or has no Status line.\n    82→ */\n    83→export function readStoryFileStatus(filePath: string): string | null {\n    84→  if (!existsSync(filePath)) {\n    85→    return null;\n    86→  }\n    87→  const content = readFileSync(filePath, 'utf-8');\n    88→  const match = content.match(/^Status:\\s*(.+)$/m);\n    89→  if (!match) {\n    90→    return null;\n    91→  }\n    92→  return match[1].trim();\n    93→}\n    94→\n    95→/**\n    96→ * Updates the `Status:` line in a story markdown file in-place.\n    97→ * If no `Status:` line exists, inserts one after the title line.\n    98→ */\n    99→export function updateStoryFileStatus(filePath: string, newStatus: string): void {\n   100→  const content = readFileSync(filePath, 'utf-8');\n   101→  const statusRegex = /^Status:\\s*.+$/m;\n   102→\n   103→  if (statusRegex.test(content)) {\n   104→    const updated = content.replace(statusRegex, `Status: ${newStatus}`);\n   105→    writeFileSync(filePath, updated, 'utf-8');\n   106→  } else {\n   107→    // Insert after the first line (title)\n   108→    const lines = content.split('\\n');\n   109→    const titleIndex = lines.findIndex(l => l.startsWith('# '));\n   110→    if (titleIndex !== -1) {\n   111→      lines.splice(titleIndex + 1, 0, '', `Status: ${newStatus}`);\n   112→    } else {\n   113→      // No title found, prepend\n   114→      lines.unshift(`Status: ${newStatus}`, '');\n   115→    }\n   116→    writeFileSync(filePath, lines.join('\\n'), 'utf-8');\n   117→  }\n   118→}\n   119→\n   120→// ─── Sprint Status YAML ────────────────────────────────────────────────────\n   121→\n   122→const SPRINT_STATUS_PATH = '_bmad-output/implementation-artifacts/sprint-status.yaml';\n   123→\n   124→/**\n   125→ * Reads sprint-status.yaml and returns the development_status map.\n   126→ */\n   127→export function readSprintStatus(dir?: string): Record<string, string> {\n   128→  const root = dir ?? process.cwd();\n   129→  const filePath = join(root, SPRINT_STATUS_PATH);\n   130→  if (!existsSync(filePath)) {\n   131→    return {};\n   132→  }\n   133→  try {\n   134→    const content = readFileSync(filePath, 'utf-8');\n   135→    const parsed = parse(content) as Record<string, unknown> | null;\n   136→    if (!parsed || typeof parsed !== 'object') {\n   137→      return {};\n   138→    }\n   139→    const devStatus = parsed.development_status;\n   140→    if (!devStatus || typeof devStatus !== 'object') {\n   141→      return {};\n   142→    }\n   143→    return devStatus as Record<string, string>;\n   144→  } catch {\n   145→    return {};\n   146→  }\n   147→}\n   148→\n   149→/**\n   150→ * Updates a single story's status in sprint-status.yaml while preserving structure and comments.\n   151→ * Uses line-level text replacement to preserve YAML comments.\n   152→ */\n   153→export function updateSprintStatus(storyKey: string, newStatus: string, dir?: string): void {\n   154→  const root = dir ?? process.cwd();\n   155→  const filePath = join(root, SPRINT_STATUS_PATH);\n   156→  if (!existsSync(filePath)) {\n   157→    warn(`sprint-status.yaml not found at ${filePath}, skipping update`);\n   158→    return;\n   159→  }\n   160→\n   161→  const content = readFileSync(filePath, 'utf-8');\n   162→\n   163→  // Use regex replacement to preserve comments and structure\n   164→  const keyPattern = new RegExp(`^(\\\\s*${escapeRegExp(storyKey)}:\\\\s*)\\\\S+(.*)$`, 'm');\n   165→  if (!keyPattern.test(content)) {\n   166→    // Key not found in file, skip\n   167→    return;\n   168→  }\n   169→\n   170→  const updated = content.replace(keyPattern, `$1${newStatus}$2`);\n   171→  writeFileSync(filePath, updated, 'utf-8');\n   172→}\n   173→\n   174→function escapeRegExp(s: string): string {\n   175→  return s.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n   176→}\n   177→\n   178→// ─── Onboarding Epic → Sprint Status ────────────────────────────────────────\n   179→\n   180→/**\n   181→ * Determines the next epic number by scanning existing epic-N entries.\n   182→ */\n   183→function nextEpicNumber(statuses: Record<string, string>): number {\n   184→  let max = -1;\n   185→  for (const key of Object.keys(statuses)) {\n   186→    const match = key.match(/^epic-(\\d+)$/);\n   187→    if (match) {\n   188→      const n = parseInt(match[1], 10);\n   189→      if (n > max) max = n;\n   190→    }\n   191→  }\n   192→  return max + 1;\n   193→}\n   194→\n   195→/**\n   196→ * Converts an onboarding story title to a sprint-status story key slug.\n   197→ * e.g. \"Create ARCHITECTURE.md\" → \"create-architecture-md\"\n   198→ */\n   199→function slugify(title: string): string {\n   200→  return title\n   201→    .toLowerCase()\n   202→    .replace(/[^a-z0-9]+/g, '-')\n   203→    .replace(/^-+|-+$/g, '')\n   204→    .slice(0, 60);\n   205→}\n   206→\n   207→export interface OnboardingStoryEntry {\n   208→  title: string;\n   209→  key?: string;\n   210→}\n   211→\n   212→/**\n   213→ * Appends an onboarding epic with stories to sprint-status.yaml.\n   214→ * Creates entries like:\n   215→ *   epic-10: backlog\n   216→ *   10-1-create-architecture-md: backlog\n   217→ *   10-2-add-test-coverage-for-src-lib: backlog\n   218→ *   epic-10-retrospective: optional\n   219→ *\n   220→ * Returns the epic number and story keys created.\n   221→ */\n   222→export function appendOnboardingEpicToSprint(\n   223→  stories: OnboardingStoryEntry[],\n   224→  dir?: string,\n   225→): { epicNumber: number; storyKeys: string[] } {\n   226→  const root = dir ?? process.cwd();\n   227→  const filePath = join(root, SPRINT_STATUS_PATH);\n   228→\n   229→  if (!existsSync(filePath)) {\n   230→    warn(`sprint-status.yaml not found at ${filePath}, cannot append onboarding epic`);\n   231→    return { epicNumber: -1, storyKeys: [] };\n   232→  }\n   233→\n   234→  const statuses = readSprintStatus(dir);\n   235→  const epicNum = nextEpicNumber(statuses);\n   236→  const storyKeys: string[] = [];\n   237→\n   238→  const lines: string[] = [''];\n   239→  lines.push(`  epic-${epicNum}: backlog`);\n   240→\n   241→  for (let i = 0; i < stories.length; i++) {\n   242→    const slug = slugify(stories[i].title);\n   243→    const storyKey = `${epicNum}-${i + 1}-${slug}`;\n   244→    storyKeys.push(storyKey);\n   245→    lines.push(`  ${storyKey}: backlog`);\n   246→  }\n   247→\n   248→  lines.push(`  epic-${epicNum}-retrospective: optional`);\n   249→  lines.push('');\n   250→\n   251→  const content = readFileSync(filePath, 'utf-8');\n   252→  const updated = content.trimEnd() + '\\n' + lines.join('\\n');\n   253→  writeFileSync(filePath, updated, 'utf-8');\n   254→\n   255→  return { epicNumber: epicNum, storyKeys };\n   256→}\n   257→\n   258→// ─── Sync Functions ─────────────────────────────────────────────────────────\n   259→\n   260→/**\n   261→ * Extracts a story key from a story file path.\n   262→ * e.g. `_bmad-output/implementation-artifacts/3-1-beads-installation-cli-wrapper.md` -> `3-1-beads-installation-cli-wrapper`\n   263→ */\n   264→function storyKeyFromPath(filePath: string): string {\n   265→  const base = filePath.split('/').pop() ?? filePath;\n   266→  return base.replace(/\\.md$/, '');\n   267→}\n   268→\n   269→/**\n   270→ * Syncs a beads issue status to the linked story file.\n   271→ * Reads beads issue status, resolves story file path from description,\n   272→ * reads story file status, updates story file if statuses differ.\n   273→ */\n   274→export function syncBeadsToStoryFile(\n   275→  beadsId: string,\n   276→  beadsFns: {\n   277→    listIssues: () => BeadsIssue[];\n   278→  },\n   279→  dir?: string,\n   280→): SyncResult {\n   281→  const root = dir ?? process.cwd();\n   282→  const issues = beadsFns.listIssues();\n   283→  const issue = issues.find(i => i.id === beadsId);\n   284→\n   285→  if (!issue) {\n   286→    return {\n   287→      storyKey: '',\n   288→      beadsId,\n   289→      previousStatus: '',\n   290→      newStatus: '',\n   291→      synced: false,\n   292→      error: `Beads issue not found: ${beadsId}`,\n   293→    };\n   294→  }\n   295→\n   296→  const storyFilePath = resolveStoryFilePath(issue);\n   297→  if (!storyFilePath) {\n   298→    return {\n   299→      storyKey: '',\n   300→      beadsId,\n   301→      previousStatus: issue.status,\n   302→      newStatus: '',\n   303→      synced: false,\n   304→      error: `No story file path in beads issue description: ${beadsId}`,\n   305→    };\n   306→  }\n   307→\n   308→  const storyKey = storyKeyFromPath(storyFilePath);\n   309→  const fullPath = join(root, storyFilePath);\n   310→  const currentStoryStatus = readStoryFileStatus(fullPath);\n   311→\n   312→  if (currentStoryStatus === null) {\n   313→    return {\n   314→      storyKey,\n   315→      beadsId,\n   316→      previousStatus: issue.status,\n   317→      newStatus: '',\n   318→      synced: false,\n   319→      error: `Story file not found or has no Status line: ${storyFilePath}`,\n   320→    };\n   321→  }\n   322→\n   323→  const targetStoryStatus = beadsStatusToStoryStatus(issue.status);\n   324→  if (!targetStoryStatus) {\n   325→    return {\n   326→      storyKey,\n   327→      beadsId,\n   328→      previousStatus: currentStoryStatus,\n   329→      newStatus: '',\n   330→      synced: false,\n   331→      error: `Unknown beads status: ${issue.status}`,\n   332→    };\n   333→  }\n   334→\n   335→  if (currentStoryStatus === targetStoryStatus) {\n   336→    return {\n   337→      storyKey,\n   338→      beadsId,\n   339→      previousStatus: currentStoryStatus,\n   340→      newStatus: currentStoryStatus,\n   341→      synced: false,\n   342→    };\n   343→  }\n   344→\n   345→  updateStoryFileStatus(fullPath, targetStoryStatus);\n   346→  updateSprintStatus(storyKey, targetStoryStatus, root);\n   347→\n   348→  return {\n   349→    storyKey,\n   350→    beadsId,\n   351→    previousStatus: currentStoryStatus,\n   352→    newStatus: targetStoryStatus,\n   353→    synced: true,\n   354→  };\n   355→}\n   356→\n   357→/**\n   358→ * Syncs a story file status to the matching beads issue.\n   359→ * Reads story file status, finds matching beads issue (by description path containing story key),\n   360→ * updates beads issue status if statuses differ.\n   361→ */\n   362→export function syncStoryFileToBeads(\n   363→  storyKey: string,\n   364→  beadsFns: {\n   365→    listIssues: () => BeadsIssue[];\n   366→    updateIssue: (id: string, opts: { status?: string }) => void;\n   367→    closeIssue: (id: string) => void;\n   368→  },\n   369→  dir?: string,\n   370→): SyncResult {\n   371→  const root = dir ?? process.cwd();\n   372→  const storyFilePath = `_bmad-output/implementation-artifacts/${storyKey}.md`;\n   373→  const fullPath = join(root, storyFilePath);\n   374→\n   375→  const currentStoryStatus = readStoryFileStatus(fullPath);\n   376→  if (currentStoryStatus === null) {\n   377→    return {\n   378→      storyKey,\n   379→      beadsId: '',\n   380→      previousStatus: '',\n   381→      newStatus: '',\n   382→      synced: false,\n   383→      error: `Story file not found or has no Status line: ${storyFilePath}`,\n   384→    };\n   385→  }\n   386→\n   387→  const issues = beadsFns.listIssues();\n   388→  const issue = issues.find(i => {\n   389→    const path = resolveStoryFilePath(i);\n   390→    if (!path) return false;\n   391→    return storyKeyFromPath(path) === storyKey;\n   392→  });\n   393→\n   394→  if (!issue) {\n   395→    return {\n   396→      storyKey,\n   397→      beadsId: '',\n   398→      previousStatus: currentStoryStatus,\n   399→      newStatus: '',\n   400→      synced: false,\n   401→      error: `No beads issue found for story: ${storyKey}`,\n   402→    };\n   403→  }\n   404→\n   405→  const targetBeadsStatus = storyStatusToBeadsStatus(currentStoryStatus);\n   406→  if (!targetBeadsStatus) {\n   407→    return {\n   408→      storyKey,\n   409→      beadsId: issue.id,\n   410→      previousStatus: currentStoryStatus,\n   411→      newStatus: '',\n   412→      synced: false,\n   413→      error: `Unknown story status: ${currentStoryStatus}`,\n   414→    };\n   415→  }\n   416→\n   417→  if (issue.status === targetBeadsStatus) {\n   418→    return {\n   419→      storyKey,\n   420→      beadsId: issue.id,\n   421→      previousStatus: currentStoryStatus,\n   422→      newStatus: currentStoryStatus,\n   423→      synced: false,\n   424→    };\n   425→  }\n   426→\n   427→  // Use closeIssue for closing, updateIssue for reopening\n   428→  if (targetBeadsStatus === 'closed') {\n   429→    beadsFns.closeIssue(issue.id);\n   430→  } else {\n   431→    beadsFns.updateIssue(issue.id, { status: targetBeadsStatus });\n   432→  }\n   433→\n   434→  // Also update sprint-status.yaml\n   435→  updateSprintStatus(storyKey, currentStoryStatus, root);\n   436→\n   437→  return {\n   438→    storyKey,\n   439→    beadsId: issue.id,\n   440→    previousStatus: issue.status,\n   441→    newStatus: targetBeadsStatus,\n   442→    synced: true,\n   443→  };\n   444→}\n   445→\n   446→/**\n   447→ * Closes a beads issue and updates the linked story file to `done`.\n   448→ * This is the primary path used by Ralph/sprint execution when completing a story.\n   449→ */\n   450→export function syncClose(\n   451→  beadsId: string,\n   452→  beadsFns: {\n   453→    closeIssue: (id: string) => void;\n   454→    listIssues: () => BeadsIssue[];\n   455→  },\n   456→  dir?: string,\n   457→): SyncResult {\n   458→  const root = dir ?? process.cwd();\n   459→\n   460→  // Capture issue data BEFORE closing — listIssues() may exclude closed issues\n   461→  const issues = beadsFns.listIssues();\n   462→  const issue = issues.find(i => i.id === beadsId);\n   463→\n   464→  // Close the beads issue\n   465→  beadsFns.closeIssue(beadsId);\n   466→\n   467→  if (!issue) {\n   468→    return {\n   469→      storyKey: '',\n   470→      beadsId,\n   471→      previousStatus: '',\n   472→      newStatus: 'closed',\n   473→      synced: false,\n   474→      error: `Beads issue not found: ${beadsId}`,\n   475→    };\n   476→  }\n   477→\n   478→  const storyFilePath = resolveStoryFilePath(issue);\n   479→  if (!storyFilePath) {\n   480→    return {\n   481→      storyKey: '',\n   482→      beadsId,\n   483→      previousStatus: issue.status,\n   484→      newStatus: 'closed',\n   485→      synced: false,\n   486→      error: `No story file path in beads issue description: ${beadsId}`,\n   487→    };\n   488→  }\n   489→\n   490→  const storyKey = storyKeyFromPath(storyFilePath);\n   491→  const fullPath = join(root, storyFilePath);\n   492→  const previousStatus = readStoryFileStatus(fullPath);\n   493→\n   494→  if (previousStatus === null) {\n   495→    if (!existsSync(fullPath)) {\n   496→      return {\n   497→        storyKey,\n   498→        beadsId,\n   499→        previousStatus: '',\n   500→        newStatus: 'closed',\n   501→        synced: false,\n   502→        error: `Story file not found: ${storyFilePath}`,\n   503→      };\n   504→    }\n   505→    // File exists but no Status line — insert one\n   506→  }\n   507→\n   508→  updateStoryFileStatus(fullPath, 'done');\n   509→  updateSprintStatus(storyKey, 'done', root);\n   510→\n   511→  return {\n   512→    storyKey,\n   513→    beadsId,\n   514→    previousStatus: previousStatus ?? '',\n   515→    newStatus: 'done',\n   516→    synced: true,\n   517→  };\n   518→}\n   519→\n   520→/**\n   521→ * Syncs all beads issues in the specified direction.\n   522→ * For `bidirectional`, beads is the source of truth (beads status wins on conflict).\n   523→ */\n   524→export function syncAll(\n   525→  direction: SyncDirection,\n   526→  beadsFns: {\n   527→    listIssues: () => BeadsIssue[];\n   528→    updateIssue: (id: string, opts: { status?: string }) => void;\n   529→    closeIssue: (id: string) => void;\n   530→  },\n   531→  dir?: string,\n   532→): SyncResult[] {\n   533→  const root = dir ?? process.cwd();\n   534→  const results: SyncResult[] = [];\n   535→\n   536→  // Single call to listIssues up front\n   537→  let issues: BeadsIssue[];\n   538→  try {\n   539→    issues = beadsFns.listIssues();\n   540→  } catch (err) {\n   541→    const message = err instanceof Error ? err.message : String(err);\n   542→    return [{\n   543→      storyKey: '',\n   544→      beadsId: '',\n   545→      previousStatus: '',\n   546→      newStatus: '',\n   547→      synced: false,\n   548→      error: `Failed to list beads issues: ${message}`,\n   549→    }];\n   550→  }\n   551→\n   552→  // Create a wrapper that returns cached issues\n   553→  const cachedListIssues = () => issues;\n   554→\n   555→  for (const issue of issues) {\n   556→    const storyFilePath = resolveStoryFilePath(issue);\n   557→    if (!storyFilePath) {\n   558→      // Skip issues without story file links (non-story issues from onboard, etc.)\n   559→      continue;\n   560→    }\n   561→\n   562→    const storyKey = storyKeyFromPath(storyFilePath);\n   563→\n   564→    try {\n   565→      if (direction === 'beads-to-files' || direction === 'bidirectional') {\n   566→        const result = syncBeadsToStoryFile(issue.id, { listIssues: cachedListIssues }, root);\n   567→        results.push(result);\n   568→      } else if (direction === 'files-to-beads') {\n   569→        const result = syncStoryFileToBeads(storyKey, {\n   570→          listIssues: cachedListIssues,\n   571→          updateIssue: beadsFns.updateIssue,\n   572→          closeIssue: beadsFns.closeIssue,\n   573→        }, root);\n   574→        results.push(result);\n   575→      }\n   576→    } catch (err) {\n   577→      const message = err instanceof Error ? err.message : String(err);\n   578→      results.push({\n   579→        storyKey,\n   580→        beadsId: issue.id,\n   581→        previousStatus: '',\n   582→        newStatus: '',\n   583→        synced: false,\n   584→        error: message,\n   585→      });\n   586→    }\n   587→  }\n   588→\n   589→  return results;\n   590→}\n   591→"}]},"parent_tool_use_id":"toolu_01JdxXvgowBNhnosQk7Q9BkR","session_id":"849556cc-0fdf-4120-9ec0-a67b358cdbd5","uuid":"7c7569cd-d116-4b0d-adbe-b4259862b391","timestamp":"2026-03-24T12:46:02.415Z"}
