{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018fMUQwLyVKnpeeAapGZ5RW","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, afterEach } from 'vitest';\n     2→import { mkdtempSync, rmSync, writeFileSync, mkdirSync, readFileSync } from 'node:fs';\n     3→import { tmpdir } from 'node:os';\n     4→import { join } from 'node:path';\n     5→import { NodejsProvider } from '../../stacks/nodejs.js';\n     6→\n     7→let testDir: string;\n     8→let provider: NodejsProvider;\n     9→\n    10→beforeEach(() => {\n    11→  testDir = mkdtempSync(join(tmpdir(), 'ch-nodejs-provider-'));\n    12→  provider = new NodejsProvider();\n    13→});\n    14→\n    15→afterEach(() => {\n    16→  rmSync(testDir, { recursive: true, force: true });\n    17→});\n    18→\n    19→// ── Static properties ────────────────────────────────────────────────────────\n    20→\n    21→describe('NodejsProvider — static properties', () => {\n    22→  it('has correct name', () => {\n    23→    expect(provider.name).toBe('nodejs');\n    24→  });\n    25→\n    26→  it('has correct markers', () => {\n    27→    expect(provider.markers).toEqual(['package.json']);\n    28→  });\n    29→\n    30→  it('has correct displayName', () => {\n    31→    expect(provider.displayName).toBe('Node.js (package.json)');\n    32→  });\n    33→});\n    34→\n    35→// ── detectAppType (AC4–AC7) ──────────────────────────────────────────────────\n    36→\n    37→describe('NodejsProvider.detectAppType', () => {\n    38→  it('returns \"agent\" when anthropic is in dependencies (AC4)', () => {\n    39→    writeFileSync(\n    40→      join(testDir, 'package.json'),\n    41→      JSON.stringify({ dependencies: { anthropic: '1.0.0' } }),\n    42→    );\n    43→    expect(provider.detectAppType(testDir)).toBe('agent');\n    44→  });\n    45→\n    46→  it('returns \"agent\" for @anthropic-ai/sdk', () => {\n    47→    writeFileSync(\n    48→      join(testDir, 'package.json'),\n    49→      JSON.stringify({ dependencies: { '@anthropic-ai/sdk': '1.0.0' } }),\n    50→    );\n    51→    expect(provider.detectAppType(testDir)).toBe('agent');\n    52→  });\n    53→\n    54→  it('returns \"agent\" for openai', () => {\n    55→    writeFileSync(\n    56→      join(testDir, 'package.json'),\n    57→      JSON.stringify({ dependencies: { openai: '4.0.0' } }),\n    58→    );\n    59→    expect(provider.detectAppType(testDir)).toBe('agent');\n    60→  });\n    61→\n    62→  it('returns \"agent\" for langchain', () => {\n    63→    writeFileSync(\n    64→      join(testDir, 'package.json'),\n    65→      JSON.stringify({ dependencies: { langchain: '0.1.0' } }),\n    66→    );\n    67→    expect(provider.detectAppType(testDir)).toBe('agent');\n    68→  });\n    69→\n    70→  it('returns \"web\" when react is in dependencies (AC5)', () => {\n    71→    writeFileSync(\n    72→      join(testDir, 'package.json'),\n    73→      JSON.stringify({ dependencies: { react: '18.0.0' } }),\n    74→    );\n    75→    expect(provider.detectAppType(testDir)).toBe('web');\n    76→  });\n    77→\n    78→  it('returns \"web\" for vue', () => {\n    79→    writeFileSync(\n    80→      join(testDir, 'package.json'),\n    81→      JSON.stringify({ dependencies: { vue: '3.0.0' } }),\n    82→    );\n    83→    expect(provider.detectAppType(testDir)).toBe('web');\n    84→  });\n    85→\n    86→  it('returns \"web\" when index.html exists at root', () => {\n    87→    writeFileSync(join(testDir, 'package.json'), JSON.stringify({}));\n    88→    writeFileSync(join(testDir, 'index.html'), '<html></html>');\n    89→    expect(provider.detectAppType(testDir)).toBe('web');\n    90→  });\n    91→\n    92→  it('returns \"web\" when public/index.html exists', () => {\n    93→    writeFileSync(join(testDir, 'package.json'), JSON.stringify({}));\n    94→    mkdirSync(join(testDir, 'public'));\n    95→    writeFileSync(join(testDir, 'public', 'index.html'), '<html></html>');\n    96→    expect(provider.detectAppType(testDir)).toBe('web');\n    97→  });\n    98→\n    99→  it('returns \"cli\" when bin field exists and no start script (AC6)', () => {\n   100→    writeFileSync(\n   101→      join(testDir, 'package.json'),\n   102→      JSON.stringify({ bin: { mycli: './cli.js' } }),\n   103→    );\n   104→    expect(provider.detectAppType(testDir)).toBe('cli');\n   105→  });\n   106→\n   107→  it('returns \"server\" when start script exists, no agent/web deps (AC7)', () => {\n   108→    writeFileSync(\n   109→      join(testDir, 'package.json'),\n   110→      JSON.stringify({ scripts: { start: 'node server.js' } }),\n   111→    );\n   112→    expect(provider.detectAppType(testDir)).toBe('server');\n   113→  });\n   114→\n   115→  it('returns \"server\" when both bin and start exist (start takes priority)', () => {\n   116→    writeFileSync(\n   117→      join(testDir, 'package.json'),\n   118→      JSON.stringify({ bin: { mycli: './cli.js' }, scripts: { start: 'node server.js' } }),\n   119→    );\n   120→    // bin + start => not cli (hasStart is true), falls to server\n   121→    expect(provider.detectAppType(testDir)).toBe('server');\n   122→  });\n   123→\n   124→  it('returns \"generic\" for minimal package.json', () => {\n   125→    writeFileSync(join(testDir, 'package.json'), JSON.stringify({ name: 'empty' }));\n   126→    expect(provider.detectAppType(testDir)).toBe('generic');\n   127→  });\n   128→\n   129→  it('returns \"generic\" when no package.json exists', () => {\n   130→    expect(provider.detectAppType(testDir)).toBe('generic');\n   131→  });\n   132→\n   133→  it('returns \"generic\" for malformed package.json', () => {\n   134→    writeFileSync(join(testDir, 'package.json'), 'not-json');\n   135→    expect(provider.detectAppType(testDir)).toBe('generic');\n   136→  });\n   137→\n   138→  it('agent deps take priority over web deps', () => {\n   139→    writeFileSync(\n   140→      join(testDir, 'package.json'),\n   141→      JSON.stringify({ dependencies: { openai: '1.0.0', react: '18.0.0' } }),\n   142→    );\n   143→    expect(provider.detectAppType(testDir)).toBe('agent');\n   144→  });\n   145→});\n   146→\n   147→// ── getCoverageTool (AC1) ────────────────────────────────────────────────────\n   148→\n   149→describe('NodejsProvider.getCoverageTool', () => {\n   150→  it('returns \"c8\"', () => {\n   151→    expect(provider.getCoverageTool()).toBe('c8');\n   152→  });\n   153→});\n   154→\n   155→// ── detectCoverageConfig (AC2, AC3) ──────────────────────────────────────────\n   156→\n   157→describe('NodejsProvider.detectCoverageConfig', () => {\n   158→  it('detects vitest coverage from vitest.config.ts + @vitest/coverage-v8 (AC2)', () => {\n   159→    writeFileSync(\n   160→      join(testDir, 'package.json'),\n   161→      JSON.stringify({ devDependencies: { '@vitest/coverage-v8': '1.0.0' } }),\n   162→    );\n   163→    writeFileSync(join(testDir, 'vitest.config.ts'), 'export default {}');\n   164→    const result = provider.detectCoverageConfig(testDir);\n   165→    expect(result.tool).toBe('c8');\n   166→    expect(result.configFile).toBeDefined();\n   167→    expect(result.configFile).toContain('vitest.config.ts');\n   168→  });\n   169→\n   170→  it('detects vitest from vitest.config.js', () => {\n   171→    writeFileSync(join(testDir, 'package.json'), JSON.stringify({}));\n   172→    writeFileSync(join(testDir, 'vitest.config.js'), 'module.exports = {}');\n   173→    const result = provider.detectCoverageConfig(testDir);\n   174→    expect(result.tool).toBe('c8');\n   175→    expect(result.configFile).toContain('vitest.config.js');\n   176→  });\n   177→\n   178→  it('detects vitest from @vitest/coverage-istanbul', () => {\n   179→    writeFileSync(\n   180→      join(testDir, 'package.json'),\n   181→      JSON.stringify({ devDependencies: { '@vitest/coverage-istanbul': '1.0.0' } }),\n   182→    );\n   183→    const result = provider.detectCoverageConfig(testDir);\n   184→    expect(result.tool).toBe('c8');\n   185→  });\n   186→\n   187→  it('detects jest and returns c8 (AC3)', () => {\n   188→    writeFileSync(\n   189→      join(testDir, 'package.json'),\n   190→      JSON.stringify({ devDependencies: { jest: '29.0.0' } }),\n   191→    );\n   192→    const result = provider.detectCoverageConfig(testDir);\n   193→    expect(result.tool).toBe('c8');\n   194→  });\n   195→\n   196→  it('detects standalone c8', () => {\n   197→    writeFileSync(\n   198→      join(testDir, 'package.json'),\n   199→      JSON.stringify({ devDependencies: { c8: '8.0.0' } }),\n   200→    );\n   201→    const result = provider.detectCoverageConfig(testDir);\n   202→    expect(result.tool).toBe('c8');\n   203→  });\n   204→\n   205→  it('returns none when no coverage tools found', () => {\n   206→    writeFileSync(\n   207→      join(testDir, 'package.json'),\n   208→      JSON.stringify({ devDependencies: { typescript: '5.0.0' } }),\n   209→    );\n   210→    const result = provider.detectCoverageConfig(testDir);\n   211→    expect(result.tool).toBe('none');\n   212→  });\n   213→\n   214→  it('returns none when no package.json exists', () => {\n   215→    const result = provider.detectCoverageConfig(testDir);\n   216→    expect(result.tool).toBe('none');\n   217→  });\n   218→});\n   219→\n   220→// ── getOtlpPackages (AC8) ────────────────────────────────────────────────────\n   221→\n   222→describe('NodejsProvider.getOtlpPackages', () => {\n   223→  it('returns exact OTLP packages (AC8)', () => {\n   224→    expect(provider.getOtlpPackages()).toEqual([\n   225→      '@opentelemetry/auto-instrumentations-node',\n   226→      '@opentelemetry/sdk-node',\n   227→      '@opentelemetry/exporter-trace-otlp-http',\n   228→      '@opentelemetry/exporter-metrics-otlp-http',\n   229→    ]);\n   230→  });\n   231→\n   232→  it('returns a new array each time (not shared reference)', () => {\n   233→    const a = provider.getOtlpPackages();\n   234→    const b = provider.getOtlpPackages();\n   235→    expect(a).not.toBe(b);\n   236→    expect(a).toEqual(b);\n   237→  });\n   238→});\n   239→\n   240→// ── getDockerfileTemplate (AC9) ──────────────────────────────────────────────\n   241→\n   242→describe('NodejsProvider.getDockerfileTemplate', () => {\n   243→  it('contains FROM node:22-slim (AC9)', () => {\n   244→    const template = provider.getDockerfileTemplate();\n   245→    expect(template).toContain('FROM node:22-slim');\n   246→  });\n   247→\n   248→  it('contains npm install -g (AC9)', () => {\n   249→    const template = provider.getDockerfileTemplate();\n   250→    expect(template).toContain('npm install -g');\n   251→  });\n   252→\n   253→  it('contains USER node (AC9)', () => {\n   254→    const template = provider.getDockerfileTemplate();\n   255→    expect(template).toContain('USER node');\n   256→  });\n   257→});\n   258→\n   259→// ── getDockerBuildStage (AC10) ───────────────────────────────────────────────\n   260→\n   261→describe('NodejsProvider.getDockerBuildStage', () => {\n   262→  it('contains FROM node:22-slim AS build-nodejs (AC10)', () => {\n   263→    const stage = provider.getDockerBuildStage();\n   264→    expect(stage).toContain('FROM node:22-slim AS build-nodejs');\n   265→  });\n   266→\n   267→  it('contains npm ci --production (AC10)', () => {\n   268→    const stage = provider.getDockerBuildStage();\n   269→    expect(stage).toContain('npm ci --production');\n   270→  });\n   271→});\n   272→\n   273→// ── getRuntimeCopyDirectives (AC11) ──────────────────────────────────────────\n   274→\n   275→describe('NodejsProvider.getRuntimeCopyDirectives', () => {\n   276→  it('contains COPY --from=build-nodejs (AC11)', () => {\n   277→    const directives = provider.getRuntimeCopyDirectives();\n   278→    expect(directives).toContain('COPY --from=build-nodejs');\n   279→  });\n   280→\n   281→  it('copies node_modules and app', () => {\n   282→    const directives = provider.getRuntimeCopyDirectives();\n