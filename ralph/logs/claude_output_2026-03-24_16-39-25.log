{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013z4tN9DTH4zBeetfhxY5bQ","type":"tool_result","content":"     1→import { existsSync, readFileSync, writeFileSync } from 'node:fs';\n     2→import type { BeadsIssue } from '../beads.js';\n     3→\n     4→/**\n     5→ * Extracts story file path from beads issue description field.\n     6→ * The bridge command sets description = story file path.\n     7→ * Returns null if description doesn't contain a valid path.\n     8→ */\n     9→export function resolveStoryFilePath(beadsIssue: BeadsIssue): string | null {\n    10→  const desc = beadsIssue.description;\n    11→  if (!desc || !desc.trim()) {\n    12→    return null;\n    13→  }\n    14→  const trimmed = desc.trim();\n    15→  if (!trimmed.endsWith('.md')) {\n    16→    return null;\n    17→  }\n    18→  return trimmed;\n    19→}\n    20→\n    21→/**\n    22→ * Reads the `Status:` line from a story markdown file.\n    23→ * Returns null if file doesn't exist or has no Status line.\n    24→ */\n    25→export function readStoryFileStatus(filePath: string): string | null {\n    26→  if (!existsSync(filePath)) {\n    27→    return null;\n    28→  }\n    29→  const content = readFileSync(filePath, 'utf-8');\n    30→  const match = content.match(/^Status:\\s*(.+)$/m);\n    31→  if (!match) {\n    32→    return null;\n    33→  }\n    34→  return match[1].trim();\n    35→}\n    36→\n    37→/**\n    38→ * Updates the `Status:` line in a story markdown file in-place.\n    39→ * If no `Status:` line exists, inserts one after the title line.\n    40→ */\n    41→export function updateStoryFileStatus(filePath: string, newStatus: string): void {\n    42→  const content = readFileSync(filePath, 'utf-8');\n    43→  const statusRegex = /^Status:\\s*.+$/m;\n    44→\n    45→  if (statusRegex.test(content)) {\n    46→    const updated = content.replace(statusRegex, `Status: ${newStatus}`);\n    47→    writeFileSync(filePath, updated, 'utf-8');\n    48→  } else {\n    49→    const lines = content.split('\\n');\n    50→    const titleIndex = lines.findIndex(l => l.startsWith('# '));\n    51→    if (titleIndex !== -1) {\n    52→      lines.splice(titleIndex + 1, 0, '', `Status: ${newStatus}`);\n    53→    } else {\n    54→      lines.unshift(`Status: ${newStatus}`, '');\n    55→    }\n    56→    writeFileSync(filePath, lines.join('\\n'), 'utf-8');\n    57→  }\n    58→}\n    59→"}]},"parent_tool_use_id":"toolu_01JdxXvgowBNhnosQk7Q9BkR","session_id":"849556cc-0fdf-4120-9ec0-a67b358cdbd5","uuid":"9dd9b560-c544-4884-ace4-c655519ad2a5","timestamp":"2026-03-24T13:03:50.234Z"}
