{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014zXyy612tNvenEMBrhdvWJ","type":"tool_result","content":"1\t/**\n2\t * Sprint module — story selection, status tracking, reporting.\n3\t */\n4\t\n5\timport { ok, fail } from '../../types/result.js';\n6\timport type { Result } from '../../types/result.js';\n7\timport type { StoryStatus } from '../../types/state.js';\n8\timport type { SprintState } from '../../types/state.js';\n9\timport type {\n10\t  StorySelection,\n11\t  StoryDetail,\n12\t  StatusReport,\n13\t  SelectionResult,\n14\t  FailedStoryDetail,\n15\t  LabeledActionItem,\n16\t  RunSummary,\n17\t  StoryDrillDown,\n18\t  TimeoutReport,\n19\t  TimeoutCapture,\n20\t  FeedbackResult,\n21\t  FailingAc,\n22\t  TimeoutSummary,\n23\t  RunProgressUpdate,\n24\t} from './types.js';\n25\timport {\n26\t  getSprintState as getSprintStateImpl,\n27\t  updateStoryStatus as updateStoryStatusImpl,\n28\t  writeStateAtomic as writeStateAtomicImpl,\n29\t  computeSprintCounts as computeSprintCountsImpl,\n30\t  updateRunProgress as updateRunProgressImpl,\n31\t  clearRunProgress as clearRunProgressImpl,\n32\t  generateSprintStatusYaml as generateSprintStatusYamlImpl,\n33\t  getStoryStatusesFromState as getStoryStatusesFromStateImpl,\n34\t  reconcileState as reconcileStateImpl,\n35\t  registerStory as registerStoryImpl,\n36\t} from './state.js';\n37\timport type { ReconciliationResult } from './state.js';\n38\timport { selectNextStory } from './selector.js';\n39\timport { generateReport as generateReportImpl, getStoryDrillDown as getStoryDrillDownImpl } from './reporter.js';\n40\timport { captureTimeoutReport as captureTimeoutReportImpl, findLatestTimeoutReport as findLatestTimeoutReportImpl } from './timeout.js';\n41\timport { processVerifyResult as processVerifyResultImpl } from './feedback.js';\n42\timport { validateStateConsistency as validateStateConsistencyImpl } from './validator.js';\n43\timport type { ValidationReport, ValidationIssue } from './validator.js';\n44\timport { shouldDeferPhase as shouldDeferPhaseImpl, getPhaseEstimate as getPhaseEstimateImpl, computeRemainingMinutes as computeRemainingMinutesImpl, PHASE_ESTIMATES } from './budget.js';\n45\t\n46\texport type {\n47\t  StorySelection,\n48\t  StoryDetail,\n49\t  StatusReport,\n50\t  SelectionResult,\n51\t  FailedStoryDetail,\n52\t  LabeledActionItem,\n53\t  RunSummary,\n54\t  StoryDrillDown,\n55\t  TimeoutReport,\n56\t  TimeoutCapture,\n57\t  TimeoutSummary,\n58\t  FeedbackResult,\n59\t  FailingAc,\n60\t  RunProgressUpdate,\n61\t};\n62\t\n63\texport type { ValidationReport, ValidationIssue };\n64\texport type { ReconciliationResult };\n65\t\n66\t/**\n67\t * Select the next actionable story.\n68\t * Also marks retry-exhausted stories as blocked (AC #2).\n69\t */\n70\texport function getNextStory(): Result<SelectionResult> {\n71\t  const stateResult = getSprintStateImpl();\n72\t  if (!stateResult.success) {\n73\t    return fail(stateResult.error);\n74\t  }\n75\t\n76\t  const selectionResult = selectNextStory(stateResult.data);\n77\t  if (!selectionResult.success) {\n78\t    return fail(selectionResult.error);\n79\t  }\n80\t\n81\t  // Side-effect: mark retry-exhausted stories as blocked (AC #2)\n82\t  for (const exhausted of selectionResult.data.retryExhausted) {\n83\t    updateStoryStatusImpl(exhausted.key, 'blocked', {\n84\t      error: 'retry-exhausted',\n85\t    });\n86\t  }\n87\t\n88\t  return ok(selectionResult.data);\n89\t}\n90\t\n91\texport function updateStoryStatus(\n92\t  key: string,\n93\t  status: StoryStatus,\n94\t  detail?: StoryDetail,\n95\t): Result<void> {\n96\t  return updateStoryStatusImpl(key, status, detail);\n97\t}\n98\t\n99\texport function registerStory(key: string): Result<void> {\n100\t  return registerStoryImpl(key);\n101\t}\n102\t\n103\texport function getSprintState(): Result<SprintState> {\n104\t  return getSprintStateImpl();\n105\t}\n106\t\n107\texport function generateReport(): Result<StatusReport> {\n108\t  const stateResult = getSprintStateImpl();\n109\t  if (!stateResult.success) {\n110\t    return fail(stateResult.error);\n111\t  }\n112\t  return generateReportImpl(stateResult.data);\n113\t}\n114\t\n115\texport function getStoryDrillDown(key: string): Result<StoryDrillDown> {\n116\t  const stateResult = getSprintStateImpl();\n117\t  if (!stateResult.success) {\n118\t    return fail(stateResult.error);\n119\t  }\n120\t\n121\t  // Look up latest timeout report for this story\n122\t  const timeoutResult = findLatestTimeoutReportImpl(key);\n123\t  const timeoutSummary = timeoutResult.success ? timeoutResult.data : null;\n124\t\n125\t  return getStoryDrillDownImpl(stateResult.data, key, { timeoutSummary });\n126\t}\n127\t\n128\texport function captureTimeoutReport(opts: {\n129\t  storyKey: string;\n130\t  iteration: number;\n131\t  durationMinutes: number;\n132\t  outputFile: string;\n133\t  stateSnapshotPath: string;\n134\t}): Result<TimeoutReport> {\n135\t  return captureTimeoutReportImpl(opts);\n136\t}\n137\t\n138\texport function processVerifyResult(\n139\t  storyKey: string,\n140\t  opts?: { maxAttempts?: number },\n141\t): Result<FeedbackResult> {\n142\t  return processVerifyResultImpl(storyKey, opts);\n143\t}\n144\t\n145\texport function validateStateConsistency(\n146\t  statePath: string,\n147\t  sprintStatusPath: string,\n148\t): Result<ValidationReport> {\n149\t  return validateStateConsistencyImpl(statePath, sprintStatusPath);\n150\t}\n151\t\n152\texport function writeStateAtomic(state: SprintState): Result<void> {\n153\t  return writeStateAtomicImpl(state);\n154\t}\n155\t\n156\texport function computeSprintCounts(\n157\t  stories: Record<string, import('../../types/state.js').StoryState>,\n158\t): SprintState['sprint'] {\n159\t  return computeSprintCountsImpl(stories);\n160\t}\n161\t\n162\texport function updateRunProgress(update: RunProgressUpdate): Result<void> {\n163\t  return updateRunProgressImpl(update);\n164\t}\n165\t\n166\texport function clearRunProgress(): Result<void> {\n167\t  return clearRunProgressImpl();\n168\t}\n169\t\n170\texport function generateSprintStatusYaml(state: SprintState): string {\n171\t  return generateSprintStatusYamlImpl(state);\n172\t}\n173\t\n174\texport function getStoryStatusesFromState(state: SprintState): Record<string, string> {\n175\t  return getStoryStatusesFromStateImpl(state);\n176\t}\n177\t\n178\t/**\n179\t * Reconcile sprint state on session start.\n180\t * Merges orphaned files, validates epic consistency, regenerates YAML.\n181\t */\n182\texport function reconcileState(): Result<ReconciliationResult> {\n183\t  return reconcileStateImpl();\n184\t}\n185\t\n186\t/**\n187\t * Read sprint state and derive story statuses as a flat map.\n188\t * Drop-in replacement for the old readSprintStatus() that parsed YAML.\n189\t * Falls back to parsing sprint-status.yaml if sprint-state.json has no stories\n190\t * (handles projects that haven't been migrated to unified state yet).\n191\t */\n192\texport function readSprintStatusFromState(): Record<string, string> {\n193\t  const stateResult = getSprintStateImpl();\n194\t  if (!stateResult.success) return {};\n195\t  const statuses = getStoryStatusesFromStateImpl(stateResult.data);\n196\t  return statuses;\n197\t}\n198\t\n199\t// ── Budget awareness ────────────────────────────────────────────────────────\n200\t\n201\texport { PHASE_ESTIMATES };\n202\t\n203\texport function shouldDeferPhase(phase: string, remainingMinutes: number): boolean {\n204\t  return shouldDeferPhaseImpl(phase, remainingMinutes);\n205\t}\n206\t\n207\texport function getPhaseEstimate(phase: string): number {\n208\t  return getPhaseEstimateImpl(phase);\n209\t}\n210\t\n211\texport function computeRemainingMinutes(sessionStartMs: number, totalBudgetMinutes: number): number {\n212\t  return computeRemainingMinutesImpl(sessionStartMs, totalBudgetMinutes);\n213\t}\n214\t"}]},"parent_tool_use_id":"toolu_01YVAicDPB2Xe9r2bfCAtkWv","session_id":"1e0d780f-040f-4c10-b8e5-df49ae6fae2c","uuid":"d0