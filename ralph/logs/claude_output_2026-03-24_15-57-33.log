Tool(testDir);\n   140ŌåÆ    expect(result.tool).toBe('unknown');\n   141ŌåÆ  });\n   142ŌåÆ\n   143ŌåÆ  it('CoverageToolInfo type accepts cargo-tarpaulin', () => {\n   144ŌåÆ    const info: CoverageToolInfo = {\n   145ŌåÆ      tool: 'cargo-tarpaulin',\n   146ŌåÆ      runCommand: 'cargo tarpaulin --out json',\n   147ŌåÆ      reportFormat: 'tarpaulin-json',\n   148ŌåÆ    };\n   149ŌåÆ    expect(info.tool).toBe('cargo-tarpaulin');\n   150ŌåÆ  });\n   151ŌåÆ\n   152ŌåÆ  it('detects cargo-tarpaulin for rust project with Cargo.toml when tarpaulin installed (AC1)', () => {\n   153ŌåÆ    writeFileSync(join(testDir, 'Cargo.toml'), '[package]\\nname = \"my-crate\"\\nversion = \"0.1.0\"\\n');\n   154ŌåÆ\n   155ŌåÆ    mockedExecSync.mockImplementation((cmd: unknown) => {\n   156ŌåÆ      if (typeof cmd === 'string' && cmd.includes('cargo tarpaulin --version')) {\n   157ŌåÆ        return Buffer.from('cargo-tarpaulin 0.27.0');\n   158ŌåÆ      }\n   159ŌåÆ      return Buffer.from('');\n   160ŌåÆ    });\n   161ŌåÆ\n   162ŌåÆ    const result = detectCoverageTool(testDir);\n   163ŌåÆ    expect(result.tool).toBe('cargo-tarpaulin');\n   164ŌåÆ    expect(result.runCommand).toBe('cargo tarpaulin --out json --output-dir coverage/');\n   165ŌåÆ    expect(result.reportFormat).toBe('tarpaulin-json');\n   166ŌåÆ  });\n   167ŌåÆ\n   168ŌåÆ  it('returns unknown for rust project when tarpaulin not installed (AC5)', () => {\n   169ŌåÆ    writeFileSync(join(testDir, 'Cargo.toml'), '[package]\\nname = \"my-crate\"\\nversion = \"0.1.0\"\\n');\n   170ŌåÆ\n   171ŌåÆ    mockedExecSync.mockImplementation((cmd: unknown) => {\n   172ŌåÆ      if (typeof cmd === 'string' && cmd.includes('cargo tarpaulin --version')) {\n   173ŌåÆ        throw new Error('command not found: cargo-tarpaulin');\n   174ŌåÆ      }\n   175ŌåÆ      return Buffer.from('');\n   176ŌåÆ    });\n   177ŌåÆ\n   178ŌåÆ    const result = detectCoverageTool(testDir);\n   179ŌåÆ    expect(result.tool).toBe('unknown');\n   180ŌåÆ    expect(resu