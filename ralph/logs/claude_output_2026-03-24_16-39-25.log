{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011fSVcJjcUzg5YCD7KxyCcc","type":"tool_result","content":"     1→import { execFileSync } from 'node:child_process';\n     2→import { writeFileSync } from 'node:fs';\n     3→import { getComposeFilePath, getOtelConfigPath, ensureStackDir } from './stack-path.js';\n     4→import { dockerComposeTemplate, dockerComposeCollectorOnlyTemplate } from '../templates/docker-compose.js';\n     5→import { otelCollectorConfigTemplate, otelCollectorRemoteTemplate } from '../templates/otel-config.js';\n     6→\n     7→export interface DockerServiceStatus {\n     8→  name: string;\n     9→  status: string;\n    10→  port: string;\n    11→}\n    12→\n    13→export interface DockerStartResult {\n    14→  started: boolean;\n    15→  services: DockerServiceStatus[];\n    16→  error?: string;\n    17→}\n    18→\n    19→export interface DockerHealthService {\n    20→  name: string;\n    21→  running: boolean;\n    22→}\n    23→\n    24→export interface DockerHealthResult {\n    25→  healthy: boolean;\n    26→  services: DockerHealthService[];\n    27→  remedy?: string;\n    28→}\n    29→\n    30→export function isDockerAvailable(): boolean {\n    31→  try {\n    32→    execFileSync('docker', ['--version'], { stdio: 'pipe', timeout: 10_000 });\n    33→    return true;\n    34→  } catch {\n    35→    return false;\n    36→  }\n    37→}\n    38→\n    39→export function isDockerComposeAvailable(): boolean {\n    40→  try {\n    41→    execFileSync('docker', ['compose', 'version'], { stdio: 'pipe', timeout: 10_000 });\n    42→    return true;\n    43→  } catch {\n    44→    return false;\n    45→  }\n    46→}\n    47→\n    48→export function isStackRunning(composeFile: string): boolean {\n    49→  try {\n    50→    const output = execFileSync('docker', ['compose', '-f', composeFile, 'ps', '--format', 'json'], {\n    51→      stdio: 'pipe',\n    52→      timeout: 15_000,\n    53→    });\n    54→    const text = output.toString().trim();\n    55→    if (!text) return false;\n    56→\n    57→    // docker compose ps --format json outputs one JSON object per line\n    58→    const lines = text.split('\\n').filter(l => l.trim());\n    59→    for (const line of lines) {\n    60→      const svc = JSON.parse(line) as { State?: string };\n    61→      if (svc.State !== 'running') return false;\n    62→    }\n    63→    return lines.length > 0;\n    64→  } catch {\n    65→    return false;\n    66→  }\n    67→}\n    68→\n    69→export function isSharedStackRunning(): boolean {\n    70→  try {\n    71→    const composeFile = getComposeFilePath();\n    72→    const output = execFileSync('docker', ['compose', '-p', 'codeharness-shared', '-f', composeFile, 'ps', '--format', 'json'], {\n    73→      stdio: 'pipe',\n    74→      timeout: 15_000,\n    75→    });\n    76→    const text = output.toString().trim();\n    77→    if (!text) return false;\n    78→\n    79→    const lines = text.split('\\n').filter(l => l.trim());\n    80→    for (const line of lines) {\n    81→      const svc = JSON.parse(line) as { State?: string };\n    82→      if (svc.State !== 'running') return false;\n    83→    }\n    84→    return lines.length > 0;\n    85→  } catch {\n    86→    return false;\n    87→  }\n    88→}\n    89→\n    90→export function startStack(composeFile: string): DockerStartResult {\n    91→  try {\n    92→    execFileSync('docker', ['compose', '-f', composeFile, 'up', '-d'], {\n    93→      stdio: 'pipe',\n    94→      timeout: 30_000,\n    95→    });\n    96→\n    97→    const services = getRunningServices(composeFile);\n    98→    return {\n    99→      started: true,\n   100→      services,\n   101→    };\n   102→  } catch (err) {\n   103→    const message = err instanceof Error ? err.message : String(err);\n   104→    return {\n   105→      started: false,\n   106→      services: [],\n   107→      error: message,\n   108→    };\n   109→  }\n   110→}\n   111→\n   112→export function startSharedStack(): DockerStartResult {\n   113→  try {\n   114→    ensureStackDir();\n   115→\n   116→    const composeFile = getComposeFilePath();\n   117→    const otelConfigFile = getOtelConfigPath();\n   118→\n   119→    const composeContent = dockerComposeTemplate({ shared: true });\n   120→    writeFileSync(composeFile, composeContent, 'utf-8');\n   121→\n   122→    const otelContent = otelCollectorConfigTemplate();\n   123→    writeFileSync(otelConfigFile, otelContent, 'utf-8');\n   124→\n   125→    execFileSync('docker', ['compose', '-p', 'codeharness-shared', '-f', composeFile, 'up', '-d'], {\n   126→      stdio: 'pipe',\n   127→      timeout: 30_000,\n   128→    });\n   129→\n   130→    const services = getRunningServices(composeFile, 'codeharness-shared');\n   131→    return {\n   132→      started: true,\n   133→      services,\n   134→    };\n   135→  } catch (err) {\n   136→    const message = err instanceof Error ? err.message : String(err);\n   137→    return {\n   138→      started: false,\n   139→      services: [],\n   140→      error: message,\n   141→    };\n   142→  }\n   143→}\n   144→\n   145→export function stopStack(composeFile: string): void {\n   146→  execFileSync('docker', ['compose', '-f', composeFile, 'down', '-v'], {\n   147→    stdio: 'pipe',\n   148→    timeout: 30_000,\n   149→  });\n   150→}\n   151→\n   152→export function stopSharedStack(): void {\n   153→  const composeFile = getComposeFilePath();\n   154→  execFileSync('docker', ['compose', '-p', 'codeharness-shared', '-f', composeFile, 'down'], {\n   155→    stdio: 'pipe',\n   156→    timeout: 30_000,\n   157→  });\n   158→}\n   159→\n   160→export interface RemoteEndpointCheckResult {\n   161→  reachable: boolean;\n   162→  error?: string;\n   163→}\n   164→\n   165→export function startCollectorOnly(logsUrl: string, metricsUrl: string, tracesUrl: string): DockerStartResult {\n   166→  try {\n   167→    ensureStackDir();\n   168→\n   169→    const composeFile = getComposeFilePath();\n   170→    const otelConfigFile = getOtelConfigPath();\n   171→\n   172→    const composeContent = dockerComposeCollectorOnlyTemplate();\n   173→    writeFileSync(composeFile, composeContent, 'utf-8');\n   174→\n   175→    const otelContent = otelCollectorRemoteTemplate({ logsUrl, metricsUrl, tracesUrl });\n   176→    writeFileSync(otelConfigFile, otelContent, 'utf-8');\n   177→\n   178→    execFileSync('docker', ['compose', '-p', 'codeharness-collector', '-f', composeFile, 'up', '-d'], {\n   179→      stdio: 'pipe',\n   180→      timeout: 30_000,\n   181→    });\n   182→\n   183→    const services = getRunningServices(composeFile, 'codeharness-collector');\n   184→    return {\n   185→      started: true,\n   186→      services,\n   187→    };\n   188→  } catch (err) {\n   189→    const message = err instanceof Error ? err.message : String(err);\n   190→    return {\n   191→      started: false,\n   192→      services: [],\n   193→      error: message,\n   194→    };\n   195→  }\n   196→}\n   197→\n   198→export function isCollectorRunning(): boolean {\n   199→  try {\n   200→    const composeFile = getComposeFilePath();\n   201→    const output = execFileSync('docker', ['compose', '-p', 'codeharness-collector', '-f', composeFile, 'ps', '--format', 'json'], {\n   202→      stdio: 'pipe',\n   203→      timeout: 15_000,\n   204→    });\n   205→    const text = output.toString().trim();\n   206→    if (!text) return false;\n   207→\n   208→    const lines = text.split('\\n').filter(l => l.trim());\n   209→    for (const line of lines) {\n   210→      const svc = JSON.parse(line) as { State?: string };\n   211→      if (svc.State !== 'running') return false;\n   212→    }\n   213→    return lines.length > 0;\n   214→  } catch {\n   215→    return false;\n   216→  }\n   217→}\n   218→\n   219→export function stopCollectorOnly(): void {\n   220→  const composeFile = getComposeFilePath();\n   221→  execFileSync('docker', ['compose', '-p', 'codeharness-collector', '-f', composeFile, 'down'], {\n   222→    stdio: 'pipe',\n   223→    timeout: 30_000,\n   224→  });\n   225→}\n   226→\n   227→export function getCollectorHealth(composeFile: string): DockerHealthResult {\n   228→  const expectedServices = ['otel-collector'];\n   229→\n   230→  try {\n   231→    const output = execFileSync('docker', ['compose', '-p', 'codeharness-collector', '-f', composeFile, 'ps', '--format', 'json'], {\n   232→      stdio: 'pipe',\n   233→      timeout: 15_000,\n   234→    });\n   235→    const text = output.toString().trim();\n   236→    const runningNames = new Set<string>();\n   237→\n   238→    if (text) {\n   239→      const lines = text.split('\\n').filter(l => l.trim());\n   240→      for (const line of lines) {\n   241→        const svc = JSON.parse(line) as { Service?: string; State?: string };\n   242→        if (svc.State === 'running' && svc.Service) {\n   243→          runningNames.add(svc.Service);\n   244→        }\n   245→      }\n   246→    }\n   247→\n   248→    const services: DockerHealthService[] = expectedServices.map(name => ({\n   249→      name,\n   250→      running: runningNames.has(name),\n   251→    }));\n   252→\n   253→    const healthy = services.every(s => s.running);\n   254→\n   255→    return {\n   256→      healthy,\n   257→      services,\n   258→      remedy: healthy ? undefined : `Restart: docker compose -p codeharness-collector -f ${composeFile} up -d`,\n   259→    };\n   260→  } catch {\n   261→    const services: DockerHealthService[] = expectedServices.map(name => ({\n   262→      name,\n   263→      running: false,\n   264→    }));\n   265→\n   266→    return {\n   267→      healthy: false,\n   268→      services,\n   269→      remedy: `Restart: docker compose -p codeharness-collector -f ${composeFile} up -d`,\n   270→    };\n   271→  }\n   272→}\n   273→\n   274→export async function checkRemoteEndpoint(url: string): Promise<RemoteEndpointCheckResult> {\n   275→  try {\n   276→    const controller = new AbortController();\n   277→    const timeout = setTimeout(() => controller.abort(), 5000);\n   278→    try {\n   279→      await fetch(url, { signal: controller.signal });\n   280→      return { reachable: true };\n   281→    } finally {\n   282→      clearTimeout(timeout);\n   283→    }\n   284→  } catch (err) {\n   285→    const message = err instanceof Error ? err.message : String(err);\n   286→    return { reachable: false, error: message };\n   287→  }\n   288→}\n   289→\n   290→export function getStackHealth(composeFile: string, projectName?: string): DockerHealthResult {\n   291→  const expectedServices = ['victoria-logs', 'victoria-metrics', 'victoria-traces', 'otel-collector'];\n   292→\n   293→  try {\n   294→    const args = projectName\n   295→      ? ['compose', '-p', projectName, '-f', composeFile, 'ps', '--format', 'json']\n   296→      : ['compose', '-f', composeFile, 'ps', '--format', 'json'];\n   297→\n   298→    const output = execFileSync('docker', args, {\n   299→      stdio: 'pipe',\n   300→      timeout: 15_000,\n   301→    });\n   302→    const text = output.toString().trim();\n   303→    const runningNames = new Set<string>();\n   304→\n   305→    if (text) {\n   306→      const lines = text.split('\\n').filter(l => l.trim());\n   307→      for (const line of lines) {\n   308→        const svc = JSON.parse(line) as { Service?: string; State?: string };\n   309→        if (svc.State === 'running' && svc.Service) {\n   310→          runningNames.add(svc.Service);\n   311→        }\n   312→      }\n   313→    }\n   314→\n   315→    const services: DockerHealthService[] = expectedServices.map(name => ({\n   316→      name,\n   317→      running: runningNames.has(name),\n   318→    }));\n   319→\n   320→    const healthy = services.every(s => s.running);\n   321→    const remedyCmd = projectName\n   322→      ? `docker compose -p ${projectName} -f ${composeFile} up -d`\n   323→      : `docker compose -f ${composeFile} up -d`;\n   324→\n   325→    return {\n   326→      healthy,\n   327→      services,\n   328→      remedy: healthy ? undefined : `Restart: ${remedyCmd}`,\n   329→    };\n   330→  } catch {\n   331→    const remedyCmd = projectName\n   332→      ? `docker compose -p ${projectName} -f ${composeFile} up -d`\n   333→      : `docker compose -f ${composeFile} up -d`;\n   334→\n   335→    const services: DockerHealthService[] = expectedServices.map(name => ({\n   336→      name,\n   337→      running: false,\n   338→    }));\n   339→\n   340→    return {\n   341→      healthy: false,\n   342→      services,\n   343→      remedy: `Restart: ${remedyCmd}`,\n   344→    };\n   345→  }\n   346→}\n   347→\n   348→function getRunningServices(composeFile: string, projectName?: string): DockerServiceStatus[] {\n   349→  try {\n   350→    const args = projectName\n   351→      ? ['compose', '-p', projectName, '-f', composeFile, 'ps', '--format', 'json']\n   352→      : ['compose', '-f', composeFile, 'ps', '--format', 'json'];\n   353→\n   354→    const output = execFileSync('docker', args, {\n   355→      stdio: 'pipe',\n   356→      timeout: 15_000,\n   357→    });\n   358→    const text = output.toString().trim();\n   359→    if (!text) return [];\n   360→\n   361→    const lines = text.split('\\n').filter(l => l.trim());\n   362→    const services: DockerServiceStatus[] = [];\n   363→    for (const line of lines) {\n   364→      const svc = JSON.parse(line) as { Service?: string; State?: string; Publishers?: Array<{ PublishedPort?: number }> };\n   365→      const ports = (svc.Publishers ?? [])\n   366→        .filter(p => p.PublishedPort && p.PublishedPort > 0)\n   367→        .map(p => String(p.PublishedPort));\n   368→      services.push({\n   369→        name: svc.Service ?? 'unknown',\n   370→        status: svc.State ?? 'unknown',\n   371→        port: ports.join(','),\n   372→      });\n   373→    }\n   374→    return services;\n   375→  } catch {\n   376→    return [];\n   377→  }\n   378→}\n   379→"}]},"