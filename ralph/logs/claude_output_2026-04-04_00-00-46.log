{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Dz48cNjKMfXUXV1QDosHU6","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, type Mock } from 'vitest';\n2\timport { WorktreeManager, WorktreeError, BRANCH_PREFIX, WORKTREE_BASE } from '../worktree-manager.js';\n3\timport type { WorktreeInfo } from '../worktree-manager.js';\n4\t\n5\t// Mock child_process\n6\tvi.mock('node:child_process', () => ({\n7\t  execSync: vi.fn(),\n8\t}));\n9\t\n10\t// Mock node:fs\n11\tvi.mock('node:fs', () => ({\n12\t  existsSync: vi.fn(),\n13\t  readFileSync: vi.fn(),\n14\t  statSync: vi.fn(),\n15\t}));\n16\t\n17\timport { execSync } from 'node:child_process';\n18\timport { existsSync, readFileSync, statSync } from 'node:fs';\n19\t\n20\tconst mockExecSync = execSync as Mock;\n21\tconst mockExistsSync = existsSync as Mock;\n22\tconst mockReadFileSync = readFileSync as Mock;\n23\tconst mockStatSync = statSync as Mock;\n24\t\n25\tdescribe('worktree-manager', () => {\n26\t  let manager: WorktreeManager;\n27\t\n28\t  beforeEach(() => {\n29\t    vi.clearAllMocks();\n30\t    manager = new WorktreeManager('main', '/repo');\n31\t    // Default: no stale state exists\n32\t    mockExistsSync.mockReturnValue(false);\n33\t    // Default: no existing branches\n34\t    mockExecSync.mockReturnValue(Buffer.from(''));\n35\t    // Default: statSync returns a fixed birthtime\n36\t    mockStatSync.mockReturnValue({ birthtime: new Date('2026-01-15T10:00:00Z') });\n37\t  });\n38\t\n39\t  describe('WorktreeError', () => {\n40\t    it('includes stderr in the error (AC #11)', () => {\n41\t      const err = new WorktreeError('something failed', 'fatal: not a git repo');\n42\t      expect(err).toBeInstanceOf(Error);\n43\t      expect(err.name).toBe('WorktreeError');\n44\t      expect(err.message).toBe('something failed');\n45\t      expect(err.stderr).toBe('fatal: not a git repo');\n46\t    });\n47\t  });\n48\t\n49\t  describe('constants', () => {\n50\t    it('branch prefix uses codeharness/ namespace (NFR12)', () => {\n51\t      expect(BRANCH_PREFIX).toBe('codeharness/epic-');\n52\t      expect(BRANCH_PREFIX.startsWith('codeharness/')).toBe(true);\n53\t    });\n54\t\n55\t    it('worktree base is in /tmp', () => {\n56\t      expect(WORKTREE_BASE).toBe('/tmp/codeharness-wt-epic-');\n57\t    });\n58\t  });\n59\t\n60\t  describe('createWorktree', () => {"}]},"parent_tool_use_id":"toolu_01J5dz8FwhQ5vQhY4hrEgpDq","session_id":"5f276c07-4ea2-4b01-86c9-d8e4e30ebe94","uuid":"0ca5390e-9acb-4f4a-a3cd-67a237e71a84","timestamp":"2026-04-03T20:06:27.808Z"}
