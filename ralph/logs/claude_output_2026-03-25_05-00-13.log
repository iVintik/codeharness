{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015EPwug7kJ4kaPkxw2dXgdq","type":"tool_result","content":"     1→/**\n     2→ * Boundary test — enforces NFR4: no direct stack conditionals outside src/lib/stacks/.\n     3→ *\n     4→ * Scans all .ts files in src/ (excluding src/lib/stacks/) for patterns that indicate\n     5→ * leaked stack abstraction: direct stack name comparisons and legacy imports.\n     6→ */\n     7→\n     8→import { describe, it, expect } from 'vitest';\n     9→import { readdirSync, readFileSync, statSync } from 'node:fs';\n    10→import { join, relative } from 'node:path';\n    11→\n    12→const SRC_DIR = join(__dirname, '..', '..', '..');\n    13→const STACKS_DIR = join(SRC_DIR, 'lib', 'stacks');\n    14→\n    15→/**\n    16→ * Files that are intentional exceptions to the boundary check.\n    17→ * These use AppType / PromptProjectType / ProjectType comparisons,\n    18→ * NOT StackName comparisons. Documented here per AC17.\n    19→ */\n    20→const ALLOWED_EXCEPTIONS = new Set([\n    21→  // verify-prompt.ts uses PromptProjectType ('nodejs' | 'python' | 'plugin' | 'generic'),\n    22→  // not StackName. The comparisons are for display logic, not stack dispatch.\n    23→  'templates/verify-prompt.ts',\n    24→]);\n    25→\n    26→/** Stack comparison patterns that should not appear outside src/lib/stacks/. */\n    27→const FORBIDDEN_PATTERNS = [\n    28→  /stack\\s*===\\s*'nodejs'/,\n    29→  /stack\\s*===\\s*'python'/,\n    30→  /stack\\s*===\\s*'rust'/,\n    31→  /===\\s*'nodejs'/,\n    32→  /===\\s*'python'/,\n    33→  /===\\s*'rust'/,\n    34→];\n    35→\n    36→/** Legacy import pattern that should not appear after migration. */\n    37→const LEGACY_IMPORT_PATTERN = /from\\s+['\"].*stack-detect/;\n    38→\n    39→/** Recursively collect all .ts files under a directory. */\n    40→function collectTsFiles(dir: string): string[] {\n    41→  const results: string[] = [];\n    42→  let entries: string[];\n    43→  try {\n    44→    entries = readdirSync(dir);\n    45→  } catch {\n    46→    return results;\n    47→  }\n    48→  for (const name of entries) {\n    49→    const fullPath = join(dir, name);\n    50→    try {\n    51→      const stat = statSync(fullPath);\n    52→      if (stat.isDirectory()) {\n    53→        // Skip node_modules, coverage, dist\n    54→        if (['node_modules', 'coverage', 'dist'].includes(name)) continue;\n    55→        results.push(...collectTsFiles(fullPath));\n    56→      } else if (stat.isFile() && name.endsWith('.ts')) {\n    57→        results.push(fullPath);\n    58→      }\n    59→    } catch {\n    60→      continue;\n    61→    }\n    62→  }\n    63→  return results;\n    64→}\n    65→\n    66→/** Check if a file path is inside the stacks directory. */\n    67→function isInsideStacksDir(filePath: string): boolean {\n    68→  return filePath.startsWith(STACKS_DIR);\n    69→}\n    70→\n    71→describe('stack abstraction boundary', () => {\n    72→  const allFiles = collectTsFiles(SRC_DIR);\n    73→  const outsideFiles = allFiles.filter(f => !isInsideStacksDir(f));\n    74→\n    75→  it('no stack string comparisons outside src/lib/stacks/', () => {\n    76→    const violations: Array<{ file: string; line: number; content: string; pattern: string }> = [];\n    77→\n    78→    for (const filePath of outsideFiles) {\n    79→      const relPath = relative(SRC_DIR, filePath);\n    80→      if (ALLOWED_EXCEPTIONS.has(relPath)) continue;\n    81→\n    82→      const content = readFileSync(filePath, 'utf-8');\n    83→      const lines = content.split('\\n');\n    84→\n    85→      for (let i = 0; i < lines.length; i++) {\n    86→        const line = lines[i];\n    87→        // Skip comments\n    88→        if (line.trimStart().startsWith('//') || line.trimStart().startsWith('*')) continue;\n    89→\n    90→        for (const pattern of FORBIDDEN_PATTERNS) {\n    91→          if (pattern.test(line)) {\n    92→            violations.push({\n    93→              file: relPath,\n    94→              line: i + 1,\n    95→              content: line.trim(),\n    96→              pattern: pattern.source,\n    97→            });\n    98→          }\n    99→        }\n   100→      }\n   101→    }\n   102→\n   103→    if (violations.length > 0) {\n   104→      const report = violations\n   105→        .map(v => `  ${v.file}:${v.line} — ${v.content}`)\n   106→        .join('\\n');\n   107→      expect.fail(\n   108→        `Found ${violations.length} stack string comparison(s) outside src/lib/stacks/:\\n${report}`,\n   109→      );\n   110→    }\n   111→\n   112→    expect(violations).toHaveLength(0);\n   113→  });\n   114→\n   115→  it('no imports from stack-detect.ts outside src/lib/stacks/', () => {\n   116→    const violations: Array<{ file: string; line: number; content: string }> = [];\n   117→\n   118→    for (const filePath of outsideFiles) {\n   119→      const content = readFileSync(filePath, 'utf-8');\n   120→      const lines = content.split('\\n');\n   121→\n   122→      for (let i = 0; i < lines.length; i++) {\n   123→        const line = lines[i];\n   124→        // Skip comments\n   125→        if (line.trimStart().startsWith('//') || line.trimStart().startsWith('*')) continue;\n   126→\n   127→        if (LEGACY_IMPORT_PATTERN.test(line)) {\n   128→          violations.push({\n   129→            file: relative(SRC_DIR, filePath),\n   130→            line: i + 1,\n   131→            content: line.trim(),\n   132→          });\n   133→        }\n   134→      }\n   135→    }\n   136→\n   137→    if (violations.length > 0) {\n   138→      const report = violations\n   139→        .map(v => `  ${v.file}:${v.line} — ${v.content}`)\n   140→        .join('\\n');\n   141→      expect.fail(\n   142→        `Found ${violations.length} import(s) from stack-detect.ts:\\n${report}`,\n   143→      );\n   144→    }\n   145→\n   146→    expect(violations).toHaveLength(0);\n   147→  });\n   148→});\n   149→"}]},"parent_tool_use_id":"toolu_01E6L7Bd8eeBpjKQ16gXWPQk","session_id":"809dbebc-105d-4f42-bb69-c6ae04307c59","uuid":"e6834d9f-bbd4-4272-9ee0-5f5f8fb52777","timestamp":"2026-03-25T01:07:47.847Z"}
