{"type":"system","subtype":"task_progress","task_id":"a262d2682dbcaa38e","tool_use_id":"toolu_01T5izCnprn3BanMVUeAKGXz","description":"Writing src/lib/__tests__/schema-validate.test.ts","usage":{"total_tokens":27083,"tool_uses":14,"duration_ms":97807},"last_tool_name":"Write","uuid":"d8bf529a-ca06-4b2d-ac15-522af9841958","session_id":"c54cfa66-957c-4f2c-a205-da1113d93a9b"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01B4kMMxc4kA6Quo2z6jj5mm","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01VvBfkM9hSjRUEr16UexiTm","name":"Write","input":{"file_path":"/Users/ivintik/dev/personal/codeharness/src/lib/__tests__/schema-validate.test.ts","content":"import { describe, it, expect } from 'vitest';\nimport { validateWorkflowSchema, validateAgainstSchema } from '../schema-validate.js';\n\n// --- Helpers ---\n\nfunction minimalValidWorkflow() {\n  return {\n    tasks: {\n      implement: {\n        agent: 'dev',\n      },\n    },\n    flow: ['implement'],\n  };\n}\n\nfunction fullValidWorkflow() {\n  return {\n    tasks: {\n      implement: {\n        agent: 'dev',\n        scope: 'per-story',\n        session: 'fresh',\n        source_access: true,\n        prompt_template: 'Implement story {{story_key}}',\n        input_contract: { type: 'object' },\n        output_contract: { type: 'object' },\n        max_budget_usd: 5.0,\n      },\n      verify: {\n        agent: 'evaluator',\n        scope: 'per-run',\n        session: 'continue',\n        source_access: false,\n      },\n      retry: {\n        agent: 'dev',\n        scope: 'per-story',\n        session: 'fresh',\n        source_access: true,\n        prompt_template: 'Fix failures: {{findings}}',\n      },\n    },\n    flow: ['implement', 'verify', { loop: ['retry', 'verify'] }],\n  };\n}\n\n// --- Tests ---\n\ndescribe('validateWorkflowSchema', () => {\n  describe('valid workflows', () => {\n    it('accepts a minimal valid workflow (AC #1)', () => {\n      const result = validateWorkflowSchema(minimalValidWorkflow());\n      expect(result.valid).toBe(true);\n      expect(result.errors).toEqual([]);\n    });\n\n    it('accepts a full workflow with all optional fields (AC #9)', () => {\n      const result = validateWorkflowSchema(fullValidWorkflow());\n      expect(result.valid).toBe(true);\n      expect(result.errors).toEqual([]);\n    });\n\n    it('accepts empty tasks object', () => {\n      const result = validateWorkflowSchema({ tasks: {}, flow: [] });\n      expect(result.valid).toBe(true);\n    });\n\n    it('accepts empty flow array', () => {\n      const result = validateWorkflowSchema({ tasks: {}, flow: [] });\n      expect(result.valid).toBe(true);\n    });\n\n    it('accepts a loop block in flow (AC #6)', () => {\n      const workflow = {\n        tasks: {\n          retry: { agent: 'dev' },\n          verify: { agent: 'evaluator' },\n        },\n        flow: [{ loop: ['retry', 'verify'] }],\n      };\n      const result = validateWorkflowSchema(workflow);\n      expect(result.valid).toBe(true);\n    });\n\n    it('accepts optional fields when present and passes when absent (AC #9)', () => {\n      // With all optional fields\n      const withOptional = validateWorkflowSchema(fullValidWorkflow());\n      expect(withOptional.valid).toBe(true);\n\n      // Without optional fields (only required agent)\n      const withoutOptional = validateWorkflowSchema(minimalValidWorkflow());\n      expect(withoutOptional.valid).toBe(true);\n    });\n  });\n\n  describe('missing required fields', () => {\n    it('rejects missing tasks field (AC #2)', () => {\n      const result = validateWorkflowSchema({ flow: ['implement'] });\n      expect(result.valid).toBe(false);\n      expect(result.errors.some((e) => e.message.includes('tasks'))).toBe(true);\n      expect(result.errors.some((e) => e.keyword === 'required')).toBe(true);\n    });\n\n    it('rejects missing flow field (AC #3)', () => {\n      const result = validateWorkflowSchema({ tasks: {} });\n      expect(result.valid).toBe(false);\n      expect(result.errors.some((e) => e.message.includes('flow'))).toBe(true);\n      expect(result.errors.some((e) => e.keyword === 'required')).toBe(true);\n    });\n\n    it('rejects missing agent in task (AC #7)', () => {\n      const workflow = {\n        tasks: {\n          implement: { scope: 'per-story' },\n        },\n        flow: ['implement'],\n      };\n      const result = validateWorkflowSchema(workflow);\n      expect(result.valid).toBe(false);\n      expect(result.errors.some((e) => e.keyword === 'required')).toBe(true);\n    });\n  });\n\n  describe('invalid enum values', () => {\n    it('rejects invalid scope value (AC #4)', () => {\n      const workflow = {\n        tasks: {\n          implement: { agent: 'dev', scope: 'invalid-scope' },\n        },\n        flow: ['implement'],\n      };\n      const result = validateWorkflowSchema(workflow);\n      expect(result.valid).toBe(false);\n      expect(result.errors.some((e) => e.keyword === 'enum')).toBe(true);\n      expect(result.errors.some((e) => e.path.includes('scope'))).toBe(true);\n    });\n\n    it('rejects invalid session value (AC #5)', () => {\n      const workflow = {\n        tasks: {\n          implement: { agent: 'dev', session: 'invalid-session' },\n        },\n        flow: ['implement'],\n      };\n      const result = validateWorkflowSchema(workflow);\n      expect(result.valid).toBe(false);\n      expect(result.errors.some((e) => e.keyword === 'enum')).toBe(true);\n      expect(result.errors.some((e) => e.path.includes('session'))).toBe(true);\n    });\n  });\n\n  describe('invalid types', () => {\n    it('rejects source_access as non-boolean', () => {\n      const workflow = {\n        tasks: {\n          implement: { agent: 'dev', source_access: 'yes' },\n        },\n        flow: ['implement'],\n      };\n      const result = validateWorkflowSchema(workflow);\n      expect(result.valid).toBe(false);\n      expect(result.errors.some((e) => e.keyword === 'type')).toBe(true);\n    });\n\n    it('rejects max_budget_usd as non-number', () => {\n      const workflow = {\n        tasks: {\n          implement: { agent: 'dev', max_budget_usd: 'five' },\n        },\n        flow: ['implement'],\n      };\n      const result = validateWorkflowSchema(workflow);\n      expect(result.valid).toBe(false);\n      expect(result.errors.some((e) => e.keyword === 'type')).toBe(true);\n    });\n  });\n\n  describe('flow validation', () => {\n    it('rejects invalid flow item types', () => {\n      const workflow = {\n        tasks: { implement: { agent: 'dev' } },\n        flow: [123],\n      };\n      const result = validateWorkflowSchema(workflow);\n      expect(result.valid).toBe(false);\n    });\n\n    it('rejects loop with empty array', () => {\n      const workflow = {\n        tasks: { retry: { agent: 'dev' } },\n        flow: [{ loop: [] }],\n      };\n      const result = validateWorkflowSchema(workflow);\n      expect(result.valid).toBe(false);\n    });\n\n    it('rejects loop with non-string items', () => {\n      const workflow = {\n        tasks: { retry: { agent: 'dev' } },\n        flow: [{ loop: [123] }],\n      };\n      const result = validateWorkflowSchema(workflow);\n      expect(result.valid).toBe(false);\n    });\n\n    it('rejects flow object with unknown properties', () => {\n      const workflow = {\n        tasks: { implement: { agent: 'dev' } },\n        flow: [{ loop: ['implement'], extra: true }],\n      };\n      const result = validateWorkflowSchema(workflow);\n      expect(result.valid).toBe(false);\n    });\n  });\n\n  describe('additional properties', () => {\n    it('rejects unknown top-level properties', () => {\n      const workflow = {\n        tasks: {},\n        flow: [],\n        extra: 'nope',\n      };\n      const result = validateWorkflowSchema(workflow);\n      expect(result.valid).toBe(false);\n      expect(result.errors.some((e) => e.keyword === 'additionalProperties')).toBe(true);\n    });\n\n    it('rejects unknown task properties', () => {\n      const workflow = {\n        tasks: {\n          implement: { agent: 'dev', unknown_field: true },\n        },\n        flow: ['implement'],\n      };\n      const result = validateWorkflowSchema(workflow);\n      expect(result.valid).toBe(false);\n    });\n  });\n\n  describe('error structure', () => {\n    it('returns errors with path, message, and keyword', () => {\n      const result = validateWorkflowSchema({});\n      expect(result.valid).toBe(false);\n      expect(result.errors.length).toBeGreaterThan(0);\n      for (const err of result.errors) {\n        expect(err).toHaveProperty('path');\n        expect(err).toHaveProperty('message');\n        expect(err).toHaveProperty('keyword');\n        expect(typeof err.path).toBe('string');\n        expect(typeof err.message).toBe('string');\n        expect(typeof err.keyword).toBe('string');\n      }\n    });\n  });\n\n  describe('edge cases', () => {\n    it('rejects null input', () => {\n      const result = validateWorkflowSchema(null);\n      expect(result.valid).toBe(false);\n    });\n\n    it('rejects non-object input', () => {\n      const result = validateWorkflowSchema('not an object');\n      expect(result.valid).toBe(false);\n    });\n\n    it('rejects array input', () => {\n      const result = validateWorkflowSchema([]);\n      expect(result.valid).toBe(false);\n    });\n  });\n});\n\ndescribe('validateAgainstSchema', () => {\n  it('works with the workflow schema via the generic API', () => {\n    const Ajv = require('ajv').default;\n    const schema = require('../../schemas/workflow.schema.json');\n    const ajv = new Ajv({ allErrors: true });\n    const validate = ajv.compile(schema);\n    const result = validateAgainstSchema(minimalValidWorkflow(), validate);\n    expect(result.valid).toBe(true);\n    expect(result.errors).toEqual([]);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":491,"cache_read_input_tokens":26453,"cache_creation":{"ephemeral_5m_input_tokens":491,"ephemeral_1h_input_tokens":0},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01T5izCnprn3BanMVUeAKGXz","session_id":"c54cfa66-957c-4f2c-a205-da1113d93a9b","uuid":"379f9d37-fad2-4895-a55f-fec41ea3b7c2"}
