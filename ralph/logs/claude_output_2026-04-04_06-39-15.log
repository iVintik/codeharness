{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Hmaj7X2U5f3JAZodMupjnY","type":"tool_result","content":"1\t/**\n2\t * MergeStatus — Ink component showing detailed merge progress.\n3\t *\n4\t * Renders merge outcome (clean/resolved/escalated), conflict details,\n5\t * and post-merge test results. Pure presentational component.\n6\t *\n7\t * @see Story 20.2: Summary Bar & Merge Status\n8\t */\n9\t\n10\timport React from 'react';\n11\timport { Text, Box } from 'ink';\n12\t\n13\t// --- Types ---\n14\t\n15\texport interface MergeTestResults {\n16\t  passed: number;\n17\t  failed: number;\n18\t  total: number;\n19\t  durationSecs: number;\n20\t  coverage: number | null;\n21\t}\n22\t\n23\texport interface MergeState {\n24\t  epicId: string;\n25\t  outcome: 'clean' | 'resolved' | 'escalated' | 'in-progress';\n26\t  conflicts?: string[];\n27\t  conflictCount?: number;\n28\t  testResults?: MergeTestResults;\n29\t  worktreePath?: string;\n30\t  reason?: string;\n31\t}\n32\t\n33\texport interface MergeStatusProps {\n34\t  mergeState: MergeState | null;\n35\t}\n36\t\n37\t// --- Component ---\n38\t\n39\texport function MergeStatus({ mergeState }: MergeStatusProps) {\n40\t  if (!mergeState) return null;\n41\t\n42\t  const lines: React.ReactNode[] = [];\n43\t\n44\t  if (mergeState.outcome === 'clean') {\n45\t    const count = mergeState.conflictCount ?? 0;\n46\t    lines.push(\n47\t      <Text key=\"merge-clean\" color=\"green\">\n48\t        {`[OK] Merge ${mergeState.epicId} \\u2192 main: clean (${count} conflicts)`}\n49\t      </Text>\n50\t    );\n51\t  } else if (mergeState.outcome === 'resolved') {\n52\t    const count = mergeState.conflictCount ?? mergeState.conflicts?.length ?? 0;\n53\t    const suffix = count === 1 ? '' : 's';\n54\t    lines.push(\n55\t      <Text key=\"merge-resolved\" color=\"green\">\n56\t        {`[OK] Merge ${mergeState.epicId} \\u2192 main: ${count} conflict${suffix} auto-resolved`}\n57\t      </Text>\n58\t    );\n59\t    if (mergeState.conflicts && mergeState.conflicts.length > 0) {\n60\t      for (let i = 0; i < mergeState.conflicts.length; i++) {\n61\t        lines.push(\n62\t          <Text key={`conflict-${i}`}>\n63\t            {'     \\u2514 '}{mergeState.conflicts[i]}\n64\t          </Text>\n65\t        );\n66\t      }\n67\t    }\n68\t  } else if (mergeState.outcome === 'escalated') {\n69\t    lines.push(\n70\t      <Text key=\"merge-escalated\" color=\"red\">\n71\t        {`[FAIL] Merge ${mergeState.epicId} \\u2192 main: ${mergeState.reason ?? 'unknown error'}`}\n72\t      </Text>\n73\t    );\n74\t    if (mergeState.conflicts && mergeState.conflicts.length > 0) {\n75\t      for (let i = 0; i < mergeState.conflicts.length; i++) {\n76\t        lines.push(\n77\t          <Text key={`esc-conflict-${i}`}>\n78\t            {'       \\u2514 '}{mergeState.conflicts[i]}\n79\t          </Text>\n80\t        );\n81\t      }\n82\t    }\n83\t    lines.push(\n84\t      <Text key=\"manual\" color=\"red\">{'       \\u2192 Manual resolution required'}</Text>\n85\t    );\n86\t    if (mergeState.worktreePath) {\n87\t      lines.push(\n88\t        <Text key=\"worktree\" color=\"red\">\n89\t          {`       \\u2192 Worktree preserved: ${mergeState.worktreePath}`}\n90\t        </Text>\n91\t      );\n92\t    }\n93\t  } else if (mergeState.outcome === 'in-progress') {\n94\t    lines.push(\n95\t      <Text key=\"merge-inprog\">\n96\t        {`Merging ${mergeState.epicId} \\u2192 main \\u25CC`}\n97\t      </Text>\n98\t    );\n99\t  }\n100\t\n101\t  // Test results\n102\t  if (mergeState.testResults) {\n103\t    const t = mergeState.testResults;\n104\t    const hasFailed = t.failed > 0;\n105\t    const prefix = hasFailed ? '[FAIL]' : '[OK]';\n106\t    const color = hasFailed ? 'red' : 'green';\n107\t    let testLine = `${prefix} Tests: ${t.passed}/${t.total} passed (${t.durationSecs}s)`;\n108\t    if (t.coverage != null) {\n109\t      testLine += ` ${t.coverage}% coverage`;\n110\t    }\n111\t    lines.push(\n112\t      <Text key=\"tests\" color={color}>{testLine}</Text>\n113\t    );\n114\t  }\n115\t\n116\t  return (\n117\t    <Box flexDirection=\"column\">\n118\t      {lines}\n119\t    </Box>\n120\t  );\n121\t}\n122\t"}]},"parent_tool_use_id":"toolu_01TzQwpEV7uekTzzh7pB5DWd","session_id":"7e3ded59-6184-4f8b-8f55-ba5e63dae51f","uuid":"fe07e5ea-fff8-4375-b159-2c3e4a6bc59c","timestamp":"2026-04-04T02:49:34.919Z"}
