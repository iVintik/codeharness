{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q9xettVfonbsBBuJFyFH2V","type":"tool_result","content":"     1→/**\n     2→ * Verification environment management: Docker image lifecycle, clean workspace,\n     3→ * and environment checks for black-box verification.\n     4→ */\n     5→import { execFileSync } from 'node:child_process';\n     6→import { existsSync, mkdirSync, readdirSync, readFileSync, writeFileSync, cpSync, rmSync, statSync } from 'node:fs';\n     7→import { join, basename } from 'node:path';\n     8→import { createHash } from 'node:crypto';\n     9→import { info } from '../../lib/output.js';\n    10→import { detectStacks } from '../../lib/stacks/index.js';\n    11→import { readStateWithBody, writeState } from '../../lib/state.js';\n    12→import { isDockerAvailable } from '../../lib/docker/index.js';\n    13→import type { BuildOptions, BuildResult, CheckResult, ProjectType } from './types.js';\n    14→import { generateVerifyDockerfile } from './dockerfile-generator.js';\n    15→\n    16→const IMAGE_TAG = 'codeharness-verify';\n    17→const STORY_DIR = '_bmad-output/implementation-artifacts';\n    18→const TEMP_PREFIX = '/tmp/codeharness-verify-';\n    19→const STATE_KEY_DIST_HASH = 'verify_env_dist_hash';\n    20→\n    21→/** Validates that a story key is safe for file paths and container names. */\n    22→export function isValidStoryKey(storyKey: string): boolean {\n    23→  if (!storyKey || storyKey.includes('..') || storyKey.includes('/') || storyKey.includes('\\\\')) {\n    24→    return false;\n    25→  }\n    26→  return /^[a-zA-Z0-9_-]+$/.test(storyKey);\n    27→}\n    28→\n    29→/** Computes a SHA-256 hash of all files in dist/ for cache invalidation. */\n    30→export function computeDistHash(projectDir: string): string | null {\n    31→  const distDir = join(projectDir, 'dist');\n    32→  if (!existsSync(distDir)) return null;\n    33→  const hash = createHash('sha256');\n    34→  const files = collectFiles(distDir).sort();\n    35→  for (const file of files) {\n    36→    hash.update(file.slice(distDir.length));\n    37→    hash.update(readFileSync(file));\n    38→  }\n    39→  return hash.digest('hex');\n    40→}\n    41→\n    42→function collectFiles(dir: string): string[] {\n    43→  const results: string[] = [];\n    44→  for (const entry of readdirSync(dir, { withFileTypes: true })) {\n    45→    const fullPath = join(dir, entry.name);\n    46→    if (entry.isDirectory()) { results.push(...collectFiles(fullPath)); }\n    47→    else { results.push(fullPath); }\n    48→  }\n    49→  return results;\n    50→}\n    51→\n    52→function getStoredDistHash(projectDir: string): string | null {\n    53→  try {\n    54→    const { state } = readStateWithBody(projectDir);\n    55→    return ((state as unknown as Record<string, unknown>)[STATE_KEY_DIST_HASH] as string) ?? null;\n    56→  } catch { return null; } // IGNORE: state file may not exist\n    57→}\n    58→\n    59→function storeDistHash(projectDir: string, hash: string): void {\n    60→  try {\n    61→    const { state, body } = readStateWithBody(projectDir);\n    62→    (state as unknown as Record<string, unknown>)[STATE_KEY_DIST_HASH] = hash;\n    63→    writeState(state, projectDir, body);\n    64→  } catch {\n    65→    // IGNORE: state file may not be initialized yet\n    66→    info('Could not persist dist hash to state file — cache will not be available until state is initialized');\n    67→  }\n    68→}\n    69→\n    70→/** Detects the project type for verification strategy selection. */\n    71→/** Stack names that map directly to ProjectType values. */\n    72→const STACK_TO_PROJECT_TYPE: Record<string, ProjectType> = {\n    73→  nodejs: 'nodejs',\n    74→  python: 'python',\n    75→  rust: 'rust',\n    76→};\n    77→\n    78→export function detectProjectType(projectDir: string): ProjectType {\n    79→  // Use detectStacks() (plural) for multi-stack awareness; derive primary from root detection\n    80→  const allStacks = detectStacks(projectDir);\n    81→  const rootDetection = allStacks.find(s => s.dir === '.');\n    82→  const stack = rootDetection ? rootDetection.stack : null;\n    83→  // Prefer known stacks when the project has a buildable package — the npm tarball\n    84→  // or Python wheel includes all distributable files. Plugin-only detection is the\n    85→  // fallback for projects that are purely Claude Code plugins with no build artifact.\n    86→  if (stack && STACK_TO_PROJECT_TYPE[stack]) return STACK_TO_PROJECT_TYPE[stack];\n    87→  if (existsSync(join(projectDir, '.claude-plugin', 'plugin.json'))) return 'plugin';\n    88→  return 'generic';\n    89→}\n    90→\n    91→/** Builds the verification Docker image with cache invalidation. */\n    92→export function buildVerifyImage(options: BuildOptions = {}): BuildResult {\n    93→  const projectDir = options.projectDir ?? process.cwd();\n    94→  if (!isDockerAvailable()) {\n    95→    throw new Error('Docker is not available. Install Docker and ensure the daemon is running.');\n    96→  }\n    97→  const projectType = detectProjectType(projectDir);\n    98→  const currentHash = computeDistHash(projectDir);\n    99→  /** Project types that don't require dist/ for verification image build */\n   100→  const NO_DIST_REQUIRED = new Set<ProjectType>(['generic', 'plugin', 'rust']);\n   101→  if (NO_DIST_REQUIRED.has(projectType)) {\n   102→    // Generic, plugin, and Rust projects may not have dist/ — skip hash check\n   103→  } else if (!currentHash) {\n   104→    throw new Error('No dist/ directory found. Run your build command first (e.g., npm run build).');\n   105→  }\n   106→  if (currentHash) {\n   107→    const storedHash = getStoredDistHash(projectDir);\n   108→    if (storedHash === currentHash && dockerImageExists(IMAGE_TAG)) {\n   109→      return { imageTag: IMAGE_TAG, imageSize: getImageSize(IMAGE_TAG), buildTimeMs: 0, cached: true };\n   110→    }\n   111→  }\n   112→  const startTime = Date.now();\n   113→  /** Per-project-type Docker image builders (no stack string comparisons). */\n   114→  const imageBuilders: Record<ProjectType, () => void> = {\n   115→    nodejs: () => buildNodeImage(projectDir),\n   116→    python: () => buildPythonImage(projectDir),\n   117→    rust: () => buildSimpleImage(projectDir, 300_000),\n   118→    plugin: () => buildPluginImage(projectDir),\n   119→    generic: () => buildSimpleImage(projectDir),\n   120→  };\n   121→  imageBuilders[projectType]();\n   122→  if (currentHash) { storeDistHash(projectDir, currentHash); }\n   123→  return { imageTag: IMAGE_TAG, imageSize: getImageSize(IMAGE_TAG), buildTimeMs: Date.now() - startTime, cached: false };\n   124→}\n   125→\n   126→function buildNodeImage(projectDir: string): void {\n   127→  const packOutput = execFileSync('npm', ['pack', '--pack-destination', '/tmp'], {\n   128→    cwd: projectDir, stdio: 'pipe', timeout: 60_000,\n   129→  }).toString().trim();\n   130→  const lastLine = packOutput.split('\\n').pop()?.trim();\n   131→  if (!lastLine) throw new Error('npm pack produced no output — cannot determine tarball filename.');\n   132→  const tarballName = basename(lastLine);\n   133→  const tarballPath = join('/tmp', tarballName);\n   134→  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   135→  mkdirSync(buildContext, { recursive: true });\n   136→  try {\n   137→    cpSync(tarballPath, join(buildContext, tarballName));\n   138→    const dockerfile = generateVerifyDockerfile(projectDir)\n   139→      + `\\n# Install project from tarball\\nARG TARBALL=package.tgz\\nCOPY \\${TARBALL} /tmp/\\${TARBALL}\\nRUN npm install -g /tmp/\\${TARBALL} && rm /tmp/\\${TARBALL}\\n`;\n   140→    writeFileSync(join(buildContext, 'Dockerfile'), dockerfile);\n   141→    execFileSync('docker', ['build', '-t', IMAGE_TAG, '--build-arg', `TARBALL=${tarballName}`, '.'], {\n   142→      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   143→    });\n   144→  } finally {\n   145→    rmSync(buildContext, { recursive: true, force: true });\n   146→    rmSync(tarballPath, { force: true });\n   147→  }\n   148→}\n   149→\n   150→function buildPythonImage(projectDir: string): void {\n   151→  const distDir = join(projectDir, 'dist');\n   152→  const distFiles = readdirSync(distDir).filter(f => f.endsWith('.tar.gz') || f.endsWith('.whl'));\n   153→  if (distFiles.length === 0) {\n   154→    throw new Error('No distribution files found in dist/. Run your build command first (e.g., python -m build).');\n   155→  }\n   156→  const distFile = distFiles.filter(f => f.endsWith('.tar.gz'))[0] ?? distFiles[0];\n   157→  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   158→  mkdirSync(buildContext, { recursive: true });\n   159→  try {\n   160→    cpSync(join(distDir, distFile), join(buildContext, distFile));\n   161→    const dockerfile = generateVerifyDockerfile(projectDir)\n   162→      + `\\n# Install project from distribution\\nCOPY ${distFile} /tmp/${distFile}\\nRUN pip install --break-system-packages /tmp/${distFile} && rm /tmp/${distFile}\\n`;\n   163→    writeFileSync(join(buildContext, 'Dockerfile'), dockerfile);\n   164→    execFileSync('docker', ['build', '-t', IMAGE_TAG, '.'], {\n   165→      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   166→    });\n   167→  } finally {\n   168→    rmSync(buildContext, { recursive: true, force: true });\n   169→  }\n   170→}\n   171→\n   172→/** Creates a clean temp workspace for verification (no src/, tests/, .git/). */\n   173→export function prepareVerifyWorkspace(storyKey: string, projectDir?: string): string {\n   174→  const root = projectDir ?? process.cwd();\n   175→  if (!isValidStoryKey(storyKey)) {\n   176→    throw new Error(`Invalid story key: ${storyKey}. Keys must contain only alphanumeric characters, hyphens, and underscores.`);\n   177→  }\n   178→  const storyFile = join(root, STORY_DIR, `${storyKey}.md`);\n   179→  if (!existsSync(storyFile)) throw new Error(`Story file not found: ${storyFile}`);\n   180→  const workspace = `${TEMP_PREFIX}${storyKey}`;\n   181→  if (existsSync(workspace)) rmSync(workspace, { recursive: true, force: true });\n   182→  mkdirSync(workspace, { recursive: true });\n   183→  cpSync(storyFile, join(workspace, 'story.md'));\n   184→  const readmePath = join(root, 'README.md');\n   185→  if (existsSync(readmePath)) cpSync(readmePath, join(workspace, 'README.md'));\n   186→  const docsDir = join(root, 'docs');\n   187→  if (existsSync(docsDir) && statSync(docsDir).isDirectory()) {\n   188→    cpSync(docsDir, join(workspace, 'docs'), { recursive: true });\n   189→  }\n   190→  mkdirSync(join(workspace, 'verification'), { recursive: true });\n   191→  return workspace;\n   192→}\n   193→\n   194→/** Validates verification environment: image, CLI, observability. */\n   195→export function checkVerifyEnv(): CheckResult {\n   196→  let imageExists = false;\n   197→  let cliWorks = false;\n   198→  let otelReachable = false;\n   199→\n   200→  imageExists = dockerImageExists(IMAGE_TAG);\n   201→  if (!imageExists) return { imageExists, cliWorks, otelReachable };\n   202→  try {\n   203→    execFileSync('docker', ['run', '--rm', IMAGE_TAG, 'codeharness', '--help'], {\n   204→      stdio: 'pipe', timeout: 30_000,\n   205→    });\n   206→    cliWorks = true;\n   207→  } catch { cliWorks = false; } // IGNORE: CLI check failed in container\n   208→  try {\n   209→    execFileSync('docker', [\n   210→      'run', '--rm', '--add-host=host.docker.internal:host-gateway', IMAGE_TAG,\n   211→      'curl', '-sf', '--max-time', '5', 'http://host.docker.internal:4318/v1/status',\n   212→    ], { stdio: 'pipe', timeout: 30_000 });\n   213→    otelReachable = true;\n   214→  } catch { otelReachable = false; } // IGNORE: OTEL endpoint unreachable in container\n   215→  return { imageExists, cliWorks, otelReachable };\n   216→}\n   217→\n   218→/** Cleans up all stale containers matching `codeharness-verify-*` pattern. Idempotent. */\n   219→export function cleanupStaleContainers(): void {\n   220→  try {\n   221→    const output = execFileSync(\n   222→      'docker', ['ps', '-a', '--filter', 'name=codeharness-verify-', '--format', '{{.Names}}'],\n   223→      { stdio: 'pipe', timeout: 15_000 },\n   224→    ).toString('utf-8').trim();\n   225→    if (output.length === 0) return;\n   226→    const containers = output.split('\\n').filter(name => name.length > 0);\n   227→    for (const name of containers) {\n   228→      try {\n   229→        execFileSync('docker', ['rm', '-f', name], { stdio: 'pipe', timeout: 15_000 });\n   230→      } catch { /* IGNORE: container may already be removed */ }\n   231→    }\n   232→  } catch { /* IGNORE: docker not available or no containers */ }\n   233→}\n   234→\n   235→/** Removes temp workspace and stops/removes the container. Idempotent. */\n   236→export function cleanupVerifyEnv(storyKey: string): void {\n   237→  if (!isValidStoryKey(storyKey)) {\n   238→    throw new Error(`Invalid story key: ${storyKey}. Keys must contain only alphanumeric characters, hyphens, and underscores.`);\n   239→  }\n   240→  const workspace = `${TEMP_PREFIX}${storyKey}`;\n   241→  const containerName = `codeharness-verify-${storyKey}`;\n   242→  if (existsSync(workspace)) rmSync(workspace, { recursive: true, force: true });\n   243→  try { execFileSync('docker', ['stop', containerName], { stdio: 'pipe', timeout: 15_000 }); }\n   244→  catch { /* IGNORE: container may not exist */ }\n   245→  try { execFileSync('docker', ['rm', '-f', containerName], { stdio: 'pipe', timeout: 15_000 }); }\n   246→  catch { /* IGNORE: container may not exist */ }\n   247→}\n   248→\n   249→function buildPluginImage(projectDir: string): void {\n   250→  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   251→  mkdirSync(buildContext, { recursive: true });\n   252→  try {\n   253→    // Copy plugin source into build context\n   254→    const pluginDir = join(projectDir, '.claude-plugin');\n   255→    cpSync(pluginDir, join(buildContext, '.claude-plugin'), { recursive: true });\n   256→    // Copy any commands, hooks, knowledge, skills directories if they exist\n   257→    for (const dir of ['commands', 'hooks', 'knowledge', 'skills']) {\n   258→      const src = join(projectDir, dir);\n   259→      if (existsSync(src) && statSync(src).isDirectory()) {\n   260→        cpSync(src, join(buildContext, dir), { recursive: true });\n   261→      }\n   262→    }\n   263→    writeFileSync(join(buildContext, 'Dockerfile'), generateVerifyDockerfile(projectDir));\n   264→    execFileSync('docker', ['build', '-t', IMAGE_TAG, '.'], {\n   265→      cwd: buildContext, stdio: 'pipe', timeout: 120_000,\n   266→    });\n   267→  } finally {\n   268→    rmSync(buildContext, { recursive: true, force: true });\n   269→  }\n   270→}\n   271→\n   272→function buildSimpleImage(projectDir: string, timeout = 120_000): void {\n   273→  const buildContext = join('/tmp', `codeharness-verify-build-${Date.now()}`);\n   274→  mkdirSync(buildContext, { recursive: true });\n   275→  try {\n   276→    writeFileSync(join(buildContext, 'Dockerfile'), generateVerifyDockerfile(projectDir));\n   277→    execFileSync('docker', ['build', '-t', IMAGE_TAG, '.'], {\n   278→      cwd: buildContext, stdio: 'pipe', timeout,\n   279→    });\n   280→  } finally {\n   281→    rmSync(buildContext, { recursive: true, force: true });\n   282→  }\n   283→}\n   284→\n   285→function dockerImageExists(tag: string): boolean {\n   286→  try {\n   287→    execFileSync('docker', ['image', 'inspect', tag], { stdio: 'pipe', timeout: 10_000 });\n   288→    return true;\n   289→  } catch { return false; } // IGNORE: docker image inspect may fail\n   290→}\n   291→\n   292→function getImageSize(tag: string): string {\n   293→  try {\n   294→    const output = execFileSync('docker', ['image', 'inspect', tag, '--format', '{{.Size}}'], {\n   295→      stdio: 'pipe', timeout: 10_000,\n   296→    }).toString().trim();\n   297→    const bytes = parseInt(output, 10);\n   298→    if (isNaN(bytes)) return output;\n   299→    if (bytes >= 1_000_000_000) return `${(bytes / 1_000_000_000).toFixed(1)}GB`;\n   300→    if (bytes >= 1_000_000) return `${(bytes / 1_000_000).toFixed(1)}MB`;\n   301→    if (bytes >= 1_000) return `${(bytes / 1_000).toFixed(1)}KB`;\n   302→    return `${bytes}B`;\n   303→  } catch { return 'unknown'; } // IGNORE: docker inspect may fail\n   304→}\n   305→"}]},"parent_tool_use_id":"toolu_012s5F8VLuWD2mi6SZkrCKSA","session_id":"304d3f28-c0c7-4595-b234-47d916dfe3ac","uuid":"367c6ad7-f212-439e-8150-02755a882a49","timestamp":"2026-03-27T09:52:21.933Z"}
