ateResult.data.stories['exhausted-story'].lastError).toBe(\n   130→        'retry-exhausted',\n   131→      );\n   132→    }\n   133→  });\n   134→\n   135→  it('getNextStory returns fail on state read error', () => {\n   136→    writeFileSync(STATE_FILE, '{invalid json!!!', 'utf-8');\n   137→    const result = getNextStory();\n   138→    expect(result.success).toBe(false);\n   139→    if (!result.success) {\n   140→      expect(result.error).toContain('Failed to read sprint state');\n   141→    }\n   142→  });\n   143→\n   144→  it('getSprintState returns ok with default state when no file exists', () => {\n   145→    const result = getSprintState();\n   146→    expect(result.success).toBe(true);\n   147→    if (result.success) {\n   148→      expect(result.data.version).toBe(1);\n   149→      expect(result.data.stories).toEqual({});\n   150→    }\n   151→  });\n   152→\n   153→  it('updateStoryStatus writes state successfully', () => {\n   154→    const result = updateStoryStatus('1.1', 'in-progress');\n   155→    expect(result.success).toBe(true);\n   156→  });\n   157→\n   158→  it('updateStoryStatus with detail writes state successfully', () => {\n   159→    const result = updateStoryStatus('1.1', 'failed', { error: 'boom' });\n   160→    expect(result.success).toBe(true);\n   161→  });\n   162→\n   163→  it('generateReport returns a valid StatusReport from state', () => {\n   164→    // Write a state file with some stories\n   165→    const state = {\n   166→      version: 1,\n   167→      sprint: { total: 2, done: 1, failed: 0, blocked: 0, inProgress: null },\n   168→      stories: {\n   169→        '1-1-a': {\n   170→          status: 'done',\n   171→          attempts: 1,\n   172→          lastAttempt: null,\n   173→          lastError: null,\n   174→          proofPath: null,\n   175→          acResults: null,\n   176→        },\n   177→        '2-1-b': {\n   178→          status: 'backlog',\n   179→          attempts: 0,\n   180→          lastAttempt: null,\n   181→          lastError: null,\n   182→          proofPath: null,\n   183→          acResults: null,\n   184→        },\n   185→      },\n   186→      run: {\n   187→        active: false,\n   188→        startedAt: null,\n   189→        iteration: 0,\n   190→        cost: 0,\n   191→        completed: [],\n   192→        failed: [],\n   193→      },\n   194→      actionItems: [],\n   195→    };\n   196→    writeFileSync(STATE_FILE, JSON.stringify(state, null, 2), 'utf-8');\n   197→\n   198→    const result = generateReport();\n   199→    expect(result.success).toBe(true);\n   200→    if (result.success) {\n   201→      expect(result.data.total).toBe(2);\n   202→      expect(result.data.done).toBe(1);\n   203→      expect(result.data.epicsTotal).toBe(2);\n   204→      expect(result.data.sprintPercent).toBe(50);\n   205→      expect(result.data.storyStatuses).toHaveLength(2);\n   206→    }\n   207→  });\n   208→\n   209→  it('generateReport returns ok with empty report when no state file', () => {\n   210→    const result = generateReport();\n   211→    expect(result.success).toBe(true);\n   212→    if (result.success) {\n   213→      expect(result.data.total).toBe(0);\n   214→      expect(result.data.done).toBe(0);\n   215→    }\n   216→  });\n   217→\n   218→  it('generateReport returns fail on corrupted state file', () => {\n   219→    writeFileSync(STATE_FILE, '{bad json!!!', 'utf-8');\n   220→    const result = generateReport();\n   221→    expect(result.success).toBe(false);\n   222→  });\n   223→\n   224→  it('getStoryDrillDown delegates to reporter and returns drill-down data', () => {\n   225→    const state = {\n   226→      version: 1,\n   227→      sprint: { total: 1, done: 0, failed: 1, blocked: 0, inProgress: null },\n   228→      stories: {\n   229→        '2-3-status': {\n   230→          status: 'failed',\n   231→          attempts: 3,\n   232→          lastAttempt: '2026-03-18T03:42:15Z',\n   233→          lastError: 'exit 1',\n   234→       