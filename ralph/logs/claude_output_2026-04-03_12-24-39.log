{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Da5oKWkY7dJDVP3gxEk1xH","type":"tool_result","content":"1140\t});\n1141\t\n1142\t// --- Referential Integrity Validation Tests (Story 11-2) ---\n1143\t\n1144\tdescribe('referential integrity validation', () => {\n1145\t  function mockDriver(name: string): AgentDriver {\n1146\t    return {\n1147\t      name,\n1148\t      defaultModel: 'test-model',\n1149\t      capabilities: { streaming: false, tools: false, subagents: false, computerUse: false },\n1150\t      async healthCheck() { return { status: 'healthy' as const, driver: name }; },\n1151\t      async *dispatch() { /* empty */ },\n1152\t      getLastCost() { return null; },\n1153\t    };\n1154\t  }\n1155\t\n1156\t  afterEach(() => {\n1157\t    resetDrivers();\n1158\t  });\n1159\t\n1160\t  describe('driver validation (AC #1, #4)', () => {\n1161\t    it('workflow with driver: claude-code passes when driver is registered (AC #4)', () => {\n1162\t      registerDriver(mockDriver('claude-code'));\n1163\t\n1164\t      const yaml = `\n1165\ttasks:\n1166\t  implement:\n1167\t    agent: dev\n1168\t    driver: claude-code\n1169\tflow:\n1170\t  - implement\n1171\t`;\n1172\t      const filePath = writeYaml('valid-driver.yaml', yaml);\n1173\t      const result = parseWorkflow(filePath);\n1174\t      expect(result.tasks.implement.driver).toBe('claude-code');\n1175\t    });\n1176\t\n1177\t    it('workflow with driver: nonexistent throws WorkflowParseError with helpful message (AC #1)', () => {\n1178\t      registerDriver(mockDriver('claude-code'));\n1179\t\n1180\t      const yaml = `\n1181\ttasks:\n1182\t  implement:\n1183\t    agent: dev\n1184\t    driver: codex\n1185\tflow:\n1186\t  - implement\n1187\t`;\n1188\t      const filePath = writeYaml('invalid-driver.yaml', yaml);\n1189\t\n1190\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n1191\t      try {\n1192\t        parseWorkflow(filePath);\n1193\t      } catch (err) {\n1194\t        const pe = err as WorkflowParseError;\n1195\t        expect(pe.message).toContain('Referential integrity errors');\n1196\t        expect(pe.errors.some((e) => e.path === '/tasks/implement/driver')).toBe(true);\n1197\t        expect(pe.errors.some((e) => e.message.includes('codex'))).toBe(true);\n1198\t        expect(pe.errors.some((e) => e.message.includes('implement'))).toBe(true);\n1199\t        expect(pe.errors.some((e) => e.message.includes('claude-code'))).toBe(true);\n1200\t      }\n1201\t    });\n1202\t\n1203\t    it('driver validation is skipped when registry is empty (AC #4, Task 4)', () => {\n1204\t      // No drivers registered — validation should be skipped\n1205\t      const yaml = `\n1206\ttasks:\n1207\t  implement:\n1208\t    agent: dev\n1209\t    driver: any-driver-name\n1210\tflow:\n1211\t  - implement\n1212\t`;\n1213\t      const filePath = writeYaml('empty-registry.yaml', yaml);\n1214\t      const result = parseWorkflow(filePath);\n1215\t      expect(result.tasks.implement.driver).toBe('any-driver-name');\n1216\t    });\n1217\t  });\n1218\t\n1219\t  describe('agent validation (AC #2, #6)', () => {\n1220\t    it('workflow with agent: dev (valid embedded agent) passes validation (AC #2)', () => {\n1221\t      const yaml = `\n1222\ttasks:\n1223\t  implement:\n1224\t    agent: dev\n1225\tflow:\n1226\t  - implement\n1227\t`;\n1228\t      const filePath = writeYaml('valid-agent.yaml', yaml);\n1229\t      const result = parseWorkflow(filePath);\n1230\t      expect(result.tasks.implement.agent).toBe('dev');\n1231\t    });\n1232\t\n1233\t    it('workflow with agent: nonexistent-agent throws WorkflowParseError with helpful message (AC #2)', () => {\n1234\t      const yaml = `\n1235\ttasks:\n1236\t  implement:\n1237\t    agent: nonexistent-agent\n1238\tflow:\n1239\t  - implement\n1240\t`;\n1241\t      const filePath = writeYaml('invalid-agent.yaml', yaml);\n1242\t\n1243\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n1244\t      try {\n1245\t        parseWorkflow(filePath);\n1246\t      } catch (err) {\n1247\t        const pe = err as WorkflowParseError;\n1248\t        expect(pe.message).toContain('Referential integrity errors');\n1249\t        expect(pe.errors.some((e) => e.path === '/tasks/implement/agent')).toBe(true);\n1250\t        expect(pe.errors.some((e) => e.message.includes('nonexistent-agent'))).toBe(true);\n1251\t        expect(pe.errors.some((e) => e.message.includes('implement'))).toBe(true);\n1252\t        expect(pe.errors.some((e) => e.message.includes('dev'))).toBe(true);\n1253\t      }\n1254\t    });\n1255\t\n1256\t    it('all embedded agent names pass validation', () => {\n1257\t      const agents = ['dev', 'qa', 'architect', 'pm', 'sm', 'analyst', 'ux-designer', 'tech-writer', 'evaluator'];\n1258\t      for (const agentName of agents) {\n1259\t        const yaml = `\n1260\ttasks:\n1261\t  task1:\n1262\t    agent: ${agentName}\n1263\tflow:\n1264\t  - task1\n1265\t`;\n1266\t        const filePath = writeYaml(`agent-${agentName}.yaml`, yaml);\n1267\t        const result = parseWorkflow(filePath);\n1268\t        expect(result.tasks.task1.agent).toBe(agentName);\n1269\t      }\n1270\t    });\n1271\t\n1272\t    it('not-found agent error includes \"not found\" and available agents list', () => {\n1273\t      const yaml = `\n1274\ttasks:\n1275\t  implement:\n1276\t    agent: nonexistent-agent\n1277\tflow:\n1278\t  - implement\n1279\t`;\n1280\t      const filePath = writeYaml('notfound-msg.yaml', yaml);\n1281\t\n1282\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n1283\t      try {\n1284\t        parseWorkflow(filePath);\n1285\t      } catch (err) {\n1286\t        const pe = err as WorkflowParseError;\n1287\t        const agentError = pe.errors.find((e) => e.path === '/tasks/implement/agent');\n1288\t        expect(agentError).toBeDefined();\n1289\t        // \"not found\" path: message says \"not found\" and lists available agents\n1290\t        expect(agentError!.message).toContain('not found');\n1291\t        expect(agentError!.message).toContain('Available agents:');\n1292\t        expect(agentError!.message).toContain('dev');\n1293\t      }\n1294\t    });\n1295\t  });\n1296\t\n1297\t  describe('multiple errors collected (AC #3)', () => {\n1298\t    it('collects all referential integrity errors in a single throw', () => {\n1299\t      registerDriver(mockDriver('claude-code'));\n1300\t\n1301\t      const yaml = `\n1302\ttasks:\n1303\t  task1:\n1304\t    agent: fake-agent\n1305\t    driver: nonexistent\n1306\t  task2:\n1307\t    agent: another-fake\n1308\tflow:\n1309\t  - task1\n1310\t  - task2\n1311\t`;\n1312\t      const filePath = writeYaml('multi-errors.yaml', yaml);\n1313\t\n1314\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n1315\t      try {\n1316\t        parseWorkflow(filePath);\n1317\t      } catch (err) {\n1318\t        const pe = err as WorkflowParseError;\n1319\t        // Should have errors for: task1/driver, task1/agent, task2/agent\n1320\t        expect(pe.errors.length).toBeGreaterThanOrEqual(3);\n1321\t        expect(pe.errors.some((e) => e.path === '/tasks/task1/driver')).toBe(true);\n1322\t        expect(pe.errors.some((e) => e.path === '/tasks/task1/agent')).toBe(true);\n1323\t        expect(pe.errors.some((e) => e.path === '/tasks/task2/agent')).toBe(true);\n1324\t      }\n1325\t    });\n1326\t\n1327\t    it('combines flow-ref and driver/agent errors in a single throw (AC #7)', () => {\n1328\t      registerDriver(mockDriver('claude-code'));\n1329\t\n1330\t      const yaml = `\n1331\ttasks:\n1332\t  implement:\n1333\t    agent: fake-agent\n1334\t    driver: bad-driver\n1335\tflow:\n1336\t  - implement\n1337\t  - nonexistent-task\n1338\t`;\n1339\t      const filePath = writeYaml('combined-errors.yaml', yaml);"}]},"parent_tool_use_id":"toolu_01NbvnX8QKy5nChzR2X7gMdM","session_id":"4b1f7711-6ed7-4488-a0af-b261e761b450","uuid":"2c596747-5171-481f-9371-9b19b14813