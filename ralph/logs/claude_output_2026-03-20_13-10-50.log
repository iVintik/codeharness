{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014D158RNSRH47Rg7DPLT9jX","type":"tool_result","content":"     1→/**\n     2→ * CLI command: `codeharness audit`\n     3→ *\n     4→ * Checks all compliance dimensions and reports project health.\n     5→ * Supports --json for machine-readable output.\n     6→ * Supports --fix to generate stories for audit gaps (FR15).\n     7→ */\n     8→\n     9→import { Command } from 'commander';\n    10→import { ok as okOutput, fail as failOutput, info, jsonOutput } from '../lib/output.js';\n    11→import { runPreconditions } from '../lib/onboard-checks.js';\n    12→import { runAudit } from '../modules/audit/index.js';\n    13→import { formatAuditHuman, formatAuditJson } from '../modules/audit/report.js';\n    14→import { generateFixStories, addFixStoriesToState } from '../modules/audit/index.js';\n    15→\n    16→export function registerAuditCommand(program: Command): void {\n    17→  program\n    18→    .command('audit')\n    19→    .description('Check all compliance dimensions and report project health')\n    20→    .option('--json', 'Output in machine-readable JSON format')\n    21→    .option('--fix', 'Generate fix stories for every gap found')\n    22→    .action(async (opts, cmd) => {\n    23→      const globalOpts = cmd.optsWithGlobals();\n    24→      const isJson = opts.json === true || globalOpts.json === true;\n    25→      const isFix = opts.fix === true;\n    26→\n    27→      // Precondition: harness must be initialized (AC #10)\n    28→      const preconditions = runPreconditions();\n    29→      if (!preconditions.canProceed) {\n    30→        if (isJson) {\n    31→          jsonOutput({\n    32→            status: 'fail',\n    33→            message: 'Harness not initialized -- run codeharness init first',\n    34→          });\n    35→        } else {\n    36→          failOutput('Harness not initialized -- run codeharness init first');\n    37→        }\n    38→        process.exitCode = 1;\n    39→        return;\n    40→      }\n    41→\n    42→      // Run audit\n    43→      const result = await runAudit(process.cwd());\n    44→\n    45→      if (!result.success) {\n    46→        if (isJson) {\n    47→          jsonOutput({ status: 'fail', message: result.error });\n    48→        } else {\n    49→          failOutput(result.error);\n    50→        }\n    51→        process.exitCode = 1;\n    52→        return;\n    53→      }\n    54→\n    55→      // Handle --fix flag\n    56→      let fixStories: ReturnType<typeof generateFixStories> extends infer R ? R : never = undefined as never;\n    57→\n    58→      if (isFix) {\n    59→        // AC #4: No gaps found\n    60→        if (result.data.gapCount === 0) {\n    61→          if (!isJson) {\n    62→            okOutput('No gaps found -- nothing to fix');\n    63→          }\n    64→        } else {\n    65→          // Generate fix stories\n    66→          const fixResult = generateFixStories(result.data);\n    67→          fixStories = fixResult;\n    68→\n    69→          if (fixResult.success) {\n    70→            // Add to sprint state (AC #2)\n    71→            const stateResult = addFixStoriesToState(fixResult.data.stories);\n    72→            if (!stateResult.success && !isJson) {\n    73→              failOutput(`Failed to update sprint state: ${stateResult.error}`);\n    74→            }\n    75→\n    76→            if (!isJson) {\n    77→              info(`Generated ${fixResult.data.created} fix stories (${fixResult.data.skipped} skipped)`);\n    78→            }\n    79→          } else if (!isJson) {\n    80→            failOutput(fixResult.error);\n    81→          }\n    82→        }\n    83→      }\n    84→\n    85→      // Format output\n    86→      if (isJson) {\n    87→        const jsonData: Record<string, unknown> = formatAuditJson(result.data) as unknown as Record<string, unknown>;\n    88→        // AC #5: Include fixStories in JSON when --fix\n    89→        if (isFix) {\n    90→          if (result.data.gapCount === 0) {\n    91→            jsonData.fixStories = [];\n    92→          } else if (fixStories && fixStories.success) {\n    93→            jsonData.fixStories = fixStories.data.stories.map(s => ({\n    94→              key: s.key,\n    95→              filePath: s.filePath,\n    96→              gap: s.gap,\n    97→              ...(s.skipped ? { skipped: true } : {}),\n    98→            }));\n    99→          }\n   100→        }\n   101→        jsonOutput(jsonData);\n   102→      } else if (!isFix || (isFix && result.data.gapCount > 0)) {\n   103→        // Print human audit output (skip if --fix with no gaps, already printed OK)\n   104→        const lines = formatAuditHuman(result.data);\n   105→        for (const line of lines) {\n   106→          console.log(line);\n   107→        }\n   108→      }\n   109→\n   110→      // Set exit code based on overall status\n   111→      if (result.data.overallStatus === 'fail') {\n   112→        process.exitCode = 1;\n   113→      }\n   114→    });\n   115→}\n   116→"}]},"parent_tool_use_id":"toolu_01KBt1xzNkF45pjf2bZesegY","session_id":"0deb1693-f450-4ee3-ba9f-130c7ba0aec5","uuid":"4123db3a-6764-4b90-9ff8-db59da3ef45b","timestamp":"2026-03-20T09:21:33.735Z"}
