{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BxXnRifWpdMktp4tfSFQtP","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport {\n3\t  resolveSessionId,\n4\t  recordSessionId,\n5\t  getLastSessionId,\n6\t} from '../session-manager.js';\n7\timport type { SessionBoundary, SessionLookupKey } from '../session-manager.js';\n8\timport type { WorkflowState, TaskCheckpoint } from '../workflow-state.js';\n9\timport { getDefaultWorkflowState } from '../workflow-state.js';\n10\t\n11\t// --- Helpers ---\n12\t\n13\tfunction makeState(checkpoints: TaskCheckpoint[]): WorkflowState {\n14\t  return {\n15\t    ...getDefaultWorkflowState(),\n16\t    tasks_completed: checkpoints,\n17\t  };\n18\t}\n19\t\n20\tfunction makeCheckpoint(overrides?: Partial<TaskCheckpoint>): TaskCheckpoint {\n21\t  return {\n22\t    task_name: 'implement-feature',\n23\t    story_key: '4-2-session-boundary',\n24\t    completed_at: '2026-04-01T00:00:00.000Z',\n25\t    ...overrides,\n26\t  };\n27\t}\n28\t\n29\tfunction makeKey(overrides?: Partial<SessionLookupKey>): SessionLookupKey {\n30\t  return {\n31\t    taskName: 'implement-feature',\n32\t    storyKey: '4-2-session-boundary',\n33\t    ...overrides,\n34\t  };\n35\t}\n36\t\n37\t// --- Tests ---\n38\t\n39\tdescribe('session-manager', () => {\n40\t  describe('resolveSessionId', () => {\n41\t    it('returns undefined for fresh boundary regardless of state', () => {\n42\t      const state = makeState([\n43\t        makeCheckpoint({ session_id: 'sess-existing' }),\n44\t      ]);\n45\t\n46\t      const result = resolveSessionId('fresh', makeKey(), state);\n47\t\n48\t      expect(result).toBeUndefined();\n49\t    });\n50\t\n51\t    it('returns undefined for fresh boundary with empty state', () => {\n52\t      const state = makeState([]);\n53\t\n54\t      const result = resolveSessionId('fresh', makeKey(), state);\n55\t\n56\t      expect(result).toBeUndefined();\n57\t    });\n58\t\n59\t    it('returns undefined for continue boundary when no prior checkpoint exists', () => {\n60\t      const state = makeState([]);\n61\t\n62\t      const result = resolveSessionId('continue', makeKey(), state);\n63\t\n64\t      expect(result).toBeUndefined();\n65\t    });\n66\t\n67\t    it('returns undefined for continue boundary when checkpoints exist but none match', () => {\n68\t      const state = makeState([\n69\t        makeCheckpoint({\n70\t          task_name: 'other-task',\n71\t          story_key: 'other-story',\n72\t          session_id: 'sess-other',\n73\t        }),\n74\t      ]);\n75\t\n76\t      const result = resolveSessionId('continue', makeKey(), state);\n77\t\n78\t      expect(result).toBeUndefined();\n79\t    });\n80\t\n81\t    it('returns session ID from matching checkpoint for continue boundary', () => {\n82\t      const state = makeState([\n83\t        makeCheckpoint({ session_id: 'sess-abc-123' }),\n84\t      ]);\n85\t\n86\t      const result = resolveSessionId('continue', makeKey(), state);\n87\t\n88\t      expect(result).toBe('sess-abc-123');\n89\t    });\n90\t\n91\t    it('returns most recent session ID when multiple checkpoints exist (loop iterations)', () => {\n92\t      const state = makeState([\n93\t        makeCheckpoint({\n94\t          session_id: 'sess-iter-1',\n95\t          completed_at: '2026-04-01T00:00:00.000Z',\n96\t        }),\n97\t        makeCheckpoint({\n98\t          session_id: 'sess-iter-2',\n99\t          completed_at: '2026-04-01T01:00:00.000Z',\n100\t        }),\n101\t        makeCheckpoint({\n102\t          session_id: 'sess-iter-3',\n103\t          completed_at: '2026-04-01T02:00:00.000Z',\n104\t        }),\n105\t      ]);\n106\t\n107\t      const result = resolveSessionId('continue', makeKey(), state);\n108\t\n109\t      expect(result).toBe('sess-iter-3');\n110\t    });\n111\t\n112\t    it('skips checkpoints with undefined session_id when looking for continue', () => {\n113\t      const state = makeState([\n114\t        makeCheckpoint({ session_id: 'sess-first' }),\n115\t        makeCheckpoint({ session_id: undefined }),\n116\t      ]);\n117\t\n118\t      const result = resolveSessionId('continue', makeKey(), state);\n119\t\n120\t      // Most recent checkpoint has undefined session_id, so it's skipped\n121\t      expect(result).toBe('sess-first');\n122\t    });\n123\t\n124\t    it('matches on both taskName and storyKey', () => {\n125\t      const state = makeState([\n126\t        makeCheckpoint({\n127\t          task_name: 'implement-feature',\n128\t          story_key: 'wrong-story',\n129\t          session_id: 'sess-wrong-story',\n130\t        }),\n131\t        makeCheckpoint({\n132\t          task_name: 'wrong-task',\n133\t          story_key: '4-2-session-boundary',\n134\t          session_id: 'sess-wrong-task',\n135\t        }),\n136\t        makeCheckpoint({\n137\t          task_name: 'implement-feature',\n138\t          story_key: '4-2-session-boundary',\n139\t          session_id: 'sess-correct',\n140\t        }),\n141\t      ]);\n142\t\n143\t      const result = resolveSessionId('continue', makeKey(), state);\n144\t\n145\t      expect(result).toBe('sess-correct');\n146\t    });\n147\t\n148\t    it('defaults to fresh behavior when boundary is fresh (schema default)', () => {\n149\t      // This test verifies that the default session value (fresh) produces no resume\n150\t      const boundary: SessionBoundary = 'fresh'; // workflow schema default\n151\t      const state = makeState([\n152\t        makeCheckpoint({ session_id: 'sess-should-not-use' }),\n153\t      ]);\n154\t\n155\t      const result = resolveSessionId(boundary, makeKey(), state);\n156\t\n157\t      expect(result).toBeUndefined();\n158\t    });\n159\t\n160\t    it('returns undefined for unknown boundary value (defensive fallback to fresh)', () => {\n161\t      const state = makeState([\n162\t        makeCheckpoint({ session_id: 'sess-existing' }),\n163\t      ]);\n164\t\n165\t      // Force an invalid boundary value to test defensive check\n166\t      const result = resolveSessionId('invalid' as SessionBoundary, makeKey(), state);\n167\t\n168\t      expect(result).toBeUndefined();\n169\t    });\n170\t  });\n171\t\n172\t  describe('recordSessionId', () => {\n173\t    it('returns a new state with session_id on the checkpoint', () => {\n174\t      const originalState = makeState([]);\n175\t\n176\t      const newState = recordSessionId(makeKey(), 'sess-new-123', originalState);\n177\t\n178\t      expect(newState.tasks_completed).toHaveLength(1);\n179\t      expect(newState.tasks_completed[0].session_id).toBe('sess-new-123');\n180\t      expect(newState.tasks_completed[0].task_name).toBe('implement-feature');\n181\t      expect(newState.tasks_completed[0].story_key).toBe('4-2-session-boundary');\n182\t      expect(newState.tasks_completed[0].completed_at).toBeTruthy();\n183\t    });\n184\t\n185\t    it('does not mutate the original state', () => {\n186\t      const originalState = makeState([]);\n187\t      const originalLength = originalState.tasks_completed.length;\n188\t\n189\t      recordSessionId(makeKey(), 'sess-new', originalState);\n190\t\n191\t      expect(originalState.tasks_completed.length).toBe(originalLength);\n192\t    });\n193\t\n194\t    it('appends to existing checkpoints', () => {\n195\t      const existingCheckpoint = makeCheckpoint({ session_id: 'sess-existing' });\n196\t      const originalState = makeState([existingCheckpoint]);\n197\t\n198\t      const newState = recordSessionId(makeKey(), 'sess-appended', originalState);\n199\t\n200\t      expect(newState.tasks_completed).toHaveLength(2);\n201\t      expect(newState.tasks_completed[0].session_id).toBe('sess-existing');\n202\t      expect(newState.tasks_completed[1].session_id).toBe('sess-appended');\n203\t    });\n204\t\n205\t    it('throws when sessionId is empty string', () => {\n206\t      const state = makeState([]);\n207\t\n208\t      expect(() => recordSessionId(makeKey(), '', state)).toThrow(\n209\t        'recordSessionId: sessionId must be a non-empty string',\n210\t      );\n211\t    });\n212\t\n213\t    it('preserves other state fields', () => {\n214\t      const originalState: WorkflowState = {\n215\t        ...getDefaultWorkflowState(),\n216\t        workflow_name: 'test-workflow',\n217\t        iteration: 5,\n218\t        phase: 'execute',\n219\t      };\n220\t\n221\t      const newState = recordSessionId(makeKey(), 'sess-new', originalState);\n222\t\n223\t      expect(newState.workflow_name).toBe('test-workflow');\n224\t      expect(newState.iteration).toBe(5);\n225\t      expect(newState.phase).toBe('execute');\n226\t    });\n227\t  });\n228\t\n229\t  describe('getLastSessionId', () => {\n230\t    it('returns undefined when no checkpoints exist', () => {\n231\t      const state = makeState([]);\n232\t\n233\t      const result = getLastSessionId(state, 'any-task', 'any-story');\n234\t\n235\t      expect(result).toBeUndefined();\n236\t    });\n237\t\n238\t    it('returns undefined when no matching checkpoint exists', () => {\n239\t      const state = makeState([\n240\t        makeCheckpoint({\n241\t          task_name: 'other-task',\n242\t          story_key: 'other-story',\n243\t          session_id: 'sess-other',\n244\t        }),\n245\t      ]);\n246\t\n247\t      const result = getLastSessionId(state, 'my-task', 'my-story');\n248\t\n249\t      expect(result).toBeUndefined();\n250\t    });\n251\t\n252\t    it('returns the most recent match (reverse order)', () => {\n253\t      const state = makeState([\n254\t        makeCheckpoint({ session_id: 'sess-old' }),\n255\t        makeCheckpoint({ session_id: 'sess-new' }),\n256\t      ]);\n257\t\n258\t      const result = getLastSessionId(state, 'implement-feature', '4-2-session-boundary');\n259\t\n260\t      expect(result).toBe('sess-new');\n261\t    });\n262\t\n263\t    it('skips checkpoints where session_id is undefined', () => {\n264\t      const state = makeState([\n265\t        makeCheckpoint({ session_id: 'sess-has-id' }),\n266\t        makeCheckpoint({ session_id: undefined }),\n267\t      ]);\n268\t\n269\t      const result = getLastSessionId(state, 'implement-feature', '4-2-session-boundary');\n270\t\n271\t      expect(result).toBe('sess-has-id');\n272\t    });\n273\t\n274\t    it('returns undefined when matching checkpoints have no session_id', () => {\n275\t      const state = makeState([\n276\t        makeCheckpoint({ session_id: undefined }),\n277\t      ]);\n278\t\n279\t      const result = getLastSessionId(state, 'implement-feature', '4-2-session-boundary');\n280\t\n281\t      expect(result).toBeUndefined();\n282\t    });\n283\t\n284\t    it('returns empty string session_id when present (does not skip it)', () => {\n285\t      // After recordSessionId validation, empty strings should never appear,\n286\t      // but getLastSessionId should not silently skip them if they do.\n287\t      const state = makeState([\n288\t        makeCheckpoint({ session_id: '' }),\n289\t      ]);\n290\t\n291\t      const result = getLastSessionId(state, 'implement-feature', '4-2-session-boundary');\n292\t\n293\t      // Empty string is not undefined, so it IS returned\n294\t      expect(result).toBe('');\n295\t    });\n296\t  });\n297\t\n298\t  describe('crash recovery scenario', () => {\n299\t    it('session ID retrieved from deserialized state (simulating disk round-trip)', () => {\n300\t      // Simulate a state that was previously persisted and then read back from disk.\n301\t      // The workflow-engine would call readWorkflowState() which returns a WorkflowState.\n302\t      // We verify that resolveSessionId works correctly with such deserialized state.\n303\t      const deserializedState: WorkflowState = {\n304\t        workflow_name: 'harness-run',\n305\t        started: '2026-04-01T00:00:00.000Z',\n306\t        iteration: 3,\n307\t        phase: 'execute',\n308\t        tasks_completed: [\n309\t          {\n310\t            task_name: 'implement-feature',\n311\t            story_key: '4-2-session-boundary',\n312\t            completed_at: '2026-04-01T01:00:00.000Z',\n313\t            session_id: 'sess-persisted-abc',\n314\t          },\n315\t          {\n316\t            task_name: 'write-tests',\n317\t            story_key: '4-2-session-boundary',\n318\t            completed_at: '2026-04-01T02:00:00.000Z',\n319\t            session_id: 'sess-persisted-def',\n320\t          },\n321\t        ],\n322\t        evaluator_scores: [],\n323\t        circuit_breaker: {\n324\t          triggered: false,\n325\t          reason: null,\n326\t          score_history: [],\n327\t        },\n328\t      };\n329\t\n330\t      // After crash recovery, the engine calls resolveSessionId with the persisted state\n331\t      const sessionId = resolveSessionId(\n332\t        'continue',\n333\t        { taskName: 'implement-feature', storyKey: '4-2-session-boundary' },\n334\t        deserializedState,\n335\t      );\n336\t\n337\t      expect(sessionId).toBe('sess-persisted-abc');\n338\t\n339\t      // Different task in the same story gets its own session\n340\t      const testSessionId = resolveSessionId(\n341\t        'continue',\n342\t        { taskName: 'write-tests', storyKey: '4-2-session-boundary' },\n343\t        deserializedState,\n344\t      );\n345\t\n346\t      expect(testSessionId).toBe('sess-persisted-def');\n347\t    });\n348\t  });\n349\t\n350\t  describe('loop iteration behavior', () => {\n351\t    it('fresh in loop: returns undefined for every iteration', () => {\n352\t      // Simulate a loop where previous iterations already recorded checkpoints\n353\t      const state = makeState([\n354\t        makeCheckpoint({ session_id: 'sess-loop-1' }),\n355\t        makeCheckpoint({ session_id: 'sess-loop-2' }),\n356\t      ]);\n357\t\n358\t      // Each loop iteration with session: fresh starts a new session\n359\t      const iter3 = resolveSessionId('fresh', makeKey(), state);\n360\t      expect(iter3).toBeUndefined();\n361\t    });\n362\t\n363\t    it('continue in loop: returns session ID from previous iteration', () => {\n364\t      // Simulate loop iteration 1 completed\n365\t      const stateAfterIter1 = makeState([\n366\t        makeCheckpoint({ session_id: 'sess-loop-iter-1' }),\n367\t      ]);\n368\t\n369\t      // Iteration 2 should continue from iteration 1\n370\t      const iter2SessionId = resolveSessionId('continue', makeKey(), stateAfterIter1);\n371\t      expect(iter2SessionId).toBe('sess-loop-iter-1');\n372\t\n373\t      // After iteration 2 completes, record its session\n374\t      const stateAfterIter2 = recordSessionId(makeKey(), 'sess-loop-iter-2', stateAfterIter1);\n375\t\n376\t      // Iteration 3 should continue from iteration 2 (most recent)\n377\t      const iter3SessionId = resolveSessionId('continue', makeKey(), stateAfterIter2);\n378\t      expect(iter3SessionId).toBe('sess-loop-iter-2');\n379\t    });\n380\t\n381\t    it('fresh in loop: each iteration session ID is independently recorded', () => {\n382\t      let state = makeState([]);\n383\t\n384\t      // Simulate 3 loop iterations, each recording independently\n385\t      state = recordSessionId(makeKey(), 'sess-fresh-1', state);\n386\t      state = recordSessionId(makeKey(), 'sess-fresh-2', state);\n387\t      state = recordSessionId(makeKey(), 'sess-fresh-3', state);\n388\t\n389\t      expect(state.tasks_completed).toHaveLength(3);\n390\t      expect(state.tasks_completed[0].session_id).toBe('sess-fresh-1');\n391\t      expect(state.tasks_completed[1].session_id).toBe('sess-fresh-2');\n392\t      expect(state.tasks_completed[2].session_id).toBe('sess-fresh-3');\n393\t    });\n394\t  });\n395\t});\n396\t"}]},"parent_tool_use_id":"toolu_01Le5u7XBMVhVN7gReXY7qLB","session_id":"45fbbef5-e9ca-4512-91b9-2760b179ad44","uuid":"33e4b1c5-fad9-488f-8d57-23a1fbebcced","timestamp":"2026-04-02T20:21:34.991Z"}
