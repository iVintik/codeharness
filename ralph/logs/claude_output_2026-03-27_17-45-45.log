roperty('observabilityCount');\n   346→    expect(result).toHaveProperty('otherCount');\n   347→    expect(result).toHaveProperty('blackBoxPass');\n   348→    expect(result.dockerExecCount).toBe(1);\n   349→    expect(result.blackBoxPass).toBe(true);\n   350→    expect(result.passed).toBe(true);\n   351→  });\n   352→\n   353→  it('rejects proofs where >50% of commands are grep against src/', () => {\n   354→    const path = join(testDir, 'proof.md');\n   355→    writeFileSync(path, [\n   356→      '## AC 1: Check impl',\n   357→      '',\n   358→      '```bash',\n   359→      \"grep -rn 'function' src/lib/verify.ts\",\n   360→      '```',\n   361→      '',\n   362→      '```output',\n   363→      '42: function validateProofQuality() {',\n   364→      '```',\n   365→      '',\n   366→      '```bash',\n   367→      \"grep -rn 'export' src/lib/output.ts\",\n   368→      '```',\n   369→      '',\n   370→      '```output',\n   371→      '1: export function ok() {}',\n   372→      '```',\n   373→    ].join('\\n'));\n   374→\n   375→    const result = validateProofQuality(path);\n   376→    expect(result.grepSrcCount).toBe(2);\n   377→    expect(result.blackBoxPass).toBe(false);\n   378→    expect(result.passed).toBe(false);\n   379→  });\n   380→\n   381→  it('rejects proofs with zero docker exec per AC', () => {\n   382→    const path = join(testDir, 'proof.md');\n   383→    writeFileSync(path, [\n   384→      '## AC 1: Check something',\n   385→      '',\n   386→      '```bash',\n   387→      'cat README.md',\n   388→      '```',\n   389→      '',\n   390→      '```output',\n   391→      '# Codeharness',\n   392→      '```',\n   393→    ].join('\\n'));\n   394→\n   395→    const result = validateProofQuality(path);\n   396→    expect(result.dockerExecCount).toBe(0);\n   397→    expect(result.blackBoxPass).toBe(false);\n   398→    expect(result.passed).toBe(false);\n   399→  });\n   400→\n   401→  it('passes proofs with adequate docker exec and observability evidence', 