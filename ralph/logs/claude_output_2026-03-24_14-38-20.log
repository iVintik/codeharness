nst result = getStoryDrillDown(state, '2-3-status');\n   266→    expect(result.success).toBe(true);\n   267→    if (!result.success) return;\n   268→    expect(result.data.acDetails).toHaveLength(4);\n   269→    expect(result.data.acDetails[0].verdict).toBe('pass');\n   270→    expect(result.data.acDetails[1].verdict).toBe('fail');\n   271→    expect(result.data.acDetails[2].verdict).toBe('escalate');\n   272→    expect(result.data.acDetails[3].verdict).toBe('pending');\n   273→  });\n   274→\n   275→  it('includes reason for FAIL verdict from lastError', () => {\n   276→    const state = makeState({\n   277→      stories: {\n   278→        '2-3-status': s({\n   279→          status: 'failed', attempts: 1,\n   280→          lastError: 'container name mismatch',\n   281→          acResults: [{ id: 'AC4', verdict: 'fail' }],\n   282→        }),\n   283→      },\n   284→    });\n   285→    const result = getStoryDrillDown(state, '2-3-status');\n   286→    expect(result.success).toBe(true);\n   287→    if (!result.success) return;\n   288→    const failAc = result.data.acDetails[0];\n   289→    expect(failAc.verdict).toBe('fail');\n   290→    expect(failAc.reason).toBe('container name mismatch');\n   291→  });\n   292→\n   293→  it('renders attempt history with synthetic entries for old attempts', () => {\n   294→    const state = makeState({\n   295→      stories: {\n   296→        '2-3-status': s({\n   297→          status: 'failed', attempts: 3,\n   298→          lastAttempt: '2026-03-18T03:42:15Z',\n   299→          lastError: 'exit 1',\n   300→          acResults: [{ id: 'AC4', verdict: 'fail' }],\n   301→        }),\n   302→      },\n   303→    });\n   304→    const result = getStoryDrillDown(state, '2-3-status');\n   305→    expect(result.success).toBe(true);\n   306→    if (!result.success) return;\n   307→    expect(result.data.attemptHistory).toHaveLength(3);\n   308→    expect(result.data.attemptHistory[0]).toEqual({ number: 1, outcome: 'details unavailable' });\n   309→    expect(result.data.attemptHistory[1]).toEqual({ number: 2, outcome: 'details unavailable' });\n   310→    expect(result.data.attemptHistory[2].number).toBe(3);\n   311→    expect(result.data.attemptHistory[2].outcome).toBe('verify failed');\n   312→    expect(result.data.attemptHistory[2].failingAc).toBe('AC4');\n   313→    expect(result.data.attemptHistory[2].timestamp).toBe('2026-03-18T03:42:15Z');\n   314→  });\n   315→\n   316→  it('shows proof summary with counts', () => {\n   317→    const acResults: AcResult[] = [\n   318→      { id: 'AC1', verdict: 'pass' },\n   319→      { id: 'AC2', verdict: 'pass' },\n   320→      { id: 'AC3', verdict: 'fail' },\n   321→      { id: 'AC4', verdict: 'escalate' },\n   322→    ];\n   323→    const state = makeState({\n   324→      stories: {\n   325→        '2-3-status': s({\n   326→          status: 'failed', attempts: 1,\n   327→          proofPath: 'verification/2-3-proof.md',\n   328→          acResults,\n   329→        }),\n   330→      },\n   331→    });\n   332→    const result = getStoryDrillDown(state, '2-3-status');\n   333→    expect(result.success).toBe(true);\n   334→    if (!result.success) return;\n   335→    expect(result.data.proofSummary).not.toBeNull();\n   336→    expect(result.data.proofSummary!.path).toBe('verification/2-3-proof.md');\n   337→    expect(result.data.proofSummary!.passCount).toBe(2);\n   338→    expect(result.data.proofSummary!.failCount).toBe(1);\n   339→    expect(result.data.proofSummary!.escalateCount).toBe(1);\n   340→    expect(result.data.proofSummary!.pendingCount).toBe(0);\n   341→  });\n   342→\n   343→  it('returns fail() for story not found', () => {\n   344→    const state = makeState({ stories: {} });\n   345→    const result = getStoryDrillDown(state, 'nonexistent');\n   346→    expect(result.success).toBe(false);\n   347→    if (!result.success) {\n   348→      expect(result.error).toContain(\"Story 'nonexistent' not found\");\n   349→    }\n   350→  });\n  