{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01X85DLZv7Qb4jgp2agAMD1D","type":"tool_result","content":"     1→/**\n     2→ * Ink Terminal Renderer — live terminal UI for Claude activity display.\n     3→ *\n     4→ * Exports a controller API: startRenderer(), which returns a RendererHandle\n     5→ * with update(), updateSprintState(), and cleanup() methods.\n     6→ *\n     7→ * The renderer accumulates state from StreamEvent objects and renders\n     8→ * tool calls, thoughts, and sprint progress using Ink (React for terminals).\n     9→ */\n    10→\n    11→import React from 'react';\n    12→import { render as inkRender } from 'ink';\n    13→import type { StreamEvent } from './stream-parser.js';\n    14→import {\n    15→  App,\n    16→  type SprintInfo,\n    17→  type CompletedToolEntry,\n    18→  type RetryInfo,\n    19→  type RendererState,\n    20→  type StoryStatusEntry,\n    21→  type StoryMessage,\n    22→} from './ink-components.js';\n    23→\n    24→// --- Public Types ---\n    25→\n    26→export interface RendererOptions {\n    27→  quiet?: boolean;\n    28→  sprintState?: SprintInfo;\n    29→  /** @internal Force TTY mode for testing. Not part of the public API. */\n    30→  _forceTTY?: boolean;\n    31→}\n    32→\n    33→export interface RendererHandle {\n    34→  update(event: StreamEvent): void;\n    35→  updateSprintState(state: SprintInfo | undefined): void;\n    36→  updateStories(stories: StoryStatusEntry[]): void;\n    37→  addMessage(msg: StoryMessage): void;\n    38→  cleanup(): void;\n    39→}\n    40→\n    41→// --- No-op handle for quiet mode ---\n    42→\n    43→const noopHandle: RendererHandle = {\n    44→  update() {},\n    45→  updateSprintState() {},\n    46→  updateStories() {},\n    47→  addMessage() {},\n    48→  cleanup() {},\n    49→};\n    50→\n    51→/** Maximum number of completed tools to retain in the display list. */\n    52→const MAX_COMPLETED_TOOLS = 50;\n    53→\n    54→// --- Controller ---\n    55→\n    56→/**\n    57→ * Start the Ink terminal renderer.\n    58→ *\n    59→ * If `quiet` is true or stdout is not a TTY, returns a no-op handle\n    60→ * (no Ink instance created).\n    61→ * Otherwise, mounts the component tree and returns a handle for feeding events.\n    62→ */\n    63→export function startRenderer(options?: RendererOptions): RendererHandle {\n    64→  if (options?.quiet || (!process.stdout.isTTY && !options?._forceTTY)) {\n    65→    return noopHandle;\n    66→  }\n    67→\n    68→  // Clear screen so dashboard renders from top\n    69→  process.stdout.write('\\x1b[2J\\x1b[H');\n    70→\n    71→  // Mutable state that drives re-renders\n    72→  let state: RendererState = {\n    73→    sprintInfo: options?.sprintState ?? null,\n    74→    stories: [],\n    75→    messages: [],\n    76→    completedTools: [],\n    77→    activeTool: null,\n    78→    activeToolArgs: '',\n    79→    lastThought: null,\n    80→    retryInfo: null,\n    81→  };\n    82→\n    83→  let cleaned = false;\n    84→\n    85→  // Mount Ink with performance optimizations\n    86→  const inkInstance = inkRender(<App state={state} />, {\n    87→    exitOnCtrlC: false,\n    88→    patchConsole: false,\n    89→    incrementalRendering: true,  // Only redraw changed lines (v6.5+)\n    90→    maxFps: 15,                  // Dashboard doesn't need 30fps\n    91→  });\n    92→\n    93→  function rerender() {\n    94→    if (!cleaned) {\n    95→      // Create a new state object reference to trigger React re-render\n    96→      state = { ...state };\n    97→      inkInstance.rerender(<App state={state} />);\n    98→    }\n    99→  }\n   100→\n   101→  function cleanup() {\n   102→    if (cleaned) return;\n   103→    cleaned = true;\n   104→    try {\n   105→      inkInstance.unmount();\n   106→    } catch {\n   107→      // Ignore — may already be unmounted\n   108→    }\n   109→    try {\n   110→      inkInstance.cleanup();\n   111→    } catch {\n   112→      // Ignore\n   113→    }\n   114→    // Remove our signal handlers\n   115→    process.removeListener('SIGINT', onSigint);\n   116→    process.removeListener('SIGTERM', onSigterm);\n   117→  }\n   118→\n   119→  function onSigint() {\n   120→    cleanup();\n   121→    // Re-raise signal so the default handler runs (allows caller to handle exit)\n   122→    process.kill(process.pid, 'SIGINT');\n   123→  }\n   124→\n   125→  function onSigterm() {\n   126→    cleanup();\n   127→    process.kill(process.pid, 'SIGTERM');\n   128→  }\n   129→\n   130→  // Register signal handlers\n   131→  process.on('SIGINT', onSigint);\n   132→  process.on('SIGTERM', onSigterm);\n   133→\n   134→  function update(event: StreamEvent): void {\n   135→    if (cleaned) return;\n   136→\n   137→    switch (event.type) {\n   138→      case 'tool-start':\n   139→        state.activeTool = { name: event.name };\n   140→        state.activeToolArgs = '';\n   141→        state.lastThought = null;\n   142→        state.retryInfo = null;\n   143→        break;\n   144→\n   145→      case 'tool-input':\n   146→        state.activeToolArgs += event.partial;\n   147→        break;\n   148→\n   149→      case 'tool-complete':\n   150→        // CRITICAL: Only promote if there's an active tool.\n   151→        // The parser emits tool-complete for ALL content_block_stop events\n   152→        // (both tool and text blocks). Ignore if no activeTool is set.\n   153→        if (state.activeTool) {\n   154→          const entry: CompletedToolEntry = {\n   155→            name: state.activeTool.name,\n   156→            args: state.activeToolArgs,\n   157→          };\n   158→          const updated = [...state.completedTools, entry];\n   159→          // Bound the list to prevent unbounded memory growth in long sessions\n   160→          state.completedTools = updated.length > MAX_COMPLETED_TOOLS\n   161→            ? updated.slice(updated.length - MAX_COMPLETED_TOOLS)\n   162→            : updated;\n   163→          state.activeTool = null;\n   164→          state.activeToolArgs = '';\n   165→        }\n   166→        break;\n   167→\n   168→      case 'text':\n   169→        state.lastThought = event.text;\n   170→        state.retryInfo = null;\n   171→        break;\n   172→\n   173→      case 'retry':\n   174→        state.retryInfo = { attempt: event.attempt, delay: event.delay };\n   175→        break;\n   176→\n   177→      case 'result':\n   178→        // No rendering change — handled by caller\n   179→        break;\n   180→    }\n   181→\n   182→    rerender();\n   183→  }\n   184→\n   185→  function updateSprintState(sprintState: SprintInfo | undefined): void {\n   186→    if (cleaned) return;\n   187→    state.sprintInfo = sprintState ?? null;\n   188→    rerender();\n   189→  }\n   190→\n   191→  function updateStories(stories: StoryStatusEntry[]): void {\n   192→    if (cleaned) return;\n   193→    state.stories = [...stories];\n   194→    rerender();\n   195→  }\n   196→\n   197→  function addMessage(msg: StoryMessage): void {\n   198→    if (cleaned) return;\n   199→    state.messages = [...state.messages, msg];\n   200→    rerender();\n   201→  }\n   202→\n   203→  return { update, updateSprintState, updateStories, addMessage, cleanup };\n   204→}\n   205→\n   206→// Re-export types that consumers may need\n   207→export type { SprintInfo, CompletedToolEntry, RetryInfo, RendererState, StoryStatusEntry, StoryStatusValue, StoryMessage } from './ink-components.js';\n   208→"}]},"parent_tool_use_id":"toolu_01RBNT2MWnVmL9E8BNgKEP4b","session_id":"3e8c45fc-a757-4d77-9a55-f32a41bfdb65","uuid":"baae06db-863d-4c6f-a619-8c57fcb7058d","timestamp":"2026-03-21T10:46:18.661Z"}
