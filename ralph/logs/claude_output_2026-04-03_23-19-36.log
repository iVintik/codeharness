{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CXMzKwWNQtTsV8pyeqMRM9","type":"tool_result","content":"1\t/**\n2\t * Worktree Manager.\n3\t *\n4\t * Handles git worktree lifecycle for parallel epic execution:\n5\t * create, cleanup, list, and orphan detection. Each epic gets\n6\t * its own git worktree on a dedicated branch under the\n7\t * `codeharness/` namespace.\n8\t *\n9\t * @see Story 17-1: Worktree Manager\n10\t */\n11\t\n12\timport { execSync } from 'node:child_process';\n13\timport { existsSync, readFileSync } from 'node:fs';\n14\timport { join } from 'node:path';\n15\t\n16\t// --- Constants ---\n17\t\n18\t/** Branch prefix for all codeharness worktree branches. */\n19\texport const BRANCH_PREFIX = 'codeharness/epic-';\n20\t\n21\t/** Base path for worktree directories in /tmp. */\n22\texport const WORKTREE_BASE = '/tmp/codeharness-wt-epic-';\n23\t\n24\t// --- Interfaces ---\n25\t\n26\t/**\n27\t * Information about a codeharness worktree.\n28\t */\n29\texport interface WorktreeInfo {\n30\t  /** Epic identifier extracted from the branch name. */\n31\t  readonly epicId: string;\n32\t  /** Absolute path to the worktree directory. */\n33\t  readonly path: string;\n34\t  /** Full branch name (e.g., `codeharness/epic-17-worktree-manager`). */\n35\t  readonly branch: string;\n36\t  /** Timestamp when the worktree was created. */\n37\t  readonly createdAt: Date;\n38\t}\n39\t\n40\t// --- Error Class ---\n41\t\n42\t/**\n43\t * Error thrown by worktree operations. Includes stderr from git commands.\n44\t */\n45\texport class WorktreeError extends Error {\n46\t  /** Raw stderr output from the failed git command. */\n47\t  readonly stderr: string;\n48\t\n49\t  constructor(message: string, stderr: string) {\n50\t    super(message);\n51\t    this.name = 'WorktreeError';\n52\t    this.stderr = stderr;\n53\t  }\n54\t}\n55\t\n56\t// --- WorktreeManager Class ---\n57\t\n58\t/**\n59\t * Manages git worktrees for parallel epic execution.\n60\t *\n61\t * Creates isolated working directories (worktrees) for each epic,\n62\t * each on its own branch under the `codeharness/` namespace.\n63\t */\n64\texport class WorktreeManager {\n65\t  private readonly mainBranch: string;\n66\t  private readonly cwd: string;\n67\t\n68\t  /**\n69\t   * @param mainBranch  The main branch to base new worktree branches on (default: `'main'`).\n70\t   * @param cwd  The git repository root directory (default: `process.cwd()`).\n71\t   */\n72\t  constructor(mainBranch: string = 'main', cwd?: string) {\n73\t    this.mainBranch = mainBranch;\n74\t    this.cwd = cwd ?? process.cwd();\n75\t  }\n76\t\n77\t  /**\n78\t   * Create a worktree for a parallel epic.\n79\t   *\n80\t   * Creates a branch `codeharness/epic-{epicId}-{slug}` from the main branch HEAD,\n81\t   * then creates a git worktree at `/tmp/codeharness-wt-epic-{epicId}`.\n82\t   *\n83\t   * If a stale branch or worktree exists from a previous crashed run,\n84\t   * it is cleaned up before re-creating (idempotent recovery).\n85\t   *\n86\t   * @param epicId  The epic identifier (numeric or string).\n87\t   * @param slug  A human-readable slug for the branch name (sanitized to `[a-z0-9-]`).\n88\t   * @returns The absolute path to the created worktree directory.\n89\t   * @throws {WorktreeError} If the git command fails.\n90\t   */\n91\t  createWorktree(epicId: string, slug: string): string {\n92\t    const sanitizedSlug = this.sanitizeSlug(slug);\n93\t    const branchName = `${BRANCH_PREFIX}${epicId}-${sanitizedSlug}`;\n94\t    const worktreePath = `${WORKTREE_BASE}${epicId}`;\n95\t\n96\t    // Clean up stale state from previous crashed runs (AC #9)\n97\t    this.cleanupStale(epicId, branchName, worktreePath);\n98\t\n99\t    let branchCreated = false;\n100\t    try {\n101\t      // Create branch from main branch HEAD\n102\t      this.execGit(`git branch ${branchName} ${this.mainBranch}`);\n103\t      branchCreated = true;\n104\t\n105\t      // Create worktree\n106\t      this.execGit(`git worktree add ${worktreePath} ${branchName}`);\n107\t\n108\t      return worktreePath;\n109\t    } catch (err: unknown) {\n110\t      // Clean up partial state on failure (AC #10)\n111\t      this.cleanupPartial(branchCreated, branchName, worktreePath);\n112\t\n113\t      if (err instanceof WorktreeError) {\n114\t        throw err;\n115\t      }\n116\t\n117\t      const stderr = (err as { stderr?: Buffer })?.stderr?.toString() ?? '';\n118\t      throw new WorktreeError(\n119\t        `Failed to create worktree for epic ${epicId}: ${stderr}`,\n120\t        stderr,\n121\t      );\n122\t    }\n123\t  }\n124\t\n125\t  /**\n126\t   * Remove a worktree and its branch for an epic.\n127\t   *\n128\t   * Idempotent: completes without error if the worktree or branch\n129\t   * does not exist (AC #5).\n130\t   *\n131\t   * @param epicId  The epic identifier.\n132\t   */\n133\t  cleanupWorktree(epicId: string): void {\n134\t    const worktreePath = `${WORKTREE_BASE}${epicId}`;\n135\t\n136\t    // Remove worktree (ignore errors if it doesn't exist)\n137\t    try {\n138\t      this.execGit(`git worktree remove ${worktreePath} --force`);\n139\t    } catch { // IGNORE: idempotent cleanup — worktree may not exist per AC #5\n140\t    }\n141\t\n142\t    // Find and delete the branch matching this epicId\n143\t    const branch = this.findBranchForEpic(epicId);\n144\t    if (branch) {\n145\t      try {\n146\t        this.execGit(`git branch -D ${branch}`);\n147\t      } catch { // IGNORE: idempotent cleanup — branch may not exist per AC #5\n148\t      }\n149\t    }\n150\t  }\n151\t\n152\t  /**\n153\t   * List all codeharness worktrees.\n154\t   *\n155\t   * @returns An array of `WorktreeInfo` objects sorted by epicId.\n156\t   *          Returns an empty array when no codeharness worktrees exist.\n157\t   */\n158\t  listWorktrees(): WorktreeInfo[] {\n159\t    let output: string;\n160\t    try {\n161\t      output = this.execGit('git worktree list --porcelain');\n162\t    } catch { // IGNORE: non-git-repo or corrupt state returns empty list safely\n163\t      return [];\n164\t    }\n165\t\n166\t    const entries = this.parsePorcelainOutput(output);\n167\t    return entries\n168\t      .filter((e) => e.branch.startsWith(`refs/heads/${BRANCH_PREFIX}`))\n169\t      .map((e) => {\n170\t        const branchName = e.branch.replace('refs/heads/', '');\n171\t        const epicId = this.extractEpicId(branchName);\n172\t        return {\n173\t          epicId,\n174\t          path: e.path,\n175\t          branch: branchName,\n176\t          createdAt: new Date(),\n177\t        };\n178\t      })\n179\t      .sort((a, b) => a.epicId.localeCompare(b.epicId, undefined, { numeric: true }));\n180\t  }\n181\t\n182\t  /**\n183\t   * Detect orphaned worktrees from previous crashed runs.\n184\t   *\n185\t   * A worktree is considered orphaned if its directory exists on disk\n186\t   * but has no `.codeharness/lane-state.json` file or the file has\n187\t   * no active PID.\n188\t   *\n189\t   * @returns An array of orphaned `WorktreeInfo` entries.\n190\t   */\n191\t  detectOrphans(): WorktreeInfo[] {\n192\t    const worktrees = this.listWorktrees();\n193\t    return worktrees.filter((wt) => this.isOrphaned(wt));\n194\t  }\n195\t\n196\t  // --- Private Helpers ---\n197\t\n198\t  /**\n199\t   * Sanitize a slug to contain only `[a-z0-9-]`.\n200\t   */\n201\t  private sanitizeSlug(slug: string): string {\n202\t    return slug\n203\t      .toLowerCase()\n204\t      .replace(/[^a-z0-9-]/g, '-')\n205\t      .replace(/-+/g, '-')\n206\t      .replace(/^-|-$/g, '');\n207\t  }\n208\t\n209\t  /**\n210\t   * Execute a git command and return its stdout.\n211\t   * Wraps errors in WorktreeError with captured stderr.\n212\t   */\n213\t  private execGit(cmd: string): string {\n214\t    try {\n215\t      const result = execSync(cmd, {\n216\t        cwd: this.cwd,\n217\t        stdio: ['pipe', 'pipe', 'pipe'],\n218\t        timeout: 30_000,\n219\t      });\n220\t      return result.toString().trim();\n221\t    } catch (err: unknown) {\n222\t      const stderr = (err as { stderr?: Buffer })?.stderr?.toString() ?? '';\n223\t      throw new WorktreeError(`Git command failed: ${cmd} — ${stderr}`, stderr);\n224\t    }\n225\t  }\n226\t\n227\t  /**\n228\t   * Clean up stale branch and worktree from a previous crash (AC #9).\n229\t   */\n230\t  private cleanupStale(epicId: string, branchName: string, worktreePath: string): void {\n231\t    // Check if worktree path exists on disk\n232\t    if (existsSync(worktreePath)) {\n233\t      try {\n234\t        this.execGit(`git worktree remove ${worktreePath} --force`);\n235\t      } catch { // IGNORE: stale worktree removal is best-effort before re-create per AC #9\n236\t        try {\n237\t          this.execGit('git worktree prune');\n238\t        } catch { // IGNORE: prune is best-effort fallback for stale worktree cleanup\n239\t        }\n240\t      }\n241\t    }\n242\t\n243\t    // Check if branch already exists\n244\t    const existingBranch = this.findBranchForEpic(epicId);\n245\t    if (existingBranch) {\n246\t      try {\n247\t        this.execGit(`git branch -D ${existingBranch}`);\n248\t      } catch { // IGNORE: stale branch deletion is best-effort before re-create per AC #9\n249\t      }\n250\t    }\n251\t  }\n252\t\n253\t  /**\n254\t   * Clean up partial state after a failed createWorktree (AC #10).\n255\t   */\n256\t  private cleanupPartial(branchCreated: boolean, branchName: string, worktreePath: string): void {\n257\t    // Try to remove worktree if it was partially created\n258\t    try {\n259\t      this.execGit(`git worktree remove ${worktreePath} --force`);\n260\t    } catch { // IGNORE: partial worktree may not exist during failure cleanup per AC #10\n261\t    }\n262\t\n263\t    // Delete branch if it was created\n264\t    if (branchCreated) {\n265\t      try {\n266\t        this.execGit(`git branch -D ${branchName}`);\n267\t      } catch { // IGNORE: partial branch may not exist during failure cleanup per AC #10\n268\t      }\n269\t    }\n270\t  }\n271\t\n272\t  /**\n273\t   * Find a branch matching `codeharness/epic-{epicId}-*`.\n274\t   */\n275\t  private findBranchForEpic(epicId: string): string | undefined {\n276\t    try {\n277\t      const output = this.execGit(`git branch --list ${BRANCH_PREFIX}${epicId}-*`);\n278\t      const branches = output\n279\t        .split('\\n')\n280\t        .map((b) => b.trim().replace(/^\\*\\s*/, ''))\n281\t        .filter((b) => b.length > 0);\n282\t      return branches[0];\n283\t    } catch { // IGNORE: branch listing failure means no branch exists — safe to return undefined\n284\t      return undefined;\n285\t    }\n286\t  }\n287\t\n288\t  /**\n289\t   * Parse `git worktree list --porcelain` output into structured entries.\n290\t   */\n291\t  private parsePorcelainOutput(output: string): Array<{ path: string; branch: string }> {\n292\t    if (!output.trim()) return [];\n293\t\n294\t    const blocks = output.split('\\n\\n').filter((b) => b.trim());\n295\t    const entries: Array<{ path: string; branch: string }> = [];\n296\t\n297\t    for (const block of blocks) {\n298\t      const lines = block.split('\\n');\n299\t      let path = '';\n300\t      let branch = '';\n301\t\n302\t      for (const line of lines) {\n303\t        if (line.startsWith('worktree ')) {\n304\t          path = line.slice('worktree '.length);\n305\t        } else if (line.startsWith('branch ')) {\n306\t          branch = line.slice('branch '.length);\n307\t        }\n308\t      }\n309\t\n310\t      if (path && branch) {\n311\t        entries.push({ path, branch });\n312\t      }\n313\t    }\n314\t\n315\t    return entries;\n316\t  }\n317\t\n318\t  /**\n319\t   * Extract epicId from a branch name like `codeharness/epic-17-slug`.\n320\t   */\n321\t  private extractEpicId(branchName: string): string {\n322\t    const withoutPrefix = branchName.slice(BRANCH_PREFIX.length);\n323\t    const dashIndex = withoutPrefix.indexOf('-');\n324\t    if (dashIndex === -1) return withoutPrefix;\n325\t    return withoutPrefix.slice(0, dashIndex);\n326\t  }\n327\t\n328\t  /**\n329\t   * Check if a worktree is orphaned (no active codeharness process).\n330\t   */\n331\t  private isOrphaned(wt: WorktreeInfo): boolean {\n332\t    const laneStatePath = join(wt.path, '.codeharness', 'lane-state.json');\n333\t\n334\t    if (!existsSync(laneStatePath)) {\n335\t      return true;\n336\t    }\n337\t\n338\t    try {\n339\t      const content = readFileSync(laneStatePath, 'utf-8');\n340\t      const state = JSON.parse(content) as { pid?: number };\n341\t\n342\t      if (!state.pid) {\n343\t        return true;\n344\t      }\n345\t\n346\t      // Check if the PID is still running\n347\t      try {\n348\t        process.kill(state.pid, 0);\n349\t        return false; // Process is alive — not orphaned\n350\t      } catch { // IGNORE: ESRCH means process is dead — worktree is orphaned per AC #8\n351\t        return true;\n352\t      }\n353\t    } catch { // IGNORE: unreadable/corrupt lane-state.json means orphaned per AC #8\n354\t      return true;\n355\t    }\n356\t  }\n357\t}\n358\t"}]},"parent_tool_use_id":"toolu_01M4NenhzW72RWGSvvu339mv","session_id":"187035da-d60e-40cf-8aef-09e6134be246","uuid":"7f161a86-735c-48ef-b675-59d526d7a346","timestamp":"2026-04-03T19:32:21.597Z"}
