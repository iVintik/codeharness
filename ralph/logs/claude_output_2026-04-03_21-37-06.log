{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GbqVJ71upcL1S3nJ7dD8gw","type":"tool_result","content":"1\timport { execSync } from 'node:child_process';\n2\timport { existsSync, readFileSync } from 'node:fs';\n3\timport { join } from 'node:path';\n4\timport { warn } from '../output.js';\n5\timport { readStateWithBody } from '../state.js';\n6\timport { detectStack, getStackProvider } from '../stacks/index.js';\n7\timport type { StackName } from '../stacks/index.js';\n8\timport type { CoverageToolInfo, CoverageResult } from './types.js';\n9\timport { parseTestCounts, parseCoverageReport } from './parser.js';\n10\t\n11\texport function detectCoverageTool(dir?: string): CoverageToolInfo {\n12\t  const baseDir = dir ?? process.cwd();\n13\t  const stateHint = getStateToolHint(baseDir);\n14\t  const stack = detectStack(baseDir);\n15\t  if (!stack) {\n16\t    warn('No recognized stack detected — cannot determine coverage tool');\n17\t    return { tool: 'unknown', runCommand: '', reportFormat: '' };\n18\t  }\n19\t\n20\t  const provider = getStackProvider(stack as StackName);\n21\t  if (!provider) {\n22\t    warn('No recognized stack detected — cannot determine coverage tool');\n23\t    return { tool: 'unknown', runCommand: '', reportFormat: '' };\n24\t  }\n25\t\n26\t  const detector = coverageDetectors[provider.name];\n27\t  if (detector) {\n28\t    return detector(baseDir, stateHint);\n29\t  }\n30\t\n31\t  warn('No recognized stack detected — cannot determine coverage tool');\n32\t  return { tool: 'unknown', runCommand: '', reportFormat: '' };\n33\t}\n34\t\n35\tconst coverageDetectors: Record<string, (dir: string, stateHint: string | null) => CoverageToolInfo> = {\n36\t  nodejs: (dir, stateHint) => detectNodeCoverageTool(dir, stateHint),\n37\t  python: (dir) => detectPythonCoverageTool(dir),\n38\t  rust: (dir) => detectRustCoverageTool(dir),\n39\t};\n40\t\n41\tfunction detectRustCoverageTool(dir: string): CoverageToolInfo {\n42\t  try {\n43\t    execSync('cargo tarpaulin --version', { stdio: 'pipe', timeout: 10_000 });\n44\t  } catch {\n45\t    // IGNORE: cargo-tarpaulin not installed\n46\t    warn('cargo-tarpaulin not installed — coverage detection unavailable');\n47\t    return { tool: 'unknown', runCommand: '', reportFormat: '' };\n48\t  }\n49\t\n50\t  // Detect workspace\n51\t  const cargoPath = join(dir, 'Cargo.toml');\n52\t  let isWorkspace = false;\n53\t  try {\n54\t    const cargoContent = readFileSync(cargoPath, 'utf-8');\n55\t    isWorkspace = /^\\[workspace\\]/m.test(cargoContent);\n56\t  } catch { /* IGNORE: Cargo.toml may not exist */ }\n57\t  const wsFlag = isWorkspace ? ' --workspace' : '';\n58\t  return {\n59\t    tool: 'cargo-tarpaulin',\n60\t    runCommand: `cargo tarpaulin --out json --output-dir coverage/${wsFlag}`,\n61\t    reportFormat: 'tarpaulin-json',\n62\t  };\n63\t}\n64\t\n65\tfunction getStateToolHint(dir: string): string | null {\n66\t  try {\n67\t    const { state } = readStateWithBody(dir);\n68\t    return state.coverage.tool || null;\n69\t  } catch {\n70\t    // IGNORE: state file may not exist\n71\t    return null;\n72\t  }\n73\t}\n74\t\n75\tfunction detectNodeCoverageTool(dir: string, stateHint: string | null): CoverageToolInfo {\n76\t  const hasVitestConfig =\n77\t    existsSync(join(dir, 'vitest.config.ts')) ||\n78\t    existsSync(join(dir, 'vitest.config.js'));\n79\t  const pkgPath = join(dir, 'package.json');\n80\t  let hasVitestCoverageV8 = false;\n81\t  let hasVitestCoverageIstanbul = false;\n82\t  let hasC8 = false;\n83\t  let hasJest = false;\n84\t  let pkgScripts: Record<string, string> = {};\n85\t\n86\t  if (existsSync(pkgPath)) {\n87\t    try {\n88\t      const pkg = JSON.parse(readFileSync(pkgPath, 'utf-8')) as {\n89\t        devDependencies?: Record<string, string>;\n90\t        dependencies?: Record<string, string>;\n91\t        scripts?: Record<string, string>;\n92\t      };\n93\t      const allDeps = { ...(pkg.dependencies ?? {}), ...(pkg.devDependencies ?? {}) };\n94\t      hasVitestCoverageV8 = '@vitest/coverage-v8' in allDeps;\n95\t      hasVitestCoverageIstanbul = '@vitest/coverage-istanbul' in allDeps;\n96\t      hasC8 = 'c8' in allDeps;\n97\t      hasJest = 'jest' in allDeps;\n98\t      pkgScripts = pkg.scripts ?? {};\n99\t    } catch {\n100\t      // IGNORE: malformed package.json, continue with defaults\n101\t    }\n102\t  }\n103\t\n104\t  if (hasVitestConfig || hasVitestCoverageV8 || hasVitestCoverageIstanbul) {\n105\t    const runCommand = getNodeTestCommand(pkgScripts, 'vitest');\n106\t    return { tool: 'c8', runCommand, reportFormat: 'vitest-json' };\n107\t  }\n108\t\n109\t  if (hasC8) {\n110\t    const runCommand = getNodeTestCommand(pkgScripts, 'c8');\n111\t    return { tool: 'c8', runCommand, reportFormat: 'vitest-json' };\n112\t  }\n113\t\n114\t  if (hasJest) {\n115\t    return {\n116\t      tool: 'c8',\n117\t      runCommand: 'npx jest --coverage --coverageReporters=json-summary',\n118\t      reportFormat: 'jest-json',\n119\t    };\n120\t  }\n121\t\n122\t  if (stateHint === 'c8') {\n123\t    warn('State indicates c8 but no Vitest/c8 found in project — re-detecting');\n124\t  }\n125\t\n126\t  warn('No Node.js coverage tool detected');\n127\t  return { tool: 'unknown', runCommand: '', reportFormat: '' };\n128\t}\n129\t\n130\tfunction getNodeTestCommand(scripts: Record<string, string>, runner: string): string {\n131\t  if (scripts['test:coverage']) {\n132\t    return 'npm run test:coverage';\n133\t  }\n134\t  if (scripts['test:unit']) {\n135\t    if (runner === 'vitest') {\n136\t      return 'npx vitest run --coverage';\n137\t    }\n138\t    return `npm run test:unit`;\n139\t  }\n140\t  if (scripts['test']) {\n141\t    if (runner === 'vitest') {\n142\t      return 'npx vitest run --coverage';\n143\t    }\n144\t    return 'npm test';\n145\t  }\n146\t  if (runner === 'vitest') {\n147\t    return 'npx vitest run --coverage';\n148\t  }\n149\t  return 'npm test';\n150\t}\n151\t\n152\tfunction detectPythonCoverageTool(dir: string): CoverageToolInfo {\n153\t  const reqPath = join(dir, 'requirements.txt');\n154\t  if (existsSync(reqPath)) {\n155\t    try {\n156\t      const content = readFileSync(reqPath, 'utf-8');\n157\t      if (content.includes('pytest-cov') || content.includes('coverage')) {\n158\t        return {\n159\t          tool: 'coverage.py',\n160\t          runCommand: 'coverage run -m pytest && coverage json',\n161\t          reportFormat: 'coverage-py-json',\n162\t        };\n163\t      }\n164\t    } catch {\n165\t      // IGNORE: requirements.txt may be unreadable\n166\t    }\n167\t  }\n168\t\n169\t  const pyprojectPath = join(dir, 'pyproject.toml');\n170\t  if (existsSync(pyprojectPath)) {\n171\t    try {\n172\t      const content = readFileSync(pyprojectPath, 'utf-8');\n173\t      if (content.includes('pytest-cov') || content.includes('coverage')) {\n174\t        return {\n175\t          tool: 'coverage.py',\n176\t          runCommand: 'coverage run -m pytest && coverage json',\n177\t          reportFormat: 'coverage-py-json',\n178\t        };\n179\t      }\n180\t    } catch {\n181\t      // IGNORE: pyproject.toml may be unreadable\n182\t    }\n183\t  }\n184\t\n185\t  warn('No Python coverage tool detected');\n186\t  return { tool: 'unknown', runCommand: '', reportFormat: '' };\n187\t}\n188\t\n189\texport function getTestCommand(dir?: string): string {\n190\t  const toolInfo = detectCoverageTool(dir);\n191\t  return toolInfo.runCommand;\n192\t}\n193\t\n194\texport function runCoverage(dir?: string): CoverageResult {\n195\t  const baseDir = dir ?? process.cwd();\n196\t  const toolInfo = detectCoverageTool(baseDir);\n197\t\n198\t  if (toolInfo.tool === 'unknown' || !toolInfo.runCommand) {\n199\t    return {\n200\t      success: false,\n201\t      testsPassed: false,\n202\t      passCount: 0,\n203\t      failCount: 0,\n204\t      coveragePercent: 0,\n205\t      rawOutput: 'No coverage tool detected. Ensure your project has a test runner configured.',\n206\t    };\n207\t  }\n208\t\n209\t  let rawOutput = '';\n210\t  let testsPassed = true;\n211\t\n212\t  try {\n213\t    rawOutput = execSync(toolInfo.runCommand, {\n214\t      cwd: baseDir,\n215\t      encoding: 'utf-8',\n216\t      stdio: ['pipe', 'pipe', 'pipe'],\n217\t      timeout: 300_000, // 5 minute timeout\n218\t    });\n219\t  } catch (err: unknown) {\n220\t    const execError = err as { status?: number; stdout?: string; stderr?: string };\n221\t    testsPassed = false;\n222\t    rawOutput = (execError.stdout ?? '') + (execError.stderr ?? '');\n223\t\n224\t    if (!rawOutput) {\n225\t      return {\n226\t        success: false,\n227\t        testsPassed: false,\n228\t        passCount: 0,\n229\t        failCount: 0,\n230\t        coveragePercent: 0,\n231\t        rawOutput: 'Test command failed with no output',\n232\t      };\n233\t    }\n234\t  }\n235\t\n236\t  const { passCount, failCount } = parseTestCounts(rawOutput);\n237\t  if (failCount > 0) {\n238\t    testsPassed = false;\n239\t  }\n240\t\n241\t  const coveragePercent = parseCoverageReport(baseDir, toolInfo.reportFormat);\n242\t\n243\t  return {\n244\t    success: true,\n245\t    testsPassed,\n246\t    passCount,\n247\t    failCount,\n248\t    coveragePercent,\n249\t    rawOutput,\n250\t  };\n251\t}\n252\t\n253\texport function checkOnlyCoverage(dir?: string): CoverageResult {\n254\t  const baseDir = dir ?? process.cwd();\n255\t  const toolInfo = detectCoverageTool(baseDir);\n256\t\n257\t  if (toolInfo.tool === 'unknown') {\n258\t    return {\n259\t      success: false,\n260\t      testsPassed: false,\n261\t      passCount: 0,\n262\t      failCount: 0,\n263\t      coveragePercent: 0,\n264\t      rawOutput: 'No coverage tool detected',\n265\t    };\n266\t  }\n267\t\n268\t  const coveragePercent = parseCoverageReport(baseDir, toolInfo.reportFormat);\n269\t  // Preserve existing tests_passed flag — check-only doesn't run tests\n270\t  let testsPassed = true;\n271\t  try {\n272\t    const { state } = readStateWithBody(baseDir);\n273\t    testsPassed = state.session_flags.tests_passed;\n274\t  } catch {\n275\t    // IGNORE: no state file, default to true for first-run check-only\n276\t  }\n277\t\n278\t  return {\n279\t    success: true,\n280\t    testsPassed,\n281\t    passCount: 0,\n282\t    failCount: 0,\n283\t    coveragePercent,\n284\t    rawOutput: 'Check-only mode — read existing coverage report',\n285\t  };\n286\t}\n287\t"}]},"parent_tool_use_id":"toolu_01EThU22wRDbXmvukgem8PY8","session_id":"3330d992-072a-4898-af8b-5f3f7e12cbac","uuid":"3c8be211-40e6-44a3-b1bf-1c73b418c358","timestamp":"2026-04-03T17:52:41.862Z"}
