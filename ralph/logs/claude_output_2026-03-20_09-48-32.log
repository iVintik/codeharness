{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HmSjYozQrPb24JnR8dgPBB","type":"tool_result","content":"     1→#!/usr/bin/env bats\n     2→# Integration tests for observability gate in pre-commit-gate.sh\n     3→# Tests Story 2.2: hook blocks/allows based on observability coverage.\n     4→\n     5→load test_helper\n     6→\n     7→HOOKS_DIR=\"$PROJECT_ROOT/hooks\"\n     8→\n     9→setup() {\n    10→    setup_test_dir\n    11→}\n    12→\n    13→teardown() {\n    14→    teardown_test_dir\n    15→}\n    16→\n    17→# Helper: create state file with all quality gates passing\n    18→create_passing_state() {\n    19→    mkdir -p \"$TEST_DIR/.claude\"\n    20→    cat > \"$TEST_DIR/.claude/codeharness.local.md\" << EOF\n    21→---\n    22→harness_version: \"0.1.0\"\n    23→initialized: true\n    24→stack: nodejs\n    25→session_flags:\n    26→  tests_passed: true\n    27→  coverage_met: true\n    28→  verification_run: true\n    29→---\n    30→EOF\n    31→}\n    32→\n    33→# Helper: create sprint-state.json with observability coverage\n    34→create_obs_state() {\n    35→    local static_pct=\"${1:-85}\"\n    36→    local static_target=\"${2:-80}\"\n    37→    cat > \"$TEST_DIR/sprint-state.json\" << EOF\n    38→{\n    39→  \"version\": 1,\n    40→  \"observability\": {\n    41→    \"static\": {\n    42→      \"coveragePercent\": ${static_pct},\n    43→      \"lastScanTimestamp\": \"2026-03-20T10:00:00.000Z\",\n    44→      \"history\": []\n    45→    },\n    46→    \"targets\": {\n    47→      \"staticTarget\": ${static_target}\n    48→    }\n    49→  }\n    50→}\n    51→EOF\n    52→}\n    53→\n    54→# ============================================================\n    55→# Hook allows commit when observability passes\n    56→# ============================================================\n    57→\n    58→@test \"pre-commit-gate: allows when quality gates pass and no HARNESS_CLI\" {\n    59→    create_passing_state\n    60→    # No HARNESS_CLI available — should fail open\n    61→    run bash -c 'echo \"{\\\"tool_name\\\":\\\"Bash\\\",\\\"tool_input\\\":{\\\"command\\\":\\\"git commit -m test\\\"}}\" | bash '\"$HOOKS_DIR/pre-commit-gate.sh\"\n    62→    [ \"$status\" -eq 0 ]\n    63→    [[ \"$output\" == *'\"decision\": \"allow\"'* ]]\n    64→}\n    65→\n    66→# ============================================================\n    67→# Hook fails open when CLI not available\n    68→# ============================================================\n    69→\n    70→@test \"pre-commit-gate: fails open when HARNESS_CLI is not available\" {\n    71→    create_passing_state\n    72→    # Set HARNESS_CLI to non-existent path\n    73→    export HARNESS_CLI=\"/nonexistent/path/codeharness\"\n    74→    run bash -c 'echo \"{\\\"tool_name\\\":\\\"Bash\\\",\\\"tool_input\\\":{\\\"command\\\":\\\"git commit -m test\\\"}}\" | HARNESS_CLI=/nonexistent/path/codeharness bash '\"$HOOKS_DIR/pre-commit-gate.sh\"\n    75→    [ \"$status\" -eq 0 ]\n    76→    [[ \"$output\" == *'\"decision\": \"allow\"'* ]]\n    77→}\n    78→\n    79→# ============================================================\n    80→# Hook blocks commit when quality gates fail (existing behavior preserved)\n    81→# ============================================================\n    82→\n    83→@test \"pre-commit-gate: still blocks when tests_passed is false\" {\n    84→    mkdir -p \"$TEST_DIR/.claude\"\n    85→    cat > \"$TEST_DIR/.claude/codeharness.local.md\" << EOF\n    86→---\n    87→harness_version: \"0.1.0\"\n    88→initialized: true\n    89→session_flags:\n    90→  tests_passed: false\n    91→  coverage_met: true\n    92→  verification_run: true\n    93→---\n    94→EOF\n    95→    run bash -c 'echo \"{\\\"tool_name\\\":\\\"Bash\\\",\\\"tool_input\\\":{\\\"command\\\":\\\"git commit -m test\\\"}}\" | bash '\"$HOOKS_DIR/pre-commit-gate.sh\"\n    96→    [ \"$status\" -eq 2 ]\n    97→    [[ \"$output\" == *'\"decision\": \"block\"'* ]]\n    98→}\n    99→\n   100→# ============================================================\n   101→# Hook completes within performance budget\n   102→# ============================================================\n   103→\n   104→@test \"pre-commit-gate: completes within 2s (observability section included)\" {\n   105→    create_passing_state\n   106→    create_obs_state 85 80\n   107→    local start_ms=$(($(date +%s) * 1000 + $(date +%N 2>/dev/null | head -c 3 || echo 0)))\n   108→    run bash -c 'echo \"{\\\"tool_name\\\":\\\"Bash\\\",\\\"tool_input\\\":{\\\"command\\\":\\\"git commit -m test\\\"}}\" | bash '\"$HOOKS_DIR/pre-commit-gate.sh\"\n   109→    local end_ms=$(($(date +%s) * 1000 + $(date +%N 2>/dev/null | head -c 3 || echo 0)))\n   110→    local elapsed=$((end_ms - start_ms))\n   111→    [ \"$status\" -eq 0 ]\n   112→    [ \"$elapsed\" -lt 2000 ]\n   113→}\n   114→"}]},"parent_tool_use_id":"toolu_01L7x1Zkv5Yv1DsfgSndzqDQ","session_id":"f7a66acd-0cc1-40de-a592-d59e75273c0b","uuid":"ed35948c-75a6-4aa6-8855-ffe712fec28a","timestamp":"2026-03-20T06:00:24.442Z"}
