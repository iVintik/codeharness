{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YGAJCY4WaKKH2Hdcgc8gAb","type":"tool_result","content":"     1→/**\n     2→ * Discriminated union Result type for consistent error handling.\n     3→ * All module functions return Result<T> instead of throwing exceptions.\n     4→ */\n     5→\n     6→/** Successful result carrying data of type T */\n     7→export interface Ok<T> {\n     8→  readonly success: true;\n     9→  readonly data: T;\n    10→}\n    11→\n    12→/** Failed result carrying an error message and optional context */\n    13→export interface Fail {\n    14→  readonly success: false;\n    15→  readonly error: string;\n    16→  readonly context?: Record<string, unknown>;\n    17→}\n    18→\n    19→/** Discriminated union: success field is the discriminant */\n    20→export type Result<T> = Ok<T> | Fail;\n    21→\n    22→/** Construct a successful Result */\n    23→export function ok<T>(data: T): Result<T> {\n    24→  return { success: true, data };\n    25→}\n    26→\n    27→/** Construct a failed Result, assignable to any Result<T> */\n    28→export function fail(error: string, context?: Record<string, unknown>): Result<never> {\n    29→  if (context !== undefined) {\n    30→    return { success: false, error, context };\n    31→  }\n    32→  return { success: false, error };\n    33→}\n    34→\n    35→/** Type guard: narrows Result<T> to Ok<T> */\n    36→export function isOk<T>(result: Result<T>): result is Ok<T> {\n    37→  return result.success === true;\n    38→}\n    39→\n    40→/** Type guard: narrows Result<T> to Fail */\n    41→export function isFail<T>(result: Result<T>): result is Fail {\n    42→  return result.success === false;\n    43→}\n    44→"}]},"parent_tool_use_id":"toolu_015U2Dv9GBzjkQ93L4EzWA3k","session_id":"ef2f2ce5-c013-4ad4-b6dd-a80c40f8ca85","uuid":"d53c625d-5b54-45ad-9c7c-d6894472502d","timestamp":"2026-03-21T05:17:45.886Z"}
