ption, suggestedFix };\n    49→  if (line !== undefined) return { ...g, line };\n    50→  return g;\n    51→}\n    52→\n    53→/**\n    54→ * Load rules from patches/infra/dockerfile-rules.md or fall back to defaults.\n    55→ * The markdown is documentation — the actual rules are hardcoded defaults.\n    56→ * Returns rules + any warnings about missing file.\n    57→ */\n    58→export function loadRules(projectDir: string): { rules: DockerfileRules; warnings: string[] } {\n    59→  const rulesPath = join(projectDir, 'patches', 'infra', 'dockerfile-rules.md');\n    60→  if (!existsSync(rulesPath)) {\n    61→    return {\n    62→      rules: DEFAULT_RULES,\n    63→      warnings: ['dockerfile-rules.md not found -- using defaults.'],\n    64→    };\n    65→  }\n    66→  return { rules: DEFAULT_RULES, warnings: [] };\n    67→}\n    68→\n    69→// ─── Rule checkers ──────────────────────────────────────────────────────────\n    70→\n    71→function checkPinnedFrom(lines: string[]): DockerfileGap[] {\n    72→  const gaps: DockerfileGap[] = [];\n    73→  for (let i = 0; i < lines.length; i++) {\n    74→    if (!/^\\s*FROM\\s+/i.test(lines[i])) continue;\n    75→    const ref = lines[i].replace(/^\\s*FROM\\s+/i, '').split(/\\s+/)[0];\n    76→    if (ref.endsWith(':latest')) {\n    77→      gaps.push(dfGap('pinned-from', `unpinned base image -- use specific version.`, `Pin ${ref} to a specific version tag`, i + 1));\n    78→    } else if (!ref.includes(':') && !ref.includes('@')) {\n    79→      gaps.push(dfGap('pinned-from', `unpinned base image -- use specific version.`, `Pin ${ref} to a specific version tag (e.g., ${ref}:22-slim)`, i + 1));\n    80→    }\n    81→  }\n    82→  return gaps;\n    83→}\n    84→\n    85→function checkBinaryOnPath(lines: string[]): DockerfileGap[] {\n    86→  const content = lines.join('\\n');\n    87→  const hasBinary =\n    88→    /npm\\s+install\\s+(-g|--global)\\b/i.test(content) ||\n    89→    /pip\\s+install\\b/i.test(content) ||\n    90→    /COPY\\s+--from=/i.test(content);\n    91→  if (!hasBinary) {\n    92→    return [dfGap('binary-on-path', 'project binary not installed.', 'Add npm install -g, pip install, or COPY --from to install the project binary')];\n    93→  }\n    94→  return [];\n    95→}\n    96→\n    97→function checkVerificationTools(lines: string[], tools: string[]): DockerfileGap[] {\n    98→  const gaps: DockerfileGap[] = [];\n    99→  for (const tool of tools) {\n   100→    let found = false;\n   101→    for (const line of lines) {\n   102→      const lower = line.toLowerCase();\n   103→      const isInstallLine = lower.includes('apt-get install') || lower.includes('apk add');\n   104→      if (isInstallLine && new RegExp(`\\\\b${tool.toLowerCase()}\\\\b`).test(lower)) {\n   105→        found = true;\n   106→        break;\n   107→      }\n   108→    }\n   109→    if (!found) {\n   110→      gaps.push(dfGap('verification-tools', `verification tool missing: ${tool}`, `Install ${tool} via apt-get install or apk add`));\n   111→    }\n   112→  }\n   113→  return gaps;\n   114→}\n   115→\n   116→function checkNoSourceCopy(lines: string[]): DockerfileGap[] {\n   117→  const gaps: DockerfileGap[] = [];\n   118→  const sourcePatterns = [/COPY\\s+(?:--\\S+\\s+)*src\\//i, /COPY\\s+(?:--\\S+\\s+)*lib\\//i, /COPY\\s+(?:--\\S+\\s+)*test\\//i];\n   119→  for (let i = 0; i < lines.length; i++) {\n   120→    for (const pattern of sourcePatterns) {\n   121→      if (pattern.test(lines[i])) {\n   122→        gaps.push(dfGap('no-source-copy', 'source code copied into container -- use build artifact instead.', 'Use COPY --from=builder or COPY dist/ instead of copying source', i + 1));\n   123→      }\n   124→    }\n   125→  }\n   126→  return gaps;\n   127→}\n   128→\n   129→function checkNonRootUser(lines: string[]): DockerfileGap[] {\n   130→  const userLines = lines.filter(l => /^\\s*USER\\s+/i.test(l));\n   131→  if (userLines.length === 0) {\n   132→    return [dfGap('non-root-user', 'no non-root USER instruction found.', 'Add USER <non-root-user> instruction (e.g., USER node)')];\n   133→  }\n   134→  const hasNonRoot = userLines.some(l => {\n   135→    const user = l.replace(/^\\s*USER\\s+/i, '').trim().split(/\\s+/)[0];\n   136→    return user.toLowerCase() !== 'root';\n   137→  });\n   138→  if (!hasNonRoot) {\n   139→    return [dfGap('non-root-user', 'no non-root USER instruction found.', 'Add USER <non-root-user> instruction (e.g., USER node)')];\n   140→  }\n   141→  return [];\n   142→}\n   143→\n   144→function checkCacheCleanup(lines: string[]): DockerfileGap[] {\n   145→  const content = lines.join('\\n');\n   146→  const hasCleanup =\n   147→    /rm\\s+-rf\\s+\\/var\\/lib\\/apt\\/lists/i.test(content) ||\n   148→    /rm\\s+-rf\\s+\\/var\\/cache\\/apk/i.test(content) ||\n   149→    /npm\\s+cache\\s+clean/i.test(content) ||\n   150→    /pip\\s+cache\\s+purge/i.test(content);\n   151→  if (!hasCleanup) {\n   152→    return [dfGap('cache-cleanup', 'no cache cleanup detected.', 'Add cache cleanup: rm -rf /var/lib/apt/lists/*, npm cache clean --force, or pip cache purge')];\n   153→  }\n   154→  return [];\n   155→}\n   156→\n   157→// ─── Main validator ─────────────────────────────────────────────────────────\n   158→\n   159→/**\n   160→ * Validate a Dockerfile against all 6 rule categories.\n   161→ * Returns Result<DockerfileValidationResult>.\n   162→ */\n   163→export function validateDockerfile(projectDir: string): Result<DockerfileValidationResult> {\n   164→  const dfPath = join(projectDir, 'Dockerfile');\n   165→\n   166→  if (!existsSync(dfPath)) {\n   167→    return fail('No Dockerfile found');\n   168→  }\n   169→\n   170→  let content: string;\n   171→  try {\n   172→    content = readFileSync(dfPath, 'utf-8');\n   173→  } catch {\n   174→    return fail('Dockerfile exists but could not be read');\n   175→  }\n   176→\n   177→  const lines = content.split('\\n');\n   178→  const fromLines = lines.filter(l => /^\\s*FROM\\s+/i.test(l));\n   179→  if (fromLines.length === 0) {\n   180→    return fail('Dockerfile has no FROM instruction');\n   181→  }\n   182→\n   183→  const { rules, warnings } = loadRules(projectDir);\n   184→  const gaps: DockerfileGap[] = [];\n   185→\n   186→  if (rules.requirePinnedFrom) gaps.push(...checkPinnedFrom(lines));\n   187→  if (rules.requireBinaryOnPath) gaps.push(...checkBinaryOnPath(lines));\n   188→  gaps.push(...checkVerificationTools(lines, rules.verificationTools));\n   189→  if (rules.forbidSourceCopy) gaps.push(...checkNoSourceCopy(lines));\n   190→  if (rules.requireNonRootUser) gaps.push(...checkNonRootUser(lines));\n   191→  if (rules.requireCacheCleanup) gaps.push(...checkCacheCleanup(lines));\n   192→\n   193→  return ok({\n   194→    passed: gaps.length === 0,\n   195→    gaps,\n   196→    warnings,\n   197→  });\n   198→}\n   199→"}]},"parent_tool_use_id":null,"session_id":"77451c69-f489-4aef-ba6d-37b512cc36ec","uuid":"3d75d617-82fc-4de4-b9a0-b45bfd0d121f","timestamp":"2026-03-21T05:36:05.164Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ivintik/dev/personal/codeharness/src/modules/infra/dockerfile-validator.ts","content":"/**\n * Dockerfile validator — checks Dockerfiles against 6 required rule categories.\n * Returns structured gaps for audit integration.\n *\n * FR23 (formalized Dockerfile rules), FR24 (audit validates against rules).\n */\n\nimport { existsSync, readFileSync } from 'node:fs';\nimport { join } from 'node:path';\nimport { ok, fail } from '../../types/result.js';\nimport type { Result } from '../../types/result.js';\n\n/** A single gap found during Dockerfile validation */\nexport interface DockerfileGap {\n  readonly rule: string;\n  readonly description: string;\n  readonly suggestedFix: string;\n  readonly line?: number;\n}\n\n/** Result of validating a Dockerfile against all rules */\nexport interface DockerfileValidationResult {\n  readonly passed: boolean;\n  readonly gaps: DockerfileGap[];\n  readonly warnings: string[];\n}\n\n/** Internal rules structure */\ninterface DockerfileRules {\n  readonly requirePinnedFrom: boolean;\n  readonly requireBinaryOnPath: boolean;\n  readonly verificationTools: string[];\n  readonly forbidSourceCopy: boolean;\n  readonly requireNonRootUser: boolean;\n  readonly requireCacheCleanup: boolean;\n}\n\nconst DEFAULT_RULES: DockerfileRules = {\n  requirePinnedFrom: true,\n  requireBinaryOnPath: true,\n  verificationTools: ['curl', 'jq'],\n  forbidSourceCopy: true,\n  requireNonRootUser: true,\n  requireCacheCleanup: true,\n};\n\nfunction dfGap(rule: string, description: string, suggestedFix: string, line?: number): DockerfileGap {\n  const g: DockerfileGap = { rule, description, suggestedFix };\n  if (line !== undefined) return { ...g, line };\n  return g;\n}\n\n/**\n * Load rules from patches/infra/dockerfile-rules.md or fall back to defaults.\n * The markdown is documentation — the actual rules are hardcoded defaults.\n * Returns rules + any warnings about missing file.\n */\nexport function loadRules(projectDir: string): { rules: DockerfileRules; warnings: string[] } {\n  const rulesPath = join(projectDir, 'patches', 'infra', 'dockerfile-rules.md');\n  if (!existsSync(rulesPath)) {\n    return {\n      rules: DEFAULT_RULES,\n      warnings: ['dockerfile-rules.md not found -- using defaults.'],\n    };\n  }\n  return { rules: DEFAULT_RULES, warnings: [] };\n}\n\n// ─── Rule checkers ──────────────────────────────────────────────────────────\n\nfunction checkPinnedFrom(lines: string[]): DockerfileGap[] {\n  const gaps: DockerfileGap[] = [];\n  for (let i = 0; i < lines.length; i++) {\n    if (!/^\\s*FROM\\s+/i.test(lines[i])) continue;\n    const ref = lines[i].replace(/^\\s*FROM\\s+/i, '').split(/\\s+/)[0];\n    if (ref.endsWith(':latest')) {\n      gaps.push(dfGap('pinned-from', `unpinned base image -- use specific version.`, `Pin ${ref} to a specific version tag`, i + 1));\n    } else if (!ref.includes(':') && !ref.includes('@')) {\n      gaps.push(dfGap('pinned-from', `unpinned base image -- use specific version.`, `Pin ${ref} to a specific version tag (e.g., ${ref}:22-slim)`, i + 1));\n    }\n  }\n  return gaps;\n}\n\nfunction checkBinaryOnPath(lines: string[]): DockerfileGap[] {\n  const content = lines.join('\\n');\n  const hasBinary =\n    /npm\\s+install\\s+(-g|--global)\\b/i.test(content) ||\n    /pip\\s+install\\b/i.test(content) ||\n    /COPY\\s+--from=/i.test(content);\n  if (!hasBinary) {\n    return [dfGap('binary-on-path', 'project binary not installed.', 'Add npm install -g, pip install, or COPY --from to install the project binary')];\n  }\n  return [];\n}\n\nfunction checkVerificationTools(lines: string[], tools: string[]): DockerfileGap[] {\n  const gaps: DockerfileGap[] = [];\n  for (const tool of tools) {\n    let found = false;\n    for (const line of lines) {\n      const lower = line.toLowerCase();\n      const isInstallLine = lower.includes('apt-get install') || lower.includes('apk add');\n      if (isInstallLine && new RegExp(`\\\\b${tool.toLowerCase()}\\\\b`).test(lower)) {\n        found = true;\n        break;\n      }\n    }\n    if (!found) {\n      gaps.push(dfGap('verification-tools', `verification tool missing: ${tool}`, `Install ${tool} via apt-get install or apk add`));\n    }\n  }\n  return gaps;\n}\n\nfunction checkNoSourceCopy(lines: string[]): DockerfileGap[] {\n  const gaps: DockerfileGap[] = [];\n  const sourcePatterns = [/COPY\\s+(?:--\\S+\\s+)*src\\//i, /COPY\\s+(?:--\\S+\\s+)*lib\\//i, /COPY\\s+(?:--\\S+\\s+)*test\\//i];\n  for (let i = 0; i < lines.length; i++) {\n    for (const pattern of sourcePatterns) {\n      if (pattern.test(lines[i])) {\n        gaps.push(dfGap('no-source-copy', 'source code copied into container -- use build artifact instead.', 'Use COPY --from=builder or COPY dist/ instead of copying source', i + 1));\n      }\n    }\n  }\n  return gaps;\n}\n\nfunction checkNonRootUser(lines: string[]): DockerfileGap[] {\n  const userLines = lines.filter(l => /^\\s*USER\\s+/i.test(l));\n  if (userLines.length === 0) {\n    return [dfGap('non-root-user', 'no non-root USER instruction found.', 'Add USER <non-root-user> instruction (e.g., USER node)')];\n  }\n  const hasNonRoot = userLines.some(l => {\n    const user = l.replace(/^\\s*USER\\s+/i, '').trim().split(/\\s+/)[0];\n    return user.toLowerCase() !== 'root';\n  });\n  if (!hasNonRoot) {\n    return [dfGap('non-root-user', 'no non-root USER instruction found.', 'Add USER <non-root-user> instruction (e.g., USER node)')];\n  }\n  return [];\n}\n\nfunction checkCacheCleanup(lines: string[]): DockerfileGap[] {\n  const content = lines.join('\\n');\n  const hasCleanup =\n    /rm\\s+-rf\\s+\\/var\\/lib\\/apt\\/lists/i.test(content) ||\n    /rm\\s+-rf\\s+\\/var\\/cache\\/apk/i.test(content) ||\n    /npm\\s+cache\\s+clean/i.test(content) ||\n    /pip\\s+cache\\s+purge/i.test(content);\n  if (!hasCleanup) {\n    return [dfGap('cache-cleanup', 'no cache cleanup detected.', 'Add cache cleanup: rm -rf /var/lib/apt/lists/*, npm cache clean --force, or pip cache purge')];\n  }\n  return [];\n}\n\n// ─── Main validator ─────────────────────────────────────────────────────────\n\n/**\n * Validate a Dockerfile against all 6 rule categories.\n * Returns Result<DockerfileValidationResult>.\n */\nexport function validateDockerfile(projectDir: string): Result<DockerfileValidationResult> {\n  const dfPath = join(projectDir, 'Dockerfile');\n\n  if (!existsSync(dfPath)) {\n    return fail('No Dockerfile found');\n  }\n\n  let content: string;\n  try {\n    content = readFileSync(dfPath, 'utf-8');\n  } catch {\n    return fail('Dockerfile exists but could not be read');\n  }\n\n  const lines = content.split('\\n');\n  const fromLines = lines.filter(l => /^\\s*FROM\\s+/i.test(l));\n  if (fromLines.length === 0) {\n    return fail('Dockerfile has no FROM instruction');\n  }\n\n  const { rules, warnings } = loadRules(projectDir);\n  const gaps: DockerfileGap[] = [];\n\n  if (rules.requirePinnedFrom) gaps.push(...checkPinnedFrom(lines));\n  if (rules.requireBinaryOnPath) gaps.push(...checkBinaryOnPath(lines));\n  gaps.push(...checkVerificationTools(lines, rules.verificationTools));\n  if (rules.forbidSourceCopy) gaps.push(...checkNoSourceCopy(lines));\n  if (rules.requireNonRootUser) gaps.push(...checkNonRootUser(lines));\n  if (rules.requireCacheCleanup) gaps.push(...checkCacheCleanup(lines));\n\n  return ok({\n    passed: gaps.length === 0,\n    gaps,\n    warnings,\n  });\n}\n","numLines":199,"startLine":1,"totalLines":199}}}
