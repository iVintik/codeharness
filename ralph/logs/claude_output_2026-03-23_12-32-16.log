ttern-not: |\n    62→          let $FUNC = (...) => {\n    63→            ...\n    64→            console.log(...)\n    65→            ...\n    66→          }\n    67→      - pattern-not: |\n    68→          let $FUNC = (...) => {\n    69→            ...\n    70→            console.debug(...)\n    71→            ...\n    72→          }\n    73→      - pattern-not: |\n    74→          let $FUNC = (...) => {\n    75→            ...\n    76→            logger.debug(...)\n    77→            ...\n    78→          }\n    79→      - pattern-not: |\n    80→          let $FUNC = (...) => {\n    81→            ...\n    82→            logger.info(...)\n    83→            ...\n    84→          }\n    85→      - pattern-not: |\n    86→          $FUNC(...) {\n    87→            ...\n    88→            console.log(...)\n    89→            ...\n    90→          }\n    91→      - pattern-not: |\n    92→          $FUNC(...) {\n    93→            ...\n    94→            console.debug(...)\n    95→            ...\n    96→          }\n    97→      - pattern-not: |\n    98→          $FUNC(...) {\n    99→            ...\n   100→            logger.debug(...)\n   101→            ...\n   102→          }\n   103→      - pattern-not: |\n   104→          $FUNC(...) {\n   105→            ...\n   106→            logger.info(...)\n   107→            ...\n   108→          }\n   109→    message: \"Function without debug/info logging — observability gap\"\n   110→    languages: [typescript, javascript]\n   111→    severity: INFO\n   112→    metadata:\n   113→      category: observability\n   114→      cwe: \"CWE-778: Insufficient Logging\"\n   115→"}]},"parent_tool_use_id":"toolu_01Y5Vmp4wHswe3FNr3ap85bX","session_id":"9d3ab825-6dfa-42d3-92d1-28b7bc09852d","uuid":"7c8bf6ae-27ad-4d3a-87a4-59a27af40e1c","timestamp":"2026-03-23T08:36:15.523Z"}
