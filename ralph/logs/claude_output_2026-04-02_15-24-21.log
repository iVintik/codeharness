{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01URY1GbR4mQtS7ECaH7cPZK","type":"tool_result","content":"1\timport Ajv from 'ajv';\n2\timport workflowSchema from '../schemas/workflow.schema.json';\n3\t\n4\t// --- Interfaces ---\n5\t\n6\texport interface ValidationError {\n7\t  path: string;\n8\t  message: string;\n9\t  keyword: string;\n10\t}\n11\t\n12\texport interface ValidationResult {\n13\t  valid: boolean;\n14\t  errors: ValidationError[];\n15\t}\n16\t\n17\t// --- Validation ---\n18\t\n19\tconst ajv = new Ajv({ allErrors: true });\n20\tconst validateWorkflow = ajv.compile(workflowSchema);\n21\t\n22\t/**\n23\t * Validate data against a JSON schema.\n24\t * Schema-agnostic: pass any compiled Ajv ValidateFunction.\n25\t */\n26\texport function validateAgainstSchema(\n27\t  data: unknown,\n28\t  validate: ReturnType<typeof ajv.compile>,\n29\t): ValidationResult {\n30\t  const valid = validate(data);\n31\t\n32\t  if (valid) {\n33\t    return { valid: true, errors: [] };\n34\t  }\n35\t\n36\t  const errors: ValidationError[] = (validate.errors ?? []).map((err) => ({\n37\t    path: err.instancePath || '/',\n38\t    message: err.message ?? 'Unknown validation error',\n39\t    keyword: err.keyword,\n40\t  }));\n41\t\n42\t  return { valid: false, errors };\n43\t}\n44\t\n45\t/**\n46\t * Validate data against the workflow YAML schema.\n47\t * Primary entry point for workflow validation.\n48\t */\n49\texport function validateWorkflowSchema(data: unknown): ValidationResult {\n50\t  return validateAgainstSchema(data, validateWorkflow);\n51\t}\n52\t"}]},"parent_tool_use_id":"toolu_01HyS3onm3YhU66FXQgZALNu","session_id":"06dc1e0b-83a0-4950-9e66-ec9396bae461","uuid":"a7e48b39-676f-448f-9013-cc03a60c1c51","timestamp":"2026-04-02T11:32:40.915Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NEWvBYXjXiwkquzbGWSkRs","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach, afterEach } from 'vitest';\n2\timport { mkdtempSync, rmSync, writeFileSync, mkdirSync } from 'node:fs';\n3\timport { tmpdir } from 'node:os';\n4\timport { join } from 'node:path';\n5\timport {\n6\t  parseWorkflow,\n7\t  WorkflowParseError,\n8\t  type ResolvedWorkflow,\n9\t  type ResolvedTask,\n10\t  type LoopBlock,\n11\t  type FlowStep,\n12\t} from '../workflow-parser.js';\n13\t\n14\tlet testDir: string;\n15\t\n16\tbeforeEach(() => {\n17\t  testDir = mkdtempSync(join(tmpdir(), 'ch-wfparser-test-'));\n18\t});\n19\t\n20\tafterEach(() => {\n21\t  rmSync(testDir, { recursive: true, force: true });\n22\t});\n23\t\n24\tfunction writeYaml(filename: string, content: string): string {\n25\t  const filePath = join(testDir, filename);\n26\t  writeFileSync(filePath, content, 'utf-8');\n27\t  return filePath;\n28\t}\n29\t\n30\t// --- Helpers: YAML content ---\n31\t\n32\tconst minimalYaml = `\n33\ttasks:\n34\t  implement:\n35\t    agent: dev\n36\tflow:\n37\t  - implement\n38\t`;\n39\t\n40\tconst fullYaml = `\n41\ttasks:\n42\t  implement:\n43\t    agent: dev\n44\t    scope: per-story\n45\t    session: fresh\n46\t    source_access: true\n47\t    prompt_template: \"Implement story {{story_key}}\"\n48\t    input_contract:\n49\t      type: object\n50\t    output_contract:\n51\t      type: object\n52\t    max_budget_usd: 5.0\n53\t  verify:\n54\t    agent: evaluator\n55\t    scope: per-run\n56\t    session: continue\n57\t    source_access: false\n58\tflow:\n59\t  - implement\n60\t  - verify\n61\t`;\n62\t\n63\tconst loopYaml = `\n64\ttasks:\n65\t  implement:\n66\t    agent: dev\n67\t  verify:\n68\t    agent: evaluator\n69\t  retry:\n70\t    agent: dev\n71\tflow:\n72\t  - implement\n73\t  - verify\n74\t  - loop:\n75\t      - retry\n76\t      - verify\n77\t`;\n78\t\n79\tconst emptyYaml = `\n80\ttasks: {}\n81\tflow: []\n82\t`;\n83\t\n84\t// --- Tests ---\n85\t\n86\tdescribe('parseWorkflow', () => {\n87\t  describe('valid workflows (AC #1)', () => {\n88\t    it('parses a minimal valid workflow and returns ResolvedWorkflow', () => {\n89\t      const filePath = writeYaml('minimal.yaml', minimalYaml);\n90\t      const result = parseWorkflow(filePath);\n91\t\n92\t      expect(result.tasks).toBeDefined();\n93\t      expect(result.flow).toBeDefined();\n94\t      expect(result.tasks.implement).toBeDefined();\n95\t      expect(result.tasks.implement.agent).toBe('dev');\n96\t      expect(result.flow).toEqual(['implement']);\n97\t    });\n98\t\n99\t    it('parses a full workflow with all optional fields (AC #1)', () => {\n100\t      const filePath = writeYaml('full.yaml', fullYaml);\n101\t      const result = parseWorkflow(filePath);\n102\t\n103\t      expect(result.tasks.implement.agent).toBe('dev');\n104\t      expect(result.tasks.implement.scope).toBe('per-story');\n105\t      expect(result.tasks.implement.session).toBe('fresh');\n106\t      expect(result.tasks.implement.source_access).toBe(true);\n107\t      expect(result.tasks.implement.prompt_template).toBe('Implement story {{story_key}}');\n108\t      expect(result.tasks.implement.input_contract).toEqual({ type: 'object' });\n109\t      expect(result.tasks.implement.output_contract).toEqual({ type: 'object' });\n110\t      expect(result.tasks.implement.max_budget_usd).toBe(5.0);\n111\t\n112\t      expect(result.tasks.verify.agent).toBe('evaluator');\n113\t      expect(result.tasks.verify.scope).toBe('per-run');\n114\t      expect(result.tasks.verify.session).toBe('continue');\n115\t      expect(result.tasks.verify.source_access).toBe(false);\n116\t    });\n117\t\n118\t    it('applies defaults when optional fields are omitted (AC #1)', () => {\n119\t      const filePath = writeYaml('defaults.yaml', minimalYaml);\n120\t      const result = parseWorkflow(filePath);\n121\t      const task = result.tasks.implement;\n122\t\n123\t      expect(task.scope).toBe('per-story');\n124\t      expect(task.session).toBe('fresh');\n125\t      expect(task.source_access).toBe(true);\n126\t      expect(task.prompt_template).toBeUndefined();\n127\t      expect(task.input_contract).toBeUndefined();\n128\t      expect(task.output_contract).toBeUndefined();\n129\t      expect(task.max_budget_usd).toBeUndefined();\n130\t    });\n131\t\n132\t    it('parses empty tasks and flow as valid degenerate case', () => {\n133\t      const filePath = writeYaml('empty.yaml', emptyYaml);\n134\t      const result = parseWorkflow(filePath);\n135\t\n136\t      expect(result.tasks).toEqual({});\n137\t      expect(result.flow).toEqual([]);\n138\t    });\n139\t  });\n140\t\n141\t  describe('invalid YAML syntax (AC #2)', () => {\n142\t    it('throws WorkflowParseError for bad YAML', () => {\n143\t      const filePath = writeYaml('bad.yaml', '{{{{not yaml at all');\n144\t\n145\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n146\t      try {\n147\t        parseWorkflow(filePath);\n148\t      } catch (err) {\n149\t        expect(err).toBeInstanceOf(WorkflowParseError);\n150\t        const pe = err as WorkflowParseError;\n151\t        expect(pe.message).toContain('Invalid YAML syntax');\n152\t        expect(pe.errors.length).toBeGreaterThan(0);\n153\t      }\n154\t    });\n155\t\n156\t    it('throws WorkflowParseError for unclosed quotes in YAML', () => {\n157\t      const badYaml = `\n158\ttasks:\n159\t  implement:\n160\t    agent: \"dev\n161\tflow:\n162\t  - implement\n163\t`;\n164\t      const filePath = writeYaml('unclosed.yaml', badYaml);\n165\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n166\t    });\n167\t  });\n168\t\n169\t  describe('schema validation failures (AC #3)', () => {\n170\t    it('throws WorkflowParseError when tasks is missing', () => {\n171\t      const yaml = 'flow:\\n  - implement\\n';\n172\t      const filePath = writeYaml('no-tasks.yaml', yaml);\n173\t\n174\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n175\t      try {\n176\t        parseWorkflow(filePath);\n177\t      } catch (err) {\n178\t        const pe = err as WorkflowParseError;\n179\t        expect(pe.message).toContain('Schema validation failed');\n180\t        expect(pe.errors.length).toBeGreaterThan(0);\n181\t        expect(pe.errors.some((e) => e.message.includes('tasks'))).toBe(true);\n182\t      }\n183\t    });\n184\t\n185\t    it('throws WorkflowParseError for invalid scope enum value', () => {\n186\t      const yaml = `\n187\ttasks:\n188\t  implement:\n189\t    agent: dev\n190\t    scope: invalid-scope\n191\tflow:\n192\t  - implement\n193\t`;\n194\t      const filePath = writeYaml('bad-scope.yaml', yaml);\n195\t\n196\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n197\t      try {\n198\t        parseWorkflow(filePath);\n199\t      } catch (err) {\n200\t        const pe = err as WorkflowParseError;\n201\t        expect(pe.message).toContain('Schema validation failed');\n202\t        expect(pe.errors.some((e) => e.path.includes('scope'))).toBe(true);\n203\t      }\n204\t    });\n205\t  });\n206\t\n207\t  describe('dangling task references (AC #4)', () => {\n208\t    it('throws WorkflowParseError when flow references non-existent task', () => {\n209\t      const yaml = `\n210\ttasks:\n211\t  implement:\n212\t    agent: dev\n213\tflow:\n214\t  - implement\n215\t  - nonexistent\n216\t`;\n217\t      const filePath = writeYaml('dangling.yaml', yaml);\n218\t\n219\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n220\t      try {\n221\t        parseWorkflow(filePath);\n222\t      } catch (err) {\n223\t        const pe = err as WorkflowParseError;\n224\t        expect(pe.message).toContain('Dangling task references');\n225\t        expect(pe.errors.some((e) => e.message.includes('nonexistent'))).toBe(true);\n226\t      }\n227\t    });\n228\t\n229\t    it('throws WorkflowParseError when loop references non-existent task', () => {\n230\t      const yaml = `\n231\ttasks:\n232\t  implement:\n233\t    agent: dev\n234\tflow:\n235\t  - implement\n236\t  - loop:\n237\t      - ghost_task\n238\t`;\n239\t      const filePath = writeYaml('dangling-loop.yaml', yaml);\n240\t\n241\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n242\t      try {\n243\t        parseWorkflow(filePath);\n244\t      } catch (err) {\n245\t        const pe = err as WorkflowParseError;\n246\t        expect(pe.message).toContain('Dangling task references');\n247\t        expect(pe.errors.some((e) => e.message.includes('ghost_task'))).toBe(true);\n248\t        expect(pe.errors.some((e) => e.path.includes('loop'))).toBe(true);\n249\t      }\n250\t    });\n251\t  });\n252\t\n253\t  describe('loop blocks (AC #5)', () => {\n254\t    it('resolves loop block with valid task references', () => {\n255\t      const filePath = writeYaml('loop.yaml', loopYaml);\n256\t      const result = parseWorkflow(filePath);\n257\t\n258\t      expect(result.flow).toHaveLength(3);\n259\t      expect(result.flow[0]).toBe('implement');\n260\t      expect(result.flow[1]).toBe('verify');\n261\t\n262\t      const loopStep = result.flow[2] as LoopBlock;\n263\t      expect(loopStep).toHaveProperty('loop');\n264\t      expect(loopStep.loop).toEqual(['retry', 'verify']);\n265\t    });\n266\t  });\n267\t\n268\t  describe('performance (AC #6)', () => {\n269\t    it('parses a typical workflow in under 500ms', () => {\n270\t      const filePath = writeYaml('perf.yaml', fullYaml);\n271\t\n272\t      const start = performance.now();\n273\t      parseWorkflow(filePath);\n274\t      const elapsed = performance.now() - start;\n275\t\n276\t      expect(elapsed).toBeLessThan(500);\n277\t    });\n278\t  });\n279\t\n280\t  describe('file not found (AC #7)', () => {\n281\t    it('throws WorkflowParseError for non-existent file', () => {\n282\t      const fakePath = join(testDir, 'does-not-exist.yaml');\n283\t\n284\t      expect(() => parseWorkflow(fakePath)).toThrow(WorkflowParseError);\n285\t      try {\n286\t        parseWorkflow(fakePath);\n287\t      } catch (err) {\n288\t        const pe = err as WorkflowParseError;\n289\t        expect(pe.message).toContain('File not found');\n290\t        expect(pe.errors.length).toBeGreaterThan(0);\n291\t      }\n292\t    });\n293\t  });\n294\t\n295\t  describe('typed interfaces (AC #8)', () => {\n296\t    it('ResolvedWorkflow has correct structure', () => {\n297\t      const filePath = writeYaml('typed.yaml', fullYaml);\n298\t      const result: ResolvedWorkflow = parseWorkflow(filePath);\n299\t\n300\t      // tasks is Record<string, ResolvedTask>\n301\t      const taskKeys = Object.keys(result.tasks);\n302\t      expect(taskKeys).toContain('implement');\n303\t      expect(taskKeys).toContain('verify');\n304\t\n305\t      // flow is FlowStep[]\n306\t      expect(Array.isArray(result.flow)).toBe(true);\n307\t\n308\t      // Each task has ResolvedTask properties\n309\t      const task: ResolvedTask = result.tasks.implement;\n310\t      expect(typeof task.agent).toBe('string');\n311\t      expect(typeof task.scope).toBe('string');\n312\t      expect(typeof task.session).toBe('string');\n313\t      expect(typeof task.source_access).toBe('boolean');\n314\t    });\n315\t\n316\t    it('FlowStep is a union of string | LoopBlock', () => {\n317\t      const filePath = writeYaml('flow-types.yaml', loopYaml);\n318\t      const result = parseWorkflow(filePath);\n319\t\n320\t      // String flow step\n321\t      const stringStep: FlowStep = result.flow[0];\n322\t      expect(typeof stringStep).toBe('string');\n323\t\n324\t      // LoopBlock flow step\n325\t      const loopStep: FlowStep = result.flow[2];\n326\t      expect(typeof loopStep).toBe('object');\n327\t      expect((loopStep as LoopBlock).loop).toBeDefined();\n328\t    });\n329\t  });\n330\t\n331\t  describe('WorkflowParseError structure (AC #8)', () => {\n332\t    it('extends Error and has name and errors array', () => {\n333\t      const err = new WorkflowParseError('test error', [\n334\t        { path: '/tasks', message: 'missing' },\n335\t      ]);\n336\t\n337\t      expect(err).toBeInstanceOf(Error);\n338\t      expect(err.name).toBe('WorkflowParseError');\n339\t      expect(err.message).toBe('test error');\n340\t      expect(err.errors).toHaveLength(1);\n341\t      expect(err.errors[0]).toEqual({ path: '/tasks', message: 'missing' });\n342\t    });\n343\t\n344\t    it('defaults errors to empty array when not provided', () => {\n345\t      const err = new WorkflowParseError('test error');\n346\t      expect(err.errors).toEqual([]);\n347\t    });\n348\t  });\n349\t});\n350\t"}]},"parent_tool_use_id":"toolu_01HyS3onm3YhU66FXQgZALNu","session_id":"06dc1e0b-83a0-4950-9e66-ec9396bae461","uuid":"95af2597-e3a0-4b39-a9ac-8787cfcc33bd","timestamp":"2026-04-02T11:32:41.086Z"}
