{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GdEHpMyoetKzC1FGnaU1Y7","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n     2→import { mkdtempSync, rmSync, readFileSync, writeFileSync, mkdirSync } from 'node:fs';\n     3→import { tmpdir } from 'node:os';\n     4→import { join } from 'node:path';\n     5→import {\n     6→  readRetries,\n     7→  writeRetries,\n     8→  getRetryCount,\n     9→  setRetryCount,\n    10→  resetRetry,\n    11→  readFlaggedStories,\n    12→  writeFlaggedStories,\n    13→  removeFlaggedStory,\n    14→  retriesPath,\n    15→  flaggedPath,\n    16→} from '../retry-state.js';\n    17→\n    18→let testDir: string;\n    19→\n    20→beforeEach(() => {\n    21→  testDir = mkdtempSync(join(tmpdir(), 'ch-retry-test-'));\n    22→});\n    23→\n    24→afterEach(() => {\n    25→  rmSync(testDir, { recursive: true, force: true });\n    26→  vi.restoreAllMocks();\n    27→});\n    28→\n    29→// ─── readRetries ──────────────────────────────────────────────────────────────\n    30→\n    31→describe('readRetries', () => {\n    32→  it('returns empty map when file does not exist', () => {\n    33→    const result = readRetries(testDir);\n    34→    expect(result.size).toBe(0);\n    35→  });\n    36→\n    37→  it('parses strict key=count format', () => {\n    38→    writeFileSync(retriesPath(testDir), '2-1-dependency-auto-install=4\\n0-1-sprint-execution-skill=3\\n');\n    39→    const result = readRetries(testDir);\n    40→    expect(result.get('2-1-dependency-auto-install')).toBe(4);\n    41→    expect(result.get('0-1-sprint-execution-skill')).toBe(3);\n    42→    expect(result.size).toBe(2);\n    43→  });\n    44→\n    45→  it('ignores empty lines', () => {\n    46→    writeFileSync(retriesPath(testDir), '\\n2-1-dep=1\\n\\n\\n');\n    47→    const result = readRetries(testDir);\n    48→    expect(result.size).toBe(1);\n    49→    expect(result.get('2-1-dep')).toBe(1);\n    50→  });\n    51→\n    52→  it('ignores malformed lines with a warning', () => {\n    53→    const warnSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n    54→    writeFileSync(retriesPath(testDir), '13-3-black-box-verifier-agent 4\\ngood-key=2\\nbad line here\\n');\n    55→    const result = readRetries(testDir);\n    56→    expect(result.size).toBe(1);\n    57→    expect(result.get('good-key')).toBe(2);\n    58→    // Two bad lines should produce two warnings\n    59→    expect(warnSpy).toHaveBeenCalledTimes(2);\n    60→    expect(warnSpy.mock.calls[0][0]).toContain('Ignoring malformed retry line');\n    61→    expect(warnSpy.mock.calls[1][0]).toContain('Ignoring malformed retry line');\n    62→    warnSpy.mockRestore();\n    63→  });\n    64→\n    65→  it('last occurrence wins when duplicates exist', () => {\n    66→    writeFileSync(retriesPath(testDir), 'story-a=1\\nstory-a=5\\n');\n    67→    const result = readRetries(testDir);\n    68→    expect(result.get('story-a')).toBe(5);\n    69→    expect(result.size).toBe(1);\n    70→  });\n    71→\n    72→  it('handles count of zero', () => {\n    73→    writeFileSync(retriesPath(testDir), 'story-a=0\\n');\n    74→    const result = readRetries(testDir);\n    75→    expect(result.get('story-a')).toBe(0);\n    76→  });\n    77→\n    78→  it('rejects lines with non-numeric count', () => {\n    79→    const warnSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n    80→    writeFileSync(retriesPath(testDir), 'story-a=abc\\nstory-b=2\\n');\n    81→    const result = readRetries(testDir);\n    82→    expect(result.size).toBe(1);\n    83→    expect(result.get('story-b')).toBe(2);\n    84→    warnSpy.mockRestore();\n    85→  });\n    86→\n    87→  it('rejects lines with space delimiter (old format)', () => {\n    88→    const warnSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n    89→    writeFileSync(retriesPath(testDir), '13-3-black-box-verifier-agent 4\\n');\n    90→    const result = readRetries(testDir);\n    91→    expect(result.size).toBe(0);\n    92→    expect(warnSpy).toHaveBeenCalledTimes(1);\n    93→    warnSpy.mockRestore();\n    94→  });\n    95→\n    96→  it('rejects lines with multiple = signs', () => {\n    97→    const warnSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n    98→    writeFileSync(retriesPath(testDir), 'story=key=2\\n');\n    99→    const result = readRetries(testDir);\n   100→    expect(result.size).toBe(0);\n   101→    warnSpy.mockRestore();\n   102→  });\n   103→});\n   104→\n   105→// ─── writeRetries ─────────────────────────────────────────────────────────────\n   106→\n   107→describe('writeRetries', () => {\n   108→  it('writes strict key=count format', () => {\n   109→    const map = new Map([['story-a', 3], ['story-b', 1]]);\n   110→    writeRetries(testDir, map);\n   111→    const content = readFileSync(retriesPath(testDir), 'utf-8');\n   112→    expect(content).toBe('story-a=3\\nstory-b=1\\n');\n   113→  });\n   114→\n   115→  it('writes empty file for empty map', () => {\n   116→    writeRetries(testDir, new Map());\n   117→    const content = readFileSync(retriesPath(testDir), 'utf-8');\n   118→    expect(content).toBe('');\n   119→  });\n   120→\n   121→  it('deduplicates by nature of Map (last set wins)', () => {\n   122→    const map = new Map<string, number>();\n   123→    map.set('story-a', 1);\n   124→    map.set('story-a', 5);\n   125→    writeRetries(testDir, map);\n   126→    const content = readFileSync(retriesPath(testDir), 'utf-8');\n   127→    expect(content).toBe('story-a=5\\n');\n   128→  });\n   129→\n   130→  it('overwrites existing file', () => {\n   131→    writeFileSync(retriesPath(testDir), 'old-story=99\\n');\n   132→    writeRetries(testDir, new Map([['new-story', 1]]));\n   133→    const content = readFileSync(retriesPath(testDir), 'utf-8');\n   134→    expect(content).toBe('new-story=1\\n');\n   135→    expect(content).not.toContain('old-story');\n   136→  });\n   137→});\n   138→\n   139→// ─── getRetryCount ────────────────────────────────────────────────────────────\n   140→\n   141→describe('getRetryCount', () => {\n   142→  it('returns 0 when file does not exist', () => {\n   143→    expect(getRetryCount(testDir, 'nonexistent')).toBe(0);\n   144→  });\n   145→\n   146→  it('returns 0 for unknown story key', () => {\n   147→    writeFileSync(retriesPath(testDir), 'story-a=3\\n');\n   148→    expect(getRetryCount(testDir, 'story-b')).toBe(0);\n   149→  });\n   150→\n   151→  it('returns count for known story key', () => {\n   152→    writeFileSync(retriesPath(testDir), 'story-a=7\\n');\n   153→    expect(getRetryCount(testDir, 'story-a')).toBe(7);\n   154→  });\n   155→});\n   156→\n   157→// ─── setRetryCount ────────────────────────────────────────────────────────────\n   158→\n   159→describe('setRetryCount', () => {\n   160→  it('creates file if it does not exist', () => {\n   161→    setRetryCount(testDir, 'story-a', 1);\n   162→    const content = readFileSync(retriesPath(testDir), 'utf-8');\n   163→    expect(content).toBe('story-a=1\\n');\n   164→  });\n   165→\n   166→  it('adds entry to existing file', () => {\n   167→    writeFileSync(retriesPath(testDir), 'story-a=2\\n');\n   168→    setRetryCount(testDir, 'story-b', 3);\n   169→    const content = readFileSync(retriesPath(testDir), 'utf-8');\n   170→    expect(content).toContain('story-a=2');\n   171→    expect(content).toContain('story-b=3');\n   172→  });\n   173→\n   174→  it('updates existing entry (deduplicates)', () => {\n   175→    writeFileSync(retriesPath(testDir), 'story-a=2\\nstory-b=1\\n');\n   176→    setRetryCount(testDir, 'story-a', 5);\n   177→    const content = readFileSync(retriesPath(testDir), 'utf-8');\n   178→    expect(content).toContain('story-a=5');\n   179→    expect(content).toContain('story-b=1');\n   180→    // Only one occurrence of story-a\n   181→    const lines = content.trim().split('\\n');\n   182→    const storyALines = lines.filter(l => l.startsWith('story-a='));\n   183→    expect(storyALines).toHaveLength(1);\n   184→  });\n   185→});\n   186→\n   187→// ─── resetRetry ───────────────────────────────────────────────────────────────\n   188→\n   189→describe('resetRetry', () => {\n   190→  it('clears all entries when no storyKey provided', () => {\n   191→    writeFileSync(retriesPath(testDir), 'story-a=2\\nstory-b=3\\n');\n   192→    writeFileSync(flaggedPath(testDir), 'story-a\\nstory-b\\n');\n   193→    resetRetry(testDir);\n   194→    expect(readFileSync(retriesPath(testDir), 'utf-8')).toBe('');\n   195→    expect(readFileSync(flaggedPath(testDir), 'utf-8')).toBe('');\n   196→  });\n   197→\n   198→  it('clears only specified story when storyKey provided', () => {\n   199→    writeFileSync(retriesPath(testDir), 'story-a=2\\nstory-b=3\\n');\n   200→    writeFileSync(flaggedPath(testDir), 'story-a\\nstory-b\\n');\n   201→    resetRetry(testDir, 'story-a');\n   202→    const retries = readRetries(testDir);\n   203→    expect(retries.has('story-a')).toBe(false);\n   204→    expect(retries.get('story-b')).toBe(3);\n   205→    const flagged = readFlaggedStories(testDir);\n   206→    expect(flagged).not.toContain('story-a');\n   207→    expect(flagged).toContain('story-b');\n   208→  });\n   209→\n   210→  it('is a no-op when clearing a nonexistent story key', () => {\n   211→    writeFileSync(retriesPath(testDir), 'story-a=2\\n');\n   212→    writeFileSync(flaggedPath(testDir), 'story-a\\n');\n   213→    resetRetry(testDir, 'nonexistent');\n   214→    const retries = readRetries(testDir);\n   215→    expect(retries.get('story-a')).toBe(2);\n   216→    const flagged = readFlaggedStories(testDir);\n   217→    expect(flagged).toContain('story-a');\n   218→  });\n   219→\n   220→  it('works when files do not exist', () => {\n   221→    // Should not throw\n   222→    resetRetry(testDir);\n   223→    expect(readFileSync(retriesPath(testDir), 'utf-8')).toBe('');\n   224→    expect(readFileSync(flaggedPath(testDir), 'utf-8')).toBe('');\n   225→  });\n   226→\n   227→  it('works with storyKey when files do not exist', () => {\n   228→    resetRetry(testDir, 'story-a');\n   229→    expect(readFileSync(retriesPath(testDir), 'utf-8')).toBe('');\n   230→    expect(readFileSync(flaggedPath(testDir), 'utf-8')).toBe('');\n   231→  });\n   232→});\n   233→\n   234→// ─── readFlaggedStories ───────────────────────────────────────────────────────\n   235→\n   236→describe('readFlaggedStories', () => {\n   237→  it('returns empty array when file does not exist', () => {\n   238→    expect(readFlaggedStories(testDir)).toEqual([]);\n   239→  });\n   240→\n   241→  it('returns story keys one per line', () => {\n   242→    writeFileSync(flaggedPath(testDir), 'story-a\\nstory-b\\n');\n   243→    expect(readFlaggedStories(testDir)).toEqual(['story-a', 'story-b']);\n   244→  });\n   245→\n   246→  it('ignores empty lines', () => {\n   247→    writeFileSync(flaggedPath(testDir), '\\nstory-a\\n\\nstory-b\\n\\n');\n   248→    expect(readFlaggedStories(testDir)).toEqual(['story-a', 'story-b']);\n   249→  });\n   250→\n   251→  it('trims whitespace', () => {\n   252→    writeFileSync(flaggedPath(testDir), '  story-a  \\n  story-b  \\n');\n   253→    expect(readFlaggedStories(testDir)).toEqual(['story-a', 'story-b']);\n   254→  });\n   255→});\n   256→\n   257→// ─── writeFlaggedStories ──────────────────────────────────────────────────────\n   258→\n   259→describe('writeFlaggedStories', () => {\n   260→  it('writes one key per line', () => {\n   261→    writeFlaggedStories(testDir, ['story-a', 'story-b']);\n   262→    const content = readFileSync(flaggedPath(testDir), 'utf-8');\n   263→    expect(content).toBe('story-a\\nstory-b\\n');\n   264→  });\n   265→\n   266→  it('writes empty file for empty array', () => {\n   267→    writeFlaggedStories(testDir, []);\n   268→    const content = readFileSync(flaggedPath(testDir), 'utf-8');\n   269→    expect(content).toBe('');\n   270→  });\n   271→});\n   272→\n   273→// ─── removeFlaggedStory ───────────────────────────────────────────────────────\n   274→\n   275→describe('removeFlaggedStory', () => {\n   276→  it('removes a single story from flagged list', () => {\n   277→    writeFileSync(flaggedPath(testDir), 'story-a\\nstory-b\\nstory-c\\n');\n   278→    removeFlaggedStory(testDir, 'story-b');\n   279→    expect(readFlaggedStories(testDir)).toEqual(['story-a', 'story-c']);\n   280→  });\n   281→\n   282→  it('is a no-op when story is not in list', () => {\n   283→    writeFileSync(flaggedPath(testDir), 'story-a\\n');\n   284→    removeFlaggedStory(testDir, 'nonexistent');\n   285→    expect(readFlaggedStories(testDir)).toEqual(['story-a']);\n   286→  });\n   287→\n   288→  it('works when file does not exist', () => {\n   289→    removeFlaggedStory(testDir, 'story-a');\n   290→    // Should create an empty file\n   291→    expect(readFileSync(flaggedPath(testDir), 'utf-8')).toBe('');\n   292→  });\n   293→});\n   294→\n   295→// ─── path helpers ─────────────────────────────────────────────────────────────\n   296→\n   297→describe('path helpers', () => {\n   298→  it('retriesPath returns correct path', () => {\n   299→    expect(retriesPath('/some/dir')).toBe('/some/dir/.story_retries');\n   300→  });\n   301→\n   302→  it('flaggedPath returns correct path', () => {\n   303→    expect(flaggedPath('/some/dir')).toBe('/some/dir/.flagged_stories');\n   304→  });\n   305→});\n   306→"}]},"parent_tool_use_id":"toolu_01EPL4eJAP5W5qUxFXY5uuFc","session_id":"6707468c-554d-4568-9ea5-0d04d4a85f59","uuid":"8b070338-fb90-465b-a23d-30828cd6e0c8","timestamp":"2026-03-24T10:20:59.102Z"}
