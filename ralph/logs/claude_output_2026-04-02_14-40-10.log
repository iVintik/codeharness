{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QyLwYAh5Av99YNu68WktyM","type":"tool_result","content":"1\timport { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n2\timport { join } from 'node:path';\n3\timport { parse, stringify } from 'yaml';\n4\timport { warn } from './output.js';\n5\t\n6\t// --- Interfaces ---\n7\t\n8\texport interface TaskCheckpoint {\n9\t  task_name: string;\n10\t  story_key: string;\n11\t  completed_at: string;\n12\t  session_id?: string;\n13\t}\n14\t\n15\texport interface EvaluatorScore {\n16\t  iteration: number;\n17\t  passed: number;\n18\t  failed: number;\n19\t  unknown: number;\n20\t  total: number;\n21\t  timestamp: string;\n22\t}\n23\t\n24\texport interface CircuitBreakerState {\n25\t  triggered: boolean;\n26\t  reason: string | null;\n27\t  score_history: number[];\n28\t}\n29\t\n30\texport interface WorkflowState {\n31\t  workflow_name: string;\n32\t  started: string;\n33\t  iteration: number;\n34\t  phase: string;\n35\t  tasks_completed: TaskCheckpoint[];\n36\t  evaluator_scores: EvaluatorScore[];\n37\t  circuit_breaker: CircuitBreakerState;\n38\t}\n39\t\n40\t// --- Constants ---\n41\t\n42\tconst STATE_DIR = '.codeharness';\n43\tconst STATE_FILE = 'workflow-state.yaml';\n44\t\n45\t// --- Functions ---\n46\t\n47\texport function getDefaultWorkflowState(): WorkflowState {\n48\t  return {\n49\t    workflow_name: '',\n50\t    started: '',\n51\t    iteration: 0,\n52\t    phase: 'idle',\n53\t    tasks_completed: [],\n54\t    evaluator_scores: [],\n55\t    circuit_breaker: {\n56\t      triggered: false,\n57\t      reason: null,\n58\t      score_history: [],\n59\t    },\n60\t  };\n61\t}\n62\t\n63\texport function writeState(state: WorkflowState, dir?: string): void {\n64\t  const baseDir = dir ?? process.cwd();\n65\t  const stateDir = join(baseDir, STATE_DIR);\n66\t  mkdirSync(stateDir, { recursive: true });\n67\t  const yamlContent = stringify(state, { nullStr: 'null' });\n68\t  writeFileSync(join(stateDir, STATE_FILE), yamlContent, 'utf-8');\n69\t}\n70\t\n71\texport function readState(dir?: string): WorkflowState {\n72\t  const baseDir = dir ?? process.cwd();\n73\t  const filePath = join(baseDir, STATE_DIR, STATE_FILE);\n74\t\n75\t  if (!existsSync(filePath)) {\n76\t    return getDefaultWorkflowState();\n77\t  }\n78\t\n79\t  let raw: string;\n80\t  try {\n81\t    raw = readFileSync(filePath, 'utf-8');\n82\t  } catch { // IGNORE: unreadable file (permissions, EISDIR, etc.) — recover with defaults\n83\t    warn('workflow-state.yaml could not be read — returning default state');\n84\t    return getDefaultWorkflowState();\n85\t  }\n86\t\n87\t  let parsed: unknown;\n88\t  try {\n89\t    parsed = parse(raw);\n90\t  } catch { // IGNORE: corrupted YAML — recover with defaults\n91\t    warn('workflow-state.yaml contains invalid YAML — returning default state');\n92\t    return getDefaultWorkflowState();\n93\t  }\n94\t\n95\t  if (!isValidWorkflowState(parsed)) {\n96\t    warn('workflow-state.yaml has invalid shape — returning default state');\n97\t    return getDefaultWorkflowState();\n98\t  }\n99\t\n100\t  return parsed;\n101\t}\n102\t\n103\t// --- Validation ---\n104\t\n105\tfunction isValidWorkflowState(value: unknown): value is WorkflowState {\n106\t  if (!value || typeof value !== 'object') return false;\n107\t  const s = value as Record<string, unknown>;\n108\t\n109\t  if (typeof s.workflow_name !== 'string') return false;\n110\t  if (typeof s.started !== 'string') return false;\n111\t  if (typeof s.iteration !== 'number') return false;\n112\t  if (typeof s.phase !== 'string') return false;\n113\t  if (!Array.isArray(s.tasks_completed)) return false;\n114\t  if (!Array.isArray(s.evaluator_scores)) return false;\n115\t  if (!s.circuit_breaker || typeof s.circuit_breaker !== 'object') return false;\n116\t\n117\t  const cb = s.circuit_breaker as Record<string, unknown>;\n118\t  if (typeof cb.triggered !== 'boolean') return false;\n119\t  if (cb.reason !== null && typeof cb.reason !== 'string') return false;\n120\t  if (!Array.isArray(cb.score_history)) return false;\n121\t\n122\t  return true;\n123\t}\n124\t"}]},"parent_tool_use_id":"toolu_01JWPSfMd9pChrXHMHYJCdbA","session_id":"aeb5b1ee-06a7-4bdc-8279-6cd22d306d14","uuid":"0174fd8a-071c-4bc3-8c74-f5332b175c21","timestamp":"2026-04-02T10:51:09.717Z"}
