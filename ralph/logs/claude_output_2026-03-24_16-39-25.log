{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AdbGpMadAbpU3j3Gk6mAVY","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';\n     2→import {\n     3→  mkdtempSync,\n     4→  mkdirSync,\n     5→  rmSync,\n     6→  writeFileSync,\n     7→  readFileSync,\n     8→  existsSync,\n     9→  utimesSync,\n    10→} from 'node:fs';\n    11→import { tmpdir } from 'node:os';\n    12→import { join } from 'node:path';\n    13→import {\n    14→  findModules,\n    15→  isDocStale,\n    16→  checkAgentsMdForModule,\n    17→  checkDoNotEditHeaders,\n    18→  scanDocHealth,\n    19→  checkStoryDocFreshness,\n    20→  createExecPlan,\n    21→  completeExecPlan,\n    22→  getExecPlanStatus,\n    23→  formatDocHealthOutput,\n    24→  printDocHealthOutput,\n    25→  getSourceFilesInModule,\n    26→  getMentionedFilesInAgentsMd,\n    27→  checkAgentsMdCompleteness,\n    28→} from '../doc-health.js';\n    29→import type { DocHealthReport } from '../doc-health.js';\n    30→\n    31→let testDir: string;\n    32→\n    33→beforeEach(() => {\n    34→  testDir = mkdtempSync(join(tmpdir(), 'ch-doc-health-test-'));\n    35→});\n    36→\n    37→afterEach(() => {\n    38→  rmSync(testDir, { recursive: true, force: true });\n    39→});\n    40→\n    41→// Helper to set file mtime to a specific time\n    42→function setMtime(filePath: string, date: Date): void {\n    43→  utimesSync(filePath, date, date);\n    44→}\n    45→\n    46→// Helper to create a file with specific content\n    47→function createFile(relPath: string, content = ''): string {\n    48→  const fullPath = join(testDir, relPath);\n    49→  mkdirSync(join(fullPath, '..'), { recursive: true });\n    50→  writeFileSync(fullPath, content, 'utf-8');\n    51→  return fullPath;\n    52→}\n    53→\n    54→// ─── findModules ─────────────────────────────────────────────────────────────\n    55→\n    56→describe('findModules', () => {\n    57→  it('finds directories with at least 3 source files', () => {\n    58→    createFile('src/a.ts', 'code');\n    59→    createFile('src/b.ts', 'code');\n    60→    createFile('src/c.ts', 'code');\n    61→    createFile('lib/x.ts', 'code');\n    62→    createFile('lib/y.ts', 'code');\n    63→\n    64→    const modules = findModules(testDir);\n    65→    expect(modules).toContain('src');\n    66→    expect(modules).not.toContain('lib');\n    67→  });\n    68→\n    69→  it('respects custom threshold', () => {\n    70→    createFile('lib/x.ts', 'code');\n    71→    createFile('lib/y.ts', 'code');\n    72→\n    73→    const modules = findModules(testDir, 2);\n    74→    expect(modules).toContain('lib');\n    75→  });\n    76→\n    77→  it('excludes test files', () => {\n    78→    createFile('src/a.test.ts', 'test');\n    79→    createFile('src/b.spec.ts', 'test');\n    80→    createFile('src/test_c.ts', 'test');\n    81→    createFile('src/d.ts', 'code');\n    82→\n    83→    const modules = findModules(testDir, 2);\n    84→    // Only d.ts is a source file, so src should not qualify\n    85→    expect(modules).not.toContain('src');\n    86→  });\n    87→\n    88→  it('excludes node_modules', () => {\n    89→    createFile('node_modules/pkg/a.ts', 'code');\n    90→    createFile('node_modules/pkg/b.ts', 'code');\n    91→    createFile('node_modules/pkg/c.ts', 'code');\n    92→\n    93→    const modules = findModules(testDir);\n    94→    expect(modules).toHaveLength(0);\n    95→  });\n    96→\n    97→  it('finds nested modules', () => {\n    98→    createFile('src/lib/a.ts', 'code');\n    99→    createFile('src/lib/b.ts', 'code');\n   100→    createFile('src/lib/c.ts', 'code');\n   101→\n   102→    const modules = findModules(testDir);\n   103→    expect(modules).toContain('src/lib');\n   104→  });\n   105→\n   106→  it('supports .js and .py extensions', () => {\n   107→    createFile('app/a.js', 'code');\n   108→    createFile('app/b.py', 'code');\n   109→    createFile('app/c.ts', 'code');\n   110→\n   111→    const modules = findModules(testDir);\n   112→    expect(modules).toContain('app');\n   113→  });\n   114→\n   115→  it('returns empty for directory with no source files', () => {\n   116→    createFile('docs/readme.md', 'text');\n   117→    createFile('docs/guide.md', 'text');\n   118→    createFile('docs/faq.md', 'text');\n   119→\n   120→    const modules = findModules(testDir);\n   121→    expect(modules).toHaveLength(0);\n   122→  });\n   123→});\n   124→\n   125→// ─── isDocStale ──────────────────────────────────────────────────────────────\n   126→\n   127→describe('isDocStale', () => {\n   128→  it('returns true when source is newer than doc', () => {\n   129→    const docPath = createFile('AGENTS.md', '# Agents');\n   130→    const srcPath = createFile('src/a.ts', 'code');\n   131→\n   132→    const past = new Date(Date.now() - 10000);\n   133→    const future = new Date(Date.now() + 10000);\n   134→\n   135→    setMtime(docPath, past);\n   136→    setMtime(srcPath, future);\n   137→\n   138→    expect(isDocStale(docPath, join(testDir, 'src'))).toBe(true);\n   139→  });\n   140→\n   141→  it('returns false when doc is newer than source', () => {\n   142→    const docPath = createFile('AGENTS.md', '# Agents');\n   143→    const srcPath = createFile('src/a.ts', 'code');\n   144→\n   145→    const past = new Date(Date.now() - 10000);\n   146→    const future = new Date(Date.now() + 10000);\n   147→\n   148→    setMtime(srcPath, past);\n   149→    setMtime(docPath, future);\n   150→\n   151→    expect(isDocStale(docPath, join(testDir, 'src'))).toBe(false);\n   152→  });\n   153→\n   154→  it('returns true when doc does not exist', () => {\n   155→    createFile('src/a.ts', 'code');\n   156→    expect(isDocStale(join(testDir, 'AGENTS.md'), join(testDir, 'src'))).toBe(true);\n   157→  });\n   158→\n   159→  it('returns false when code dir does not exist', () => {\n   160→    const docPath = createFile('AGENTS.md', '# Agents');\n   161→    expect(isDocStale(docPath, join(testDir, 'nonexistent'))).toBe(false);\n   162→  });\n   163→\n   164→  it('returns false when code dir has no source files', () => {\n   165→    const docPath = createFile('AGENTS.md', '# Agents');\n   166→    createFile('src/readme.md', 'text');\n   167→\n   168→    expect(isDocStale(docPath, join(testDir, 'src'))).toBe(false);\n   169→  });\n   170→});\n   171→\n   172→// ─── checkAgentsMdForModule ──────────────────────────────────────────────────\n   173→\n   174→describe('checkAgentsMdForModule', () => {\n   175→  it('returns fresh when all source files are mentioned in AGENTS.md', () => {\n   176→    createFile('src/AGENTS.md', '# Agents\\n\\nFiles: `a.ts`\\n');\n   177→    createFile('src/a.ts', 'code');\n   178→\n   179→    const result = checkAgentsMdForModule('src', testDir);\n   180→    expect(result.grade).toBe('fresh');\n   181→    expect(result.reason).toBe('Up to date');\n   182→  });\n   183→\n   184→  it('returns stale when source files are missing from AGENTS.md', () => {\n   185→    createFile('src/AGENTS.md', '# Agents\\n\\nFiles: `a.ts`\\n');\n   186→    createFile('src/a.ts', 'code');\n   187→    createFile('src/b.ts', 'code');\n   188→\n   189→    const result = checkAgentsMdForModule('src', testDir);\n   190→    expect(result.grade).toBe('stale');\n   191→    expect(result.reason).toContain('AGENTS.md stale for module: src');\n   192→    expect(result.reason).toContain('missing: b.ts');\n   193→  });\n   194→\n   195→  it('returns fresh regardless of mtime when all files are mentioned', () => {\n   196→    // AGENTS.md is older than code, but all files are mentioned — should be fresh\n   197→    const agentsPath = createFile('src/AGENTS.md', '# Agents\\n\\n- `a.ts` — main module\\n');\n   198→    const srcPath = createFile('src/a.ts', 'code');\n   199→\n   200→    const past = new Date(Date.now() - 10000);\n   201→    const future = new Date(Date.now() + 10000);\n   202→\n   203→    setMtime(agentsPath, past);\n   204→    setMtime(srcPath, future);\n   205→\n   206→    const result = checkAgentsMdForModule('src', testDir);\n   207→    expect(result.grade).toBe('fresh');\n   208→  });\n   209→\n   210→  it('falls back to root AGENTS.md when module has none', () => {\n   211→    createFile('AGENTS.md', '# Root\\n\\nFiles: `a.ts`\\n');\n   212→    createFile('src/a.ts', 'code');\n   213→\n   214→    const result = checkAgentsMdForModule('src', testDir);\n   215→    expect(result.grade).toBe('fresh');\n   216→  });\n   217→\n   218→  it('returns missing when no AGENTS.md found', () => {\n   219→    createFile('src/a.ts', 'code');\n   220→\n   221→    const result = checkAgentsMdForModule('src', testDir);\n   222→    expect(result.grade).toBe('missing');\n   223→    expect(result.reason).toContain('No AGENTS.md found for module: src');\n   224→  });\n   225→\n   226→  it('includes missing filenames in stale reason', () => {\n   227→    createFile('src/AGENTS.md', '# Agents\\n');\n   228→    createFile('src/a.ts', 'code');\n   229→    createFile('src/b.ts', 'code');\n   230→\n   231→    const result = checkAgentsMdForModule('src', testDir);\n   232→    expect(result.grade).toBe('stale');\n   233→    expect(result.reason).toMatch(/missing: .*a\\.ts/);\n   234→    expect(result.reason).toMatch(/missing: .*b\\.ts/);\n   235→  });\n   236→});\n   237→\n   238→// ─── checkDoNotEditHeaders ───────────────────────────────────────────────────\n   239→\n   240→describe('checkDoNotEditHeaders', () => {\n   241→  it('returns true when file starts with DO NOT EDIT MANUALLY', () => {\n   242→    const filePath = createFile('docs/quality/report.md', '<!-- DO NOT EDIT MANUALLY -->\\n# Report');\n   243→    expect(checkDoNotEditHeaders(filePath)).toBe(true);\n   244→  });\n   245→\n   246→  it('returns true with whitespace before header', () => {\n   247→    const filePath = createFile('docs/quality/report.md', '\\n<!-- DO NOT EDIT MANUALLY -->\\n# Report');\n   248→    expect(checkDoNotEditHeaders(filePath)).toBe(true);\n   249→  });\n   250→\n   251→  it('returns false when header is missing', () => {\n   252→    const filePath = createFile('docs/quality/report.md', '# Report\\nSome content');\n   253→    expect(checkDoNotEditHeaders(filePath)).toBe(false);\n   254→  });\n   255→\n   256→  it('returns false for empty file', () => {\n   257→    const filePath = createFile('docs/quality/empty.md', '');\n   258→    expect(checkDoNotEditHeaders(filePath)).toBe(false);\n   259→  });\n   260→\n   261→  it('returns false for nonexistent file', () => {\n   262→    expect(checkDoNotEditHeaders(join(testDir, 'nope.md'))).toBe(false);\n   263→  });\n   264→});\n   265→\n   266→// ─── scanDocHealth ───────────────────────────────────────────────────────────\n   267→\n   268→describe('scanDocHealth', () => {\n   269→  it('produces correct grades for fresh AGENTS.md when all files mentioned', () => {\n   270→    // Create AGENTS.md mentioning all source files\n   271→    createFile('AGENTS.md', '# Agents\\n\\nFiles: `a.ts`, `b.ts`, `c.ts`\\n');\n   272→    createFile('src/a.ts', 'code');\n   273→    createFile('src/b.ts', 'code');\n   274→    createFile('src/c.ts', 'code');\n   275→\n   276→    const report = scanDocHealth(testDir);\n   277→    const agentsResult = report.documents.find(d => d.path === 'AGENTS.md' && !d.reason.includes('exceeds'));\n   278→    expect(agentsResult).toBeDefined();\n   279→    expect(agentsResult!.grade).toBe('fresh');\n   280→  });\n   281→\n   282→  it('produces stale grade when source files are missing from AGENTS.md', () => {\n   283→    createFile('AGENTS.md', '# Agents\\n\\nFiles: `a.ts`\\n');\n   284→    createFile('src/a.ts', 'code');\n   285→    createFile('src/b.ts', 'code');\n   286→    createFile('src/c.ts', 'code');\n   287→\n   288→    const report = scanDocHealth(testDir);\n   289→    expect(report.passed).toBe(false);\n   290→    expect(report.summary.stale).toBeGreaterThanOrEqual(1);\n   291→  });\n   292→\n   293→  it('reports missing AGENTS.md', () => {\n   294→    createFile('src/a.ts', 'code');\n   295→    createFile('src/b.ts', 'code');\n   296→    createFile('src/c.ts', 'code');\n   297→\n   298→    const report = scanDocHealth(testDir);\n   299→    expect(report.passed).toBe(false);\n   300→    const missing = report.documents.find(d => d.path === 'AGENTS.md' && d.grade === 'missing');\n   301→    expect(missing).toBeDefined();\n   302→  });\n   303→\n   304→  it('checks docs/quality files for DO NOT EDIT header', () => {\n   305→    createFile('AGENTS.md', '# Agents');\n   306→    createFile('docs/quality/report.md', '<!-- DO NOT EDIT MANUALLY -->\\n# Report');\n   307→    createFile('docs/quality/bad.md', '# Bad report');\n   308→\n   309→    const report = scanDocHealth(testDir);\n   310→    const goodDoc = report.documents.find(d => d.path === 'docs/quality/report.md');\n   311→    const badDoc = report.documents.find(d => d.path === 'docs/quality/bad.md');\n   312→\n   313→    expect(goodDoc?.grade).toBe('fresh');\n   314→    expect(badDoc?.grade).toBe('stale');\n   315→  });\n   316→\n   317→  it('checks docs/generated files for DO NOT EDIT header', () => {\n   318→    createFile('AGENTS.md', '# Agents');\n   319→    createFile('docs/generated/auto.md', '<!-- DO NOT EDIT MANUALLY -->\\n# Auto');\n   320→\n   321→    const report = scanDocHealth(testDir);\n   322→    const doc = report.documents.find(d => d.path === 'docs/generated/auto.md');\n   323→    expect(doc?.grade).toBe('fresh');\n   324→  });\n   325→\n   326→  it('includes docs/index.md in scan', () => {\n   327→    createFile('AGENTS.md', '# Agents');\n   328→    createFile('docs/index.md', '# Index\\n[link](../artifacts/prd.md)');\n   329→\n   330→    const report = scanDocHealth(testDir);\n   331→    const indexDoc = report.documents.find(d => d.path === 'docs/index.md');\n   332→    expect(indexDoc).toBeDefined();\n   333→    expect(indexDoc!.grade).toBe('fresh');\n   334→  });\n   335→\n   336→  it('reports active exec-plans', () => {\n   337→    createFile('AGENTS.md', '# Agents');\n   338→    createFile('docs/exec-plans/active/test-story.md', '# Exec Plan');\n   339→\n   340→    const report = scanDocHealth(testDir);\n   341→    const execPlan = report.documents.find(d => d.path === 'docs/exec-plans/active/test-story.md');\n   342→    expect(execPlan).toBeDefined();\n   343→    expect(execPlan!.grade).toBe('fresh');\n   344→  });\n   345→\n   346→  it('completes within 60 seconds (NFR23)', () => {\n   347→    // Create a project with ~50 files\n   348→    createFile('AGENTS.md', '# Agents');\n   349→    for (let i = 0; i < 50; i++) {\n   350→      createFile(`src/file${i}.ts`, `// file ${i}`);\n   351→    }\n   352→\n   353→    const report = scanDocHealth(testDir);\n   354→    expect(report.scanDurationMs).toBeLessThan(60_000);\n   355→  });\n   356→\n   357→  it('warns when AGENTS.md exceeds 100 lines (NFR24)', () => {\n   358→    // Include source file mentions so it's not stale\n   359→    const lines = ['# Agents', '`a.ts` `b.ts` `c.ts`', ...Array.from({ length: 120 }, (_, i) => `Line ${i}`)].join('\\n');\n   360→    createFile('AGENTS.md', lines);\n   361→    createFile('src/a.ts', 'code');\n   362→    createFile('src/b.ts', 'code');\n   363→    createFile('src/c.ts', 'code');\n   364→\n   365→    const report = scanDocHealth(testDir);\n   366→    const warnings = report.documents.filter(d => d.reason.includes('exceeds 100 lines'));\n   367→    expect(warnings.length).toBeGreaterThanOrEqual(1);\n   368→  });\n   369→\n   370→  it('correctly computes summary counts', () => {\n   371→    createFile('AGENTS.md', '# Agents');\n   372→    createFile('docs/quality/good.md', '<!-- DO NOT EDIT MANUALLY -->\\n# Good');\n   373→    createFile('docs/quality/bad.md', '# Bad');\n   374→\n   375→    const report = scanDocHealth(testDir);\n   376→    expect(report.summary.total).toBe(report.documents.length);\n   377→    expect(report.summary.fresh + report.summary.stale + report.summary.missing).toBe(report.summary.total);\n   378→  });\n   379→\n   380→  it('skips hidden directories in docs/quality', () => {\n   381→    createFile('AGENTS.md', '# Agents');\n   382→    createFile('docs/quality/.gitkeep', '');\n   383→\n   384→    const report = scanDocHealth(testDir);\n   385→    const gitkeep = report.documents.find(d => d.path.includes('.gitkeep'));\n   386→    expect(gitkeep).toBeUndefined();\n   387→  });\n   388→});\n   389→\n   390→// ─── checkStoryDocFreshness ──────────────────────────────────────────────────\n   391→\n   392→describe('checkStoryDocFreshness', () => {\n   393→  it('checks AGENTS.md freshness for modules', () => {\n   394→    createFile('AGENTS.md', '# Agents\\n\\n`a.ts` `b.ts` `c.ts`\\n');\n   395→    createFile('src/a.ts', 'code');\n   396→    createFile('src/b.ts', 'code');\n   397→    createFile('src/c.ts', 'code');\n   398→\n   399→    // Without git, falls back to full scan\n   400→    const report = checkStoryDocFreshness('test-story', testDir);\n   401→    expect(report.documents.length).toBeGreaterThanOrEqual(1);\n   402→  });\n   403→\n   404→  it('returns passed when all source files are mentioned', () => {\n   405→    createFile('AGENTS.md', '# Agents\\n\\n`a.ts` `b.ts` `c.ts`\\n');\n   406→    createFile('src/a.ts', 'code');\n   407→    createFile('src/b.ts', 'code');\n   408→    createFile('src/c.ts', 'code');\n   409→\n   410→    const report = checkStoryDocFreshness('test-story', testDir);\n   411→    expect(report.passed).toBe(true);\n   412→  });\n   413→\n   414→  it('returns not passed when AGENTS.md is missing source files', () => {\n   415→    createFile('AGENTS.md', '# Agents\\n\\nOnly `a.ts`\\n');\n   416→    createFile('src/a.ts', 'code');\n   417→    createFile('src/b.ts', 'code');\n   418→    createFile('src/c.ts', 'code');\n   419→\n   420→    const report = checkStoryDocFreshness('test-story', testDir);\n   421→    expect(report.passed).toBe(false);\n   422→  });\n   423→\n 