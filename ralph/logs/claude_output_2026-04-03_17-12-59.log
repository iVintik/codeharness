{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ju7ZCkBQCx1pqvAp9y6euq","type":"tool_result","content":"1\t/**\n2\t * Public API for the agents subsystem.\n3\t *\n4\t * Re-exports types (story 10-1), stream parser functions/types,\n5\t * and the driver factory (story 10-2).\n6\t */\n7\t\n8\t// New types (Epic 10)\n9\texport type {\n10\t  AgentDriver,\n11\t  DriverHealth,\n12\t  DriverCapabilities,\n13\t  CapabilityWarning,\n14\t  DispatchOpts,\n15\t  ErrorCategory,\n16\t  OutputContract,\n17\t  TestResults,\n18\t  ACStatus,\n19\t} from './types.js';\n20\t\n21\t// Deprecated types — kept for backward compatibility until story 10-3\n22\t/** @deprecated Use `DispatchOpts` instead. */\n23\texport type { SpawnOpts } from './types.js';\n24\t/** @deprecated Use `AsyncIterable<StreamEvent>` from `dispatch()` instead. */\n25\texport type { AgentProcess } from './types.js';\n26\t/** @deprecated Use `StreamEvent` from `stream-parser.ts` instead. */\n27\texport type { AgentEvent } from './types.js';\n28\t\n29\t// Stream parser\n30\texport { parseStreamLine } from './stream-parser.js';\n31\texport type {\n32\t  StreamEvent,\n33\t  ToolStartEvent,\n34\t  ToolInputEvent,\n35\t  ToolCompleteEvent,\n36\t  TextEvent,\n37\t  RetryEvent,\n38\t  ResultEvent,\n39\t} from './stream-parser.js';\n40\t\n41\t// --- Driver Factory ---\n42\t\n43\texport { getDriver, registerDriver, listDrivers, resetDrivers, suggestCheaperDriver } from './drivers/factory.js';\n44\t\n45\t// --- Capability Check ---\n46\t\n47\texport { checkCapabilityConflicts } from './capability-check.js';\n48\t\n49\t// --- Model Resolution ---\n50\t\n51\texport { resolveModel } from './model-resolver.js';\n52\t\n53\t// --- Output Contract ---\n54\t\n55\texport {\n56\t  writeOutputContract,\n57\t  readOutputContract,\n58\t  formatContractAsPromptContext,\n59\t  buildPromptWithContractContext,\n60\t} from './output-contract.js';\n61\t"}]},"parent_tool_use_id":"toolu_01WL7MCsNF3La2JHGCjnTeXK","session_i