{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Fo74F81zTbB3ropA3Cu2PK","type":"tool_result","content":"1\t{\n2\t  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n3\t  \"$id\": \"https://codeharness.dev/schemas/output-contract.schema.json\",\n4\t  \"title\": \"Codeharness Output Contract\",\n5\t  \"description\": \"Schema for output contract JSON files produced by task dispatches\",\n6\t  \"type\": \"object\",\n7\t  \"required\": [\n8\t    \"version\",\n9\t    \"taskName\",\n10\t    \"storyId\",\n11\t    \"driver\",\n12\t    \"model\",\n13\t    \"timestamp\",\n14\t    \"cost_usd\",\n15\t    \"duration_ms\",\n16\t    \"changedFiles\",\n17\t    \"testResults\",\n18\t    \"output\",\n19\t    \"acceptanceCriteria\"\n20\t  ],\n21\t  \"properties\": {\n22\t    \"version\": {\n23\t      \"type\": \"number\",\n24\t      \"description\": \"Contract format version (currently 1)\"\n25\t    },\n26\t    \"taskName\": {\n27\t      \"type\": \"string\",\n28\t      \"description\": \"Name of the task that produced this contract\"\n29\t    },\n30\t    \"storyId\": {\n31\t      \"type\": \"string\",\n32\t      \"description\": \"Story identifier this task belongs to\"\n33\t    },\n34\t    \"driver\": {\n35\t      \"type\": \"string\",\n36\t      \"description\": \"Driver that executed the task (e.g. claude-code, codex, opencode)\"\n37\t    },\n38\t    \"model\": {\n39\t      \"type\": \"string\",\n40\t      \"description\": \"Model used for the task\"\n41\t    },\n42\t    \"timestamp\": {\n43\t      \"type\": \"string\",\n44\t      \"description\": \"ISO 8601 timestamp of task completion\"\n45\t    },\n46\t    \"cost_usd\": {\n47\t      \"type\": [\"number\", \"null\"],\n48\t      \"description\": \"Cost in USD, or null if not available\"\n49\t    },\n50\t    \"duration_ms\": {\n51\t      \"type\": \"number\",\n52\t      \"description\": \"Task duration in milliseconds\"\n53\t    },\n54\t    \"changedFiles\": {\n55\t      \"type\": \"array\",\n56\t      \"items\": {\n57\t        \"type\": \"string\"\n58\t      },\n59\t      \"description\": \"List of files changed by the task\"\n60\t    },\n61\t    \"testResults\": {\n62\t      \"oneOf\": [\n63\t        { \"type\": \"null\" },\n64\t        {\n65\t          \"type\": \"object\",\n66\t          \"required\": [\"passed\", \"failed\", \"coverage\"],\n67\t          \"properties\": {\n68\t            \"passed\": {\n69\t              \"type\": \"number\"\n70\t            },\n71\t            \"failed\": {\n72\t              \"type\": \"number\"\n73\t            },\n74\t            \"coverage\": {\n75\t              \"type\": [\"number\", \"null\"]\n76\t            }\n77\t          }\n78\t        }\n79\t      ],\n80\t      \"description\": \"Test results summary, or null if no tests were run\"\n81\t    },\n82\t    \"output\": {\n83\t      \"type\": \"string\",\n84\t      \"description\": \"Raw output from the task\"\n85\t    },\n86\t    \"acceptanceCriteria\": {\n87\t      \"type\": \"array\",\n88\t      \"items\": {\n89\t        \"type\": \"object\",\n90\t        \"required\": [\"id\", \"description\", \"status\"],\n91\t        \"properties\": {\n92\t          \"id\": {\n93\t            \"type\": \"string\"\n94\t          },\n95\t          \"description\": {\n96\t            \"type\": \"string\"\n97\t          },\n98\t          \"status\": {\n99\t            \"type\": \"string\"\n100\t          }\n101\t        }\n102\t      },\n103\t      \"description\": \"Acceptance criteria status entries\"\n104\t    }\n105\t  },\n106\t  \"additionalProperties\": false\n107\t}\n108\t"}]},"parent_tool_use_id":"toolu_017MrrsWsE9mo9fwEmkkmV2k","session_id":"be33ba5d-0e81-49c4-ae53-e69ac56cd1fb","uuid":"c3d1c98c-9725-47dc-a04c-b43985ec76bf","timestamp":"2026-04-03T10:15:35.041Z"}
