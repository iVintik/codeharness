{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014C7mR2VnVJMi858MhUbSkS","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n     2→import { Command } from 'commander';\n     3→\n     4→vi.mock('../../modules/observability/index.js', () => ({\n     5→  checkObservabilityCoverageGate: vi.fn(),\n     6→}));\n     7→\n     8→vi.mock('../../lib/output.js', () => ({\n     9→  ok: vi.fn(),\n    10→  fail: vi.fn(),\n    11→  warn: vi.fn(),\n    12→  info: vi.fn(),\n    13→  jsonOutput: vi.fn(),\n    14→}));\n    15→\n    16→import { registerObservabilityGateCommand } from '../observability-gate.js';\n    17→import { checkObservabilityCoverageGate } from '../../modules/observability/index.js';\n    18→import { ok, fail, jsonOutput } from '../../lib/output.js';\n    19→\n    20→beforeEach(() => {\n    21→  vi.clearAllMocks();\n    22→  process.exitCode = undefined;\n    23→});\n    24→\n    25→afterEach(() => {\n    26→  process.exitCode = undefined;\n    27→});\n    28→\n    29→async function runGateCmd(args: string[]): Promise<void> {\n    30→  const program = new Command();\n    31→  program.exitOverride();\n    32→  program.option('--json', 'JSON output');\n    33→  registerObservabilityGateCommand(program);\n    34→  try {\n    35→    await program.parseAsync(['node', 'test', 'observability-gate', ...args]);\n    36→  } catch {\n    37→    // Commander throws on exitOverride — ignore\n    38→  }\n    39→}\n    40→\n    41→// ============================================================\n    42→// JSON output format\n    43→// ============================================================\n    44→\n    45→describe('observability-gate --json output', () => {\n    46→  it('outputs expected schema on pass', async () => {\n    47→    vi.mocked(checkObservabilityCoverageGate).mockReturnValue({\n    48→      success: true,\n    49→      data: {\n    50→        passed: true,\n    51→        staticResult: { met: true, current: 85, target: 80, gap: 0 },\n    52→        runtimeResult: null,\n    53→        gapSummary: [],\n    54→      },\n    55→    });\n    56→\n    57→    await runGateCmd(['--json']);\n    58→\n    59→    expect(jsonOutput).toHaveBeenCalledWith(\n    60→      expect.objectContaining({\n    61→        status: 'pass',\n    62→        passed: true,\n    63→        static: { current: 85, target: 80, met: true, gap: 0 },\n    64→        runtime: null,\n    65→        gaps: [],\n    66→      }),\n    67→    );\n    68→  });\n    69→\n    70→  it('outputs expected schema on fail', async () => {\n    71→    vi.mocked(checkObservabilityCoverageGate).mockReturnValue({\n    72→      success: true,\n    73→      data: {\n    74→        passed: false,\n    75→        staticResult: { met: false, current: 72, target: 80, gap: 8 },\n    76→        runtimeResult: null,\n    77→        gapSummary: [],\n    78→      },\n    79→    });\n    80→\n    81→    await runGateCmd(['--json']);\n    82→\n    83→    expect(jsonOutput).toHaveBeenCalledWith(\n    84→      expect.objectContaining({\n    85→        status: 'fail',\n    86→        passed: false,\n    87→        static: { current: 72, target: 80, met: false, gap: 8 },\n    88→      }),\n    89→    );\n    90→    expect(process.exitCode).toBe(1);\n    91→  });\n    92→\n    93→  it('includes runtime in JSON when present', async () => {\n    94→    vi.mocked(checkObservabilityCoverageGate).mockReturnValue({\n    95→      success: true,\n    96→      data: {\n    97→        passed: true,\n    98→        staticResult: { met: true, current: 85, target: 80, gap: 0 },\n    99→        runtimeResult: { met: true, current: 65, target: 60, gap: 0 },\n   100→        gapSummary: [],\n   101→      },\n   102→    });\n   103→\n   104→    await runGateCmd(['--json']);\n   105→\n   106→    expect(jsonOutput).toHaveBeenCalledWith(\n   107→      expect.objectContaining({\n   108→        runtime: { current: 65, target: 60, met: true, gap: 0 },\n   109→      }),\n   110→    );\n   111→  });\n   112→});\n   113→\n   114→// ============================================================\n   115→// Exit codes\n   116→// ============================================================\n   117→\n   118→describe('observability-gate exit codes', () => {\n   119→  it('exit code 0 on pass', async () => {\n   120→    vi.mocked(checkObservabilityCoverageGate).mockReturnValue({\n   121→      success: true,\n   122→      data: {\n   123→        passed: true,\n   124→        staticResult: { met: true, current: 85, target: 80, gap: 0 },\n   125→        runtimeResult: null,\n   126→        gapSummary: [],\n   127→      },\n   128→    });\n   129→\n   130→    await runGateCmd([]);\n   131→\n   132→    expect(process.exitCode).toBeUndefined();\n   133→  });\n   134→\n   135→  it('exit code 1 on fail', async () => {\n   136→    vi.mocked(checkObservabilityCoverageGate).mockReturnValue({\n   137→      success: true,\n   138→      data: {\n   139→        passed: false,\n   140→        staticResult: { met: false, current: 72, target: 80, gap: 8 },\n   141→        runtimeResult: null,\n   142→        gapSummary: [],\n   143→      },\n   144→    });\n   145→\n   146→    await runGateCmd([]);\n   147→\n   148→    expect(process.exitCode).toBe(1);\n   149→  });\n   150→\n   151→  it('exit code 1 on error', async () => {\n   152→    vi.mocked(checkObservabilityCoverageGate).mockReturnValue({\n   153→      success: false,\n   154→      error: 'Failed to read state',\n   155→    });\n   156→\n   157→    await runGateCmd([]);\n   158→\n   159→    expect(process.exitCode).toBe(1);\n   160→  });\n   161→});\n   162→\n   163→// ============================================================\n   164→// --min-static override\n   165→// ============================================================\n   166→\n   167→describe('observability-gate --min-static', () => {\n   168→  it('passes custom static target to gate function', async () => {\n   169→    vi.mocked(checkObservabilityCoverageGate).mockReturnValue({\n   170→      success: true,\n   171→      data: {\n   172→        passed: true,\n   173→        staticResult: { met: true, current: 72, target: 70, gap: 0 },\n   174→        runtimeResult: null,\n   175→        gapSummary: [],\n   176→      },\n   177→    });\n   178→\n   179→    await runGateCmd(['--min-static', '70']);\n   180→\n   181→    expect(checkObservabilityCoverageGate).toHaveBeenCalledWith(\n   182→      expect.any(String),\n   183→      expect.objectContaining({ staticTarget: 70 }),\n   184→    );\n   185→  });\n   186→\n   187→  it('passes custom runtime target to gate function', async () => {\n   188→    vi.mocked(checkObservabilityCoverageGate).mockReturnValue({\n   189→      success: true,\n   190→      data: {\n   191→        passed: true,\n   192→        staticResult: { met: true, current: 85, target: 80, gap: 0 },\n   193→        runtimeResult: { met: true, current: 50, target: 50, gap: 0 },\n   194→        gapSummary: [],\n   195→      },\n   196→    });\n   197→\n   198→    await runGateCmd(['--min-runtime', '50']);\n   199→\n   200→    expect(checkObservabilityCoverageGate).toHaveBeenCalledWith(\n   201→      expect.any(String),\n   202→      expect.objectContaining({ runtimeTarget: 50 }),\n   203→    );\n   204→  });\n   205→});\n   206→\n   207→// ============================================================\n   208→// Text output\n   209→// ============================================================\n   210→\n   211→describe('observability-gate text output', () => {\n   212→  it('prints pass message in text mode', async () => {\n   213→    vi.mocked(checkObservabilityCoverageGate).mockReturnValue({\n   214→      success: true,\n   215→      data: {\n   216→        passed: true,\n   217→        staticResult: { met: true, current: 85, target: 80, gap: 0 },\n   218→        runtimeResult: null,\n   219→        gapSummary: [],\n   220→      },\n   221→    });\n   222→\n   223→    await runGateCmd([]);\n   224→\n   225→    expect(ok).toHaveBeenCalledWith(expect.stringContaining('passed'));\n   226→    expect(ok).toHaveBeenCalledWith(expect.stringContaining('85%'));\n   227→  });\n   228→\n   229→  it('prints fail message with fix suggestion in text mode', async () => {\n   230→    vi.mocked(checkObservabilityCoverageGate).mockReturnValue({\n   231→      success: true,\n   232→      data: {\n   233→        passed: false,\n   234→        staticResult: { met: false, current: 72, target: 80, gap: 8 },\n   235→        runtimeResult: null,\n   236→        gapSummary: [],\n   237→      },\n   238→    });\n   239→\n   240→    await runGateCmd([]);\n   241→\n   242→    expect(fail).toHaveBeenCalledWith(expect.stringContaining('failed'));\n   243→    expect(fail).toHaveBeenCalledWith(expect.stringContaining('codeharness analyze'));\n   244→  });\n   245→\n   246→  it('prints error message on gate error', async () => {\n   247→    vi.mocked(checkObservabilityCoverageGate).mockReturnValue({\n   248→      success: false,\n   249→      error: 'File not found',\n   250→    });\n   251→\n   252→    await runGateCmd([]);\n   253→\n   254→    expect(fail).toHaveBeenCalledWith(expect.stringContaining('File not found'));\n   255→  });\n   256→\n   257→  it('prints error JSON on gate error with --json', async () => {\n   258→    vi.mocked(checkObservabilityCoverageGate).mockReturnValue({\n   259→      success: false,\n   260→      error: 'File not found',\n   261→    });\n   262→\n   263→    await runGateCmd(['--json']);\n   264→\n   265→    expect(jsonOutput).toHaveBeenCalledWith(\n   266→      expect.objectContaining({ status: 'error', message: 'File not found' }),\n   267→    );\n   268→  });\n   269→\n   270→  it('prints runtime info in text mode when runtime passes', async () => {\n   271→    vi.mocked(checkObservabilityCoverageGate).mockReturnValue({\n   272→      success: true,\n   273→      data: {\n   274→        passed: true,\n   275→        staticResult: { met: true, current: 85, target: 80, gap: 0 },\n   276→        runtimeResult: { met: true, current: 65, target: 60, gap: 0 },\n   277→        gapSummary: [],\n   278→      },\n   279→    });\n   280→\n   281→    await runGateCmd([]);\n   282→\n   283→    expect(ok).toHaveBeenCalledWith(expect.stringContaining('Runtime'));\n   284→    expect(ok).toHaveBeenCalledWith(expect.stringContaining('65%'));\n   285→  });\n   286→\n   287→  it('prints runtime fail in text mode when runtime fails', async () => {\n   288→    vi.mocked(checkObservabilityCoverageGate).mockReturnValue({\n   289→      success: true,\n   290→      data: {\n   291→        passed: false,\n   292→        staticResult: { met: true, current: 85, target: 80, gap: 0 },\n   293→        runtimeResult: { met: false, current: 50, target: 60, gap: 10 },\n   294→        gapSummary: [],\n   295→      },\n   296→    });\n   297→\n   298→    await runGateCmd([]);\n   299→\n   300→    expect(fail).toHaveBeenCalledWith(expect.stringContaining('Runtime'));\n   301→    expect(fail).toHaveBeenCalledWith(expect.stringContaining('50%'));\n   302→  });\n   303→});\n   304→"}]},"parent_tool_use_id":"toolu_01L7x1Zkv5Yv1DsfgSndzqDQ","session_id":"f7a66acd-0cc1-40de-a592-d59e75273c0b","uuid":"1e720236-ceda-4d95-8b3b-4c36c35f614d","timestamp":"2026-03-20T06:00:23.958Z"}
