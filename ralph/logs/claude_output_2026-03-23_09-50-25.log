{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017XLtPCcw1pUSXaVZ7D6j5J","type":"tool_result","content":"     1→import { execSync } from 'node:child_process';\n     2→import { existsSync, readFileSync } from 'node:fs';\n     3→import { join } from 'node:path';\n     4→import { ok, fail as failOut, info, warn } from './output.js';\n     5→import { readStateWithBody, writeState } from './state.js';\n     6→import { detectStack } from './stack-detect.js';\n     7→\n     8→// ─── Types ───────────────────────────────────────────────────────────────────\n     9→\n    10→export interface CoverageToolInfo {\n    11→  tool: 'c8' | 'coverage.py' | 'cargo-tarpaulin' | 'unknown';\n    12→  runCommand: string;\n    13→  reportFormat: string;\n    14→}\n    15→\n    16→export interface CoverageResult {\n    17→  success: boolean;\n    18→  testsPassed: boolean;\n    19→  passCount: number;\n    20→  failCount: number;\n    21→  coveragePercent: number;\n    22→  rawOutput: string;\n    23→}\n    24→\n    25→export interface CoverageEvaluation {\n    26→  met: boolean;\n    27→  target: number;\n    28→  actual: number;\n    29→  delta: number | null;\n    30→  baseline: number | null;\n    31→}\n    32→\n    33→// ─── Coverage Tool Detection (Task 1) ────────────────────────────────────────\n    34→\n    35→export function detectCoverageTool(dir?: string): CoverageToolInfo {\n    36→  const baseDir = dir ?? process.cwd();\n    37→\n    38→  // Check state file hint first\n    39→  const stateHint = getStateToolHint(baseDir);\n    40→\n    41→  const stack = detectStack(baseDir);\n    42→\n    43→  if (stack === 'nodejs') {\n    44→    return detectNodeCoverageTool(baseDir, stateHint);\n    45→  }\n    46→\n    47→  if (stack === 'python') {\n    48→    return detectPythonCoverageTool(baseDir);\n    49→  }\n    50→\n    51→  if (stack === 'rust') {\n    52→    return {\n    53→      tool: 'cargo-tarpaulin',\n    54→      runCommand: 'cargo tarpaulin --out json',\n    55→      reportFormat: 'tarpaulin-json',\n    56→    };\n    57→  }\n    58→\n    59→  warn('No recognized stack detected — cannot determine coverage tool');\n    60→  return { tool: 'unknown', runCommand: '', reportFormat: '' };\n    61→}\n    62→\n    63→function getStateToolHint(dir: string): string | null {\n    64→  try {\n    65→    const { state } = readStateWithBody(dir);\n    66→    return state.coverage.tool || null;\n    67→  } catch {\n    68→    return null;\n    69→  }\n    70→}\n    71→\n    72→function detectNodeCoverageTool(dir: string, stateHint: string | null): CoverageToolInfo {\n    73→  // Check for Vitest config files\n    74→  const hasVitestConfig =\n    75→    existsSync(join(dir, 'vitest.config.ts')) ||\n    76→    existsSync(join(dir, 'vitest.config.js'));\n    77→\n    78→  // Check package.json devDependencies\n    79→  const pkgPath = join(dir, 'package.json');\n    80→  let hasVitestCoverageV8 = false;\n    81→  let hasVitestCoverageIstanbul = false;\n    82→  let hasC8 = false;\n    83→  let hasJest = false;\n    84→  let pkgScripts: Record<string, string> = {};\n    85→\n    86→  if (existsSync(pkgPath)) {\n    87→    try {\n    88→      const pkg = JSON.parse(readFileSync(pkgPath, 'utf-8')) as {\n    89→        devDependencies?: Record<string, string>;\n    90→        dependencies?: Record<string, string>;\n    91→        scripts?: Record<string, string>;\n    92→      };\n    93→      const allDeps = { ...(pkg.dependencies ?? {}), ...(pkg.devDependencies ?? {}) };\n    94→      hasVitestCoverageV8 = '@vitest/coverage-v8' in allDeps;\n    95→      hasVitestCoverageIstanbul = '@vitest/coverage-istanbul' in allDeps;\n    96→      hasC8 = 'c8' in allDeps;\n    97→      hasJest = 'jest' in allDeps;\n    98→      pkgScripts = pkg.scripts ?? {};\n    99→    } catch {\n   100→      // Malformed package.json — continue with defaults\n   101→    }\n   102→  }\n   103→\n   104→  // Determine tool and run command\n   105→  if (hasVitestConfig || hasVitestCoverageV8 || hasVitestCoverageIstanbul) {\n   106→    const runCommand = getNodeTestCommand(pkgScripts, 'vitest');\n   107→    return { tool: 'c8', runCommand, reportFormat: 'vitest-json' };\n   108→  }\n   109→\n   110→  if (hasC8) {\n   111→    const runCommand = getNodeTestCommand(pkgScripts, 'c8');\n   112→    return { tool: 'c8', runCommand, reportFormat: 'vitest-json' };\n   113→  }\n   114→\n   115→  if (hasJest) {\n   116→    return {\n   117→      tool: 'c8',\n   118→      runCommand: 'npx jest --coverage --coverageReporters=json-summary',\n   119→      reportFormat: 'jest-json',\n   120→    };\n   121→  }\n   122→\n   123→  // State hint says c8 but nothing found — re-detect failed\n   124→  if (stateHint === 'c8') {\n   125→    warn('State indicates c8 but no Vitest/c8 found in project — re-detecting');\n   126→  }\n   127→\n   128→  warn('No Node.js coverage tool detected');\n   129→  return { tool: 'unknown', runCommand: '', reportFormat: '' };\n   130→}\n   131→\n   132→function getNodeTestCommand(scripts: Record<string, string>, runner: string): string {\n   133→  // Prefer package.json scripts in order: test:coverage -> test:unit -> test\n   134→  if (scripts['test:coverage']) {\n   135→    return 'npm run test:coverage';\n   136→  }\n   137→  if (scripts['test:unit']) {\n   138→    // Need to add --coverage flag\n   139→    if (runner === 'vitest') {\n   140→      return 'npx vitest run --coverage';\n   141→    }\n   142→    return `npm run test:unit`;\n   143→  }\n   144→  if (scripts['test']) {\n   145→    if (runner === 'vitest') {\n   146→      return 'npx vitest run --coverage';\n   147→    }\n   148→    return 'npm test';\n   149→  }\n   150→  if (runner === 'vitest') {\n   151→    return 'npx vitest run --coverage';\n   152→  }\n   153→  return 'npm test';\n   154→}\n   155→\n   156→function detectPythonCoverageTool(dir: string): CoverageToolInfo {\n   157→  // Check requirements.txt\n   158→  const reqPath = join(dir, 'requirements.txt');\n   159→  if (existsSync(reqPath)) {\n   160→    try {\n   161→      const content = readFileSync(reqPath, 'utf-8');\n   162→      if (content.includes('pytest-cov') || content.includes('coverage')) {\n   163→        return {\n   164→          tool: 'coverage.py',\n   165→          runCommand: 'coverage run -m pytest && coverage json',\n   166→          reportFormat: 'coverage-py-json',\n   167→        };\n   168→      }\n   169→    } catch {\n   170→      // Continue checking\n   171→    }\n   172→  }\n   173→\n   174→  // Check pyproject.toml\n   175→  const pyprojectPath = join(dir, 'pyproject.toml');\n   176→  if (existsSync(pyprojectPath)) {\n   177→    try {\n   178→      const content = readFileSync(pyprojectPath, 'utf-8');\n   179→      if (content.includes('pytest-cov') || content.includes('coverage')) {\n   180→        return {\n   181→          tool: 'coverage.py',\n   182→          runCommand: 'coverage run -m pytest && coverage json',\n   183→          reportFormat: 'coverage-py-json',\n   184→        };\n   185→      }\n   186→    } catch {\n   187→      // Continue checking\n   188→    }\n   189→  }\n   190→\n   191→  warn('No Python coverage tool detected');\n   192→  return { tool: 'unknown', runCommand: '', reportFormat: '' };\n   193→}\n   194→\n   195→export function getTestCommand(dir?: string): string {\n   196→  const toolInfo = detectCoverageTool(dir);\n   197→  return toolInfo.runCommand;\n   198→}\n   199→\n   200→// ─── Coverage Execution and Parsing (Task 2) ─────────────────────────────────\n   201→\n   202→export function runCoverage(dir?: string): CoverageResult {\n   203→  const baseDir = dir ?? process.cwd();\n   204→  const toolInfo = detectCoverageTool(baseDir);\n   205→\n   206→  if (toolInfo.tool === 'unknown' || !toolInfo.runCommand) {\n   207→    return {\n   208→      success: false,\n   209→      testsPassed: false,\n   210→      passCount: 0,\n   211→      failCount: 0,\n   212→      coveragePercent: 0,\n   213→      rawOutput: 'No coverage tool detected. Ensure your project has a test runner configured.',\n   214→    };\n   215→  }\n   216→\n   217→  let rawOutput = '';\n   218→  let testsPassed = true;\n   219→\n   220→  try {\n   221→    rawOutput = execSync(toolInfo.runCommand, {\n   222→      cwd: baseDir,\n   223→      encoding: 'utf-8',\n   224→      stdio: ['pipe', 'pipe', 'pipe'],\n   225→      timeout: 300_000, // 5 minute timeout\n   226→    });\n   227→  } catch (err: unknown) {\n   228→    const execError = err as { status?: number; stdout?: string; stderr?: string };\n   229→    testsPassed = false;\n   230→    rawOutput = (execError.stdout ?? '') + (execError.stderr ?? '');\n   231→\n   232→    if (!rawOutput) {\n   233→      return {\n   234→        success: false,\n   235→        testsPassed: false,\n   236→        passCount: 0,\n   237→        failCount: 0,\n   238→        coveragePercent: 0,\n   239→        rawOutput: 'Test command failed with no output',\n   240→      };\n   241→    }\n   242→  }\n   243→\n   244→  // Parse test counts from output\n   245→  const { passCount, failCount } = parseTestCounts(rawOutput);\n   246→\n   247→  // If we detected failures from output but exit code was 0, trust the output\n   248→  if (failCount > 0) {\n   249→    testsPassed = false;\n   250→  }\n   251→\n   252→  // Parse coverage from report file\n   253→  const coveragePercent = parseCoverageReport(baseDir, toolInfo.reportFormat);\n   254→\n   255→  return {\n   256→    success: true,\n   257→    testsPassed,\n   258→    passCount,\n   259→    failCount,\n   260→    coveragePercent,\n   261→    rawOutput,\n   262→  };\n   263→}\n   264→\n   265→export function parseCoverageReport(dir: string, format: string): number {\n   266→  if (format === 'vitest-json' || format === 'jest-json') {\n   267→    return parseVitestCoverage(dir);\n   268→  }\n   269→  if (format === 'coverage-py-json') {\n   270→    return parsePythonCoverage(dir);\n   271→  }\n   272→  return 0;\n   273→}\n   274→\n   275→function parseVitestCoverage(dir: string): number {\n   276→  const reportPath = findCoverageSummary(dir);\n   277→  if (!reportPath) {\n   278→    warn('Coverage report not found at coverage/coverage-summary.json');\n   279→    return 0;\n   280→  }\n   281→\n   282→  try {\n   283→    const report = JSON.parse(readFileSync(reportPath, 'utf-8')) as {\n   284→      total?: {\n   285→        statements?: { pct?: number };\n   286→        lines?: { pct?: number };\n   287→        branches?: { pct?: number };\n   288→        functions?: { pct?: number };\n   289→      };\n   290→    };\n   291→    return report.total?.statements?.pct ?? 0;\n   292→  } catch {\n   293→    warn('Failed to parse coverage report');\n   294→    return 0;\n   295→  }\n   296→}\n   297→\n   298→function parsePythonCoverage(dir: string): number {\n   299→  const reportPath = join(dir, 'coverage.json');\n   300→  if (!existsSync(reportPath)) {\n   301→    warn('Coverage report not found at coverage.json');\n   302→    return 0;\n   303→  }\n   304→\n   305→  try {\n   306→    const report = JSON.parse(readFileSync(reportPath, 'utf-8')) as {\n   307→      totals?: { percent_covered?: number };\n   308→    };\n   309→    return report.totals?.percent_covered ?? 0;\n   310→  } catch {\n   311→    warn('Failed to parse coverage report');\n   312→    return 0;\n   313→  }\n   314→}\n   315→\n   316→export function parseTestCounts(output: string): { passCount: number; failCount: number } {\n   317→  // Vitest format: \"Tests  12 passed | 3 failed\"\n   318→  const vitestMatch = /Tests\\s+(\\d+)\\s+passed(?:\\s*\\|\\s*(\\d+)\\s+failed)?/i.exec(output);\n   319→  if (vitestMatch) {\n   320→    return {\n   321→      passCount: parseInt(vitestMatch[1], 10),\n   322→      failCount: vitestMatch[2] ? parseInt(vitestMatch[2], 10) : 0,\n   323→    };\n   324→  }\n   325→\n   326→  // Jest format: \"Tests:  3 failed, 12 passed, 15 total\"\n   327→  const jestMatch = /Tests:\\s*(?:(\\d+)\\s+failed,\\s*)?(\\d+)\\s+passed/i.exec(output);\n   328→  if (jestMatch) {\n   329→    return {\n   330→      passCount: parseInt(jestMatch[2], 10),\n   331→      failCount: jestMatch[1] ? parseInt(jestMatch[1], 10) : 0,\n   332→    };\n   333→  }\n   334→\n   335→  // pytest format: \"12 passed, 3 failed\"\n   336→  const pytestMatch = /(\\d+)\\s+passed(?:,\\s*(\\d+)\\s+failed)?/i.exec(output);\n   337→  if (pytestMatch) {\n   338→    return {\n   339→      passCount: parseInt(pytestMatch[1], 10),\n   340→      failCount: pytestMatch[2] ? parseInt(pytestMatch[2], 10) : 0,\n   341→    };\n   342→  }\n   343→\n   344→  return { passCount: 0, failCount: 0 };\n   345→}\n   346→\n   347→// ─── Check-only mode: read last coverage report without running tests ────────\n   348→\n   349→export function checkOnlyCoverage(dir?: string): CoverageResult {\n   350→  const baseDir = dir ?? process.cwd();\n   351→  const toolInfo = detectCoverageTool(baseDir);\n   352→\n   353→  if (toolInfo.tool === 'unknown') {\n   354→    return {\n   355→      success: false,\n   356→      testsPassed: false,\n   357→      passCount: 0,\n   358→      failCount: 0,\n   359→      coveragePercent: 0,\n   360→      rawOutput: 'No coverage tool detected',\n   361→    };\n   362→  }\n   363→\n   364→  const coveragePercent = parseCoverageReport(baseDir, toolInfo.reportFormat);\n   365→\n   366→  // Preserve existing tests_passed flag from state rather than blindly assuming true.\n   367→  // Check-only mode doesn't run tests, so it should not overwrite the flag.\n   368→  let testsPassed = true;\n   369→  try {\n   370→    const { state } = readStateWithBody(baseDir);\n   371→    testsPassed = state.session_flags.tests_passed;\n   372→  } catch {\n   373→    // No state file — default to true (optimistic for first-run check-only)\n   374→  }\n   375→\n   376→  return {\n   377→    success: true,\n   378→    testsPassed,\n   379→    passCount: 0,\n   380→    failCount: 0,\n   381→    coveragePercent,\n   382→    rawOutput: 'Check-only mode — read existing coverage report',\n   383→  };\n   384→}\n   385→\n   386→// ─── Coverage Evaluation and State Updates (Task 3) ──────────────────────────\n   387→\n   388→export function evaluateCoverage(result: CoverageResult, dir?: string): CoverageEvaluation {\n   389→  const baseDir = dir ?? process.cwd();\n   390→\n   391→  let target = 90;\n   392→  let baseline: number | null = null;\n   393→\n   394→  try {\n   395→    const { state } = readStateWithBody(baseDir);\n   396→    target = state.coverage.target ?? 90;\n   397→    baseline = state.coverage.baseline;\n   398→  } catch {\n   399→    // No state file — use defaults\n   400→  }\n   401→\n   402→  const actual = result.coveragePercent;\n   403→  const met = actual >= target;\n   404→\n   405→  // If baseline is null (first run), set it to current\n   406→  const effectiveBaseline = baseline ?? actual;\n   407→  const delta = baseline !== null ? actual - baseline : null;\n   408→\n   409→  return {\n   410→    met,\n   411→    target,\n   412→    actual,\n   413→    delta,\n   414→    baseline: effectiveBaseline,\n   415→  };\n   416→}\n   417→\n   418→export function updateCoverageState(\n   419→  result: CoverageResult,\n   420→  evaluation: CoverageEvaluation,\n   421→  dir?: string,\n   422→): void {\n   423→  const baseDir = dir ?? process.cwd();\n   424→  const { state, body } = readStateWithBody(baseDir);\n   425→\n   426→  state.session_flags.tests_passed = result.testsPassed;\n   427→  state.session_flags.coverage_met = evaluation.met;\n   428→  state.coverage.current = evaluation.actual;\n   429→\n   430→  // Set baseline on first run (when it was null)\n   431→  if (state.coverage.baseline === null) {\n   432→    state.coverage.baseline = evaluation.actual;\n   433→  }\n   434→\n   435→  writeState(state, baseDir, body);\n   436→}\n   437→\n   438→// ─── Per-file Coverage Floor Check ───────────────────────────────────────────\n   439→\n   440→export interface FileCoverageEntry {\n   441→  file: string;\n   442→  statements: number;\n   443→  branches: number;\n   444→  functions: number;\n   445→  lines: number;\n   446→}\n   447→\n   448→export interface PerFileCoverageResult {\n   449→  floor: number;\n   450→  violations: FileCoverageEntry[];\n   451→  totalFiles: number;\n   452→}\n   453→\n   454→/**\n   455→ * Checks per-file coverage against a minimum floor.\n   456→ * Reads coverage-summary.json and returns any files below the threshold.\n   457→ */\n   458→export function checkPerFileCoverage(floor: number, dir?: string): PerFileCoverageResult {\n   459→  const baseDir = dir ?? process.cwd();\n   460→  const reportPath = findCoverageSummary(baseDir);\n   461→\n   462→  if (!reportPath) {\n   463→    return { floor, violations: [], totalFiles: 0 };\n   464→  }\n   465→\n   466→  let report: Record<string, { statements?: { pct?: number }; branches?: { pct?: number }; functions?: { pct?: number }; lines?: { pct?: number } }>;\n   467→  try {\n   468→    report = JSON.parse(readFileSync(reportPath, 'utf-8')) as typeof report;\n   469→  } catch {\n   470→    warn('Failed to parse coverage-summary.json');\n   471→    return { floor, violations: [], totalFiles: 0 };\n   472→  }\n   473→\n   474→  const violations: FileCoverageEntry[] = [];\n   475→  let totalFiles = 0;\n   476→\n   477→  for (const [key, data] of Object.entries(report)) {\n   478→    if (key === 'total') continue;\n   479→    totalFiles++;\n   480→\n   481→    const stmts = data.statements?.pct ?? 0;\n   482→    const branches = data.branches?.pct ?? 0;\n   483→    const funcs = data.functions?.pct ?? 0;\n   484→    const lines = data.lines?.pct ?? 0;\n   485→\n   486→    if (stmts < floor) {\n   487→      // Extract relative path from absolute\n   488→      const relative = key.startsWith(baseDir)\n   489→        ? key.slice(baseDir.length + 1)\n   490→        : key;\n   491→\n   492→      violations.push({\n   493→        file: relative,\n   494→        statements: stmts,\n   495→        branches,\n   496→        functions: funcs,\n   497→        lines,\n   498→      });\n   499→    }\n   500→  }\n   501→\n   502→  // Sort worst first\n   503→  violations.sort((a, b) => a.statements - b.statements);\n   504→\n   505→  return { floor, violations, totalFiles };\n   506→}\n   507→\n   508→/**\n   509→ * Find coverage-summary.json — it may be at coverage/ or src/coverage/\n   510→ * depending on the vitest root config.\n   511→ */\n   512→function findCoverageSummary(dir: string): string | null {\n   513→  const candidates = [\n   514→    join(dir, 'coverage', 'coverage-summary.json'),\n   515→    join(dir, 'src', 'coverage', 'coverage-summary.json'),\n   516→  ];\n   517→  for (const p of candidates) {\n   518→    if (existsSync(p)) return p;\n   519→  }\n   520→  return null;\n   521→}\n   522→\n   523→export function formatCoverageOutput(evaluation: CoverageEvaluation): string[] {\n   524→  const lines: string[] = [];\n   525→\n   526→  if (evaluation.met) {\n   527→    lines.push(`[OK] Coverage: ${evaluation.actual}%`);\n   528→  } else {\n   529→    lines.push(`[FAIL] Coverage: ${evaluation.actual}% (target: ${evaluation.target}%)`);\n   530→  }\n   531→\n   532→  if (evaluation.delta !== null && evaluation.baseline !== null) {\n   533→    const sign = evaluation.delta >= 0 ? '+' : '';\n   534→    const before = evaluation.actual - evaluation.delta;\n   535→    lines.push(\n   536→      `[INFO] Coverage delta: ${sign}${evaluation.delta}% (${before}% -> ${evaluation.actual}%)`,\n   537→    );\n   538→  }\n   539→\n   540→  return lines;\n   541→}\n   542→\n   543→export function printCoverageOutput(\n   544→  result: CoverageResult,\n   545→  evaluation: CoverageEvaluation,\n   546→): void {\n   547→  // Print test results\n   548→  if (result.testsPassed) {\n   549→    ok(`Tests passed: ${result.passCount} passed`);\n   550→  } else {\n   551→    failOut(`Tests failed: ${result.passCount} passed, ${result.failCount} failed`);\n   552→  }\n   553→\n   554→  // Print coverage evaluation\n   555→  if (evaluation.met) {\n   556→    ok(`Coverage: ${evaluation.actual}%`);\n   557→  } else {\n   558→    failOut(`Coverage: ${evaluation.actual}% (target: ${evaluation.target}%)`);\n   559→  }\n   560→\n   561→  // Print delta if available\n   562→  if (evaluation.delta !== null && evaluation.baseline !== null) {\n   563→    const sign = evaluation.delta >= 0 ? '+' : '';\n   564→    const before = evaluation.actual - evaluation.delta;\n   565→    info(`Coverage delta: ${sign}${evaluation.delta}% (${before}% -> ${evaluation.actual}%)`);\n   566→  }\n   567→}\n   568→"}]},"parent_tool_use_id":"toolu_01L8FFCpVh7KBCcfMN3fKhC4","session_id":"900ad046-8ed4-4678-b2b2-9fd66fbde286","uuid":"bdb1bbed-bfbe-4b3f-8a05-16a40dd849e5","timestamp":"2026-03-23T05:51:55.934Z"}
