[\n   563→      '# Story',\n   564→      '',\n   565→      '## Acceptance Criteria',\n   566→      '',\n   567→      '1. Given the CLI is built, Then codeharness --version shows the version',\n   568→      '2. Given a sprint, Then it invokes /create-story via Agent tool for backlog stories',\n   569→    ].join('\\n'));\n   570→\n   571→    const acs = parseStoryACs(storyPath);\n   572→    expect(acs).toHaveLength(2);\n   573→    expect(acs[0].strategy).toBe('docker');\n   574→    expect(acs[1].strategy).toBe('docker');\n   575→  });\n   576→\n   577→  // ─── AC #6: classifyStrategy never refuses based on project type ──────\n   578→\n   579→  it('returns docker for empty description', () => {\n   580→    expect(classifyStrategy('')).toBe('docker');\n   581→  });\n   582→\n   583→  it('returns docker for unusual project keywords', () => {\n   584→    expect(classifyStrategy('Rust cargo build and run tests')).toBe('docker');\n   585→    expect(classifyStrategy('Go binary compilation with modules')).toBe('docker');\n   586→    expect(classifyStrategy('Java Maven Spring Boot application')).toBe('docker');\n   587→    expect(classifyStrategy('Ruby on Rails web server')).toBe('docker');\n   588→  });\n   589→\n   590→  it('never returns escalate for project-type descriptions', () => {\n   591→    const projectDescriptions = [\n   592→      'CLI project with Node.js',\n   593→      'Python library with pip install',\n   594→      'Claude Code plugin with slash commands',\n   595→      'Unknown project with no package.json',\n   596→      'Generic container with basic tools',\n   597→      'Web application with React frontend',\n   598→      'API server with Express',\n   599→      'Library published on npm',\n   600→    ];\n   601→    for (const desc of projectDescriptions) {\n   602→      expect(classifyStrategy(desc)).toBe('docker');\n   603→    }\n   604→  });\n   605→\n   606→  it('only escalates for genuine escalation keywords', () => {\n   607→    expect(classifyStra