.exitCode).toBe(1);\n393\t    });\n394\t  });\n395\t\n396\t  describe('run command registration', () => {\n397\t    it('registers the run command with correct options', async () => {\n398\t      const { registerRunCommand } = await import('../run.js');\n399\t      const program = new Command();\n400\t      program.option('--json', 'JSON output');\n401\t      registerRunCommand(program);\n402\t\n403\t      const runCmd = program.commands.find(c => c.name() === 'run');\n404\t      expect(runCmd).toBeDefined();\n405\t      expect(runCmd!.description()).toBe('Execute the autonomous coding loop');\n406\t\n407\t      const optionNames = runCmd!.options.map(o => o.long);\n408\t      expect(optionNames).toContain('--max-iterations');\n409\t      expect(optionNames).toContain('--timeout');\n410\t      expect(optionNames).toContain('--quiet');\n411\t      expect(optionNames).toContain('--max-story-retries');\n412\t      expect(optionNames).toContain('--resume');\n413\t    });\n414\t\n415\t    it('--max-story-retries defaults to 10', async () => {\n416\t      const { registerRunCommand } = await import('../run.js');\n417\t      const program = new Command();\n418\t      program.option('--json', 'JSON output');\n419\t      registerRunCommand(program);\n420\t\n421\t      const runCmd = program.commands.find(c => c.name() === 'run');\n422\t      const retryOpt = runCmd!.options.find(o => o.long === '--max-story-retries');\n423\t      expect(retryOpt!.defaultValue).toBe('10');\n424\t    });\n425\t  });\n426\t\n427\t  describe('source code verification', () => {\n428\t    it('run.ts does not import spawn from node:child_process', () => {\n429\t      const runSource = origReadFileSync(\n430\t        join(process.cwd(), 'src', 'commands', 'run.ts'),\n431\t        'utf-8',\n432\t      );\n433\t      expect(runSource).not.toContain(\"from 'node:child_process'\");\n434\t    });\n435\t\n436\t    it('run.ts does not import buildSpawnArgs or resolveRalphPath', () => {\n437\t      const run