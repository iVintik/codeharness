e);\n   446→\n   447→    const result = checkCoverageTarget('/project');\n   448→    expect(result.success).toBe(true);\n   449→    if (result.success) {\n   450→      expect(result.data.target).toBe(80);\n   451→      expect(result.data.met).toBe(false);\n   452→      expect(result.data.gap).toBe(80);\n   453→    }\n   454→  });\n   455→\n   456→  it('uses explicit target parameter over state target', () => {\n   457→    const stateJson = makeStateWithObservability({\n   458→      static: {\n   459→        coveragePercent: 75,\n   460→        lastScanTimestamp: '2026-03-19T14:30:00.000Z',\n   461→        history: [],\n   462→      },\n   463→      targets: { staticTarget: 80 },\n   464→    });\n   465→\n   466→    mockExistsSync.mockReturnValue(true);\n   467→    mockReadFileSync.mockReturnValue(stateJson);\n   468→\n   469→    const result = checkCoverageTarget('/project', 70);\n   470→    expect(result.success).toBe(true);\n   471→    if (result.success) {\n   472→      expect(result.data.met).toBe(true);\n   473→      expect(result.data.target).toBe(70);\n   474→      expect(result.data.gap).toBe(0);\n   475→    }\n   476→  });\n   477→\n   478→  it('returns fail when state read fails', () => {\n   479→    mockExistsSync.mockReturnValue(true);\n   480→    mockReadFileSync.mockImplementation(() => {\n   481→      throw new Error('EACCES');\n   482→    });\n   483→\n   484→    const result = checkCoverageTarget('/project');\n   485→    expect(result.success).toBe(false);\n   486→    if (!result.success) {\n   487→      expect(result.error).toContain('Failed to read sprint-state.json');\n   488→    }\n   489→  });\n   490→\n   491→  it('returns met: true when coverage equals target exactly', () => {\n   492→    const stateJson = makeStateWithObservability({\n   493→      static: {\n   494→        coveragePercent: 80,\n   495→        lastScanTimestamp: '2026-03-19T14:30:00.000Z',\n   496→        history: [],\n   497→      },\n   498→      targets: { staticTarget: 80 },\n   499→    });\n   500→\n   501→    mockExistsSync.mockReturnValue(true);\n   502→    mockReadFileSync.mockReturnValue(stateJson);\n   503→\n   504→    const result = checkCoverageTarget('/project');\n   505→    expect(result.success).toBe(true);\n   506→    if (result.success) {\n   507→      expect(result.data.met).toBe(true);\n   508→      expect(result.data.gap).toBe(0);\n   509→    }\n   510→  });\n   511→});\n   512→\n   513→// ============================================================\n   514→// Input validation\n   515→// ============================================================\n   516→\n   517→describe('input validation', () => {\n   518→  it('saveCoverageResult rejects empty projectDir', () => {\n   519→    const result = saveCoverageResult('', makeAnalyzerResult(75));\n   520→    expect(result.success).toBe(false);\n   521→    if (!result.success) {\n   522→      expect(result.error).toContain('projectDir is required');\n   523→    }\n   524→  });\n   525→\n   526→  it('readCoverageState rejects empty projectDir', () => {\n   527→    const result = readCoverageState('');\n   528→    expect(result.success).toBe(false);\n   529→    if (!result.success) {\n   530→      expect(result.error).toContain('projectDir is required');\n   531→    }\n   532→  });\n   533→\n   534→  it('getCoverageTrend rejects empty projectDir', () => {\n   535→    const result = getCoverageTrend('');\n   536→    expect(result.success).toBe(false);\n   537→    if (!result.success) {\n   538→      expect(result.error).toContain('projectDir is required');\n   539→    }\n   540→  });\n   541→\n   542→  it('checkCoverageTarget rejects empty projectDir', () => {\n   543→    const result = checkCoverageTarget('');\n   544→    expect(result.success).toBe(false);\n   545→    if (!result.success) {\n   546→      expect(result.error).toContain('projectDir is required');\n   547→    }\n   548→  });\n   549→});\n   550→\n   551→// ============================================================\n   552→// extractCoverageState edge cases (branch coverage)\n   553→// ============================================================\n   554→\n   555→describe('extractCoverageState edge cases', () => {\n   556→  it('handles observability section with non-number coveragePercent', () => {\n   557→    mockExistsSync.mockReturnValue(true);\n   558→    mockReadFileSync.mockReturnValue(\n   559→      JSON.stringify({\n   560→        observability: {\n   561→          static: { coveragePercent: 'not-a-number', lastScanTimestamp: 123 },\n   562→        },\n   563→      }),\n   564→    );\n   565→\n   566→    const result = readCoverageState('/project');\n   567→    expect(result.success).toBe(true);\n   568→    if (result.success) {\n   569→      expect(result.data.static.coveragePercent).toBe(0);\n   570→      expect(result.data.static.lastScanTimestamp).toBe('');\n   571→    }\n   572→  });\n   573→\n   574→  it('filters out invalid history entries', () => {\n   575→    mockExistsSync.mockReturnValue(true);\n   576→    mockReadFileSync.mockReturnValue(\n   577→      JSON.stringify({\n   578→        observability: {\n   579→          static: {\n   580→            coveragePercent: 75,\n   581→            lastScanTimestamp: '2026-03-19T14:30:00.000Z',\n   582→            history: [\n   583→              { coveragePercent: 70, timestamp: '2026-03-18T10:00:00.000Z' },\n   584→              { coveragePercent: 'bad', timestamp: '2026-03-19T14:30:00.000Z' },\n   585→              null,\n   586→              'string-entry',\n   587→              { coveragePercent: 80 },\n   588→              { coveragePercent: 75, timestamp: '2026-03-19T14:30:00.000Z' },\n   589→            ],\n   590→          },\n   591→          targets: { staticTarget: 80 },\n   592→        },\n   593→      }),\n   594→    );\n   595→\n   596→    const result = readCoverageState('/project');\n   597→    expect(result.success).toBe(true);\n   598→    if (result.success) {\n   599→      // Only 2 valid entries should remain\n   600→      expect(result.data.static.history).toHaveLength(2);\n   601→      expect(result.data.static.history[0].coveragePercent).toBe(70);\n   602→      expect(result.data.static.history[1].coveragePercent).toBe(75);\n   603→    }\n   604→  });\n   605→\n   606→  it('handles observability with non-number staticTarget', () => {\n   607→    mockExistsSync.mockReturnValue(true);\n   608→    mockReadFileSync.mockReturnValue(\n   609→      JSON.stringify({\n   610→        observability: {\n   611→          static: {\n   612→            coveragePercent: 75,\n   613→            lastScanTimestamp: '2026-03-19T14:30:00.000Z',\n   614→            history: [],\n   615→          },\n   616→          targets: { staticTarget: 'not-a-number' },\n   617→        },\n   618→      }),\n   619→    );\n   620→\n   621→    const result = readCoverageState('/project');\n   622→    expect(result.success).toBe(true);\n   623→    if (result.success) {\n   624→      expect(result.data.targets.staticTarget).toBe(80);\n   625→    }\n   626→  });\n   627→});\n   628→\n   629→// ============================================================\n   630→// History truncation\n   631→// ============================================================\n   632→\n   633→describe('history truncation', () => {\n   634→  it('truncates history to MAX_HISTORY_ENTRIES when exceeding limit', () => {\n   635→    const longHistory = Array.from({ length: 100 }, (_, i) => ({\n   636→      coveragePercent: i,\n   637→      timestamp: `2026-03-19T14:30:00.${String(i).padStart(3, '0')}Z`,\n   638→    }));\n   639→\n   640→    const existingState = JSON.stringify({\n   641→      version: 1,\n   642→      observability: {\n   643→        static: {\n   644→          coveragePercent: 99,\n   645→          lastScanTimestamp: '2026-03-19T00:00:00.000Z',\n   646→          history: longHistory,\n   647→        },\n   648→        targets: { staticTarget: 80 },\n   649→      },\n   650→    });\n   651→\n   652→    mockExistsSync.mockReturnValue(true);\n   653→    mockReadFileSync.mockReturnValue(existingState);\n   654→\n   655→    const result = saveCoverageResult('/project', makeAnalyzerResult(100));\n   656→    expect(result.success).toBe(true);\n   657→\n   658→    const writtenData = JSON.parse(\n   659→      mockWriteFileSync.mock.calls[0][1] as string,\n   660→    );\n   661→    // 100 existing + 1 new = 101, truncated to 100\n   662→    expect(writtenData.observability.static.history).toHaveLength(100);\n   663→    // First entry should be dropped (index 0), so first is index 1\n   664→    expect(writtenData.observability.static.history[0].coveragePercent).toBe(1);\n   665→    // Last entry is the newly appended one\n   666→    expect(\n   667→      writtenData.observability.static.history[99].coveragePercent,\n   668→    ).toBe(100);\n   669→  });\n   670→});\n   671→\n   672→// ============================================================\n   673→// Atomic write safety\n   674→// ============================================================\n   675→\n   676→describe('atomic write safety', () => {\n   677→  it('partial write does not corrupt existing state when renameSync fails', () => {\n   678→    mockExistsSync.mockReturnValue(true);\n   679→    mockReadFileSync.mockReturnValue(\n   680→      JSON.stringify({ version: 1, sprint: {} }),\n   681→    );\n   682→    mockRenameSync.mockImplementation(() => {\n   683→      throw new Error('EXDEV: cross-device link');\n   684→    });\n   685→\n   686→    const result = saveCoverageResult('/project', makeAnalyzerResult(75));\n   687→    expect(result.success).toBe(false);\n   688→\n   689→    // The original file should NOT have been directly written to\n   690→    // writeFileSync writes to tmp file, not the main file\n   691→    const writeCall = mockWriteFileSync.mock.calls[0];\n   692→    expect(writeCall[0]).toContain('.sprint-state.json.tmp');\n   693→  });\n   694→});\n   695→"}]},"parent_tool_use_id":"toolu_01AP