nc(getStatePath(testDir), 'utf-8');\n   181→    expect(final).toContain('initialized: true');\n   182→    expect(final).toContain('# My Custom Notes');\n   183→  });\n   184→\n   185→  it('recovers from corrupted YAML', () => {\n   186→    const claudeDir = join(testDir, '.claude');\n   187→    mkdirSync(claudeDir, { recursive: true });\n   188→    writeFileSync(join(claudeDir, 'codeharness.local.md'), '---\\n{invalid yaml: [[\\n---\\n', 'utf-8');\n   189→\n   190→    const consoleSpy = vi.spyOn(console, 'log');\n   191→    const state = readState(testDir);\n   192→    expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('State file corrupted'));\n   193→    expect(state.harness_version).toBe('0.1.0');\n   194→    consoleSpy.mockRestore();\n   195→  });\n   196→\n   197→  it('recovers from file with no frontmatter delimiters', () => {\n   198→    const claudeDir = join(testDir, '.claude');\n   199→    mkdirSync(claudeDir, { recursive: true });\n   200→    writeFileSync(join(claudeDir, 'codeharness.local.md'), 'just some text', 'utf-8');\n   201→\n   202→    const consoleSpy = vi.spyOn(console, 'log');\n   203→    const state = readState(testDir);\n   204→    expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('State file corrupted'));\n   205→    expect(state.initialized).toBe(false);\n   206→    consoleSpy.mockRestore();\n   207→  });\n   208→\n   209→  it('recovers when YAML parses to non-object', () => {\n   210→    const claudeDir = join(testDir, '.claude');\n   211→    mkdirSync(claudeDir, { recursive: true });\n   212→    writeFileSync(join(claudeDir, 'codeharness.local.md'), '---\\njust a string\\n---\\n', 'utf-8');\n   213→\n   214→    const consoleSpy = vi.spyOn(console, 'log');\n   215→    const state = readState(testDir);\n   216→    expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('State file corrupted'));\n   217→    consoleSpy.mockRestore();\n   218→  });\n   219→\n   220→  it('recovers when YAML is valid but does 