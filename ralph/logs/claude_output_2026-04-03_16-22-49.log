ion(agent);\n532\t\n533\t      expect(result.name).toBe('test-agent');\n534\t      expect(result.model).toBe('claude-sonnet-4-20250514');\n535\t      expect(result.bare).toBe(true);\n536\t      expect(result.instructions).toContain('You are A test agent for unit tests');\n537\t      expect(result.instructions).toContain('Communication style: Direct and clear');\n538\t      expect(result.instructions).toContain('Principles:');\n539\t      expect(result.instructions).toContain('- Be thorough');\n540\t      expect(result.instructions).toContain('- Be honest');\n541\t    });\n542\t\n543\t    it('includes prompt_patches.append in instructions (AC #6)', () => {\n544\t      const agent = makeMinimalAgent({\n545\t        prompt_patches: { append: 'Run npm build first.' },\n546\t      });\n547\t      const result = compileSubagentDefinition(agent);\n548\t      expect(result.instructions).toContain('Run npm build first.');\n549\t    });\n550\t\n551\t    it('preserves disallowedTools for evaluator (AC #7)', () => {\n552\t      const agent = loadEmbeddedAgent('evaluator');\n553\t      const result = compileSubagentDefinition(agent);\n554\t      expect(result.disallowedTools).toContain('Edit');\n555\t      expect(result.disallowedTools).toContain('Write');\n556\t      expect(result.disallowedTools).toHaveLength(2);\n557\t    });\n558\t\n559\t    it('returns empty disallowedTools when not present', () => {\n560\t      const agent = makeMinimalAgent();\n561\t      const result = compileSubagentDefinition(agent);\n562\t      expect(result.disallowedTools).toEqual([]);\n563\t    });\n564\t\n565\t    it('sets bare: true always (AD2)', () => {\n566\t      const agent = makeMinimalAgent();\n567\t      const result = compileSubagentDefinition(agent);\n568\t      expect(result.bare).toBe(true);\n569\t    });\n570\t\n571\t    it('sets default model', () => {\n572\t      const agent = makeMinimalAgent();\n573\t      const result = compileSubagentDefinition(agent);\n574\t      expect(result