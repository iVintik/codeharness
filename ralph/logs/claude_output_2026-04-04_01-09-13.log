ror',\n        durationMs: Date.now() - start,\n      };\n    }\n\n    // Validate branch name to prevent command injection via malicious branch names\n    if (!/^[a-zA-Z0-9_./-]+$/.test(branch)) {\n      return {\n        success: false,\n        reason: 'git-error',\n        durationMs: Date.now() - start,\n      };\n    }\n\n    const release = await mergeMutex.acquire();\n    try {\n      // Re-verify branch still exists after acquiring mutex (could be deleted while waiting)\n      const branchCheck = this.findBranchForEpic(epicId);\n      if (!branchCheck || branchCheck !== branch) {\n        return {\n          success: false,\n          reason: 'git-error',\n          durationMs: Date.now() - start,\n        };\n      }\n\n      // Verify main branch is clean before merge\n      const status = this.execGit('git status --porcelain');\n      if (status.length > 0) {\n        return {\n          success: false,\n          reason: 'git-error',\n          durationMs: Date.now() - start,\n        };\n      }\n\n      // Attempt merge or rebase\n      try {\n        if (strategy === 'rebase') {\n          this.execGit(`git rebase ${branch}`);\n        } else {\n          this.execGit(`git merge --no-ff ${branch}`);\n        }\n      } catch {"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":410,"cache_read_input_tokens":51196,"cache_creation":{"ephemeral_5m_input_tokens":410,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01C74KKbCgdZj2LDCG8nDBR2","session_id":"80ecde4e-3ccc-44de-925d-a2036bf845d1","uuid":"5858153c-bb57-41aa-8873-c0f3d3110576"}
