    expect(result.data.docker).toBeNull();\n   354→    }\n   355→  });\n   356→});\n   357→\n   358→describe('initProject — unexpected errors', () => {\n   359→  it('returns fail instead of throwing on unexpected error', async () => {\n   360→    // Force an unexpected error by making detectStack throw\n   361→    const stackDetect = await import('../../../lib/stack-detect.js');\n   362→    vi.mocked(stackDetect.detectStack).mockImplementation(() => { throw new Error('kaboom'); });\n   363→    writeFileSync(join(testDir, 'package.json'), '{}');\n   364→    const result = await initProject({\n   365→      projectDir: testDir,\n   366→      frontend: true,\n   367→      database: true,\n   368→      api: true,\n   369→      observability: false,\n   370→    });\n   371→    expect(result.success).toBe(false);\n   372→    if (!result.success) {\n   373→      expect(result.error).toContain('kaboom');\n   374→    }\n   375→  });\n   376→});\n   377→"}]},"parent_tool_use_id":"toolu_01GahX8iUoYR49K5t7MjQw49","session_id":"46c7b24e-5b3f-4eb1-bc5a-20f6a0336cfe","uuid":"97f2d794-9d2c-41fd-b12e-35a7e2bdcb05","timestamp":"2026-03-23T14:51:22.369Z"}
