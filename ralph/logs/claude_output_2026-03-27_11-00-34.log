{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GZ7itjzEhdWTUbFiE5T7KN","type":"tool_result","content":"     1→/**\n     2→ * Status formatters — human-readable and JSON formatting for status output.\n     3→ * Handles the full status display, docker check, and health check formatting.\n     4→ */\n     5→\n     6→import { ok, fail, info, jsonOutput } from '../../lib/output.js';\n     7→import { readState, StateFileNotFoundError } from '../../lib/state.js';\n     8→import { getStackHealth, getCollectorHealth, checkRemoteEndpoint } from '../../lib/docker/index.js';\n     9→import { listIssues, isBeadsInitialized } from '../../lib/beads.js';\n    10→import { getOnboardingProgress } from '../../lib/onboard-checks.js';\n    11→import { getStackDir, getComposeFilePath, getElkComposeFilePath } from '../../lib/stack-path.js';\n    12→import { generateReport } from '../sprint/index.js';\n    13→import { getValidationProgress } from '../verify/index.js';\n    14→import { DEFAULT_ENDPOINTS, buildScopedEndpoints, resolveEndpoints, getDefaultEndpointsForBackend } from './endpoints.js';\n    15→import type { HarnessState } from '../../lib/state.js';\n    16→import type { StatusReport } from '../sprint/index.js';\n    17→\n    18→/** Resolve the shared compose file path based on the backend type. */\n    19→function resolveSharedCompose(backend: string): string {\n    20→  return backend === 'elk' ? getElkComposeFilePath() : getComposeFilePath();\n    21→}\n    22→\n    23→// ─── Full Status Display ────────────────────────────────────────────────────\n    24→\n    25→export function handleFullStatus(isJson: boolean): void {\n    26→  let state: HarnessState;\n    27→  try {\n    28→    state = readState();\n    29→  } catch (err) {\n    30→    if (err instanceof StateFileNotFoundError) {\n    31→      if (isJson) {\n    32→        jsonOutput({ status: 'fail', message: \"Harness not initialized. Run 'codeharness init' first.\" });\n    33→      } else {\n    34→        fail(\"Harness not initialized. Run 'codeharness init' first.\");\n    35→      }\n    36→      process.exitCode = 1;\n    37→      return;\n    38→    }\n    39→    throw err;\n    40→  }\n    41→\n    42→  if (isJson) {\n    43→    handleFullStatusJson(state);\n    44→    return;\n    45→  }\n    46→\n    47→  // Sprint state sections (Project State, Run, Action Items)\n    48→  printSprintState();\n    49→\n    50→  // Validation progress (if validation stories exist)\n    51→  printValidationProgress();\n    52→\n    53→  // Version & Stack\n    54→  console.log(`Harness: codeharness v${state.harness_version}`);\n    55→  console.log(`Stack: ${state.stack ?? 'unknown'}`);\n    56→  if (state.app_type) {\n    57→    console.log(`App type: ${state.app_type}`);\n    58→    if (state.app_type === 'agent' && state.otlp?.agent_sdk) {\n    59→      console.log(`Agent SDK: ${state.otlp.agent_sdk}`);\n    60→    }\n    61→  }\n    62→\n    63→  // Enforcement\n    64→  const e = state.enforcement;\n    65→  console.log(\n    66→    `Enforcement: front:${e.frontend ? 'ON' : 'OFF'} db:${e.database ? 'ON' : 'OFF'} api:${e.api ? 'ON' : 'OFF'} obs:ON`,\n    67→  );\n    68→\n    69→  // Docker (always shown — observability is mandatory unless backend is 'none')\n    70→  {\n    71→    const backend = state.otlp?.backend ?? 'victoria';\n    72→    const mode = state.otlp?.mode ?? 'local-shared';\n    73→\n    74→    if (backend === 'none') {\n    75→      console.log('Docker: disabled (observability off)');\n    76→    } else if (mode === 'remote-direct') {\n    77→      const endpoint = state.otlp?.endpoint ?? 'unknown';\n    78→      console.log(`Docker: none (remote OTLP at ${endpoint})`);\n    79→    } else if (mode === 'remote-routed') {\n    80→      const re = state.docker?.remote_endpoints;\n    81→      console.log(`Docker: OTel Collector only (backends at ${re?.logs_url ?? 'unknown'}, ${re?.metrics_url ?? 'unknown'}, ${re?.traces_url ?? 'unknown'})`);\n    82→      const sharedComposeFile = getComposeFilePath();\n    83→      const health = getCollectorHealth(sharedComposeFile);\n    84→      for (const svc of health.services) {\n    85→        console.log(`  ${svc.name}: ${svc.running ? 'running' : 'stopped'}`);\n    86→      }\n    87→    } else {\n    88→      const composeFile = state.docker?.compose_file ?? 'docker-compose.harness.yml';\n    89→      const stackDir = getStackDir();\n    90→      const isShared = composeFile.startsWith(stackDir);\n    91→\n    92→      const resolvedComposeFile = isShared ? resolveSharedCompose(backend) : composeFile;\n    93→      const projectName = isShared ? 'codeharness-shared' : undefined;\n    94→      const header = isShared ? 'Docker: shared stack at ~/.codeharness/stack/' : 'Docker:';\n    95→\n    96→      console.log(header);\n    97→      const health = getStackHealth(resolvedComposeFile, projectName);\n    98→      for (const svc of health.services) {\n    99→        console.log(`  ${svc.name}: ${svc.running ? 'running' : 'stopped'}`);\n   100→      }\n   101→      if (health.healthy) {\n   102→        const ep = getDefaultEndpointsForBackend(backend);\n   103→        console.log(\n   104→          `  Endpoints: logs=${ep.logs} metrics=${ep.metrics} traces=${ep.traces}`,\n   105→        );\n   106→      }\n   107→    }\n   108→  }\n   109→\n   110→  // Service-scoped endpoints\n   111→  const serviceName = state.otlp?.service_name;\n   112→  if (serviceName) {\n   113→    const endpoints = resolveEndpoints(state);\n   114→    const scoped = buildScopedEndpoints(endpoints, serviceName);\n   115→    console.log(`  Scoped: logs=${scoped.logs} metrics=${scoped.metrics} traces=${scoped.traces}`);\n   116→  }\n   117→\n   118→  // Beads\n   119→  printBeadsSummary();\n   120→\n   121→  // Onboarding progress\n   122→  printOnboardingProgress();\n   123→\n   124→  // Session flags\n   125→  const sf = state.session_flags;\n   126→  console.log(\n   127→    `Session: tests_passed=${sf.tests_passed} coverage_met=${sf.coverage_met} verification_run=${sf.verification_run} logs_queried=${sf.logs_queried}`,\n   128→  );\n   129→\n   130→  // Coverage\n   131→  const currentCov = state.coverage.current !== null ? `${state.coverage.current}%` : '\\u2014';\n   132→  console.log(`Coverage: ${currentCov} / ${state.coverage.target}% target`);\n   133→\n   134→  // Verification log\n   135→  if (state.verification_log.length === 0) {\n   136→    console.log('Verification: no entries');\n   137→  } else {\n   138→    console.log('Verification log:');\n   139→    for (const entry of state.verification_log) {\n   140→      console.log(`  ${entry}`);\n   141→    }\n   142→  }\n   143→}\n   144→\n   145→function handleFullStatusJson(state: HarnessState): void {\n   146→  // Docker (always present — observability is mandatory unless backend is 'none')\n   147→  let docker: Record<string, unknown>;\n   148→  {\n   149→    const backend = state.otlp?.backend ?? 'victoria';\n   150→    const mode = state.otlp?.mode ?? 'local-shared';\n   151→\n   152→    if (backend === 'none') {\n   153→      docker = { mode: 'none', message: 'Observability disabled' };\n   154→    } else if (mode === 'remote-direct') {\n   155→      docker = {\n   156→        mode: 'remote-direct',\n   157→        endpoint: state.otlp?.endpoint,\n   158→      };\n   159→    } else if (mode === 'remote-routed') {\n   160→      const sharedComposeFile = getComposeFilePath();\n   161→      const health = getCollectorHealth(sharedComposeFile);\n   162→      docker = {\n   163→        mode: 'remote-routed',\n   164→        healthy: health.healthy,\n   165→        services: health.services,\n   166→        remote_endpoints: state.docker?.remote_endpoints,\n   167→      };\n   168→    } else {\n   169→      const composeFile = state.docker?.compose_file ?? 'docker-compose.harness.yml';\n   170→      const stackDir = getStackDir();\n   171→      const isShared = composeFile.startsWith(stackDir);\n   172→\n   173→      const ep = getDefaultEndpointsForBackend(backend);\n   174→      if (isShared) {\n   175→        const sharedComposeFile = resolveSharedCompose(backend);\n   176→        const health = getStackHealth(sharedComposeFile, 'codeharness-shared');\n   177→        docker = {\n   178→          shared: true,\n   179→          stack_dir: '~/.codeharness/stack/',\n   180→          healthy: health.healthy,\n   181→          services: health.services,\n   182→          ...(health.healthy ? { endpoints: ep } : {}),\n   183→        };\n   184→      } else {\n   185→        const health = getStackHealth(composeFile);\n   186→        docker = {\n   187→          healthy: health.healthy,\n   188→          services: health.services,\n   189→          ...(health.healthy ? { endpoints: ep } : {}),\n   190→        };\n   191→      }\n   192→    }\n   193→  }\n   194→\n   195→  // Resolved endpoints\n   196→  const endpoints = resolveEndpoints(state);\n   197→\n   198→  // Scoped endpoints\n   199→  const serviceName = state.otlp?.service_name;\n   200→  const scoped_endpoints = serviceName ? buildScopedEndpoints(endpoints, serviceName) : undefined;\n   201→\n   202→  // Beads\n   203→  const beads = getBeadsData();\n   204→\n   205→  // Onboarding progress\n   206→  const onboarding = getOnboardingProgressData();\n   207→\n   208→  // Sprint state\n   209→  const sprint = getSprintReportData();\n   210→\n   211→  // Validation progress\n   212→  const validationResult = getValidationProgress();\n   213→  const validation = validationResult.success && validationResult.data.total > 0\n   214→    ? validationResult.data : undefined;\n   215→\n   216→  jsonOutput({\n   217→    version: state.harness_version,\n   218→    stack: state.stack,\n   219→    ...(state.app_type ? { app_type: state.app_type } : {}),\n   220→    ...(sprint ? { sprint } : {}),\n   221→    ...(validation ? { validation } : {}),\n   222→    enforcement: state.enforcement,\n   223→    docker,\n   224→    endpoints,\n   225→    ...(scoped_endpoints ? { scoped_endpoints } : {}),\n   226→    beads,\n   227→    ...(onboarding ? { onboarding } : {}),\n   228→    session_flags: state.session_flags,\n   229→    coverage: state.coverage,\n   230→    verification_log: state.verification_log,\n   231→  });\n   232→}\n   233→\n   234→// ─── Health Check Mode ──────────────────────────────────────────────────────\n   235→\n   236→export async function handleHealthCheck(isJson: boolean): Promise<void> {\n   237→  const checks: { name: string; status: 'ok' | 'fail'; detail: string }[] = [];\n   238→\n   239→  // 1. State file integrity\n   240→  let state: HarnessState | null = null;\n   241→  try {\n   242→    state = readState();\n   243→    checks.push({ name: 'state_file', status: 'ok', detail: 'valid' });\n   244→  } catch {\n   245→    // IGNORE: state file may not exist\n   246→    checks.push({ name: 'state_file', status: 'fail', detail: 'not found' });\n   247→  }\n   248→\n   249→  // 2. Docker health (always checked — observability is mandatory unless backend is 'none')\n   250→  if (state) {\n   251→    const backend = state.otlp?.backend ?? 'victoria';\n   252→    const mode = state.otlp?.mode ?? 'local-shared';\n   253→\n   254→    if (backend === 'none') {\n   255→      checks.push({ name: 'docker', status: 'ok', detail: 'observability disabled — skipped' });\n   256→    } else if (mode === 'remote-direct') {\n   257→      const endpoint = state.otlp?.endpoint ?? '';\n   258→      const result = await checkRemoteEndpoint(endpoint);\n   259→      checks.push({\n   260→        name: 'docker',\n   261→        status: result.reachable ? 'ok' : 'fail',\n   262→        detail: result.reachable ? `remote OTLP reachable (${endpoint})` : `remote OTLP unreachable (${result.error ?? 'unknown'})`,\n   263→      });\n   264→    } else if (mode === 'remote-routed') {\n   265→      const sharedComposeFile = getComposeFilePath();\n   266→      const health = getCollectorHealth(sharedComposeFile);\n   267→      checks.push({\n   268→        name: 'docker',\n   269→        status: health.healthy ? 'ok' : 'fail',\n   270→        detail: health.healthy ? 'OTel Collector running' : (health.remedy ?? 'collector down'),\n   271→      });\n   272→\n   273→      // Check remote endpoints\n   274→      const re = state.docker?.remote_endpoints;\n   275→      if (re) {\n   276→        for (const [label, url] of [['logs', re.logs_url], ['metrics', re.metrics_url], ['traces', re.traces_url]] as const) {\n   277→          if (url) {\n   278→            const result = await checkRemoteEndpoint(url);\n   279→            checks.push({\n   280→              name: `remote_${label}`,\n   281→              status: result.reachable ? 'ok' : 'fail',\n   282→              detail: result.reachable ? `reachable (${url})` : `unreachable (${result.error ?? 'unknown'})`,\n   283→            });\n   284→          }\n   285→        }\n   286→      }\n   287→    } else {\n   288→      const composeFile = state.docker?.compose_file ?? 'docker-compose.harness.yml';\n   289→      const sDir = getStackDir();\n   290→      const isShared = composeFile.startsWith(sDir);\n   291→      const healthComposeFile = isShared ? resolveSharedCompose(backend) : composeFile;\n   292→      const healthProjectName = isShared ? 'codeharness-shared' : undefined;\n   293→      const health = getStackHealth(healthComposeFile, healthProjectName);\n   294→      checks.push({\n   295→        name: 'docker',\n   296→        status: health.healthy ? 'ok' : 'fail',\n   297→        detail: health.healthy ? 'all services running' : (health.remedy ?? 'services down'),\n   298→      });\n   299→    }\n   300→  } else {\n   301→    checks.push({ name: 'docker', status: 'fail', detail: 'cannot check (no state)' });\n   302→  }\n   303→\n   304→  // 3. Beads availability\n   305→  try {\n   306→    if (isBeadsInitialized()) {\n   307→      listIssues();\n   308→      checks.push({ name: 'beads', status: 'ok', detail: 'available' });\n   309→    } else {\n   310→      checks.push({ name: 'beads', status: 'fail', detail: 'not initialized' });\n   311→    }\n   312→  } catch {\n   313→    // IGNORE: beads CLI may not be available\n   314→    checks.push({ name: 'beads', status: 'fail', detail: 'bd command failed' });\n   315→  }\n   316→\n   317→  const allPassed = checks.every(c => c.status === 'ok');\n   318→\n   319→  if (isJson) {\n   320→    const checksObj: Record<string, { status: string; detail: string }> = {};\n   321→    for (const c of checks) {\n   322→      checksObj[c.name] = { status: c.status, detail: c.detail };\n   323→    }\n   324→    jsonOutput({ status: allPassed ? 'ok' : 'fail', checks: checksObj });\n   325→  } else {\n   326→    for (const c of checks) {\n   327→      const prefix = c.status === 'ok' ? '[OK]' : '[FAIL]';\n   328→      const label = c.name.replace(/_/g, ' ');\n   329→      console.log(`${prefix} ${label[0].toUpperCase() + label.slice(1)}: ${c.detail}`);\n   330→    }\n   331→  }\n   332→\n   333→  process.exitCode = allPassed ? 0 : 1;\n   334→}\n   335→\n   336→// ─── Docker Check ───────────────────────────────────────────────────────────\n   337→\n   338→export async function handleDockerCheck(isJson: boolean): Promise<void> {\n   339→  let state: HarnessState | null = null;\n   340→  try {\n   341→    state = readState();\n   342→  } catch {\n   343→    // IGNORE: state file may not exist or be corrupted\n   344→  }\n   345→\n   346→  const backend = state?.otlp?.backend ?? 'victoria';\n   347→\n   348→  if (backend === 'none') {\n   349→    if (isJson) {\n   350→      jsonOutput({ status: 'ok', mode: 'none', message: 'Observability disabled — no Docker check needed' });\n   351→    } else {\n   352→      info('[INFO] Observability disabled — no Docker check needed');\n   353→    }\n   354→    return;\n   355→  }\n   356→\n   357→  const mode = state?.otlp?.mode ?? 'local-shared';\n   358→\n   359→  if (mode === 'remote-direct') {\n   360→    const endpoint = state?.otlp?.endpoint ?? '';\n   361→    const result = await checkRemoteEndpoint(endpoint);\n   362→    if (isJson) {\n   363→      jsonOutput({\n   364→        status: result.reachable ? 'ok' : 'fail',\n   365→        mode: 'remote-direct',\n   366→        endpoint,\n   367→        reachable: result.reachable,\n   368→        ...(result.error ? { error: result.error } : {}),\n   369→      });\n   370→    } else {\n   371→      if (result.reachable) {\n   372→        ok(`Remote OTLP endpoint: reachable (${endpoint})`);\n   373→      } else {\n   374→        fail(`Remote OTLP endpoint: unreachable (${endpoint})`);\n   375→        if (result.error) {\n   376→          info(`Error: ${result.error}`);\n   377→        }\n   378→      }\n   379→    }\n   380→    return;\n   381→  }\n   382→\n   383→  if (mode === 'remote-routed') {\n   384→    const sharedComposeFile = getComposeFilePath();\n   385→    const health = getCollectorHealth(sharedComposeFile);\n   386→\n   387→    if (isJson) {\n   388→      jsonOutput({\n   389→        status: health.healthy ? 'ok' : 'fail',\n   390→        mode: 'remote-routed',\n   391→        docker: {\n   392→          healthy: health.healthy,\n   393→          services: health.services,\n   394→          remedy: health.remedy,\n   395→        },\n   396→        remote_endpoints: state?.docker?.remote_endpoints,\n   397→      });\n   398→    } else {\n   399→      if (health.healthy) {\n   400→        ok('OTel Collector: running');\n   401→      } else {\n   402→        fail('OTel Collector: not running');\n   403→        if (health.remedy) {\n   404→          info(`-> ${health.remedy}`);\n   405→        }\n   406→      }\n   407→      const re = state?.docker?.remote_endpoints;\n   408→      if (re) {\n   409→        info(`Remote backends: logs=${re.logs_url} metrics=${re.metrics_url} traces=${re.traces_url}`);\n   410→      }\n   411→    }\n   412→    return;\n   413→  }\n   414→\n   415→  // local-shared mode (default)\n   416→  let composeFile = 'docker-compose.harness.yml';\n   417→  let projectName: string | undefined;\n   418→\n   419→  if (state?.docker?.compose_file) {\n   420→    composeFile = state.docker.compose_file;\n   421→  }\n   422→\n   423→  const stackDir = getStackDir();\n   424→  if (composeFile.startsWith(stackDir)) {\n   425→    composeFile = resolveSharedCompose(backend);\n   426→    projectName = 'codeharness-shared';\n   427→  }\n   428→\n   429→  const health = getStackHealth(composeFile, projectName);\n   430→\n   431→  if (isJson) {\n   432→    jsonOutput({\n   433→      status: health.healthy ? 'ok' : 'fail',\n   434→      backend,\n   435→      ...(projectName ? { project_name: projectName } : {}),\n   436→      docker: {\n   437→        healthy: health.healthy,\n   438→        services: health.services,\n   439→        remedy: health.remedy,\n   440→      },\n   441→      ...(health.healthy ? { endpoints: getDefaultEndpointsForBackend(backend) } : {}),\n   442→    });\n   443→    return;\n   444→  }\n   445→\n   446→  const stackLabel = backend === 'elk' ? 'OpenSearch/ELK stack' : 'VictoriaMetrics stack';\n   447→  const ep = getDefaultEndpointsForBackend(backend);\n   448→\n   449→  if (health.healthy) {\n   450→    ok(`${stackLabel}: running${projectName ? ` (project: ${projectName})` : ''}`);\n   451→    for (const svc of health.services) {\n   452→      info(`  ${svc.name}: ${svc.running ? 'running' : 'stopped'}`);\n   453→    }\n   454→    info(`Endpoints: logs=${ep.logs} metrics=${ep.metrics} traces=${ep.traces}`);\n   455→  } else {\n   456→    fail(`${stackLabel}: not running${projectName ? ` (project: ${projectName})` : ''}`);\n   457→    for (const svc of health.services) {\n   458→      if (!svc.running) {\n   459→        info(`  ${svc.name}: down`);\n   460→      }\n   461→    }\n   462→    if (health.remedy) {\n   463→      info(`-> ${health.remedy}`);\n   464→    }\n   465→  }\n   466→}\n   467→\n   468→// ─── Sprint State Helpers ────────────────────────────────────────────────────\n   469→\n   470→function printSprintState(): void {\n   471→  const reportResult = generateReport();\n   472→  if (!reportResult.success) {\n   473→    console.log('Sprint state: unavailable');\n   474→    return;\n   475→  }\n   476→\n   477→  const r = reportResult.data;\n   478→  console.log(`\\u2500\\u2500 Project State \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500`);\n   479→  console.log(`Sprint: ${r.done}/${r.total} done (${r.sprintPercent}%) | ${r.epicsDone}/${r.epicsTotal} epics complete`);\n   480→\n   481→  if (r.activeRun) {\n   482→    console.log('');\n   483→    console.log(`\\u2500\\u2500 Active Run \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500`);\n   484→    const currentStory = r.inProgress ?? 'none';\n   485→    console.log(`Status: running (iteration ${r.activeRun.iterations}, ${r.activeRun.duration} elapsed)`);\n   486→    console.log(`Current: ${currentStory}`);\n   487→    console.log(`Budget: $${r.activeRun.cost.toFixed(2)} spent`);\n   488→  } else if (r.lastRun) {\n   489→    console.log('');\n   490→    console.log(`\\u2500\\u2500 Last Run Summary \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500`);\n   491→    console.log(`Duration: ${r.lastRun.duration} | Cost: $${r.lastRun.cost.toFixed(2)} | Iterations: ${r.lastRun.iterations}`);\n   492→    console.log(`Completed:  ${r.lastRun.completed.length} stories${r.lastRun.completed.length > 0 ? ` (${r.lastRun.completed.join(', ')})` : ''}`);\n   493→    if (r.failedDetails.length > 0) {\n   494→      console.log(`Failed:     ${r.failedDetails.length} stor${r.failedDetails.length === 1 ? 'y' : 'ies'}`);\n   495→      for (const fd of r.failedDetails) {\n   496→        const acPart = fd.acNumber !== null ? `AC ${fd.acNumber}` : 'unknown AC';\n   497→        console.log(`  \\u2514 ${fd.key}: ${acPart} \\u2014 ${fd.errorLine} (attempt ${fd.attempts}/${fd.maxAttempts})`);\n   498→      }\n   499→    }\n   500→    if (r.lastRun.blocked.length > 0) {\n   501→      console.log(`Blocked:    ${r.lastRun.blocked.length} stories (retry-exhausted)`);\n   502→    }\n   503→  }\n   504→\n   505→  if (r.actionItemsLabeled.length > 0) {\n   506→    console.log('');\n   507→    console.log(`\\u2500\\u2500 Action Items \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500`);\n   508→    for (const la of r.actionItemsLabeled) {\n   509→      console.log(`  [${la.label}] ${la.item.story}: ${la.item.description}`);\n   510→    }\n   511→  }\n   512→\n   513→  console.log('');\n   514→}\n   515→\n   516→function printValidationProgress(): void {\n   517→  const result = getValidationProgress();\n   518→  if (!result.success) return;\n   519→  const p = result.data;\n   520→  if (p.total === 0) return;\n   521→  console.log(`Validation: ${p.passed}/${p.total} passed, ${p.failed} failed, ${p.blocked} blocked, ${p.remaining} remaining`);\n   522→}\n   523→\n   524→function getSprintReportData(): StatusReport | null {\n   525→  const reportResult = generateReport();\n   526→  if (!reportResult.success) return null;\n   527→  return reportResult.data;\n   528→}\n   529→\n   530→// ─── Beads Helpers ──────────────────────────────────────────────────────────\n   531→\n   532→function printBeadsSummary(): void {\n   533→  if (!isBeadsInitialized()) {\n   534→    console.log('Beads: not initialized');\n   535→    return;\n   536→  }\n   537→\n   538→  try {\n   539→    const issues = listIssues();\n   540→    const byType = new Map<string, number>();\n   541→    const byStatus = new Map<string, number>();\n   542→\n   543→    for (const issue of issues) {\n   544→      byType.set(issue.type, (byType.get(issue.type) ?? 0) + 1);\n   545→      byStatus.set(issue.status, (byStatus.get(issue.status) ?? 0) + 1);\n   546→    }\n   547→\n   548→    const typeParts = Array.from(byType.entries())\n   549→      .map(([t, n]) => `${t}:${n}`)\n   550→      .join(' ');\n   551→    const ready = byStatus.get('ready') ?? 0;\n   552→    const inProgress = byStatus.get('in_progress') ?? 0;\n   553→    const done = byStatus.get('done') ?? 0;\n   554→\n   555→    const typeInfo = typeParts ? ` (${typeParts})` : '';\n   556→    console.log(\n   557→      `Beads: ${issues.length} issues${typeInfo} | ready:${ready} in-progress:${inProgress} done:${done}`,\n   558→    );\n   559→  } catch {\n   560→    // IGNORE: beads CLI may not be available\n   561→    console.log('Beads: unavailable (bd command failed)');\n   562→  }\n   563→}\n   564→\n   565→function printOnboardingProgress(): void {\n   566→  const progress = getOnboardingProgress({ listIssues });\n   567→  if (progress) {\n   568→    console.log(`Onboarding: ${progress.resolved}/${progress.total} gaps resolved (${progress.remaining} remaining)`);\n   569→  }\n   570→}\n   571→\n   572→function getOnboardingProgressData(): Record<string, unknown> | null {\n   573→  const progress = getOnboardingProgress({ listIssues });\n   574→  if (!progress) {\n   575→    return null;\n   576→  }\n   577→  return {\n   578→    total: progress.total,\n   579→    resolved: progress.resolved,\n   580→    remaining: progress.remaining,\n   581→  };\n   582→}\n   583→\n   584→function getBeadsData(): Record<string, unknown> {\n   585→  if (!isBeadsInitialized()) {\n   586→    return { initialized: false };\n   587→  }\n   588→\n   589→  try {\n   590→    const issues = listIssues();\n   591→    const issuesByType: Record<string, number> = {};\n   592→    const issuesByStatus: Record<string, number> = {};\n   593→\n   594→    for (const issue of issues) {\n   595→      issuesByType[issue.type] = (issuesByType[issue.type] ?? 0) + 1;\n   596→      issuesByStatus[issue.status] = (issuesByStatus[issue.status] ?? 0) + 1;\n   597→    }\n   598→\n   599→    return {\n   600→      initialized: true,\n   601→      total: issues.length,\n   602→      issues_by_type: issuesByType,\n   603→      issues_by_status: issuesByStatus,\n   604→    };\n   605→  } catch {\n   606→    // IGNORE: beads CLI may not be available\n   607→    return { initialized: true, error: 'bd command failed' };\n   608→  }\n   609→}\n   610→"}]},"parent_tool_use_id":"toolu_01MwzbgNwEhenGxNXV9UQBeX","session_id":"507a8d0b-20bb-4c55-954f-5f817ca0f972","uuid":"e845205f-e00d-442c-abbd-ac106daccf01","timestamp":"2026-03-27T07:04:03.504Z"}
