{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ELf6pvfyquhUdXHM64T48Q","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→\n     3→vi.mock('node:fs', () => ({\n     4→  existsSync: vi.fn(),\n     5→  writeFileSync: vi.fn(),\n     6→  readFileSync: vi.fn(),\n     7→}));\n     8→\n     9→import { existsSync, writeFileSync, readFileSync } from 'node:fs';\n    10→import { join } from 'node:path';\n    11→import { generateDockerfileTemplate } from '../dockerfile-template.js';\n    12→import { validateDockerfile } from '../dockerfile-validator.js';\n    13→\n    14→const mockExistsSync = vi.mocked(existsSync);\n    15→const mockWriteFileSync = vi.mocked(writeFileSync);\n    16→\n    17→beforeEach(() => {\n    18→  vi.resetAllMocks();\n    19→});\n    20→\n    21→// ─── Node.js template ───────────────────────────────────────────────────────\n    22→\n    23→describe('generateDockerfileTemplate — nodejs', () => {\n    24→  it('generates Dockerfile with pinned FROM node:22-slim', () => {\n    25→    mockExistsSync.mockReturnValue(false);\n    26→\n    27→    const r = generateDockerfileTemplate('/project', 'nodejs');\n    28→    expect(r.success).toBe(true);\n    29→    if (r.success) {\n    30→      expect(r.data.path).toBe(join('/project', 'Dockerfile'));\n    31→      expect(r.data.stack).toBe('nodejs');\n    32→    }\n    33→\n    34→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    35→    expect(written).toContain('FROM node:22-slim');\n    36→  });\n    37→\n    38→  it('includes npm install -g for binary installation', () => {\n    39→    mockExistsSync.mockReturnValue(false);\n    40→    generateDockerfileTemplate('/project', 'nodejs');\n    41→\n    42→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    43→    expect(written).toContain('npm install -g');\n    44→  });\n    45→\n    46→  it('includes curl and jq verification tools', () => {\