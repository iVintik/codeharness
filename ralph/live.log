{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WVqd71HCXmCwgBQW5tydEK","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n     2→import { mkdtempSync, rmSync, mkdirSync, writeFileSync, readFileSync, existsSync } from 'node:fs';\n     3→import { tmpdir } from 'node:os';\n     4→import { join } from 'node:path';\n     5→\n     6→// Mock child_process before importing verify module\n     7→vi.mock('node:child_process', () => ({\n     8→  execFileSync: vi.fn(),\n     9→}));\n    10→\n    11→// Mock output\n    12→vi.mock('../../../lib/output.js', () => ({\n    13→  ok: vi.fn(),\n    14→  fail: vi.fn(),\n    15→  warn: vi.fn(),\n    16→  info: vi.fn(),\n    17→  jsonOutput: vi.fn(),\n    18→}));\n    19→\n    20→// Mock beads\n    21→vi.mock('../../../lib/beads.js', () => ({\n    22→  isBeadsInitialized: vi.fn(),\n    23→  listIssues: vi.fn(),\n    24→  closeIssue: vi.fn(),\n    25→}));\n    26→\n    27→// Mock beads-sync\n    28→vi.mock('../../../lib/sync/index.js', () => ({\n    29→  syncClose: vi.fn(),\n    30→}));\n    31→\n    32→// Mock doc-health\n    33→vi.mock('../../../lib/doc-health/index.js', () => ({\n    34→  checkStoryDocFreshness: vi.fn(),\n    35→}));\n    36→\n    37→import { execFileSync } from 'node:child_process';\n    38→import { warn } from '../../../lib/output.js';\n    39→import { isBeadsInitialized, listIssues, closeIssue } from '../../../lib/beads.js';\n    40→import { syncClose } from '../../../lib/sync/index.js';\n    41→import { checkStoryDocFreshness } from '../../../lib/doc-health/index.js';\n    42→import {\n    43→  checkPreconditions,\n    44→  createProofDocument,\n    45→  runShowboatVerify,\n    46→  updateVerificationState,\n    47→  closeBeadsIssue,\n    48→} from '../orchestrator.js';\n    49→import {\n    50→  validateProofQuality,\n    51→  proofHasContent,\n    52→} from '../proof.js';\n    53→import type { VerifyResult, ProofQuality } from '../types.js';\n    54→import { writeState, readState } from '../../../lib/state.js';\n    55→import { getDefaultState } from '../../../lib/state.js';\n    56→\n    57→let testDir: string;\n    58→\n    59→beforeEach(() => {\n    60→  vi.clearAllMocks();\n    61→  testDir = mkdtempSync(join(tmpdir(), 'ch-verify-test-'));\n    62→});\n    63→\n    64→afterEach(() => {\n    65→  rmSync(testDir, { recursive: true, force: true });\n    66→});\n    67→\n    68→function setupState(overrides: Record<string, unknown> = {}): void {\n    69→  const state = getDefaultState('node');\n    70→  if (overrides.tests_passed !== undefined) {\n    71→    state.session_flags.tests_passed = overrides.tests_passed as boolean;\n    72→  }\n    73→  if (overrides.coverage_met !== undefined) {\n    74→    state.session_flags.coverage_met = overrides.coverage_met as boolean;\n    75→  }\n    76→  if (overrides.verification_run !== undefined) {\n    77→    state.session_flags.verification_run = overrides.verification_run as boolean;\n    78→  }\n    79→  if (overrides.verification_log !== undefined) {\n    80→    state.verification_log = overrides.verification_log as string[];\n    81→  }\n    82→  writeState(state, testDir);\n    83→}\n    84→\n    85→// ─── checkPreconditions ─────────────────────────────────────────────────────\n    86→\n    87→describe('checkPreconditions', () => {\n    88→  it('returns pass when both flags are true', () => {\n    89→    setupState({ tests_passed: true, coverage_met: true });\n    90→    const result = checkPreconditions(testDir);\n    91→    expect(result.passed).toBe(true);\n    92→    expect(result.failures).toEqual([]);\n    93→  });\n    94→\n    95→  it('returns failure when tests_passed is false', () => {\n    96→    setupState({ tests_passed: false, coverage_met: true });\n    97→    const result = checkPreconditions(testDir);\n    98→    expect(result.passed).toBe(false);\n    99→    expect(result.failures).toHaveLength(1);\n   100→    expect(result.failures[0]).toContain('tests_passed');\n   101→  });\n   102→\n   103→  it('returns failure when coverage_met is false', () => {\n   104→    setupState({ tests_passed: true, coverage_met: false });\n   105→    const result = checkPreconditions(testDir);\n   106→    expect(result.passed).toBe(false);\n   107→    expect(result.failures).toHaveLength(1);\n   108→    expect(result.failures[0]).toContain('coverage_met');\n   109→  });\n   110→\n   111→  it('returns both failures when both flags are false', () => {\n   112→    setupState({ tests_passed: false, coverage_met: false });\n   113→    const result = checkPreconditions(testDir);\n   114→    expect(result.passed).toBe(false);\n   115→    expect(result.failures).toHaveLength(2);\n   116→  });\n   117→\n   118→  it('adds failure for stale docs when storyId is provided', () => {\n   119→    setupState({ tests_passed: true, coverage_met: true });\n   120→    vi.mocked(checkStoryDocFreshness).mockReturnValue({\n   121→      passed: false,\n   122→      documents: [\n   123→        { path: 'AGENTS.md', grade: 'stale', reason: 'AGENTS.md is stale', lastModified: null, codeLastModified: null },\n   124→      ],\n   125→      summary: { fresh: 0, stale: 1, missing: 0, total: 1 },\n   126→      scanDurationMs: 10,\n   127→    });\n   128→\n   129→    const result = checkPreconditions(testDir, 'test-story');\n   130→    expect(result.passed).toBe(false);\n   131→    expect(result.failures).toContain('AGENTS.md is stale');\n   132→  });\n   133→\n   134→  it('adds failure for missing docs when storyId is provided', () => {\n   135→    setupState({ tests_passed: true, coverage_met: true });\n   136→    vi.mocked(checkStoryDocFreshness).mockReturnValue({\n   137→      passed: false,\n   138→      documents: [\n   139→        { path: 'AGENTS.md', grade: 'missing', reason: 'AGENTS.md not found', lastModified: null, codeLastModified: null },\n   140→      ],\n   141→      summary: { fresh: 0, stale: 0, missing: 1, total: 1 },\n   142→      scanDurationMs: 5,\n   143→    });\n   144→\n   145→    const result = checkPreconditions(testDir, 'test-story');\n   146→    expect(result.passed).toBe(false);\n   147→    expect(result.failures).toContain('AGENTS.md not found');\n   148→  });\n   149→\n   150→  it('skips non-stale non-missing docs without adding failures', () => {\n   151→    setupState({ tests_passed: true, coverage_met: true });\n   152→    vi.mocked(checkStoryDocFreshness).mockReturnValue({\n   153→      passed: false,\n   154→      documents: [\n   155→        { path: 'AGENTS.md', grade: 'fresh', reason: '', lastModified: new Date(), codeLastModified: new Date() },\n   156→      ],\n   157→      summary: { fresh: 1, stale: 0, missing: 0, total: 1 },\n   158→      scanDurationMs: 5,\n   159→    });\n   160→\n   161→    const result = checkPreconditions(testDir, 'test-story');\n   162→    expect(result.passed).toBe(true);\n   163→    expect(result.failures).toEqual([]);\n   164→  });\n   165→\n   166→  it('passes when doc report passed is true', () => {\n   167→    setupState({ tests_passed: true, coverage_met: true });\n   168→    vi.mocked(checkStoryDocFreshness).mockReturnValue({\n   169→      passed: true,\n   170→      documents: [],\n   171→      summary: { fresh: 0, stale: 0, missing: 0, total: 0 },\n   172→      scanDurationMs: 5,\n   173→    });\n   174→\n   175→    const result = checkPreconditions(testDir, 'test-story');\n   176→    expect(result.passed).toBe(true);\n   177→  });\n   178→\n   179→  it('warns and continues when checkStoryDocFreshness throws', () => {\n   180→    setupState({ tests_passed: true, coverage_met: true });\n   181→    vi.mocked(checkStoryDocFreshness).mockImplementation(() => {\n   182→      throw new Error('git not found');\n   183→    });\n   184→\n   185→    const result = checkPreconditions(testDir, 'test-story');\n   186→    expect(result.passed).toBe(true);\n   187→    expect(warn).toHaveBeenCalledWith('Doc health check failed — skipping');\n   188→  });\n   189→});\n   190→\n   191→// ─── createProofDocument ────────────────────────────────────────────────────\n   192→\n   193→describe('createProofDocument', () => {\n   194→  it('creates directories and writes proof file', () => {\n   195→    const proofPath = createProofDocument('4-1-test', 'Story 4.1: Test', [\n   196→      { id: '1', description: 'First AC', type: 'general', verifiability: 'cli-verifiable', strategy: 'docker', tier: 'test-provable' },\n   197→    ], testDir);\n   198→\n   199→    expect(existsSync(proofPath)).toBe(true);\n   200→    expect(existsSync(join(testDir, 'verification'))).toBe(true);\n   201→    expect(existsSync(join(testDir, 'verification', 'screenshots'))).toBe(true);\n   202→\n   203→    const content = readFileSync(proofPath, 'utf-8');\n   204→    expect(content).toContain('# Proof: 4-1-test');\n   205→    expect(content).toContain('**Story:** Story 4.1: Test');\n   206→    expect(content).toContain('## AC 1:');\n   207→  });\n   208→\n   209→  it('returns the proof file path', () => {\n   210→    const proofPath = createProofDocument('test-id', 'Test', [], testDir);\n   211→    expect(proofPath).toBe(join(testDir, 'verification', 'test-id-proof.md'));\n   212→  });\n   213→\n   214→  it('handles empty ACs', () => {\n   215→    const proofPath = createProofDocument('empty', 'Empty', [], testDir);\n   216→    const content = readFileSync(proofPath, 'utf-8');\n   217→    expect(content).toContain('Total ACs | 0');\n   218→  });\n   219→});\n   220→\n   221→// ─── runShowboatVerify ──────────────────────────────────────────────────────\n   222→\n   223→describe('runShowboatVerify', () => {\n   224→  it('returns pass when showboat exits with 0', () => {\n   225→    vi.mocked(execFileSync).mockReturnValue(Buffer.from('All checks passed'));\n   226→    const result = runShowboatVerify('/path/to/proof.md');\n   227→    expect(result.passed).toBe(true);\n   228→    expect(result.output).toBe('All checks passed');\n   229→  });\n   230→\n   231→  it('returns fail when showboat exits with non-zero', () => {\n   232→    const error = new Error('Command failed') as Error & { stdout: Buffer; stderr: Buffer };\n   233→    error.stdout = Buffer.from('Diff found');\n   234→    error.stderr = Buffer.from('');\n   235→    vi.mocked(execFileSync).mockImplementation(() => { throw error; });\n   236→    const result = runShowboatVerify('/path/to/proof.md');\n   237→    expect(result.passed).toBe(false);\n   238→    expect(result.output).toBe('Diff found');\n   239→  });\n   240→\n   241→  it('handles showboat not installed (ENOENT)', () => {\n   242→    const error = new Error('spawn showboat ENOENT');\n   243→    vi.mocked(execFileSync).mockImplementation(() => { throw error; });\n   244→    const result = runShowboatVerify('/path/to/proof.md');\n   245→    expect(result.passed).toBe(false);\n   246→    expect(result.output).toBe('showboat not available');\n   247→  });\n   248→});\n   249→\n   250→// ─── validateProofQuality ────────────────────────────────────────────────────\n   251→\n   252→describe('validateProofQuality', () => {\n   253→  it('returns zeros and passed=false for nonexistent file', () => {\n   254→    const result = validateProofQuality('/nonexistent/proof.md');\n   255→    expect(result).toMatchObject({ verified: 0, pending: 0, escalated: 0, total: 0, passed: false });\n   256→  });\n   257→\n   258→  it('returns all PENDING for skeleton proof (all ACs have no evidence)', () => {\n   259→    const path = join(testDir, 'proof.md');\n   260→    writeFileSync(path, [\n   261→      '# Proof: test-story',\n   262→      '',\n   263→      '## AC 1: PENDING',\n   264→      '',\n   265→      '> Given something, Then something',\n   266→      '',\n   267→      '<!-- No evidence captured yet -->',\n   268→      '',\n   269→      '## AC 2: PENDING',\n   270→      '',\n   271→      '> Given something else, Then something else',\n   272→      '',\n   273→      '<!-- No evidence captured yet -->',\n   274→      '',\n   275→      '## AC 3: PENDING',\n   276→      '',\n   277→      '> Third AC',\n   278→      '',\n   279→      '<!-- No evidence captured yet -->',\n   280→    ].join('\\n'));\n   281→\n   282→    const result = validateProofQuality(path);\n   283→    expect(result).toMatchObject({ verified: 0, pending: 3, escalated: 0, total: 3, passed: false });\n   284→  });\n   285→\n   286→  it('returns all verified for fully verified proof (all showboat exec blocks)', () => {\n   287→    const path = join(testDir, 'proof.md');\n   288→    writeFileSync(path, [\n   289→      '# Proof: test-story',\n   290→      '',\n   291→      '## AC 1: PASS',\n   292→      '',\n   293→      '> First AC',\n   294→      '',\n   295→      '<!-- showboat exec: codeharness verify --story test -->',\n   296→      '```',\n   297→      '[OK] verified',\n   298→      '```',\n   299→      '<!-- /showboat exec -->',\n   300→      '',\n   301→      '## AC 2: PASS',\n   302→      '',\n   303→      '> Second AC',\n   304→      '',\n   305→      '<!-- showboat exec: cat file.txt -->',\n   306→      '```',\n   307→      'content',\n   308→      '```',\n   309→      '<!-- /showboat exec -->',\n   310→    ].join('\\n'));\n   311→\n   312→    const result = validateProofQuality(path);\n   313→    expect(result).toMatchObject({ verified: 2, pending: 0, escalated: 0, total: 2, passed: true });\n   314→  });\n   315→\n   316→  it('returns passed=false for mixed proof (some verified, some PENDING)', () => {\n   317→    const path = join(testDir, 'proof.md');\n   318→    writeFileSync(path, [\n   319→      '# Proof: test-story',\n   320→      '',\n   321→      '## AC 1: PASS',\n   322→      '',\n   323→      '> First AC',\n   324→      '',\n   325→      '<!-- showboat exec: codeharness verify -->',\n   326→      '```',\n   327→      'ok',\n   328→      '```',\n   329→      '<!-- /showboat exec -->',\n   330→      '',\n   331→      '## AC 2: PENDING',\n   332→      '',\n   333→      '> Second AC',\n   334→      '',\n   335→      '<!-- No evidence captured yet -->',\n   336→    ].join('\\n'));\n   337→\n   338→    const result = validateProofQuality(path);\n   339→    expect(result).toMatchObject({ verified: 1, pending: 1, escalated: 0, total: 2, passed: false });\n   340→  });\n   341→\n   342→  it('considers showboat image markers as verified evidence', () => {\n   343→    const path = join(testDir, 'proof.md');\n   344→    writeFileSync(path, [\n   345→      '# Proof: test-story',\n   346→      '',\n   347→      '## AC 1: PASS',\n   348→      '',\n   349→      '> First AC',\n   350→      '',\n   351→      '<!-- showboat image: screenshots/test.png -->',\n   352→    ].join('\\n'));\n   353→\n   354→    const result = validateProofQuality(path);\n   355→    expect(result).toMatchObject({ verified: 1, pending: 0, escalated: 0, total: 1, passed: true });\n   356→  });\n   357→\n   358→  it('returns total=0 and passed=false for file with no AC sections', () => {\n   359→    const path = join(testDir, 'proof.md');\n   360→    writeFileSync(path, '# Proof: test-story\\n\\nNo AC sections here.');\n   361→\n   362→    const result = validateProofQuality(path);\n   363→    expect(result).toMatchObject({ verified: 0, pending: 0, escalated: 0, total: 0, passed: false });\n   364→  });\n   365→\n   366→  it('recognises showboat native format (bash + output code blocks) as evidence', () => {\n   367→    const path = join(testDir, 'proof.md');\n   368→    writeFileSync(path, [\n   369→      '## AC 1: Evidence via showboat exec',\n   370→      '',\n   371→      '> AC description',\n   372→      '',\n   373→      '```bash',\n   374→      'node dist/index.js verify --story test',\n   375→      '```',\n   376→      '',\n   377→      '```output',\n   378→      '[FAIL] Proof quality check failed',\n   379→      '```',\n   380→      '',\n   381→      '## AC 2: Also showboat native',\n   382→      '',\n   383→      '```shell',\n   384→      'cat file.txt',\n   385