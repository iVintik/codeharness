{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EuGFj5qxKrpeuKBTMP6YJg","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n     2→import { buildSprintState, buildSprintStateWithStory } from '../../../lib/__tests__/helpers.js';\n     3→\n     4→// Mock node:fs before importing the module under test\n     5→vi.mock('node:fs', () => ({\n     6→  readFileSync: vi.fn(),\n     7→  writeFileSync: vi.fn(),\n     8→  existsSync: vi.fn(),\n     9→}));\n    10→\n    11→// Mock the state module\n    12→vi.mock('../state.js', () => ({\n    13→  getSprintState: vi.fn(),\n    14→  updateStoryStatus: vi.fn(),\n    15→}));\n    16→\n    17→import { readFileSync, writeFileSync, existsSync } from 'node:fs';\n    18→import { parseProofForFailures, writeVerificationFindings, processVerifyResult } from '../feedback.js';\n    19→import { getSprintState, updateStoryStatus } from '../state.js';\n    20→\n    21→const mockedReadFileSync = vi.mocked(readFileSync);\n    22→const mockedWriteFileSync = vi.mocked(writeFileSync);\n    23→const mockedExistsSync = vi.mocked(existsSync);\n    24→const mockedGetSprintState = vi.mocked(getSprintState);\n    25→const mockedUpdateStoryStatus = vi.mocked(updateStoryStatus);\n    26→\n    27→beforeEach(() => {\n    28→  vi.resetAllMocks();\n    29→});\n    30→\n    31→// Sample proof with mixed verdicts\n    32→const PROOF_WITH_FAILURES = `# Verification Proof: 3-3-test\n    33→\n    34→## AC 1: First criterion passes\n    35→\n    36→\\`\\`\\`bash\n    37→npm test\n    38→\\`\\`\\`\n    39→\n    40→\\`\\`\\`output\n    41→all tests pass\n    42→\\`\\`\\`\n    43→\n    44→**Verdict:** PASS\n    45→\n    46→## AC 2: Second criterion fails\n    47→\n    48→\\`\\`\\`bash\n    49→npm run check\n    50→\\`\\`\\`\n    51→\n    52→\\`\\`\\`output\n    53→Error: assertion failed at line 42\n    54→Expected: true\n    55→Got: false\n    56→\\`\\`\\`\n    57→\n    58→**Verdict:** FAIL\n    59→\n    60→## AC 3: Third criterion is escalated\n    61→\n    62→Some investigation text.\n    63→\n    64→**Verdict:** [ESCALATE]\n    65→\n    66→## AC 4: Fourth criterion also fails\n    67→\n    68→\\`\\`\\`bash\n    69→curl http://localhost:3000/health\n    70→\\`\\`\\`\n    71→\n    72→\\`\\`\\`output\n    73→Connection refused\n    74→\\`\\`\\`\n    75→\n    76→**Verdict:** FAIL — service not running\n    77→`;\n    78→\n    79→const PROOF_ALL_PASS = `# Verification Proof: 3-3-test\n    80→\n    81→## AC 1: First criterion\n    82→\n    83→\\`\\`\\`bash\n    84→npm test\n    85→\\`\\`\\`\n    86→\n    87→\\`\\`\\`output\n    88→ok\n    89→\\`\\`\\`\n    90→\n    91→**Verdict:** PASS\n    92→\n    93→## AC 2: Second criterion\n    94→\n    95→\\`\\`\\`bash\n    96→npm run lint\n    97→\\`\\`\\`\n    98→\n    99→\\`\\`\\`output\n   100→ok\n   101→\\`\\`\\`\n   102→\n   103→**Verdict:** PASS\n   104→`;\n   105→\n   106→const PROOF_ESCALATE_ONLY = `# Verification Proof: 3-3-test\n   107→\n   108→## AC 1: Criterion\n   109→\n   110→**Verdict:** [ESCALATE] — needs integration test\n   111→\n   112→## AC 2: Another\n   113→\n   114→**Verdict:** PASS\n   115→`;\n   116→\n   117→const PROOF_NO_VERDICT = `# Verification Proof: test\n   118→\n   119→## AC 1: Criterion with no verdict\n   120→\n   121→Some text but no verdict line at all.\n   122→\n   123→## AC 2: Criterion that fails\n   124→\n   125→**Verdict:** FAIL\n   126→`;\n   127→\n   128→const PROOF_FAIL_NO_CODE_BLOCKS = `# Verification Proof: test\n   129→\n   130→## AC 1: Criterion fails without code blocks\n   131→\n   132→Just some text describing the failure.\n   133→\n   134→**Verdict:** FAIL\n   135→`;\n   136→\n   137→const PROOF_MULTILINE_VERDICT = `# Verification Proof: test\n   138→\n   139→## AC 1: Criterion with multiline verdict\n   140→\n   141→**Verdict:**\n   142→FAIL\n   143→`;\n   144→\n   145→describe('parseProofForFailures', () => {\n   146→  it('extracts failing ACs from proof markdown', () => {\n   147→    mockedExistsSync.mockReturnValue(true);\n   148→    mockedReadFileSync.mockReturnValue(PROOF_WITH_FAILURES);\n   149→\n   150→    const result = parseProofForFailures('/tmp/proof.md');\n   151→    expect(result.success).toBe(true);\n   152→    if (!result.success) return;\n   153→\n   154→    expect(result.data).toHaveLength(2);\n   155→    expect(result.data[0].acNumber).toBe(2);\n   156→    expect(result.data[0].description).toBe('Second criterion fails');\n   157→    expect(result.data[0].verdict).toBe('FAIL');\n   158→    expect(result.data[0].errorOutput).toContain('assertion failed');\n   159→\n   160→    expect(result.data[1].acNumber).toBe(4);\n   161→    expect(result.data[1].description).toBe('Fourth criterion also fails');\n   162→    expect(result.data[1].verdict).toContain('FAIL');\n   163→    expect(result.data[1].errorOutput).toContain('Connection refused');\n   164→  });\n   165→\n   166→  it('returns empty array when all ACs pass', () => {\n   167→    mockedExistsSync.mockReturnValue(true);\n   168→    mockedReadFileSync.mockReturnValue(PROOF_ALL_PASS);\n   169→\n   170→    const result = parseProofForFailures('/tmp/proof.md');\n   171→    expect(result.success).toBe(true);\n   172→    if (!result.success) return;\n   173→    expect(result.data).toHaveLength(0);\n   174→  });\n   175→\n   176→  it('skips [ESCALATE] verdicts (not treated as failures)', () => {\n   177→    mockedExistsSync.mockReturnValue(true);\n   178→    mockedReadFileSync.mockReturnValue(PROOF_ESCALATE_ONLY);\n   179→\n   180→    const result = parseProofForFailures('/tmp/proof.md');\n   181→    expect(result.success).toBe(true);\n   182→    if (!result.success) return;\n   183→    expect(result.data).toHaveLength(0);\n   184→  });\n   185→\n   186→  it('returns fail() on missing proof file', () => {\n   187→    mockedExistsSync.mockReturnValue(false);\n   188→\n   189→    const result = parseProofForFailures('/tmp/nonexistent.md');\n   190→    expect(result.success).toBe(false);\n   191→    if (result.success) return;\n   192→    expect(result.error).toContain('Proof file not found');\n   193→  });\n   194→\n   195→  it('skips AC sections with no verdict line', () => {\n   196→    mockedExistsSync.mockReturnValue(true);\n   197→    mockedReadFileSync.mockReturnValue(PROOF_NO_VERDICT);\n   198→\n   199→    const result = parseProofForFailures('/tmp/proof.md');\n   200→    expect(result.success).toBe(true);\n   201→    if (!result.success) return;\n   202→    // Only AC 2 has a verdict, and it FAILs\n   203→    expect(result.data).toHaveLength(1);\n   204→    expect(result.data[0].acNumber).toBe(2);\n   205→  });\n   206→\n   207→  it('extracts failing AC with empty errorOutput when no code blocks present', () => {\n   208→    mockedExistsSync.mockReturnValue(true);\n   209→    mockedReadFileSync.mockReturnValue(PROOF_FAIL_NO_CODE_BLOCKS);\n   210→\n   211→    const result = parseProofForFailures('/tmp/proof.md');\n   212→    expect(result.success).toBe(true);\n   213→    if (!result.success) return;\n   214→    expect(result.data).toHaveLength(1);\n   215→    expect(result.data[0].acNumber).toBe(1);\n   216→    expect(result.data[0].errorOutput).toBe('');\n   217→  });\n   218→\n   219→  it('handles verdict on next line after Verdict: label', () => {\n   220→    mockedExistsSync.mockReturnValue(true);\n   221→    mockedReadFileSync.mockReturnValue(PROOF_MULTILINE_VERDICT);\n   222→\n   223→    const result = parseProofForFailures('/tmp/proof.md');\n   224→    expect(result.success).toBe(true);\n   225→    if (!result.success) return;\n   226→    expect(result.data).toHaveLength(1);\n   227→    expect(result.data[0].verdict).toBe('FAIL');\n   228→  });\n   229→\n   230→  it('returns fail() on read error', () => {\n   231→    mockedExistsSync.mockReturnValue(true);\n   232→    mockedReadFileSync.mockImplementation(() => {\n   233→      throw new Error('EACCES: permission denied');\n   234→    });\n   235→\n   236→    const result = parseProofForFailures('/tmp/proof.md');\n   237→    expect(result.success).toBe(false);\n   238→    if (result.success) return;\n   239→    expect(result.error).toContain('Failed to parse proof');\n   240→    expect(result.error).toContain('EACCES');\n   241→  });\n   242→});\n   243→\n   244→describe('writeVerificationFindings', () => {\n   245→  const STORY_CONTENT = `# Story 3.3\n   246→\n   247→## Acceptance Criteria\n   248→\n   249→1. Some AC\n   250→\n   251→## Tasks / Subtasks\n   252→\n   253→- [ ] Task 1\n   254→\n   255→## Dev Agent Record\n   256→\n   257→### Agent Model Used\n   258→`;\n   259→\n   260→  const STORY_WITH_FINDINGS = `# Story 3.3\n   261→\n   262→## Acceptance Criteria\n   263→\n   264→1. Some AC\n   265→\n   266→## Verification Findings\n   267→\n   268→_Last updated: 2026-01-01T00:00:00.000Z_\n   269→\n   270→The following ACs failed black-box verification:\n   271→\n   272→### AC 1: Old finding\n   273→**Verdict:** FAIL\n   274→**Error output:**\n   275→\\`\\`\\`\n   276→old error\n   277→\\`\\`\\`\n   278→\n   279→## Dev Agent Record\n   280→\n   281→### Agent Model Used\n   282→`;\n   283→\n   284→  it('appends findings section to story file before Dev Agent Record', () => {\n   285→    mockedExistsSync.mockReturnValue(true);\n   286→    mockedReadFileSync.mockReturnValue(STORY_CONTENT);\n   287→\n   288→    const failingAcs = [\n   289→      { acNumber: 2, description: 'Test fails', errorOutput: 'Error: boom', verdict: 'FAIL' },\n   290→    ];\n   291→\n   292→    const result = writeVerificationFindings('3-3-test', failingAcs);\n   293→    expect(result.success).toBe(true);\n   294→\n   295→    expect(mockedWriteFileSync).toHaveBeenCalledTimes(1);\n   296→    const written = mockedWriteFileSync.mock.calls[0][1] as string;\n   297→    expect(written).toContain('## Verification Findings');\n   298→    expect(written).toContain('### AC 2: Test fails');\n   299→    expect(written).toContain('**Verdict:** FAIL');\n   300→    expect(written).toContain('Error: boom');\n   301→    // Findings should appear before Dev Agent Record\n   302→    const findingsIdx = written.indexOf('## Verification Findings');\n   303→    const devAgentIdx = written.indexOf('## Dev Agent Record');\n   304→    expect(findingsIdx).toBeLessThan(devAgentIdx);\n   305→  });\n   306→\n   307→  it('replaces existing findings section', () => {\n   308→    mockedExistsSync.mockReturnValue(true);\n   309→    mockedReadFileSync.mockReturnValue(STORY_WITH_FINDINGS);\n   310→\n   311→    const failingAcs = [\n   312→      { acNumber: 5, description: 'New failure', errorOutput: 'new error', verdict: 'FAIL' },\n   313→    ];\n   314→\n   315→    const result = writeVerificationFindings('3-3-test', failingAcs);\n   316→    expect(result.success).toBe(true);\n   317→\n   318→    const written = mockedWriteFileSync.mock.calls[0][1] as string;\n   319→    expect(written).toContain('### AC 5: New failure');\n   320→    expect(written).not.toContain('Old finding');\n   321→    expect(written).not.toContain('old error');\n   322→    // Should still have Dev Agent Record\n   323→    expect(written).toContain('## Dev Agent Record');\n   324→  });\n   325→\n   326→  it('replaces existing findings section when it is the last section (no following heading)', () => {\n   327→    const storyFindingsAtEnd = `# Story 3.3\n   328→\n   329→## Acceptance Criteria\n   330→\n   331→1. Some AC\n   332→\n   333→## Verification Findings\n   334→\n   335→_Last updated: 2026-01-01T00:00:00.000Z_\n   336→\n   337→The following ACs failed black-box verification:\n   338→\n   339→### AC 1: Old finding\n   340→**Verdict:** FAIL\n   341→**Error output:**\n   342→\\`\\`\\`\n   343→old error\n   344→\\`\\`\\`\n   345→`;\n   346→    mockedExistsSync.mockReturnValue(true);\n   347→    mockedReadFileSync.mockReturnValue(storyFindingsAtEnd);\n   348→\n   349→    const failingAcs = [\n   350→      { acNumber: 3, description: 'New fail', errorOutput: 'new err', verdict: 'FAIL' },\n   351→    ];\n   352→\n   353→    const result = writeVerificationFindings('3-3-test', failingAcs);\n   354→    expect(result.success).toBe(true);\n   355→\n   356→    const written = mockedWriteFileSync.mock.calls[0][1] as string;\n   357→    expect(written).toContain('### AC 3: New fail');\n   358→    expect(written).not.toContain('Old finding');\n   359→    expect(written).not.toContain('old error');\n   360→  });\n   361→\n   362→  it('returns fail() on missing story file', () => {\n   363→    mockedExistsSync.mockReturnValue(false);\n   364→\n   365→    const result = writeVerificationFindings('nonexistent', []);\n   366→    expect(result.success).toBe(false);\n   367→    if (result.success) return;\n   368→    expect(result.error).toContain('Story file not found');\n   369→  });\n   370→\n   371→  it('returns fail() on write error', () => {\n   372→    mockedExistsSync.mockReturnValue(true);\n   373→    mockedReadFileSync.mockReturnValue(STORY_CONTENT);\n   374→    mockedWriteFileSync.mockImplementation(() => {\n   375→      throw new Error('ENOSPC: disk full');\n   376→    });\n   377→\n   378→    const result = writeVerificationFindings('3-3-test', [\n   379→      { acNumber: 1, description: 'x', errorOutput: 'y', verdict: 'FAIL' },\n   380→    ]);\n   381→    expect(result.success).toBe(false);\n   382→    if (result.success) return;\n   383→    expect(result.error).toContain('Failed to write verification findings');\n   384→  });\n   385→\n   386→  it('appends at end when no Dev Agent Record section exists', () => {\n   387→    const contentNoDevAgent = '# Story\\n\\n## Tasks\\n\\n- [ ] Task 1\\n';\n   388→    mockedExistsSync.mockReturnValue(true);\n   389→    mockedReadFileSync.mockReturnValue(contentNoDevAgent);\n   390→\n   391→    const result = writeVerificationFindings('3-3-test', [\n   392→      { acNumber: 1, description: 'Fail', errorOutput: 'err', verdict: 'FAIL' },\n   393→    ]);\n   394→    expect(result.success).toBe(true);\n   395→\n   396→    const written = mockedWriteFileSync.mock.calls[0][1] as string;\n   397→    expect(written).toContain('## Verification Findings');\n   398→    expect(written).toContain('### AC 1: Fail');\n   399→  });\n   400→});\n   401→\n   402→describe('processVerifyResult', () => {\n   403→  function mockState(attempts: number, status: string = 'verifying'): void {\n   404→    mockedGetSprintState.mockReturnValue({\n   405→      success: true,\n   406→      data: buildSprintStateWithStory('3-3-test', {\n   407→        status: status as 'verifying',\n   408→        attempts,\n   409→        lastAttempt: '2026-01-01T00:00:00Z',\n   410→      }),\n   411→    });\n   412→  }\n   413→\n   414→  it('returns action: \"return-to-dev\" with failing ACs', () => {\n   415→    // proof has failures\n   416→    mockedExistsSync.mockReturnValue(true);\n   417→    mockedReadFileSync\n   418→      .mockReturnValueOnce(PROOF_WITH_FAILURES) // parseProofForFailures\n   419→      .mockReturnValueOnce(`# Story\\n\\n## Dev Agent Record\\n`); // writeVerificationFindings\n   420→    mockState(2);\n   421→    mockedUpdateStoryStatus.mockReturnValue({ success: true, data: undefined });\n   422→\n   423→    const result = processVerifyResult('3-3-test');\n   424→    expect(result.success).toBe(true);\n   425→    if (!result.success) return;\n   426→\n   427→    expect(result.data.action).toBe('return-to-dev');\n   428→    expect(result.data.storyKey).toBe('3-3-test');\n   429→    expect(result.data.failingAcs).toHaveLength(2);\n   430→    expect(result.data.attempts).toBe(3); // was 2, incremented to 3\n   431→\n   432→    // Should have called updateStoryStatus with 'in-progress'\n   433→    expect(mockedUpdateStoryStatus).toHaveBeenCalledWith('3-3-test', 'in-progress');\n   434→  });\n   435→\n   436→  it('returns action: \"mark-done\" when all pass', () => {\n   437→    mockedExistsSync.mockReturnValue(true);\n   438→    mockedReadFileSync.mockReturnValueOnce(PROOF_ALL_PASS);\n   439→    mockState(3);\n   440→    mockedUpdateStoryStatus.mockReturnValue({ success: true, data: undefined });\n   441→\n   442→    const result = processVerifyResult('3-3-test');\n   443→    expect(result.success).toBe(true);\n   444→    if (!result.success) return;\n   445→\n   446→    expect(result.data.action).toBe('mark-done');\n   447→    expect(result.data.failingAcs).toHaveLength(0);\n   448→    expect(result.data.attempts).toBe(3);\n   449→\n   450→    expect(mockedUpdateStoryStatus).toHaveBeenCalledWith('3-3-test', 'done');\n   451→  });\n   452→\n   453→  it('returns action: \"mark-blocked\" when attempts >= maxAttempts (default 10)', () => {\n   454→    mockedExistsSync.mockReturnValue(true);\n   455→    mockedReadFileSync.mockReturnValueOnce(PROOF_WITH_FAILURES);\n   456→    mockState(10);\n   457→    mockedUpdateStoryStatus.mockReturnValue({ success: true, data: undefined });\n   458→\n   459→    const result = processVerifyResult('3-3-test');\n   460→    expect(result.success).toBe(true);\n   461→    if (!result.success) return;\n   462→\n   463→    expect(result.data.action).toBe('mark-blocked');\n   464→    expect(result.data.attempts).toBe(10);\n   465→\n   466→    expect(mockedUpdateStoryStatus).toHaveBeenCalledWith('3-3-test', 'blocked', {\n   467→      error: 'verify-dev-cycle-limit',\n   468→    });\n   469→  });\n   470→\n   471→  it('returns action: \"mark-blocked\" with custom maxAttempts', () => {\n   472→    mockedExistsSync.mockReturnValue(true);\n   473→    mockedReadFileSync.mockReturnValueOnce(PROOF_WITH_FAILURES);\n   474→    mockState(3);\n   475→    mockedUpdateStoryStatus.mockReturnValue({ success: true, data: undefined });\n   476→\n   477→    const result = processVerifyResult('3-3-test', { maxAttempts: 3 });\n   478→    expect(result.success).toBe(true);\n   479→    if (!result.success) return;\n   480→\n   481→    expect(result.data.action).toBe('mark-blocked');\n   482→  });\n   483→\n   484→  it('increments attempt count via updateStoryStatus(key, \"in-progress\")', () => {\n   485→    mockedExistsSync.mockReturnValue(true);\n   486→    mockedReadFileSync\n   487→      .mockReturnValueOnce(PROOF_WITH_FAILURES)\n   488→      .mockReturnValueOnce('# Story\\n\\n## Dev Agent Record\\n');\n   489→    mockState(0);\n   490→    mockedUpdateStoryStatus.mockReturnValue({ success: true, data: undefined });\n   491→\n   492→    const result = processVerifyResult('3-3-test');\n   493→    expect(result.success).toBe(true);\n   494→    if (!result.success) return;\n   495→\n   496→    expect(result.data.action).toBe('return-to-dev');\n   497→    expect(result.data.attempts).toBe(1);\n   498→    expect(mockedUpdateStoryStatus).toHaveBeenCalledWith('3-3-test', 'in-progress');\n   499→  });\n   500→\n   501→  it('reads existing attempt count from state (persistence across sessions)', () => {\n   502→    mockedExistsSync.mockReturnValue(true);\n   503→    mockedReadFileSync\n   504→      .mockReturnValueOnce(PROOF_WITH_FAILURES)\n   505→      .mockReturnValueOnce('# Story\\n\\n## Dev Agent Record\\n');\n   506→    mockState(7);\n   507→    mockedUpdateStoryStatus.mockReturnValue({ success: true, data: undefined });\n   508→\n   509→    const result = processVerifyResult('3-3-test');\n   510→    expect(result.success).toBe(true);\n   511→    if (!result.success) return;\n   512→\n   513→    expect(result.data.attempts).toBe(8); // 7 + 1\n   514→    expect(result.data.action).toBe('return-to-dev');\n   515→  });\n   516→\n   517→  it('returns fail() when proof file is missing', () => {\n   518→    mockedExistsSync.mockReturnValue(false);\n   519→\n   520→    const result = processVerifyResult('nonexistent-story');\n   521→    expect(result.success).toBe(false);\n   522→    if (result.success) return;\n   523→    expect(result.error).toContain('Proof file not found');\n   524→  });\n   525→\n   526→  it('returns fail() when getSprintState fails', () => {\n   527→    mockedExistsSync.mockReturnValue(true);\n   528→    mockedReadFileSync.mockReturnValueOnce(PROOF_WITH_FAILURES);\n   529→    mockedGetSprintState.mockReturnValue({\n   530→      success: false,\n   531→      error: 'corrupt state file',\n   532→    });\n   533→\n   534→    const result = processVerifyResult('3-3-test');\n   535→    expect(result.success).toBe(false);\n   536→    if (result.success) return;\n   537→    expect(result.error).toContain('corrupt state file');\n   538→  });\n   539→\n   540→  it('returns fail() when updateStoryStatus fails on mark-done', () => {\n   541→    mockedExistsSync.mockReturnValue(true);\n   542→    mockedReadFileSync.mockReturnValueOnce(PROOF_ALL_PASS);\n   543→    mockState(1);\n   544→    mockedUpdateStoryStatus.mockReturnValue({\n   545→      success: false,\n   546→      error: 'write failed',\n   547→    });\n   548→\n   549→    const result = processVerifyResult('3-3-test');\n   550→    expect(result.success).toBe(false);\n   551→    if (result.success) return;\n   552→    expect(result.error).toContain('write failed');\n   553→  });\n   554→\n   555→  it('returns fail() when updateStoryStatus fails on mark-blocked', () => {\n   556→    mockedExistsSync.mockReturnValue(true);\n   557→    mockedReadFileSync.mockReturnValueOnce(PROOF_WITH_FAILURES);\n   558→    mockState(10);\n   559→    mockedUpdateStoryStatus.mockReturnValue({\n   560→      success: false,\n   561→      error: 'blocked write failed',\n   562→    });\n   563→\n   564→    const result = processVerifyResult('3-3-test');\n   565→    expect(result.success).toBe(false);\n   566→    if (result.success) return;\n   567→    expect(result.error).toContain('blocked write failed');\n   568→  });\n   569→\n   570→  it('returns fail() when writeVerificationFindings fails during return-to-dev', () => {\n   571→    // Proof has failures, state is OK, but story file is missing for writeVerificationFindings\n   572→    mockedExistsSync\n   573→      .mockReturnValueOnce(true) // proof file exists\n   574→      .mockReturnValueOnce(false); // story file does NOT exist\n   575→    mockedReadFileSync.mockReturnValueOnce(PROOF_WITH_FAILURES);\n   576→    mockState(2);\n   577→    mockedUpdateStoryStatus.mockReturnValue({ success: true, data: undefined });\n   578→\n   579→    const result = processVerifyResult('3-3-test');\n   580→    expect(result.success).toBe(false);\n   581→    if (result.success) return;\n   582→    expect(result.error).toContain('Story file not found');\n   583→  });\n   584→\n   585→  it('returns fail() when updateStoryStatus fails during return-to-dev (before findings write)', () => {\n   586→    mockedExistsSync.mockReturnValue(true);\n   587→    mockedReadFileSync.mockReturnValueOnce(PROOF_WITH_FAILURES);\n   588→    mockState(2);\n   589→    mockedUpdateStoryStatus.mockReturnValue({\n   590→      success: false,\n   591→      error: 'disk full during return-to-dev',\n   592→    });\n   593→\n   594→    const result = processVerifyResult('3-3-test');\n   595→    expect(result.success).toBe(false);\n   596→    if (result.success) return;\n   597→    expect(result.error).toContain('disk full during return-to-dev');\n   598→    // Findings should NOT have been written since state update failed first\n   599→    expect(mockedWriteFileSync).not.toHaveBeenCalled();\n   600→  });\n   601→\n   602→  it('handles story with no prior state entry (defaults to 0 attempts)', () => {\n   603→    mockedExistsSync.mockReturnValue(true);\n   604→    mockedReadFileSync\n   605→      .mockReturnValueOnce(PROOF_WITH_FAILURES)\n   606→      .mockReturnValueOnce('# Story\\n\\n## Dev Agent Record\\n');\n   607→    mockedGetSprintState.mockReturnValue({\n   608→      success: true,\n   609→      data: buildSprintState(),\n   610→    });\n   611→    mockedUpdateStoryStatus.mockReturnValue({ success: true, data: undefined });\n   612→\n   613→    const result = processVerifyResult('3-3-test');\n   614→    expect(result.success).toBe(true);\n   615→    if (!result.success) return;\n   616→    expect(result.data.attempts).toBe(1);\n   617→    expect(result.data.action).toBe('return-to-dev');\n   618→  });\n   619→\n   620→  it('catches unexpected errors in processVerifyResult outer try/catch', () => {\n   621→    mockedExistsSync.mockReturnValue(true);\n   622→    mockedReadFileSync.mockReturnValueOnce(PROOF_ALL_PASS);\n   623→    // Make getSprintState throw instead of returning a Result\n   624→    mockedGetSprintState.mockImplementation(() => {\n   625→      throw new Error('unexpected kaboom');\n   626→    });\n   627→\n   628→    const result = processVerifyResult('3-3-test');\n   629→    expect(result.success).toBe(false);\n   630→    if (result.success) return;\n   631→    expect(result.error).toContain('Failed to process verify result');\n   632→    expect(result.error).toContain('unexpected kaboom');\n   633→  });\n   634→});\n   635→\n   636→describe('all functions return Result<T> — never throw', () => {\n   637→  it('parseProofForFailures never throws', () => {\n   638→    mockedExistsSync.mockReturnValue(true);\n   639→    mockedReadFileSync.mockImplementation(() => { throw new Error('crash'); });\n   640→    expect(() => parseProofForFailures('/tmp/proof.md')).not.toThrow();\n   641→    const result = parseProofForFailures('/tmp/proof.md');\n   642→    expect(result.success).toBe(false);\n   643→  });\n   644→\n   645→  it('parseProofForFailures handles non-Error thrown values', () => {\n   646→    mockedExistsSync.mockReturnValue(true);\n   647→    mockedReadFileSync.mockImplementation(() => { throw 'string error'; });\n   648→    const result = parseProofForFailures('/tmp/proof.md');\n   649→    expect(result.success).toBe(false);\n   650→    if (!result.success) {\n   651→      expect(result.error).toContain('string error');\n   652→    }\n   653→  });\n   654→\n   655→  it('writeVerificationFindings never throws', () => {\n   656→    mockedExistsSync.mockReturnValue(true);\n   657→    mockedReadFileSync.mockImplementation(() => { throw new Error('crash'); });\n   658→    expect(() => writeVerificationFindings('key', [])).not.toThrow();\n   659→    const result = writeVerificationFindings('key', []);\n   660→    expect(result.success).toBe(false);\n   661→  });\n   662→\n   663→  it('writeVerificationFindings handles non-Error thrown values', () => {\n   664→    mockedExistsSync.mockReturnValue(true);\n   665→    mockedReadFileSync.mockImplementation(() => { throw 42; });\n   666→    const result = writeVerificationFindings('key', []);\n   667→    expect(result.success).toBe(false);\n   668→    if (!result.success) {\n   669→      expect(result.error).toContain('42');\n   670→    }\n   671→  });\n   672→\n   673→  it('processVerifyResult never throws', () => {\n   674→    mockedExistsSync.mockImplementation(() => { throw new Error('crash'); });\n   675→    expect(() => processVerifyResult('key')).not.toThrow();\n   676→    const result = processVerifyResult('key');\n   677→    expect(result.success).toBe(false);\n   678→  });\n   679→\n   680→  it('processVerifyResult handles non-Error thrown values in outer catch', () => {\n   681→    // Make existsSync and readFileSync work for parseProofForFailures,\n   682→    // then make getSprintState throw a non-Error value\n   683→    mockedExistsSync.mockReturnValue(true);\n   684→    mockedReadFileSync.mockReturnValueOnce(PROOF_ALL_PASS);\n   685→    mockedGetSprintState.mockImplementation(() => { throw 'non-error string'; });\n   686→    const result = processVerifyResult('key');\n   687→    expect(result.success).toBe(false);\n   688→    if (!result.success) {\n   689→      expect(result.error).toContain('Failed to process verify result');\n   690→      expect(result.error).toContain('non-error string');\n   691→    }\n   692→  });\n   693→});\n   694→"}]},"parent_tool_use_id":"toolu_01E4d2UoNxdYuxQTG5Dezgge","session_id":"8c35c2f7-0e10-4994-a438-2b5cecce3396","uuid":"a6a66204-dd8b-4580-add2-1b1adf249065","timestamp":"2026-03-24T14:16:35.844Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014N3wAbwmJfdV3whNxp8cXC","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { selectNextStory, MAX_STORY_ATTEMPTS } from '../selector.js';\n     3→import type { SprintState, StoryState } from '../../../types/state.js';\n     4→import { buildSprintState, buildStoryEntry } from '../../../lib/__tests__/helpers.js';\n     5→\n     6→/** Helper: build a SprintState with given partial stories */\n     7→function makeState(\n     8→  stories: Record<string, Partial<StoryState>>,\n     9→): SprintState {\n    10→  const full: Record<string, StoryState> = {};\n    11→  for (const [key, partial] of Object.entries(stories)) {\n    12→    full[key] = buildStoryEntry(partial);\n    13→  }\n    14→  return buildSprintState({ stories: full });\n    15→}\n    16→\n    17→/** Helper: build a bad state that throws on stories access */\n    18→function makeBadState(throwValue: unknown): SprintState {\n    19→  const base = buildSprintState();\n    20→  return {\n    21→    ...base,\n    22→    get stories() { throw throwValue; },\n    23→  } as unknown as SprintState;\n    24→}\n    25→\n    26→describe('selectNextStory', () => {\n    27→  it('returns ok with null selected when stories map is empty', () => {\n    28→    const result = selectNextStory(makeState({}));\n    29→    expect(result.success).toBe(true);\n    30→    if (result.success) {\n    31→      expect(result.data.selected).toBeNull();\n    32→      expect(result.data.retryExhausted).toEqual([]);\n    33→    }\n    34→  });\n    35→\n    36→  it('returns ok with null selected when all stories are terminal', () => {\n    37→    const state = makeState({\n    38→      'story-a': { status: 'done' },\n    39→      'story-b': { status: 'failed' },\n    40→      'story-c': { status: 'blocked' },\n    41→    });\n    42→    const result = selectNextStory(state);\n    43→    expect(result.success).toBe(true);\n    44→    if (result.success) {\n    45→      expect(result.data.selected).toBeNull();\n    46→      expect(result.data.retryExhausted).toEqual([]);\n    47→    }\n    48→  });\n    49→\n    50→  it('reports retry-exhausted stories in retryExhausted array', () => {\n    51→    const state = makeState({\n    52→      'story-a': { status: 'backlog', attempts: 10 },\n    53→      'story-b': { status: 'backlog', attempts: 15 },\n    54→    });\n    55→    const result = selectNextStory(state);\n    56→    expect(result.success).toBe(true);\n    57→    if (result.success) {\n    58→      expect(result.data.selected).toBeNull();\n    59→      expect(result.data.retryExhausted).toHaveLength(2);\n    60→      const keys = result.data.retryExhausted.map((r) => r.key).sort();\n    61→      expect(keys).toEqual(['story-a', 'story-b']);\n    62→      for (const info of result.data.retryExhausted) {\n    63→        expect(info.reason).toBe('retry-exhausted');\n    64→      }\n    65→    }\n    66→  });\n    67→\n    68→  it('retry-exhausted stories report correct attempt counts', () => {\n    69→    const state = makeState({ 'story-x': { status: 'verifying', attempts: 12 } });\n    70→    const result = selectNextStory(state);\n    71→    expect(result.success).toBe(true);\n    72→    if (result.success) {\n    73→      expect(result.data.retryExhausted).toHaveLength(1);\n    74→      expect(result.data.retryExhausted[0]).toEqual({\n    75→        key: 'story-x', attempts: 12, reason: 'retry-exhausted',\n    76→      });\n    77→    }\n    78→  });\n    79→\n    80→  it('does not report terminal stories as retry-exhausted even with high attempts', () => {\n    81→    const state = makeState({\n    82→      'story-done': { status: 'done', attempts: 15 },\n    83→      'story-failed': { status: 'failed', attempts: 20 },\n    84→      'story-blocked': { status: 'blocked', attempts: 10 },\n    85→    });\n    86→    const result = selectNextStory(state);\n    87→    expect(result.success).toBe(true);\n    88→    if (result.success) {\n    89→      expect(result.data.selected).toBeNull();\n    90→      expect(result.data.retryExhausted).toEqual([]);\n    91→    }\n    92→  });\n    93→\n    94→  it('returns in-progress story before all others', () => {\n    95→    const state = makeState({\n    96→      'story-backlog': { status: 'backlog' },\n    97→      'story-verifying': { status: 'verifying' },\n    98→      'story-current': { status: 'in-progress', attempts: 3 },\n    99→    });\n   100→    const result = selectNextStory(state);\n   101→    expect(result.success).toBe(true);\n   102→    if (result.success) {\n   103→      expect(result.data.selected!.key).toBe('story-current');\n   104→      expect(result.data.selected!.priority).toBe(0);\n   105→    }\n   106→  });\n   107→\n   108→  it('returns verifying-with-proof before plain verifying', () => {\n   109→    const state = makeState({\n   110→      'story-no-proof': { status: 'verifying', proofPath: null },\n   111→      'story-has-proof': { status: 'verifying', proofPath: 'docs/proof.md' },\n   112→    });\n   113→    const result = selectNextStory(state);\n   114→    expect(result.success).toBe(true);\n   115→    if (result.success) {\n   116→      expect(result.data.selected!.key).toBe('story-has-proof');\n   117→      expect(result.data.selected!.priority).toBe(1);\n   118→    }\n   119→  });\n   120→\n   121→  it('returns verifying before backlog', () => {\n   122→    const state = makeState({\n   123→      'story-backlog': { status: 'backlog' },\n   124→      'story-verifying': { status: 'verifying' },\n   125→    });\n   126→    const result = selectNextStory(state);\n   127→    expect(result.success).toBe(true);\n   128→    if (result.success) {\n   129→      expect(result.data.selected!.key).toBe('story-verifying');\n   130→      expect(result.data.selected!.priority).toBe(2);\n   131→    }\n   132→  });\n   133→\n   134→  it('full priority ordering: in-progress > proof > verifying > backlog', () => {\n   135→    const state = makeState({\n   136→      'story-backlog': { status: 'backlog' },\n   137→      'story-verifying': { status: 'verifying' },\n   138→      'story-proof': { status: 'verifying', proofPath: 'proof.md' },\n   139→      'story-active': { status: 'in-progress' },\n   140→    });\n   141→    const result = selectNextStory(state);\n   142→    expect(result.success).toBe(true);\n   143→    if (result.success) {\n   144→      expect(result.data.selected!.key).toBe('story-active');\n   145→      expect(result.data.selected!.priority).toBe(0);\n   146→    }\n   147→  });\n   148→\n   149→  it('same-tier tiebreak: fewer attempts first', () => {\n   150→    const state = makeState({\n   151→      'story-a': { status: 'backlog', attempts: 5 },\n   152→      'story-b': { status: 'backlog', attempts: 2 },\n   153→      'story-c': { status: 'backlog', attempts: 8 },\n   154→    });\n   155→    const result = selectNextStory(state);\n   156→    expect(result.success).toBe(true);\n   157→    if (result.success) expect(result.data.selected!.key).toBe('story-b');\n   158→  });\n   159→\n   160→  it('same-tier same-attempts tiebreak: lexicographic key order', () => {\n   161→    const state = makeState({\n   162→      'story-charlie': { status: 'backlog', attempts: 0 },\n   163→      'story-alpha': { status: 'backlog', attempts: 0 },\n   164→      'story-bravo': { status: 'backlog', attempts: 0 },\n   165→    });\n   166→    const result = selectNextStory(state);\n   167→    expect(result.success).toBe(true);\n   168→    if (result.success) expect(result.data.selected!.key).toBe('story-alpha');\n   169→  });\n   170→\n   171→  it('cross-epic selection: considers stories from all epics equally', () => {\n   172→    const state = makeState({\n   173→      'epic-2-story-a': { status: 'backlog', attempts: 3 },\n   174→      'epic-3-story-b': { status: 'backlog', attempts: 1 },\n   175→      'epic-2-story-c': { status: 'verifying' },\n   176→    });\n   177→    const result = selectNextStory(state);\n   178→    expect(result.success).toBe(true);\n   179→    if (result.success) expect(result.data.selected!.key).toBe('epic-2-story-c');\n   180→  });\n   181→\n   182→  it.each([\n   183→    ['done', 'done' as const],\n   184→    ['failed', 'failed' as const],\n   185→    ['blocked', 'blocked' as const],\n   186→  ])('excludes %s stories from selection', (_label, status) => {\n   187→    const state = makeState({\n   188→      'story-terminal': { status },\n   189→      'story-backlog': { status: 'backlog' },\n   190→    });\n   191→    const result = selectNextStory(state);\n   192→    expect(result.success).toBe(true);\n   193→    if (result.success) expect(result.data.selected!.key).toBe('story-backlog');\n   194→  });\n   195→\n   196→  it('selects story with attempts < 10 but reports one with attempts >= 10', () => {\n   197→    const state = makeState({\n   198→      'story-exhausted': { status: 'backlog', attempts: 10 },\n   199→      'story-ok': { status: 'backlog', attempts: 9 },\n   200→    });\n   201→    const result = selectNextStory(state);\n   202→    expect(result.success).toBe(true);\n   203→    if (result.success) {\n   204→      expect(result.data.selected!.key).toBe('story-ok');\n   205→      expect(result.data.retryExhausted).toHaveLength(1);\n   206→      expect(result.data.retryExhausted[0].key).toBe('story-exhausted');\n   207→    }\n   208→  });\n   209→\n   210→  it('populates title from key', () => {\n   211→    const state = makeState({ 'my-cool-story': { status: 'backlog' } });\n   212→    const result = selectNextStory(state);\n   213→    expect(result.success).toBe(true);\n   214→    if (result.success) expect(result.data.selected!.title).toBe('My cool story');\n   215→  });\n   216→\n   217→  it('handles empty key in title generation', () => {\n   218→    const state = makeState({ '': { status: 'backlog' } });\n   219→    const result = selectNextStory(state);\n   220→    expect(result.success).toBe(true);\n   221→    if (result.success) expect(result.data.selected!.title).toBe('');\n   222→  });\n   223→\n   224→  it('returns fail() on Error throw', () => {\n   225→    const result = selectNextStory(makeBadState(new Error('corrupt state')));\n   226→    expect(result.success).toBe(false);\n   227→    if (!result.success) {\n   228→      expect(result.error).toContain('Story selection failed');\n   229→      expect(result.error).toContain('corrupt state');\n   230→    }\n   231→  });\n   232→\n   233→  it('returns fail() on non-Error throw', () => {\n   234→    const result = selectNextStory(makeBadState('string error'));\n   235→    expect(result.success).toBe(false);\n   236→    if (!result.success) expect(result.error).toContain('string error');\n   237→  });\n   238→\n   239→  it('handles ready and review statuses as backlog-tier', () => {\n   240→    const state = makeState({\n   241→      'story-ready': { status: 'ready' },\n   242→      'story-review': { status: 'review', attempts: 1 },\n   243→    });\n   244→    const result = selectNextStory(state);\n   245→    expect(result.success).toBe(true);\n   246→    if (result.success) {\n   247→      expect(result.data.selected!.key).toBe('story-ready');\n   248→      expect(result.data.selected!.priority).toBe(3);\n   249→    }\n   250→  });\n   251→\n   252→  it('MAX_STORY_ATTEMPTS is 10', () => {\n   253→    expect(MAX_STORY_ATTEMPTS).toBe(10);\n   254→  });\n   255→\n   256→  it('mixed scenario: selects actionable and reports exhausted', () => {\n   257→    const state = makeState({\n   258→      'story-done': { status: 'done' },\n   259→      'story-exhausted-1': { status: 'in-progress', attempts: 10 },\n   260→      'story-exhausted-2': { status: 'backlog', attempts: 11 },\n   261→      'story-good': { status: 'verifying', proofPath: 'p.md' },\n   262→      'story-blocked': { status: 'blocked' },\n   263→    });\n   264→    const result = selectNextStory(state);\n   265→    