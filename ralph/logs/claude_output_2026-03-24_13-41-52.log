n    46→    expect(state.verification_log).toEqual([]);\n    47→  });\n    48→\n    49→  it('returns correct defaults with a stack', () => {\n    50→    const state = getDefaultState('nodejs');\n    51→    expect(state.stack).toBe('nodejs');\n    52→  });\n    53→\n    54→  it('treats explicit null as null', () => {\n    55→    const state = getDefaultState(null);\n    56→    expect(state.stack).toBeNull();\n    57→  });\n    58→\n    59→  it('defaults coverage tool to cargo-tarpaulin for rust stack', () => {\n    60→    const state = getDefaultState('rust');\n    61→    expect(state.coverage.tool).toBe('cargo-tarpaulin');\n    62→  });\n    63→\n    64→  it('defaults coverage tool to coverage.py for python stack', () => {\n    65→    const state = getDefaultState('python');\n    66→    expect(state.coverage.tool).toBe('coverage.py');\n    67→  });\n    68→\n    69→  it('defaults coverage tool to c8 for nodejs stack', () => {\n    70→    const state = getDefaultState('nodejs');\n    71→    expect(state.coverage.tool).toBe('c8');\n    72→  });\n    73→});\n    74→\n    75→describe('writeState', () => {\n    76→  it('creates .claude directory if it does not exist', () => {\n    77→    const state = getDefaultState('nodejs');\n    78→    writeState(state, testDir);\n    79→    expect(existsSync(join(testDir, '.claude'))).toBe(true);\n    80→  });\n    81→\n    82→  it('creates file with valid YAML frontmatter', () => {\n    83→    const state = getDefaultState('nodejs');\n    84→    writeState(state, testDir);\n    85→    const content = readFileSync(getStatePath(testDir), 'utf-8');\n    86→    expect(content.startsWith('---\\n')).toBe(true);\n    87→    expect(content).toContain('---\\n');\n    88→    // Should have two --- delimiters\n    89→    const parts = content.split('---');\n    90→    expect(parts.length).toBeGreaterThanOrEqual(3);\n    91→  });\n    92→\n    93→  it('uses snake_case field names', () => {\n    94→    const state = getDefaultState('nodejs');\n    95→    writeState(state, testDir);\n    96→    const content = readFileSync(getStatePath(testDir), 'utf-8');\n    97→    expect(content).toContain('harness_version');\n    98→    expect(content).toContain('session_flags');\n    99→    expect(content).toContain('logs_queried');\n   100→    expect(content).toContain('tests_passed');\n   101→    expect(content).toContain('coverage_met');\n   102→    expect(content).toContain('verification_run');\n   103→    expect(content).toContain('verification_log');\n   104→    // No camelCase\n   105→    expect(content).not.toContain('harnessVersion');\n   106→    expect(content).not.toContain('sessionFlags');\n   107→  });\n   108→\n   109→  it('writes boolean values as YAML native true/false', () => {\n   110→    const state = getDefaultState();\n   111→    state.initialized = true;\n   112→    writeState(state, testDir);\n   113→    const content = readFileSync(getStatePath(testDir), 'utf-8');\n   114→    expect(content).toContain('initialized: true');\n   115→    expect(content).toContain('logs_queried: false');\n   116→    expect(content).not.toContain('\"true\"');\n   117→    expect(content).not.toContain('\"false\"');\n   118→  });\n   119→\n   120→  it('writes null values as YAML null', () => {\n   121→    const state = getDefaultState();\n   122→    writeState(state, testDir);\n   123→    const content = readFileSync(getStatePath(testDir), 'utf-8');\n   124→    expect(content).toContain('baseline: null');\n   125→    expect(content).toContain('current: null');\n   126→    expect(content).toContain('stack: null');\n   127→  });\n   128→\n   129→  it('includes default markdown body', () => {\n   130→    const state = getDefaultState();\n   131→    writeState(state, testDir);\n   132→    const content = readFileSync(getStatePath(testDir), 'utf-8');\n   133→    expect(content).toContain('# Codeharness State');\n   134→    expect(content).toContain('Do not edit manually');\n   135→  });\n   136→\n   137→  it('preserves custom body', () => {\n   138→    const state = getDefaultState();\n   139→    const customBody = '\\n# Custom Body\\n\\nSome custom content.\\n';\n   140→    writeState(state, testDir, customBody);\n   141→    const content = readFileSync(getStatePath(testDir), 'utf-8');\n   142→    expect(content).toContain('# Custom Body');\n   143→    expect(content).toContain('Some custom content.');\n   144→  });\n   145→});\n   146→\n   147→describe('readState', () => {\n   148→  it('parses YAML frontmatter and returns typed object', () => {\n   149→    const original = getDefaultState('nodejs');\n   150→    original.initialized = true;\n   151→    writeState(original, testDir);\n   152→    const read = readState(testDir);\n   153→    expect(read.harness_version).toBe('0.1.0');\n   154→    expect(read.initialized).toBe(true);\n   155→    expect(read.stack).toBe('nodejs');\n   156→    expect(read.enforcement.frontend).toBe(true);\n   157→    expect(read.coverage.target).toBe(90);\n   158→    expect(read.coverage.baseline).toBeNull();\n   159→    expect(read.session_flags.tests_passed).toBe(false);\n   160→    expect(read.verification_log).toEqual([]);\n   161→  });\n   162→\n   163→  it('throws StateFileNotFoundError when file does not exist', () => {\n   164→    expect(() => readState(testDir)).toThrow(StateFileNotFoundError);\n   165→  });\n   166→\n   167→  it('preserves markdown body on round-trip', () => {\n   168→    const state = getDefaultState('nodejs');\n   169→    const body = '\\n# My Custom Notes\\n\\nSome important info.\\n';\n   170→    writeState(state, testDir, body);\n   171→\n   172→    const { state: readBack, body: readBody } = readStateWithBody(testDir);\n   173→    expect(readBack.stack).toBe('nodejs');\n   174→    expect(readBody).toContain('# My Custom Notes');\n   175→    expect(readBody).toContain('Some important info.');\n   176→\n   177→    // Write back with preserved body\n   178→    readBack.initialized = true;\n   179→    writeState(readBack, testDir, readBody);\n   180→\n   181→    const final = readFileSync(getStatePath(testDir), 'utf-8');\n   182→    expect(final).toContain('initialized: true');\n   183→    expect(final).toContain('# My Custom Notes');\n   184→  });\n   185→\n   186→  it('recovers from corrupted YAML', () => {\n   187→    const claudeDir = join(testDir, '.claude');\n   188→    mkdirSync(claudeDir, { recursive: true });\n   189→    writeFileSync(join(claudeDir, 'codeharness.local.md'), '---\\n{invalid yaml: [[\\n---\\n', 'utf-8');\n   190→\n   191→    const consoleSpy = vi.spyOn(console, 'log');\n   192→    const state = readState(testDir);\n   193→    expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('State file corrupted'));\n   194→    expect(state.harness_version).toBe('0.1.0');\n   195→    consoleSpy.mockRestore();\n   196→  });\n   197→\n   198→  it('recovers from file with no frontmatter delimiters', () => {\n   199→    const claudeDir = join(testDir, '.claude');\n   200→    mkdirSync(claudeDir, { recursive: true });\n   201→    writeFileSync(join(claudeDir, 'codeharness.local.md'), 'just some text', 'utf-8');\n   202→\n   203→    const consoleSpy = vi.spyOn(console, 'log');\n   204→    const state = readState(testDir);\n   205→    expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('State file corrupted'));\n   206→    expect(state.initialized).toBe(false);\n   207→    consoleSpy.mockRestore();\n   208→  });\n   209→\n   210→  it('recovers when YAML parses to non-object', () => {\n   211→    const claudeDir = join(testDir, '.claude');\n   212→    mkdirSync(claudeDir, { recursive: true });\n   213→    writeFileSync(join(claudeDir, 'codeharness.local.md'), '---\\njust a string\\n---\\n', 'utf-8');\n   214→\n   215→    const consoleSpy = vi.spyOn(console, 'log');\n   216→    const state = readState(testDir);\n   217→    expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('State file corrupted'));\n   218→    consoleSpy.mockRestore();\n   219→  });\n   220→\n   221→  it('recovers when YAML is valid but does not match HarnessState schema', () => {\n   222→    const claudeDir = join(testDir, '.claude');\n   223→    mkdirSync(claudeDir, { recursive: true });\n   224→    // Valid YAML object but missing required fields\n   225→    writeFileSync(join(claudeDir, 'codeharness.local.md'), '---\\nfoo: bar\\nbaz: 42\\n---\\n', 'utf-8');\n   226→\n   227→    const consoleSpy = vi.spyOn(console, 'log');\n   228→    const state = readState(testDir);\n   229→    expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('State file corrupted'));\n   230→    expect(state.harness_version).toBe('0.1.0');\n   231→    consoleSpy.mockRestore();\n   232→  });\n   233→});\n   234→\n   235→describe('readStateWithBody', () => {\n   236→  it('throws StateFileNotFoundError when file does not exist', () => {\n   237→    expect(() => readStateWithBody(testDir)).toThrow(StateFileNotFoundError);\n   238→  });\n   239→\n   240→  it('returns default body on corrupted file', () => {\n   241→    const claudeDir = join(testDir, '.claude');\n   242→    mkdirSync(claudeDir, { recursive: true });\n   243→    writeFileSync(join(claudeDir, 'codeharness.local.md'), '---\\n{bad\\n---\\n', 'utf-8');\n   244→\n   245→    const consoleSpy = vi.spyOn(console, 'log');\n   246→    const { body } = readStateWithBody(testDir);\n   247→    expect(body).toContain('Codeharness State');\n   248→    consoleSpy.mockRestore();\n   249→  });\n   250→\n   251→  it('returns default body when YAML parses to non-object', () => {\n   252→    const claudeDir = join(testDir, '.claude');\n   253→    mkdirSync(claudeDir, { recursive: true });\n   254→    writeFileSync(join(claudeDir, 'codeharness.local.md'), '---\\n42\\n---\\n', 'utf-8');\n   255→\n   256→    const consoleSpy = vi.spyOn(console, 'log');\n   257→    const { body } = readStateWithBody(testDir);\n   258→    expect(body).toContain('Codeharness State');\n   259→    consoleSpy.mockRestore();\n   260→  });\n   261→\n   262→  it('returns default body on missing frontmatter delimiters', () => {\n   263→    const claudeDir = join(testDir, '.claude');\n   264→    mkdirSync(claudeDir, { recursive: true });\n   265→    writeFileSync(join(claudeDir, 'codeharness.local.md'), 'no delimiters here', 'utf-8');\n   266→\n   267→    const consoleSpy = vi.spyOn(console, 'log');\n   268→    const { body } = readStateWithBody(testDir);\n   269→    expect(body).toContain('Codeharness State');\n   270→    consoleSpy.mockRestore();\n   271→  });\n   272→});\n   273→\n   274→describe('getNestedValue', () => {\n   275→  it('gets top-level value', () => {\n   276→    expect(getNestedValue({ a: 1 }, 'a')).toBe(1);\n   277→  });\n   278→\n   279→  it('gets nested value', () => {\n   280→    expect(getNestedValue({ a: { b: { c: 42 } } }, 'a.b.c')).toBe(42);\n   281→  });\n   282→\n   283→  it('returns undefined for missing key', () => {\n   284→    expect(getNestedValue({ a: 1 }, 'b')).toBeUndefined();\n   285→  });\n   286→\n   287→  it('returns undefined for path through non-object', () => {\n   288→    expect(getNestedValue({ a: 'string' }, 'a.b')).toBeUndefined();\n   289→  });\n   290→\n   291→  it('returns undefined for path through null', () => {\n   292→    expect(getNestedValue({ a: null }, 'a.b')).toBeUndefined();\n   293→  });\n   294→\n   295→  it('rejects __proto__ key path', () => {\n   296→    expect(() => getNestedValue({ a: 1 }, '__proto__.polluted')).toThrow('not allowed');\n   297→  });\n   298→\n   299→  it('rejects constructor key path', () => {\n   300→    expect(() => getNestedValue({ a: 1 }, 'constructor.prototype')).toThrow('not allowed');\n   301→  });\n   302→\n   303→  it('rejects prototype key path', () => {\n   304→    expect(() => getNestedValue({ a: 1 }, 'a.prototype')).toThrow('not allowed');\n   305→  });\n   306→});\n   307→\n   308→describe('setNestedValue', () => {\n   309→  it('sets top-level value', () => {\n   310→    const obj: Record<string, unknown> = { a: 1 };\n   311→    setNestedValue(obj, 'a', 2);\n   312→    expect(obj.a).toBe(2);\n   313→  });\n   314→\n   315→  it('sets nested value', () => {\n   316→    const obj: Record<string, unknown> = { a: { b: 1 } };\n   317→    setNestedValue(obj, 'a.b', 42);\n   318→    expect((obj.a as Record<string, unknown>).b).toBe(42);\n   319→  });\n   320→\n   321→  it('creates intermediate objects for missing path', () => {\n   322→    const obj: Record<string, unknown> = {};\n   323→    setNestedValue(obj, 'a.b.c', 'value');\n   324→    expect((((obj.a as Record<string, unknown>).b) as Record<string, unknown>).c).toBe('value');\n   325→  });\n   326→\n   327→  it('creates intermediate objects when path goes through null', () => {\n   328→    const obj: Record<string, unknown> = { a: null };\n   329→    setNestedValue(obj, 'a.b', 'value');\n   330→    expect((obj.a as Record<string, unknown>).b).toBe('value');\n   331→  });\n   332→\n   333→  it('rejects __proto__ key path', () => {\n   334→    const obj: Record<string, unknown> = {};\n   335→    expect(() => setNestedValue(obj, '__proto__.polluted', true)).toThrow('not allowed');\n   336→  });\n   337→\n   338→  it('rejects constructor key path', () => {\n   339→    const obj: Record<string, unknown> = {};\n   340→    expect(() => setNestedValue(obj, 'constructor.prototype', true)).toThrow('not allowed');\n   341→  });\n   342→});\n   343→\n   344→describe('parseValue', () => {\n   345→  it('parses \"true\" as boolean', () => {\n   346→    expect(parseValue('true')).toBe(true);\n   347→  });\n   348→\n   349→  it('parses \"false\" as boolean', () => {\n   350→    expect(parseValue('false')).toBe(false);\n   351→  });\n   352→\n   353→  it('parses \"null\" as null', () => {\n   354→    expect(parseValue('null')).toBeNull();\n   355→  });\n   356→\n   357→  it('parses numbers', () => {\n   358→    expect(parseValue('42')).toBe(42);\n   359→    expect(parseValue('3.14')).toBe(3.14);\n   360→  });\n   361→\n   362→  it('keeps strings as strings', () => {\n   363→    expect(parseValue('hello')).toBe('hello');\n   364→  });\n   365→});\n   366→\n   367→describe('HarnessState Rust type support', () => {\n   368→  it('accepts cargo-tarpaulin as coverage.tool value', () => {\n   369→    const state = getDefaultState();\n   370→    state.coverage.tool = 'cargo-tarpaulin';\n   371→    writeState(state, testDir);\n   372→\n   373→    const read = readState(testDir);\n   374→    expect(read.coverage.tool).toBe('cargo-tarpaulin');\n   375→  });\n   376→\n   377→  it('round-trips cargo-tarpaulin through YAML write/read', () => {\n   378→    const state = getDefaultState();\n   379→    state.coverage.tool = 'cargo-tarpaulin';\n   380→    writeState(state, testDir);\n   381→\n   382→    const content = readFileSync(getStatePath(testDir), 'utf-8');\n   383→    expect(content).toContain('tool: cargo-tarpaulin');\n   384→\n   385→    const { state: read } = readStateWithBody(testDir);\n   386→    expect(read.coverage.tool).toBe('cargo-tarpaulin');\n   387→  });\n   388→\n   389→  it('accepts rust_env_hint in OTLP state section', () => {\n   390→    const state = getDefaultState();\n   391→    state.otlp = {\n   392→      enabled: true,\n   393→      endpoint: 'http://localhost:4318',\n   394→      service_name: 'my-rust-service',\n   395→      mode: 'local-shared',\n   396→      rust_env_hint: 'OTEL_EXPORTER_OTLP_ENDPOINT',\n   397→    };\n   398→    writeState(state, testDir);\n   399→\n   400→    const read = readState(testDir);\n   401→    expect(read.otlp?.rust_env_hint).toBe('OTEL_EXPORTER_OTLP_ENDPOINT');\n   402→  });\n   403→\n   404→  it('round-trips rust_env_hint through YAML write/read', () => {\n   405→    const state = getDefaultState();\n   406→    state.otlp = {\n   407→      enabled: true,\n   408→      endpoint: 'http://localhost:4318',\n   409→      service_name: 'my-rust-service',\n   410→      mode: 'local-shared',\n   411→      rust_env_hint: 'OTEL_EXPORTER_OTLP_ENDPOINT',\n   412→    };\n   413→    writeState(state, testDir);\n   414→\n   415→    const content = readFileSync(getStatePath(testDir), 'utf-8');\n   416→    expect(content).toContain('rust_env_hint: OTEL_EXPORTER_OTLP_ENDPOINT');\n   417→\n   418→    const { state: read, body } = readStateWithBody(testDir);\n   419→    expect(read.otlp?.rust_env_hint).toBe('OTEL_EXPORTER_OTLP_ENDPOINT');\n   420→\n   421→    // Write back and verify round-trip\n   422→    writeState(read, testDir, body);\n   423→    const final = readState(testDir);\n   424→    expect(final.otlp?.rust_env_hint).toBe('OTEL_EXPORTER_OTLP_ENDPOINT');\n   425→  });\n   426→\n   427→  it('omits rust_env_hint when not set (optional field)', () => {\n   428→    const state = getDefaultState();\n   429→    state.otlp = {\n   430→      enabled: true,\n   431→      endpoint: 'http://localhost:4318',\n   432→      service_name: 'my-node-service',\n   433→      mode: 'local-shared',\n   434→    };\n   435→    writeState(state, testDir);\n   436→\n   437→    const read = readState(testDir);\n   438→    expect(read.otlp?.rust_env_hint).toBeUndefined();\n   439→  });\n   440→});\n   441→\n   442→describe('Multi-stack state migration', () => {\n   443→  it('migrates old format (stack only, no stacks) to include stacks array', () => {\n   444→    // Write a state file in old format (no stacks field)\n   445→    const claudeDir = join(testDir, '.claude');\n   446→    mkdirSync(claudeDir, { recursive: true });\n   447→    const oldYaml = [\n   448→      '---',\n   449→      'harness_version: \"0.1.0\"',\n   450→      'initialized: true',\n   451→      'stack: nodejs',\n   452→      'enforcement:',\n   453→      '  frontend: true',\n   454→      '  database: true',\n   455→      '  api: true',\n   456→      'coverage:',\n   457→      '  target: 90',\n   458→      '  baseline: null',\n   459→      '  current: null',\n   460→      '  tool: c8',\n   461→      'session_flags:',\n   462→      '  logs_queried: false',\n   463→      '  tests_passed: false',\n   464→      '  coverage_met: false',\n   465→      '  verification_run: false',\n   466→      'verification_log: []',\n   467→      '---',\n   468→      '',\n   469→    ].join('\\n');\n   470→    writeFileSync(join(claudeDir, 'codeharness.local.md'), oldYaml, 'utf-8');\n   471→\n   472→    const state = readState(testDir);\n   473→    expect(state.stacks).toEqual(['nodejs']);\n   474→    expect(state.stack).toBe('nodejs');\n   475→  });\n   476→\n   477→  it('reads new format (stacks array present) and syncs stack from stacks[0]', () => {\n   478→    const claudeDir = join(testDir, '.claude');\n   479→    mkdirSync(claudeDir, { recursive: true });\n   480→    const newYaml = [\n   481→      '---',\n   482→      'harness_version: \"0.1.0\"',\n   483→      'initialized: true',\n   484→      'stack: nodejs',\n   485→      'stacks:',\n   486→      '  - nodejs',\n   487→      '  - rust',\n   488→      'enforcement:',\n   489→      '  frontend: true',\n   490→      '  database: true',\n   491→      '  api: true',\n   492→      'coverage:',\n   493→      '  target: 90',\n   494→      '  baseline: null',\n   495→      '  current: null',\n   496→      '  tool: c8',\n   497→      'session_flags:',\n   498→      '  logs_queried: false',\n   499→      '  tests_passed: false',\n   500→      '  coverage_met: false',\n   501→      '  verification_run: false',\n   502→      'verification_log: []',\n   503→      '---',\n   504→      '',\n   505→    ].join('\\n');\n   506→    writeFileSync(join(claudeDir, 'codeharness.local.md'), newYaml, 'utf-8');\n   507→\n   508→    const state = readState(testDir);\n   509→    expect(state.stacks).toEqual(['nodejs', 'rust']);\n   510→    expect(state.stack).toBe('nodejs');\n   511→  });\n   512→\n   513→  it('handles neither stack nor stacks present — produces stacks: [], stack: null', () => {\n   514→    const claudeDir = join(testDir, '.claude');\n   515→    mkdirSync(claudeDir, { recursive: true });\n   516→    const emptyStackYaml = [\n   517→      '---',\n   518→      'harness_version: \"0.1.0\"',\n   519→      'initialized: false',\n   520→      'stack: null',\n   521→      'enforcement:',\n   522→      '  frontend: true',\n   523→      '  database: true',\n   524→      '  api: true',\n   525→      'coverage:',\n   526→      '  target: 90',\n   527→      '  baseline: null',\n   528→      '  current: null',\n   529→      '  tool: c8',\n   530→      'session_flags:',\n   531→      '  logs_queried: false',\n   532→      '  tests_passed: false',\n   533→      '  coverage_met: false',\n   534→      '  verification_run: false',\n   535→      'verification_log: []',\n   536→      '---',\n   537→      '',\n   538→    ].join('\\n');\n   539→    writeFileSync(join(claudeDir, 'codeharness.local.md'), emptyStackYaml, 'utf-8');\n   540→\n   541→    const state = readState(testDir);\n   542→    expect(state.stacks).toEqual([]);\n   543→    expect(state.stack).toBeNull();\n   544→  });\n   545→\n   546→  it('writeState dual-write: both stacks array and stack field appear in YAML output', () => {\n   547→    const state = getDefaultState('nodejs');\n   548→    state.stacks = ['nodejs', 'rust'] as StackName[];\n   549→    writeState(state, testDir);\n   550→\n   551→    const content = readFileSync(getStatePath(testDir), 'utf-8');\n   552→    expect(content).toContain('stack: nodejs');\n   553→    expect(content).toContain('stacks:');\n   554→    expect(content).toContain('- nodejs');\n   555→    expect(content).toContain('- rust');\n   556→  });\n   557→\n   558→  it('getDefaultState returns consistent stack and stacks fields', () => {\n   559→    const withStack = getDefaultState('nodejs');\n   560→    expect(withStack.stack).toBe('nodejs');\n   561→    expect(withStack.stacks).toEqual(['nodejs']);\n   562→\n   563→    const noStack = getDefaultState();\n   564→    expect(noStack.stack).toBeNull();\n   565→    expect(noStack.stacks).toEqual([]);\n   566→\n   567→    const nullStack = getDefaultState(null);\n   568→    expect(nullStack.stack).toBeNull();\n   569→    expect(nullStack.stacks).toEqual([]);\n   570→  });\n   571→\n   572→  it('isValidState accepts old-format state (no stacks field)', () => {\n   573→    // Old format without stacks should still be valid — migrateState will add it\n   574→    const claudeDir = join(testDir, '.claude');\n   575→    mkdirSync(claudeDir, { recursive: true });\n   576→    const oldYaml = [\n   577→      '---',\n   578→      'harness_version: \"0.1.0\"',\n   579→      'initialized: false',\n   580→      'stack: nodejs',\n   581→      'enforcement:',\n   582→      '  frontend: true',\n   583→      '  database: true',\n   584→      '  api: true',\n   585→      'coverage:',\n   586→      '  target: 90',\n   587→      '  baseline: null',\n   588→      '  current: null',\n   589→      '  tool: c8',\n   590→      'session_flags:',\n   591→      '  logs_queried: false',\n   592→      '  tests_passed: false',\n   593→      '  coverage_met: false',\n   594→      '  verification_run: false',\n   595→      'verification_log: []',\n   596→      '---',\n   597→      '',\n   598→    ].join('\\n');\n   599→    writeFileSync(join(claudeDir, 'codeharness.local.md'), oldYaml, 'utf-8');\n   600→\n   601→    // Should not trigger recovery — isValidState should accept this\n   602→    const consoleSpy = vi.spyOn(console, 'log');\n   603→    const state = readState(testDir);\n   604→    // Should not have logged corruption warning\n   605→    expect(consoleSpy).not.toHaveBeenCalledWith(expect.stringContaining('State file corrupted'));\n   606→    expect(state.stack).toBe('nodejs');\n   607→    expect(state.stacks).toEqual(['nodejs']);\n   608→    consoleSpy.mockRestore();\n   609→  });\n   610→\n   611→  it('isValidState accepts new-format state (with stacks field)', () => {\n   612→    const state = getDefaultState('nodejs');\n   613→    state.stacks = ['nodejs', 'rust'] as StackName[];\n   614→    writeState(state, testDir);\n   615→\n   6