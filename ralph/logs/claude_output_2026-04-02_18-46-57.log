{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KASKup416VdKRda5mc1KJw","type":"tool_result","content":"1\t/**\n2\t * CLI subcommand: codeharness validate schema\n3\t * Validates workflow YAML files against JSON schemas using parseWorkflow().\n4\t * Story 2-5: Validate Command\n5\t */\n6\timport { readdirSync, existsSync } from 'node:fs';\n7\timport { join, resolve } from 'node:path';\n8\timport { Command } from 'commander';\n9\timport { ok, fail, jsonOutput } from '../lib/output.js';\n10\timport { parseWorkflow, WorkflowParseError } from '../lib/workflow-parser.js';\n11\t\n12\texport interface ValidateSchemaFileResult {\n13\t  path: string;\n14\t  valid: boolean;\n15\t  errors: Array<{ path: string; message: string }>;\n16\t}\n17\t\n18\texport interface ValidateSchemaResult {\n19\t  status: 'pass' | 'fail';\n20\t  files: ValidateSchemaFileResult[];\n21\t}\n22\t\n23\texport function runSchemaValidation(projectDir: string): ValidateSchemaResult {\n24\t  const workflowsDir = join(projectDir, '.codeharness', 'workflows');\n25\t\n26\t  if (!existsSync(workflowsDir)) {\n27\t    return {\n28\t      status: 'fail',\n29\t      files: [{\n30\t        path: workflowsDir,\n31\t        valid: false,\n32\t        errors: [{ path: workflowsDir, message: 'No workflow files found' }],\n33\t      }],\n34\t    };\n35\t  }\n36\t\n37\t  let entries: string[];\n38\t  try {\n39\t    entries = readdirSync(workflowsDir)\n40\t      .filter(f => f.endsWith('.yaml') || f.endsWith('.yml'));\n41\t  } catch { // IGNORE: graceful fallback — treat unreadable dir as empty\n42\t    entries = [];\n43\t  }\n44\t\n45\t  if (entries.length === 0) {\n46\t    return {\n47\t      status: 'fail',\n48\t      files: [{\n49\t        path: workflowsDir,\n50\t        valid: false,\n51\t        errors: [{ path: workflowsDir, message: 'No workflow files found' }],\n52\t      }],\n53\t    };\n54\t  }\n55\t\n56\t  const fileResults: ValidateSchemaFileResult[] = [];\n57\t  let allValid = true;\n58\t\n59\t  for (const entry of entries) {\n60\t    const filePath = resolve(workflowsDir, entry);\n61\t    try {\n62\t      parseWorkflow(filePath);\n63\t      fileResults.push({ path: filePath, valid: true, errors: [] });\n64\t    } catch (err: unknown) {\n65\t      allValid = false;\n66\t      if (err instanceof WorkflowParseError) {\n67\t        fileResults.push({ path: filePath, valid: false, errors: err.errors });\n68\t      } else {\n69\t        const msg = err instanceof Error ? err.message : String(err);\n70\t        fileResults.push({ path: filePath, valid: false, errors: [{ path: filePath, message: msg }] });\n71\t      }\n72\t    }\n73\t  }\n74\t\n75\t  return { status: allValid ? 'pass' : 'fail', files: fileResults };\n76\t}\n77\t\n78\texport function registerValidateSchemaCommand(parent: Command): void {\n79\t  parent\n80\t    .command('schema')\n81\t    .description('Validate workflow YAML files against JSON schemas')\n82\t    .action((_opts: Record<string, unknown>, cmd: Command) => {\n83\t      const isJson = (cmd.optsWithGlobals() as { json?: boolean }).json === true;\n84\t      const result = runSchemaValidation(process.cwd());\n85\t\n86\t      if (isJson) {\n87\t        jsonOutput(result as unknown as Record<string, unknown>);\n88\t        process.exitCode = result.status === 'pass' ? 0 : 1;\n89\t        return;\n90\t      }\n91\t\n92\t      for (const file of result.files) {\n93\t        if (file.valid) {\n94\t          ok(`Schema: ${file.path}`);\n95\t        } else {\n96\t          fail(`Schema: ${file.path}`);\n97\t          for (const error of file.errors) {\n98\t            console.log(`  ${error.path}: ${error.message}`);\n99\t          }\n100\t        }\n101\t      }\n102\t\n103\t      process.exitCode = result.status === 'pass' ? 0 : 1;\n104\t    });\n105\t}\n106\t"}]},"parent_tool_use_id":"toolu_01DuVFpc4kAp6TjMAncLaYvJ","session_id":"5fca15c0-771e-463c-9e4f-c528b230e359","uuid":"64e6ff36-5110-428d-bc3b-32db46edea93","timestamp":"2026-04-02T14:57:40.982Z"}
