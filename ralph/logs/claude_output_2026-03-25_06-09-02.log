{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01F64mN4EEa9JVKE6XpNCjr5","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import {\n     3→  showboatProofTemplate,\n     4→  verificationSummaryBlock,\n     5→} from '../showboat-template.js';\n     6→import type {\n     7→  ShowboatProofConfig,\n     8→  AcceptanceCriterion,\n     9→  EvidenceItem,\n    10→} from '../showboat-template.js';\n    11→\n    12→// ─── verificationSummaryBlock ───────────────────────────────────────────────\n    13→\n    14→describe('verificationSummaryBlock', () => {\n    15→  it('calculates correct counts for all verified', () => {\n    16→    const criteria: AcceptanceCriterion[] = [\n    17→      { id: '1', description: 'AC one', verified: true, evidence: [] },\n    18→      { id: '2', description: 'AC two', verified: true, evidence: [] },\n    19→    ];\n    20→    const block = verificationSummaryBlock(criteria);\n    21→    expect(block).toContain('Total ACs | 2');\n    22→    expect(block).toContain('Verified | 2');\n    23→    expect(block).toContain('Failed | 0');\n    24→    expect(block).toContain('Showboat Verify | PASS');\n    25→  });\n    26→\n    27→  it('calculates correct counts with failures', () => {\n    28→    const criteria: AcceptanceCriterion[] = [\n    29→      { id: '1', description: 'AC one', verified: true, evidence: [] },\n    30→      { id: '2', description: 'AC two', verified: false, evidence: [] },\n    31→      { id: '3', description: 'AC three', verified: false, evidence: [] },\n    32→    ];\n    33→    const block = verificationSummaryBlock(criteria);\n    34→    expect(block).toContain('Total ACs | 3');\n    35→    expect(block).toContain('Verified | 1');\n    36→    expect(block).toContain('Failed | 2');\n    37→    expect(block).toContain('Showboat Verify | FAIL');\n    38→  });\n    39→\n    40→  it('returns FAIL for zero ACs', () => {\n    41→    const block = verificationSummaryBlock([]);\n    42→    expect(block).toContain('Total ACs | 0');\n    43→    expect(block).toContain('Verified | 0');\n    44→    expect(block).toContain('Failed | 0');\n    45→    expect(block).toContain('Showboat Verify | FAIL');\n    46→  });\n    47→\n    48→  it('contains summary heading', () => {\n    49→    const block = verificationSummaryBlock([]);\n    50→    expect(block).toContain('## Verification Summary');\n    51→  });\n    52→});\n    53→\n    54→// ─── showboatProofTemplate ──────────────────────────────────────────────────\n    55→\n    56→describe('showboatProofTemplate', () => {\n    57→  it('generates correct markdown structure with story header', () => {\n    58→    const config: ShowboatProofConfig = {\n    59→      storyId: '4-1-test',\n    60→      storyTitle: 'Story 4.1: Test Story',\n    61→      acceptanceCriteria: [\n    62→        { id: '1', description: 'First AC', verified: false, evidence: [] },\n    63→      ],\n    64→    };\n    65→    const result = showboatProofTemplate(config);\n    66→    expect(result).toContain('# Proof: 4-1-test');\n    67→    expect(result).toContain('**Story:** Story 4.1: Test Story');\n    68→    expect(result).toContain('**Generated:**');\n    69→  });\n    70→\n    71→  it('includes AC sections with correct IDs', () => {\n    72→    const config: ShowboatProofConfig = {\n    73→      storyId: '1-1-test',\n    74→      storyTitle: 'Test',\n    75→      acceptanceCriteria: [\n    76→        { id: '1', description: 'First', verified: true, evidence: [] },\n    77→        { id: '2', description: 'Second', verified: false, evidence: [] },\n    78→      ],\n    79→    };\n    80→    const result = showboatProofTemplate(config);\n    81→    expect(result).toContain('## AC 1: PASS');\n    82→    expect(result).toContain('## AC 2: PENDING');\n    83→    expect(result).toContain('> First');\n    84→    expect(result).toContain('> Second');\n    85→  });\n    86→\n    87→  it('includes showboat exec blocks for exec evidence', () => {\n    88→    const evidence: EvidenceItem[] = [\n    89→      { type: 'exec', content: 'curl http://localhost:3000/health' },\n    90→    ];\n    91→    const config: ShowboatProofConfig = {\n    92→      storyId: 'test',\n    93→      storyTitle: 'Test',\n    94→      acceptanceCriteria: [\n    95→        { id: '1', description: 'Health check', verified: true, evidence },\n    96→      ],\n    97→    };\n    98→    const result = showboatProofTemplate(config);\n    99→    expect(result).toContain('<!-- showboat exec: curl http://localhost:3000/health -->');\n   100→    expect(result).toContain('<!-- /showboat exec -->');\n   101→  });\n   102→\n   103→  it('includes showboat image blocks for image evidence', () => {\n   104→    const evidence: EvidenceItem[] = [\n   105→      { type: 'image', content: 'screenshot desc', path: 'verification/screenshots/1-1-ac1-home.png' },\n   106→    ];\n   107→    const config: ShowboatProofConfig = {\n   108→      storyId: 'test',\n   109→      storyTitle: 'Test',\n   110→      acceptanceCriteria: [\n   111→        { id: '1', description: 'UI check', verified: true, evidence },\n   112→      ],\n   113→    };\n   114→    const result = showboatProofTemplate(config);\n   115→    expect(result).toContain('<!-- showboat image: verification/screenshots/1-1-ac1-home.png -->');\n   116→  });\n   117→\n   118→  it('uses content as path for image evidence without explicit path', () => {\n   119→    const evidence: EvidenceItem[] = [\n   120→      { type: 'image', content: 'screenshots/test.png' },\n   121→    ];\n   122→    const config: ShowboatProofConfig = {\n   123→      storyId: 'test',\n   124→      storyTitle: 'Test',\n   125→      acceptanceCriteria: [\n   126→        { id: '1', description: 'UI check', verified: true, evidence },\n   127→      ],\n   128→    };\n   129→    const result = showboatProofTemplate(config);\n   130→    expect(result).toContain('<!-- showboat image: screenshots/test.png -->');\n 