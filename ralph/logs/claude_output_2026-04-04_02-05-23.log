 coverage = parseFloat(covMatch[1]);\n\n    return { passed, failed, ...(coverage !== undefined && { coverage }) };\n  }\n\n  /**","new_string":"  /**"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":625,"cache_read_input_tokens":66096,"cache_creation":{"ephemeral_5m_input_tokens":625,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_0175npHDGRfVyrbCzjafE5Mk","session_id":"22206bba-5847-41b1-b510-883e1dd8c0da","uuid":"82576230-eff1-4ae7-b4bb-8bba85dfcccf"}
