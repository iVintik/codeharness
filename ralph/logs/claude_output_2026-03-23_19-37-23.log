{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019TCtQrfkBxqunRLyfumhKX","type":"tool_result","content":"     1→/**\n     2→ * Documentation scaffolding for project initialization.\n     3→ * Generates AGENTS.md, docs/ directory structure, and README.md.\n     4→ */\n     5→\n     6→import { existsSync, readFileSync } from 'node:fs';\n     7→import { join, basename } from 'node:path';\n     8→import { ok as okOutput } from '../../lib/output.js';\n     9→import { generateFile } from '../../lib/templates.js';\n    10→import { readmeTemplate } from '../../templates/readme.js';\n    11→import type { Result } from '../../types/result.js';\n    12→import { ok, fail } from '../../types/result.js';\n    13→import type { InitDocumentationResult } from './types.js';\n    14→import type { StackDetection } from '../../lib/stack-detect.js';\n    15→\n    16→const DO_NOT_EDIT_HEADER = '<!-- DO NOT EDIT MANUALLY -->\\n';\n    17→\n    18→export function getProjectName(projectDir: string): string {\n    19→  try {\n    20→    const pkgPath = join(projectDir, 'package.json');\n    21→    if (existsSync(pkgPath)) {\n    22→      const pkg = JSON.parse(readFileSync(pkgPath, 'utf-8')) as Record<string, unknown>;\n    23→      if (pkg.name && typeof pkg.name === 'string') {\n    24→        return pkg.name;\n    25→      }\n    26→    }\n    27→  } catch {\n    28→    // Fall through to Cargo.toml check\n    29→  }\n    30→\n    31→  // Cargo.toml fallback for Rust projects\n    32→  try {\n    33→    const cargoPath = join(projectDir, 'Cargo.toml');\n    34→    if (existsSync(cargoPath)) {\n    35→      const content = readFileSync(cargoPath, 'utf-8');\n    36→      const packageMatch = content.match(/\\[package\\]([\\s\\S]*?)(?=\\n\\[|$)/s);\n    37→      if (packageMatch) {\n    38→        const nameMatch = packageMatch[1].match(/^\\s*name\\s*=\\s*[\"']([^\"']+)[\"']/m);\n    39→        if (nameMatch) {\n    40→          return nameMatch[1];\n    41→        }\n    42→      }\n    43→    }\n    44→  } catch {\n    45→    // Fall through to basename\n    46→  }\n    47→\n    48→  return basename(projectDir);\n    49→}\n    50→\n    51→export function getStackLabel(stack: string | string[] | null): string {\n    52→  if (Array.isArray(stack)) {\n    53→    if (stack.length === 0) return 'Unknown';\n    54→    return stack.map(s => getStackLabel(s)).join(' + ');\n    55→  }\n    56→  if (stack === 'nodejs') return 'Node.js (package.json)';\n    57→  if (stack === 'python') return 'Python';\n    58→  if (stack === 'rust') return 'Rust (Cargo.toml)';\n    59→  return 'Unknown';\n    60→}\n    61→\n    62→export function getCoverageTool(stack: string | null): 'c8' | 'coverage.py' | 'cargo-tarpaulin' | 'unknown' {\n    63→  if (stack === 'python') return 'coverage.py';\n    64→  if (stack === 'rust') return 'cargo-tarpaulin';\n    65→  return 'c8';\n    66→}\n    67→\n    68→export function generateAgentsMdContent(projectDir: string, stack: string | StackDetection[] | null): string {\n    69→  // Multi-stack path: StackDetection[] with more than one entry\n    70→  if (Array.isArray(stack)) {\n    71→    return generateMultiStackAgentsMd(projectDir, stack);\n    72→  }\n    73→\n    74→  // Single-stack path: string | null (backward compat)\n    75→  const projectName = basename(projectDir);\n    76→  const stackLabel = stack === 'nodejs' ? 'Node.js' : stack === 'python' ? 'Python' : stack === 'rust' ? 'Rust' : 'Unknown';\n    77→\n    78→  const lines = [\n    79→    `# ${projectName}`,\n    80→    '',\n    81→    '## Stack',\n    82→    '',\n    83→    `- **Language/Runtime:** ${stackLabel}`,\n    84→    '',\n    85→    '## Build & Test Commands',\n    86→    '',\n    87→  ];\n    88→\n    89→  if (stack === 'nodejs') {\n    90→    lines.push(\n    91→      '```bash',\n    92→      'npm install    # Install dependencies',\n    93→      'npm run build  # Build the project',\n    94→      'npm test       # Run tests',\n    95→      '```',\n    96→    );\n    97→  } else if (stack === 'python') {\n    98→    lines.push(\n    99→      '```bash',\n   100→      'pip install -r requirements.txt  # Install dependencies',\n   101→      'python -m pytest                 # Run tests',\n   102→      '```',\n   103→    );\n   104→  } else if (stack === 'rust') {\n   105→    lines.push(\n   106→      '```bash',\n   107→      'cargo build    # Build the project',\n   108→      'cargo test     # Run tests',\n   109→      'cargo tarpaulin --out json  # Run coverage',\n   110→      '```',\n   111→    );\n   112→  } else {\n   113→    lines.push('```bash', '# No recognized stack — add build/test commands here', '```');\n   114→  }\n   115→\n   116→  lines.push(\n   117→    '',\n   118→    '## Project Structure',\n   119→    '',\n   120→    '```',\n   121→    `${projectName}/`,\n   122→    '├── src/           # Source code',\n   123→    '├── tests/         # Test files',\n   124→    '├── docs/          # Documentation',\n   125→    '└── .claude/       # Codeharness state',\n   126→    '```',\n   127→    '',\n   128→    '## Conventions',\n   129→    '',\n   130→    '- All changes must pass tests before commit',\n   131→    '- Maintain test coverage targets',\n   132→    '- Follow existing code style and patterns',\n   133→    '',\n   134→  );\n   135→\n   136→  return lines.join('\\n');\n   137→}\n   138→\n   139→function generateMultiStackAgentsMd(projectDir: string, stacks: StackDetection[]): string {\n   140→  const projectName = basename(projectDir);\n   141→  const stackNames = stacks.map(s => {\n   142→    if (s.stack === 'nodejs') return 'Node.js';\n   143→    if (s.stack === 'python') return 'Python';\n   144→    if (s.stack === 'rust') return 'Rust';\n   145→    return 'Unknown';\n   146→  });\n   147→\n   148→  const lines = [\n   149→    `# ${projectName}`,\n   150→    '',\n   151→    '## Stack',\n   152→    '',\n   153→    `- **Language/Runtime:** ${stackNames.join(' + ')}`,\n   154→    '',\n   155→    '## Build & Test Commands',\n   156→    '',\n   157→  ];\n   158→\n   159→  for (const detection of stacks) {\n   160→    const label = detection.stack === 'nodejs' ? 'Node.js'\n   161→      : detection.stack === 'python' ? 'Python'\n   162→      : detection.stack === 'rust' ? 'Rust' : 'Unknown';\n   163→    const heading = detection.dir === '.' ? `### ${label}` : `### ${label} (${detection.dir}/)`;\n   164→    const prefix = detection.dir === '.' ? '' : `cd ${detection.dir} && `;\n   165→\n   166→    lines.push(heading, '', '```bash');\n   167→\n   168→    if (detection.stack === 'nodejs') {\n   169→      lines.push(\n   170→        `${prefix}npm install    # Install dependencies`,\n   171→        `${prefix}npm run build  # Build the project`,\n   172→        `${prefix}npm test       # Run tests`,\n   173→      );\n   174→    } else if (detection.stack === 'python') {\n   175→      lines.push(\n   176→        `${prefix}pip install -r requirements.txt  # Install dependencies`,\n   177→        `${prefix}python -m pytest                 # Run tests`,\n   178→      );\n   179→    } else if (detection.stack === 'rust') {\n   180→      lines.push(\n   181→        `${prefix}cargo build    # Build the project`,\n   182→        `${prefix}cargo test     # Run tests`,\n   183→        `${prefix}cargo tarpaulin --out json  # Run coverage`,\n   184→      );\n   185→    }\n   186→\n   187→    lines.push('```', '');\n   188→  }\n   189→\n   190→  lines.push(\n   191→    '## Project Structure',\n   192→    '',\n   193→    '```',\n   194→    `${projectName}/`,\n   195→    '├── src/           # Source code',\n   196→    '├── tests/         # Test files',\n   197→    '├── docs/          # Documentation',\n   198→    '└── .claude/       # Codeharness state',\n   199→    '```',\n   200→    '',\n   201→    '## Conventions',\n   202→    '',\n   203→    '- All changes must pass tests before commit',\n   204→    '- Maintain test coverage targets',\n   205→    '- Follow existing code style and patterns',\n   206→    '',\n   207→  );\n   208→\n   209→  return lines.join('\\n');\n   210→}\n   211→\n   212→export function generateDocsIndexContent(): string {\n   213→  return [\n   214→    '# Project Documentation',\n   215→    '',\n   216→    '## Planning Artifacts',\n   217→    '- [Product Requirements](../_bmad-output/planning-artifacts/prd.md)',\n   218→    '- [Architecture](../_bmad-output/planning-artifacts/architecture.md)',\n   219→    '- [Epics & Stories](../_bmad-output/planning-artifacts/epics.md)',\n   220→    '',\n   221→    '## Execution',\n   222→    '- [Active Exec Plans](exec-plans/active/)',\n   223→    '- [Completed Exec Plans](exec-plans/completed/)',\n   224→    '',\n   225→    '## Quality',\n   226→    '- [Quality Reports](quality/)',\n   227→    '- [Generated Reports](generated/)',\n   228→    '',\n   229→  ].join('\\n');\n   230→}\n   231→\n   232→interface ScaffoldDocsOptions {\n   233→  readonly projectDir: string;\n   234→  readonly stack: string | null;\n   235→  readonly stacks?: StackDetection[];\n   236→  readonly isJson: boolean;\n   237→}\n   238→\n   239→export async function scaffoldDocs(opts: ScaffoldDocsOptions): Promise<Result<InitDocumentationResult>> {\n   240→  try {\n   241→    let agentsMd: 'created' | 'exists' | 'skipped' = 'skipped';\n   242→    let docsScaffold: 'created' | 'exists' | 'skipped' = 'skipped';\n   243→    let readme: 'created' | 'exists' | 'skipped' = 'skipped';\n   244→\n   245→    // AGENTS.md\n   246→    const agentsMdPath = join(opts.projectDir, 'AGENTS.md');\n   247→    if (!existsSync(agentsMdPath)) {\n   248→      const stackArg = opts.stacks && opts.stacks.length > 1 ? opts.stacks : opts.stack;\n   249→      const content = generateAgentsMdContent(opts.projectDir, stackArg);\n   250→      generateFile(agentsMdPath, content);\n   251→      agentsMd = 'created';\n   252→    } else {\n   253→      agentsMd = 'exists';\n   254→    }\n   255→\n   256→    // docs/ scaffold\n   257→    const docsDir = join(opts.projectDir, 'docs');\n   258→    if (!existsSync(docsDir)) {\n   259→      generateFile(join(docsDir, 'index.md'), generateDocsIndexContent());\n   260→      generateFile(join(docsDir, 'exec-plans', 'active', '.gitkeep'), '');\n   261→      generateFile(join(docsDir, 'exec-plans', 'completed', '.gitkeep'), '');\n   262→      generateFile(join(docsDir, 'quality', '.gitkeep'), DO_NOT_EDIT_HEADER);\n   263→      generateFile(join(docsDir, 'generated', '.gitkeep'), DO_NOT_EDIT_HEADER);\n   264→      docsScaffold = 'created';\n   265→    } else {\n   266→      docsScaffold = 'exists';\n   267→    }\n   268→\n   269→    // README.md\n   270→    const readmePath = join(opts.projectDir, 'README.md');\n   271→    if (!existsSync(readmePath)) {\n   272→      let cliHelpOutput = '';\n   273→      try {\n   274→        const { execFileSync } = await import('node:child_process');\n   275→        cliHelpOutput = execFileSync(process.execPath, [process.argv[1], '--help'], {\n   276→          stdio: 'pipe',\n   277→          timeout: 10_000,\n   278→        }).toString();\n   279→      } catch {\n   280→        cliHelpOutput = 'Run: codeharness --help';\n   281→      }\n   282→\n   283→      const readmeStack = opts.stacks && opts.stacks.length > 1\n   284→        ? opts.stacks.map(s => s.stack)\n   285→        : opts.stack;\n   286→      const readmeContent = readmeTemplate({\n   287→        projectName: getProjectName(opts.projectDir),\n   288→        stack: readmeStack,\n   289→        cliHelpOutput,\n   290→      });\n   291→      generateFile(readmePath, readmeContent);\n   292→      readme = 'created';\n   293→    } else {\n   294→      readme = 'exists';\n   295→    }\n   296→\n   297→    const result: InitDocumentationResult = { agents_md: agentsMd, docs_scaffold: docsScaffold, readme };\n   298→\n   299→    if (!opts.isJson) {\n   300→      if (result.agents_md === 'created' || result.docs_scaffold === 'created') {\n   301→        okOutput('Documentation: AGENTS.md + docs/ scaffold created');\n   302→      }\n   303→      if (result.readme === 'created') {\n   304→        okOutput('Documentation: README.md created');\n   305→      }\n   306→    }\n   307→\n   308→    return ok(result);\n   309→  } catch (err) {\n   310→    const message = err instanceof Error ? err.message : String(err);\n   311→    return fail(`Documentation scaffold failed: ${message}`);\n   312→  }\n   313→}\n   314→"}]},"parent_tool_use_id":"toolu_017stQocDjYtQWzyiuCXnw1e","session_id":"58ae4f51-bff6-4a66-807a-d4f10c8bdaa3","uuid":"3e7315cd-4851-422f-8b9e-714ce145b804","timestamp":"2026-03-23T15:51:40.277Z"}
