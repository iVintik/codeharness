{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Uq5xefEBjbhqzzXJxojhkF","type":"tool_result","content":"810\t * Run health checks on all unique drivers referenced in a workflow.\n811\t *\n812\t * Collects unique driver names from `workflow.tasks`, resolves each via\n813\t * `getDriver()`, and runs all `healthCheck()` calls concurrently with a\n814\t * 5-second timeout (NFR6).\n815\t *\n816\t * Throws if any driver is unavailable or if the timeout fires.\n817\t */\n818\texport async function checkDriverHealth(workflow: ResolvedWorkflow, timeoutMs?: number): Promise<void> {\n819\t  // 1. Collect unique driver names from all tasks\n820\t  const driverNames = new Set<string>();\n821\t  for (const task of Object.values(workflow.tasks)) {\n822\t    driverNames.add(task.driver ?? 'claude-code');\n823\t  }\n824\t\n825\t  // 2. Resolve drivers\n826\t  const drivers = new Map<string, ReturnType<typeof getDriver>>();\n827\t  for (const name of driverNames) {\n828\t    drivers.set(name, getDriver(name));\n829\t  }\n830\t\n831\t  // 3. Run health checks concurrently, tracking which drivers responded\n832\t  interface HealthResult { name: string; health: DriverHealth }\n833\t  const responded = new Set<string>();\n834\t  const healthChecks = Promise.all(\n835\t    [...drivers.entries()].map(async ([name, driver]): Promise<HealthResult> => {\n836\t      const health = await driver.healthCheck();\n837\t      responded.add(name);\n838\t      return { name, health };\n839\t    }),\n840\t  );\n841\t\n842\t  // 4. Race against timeout (NFR6) — clear timer on success to prevent leaks\n843\t  const effectiveTimeout = timeoutMs ?? HEALTH_CHECK_TIMEOUT_MS;\n844\t  let timer: ReturnType<typeof setTimeout>;\n845\t  const timeoutPromise = new Promise<'timeout'>((resolve) => {\n846\t    timer = setTimeout(() => resolve('timeout'), effectiveTimeout);\n847\t  });\n848\t\n849\t  const result = await Promise.race([healthChecks, timeoutPromise]);\n850\t\n851\t  if (result === 'timeout') {\n852\t    // Report only the drivers that did NOT respond (AC #6)\n853\t    const pending = [...driverNames].filter((n) => !responded.has(n));\n854\t    const names = pending.length > 0 ? pending.join(', ') : [...driverNames].join(', ');\n855\t    throw new Error(\n856\t      `Driver health check timed out after ${effectiveTimeout}ms. Drivers that did not respond: ${names}`,\n857\t    );\n858\t  }\n859\t\n860\t  // Health checks completed before timeout — clear the timer\n861\t  clearTimeout(timer!);\n862\t\n863\t  // 5. Check for failures\n864\t  const failures = result.filter((r) => !r.health.available);\n865\t  if (failures.length > 0) {\n866\t    const details = failures\n867\t      .map((f) => `${f.name}: ${f.health.error ?? 'unavailable'}`)\n868\t      .join('; ');\n869\t    throw new Error(`Driver health check failed: ${details}`);"}]},"parent_tool_use_id":"toolu_01FEeigjd5nRWkRCota9R2KA","session_id":"cf16e575-8267-4c58-a992-20b07458710f","uuid":"4c7f2cc7-9d7d-41f9-8f42-57f39529bee1","timestamp":"2026-04-03T13:16:33.327Z"}
