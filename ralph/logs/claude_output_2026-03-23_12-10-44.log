lid toml!!!');\n    const name = getProjectName(testDir);\n    expect(typeof name).toBe('string');\n    expect(name.length).toBeGreaterThan(0);\n  });\n});"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":634,"cache_read_input_tokens":27775,"cache_creation":{"ephemeral_5m_input_tokens":634,"ephemeral_1h_input_tokens":0},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01V6PzrVgf3Hd6vGXkHaJvuq","session_id":"9c50fb69-0476-4a5d-8998-78fcdfa47c24","uuid":"5ae2232a-7fc0-4de2-82bf-7a723fed66f6"}
