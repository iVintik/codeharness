   throw err;\n512\t        }\n513\t        if (cmd.includes('branch --list')) return Buffer.from('');\n514\t        return Buffer.from('');\n515\t      });\n516\t\n517\t      // Should still succeed — stale cleanup is best-effort\n518\t      const path = manager.createWorktree('17', 'slug');\n519\t      expect(path).toBe('/tmp/codeharness-wt-epic-17');\n520\t    });\n521\t  });\n522\t\n523\t  describe('detectOrphans edge cases', () => {\n524\t    it('treats corrupt lane-state.json as orphaned (AC #8)', () => {\n525\t      const porcelain = [\n526\t        'worktree /tmp/codeharness-wt-epic-17',\n527\t        'HEAD abc123',\n528\t        'branch refs/heads/codeharness/epic-17-slug',\n529\t        '',\n530\t      ].join('\\n');\n531\t      mockExecSync.mockReturnValue(Buffer.from(porcelain));\n532\t      mockExistsSync.mockReturnValue(true);\n533\t      mockReadFileSync.mockImplementation(() => { throw new Error('EACCES'); });\n534\t\n535\t      const orphans = manager.detectOrphans();\n536\t      expect(orphans).toHaveLength(1);\n537\t    });\n538\t  });\n539\t\n540\t  describe('constructor defaults', () => {\n541\t    it('defaults mainBranch to main', () => {\n542\t      const mgr = new WorktreeManager();\n543\t      mockExecSync.mockReturnValue(Buffer.from(''));\n544\t\n545\t      mgr.createWorktree('1', 'test');\n546\t\n547\t      const calls = mockExecSync.mock.calls.map((c: unknown[]) => c[0] as string);\n548\t      const branchCmd = calls.find((c) => c.startsWith('git branch codeharness/'));\n549\t      expect(branchCmd).toContain(' main');\n550\t    });\n551\t  });\n552\t});\n553\t"}]},"parent_tool_use_id":"toolu_017oQhjmWz7daop7ZDDoYBsH","session_id":"0d8bd255-97e7-4ce2-b430-6ab2ab2aca0a","uuid":"4394b84b-140d-4b7c-9054-3be9783ad703","timestamp":"2026-04-03T19:47:55.831Z"}
