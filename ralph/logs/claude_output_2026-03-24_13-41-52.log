at — single-stack project still works identically (Task 10)', async () => {\n   481→    writeFileSync(join(testDir, 'package.json'), '{}');\n   482→    mockDetectStacks.mockReturnValue([{ stack: 'nodejs', dir: '.' }]);\n   483→    mockInstrumentProject.mockClear();\n   484→\n   485→    const result = await initProject(makeOpts({ observability: true }));\n   486→\n   487→    expect(result.success).toBe(true);\n   488→    if (result.success) {\n   489→      expect(result.data.stack).toBe('nodejs');\n   490→      expect(result.data.stacks).toEqual(['nodejs']);\n   491→    }\n   492→\n   493→    const state = readState(testDir);\n   494→    expect(state.stack).toBe('nodejs');\n   495→    expect(state.stacks).toEqual(['nodejs']);\n   496→    expect(state.coverage.tool).toBe('c8');\n   497→\n   498→    // instrumentProject called exactly once for single stack\n   499→    expect(mockInstrumentProject).toHaveBeenCalledTimes(1);\n   500→    expect(mockInstrumentProject.mock.calls[0][1]).toBe('nodejs');\n   501→  });\n   502→\n   503→  it('OTLP result.otlp comes from root detection, not first matching stack name', async () => {\n   504→    writeFileSync(join(testDir, 'package.json'), '{}');\n   505→    // Subdirectory detection appears first but root detection appears second\n   506→    mockDetectStacks.mockReturnValue([\n   507→      { stack: 'nodejs', dir: 'packages/app' },\n   508→      { stack: 'nodejs', dir: '.' },\n   509→    ]);\n   510→    const rootOtlp = { status: 'configured' as const, packages_installed: true, start_script_patched: true, env_vars_configured: true };\n   511→    const subOtlp = { status: 'configured' as const, packages_installed: false, start_script_patched: false, env_vars_configured: false };\n   512→    mockInstrumentProject.mockClear();\n   513→    mockInstrumentProject.mockReturnValueOnce(subOtlp).mockReturnValueOnce(rootOtlp);\n   514→\n   515→    const result = await initProject(makeOpts({ observability: true }));\n   516→\n   517→    expect