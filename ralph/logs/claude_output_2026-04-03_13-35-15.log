{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VdPM3Gz45ciLu2YDDHVCb1","type":"tool_result","content":"1\t/**\n2\t * Documentation staleness and completeness checks.\n3\t */\n4\t\n5\timport { execSync } from 'node:child_process';\n6\timport {\n7\t  existsSync,\n8\t  readFileSync,\n9\t  readdirSync,\n10\t  statSync,\n11\t} from 'node:fs';\n12\timport { join, relative } from 'node:path';\n13\timport { getExtension, isTestFile, getNewestSourceMtime } from './types.js';\n14\timport type { DocHealthResult, DocHealthReport } from './types.js';\n15\timport { findModules } from './scanner.js';\n16\t\n17\tconst SOURCE_EXTENSIONS = new Set(['.ts', '.js', '.py']);\n18\tconst DO_NOT_EDIT_HEADER = '<!-- DO NOT EDIT MANUALLY';\n19\t\n20\t// ─── Freshness Checking ─────────────────────────────────────────────────────\n21\t\n22\texport function isDocStale(docPath: string, codeDir: string): boolean {\n23\t  if (!existsSync(docPath)) return true;\n24\t  if (!existsSync(codeDir)) return false;\n25\t\n26\t  const docMtime = statSync(docPath).mtime;\n27\t  const newestCode = getNewestSourceMtime(codeDir);\n28\t\n29\t  if (newestCode === null) return false;\n30\t  return newestCode.getTime() > docMtime.getTime();\n31\t}\n32\t\n33\t// ─── AGENTS.md Content Completeness ──────────────────────────────────────────\n34\t\n35\texport function getSourceFilesInModule(modulePath: string): string[] {\n36\t  const files: string[] = [];\n37\t\n38\t  function walk(current: string): void {\n39\t    let entries: string[];\n40\t    try {\n41\t      entries = readdirSync(current);\n42\t    } catch {\n43\t      // IGNORE: directory may not be readable\n44\t      return;\n45\t    }\n46\t\n47\t    const dirName = current.split('/').pop() ?? '';\n48\t    if (\n49\t      dirName === 'node_modules' ||\n50\t      dirName === '.git' ||\n51\t      dirName === '__tests__' ||\n52\t      dirName === 'dist' ||\n53\t      dirName === 'coverage' ||\n54\t      (dirName.startsWith('.') && current !== modulePath)\n55\t    ) return;\n56\t\n57\t    for (const entry of entries) {\n58\t      const fullPath = join(current, entry);\n59\t      let stat;\n60\t      try {\n61\t        stat = statSync(fullPath);\n62\t      } catch {\n63\t        // IGNORE: file stat may fail, skip entry\n64\t        continue;\n65\t      }\n66\t\n67\t      if (stat.isDirectory()) {\n68\t        walk(fullPath);\n69\t      } else if (stat.isFile()) {\n70\t        const ext = getExtension(entry);\n71\t        if (SOURCE_EXTENSIONS.has(ext) && !isTestFile(entry)) {\n72\t          files.push(entry);\n73\t        }\n74\t      }\n75\t    }\n76\t  }\n77\t\n78\t  walk(modulePath);\n79\t  return files;\n80\t}\n81\t\n82\texport function getMentionedFilesInAgentsMd(agentsPath: string): string[] {\n83\t  if (!existsSync(agentsPath)) return [];\n84\t\n85\t  const content = readFileSync(agentsPath, 'utf-8');\n86\t  const mentioned = new Set<string>();\n87\t\n88\t  const filenamePattern = /[\\w./-]*[\\w-]+\\.(?:ts|js|py)\\b/g;\n89\t  let match;\n90\t  while ((match = filenamePattern.exec(content)) !== null) {\n91\t    const fullMatch = match[0];\n92\t    const basename = fullMatch.split('/').pop()!;\n93\t    if (!isTestFile(basename)) {\n94\t      mentioned.add(basename);\n95\t    }\n96\t  }\n97\t\n98\t  return Array.from(mentioned);\n99\t}\n100\t\n101\texport function checkAgentsMdCompleteness(\n102\t  agentsPath: string,\n103\t  modulePath: string,\n104\t): { complete: boolean; missing: string[] } {\n105\t  const sourceFiles = getSourceFilesInModule(modulePath);\n106\t  const mentionedFiles = new Set(getMentionedFilesInAgentsMd(agentsPath));\n107\t\n108\t  const missing = sourceFiles.filter(f => !mentionedFiles.has(f));\n109\t\n110\t  return {\n111\t    complete: missing.length === 0,\n112\t    missing,\n113\t  };\n114\t}\n115\t\n116\t// ─── AGENTS.md Checking ─────────────────────────────────────────────────────\n117\t\n118\texport function checkAgentsMdForModule(\n119\t  modulePath: string,\n120\t  dir?: string,\n121\t): DocHealthResult {\n122\t  const root = dir ?? process.cwd();\n123\t  const fullModulePath = join(root, modulePath);\n124\t\n125\t  let agentsPath = join(fullModulePath, 'AGENTS.md');\n126\t  if (!existsSync(agentsPath)) {\n127\t    agentsPath = join(root, 'AGENTS.md');\n128\t  }\n129\t\n130\t  if (!existsSync(agentsPath)) {\n131\t    return {\n132\t      path: relative(root, agentsPath),\n133\t      grade: 'missing',\n134\t      lastModified: null,\n135\t      codeLastModified: getNewestSourceMtime(fullModulePath),\n136\t      reason: `No AGENTS.md found for module: ${modulePath}`,\n137\t    };\n138\t  }\n139\t\n140\t  const docMtime = statSync(agentsPath).mtime;\n141\t  const codeMtime = getNewestSourceMtime(fullModulePath);\n142\t\n143\t  const { complete, missing } = checkAgentsMdCompleteness(agentsPath, fullModulePath);\n144\t\n145\t  if (!complete) {\n146\t    const missingList = missing.join(', ');\n147\t    return {\n148\t      path: relative(root, agentsPath),\n149\t      grade: 'stale',\n150\t      lastModified: docMtime,\n151\t      codeLastModified: codeMtime,\n152\t      reason: `AGENTS.md stale for module: ${modulePath} — missing: ${missingList}`,\n153\t    };\n154\t  }\n155\t\n156\t  return {\n157\t    path: relative(root, agentsPath),\n158\t    grade: 'fresh',\n159\t    lastModified: docMtime,\n160\t    codeLastModified: codeMtime,\n161\t    reason: 'Up to date',\n162\t  };\n163\t}\n164\t\n165\t// ─── DO NOT EDIT Header Check ────────────────────────────────────────────────\n166\t\n167\texport function checkDoNotEditHeaders(docPath: string): boolean {\n168\t  if (!existsSync(docPath)) return false;\n169\t\n170\t  try {\n171\t    const content = readFileSync(docPath, 'utf-8');\n172\t    if (content.length === 0) return false;\n173\t    return content.trimStart().startsWith(DO_NOT_EDIT_HEADER);\n174\t  } catch {\n175\t    // IGNORE: doc file may not be readable\n176\t    return false;\n177\t  }\n178\t}\n179\t\n180\t// ─── Story-Specific Freshness ────────────────────────────────────────────────\n181\t\n182\texport function checkStoryDocFreshness(\n183\t  storyId: string,\n184\t  dir?: string,\n185\t): DocHealthReport {\n186\t  const start = Date.now();\n187\t  const root = dir ?? process.cwd();\n188\t  const documents: DocHealthResult[] = [];\n189\t\n190\t  const changedFiles = getRecentlyChangedFiles(root);\n191\t  const allModules = findModules(root);\n192\t\n193\t  let modulesToCheck: string[];\n194\t\n195\t  if (changedFiles.length > 0) {\n196\t    const changedModules = new Set<string>();\n197\t    for (const file of changedFiles) {\n198\t      for (const mod of allModules) {\n199\t        if (file.startsWith(mod + '/') || file.startsWith(mod + '\\\\')) {\n200\t          changedModules.add(mod);\n201\t        }\n202\t      }\n203\t    }\n204\t    modulesToCheck = Array.from(changedModules);\n205\t  } else {\n206\t    modulesToCheck = allModules;\n207\t  }\n208\t\n209\t  for (const mod of modulesToCheck) {\n210\t    const result = checkAgentsMdForModule(mod, root);\n211\t    documents.push(result);\n212\t\n213\t    const moduleAgentsPath = join(root, mod, 'AGENTS.md');\n214\t    const actualAgentsPath = existsSync(moduleAgentsPath)\n215\t      ? moduleAgentsPath\n216\t      : join(root, 'AGENTS.md');\n217\t    if (existsSync(actualAgentsPath)) {\n218\t      checkAgentsMdLineCountInternal(actualAgentsPath, result.path, documents);\n219\t    }\n220\t  }\n221\t\n222\t  if (modulesToCheck.length === 0) {\n223\t    const rootAgentsPath = join(root, 'AGENTS.md');\n224\t    if (existsSync(rootAgentsPath)) {\n225\t      documents.push({\n226\t        path: 'AGENTS.md',\n227\t        grade: 'fresh',\n228\t        lastModified: statSync(rootAgentsPath).mtime,\n229\t        codeLastModified: null,\n230\t        reason: 'No changed modules detected',\n231\t      });\n232\t    }\n233\t  }\n234\t\n235\t  const summary = {\n236\t    fresh: documents.filter(d => d.grade === 'fresh').length,\n237\t    stale: documents.filter(d => d.grade === 'stale').length,\n238\t    missing: documents.filter(d => d.grade === 'missing').length,\n239\t    total: documents.length,\n240\t  };\n241\t\n242\t  return {\n243\t    documents,\n244\t    summary,\n245\t    passed: summary.stale === 0 && summary.missing === 0,\n246\t    scanDurationMs: Date.now() - start,\n247\t  };\n248\t}\n249\t\n250\tfunction getRecentlyChangedFiles(dir: string): string[] {\n251\t  try {\n252\t    const output = execSync('git diff --name-only HEAD~5', {\n253\t      cwd: dir,\n254\t      encoding: 'utf-8',\n255\t      stdio: ['pipe', 'pipe', 'pipe'],\n256\t      timeout: 10_000,\n257\t    });\n258\t    return output\n259\t      .trim()\n260\t      .split('\\n')\n261\t      .filter(line => line.length > 0);\n262\t  } catch {\n263\t    // IGNORE: git log may fail if not in a git repo\n264\t    return [];\n265\t  }\n266\t}\n267\t\n268\tfunction checkAgentsMdLineCountInternal(\n269\t  filePath: string,\n270\t  docPath: string,\n271\t  documents: DocHealthResult[],\n272\t): void {\n273\t  try {\n274\t    const content = readFileSync(filePath, 'utf-8');\n275\t    const lineCount = content.split('\\n').length;\n276\t    if (lineCount > 100) {\n277\t      documents.push({\n278\t        path: docPath,\n279\t        grade: 'fresh',\n280\t        lastModified: statSync(filePath).mtime,\n281\t        codeLastModified: null,\n282\t        reason: `AGENTS.md exceeds 100 lines (${lineCount} lines) — consider splitting`,\n283\t      });\n284\t    }\n285\t  } catch {\n286\t    // IGNORE: AGENTS.md file may not be readable\n287\t  }\n288\t}\n289\t"}]},"parent_tool_use_id":"toolu_01N85VFKtLmtTkPN1Zj99v6H","session_id":"b101ea9e-2f9e-4377-9c5a-f109fa318b32","uuid":"15188ad3-f2b2-4e91-91db-adc9d8c545e2","timestamp":"2026-04-03T09:54:20.431Z"}
