{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NQz7HfR2RaH3mZ8ZKKBfoL","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';\n     2→import { unlinkSync, existsSync } from 'node:fs';\n     3→import { join } from 'node:path';\n     4→\n     5→// Mock migration so index tests are isolated from real project files\n     6→vi.mock('../migration.js', () => ({\n     7→  migrateFromOldFormat: vi.fn(() => ({\n     8→    success: false,\n     9→    error: 'No old format files found for migration',\n    10→  })),\n    11→}));\n    12→\n    13→const {\n    14→  getNextStory,\n    15→  updateStoryStatus,\n    16→  getSprintState,\n    17→  generateReport,\n    18→  getStoryDrillDown,\n    19→} = await import('../index.js');\n    20→\n    21→const { writeFileSync } = await import('node:fs');\n    22→\n    23→const STATE_FILE = join(process.cwd(), 'sprint-state.json');\n    24→const TMP_FILE = join(process.cwd(), '.sprint-state.json.tmp');\n    25→\n    26→function cleanup(): void {\n    27→  for (const f of [STATE_FILE, TMP_FILE]) {\n    28→    if (existsSync(f)) unlinkSync(f);\n    29→  }\n    30→}\n    31→\n    32→describe('sprint module', () => {\n    33→  beforeEach(cleanup);\n    34→  afterEach(cleanup);\n    35→\n    36→  it('getNextStory returns ok with null selected when no stories exist', () => {\n    37→    const result = getNextStory();\n    38→    expect(result.success).toBe(true);\n    39→    if (result.success) {\n    40→      expect(result.data.selected).toBeNull();\n    41→      expect(result.data.retryExhausted).toEqual([]);\n    42→    }\n    43→  });\n    44→\n    45→  it('getNextStory delegates to selector and returns selected story', () => {\n    46→    // Write a state file with a backlog story\n    47→    const state = {\n    48→      version: 1,\n    49→      sprint: { total: 1, done: 0, failed: 0, blocked: 0, inProgress: null },\n    50→      stories: {\n    51→        'test-story': {\n    52→          status: 'backlog',\n    53→          attempts: 0,\n    54→          lastAttempt: null,\n    55→          lastError: null,\n    56→          proofPath: null,\n    57→          acResults: null,\n    58→        },\n    59→      },\n    60→      run: {\n    61→        active: false,\n    62→        startedAt: null,\n    63→        iteration: 0,\n    64→        cost: 0,\n    65→        completed: [],\n    66→        failed: [],\n    67→      },\n    68→      actionItems: [],\n    69→    };\n    70→    writeFileSync(STATE_FILE, JSON.stringify(state, null, 2), 'utf-8');\n    71→\n    72→    const result = getNextStory();\n    73→    expect(result.success).toBe(true);\n    74→    if (result.success) {\n    75→      expect(result.data.selected).not.toBeNull();\n    76→      expect(result.data.selected!.key).toBe('test-story');\n    77→    }\n    78→  });\n    79→\n    80→  it('getNextStory marks retry-exhausted stories as blocked', () => {"}]},"parent_tool_use_id":"toolu_01EPL4eJAP5W5qUxFXY5uuFc","session_id":"6707468c-554d-4568-9ea5-0d04d4a85f59","uuid":"48829207-3d01-4d79-a956-5a0cb67da053","timestamp":"2026-03-24T10:30:36.716Z"}
