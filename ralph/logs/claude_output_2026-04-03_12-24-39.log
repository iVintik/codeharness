{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PQT2qYLRdS3KYvXuBR6HHg","type":"tool_result","content":"400\t    it('task with model: claude-opus-4 parses into ResolvedTask.model (AC #3)', () => {\n401\t      const yaml = `\n402\ttasks:\n403\t  implement:\n404\t    agent: dev\n405\t    model: claude-opus-4\n406\tflow:\n407\t  - implement\n408\t`;\n409\t      const filePath = writeYaml('model.yaml', yaml);\n410\t      const result = parseWorkflow(filePath);\n411\t\n412\t      expect(result.tasks.implement.model).toBe('claude-opus-4');\n413\t      expect(result.tasks.implement.driver).toBeUndefined();\n414\t    });\n415\t\n416\t    it('task with plugins: [gstack, omo] parses into ResolvedTask.plugins (AC #3)', () => {\n417\t      const yaml = `\n418\ttasks:\n419\t  implement:\n420\t    agent: dev\n421\t    plugins:\n422\t      - gstack\n423\t      - omo\n424\tflow:\n425\t  - implement\n426\t`;\n427\t      const filePath = writeYaml('plugins.yaml', yaml);\n428\t      const result = parseWorkflow(filePath);\n429\t\n430\t      expect(result.tasks.implement.plugins).toEqual(['gstack', 'omo']);\n431\t    });\n432\t\n433\t    it('task with all three new fields parses correctly (AC #3)', () => {\n434\t      const yaml = `\n435\ttasks:\n436\t  implement:\n437\t    agent: dev\n438\t    driver: codex\n439\t    model: codex-mini\n440\t    plugins:\n441\t      - gstack\n442\tflow:\n443\t  - implement\n444\t`;\n445\t      const filePath = writeYaml('all-new.yaml', yaml);\n446\t      const result = parseWorkflow(filePath);\n447\t\n448\t      expect(result.tasks.implement.driver).toBe('codex');\n449\t      expect(result.tasks.implement.model).toBe('codex-mini');\n450\t      expect(result.tasks.implement.plugins).toEqual(['gstack']);\n451\t    });\n452\t\n453\t    it('driver: 123 (wrong type) fails schema validation (AC #8)', () => {\n454\t      const yaml = `\n455\ttasks:\n456\t  implement:\n457\t    agent: dev\n458\t    driver: 123\n459\tflow:\n460\t  - implement\n461\t`;\n462\t      const filePath = writeYaml('bad-driver.yaml', yaml);\n463\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n464\t      try {\n465\t        parseWorkflow(filePath);\n466\t      } catch (err) {\n467\t        const pe = err as WorkflowParseError;\n468\t        expect(pe.message).toContain('Schema validation failed');\n469\t      }\n470\t    });\n471\t\n472\t    it('model: true (wrong type) fails schema validation (AC #8)', () => {\n473\t      const yaml = `\n474\ttasks:\n475\t  implement:\n476\t    agent: dev\n477\t    model: true\n478\tflow:\n479\t  - implement\n480\t`;\n481\t      const filePath = writeYaml('bad-model.yaml', yaml);\n482\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n483\t      try {\n484\t        parseWorkflow(filePath);\n485\t      } catch (err) {\n486\t        const pe = err as WorkflowParseError;\n487\t        expect(pe.message).toContain('Schema validation failed');\n488\t      }\n489\t    });\n490\t\n491\t    it('plugins: \"not-array\" (wrong type) fails schema validation (AC #8)', () => {\n492\t      const yaml = `\n493\ttasks:\n494\t  implement:\n495\t    agent: dev\n496\t    plugins: not-array\n497\tflow:\n498\t  - implement\n499\t`;\n500\t      const filePath = writeYaml('bad-plugins.yaml', yaml);\n501\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n502\t      try {\n503\t        parseWorkflow(filePath);\n504\t      } catch (err) {\n505\t        const pe = err as WorkflowParseError;\n506\t        expect(pe.message).toContain('Schema validation failed');\n507\t      }\n508\t    });\n509\t\n510\t    it('new fields alongside agent pass schema validation — not rejected as additionalProperties (AC #6)', () => {\n511\t      const yaml = `\n512\ttasks:\n513\t  implement:\n514\t    agent: dev\n515\t    driver: codex\n516\t    model: codex-mini\n517\t    plugins:\n518\t      - gstack\n519\tflow:\n520\t  - implement\n521\t`;\n522\t      const filePath = writeYaml('additional-props.yaml', yaml);\n523\t      // Should NOT throw — new fields are recognized by schema\n524\t      const result = parseWorkflow(filePath);\n525\t      expect(result.tasks.implement.agent).toBe('dev');\n526\t      expect(result.tasks.implement.driver).toBe('codex');\n527\t    });\n528\t\n529\t    it('ResolvedTask type exposes optional driver, model, plugins fields (AC #4)', () => {\n530\t      const filePath = writeYaml('type-check.yaml', minimalYaml);\n531\t      const result = parseWorkflow(filePath);\n532\t      const task: ResolvedTask = result.tasks.implement;\n533\t\n534\t      // TypeScript compile-time check: these fields exist on ResolvedTask\n535\t      const _driver: string | undefined = task.driver;\n536\t      const _model: string | undefined = task.model;\n537\t      const _plugins: string[] | undefined = task.plugins;\n538\t\n539\t      // Runtime: they are undefined when not set\n540\t      expect(_driver).toBeUndefined();\n541\t      expect(_model).toBeUndefined();\n542\t      expect(_plugins).toBeUndefined();\n543\t    });\n544\t\n545\t    it('plugins: [123] (non-string array items) fails schema validation', () => {\n546\t      const yaml = `\n547\ttasks:\n548\t  implement:\n549\t    agent: dev\n550\t    plugins:\n551\t      - 123\n552\tflow:\n553\t  - implement\n554\t`;\n555\t      const filePath = writeYaml('bad-plugins-items.yaml', yaml);\n556\t      expect(() => parseWorkflow(filePath)).toThrow(WorkflowParseError);\n557\t      try {\n558\t        parseWorkflow(filePath);\n559\t      } catch (err) {\n560\t        const pe = err as WorkflowParseError;\n561\t        expect(pe.message).toContain('Schema validation failed');\n562\t      }\n563\t    });\n564\t\n565\t    it('empty plugins array is valid', () => {\n566\t      const yaml = `\n567\ttasks:\n568\t  implement:\n569\t    agent: dev\n570\t    plugins: []\n571\tflow:\n572\t  - implement\n573\t`;\n574\t      const filePath = writeYaml('empty-plugins.yaml', yaml);\n575\t      const result = parseWorkflow(filePath);\n576\t      expect(result.tasks.implement.plugins).toEqual([]);\n577\t    });\n578\t  });\n579\t\n580\t  describe('WorkflowParseError structure (AC #8)', () => {\n581\t    it('extends Error and has name and errors array', () => {\n582\t      const err = new WorkflowParseError('test error', [\n583\t        { path: '/tasks', message: 'missing' },\n584\t      ]);\n585\t\n586\t      expect(err).toBeInstanceOf(Error);\n587\t      expect(err.name).toBe('WorkflowParseError');\n588\t      expect(err.message).toBe('test error');\n589\t      expect(err.errors).toHaveLength(1);\n590\t      expect(err.errors[0]).toEqual({ path: '/tasks', message: 'missing' });\n591\t    });\n592\t\n593\t    it('defaults errors to empty array when not provided', () => {\n594\t      const err = new WorkflowParseError('test error');\n595\t      expect(err.errors).toEqual([]);\n596\t    });\n597\t  });\n598\t});\n599\t\n600\t// --- Patch Resolution Tests ---\n601\t\n602\tdescribe('loadWorkflowPatch', () => {\n603\t  it('returns null for non-existent file', () => {\n604\t    const result = loadWorkflowPatch(join(testDir, 'does-not-exist.patch.yaml'));\n605\t    expect(result).toBeNull();\n606\t  });\n607\t\n608\t  it('throws WorkflowParseError for invalid YAML', () => {\n609\t    const filePath = writeYaml('bad.patch.yaml', '{{{{not yaml');\n610\t    expect(() => loadWorkflowPatch(filePath)).toThrow(WorkflowParseError);\n611\t    try {\n612\t      loadWorkflowPatch(filePath);\n613\t    } catch (err) {\n614\t      const pe = err as WorkflowParseError;\n615\t      expect(pe.message).toContain('Invalid YAML in patch file');\n616\t      expect(pe.message).toContain(filePath);\n617\t    }\n618\t  });\n619\t\n620\t  it('throws WorkflowParseError for non-object YAML (scalar)', () => {\n621\t    const filePath = writeYaml('scalar.patch.yaml', '42');\n622\t    expect(() => loadWorkflowPatch(filePath)).toThrow(WorkflowParseError);\n623\t    try {\n624\t      loadWorkflowPatch(filePath);\n625\t    } catch (err) {\n626\t      const pe = err as WorkflowParseError;\n627\t      expect(pe.message).toContain('not a valid object');\n628\t    }\n629\t  });\n630\t\n631\t  it('loads a valid patch file', () => {\n632\t    const patchContent = `\n633\textends: embedded://default\n634\toverrides:\n635\t  tasks:\n636\t    implement:\n637\t      session: continue\n638\t`;\n639\t    const filePath = writeYaml('valid.patch.yaml', patchContent);\n640\t    const result = loadWorkflowPatch(filePath);\n641\t    expect(result).not.toBeNull();\n642\t    expect(result!.extends).toBe('embedded://default');\n643\t    expect(result!.overrides).toBeDefined();\n644\t    expect((result!.overrides!.tasks as Record<string, unknown>).implement).toBeDefined();\n645\t  });\n646\t});\n647\t\n648\tdescribe('mergeWorkflowPatch', () => {\n649\t  const base: Record<string, unknown> = {\n650\t    tasks: {\n651\t      implement: { agent: 'dev', scope: 'per-story', session: 'fresh', source_access: true },\n652\t      verify: { agent: 'evaluator', scope: 'per-run', session: 'fresh', source_access: false },\n653\t    },\n654\t    flow: ['implement', 'verify'],\n655\t  };\n656\t\n657\t  it('handles overrides-only patch (deep merge)', () => {\n658\t    const patch: WorkflowPatch = {\n659\t      overrides: {\n660\t        tasks: {\n661\t          implement: { session: 'continue', max_budget_usd: 5.0 },\n662\t        },\n663\t      },\n664\t    };\n665\t    const result = mergeWorkflowPatch(base, patch);\n666\t    const tasks = result.tasks as Record<string, Record<string, unknown>>;\n667\t\n668\t    // Deep-merged: implement gets new session and max_budget_usd, keeps agent/scope/source_access\n669\t    expect(tasks.implement.agent).toBe('dev');\n670\t    expect(tasks.implement.scope).toBe('per-story');\n671\t    expect(tasks.implement.session).toBe('continue');\n672\t    expect(tasks.implement.max_budget_usd).toBe(5.0);\n673\t    expect(tasks.implement.source_access).toBe(true);\n674\t\n675\t    // verify unchanged\n676\t    expect(tasks.verify.agent).toBe('evaluator');\n677\t\n678\t    // flow unchanged\n679\t    expect(result.flow).toEqual(['implement', 'verify']);\n680\t  });\n681\t\n682\t  it('handles replace-only patch (full replacement)', () => {\n683\t    const patch: WorkflowPatch = {\n684\t      replace: {\n685\t        flow: ['implement'],\n686\t      },\n687\t    };\n688\t    const result = mergeWorkflowPatch(base, patch);\n689\t\n690\t    // flow fully replaced\n691\t    expect(result.flow).toEqual(['implement']);\n692\t\n693\t    // tasks unchanged\n694\t    const tasks = result.tasks as Record<string, Record<string, unknown>>;\n695\t    expect(tasks.implement.agent).toBe('dev');\n696\t    expect(tasks.verify.agent).toBe('evaluator');\n697\t  });\n698\t\n699\t  it('handles patch with both overrides and replace', () => {\n700\t    const patch: WorkflowPatch = {\n701\t      overrides: {\n702\t        tasks: {\n703\t          implement: { session: 'continue' },\n704\t        },\n705\t      },\n706\t      replace: {\n707\t        flow: ['implement'],\n708\t      },\n709\t    };\n710\t    const result = mergeWorkflowPatch(base, patch);\n711\t    const tasks = result.tasks as Record<string, Record<string, unknown>>;\n712\t\n713\t    // overrides applied\n714\t    expect(tasks.implement.session).toBe('continue');\n715\t    expect(tasks.implement.agent).toBe('dev');\n716\t\n717\t    // replace applied after overrides\n718\t    expect(result.flow).toEqual(['implement']);\n719\t  });\n720\t\n721\t  it('replace overwrites even if overrides also touched the same key', () => {\n722\t    const patch: WorkflowPatch = {\n723\t      overrides: {\n724\t        flow: ['implement', 'verify', 'extra'],\n725\t      },\n726\t      replace: {\n727\t        flow: ['only-this'],\n728\t      },\n729\t    };\n730\t    const result = mergeWorkflowPatch(base, patch);\n731\t    // replace wins because it runs after overrides\n732\t    expect(result.flow).toEqual(['only-this']);\n733\t  });\n734\t});\n735\t\n736\tdescribe('resolveWorkflow', () => {\n737\t  it('returns embedded workflow when no patches exist', () => {\n738\t    // Use a cwd with no .codeharness directory\n739\t    const result = resolveWorkflow({ cwd: testDir });\n740\t\n741\t    // Should return the embedded default workflow\n742\t    expect(result.tasks).toBeDefined();\n743\t    expect(result.tasks.implement).toBeDefined();\n744\t    expect(result.tasks.implement.agent).toBe('dev');\n745\t    expect(result.tasks.verify).toBeDefined();\n746\t    expect(result.tasks.verify.agent).toBe('evaluator');\n747\t    expect(result.flow.length).toBeGreaterThan(0);\n748\t  });\n749\t\n750\t  it('deep-merges overrides from project patch onto embedded base', () => {\n751\t    // Create project patch directory\n752\t    const patchDir = join(testDir, '.codeharness', 'workflows');\n753\t    mkdirSync(patchDir, { recursive: true });\n754\t\n755\t    const patchContent = `\n756\textends: embedded://default\n757\toverrides:\n758\t  tasks:\n759\t    implement:\n760\t      session: continue\n761\t      max_budget_usd: 10.0\n762\t`;\n763\t    writeFileSync(join(patchDir, 'default.patch.yaml'), patchContent, 'utf-8');\n764\t\n765\t    const result = resolveWorkflow({ cwd: testDir });\n766\t\n767\t    expect(result.tasks.implement.session).toBe('continue');\n768\t    expect(result.tasks.implement.max_budget_usd).toBe(10.0);\n769\t    // Preserved from base\n770\t    expect(result.tasks.implement.agent).toBe('dev');\n771\t    expect(result.tasks.implement.scope).toBe('per-story');\n772\t    expect(result.tasks.implement.source_access).toBe(true);\n773\t  });\n774\t\n775\t  it('deep-merges driver, model, plugins via project patch onto embedded base (Story 11-1)', () => {\n776\t    const patchDir = join(testDir, '.codeharness', 'workflows');\n777\t    mkdirSync(patchDir, { recursive: true });\n778\t\n779\t    const patchContent = `\n780\textends: embedded://default\n781\toverrides:\n782\t  tasks:\n783\t    implement:\n784\t      driver: codex\n785\t      model: codex-mini\n786\t      plugins:\n787\t        - gstack\n788\t`;\n789\t    writeFileSync(join(patchDir, 'default.patch.yaml'), patchContent, 'utf-8');\n790\t\n791\t    const result = resolveWorkflow({ cwd: testDir });\n792\t\n793\t    expect(result.tasks.implement.driver).toBe('codex');\n794\t    expect(result.tasks.implement.model).toBe('codex-mini');\n795\t    expect(result.tasks.implement.plugins).toEqual(['gstack']);\n796\t    // Preserved from base\n797\t    expect(result.tasks.implement.agent).toBe('dev');\n798\t    expect(result.tasks.implement.scope).toBe('per-story');\n799\t  });"}]},"parent_tool_use_id":"toolu_01U85MaKaYFD6RV3D181SmSg","session_id":"4b1f7711-6ed7-4488-a0af-b261e761b450","uuid":"9ae01535-aab3-42b3-bce8-51af24d45347","timestamp":"2026-04-03T08:37:09.964Z"}
