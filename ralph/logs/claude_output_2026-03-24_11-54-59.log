pect(provider.parseCoverageReport(testDir)).toBe(72.3);\n   372→  });\n   373→\n   374→  it('prefers coverage/ over src/coverage/', () => {\n   375→    mkdirSync(join(testDir, 'coverage'));\n   376→    writeFileSync(\n   377→      join(testDir, 'coverage', 'coverage-summary.json'),\n   378→      JSON.stringify({ total: { statements: { pct: 90 } } }),\n   379→    );\n   380→    mkdirSync(join(testDir, 'src', 'coverage'), { recursive: true });\n   381→    writeFileSync(\n   382→      join(testDir, 'src', 'coverage', 'coverage-summary.json'),\n   383→      JSON.stringify({ total: { statements: { pct: 50 } } }),\n   384→    );\n   385→    expect(provider.parseCoverageReport(testDir)).toBe(90);\n   386→  });\n   387→});\n   388→\n   389→// ── getProjectName (AC15) ────────────────────────────────────────────────────\n   390→\n   391→describe('NodejsProvider.getProjectName', () => {\n   392→  it('returns name from package.json (AC15)', () => {\n   393→    writeFileSync(\n   394→      join(testDir, 'package.json'),\n   395→      JSON.stringify({ name: 'my-app' }),\n   396→    );\n   397→    expect(provider.getProjectName(testDir)).toBe('my-app');\n   398→  });\n   399→\n   400→  it('returns null when no package.json', () => {\n   401→    expect(provider.getProjectName(testDir)).toBeNull();\n   402→  });\n   403→\n   404→  it('returns null when package.json has no name field', () => {\n   405→    writeFileSync(join(testDir, 'package.json'), JSON.stringify({ version: '1.0.0' }));\n   406→    expect(provider.getProjectName(testDir)).toBeNull();\n   407→  });\n   408→\n   409→  it('returns null for malformed package.json', () => {\n   410→    writeFileSync(join(testDir, 'package.json'), '{broken');\n   411→    expect(provider.getProjectName(testDir)).toBeNull();\n   412→  });\n   413→});\n   414→\n   415→// ── getSemgrepLanguages (AC16) ───────────────────────────────────────────────\n   416→\n   417→describe('NodejsProvider.getSemgrepLanguages', () => {\n   418→  it('returns javascript and typescript (AC16)', () => {\n   419→    expect(provider.getSemgrepLanguages()).toEqual(['javascript', 'typescript']);\n   420→  });\n   421→});\n   422→\n   423→// ── getBuildCommands / getTestCommands (AC17) ────────────────────────────────\n   424→\n   425→describe('NodejsProvider.getBuildCommands and getTestCommands', () => {\n   426→  it('getBuildCommands returns [\"npm install\", \"npm run build\"] (AC17)', () => {\n   427→    expect(provider.getBuildCommands()).toEqual(['npm install', 'npm run build']);\n   428→  });\n   429→\n   430→  it('getTestCommands returns [\"npm test\"] (AC17)', () => {\n   431→    expect(provider.getTestCommands()).toEqual(['npm test']);\n   432→  });\n   433→});\n   434→\n   435→// ── patchStartScript ─────────────────────────────────────────────────────────\n   436→\n   437→describe('NodejsProvider.patchStartScript', () => {\n   438→  it('patches start script with --require flag', () => {\n   439→    writeFileSync(\n   440→      join(testDir, 'package.json'),\n   441→      JSON.stringify({ scripts: { start: 'node server.js' } }, null, 2),\n   442→    );\n   443→    const result = provider.patchStartScript!(testDir);\n   444→    expect(result).toBe(true);\n   445→\n   446→    const pkg = JSON.parse(readFileSync(join(testDir, 'package.json'), 'utf-8'));\n   447→    expect(pkg.scripts['start:instrumented']).toContain('--require');\n   448→    expect(pkg.scripts['start:instrumented']).toContain('node server.js');\n   449→  });\n   450→\n   451→  it('patches dev script when no start script', () => {\n   452→    writeFileSync(\n   453→      join(testDir, 'package.json'),\n   454→      JSON.stringify({ scripts: { dev: 'ts-node src/index.ts' } }, null, 2),\n   455→    );\n   456→    const result = provider.patchStartScript!(testDir);\n   457→    expect(result).toBe(true);\n   458→\n   459→    const pkg = JSON.parse(readFileSync(join(testDir, 'package.json'), 'utf-8'));\n   460→    expect(pkg.scripts['dev:instrumented']).toContain('--require');\n   461→  });\n   462→\n   463→  it('returns false when already patched', () => {\n   464→    writeFileSync(\n   465→      join(testDir, 'package.json'),\n   466→      JSON.stringify({\n   467→        scripts: {\n   468→          start: 'node server.js',\n   469→          'start:instrumented':\n   470→            \"NODE_OPTIONS='--require @opentelemetry/auto-instrumentations-node/register' node server.js\",\n   471→        },\n   472→      }, null, 2),\n   473→    );\n   474→    expect(provider.patchStartScript!(testDir)).toBe(false);\n   475→  });\n   476→\n   477→  it('returns false when no scripts', () => {\n   478→    writeFileSync(join(testDir, 'package.json'), JSON.stringify({ name: 'test' }));\n   479→    expect(provider.patchStartScript!(testDir)).toBe(false);\n   480→  });\n   481→\n   482→  it('returns false when no package.json', () => {\n   483→    expect(provider.patchStartScript!(testDir)).toBe(false);\n   484→  });\n   485→\n   486→  it('returns false when no start or dev script', () => {\n   487→    writeFileSync(\n   488→      join(testDir, 'package.json'),\n   489→      JSON.stringify({ scripts: { test: 'vitest' } }),\n   490→    );\n   491→    expect(provider.patchStartScript!(testDir)).toBe(false);\n   492→  });\n   493→});\n   494→\n   495→// ── installOtlp ──────────────────────────────────────────────────────────────\n   496→\n   497→describe('NodejsProvider.installOtlp', () => {\n   498→  it('returns failure result for non-existent directory', () => {\n   499→    const result = provider.installOtlp(join(testDir, 'nonexistent'));\n   500→    expect(result.success).toBe(false);\n   501→    expect(result.packagesInstalled).toEqual([]);\n   502→    expect(result.error).toBeDefined();\n   503→  });\n   504→});\n   505→\n   506→// ── StackProvider interface compliance ───────────────────────────────────────\n   507→\n   508→describe('NodejsProvider — StackProvider interface compliance', () => {\n   509→  it('implements all required StackProvider methods', () => {\n   510→    expect(typeof provider.detectAppType).toBe('function');\n   511→    expect(typeof provider.getCoverageTool).toBe('function');\n   512→    expect(typeof provider.detectCoverageConfig).toBe('function');\n   513→    expect(typeof provider.getOtlpPackages).toBe('function');\n   514→    expect(typeof provider.installOtlp).toBe('function');\n   515→    expect(typeof provider.getDockerfileTemplate).toBe('function');\n   516→    expect(typeof provider.getDockerBuildStage).toBe('function');\n   517→    expect(typeof provider.getRuntimeCopyDirectives).toBe('function');\n   518→    expect(typeof provider.getBuildCommands).toBe('function');\n   519→    expect(typeof provider.getTestCommands).toBe('function');\n   520→    expect(typeof provider.getSemgrepLanguages).toBe('function');\n   521→    expect(typeof provider.parseTestOutput).toBe('function');\n   522→    expect(typeof provider.parseCoverageReport).toBe('function');\n   523→    expect(typeof provider.getProjectName).toBe('function');\n   524→  });\n   525→\n   526→  it('implements optional patchStartScript method', () => {\n   527→    expect(typeof provider.patchStartScript).toBe('function');\n   528→  });\n   529→});\n   530→"}]},"parent_tool_use_id":"toolu_01AYUK9c5QWsnPVHthUcsHao","session_id":"ec2bf7d9-1cd3-4665-9804-65790a3eadb3","uuid":"cd0d350a-d449-4194-a065-e20476ea17b5","timestamp":"2026-03-24T08:05:27.860Z"}
