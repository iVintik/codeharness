{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DKZiqqhXVQXELh8X9AM5CM","type":"tool_result","content":"300\t    sessionId: 'sess-abc-123',\n301\t    success: true,\n302\t    durationMs: 1000,\n303\t    output: 'Done',\n304\t  });\n305\t\n306\t  // Default: sprint-status.yaml exists with two stories\n307\t  mockExistsSync.mockImplementation((path: string) => {\n308\t    if (path === '/project/sprint-status.yaml') return true;\n309\t    return false;\n310\t  });\n311\t\n312\t  mockReadFileSync.mockReturnValue('dummy yaml');\n313\t  mockParse.mockReturnValue({\n314\t    development_status: {\n315\t      'epic-5': 'backlog',\n316\t      '5-1-foo': 'ready-for-dev',\n317\t      '5-2-bar': 'backlog',\n318\t    },\n319\t  });\n320\t}\n321\t\n322\t// --- Tests ---\n323\t\n324\tdescribe('loadWorkItems', () => {\n325\t  beforeEach(() => {\n326\t    vi.clearAllMocks();\n327\t  });\n328\t\n329\t  it('loads stories from sprint-status.yaml excluding epics and retrospectives', () => {\n330\t    mockExistsSync.mockReturnValue(true);\n331\t    mockReadFileSync.mockReturnValue('yaml content');\n332\t    mockParse.mockReturnValue({\n333\t      development_status: {\n334\t        'epic-5': 'backlog',\n335\t        '5-1-foo': 'ready-for-dev',\n336\t        '5-2-bar': 'backlog',\n337\t        '5-3-baz': 'done',\n338\t        'epic-5-retrospective': 'backlog',\n339\t      },\n340\t    });\n341\t\n342\t    const items = loadWorkItems('/path/sprint-status.yaml');\n343\t\n344\t    expect(items).toEqual([\n345\t      { key: '5-1-foo', source: 'sprint' },\n346\t      { key: '5-2-bar', source: 'sprint' },\n347\t    ]);\n348\t  });\n349\t"}]},"parent_tool_use_id":"toolu_01E368mBox6AGS9E4aPFSS48","session_id":"8a461711-53e2-475a-88dd-c7013f6080c5","uuid":"30bac7b0-8382-4ffc-b4cb-8144a0a434c0","timestamp":"2026-04-03T17:15:52.934Z"}
