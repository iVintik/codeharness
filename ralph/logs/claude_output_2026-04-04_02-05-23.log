{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Enqsn5GYMQo3UpRuRUa64f","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, type Mock } from 'vitest';\n2\timport type { AgentDriver, DispatchOpts, DriverCapabilities, DriverHealth } from '../agents/types.js';\n3\timport type { StreamEvent } from '../agents/stream-parser.js';\n4\t\n5\t// Create controllable mocks — must use vi.hoisted so they're available in vi.mock factories\n6\tconst { mockReadFileSync, mockExecSync, mockExecAsync } = vi.hoisted(() => ({\n7\t  mockReadFileSync: vi.fn(),\n8\t  mockExecSync: vi.fn(),\n9\t  mockExecAsync: vi.fn(),\n10\t}));\n11\t\n12\t// Mock node:fs\n13\tvi.mock('node:fs', () => ({\n14\t  readFileSync: mockReadFileSync,\n15\t}));\n16\t\n17\t// Mock node:child_process\n18\tvi.mock('node:child_process', () => ({\n19\t  execSync: mockExecSync,\n20\t  exec: vi.fn(),\n21\t}));\n22\t\n23\t// Mock node:util to return our controllable mockExecAsync\n24\tvi.mock('node:util', () => ({\n25\t  promisify: () => mockExecAsync,\n26\t}));\n27\t\n28\timport {\n29\t  resolveConflicts,\n30\t  buildConflictPrompt,\n31\t  type MergeConflictContext,\n32\t  type ConflictResolutionResult,\n33\t} from '../merge-agent.js';\n34\t\n35\t// --- Test Helpers ---\n36\t\n37\tfunction createMockDriver(overrides?: {\n38\t  dispatchFn?: (opts: DispatchOpts) => AsyncIterable<StreamEvent>;\n39\t}): AgentDriver {\n40\t  const defaultDispatch = async function* (_opts: DispatchOpts): AsyncIterable<StreamEvent> {\n41\t    // Yield nothing — simulates silent resolution\n42\t  };\n43\t\n44\t  return {\n45\t    name: 'mock-driver',\n46\t    defaultModel: 'mock-model',\n47\t    capabilities: {\n48\t      supportsPlugins: false,\n49\t      supportsStreaming: true,\n50\t      costReporting: false,\n51\t      costTier: 1,\n52\t    },\n53\t    healthCheck: vi.fn().mockResolvedValue({\n54\t      available: true,\n55\t      authenticated: true,\n56\t      version: '1.0.0',\n57\t    }),\n58\t    dispatch: overrides?.dispatchFn ?? defaultDispatch,\n59\t    getLastCost: vi.fn().mockReturnValue(null),\n60\t  };\n61\t}\n62\t\n63\tfunction createContext(overrides?: Partial<MergeConflictContext>): MergeConflictContext {\n64\t  return {\n65\t    epicId: '18',\n66\t    branch: 'codeharness/epic-18-feature',\n67\t    conflicts: ['src/index.ts', 'src/utils.ts'],\n68\t    mainDescription: 'Main branch has the base implementation',\n69\t    branchDescription: 'Feature branch adds conflict resolution',\n70\t    cwd: '/repo',\n71\t    testCommand: 'npm test',\n72\t    driver: createMockDriver(),\n73\t    ...overrides,\n74\t  };\n75\t}\n76\t\n77\tdescribe('merge-agent', () => {\n78\t  beforeEach(() => {\n79\t    vi.clearAllMocks();\n80\t  });\n81\t\n82\t  describe('MergeConflictContext interface shape (AC #9)', () => {\n83\t    it('has all required fields', () => {\n84\t      const ctx = createContext();\n85\t      expect(ctx).toHaveProperty('epicId');\n86\t      expect(ctx).toHaveProperty('branch');\n87\t      expect(ctx).toHaveProperty('conflicts');\n88\t      expect(ctx).toHaveProperty('mainDescription');\n89\t      expect(ctx).toHaveProperty('branchDescription');\n90\t      expect(ctx).toHaveProperty('cwd');\n91\t      expect(ctx).toHaveProperty('testCommand');\n92\t      expect(ctx).toHaveProperty('driver');\n93\t    });\n94\t  });\n95\t\n96\t  describe('ConflictResolutionResult interface shape (AC #7)', () => {\n97\t    it('success result has correct shape', () => {\n98\t      const result: ConflictResolutionResult = {\n99\t        resolved: true,\n100\t        attempts: 1,\n101\t        escalated: false,\n102\t        testResults: { passed: 10, failed: 0, coverage: 95 },\n103\t        resolvedFiles: ['src/index.ts'],\n104\t      };\n105\t      expect(result.resolved).toBe(true);\n106\t      expect(result.attempts).toBe(1);\n107\t      expect(result.escalated).toBe(false);\n108\t      expect(result.testResults).toEqual({ passed: 10, failed: 0, coverage: 95 });\n109\t      expect(result.resolvedFiles).toEqual(['src/index.ts']);\n110\t    });\n111\t\n112\t    it('escalated result has correct shape', () => {\n113\t      const result: ConflictResolutionResult = {\n114\t        resolved: false,\n115\t        attempts: 3,\n116\t        escalated: true,\n117\t        escalationMessage: 'Could not resolve after 3 attempts',\n118\t      };\n119\t      expect(result.resolved).toBe(false);\n120\t      expect(result.escalated).toBe(true);\n121\t      expect(result.escalationMessage).toBeDefined();\n122\t      expect(result.testResults).toBeUndefined();\n123\t      expect(result.resolvedFiles).toBeUndefined();\n124\t    });\n125\t  });\n126\t\n127\t  describe('buildConflictPrompt (AC #2, #8)', () => {\n128\t    it('includes conflict markers from files', () => {\n129\t      mockReadFileSync.mockImplementation((path: string) => {\n130\t        if (path.includes('index.ts')) return '<<<<<<< main\\nold code\\n=======\\nnew code\\n>>>>>>> branch';\n131\t        if (path.includes('utils.ts')) return '<<<<<<< main\\nutil old\\n=======\\nutil new\\n>>>>>>> branch';\n132\t        return '';\n133\t      });\n134\t\n135\t      const ctx = createContext();\n136\t      const prompt = buildConflictPrompt(ctx);\n137\t\n138\t      expect(prompt).toContain('src/index.ts');\n139\t      expect(prompt).toContain('src/utils.ts');\n140\t      expect(prompt).toContain('<<<<<<< main');\n141\t      expect(prompt).toContain('>>>>>>> branch');\n142\t    });\n143\t\n144\t    it('includes main and branch descriptions (AC #8)', () => {\n145\t      mockReadFileSync.mockReturnValue('conflict content');\n146\t\n147\t      const ctx = createContext({\n148\t        mainDescription: 'Main has base implementation',\n149\t        branchDescription: 'Branch adds conflict resolver',\n150\t      });\n151\t      const prompt = buildConflictPrompt(ctx);\n152\t\n153\t      expect(prompt).toContain('**Main branch context:** Main has base implementation');\n154\t      expect(prompt).toContain('**Feature branch context:** Branch adds conflict resolver');\n155\t    });\n156\t\n157\t    it('includes instructions to resolve and commit (AC #8)', () => {\n158\t      mockReadFileSync.mockReturnValue('conflict content');\n159\t\n160\t      const ctx = createContext();\n161\t      const prompt = buildConflictPrompt(ctx);\n162\t\n163\t      expect(prompt).toContain('Resolve ALL conflicts preserving changes from both branches');\n164\t      expect(prompt).toContain('Both are correct additions');\n165\t      expect(prompt).toContain('git add');\n166\t      expect(prompt).toContain('commit the merge resolution');\n167\t    });\n168\t\n169\t    it('handles unreadable files gracefully', () => {\n170\t      mockReadFileSync.mockImplementation(() => {\n171\t        throw new Error('ENOENT: no such file');\n172\t      });\n173\t\n174\t      const ctx = createContext();\n175\t      const prompt = buildConflictPrompt(ctx);\n176\t\n177\t      expect(prompt).toContain('deleted on one side or unreadable');\n178\t    });\n179\t\n180\t    it('includes test failure output on retry (AC #5)', () => {\n181\t      mockReadFileSync.mockReturnValue('conflict content');\n182\t\n183\t      const ctx = createContext();\n184\t      const prompt = buildConflictPrompt(ctx, 'FAIL src/index.test.ts\\n  TypeError: undefined is not a function');\n185\t\n186\t      expect(prompt).toContain('**Previous attempt failed tests:**');\n187\t      expect(prompt).toContain('TypeError: undefined is not a function');\n188\t      expect(prompt).toContain('Fix the resolution to make all tests pass');\n189\t    });\n190\t\n191\t    it('includes file count in prompt', () => {\n192\t      mockReadFileSync.mockReturnValue('content');\n193\t\n194\t      const ctx = createContext({ conflicts: ['a.ts', 'b.ts', 'c.ts'] });\n195\t      const prompt = buildConflictPrompt(ctx);\n196\t\n197\t      expect(prompt).toContain('Merge conflict in 3 file(s)');\n198\t    });\n199\t  });\n200\t\n201\t  describe('resolveConflicts — exports (AC #1)', () => {\n202\t    it('exports resolveConflicts function', () => {\n203\t      expect(typeof resolveConflicts).toBe('function');\n204\t    });\n205\t  });\n206\t\n207\t  describe('resolveConflicts — empty conflicts guard', () => {\n208\t    it('returns resolved immediately for empty conflict list', async () => {\n209\t      const ctx = createContext({ conflicts: [] });\n210\t      const result = await resolveConflicts(ctx);\n211\t\n212\t      expect(result.resolved).toBe(true);\n213\t      expect(result.attempts).toBe(0);\n214\t      expect(result.escalated).toBe(false);\n215\t    });\n216\t  });\n217\t\n218\t  describe('resolveConflicts — successful resolution (AC #3, #4)', () => {\n219\t    it('returns resolved on first attempt when tests pass', async () => {\n220\t      mockReadFileSync.mockReturnValue('conflict content');\n221\t      mockExecAsync.mockResolvedValue({ stdout: '10 passed\\n0 failed' });\n222\t\n223\t      const dispatchCalls: DispatchOpts[] = [];\n224\t      const driver = createMockDriver({\n225\t        dispatchFn: async function* (opts: DispatchOpts) {\n226\t          dispatchCalls.push(opts);\n227\t        },\n228\t      });\n229\t\n230\t      const ctx = createContext({ driver });\n231\t      const result = await resolveConflicts(ctx);\n232\t\n233\t      expect(result.resolved).toBe(true);\n234\t      expect(result.attempts).toBe(1);\n235\t      expect(result.escalated).toBe(false);\n236\t      expect(result.testResults).toEqual({ passed: 10, failed: 0 });\n237\t      expect(result.resolvedFiles).toEqual(['src/index.ts', 'src/utils.ts']);\n238\t      expect(dispatchCalls).toHaveLength(1);\n239\t    });\n240\t\n241\t    it('dispatches driver with correct prompt containing conflict markers (AC #2, #8)', async () => {\n242\t      mockReadFileSync.mockReturnValue('<<<<<<< main\\nold\\n=======\\nnew\\n>>>>>>> branch');\n243\t      mockExecAsync.mockResolvedValue({ stdout: '5 passed' });\n244\t\n245\t      const dispatchCalls: DispatchOpts[] = [];\n246\t      const driver = createMockDriver({\n247\t        dispatchFn: async function* (opts: DispatchOpts) {\n248\t          dispatchCalls.push(opts);\n249\t        },\n250\t      });\n251\t\n252\t      const ctx = createContext({ driver });\n253\t      await resolveConflicts(ctx);\n254\t\n255\t      expect(dispatchCalls).toHaveLength(1);\n256\t      expect(dispatchCalls[0].prompt).toContain('<<<<<<< main');\n257\t      expect(dispatchCalls[0].prompt).toContain('>>>>>>> branch');\n258\t      expect(dispatchCalls[0].prompt).toContain('Main branch context:');\n259\t      expect(dispatchCalls[0].prompt).toContain('Feature branch context:');\n260\t      expect(dispatchCalls[0].cwd).toBe('/repo');\n261\t      expect(dispatchCalls[0].sourceAccess).toBe(true);\n262\t    });\n263\t\n264\t    it('includes coverage in test results when available', async () => {\n265\t      mockReadFileSync.mockReturnValue('conflict');\n266\t      mockExecAsync.mockResolvedValue({ stdout: '10 passed\\nAll files | 95.5' });\n267\t\n268\t      const ctx = createContext();\n269\t      const result = await resolveConflicts(ctx);\n270\t\n271\t      expect(result.resolved).toBe(true);\n272\t      expect(result.testResults?.coverage).toBe(95.5);\n273\t    });\n274\t  });\n275\t\n276\t  describe('resolveConflicts — retry on test failure (AC #5)', () => {\n277\t    it('retries up to 3 times with test failure context', async () => {\n278\t      mockReadFileSync.mockReturnValue('conflict content');\n279\t\n280\t      let callCount = 0;\n281\t      mockExecAsync.mockImplementation(async () => {\n282\t        callCount++;\n283\t        if (callCount < 3) {\n284\t          return { stdout: '5 passed\\n2 failed' };\n285\t        }\n286\t        return { stdout: '7 passed\\n0 failed' };\n287\t      });\n288\t\n289\t      const dispatchCalls: DispatchOpts[] = [];\n290\t      const driver = createMockDriver({\n291\t        dispatchFn: async function* (opts: DispatchOpts) {\n292\t          dispatchCalls.push(opts);\n293\t        },\n294\t      });\n295\t\n296\t      const ctx = createContext({ driver });\n297\t      const result = await resolveConflicts(ctx);\n298\t\n299\t      expect(result.resolved).toBe(true);\n300\t      expect(result.attempts).toBe(3);\n301\t      expect(dispatchCalls).toHaveLength(3);\n302\t\n303\t      // Verify git reset was called between attempts\n304\t      const resetCalls = mockExecSync.mock.calls.filter(\n305\t        (c: unknown[]) => (c[0] as string).includes('reset --hard HEAD~1'),\n306\t      );\n307\t      expect(resetCalls).toHaveLength(2);\n308\t    });\n309\t\n310\t    it('retry prompt includes previous test failure output', async () => {\n311\t      mockReadFileSync.mockReturnValue('conflict');\n312\t\n313\t      let callCount = 0;\n314\t      mockExecAsync.mockImplementation(async () => {\n315\t        callCount++;\n316\t        if (callCount === 1) {\n317\t          return { stdout: '3 passed\\n1 failed\\nFAIL: TypeError at line 42' };\n318\t        }\n319\t        return { stdout: '4 passed\\n0 failed' };\n320\t      });\n321\t\n322\t      const dispatchCalls: DispatchOpts[] = [];\n323\t      const driver = createMockDriver({\n324\t        dispatchFn: async function* (opts: DispatchOpts) {\n325\t          dispatchCalls.push(opts);\n326\t        },\n327\t      });\n328\t\n329\t      const ctx = createContext({ driver });\n330\t      await resolveConflicts(ctx);\n331\t\n332\t      expect(dispatchCalls).toHaveLength(2);\n333\t      // Second dispatch should include the failure output\n334\t      expect(dispatchCalls[1].prompt).toContain('Previous attempt failed tests');\n335\t      expect(dispatchCalls[1].prompt).toContain('TypeError at line 42');\n336\t    });\n337\t  });\n338\t\n339\t  describe('resolveConflicts — escalation after 3 failures (AC #6)', () => {\n340\t    it('returns escalated after 3 consecutive failures', async () => {\n341\t      mockReadFileSync.mockReturnValue('conflict');\n342\t      mockExecAsync.mockResolvedValue({ stdout: '3 passed\\n2 failed' });\n343\t\n344\t      const ctx = createContext();\n345\t      const result = await resolveConflicts(ctx);\n346\t\n347\t      expect(result.resolved).toBe(false);\n348\t      expect(result.attempts).toBe(3);\n349\t      expect(result.escalated).toBe(true);\n350\t      expect(result.escalationMessage).toBeDefined();\n351\t    });\n352\t\n353\t    it('escalation message contains worktree path, branch, files, and git diff command', async () => {\n354\t      mockReadFileSync.mockReturnValue('conflict');\n355\t      mockExecAsync.mockResolvedValue({ stdout: '0 passed\\n1 failed' });\n356\t\n357\t      const ctx = createContext({\n358\t        epicId: '42',\n359\t        branch: 'codeharness/epic-42-feature',\n360\t        conflicts: ['src/a.ts', 'src/b.ts'],\n361\t        cwd: '/repo',\n362\t      });\n363\t      const result = await resolveConflicts(ctx);\n364\t\n365\t      expect(result.escalationMessage).toContain('/repo');\n366\t      expect(result.escalationMessage).toContain('codeharness/epic-42-feature');\n367\t      expect(result.escalationMessage).toContain('src/a.ts');\n368\t      expect(result.escalationMessage).toContain('src/b.ts');\n369\t      expect(result.escalationMessage).toContain('git diff');\n370\t    });\n371\t  });\n372\t\n373\t  describe('resolveConflicts — unparseable test output', () => {\n374\t    it('treats zero-passed zero-failed as failure and retries', async () => {\n375\t      mockReadFileSync.mockReturnValue('conflict');\n376\t      mockExecSync.mockReturnValue('');\n377\t\n378\t      // First call: unparseable output (0 passed, 0 failed from parsing)\n379\t      // Second call: valid output\n380\t      let callCount = 0;\n381\t      mockExecAsync.mockImplementation(async () => {\n382\t        callCount++;\n383\t        if (callCount === 1) {\n384\t          return { stdout: 'Build completed successfully.' };\n385\t        }\n386\t        return { stdout: '5 passed\\n0 failed' };\n387\t      });\n388\t\n389\t      const ctx = createContext();\n390\t      const result = await resolveConflicts(ctx);\n391\t\n392\t      expect(result.resolved).toBe(true);\n393\t      expect(result.attempts).toBe(2);\n394\t    });\n395\t  });\n396\t\n397\t  describe('resolveConflicts — driver dispatch failure', () => {\n398\t    it('treats dispatch error as failed attempt and retries', async () => {\n399\t      mockReadFileSync.mockReturnValue('conflict');\n400\t\n401\t      let dispatchCallCount = 0;\n402\t      const driver = createMockDriver({\n403\t        dispatchFn: async function* (_opts: DispatchOpts) {\n404\t          dispatchCallCount++;\n405\t          if (dispatchCallCount === 1) {\n406\t            throw new Error('Network error');\n407\t          }\n408\t          // Second attempt succeeds\n409\t        },\n410\t      });\n411\t\n412\t      mockExecAsync.mockResolvedValue({ stdout: '5 passed\\n0 failed' });\n413\t\n414\t      const ctx = createContext({ driver });\n415\t      const result = await resolveConflicts(ctx);\n416\t\n417\t      expect(result.resolved).toBe(true);\n418\t      expect(result.attempts).toBe(2);\n419\t    });\n420\t\n421\t    it('escalates after 3 consecutive dispatch failures', async () => {\n422\t      mockReadFileSync.mockReturnValue('conflict');\n423\t      mockExecSync.mockReturnValue(''); // git reset succeeds\n424\t\n425\t      const driver = createMockDriver({\n426\t        dispatchFn: async function* () {\n427\t          throw new Error('Network error');\n428\t        },\n429\t      });\n430\t\n431\t      const ctx = createContext({ driver });\n432\t      const result = await resolveConflicts(ctx);\n433\t\n434\t      expect(result.resolved).toBe(false);\n435\t      expect(result.attempts).toBe(3);\n436\t      expect(result.escalated).toBe(true);\n437\t      expect(result.escalationMessage).toBeDefined();\n438\t    });\n439\t\n440\t    it('escalates immediately if git reset fails after dispatch error', async () => {\n441\t      mockReadFileSync.mockReturnValue('conflict');\n442\t      mockExecSync.mockImplementation(() => {\n443\t        throw new Error('git state corrupted');\n444\t      });\n445\t\n446\t      const driver = createMockDriver({\n447\t        dispatchFn: async function* () {\n448\t          throw new Error('Network error');\n449\t        },\n450\t      });\n451\t\n452\t      const ctx = createContext({ driver });\n453\t      const result = await resolveConflicts(ctx);\n454\t\n455\t      expect(result.resolved).toBe(false);\n456\t      expect(result.escalated).toBe(true);\n457\t      expect(result.attempts).toBe(1);\n458\t    });\n459\t  });\n460\t\n461\t  describe('resolveConflicts — test command failure edge cases', () => {\n462\t    it('handles test command that throws with partial stdout', async () => {\n463\t      mockReadFileSync.mockReturnValue('conflict');\n464\t      // Allow git reset to succeed\n465\t      mockExecSync.mockReturnValue('');\n466\t\n467\t      // First call: test command throws with partial output containing pass/fail\n468\t      // Second call: tests pass\n469\t      let callCount = 0;\n470\t      mockExecAsync.mockImplementation(async () => {\n471\t        callCount++;\n472\t        if (callCount === 1) {\n473\t          const err = new Error('Command failed') as Error & { stdout: string };\n474\t          err.stdout = '3 passed\\n2 failed\\nError: some test error';\n475\t          throw err;\n476\t        }\n477\t        return { stdout: '5 passed\\n0 failed' };\n478\t      });\n479\t\n480\t      const ctx = createContext();\n481\t      const result = await resolveConflicts(ctx);\n482\t\n483\t      expect(result.resolved).toBe(true);\n484\t      expect(result.attempts).toBe(2);\n485\t    });\n486\t\n487\t    it('handles test command that throws with no output', async () => {\n488\t      mockReadFileSync.mockReturnValue('conflict');\n489\t      // Allow git reset to succeed\n490\t      mockExecSync.mockReturnValue('');\n491\t\n492\t      mockExecAsync.mockImplementation(async () => {\n493\t        const err = new Error('Command failed') as Error & { stdout: string };\n494\t        err.stdout = '';\n495\t        throw err;\n496\t      });\n497\t\n498\t      const ctx = createContext();\n499\t      const result = await resolveConflicts(ctx);\n500\t\n501\t      // Should exhaust retries and escalate\n502\t      expect(result.resolved).toBe(false);\n503\t      expect(result.attempts).toBe(3);\n504\t      expect(result.escalated).toBe(true);\n505\t    });\n506\t  });\n507\t\n508\t  describe('resolveConflicts — git reset failure during retry', () => {\n509\t    it('escalates immediately if git reset fails after test failure', async () => {\n510\t      mockReadFileSync.mockReturnValue('conflict');\n511\t      mockExecAsync.mockResolvedValue({ stdout: '2 passed\\n1 failed' });\n512\t      mockExecSync.mockImplementation(() => {\n513\t        throw new Error('git state corrupted');\n514\t      });\n515\t\n516\t      const ctx = createContext();\n517\t      const result = await resolveConflicts(ctx);\n518\t\n519\t      expect(result.resolved).toBe(false);\n520\t      expect(result.escalated).toBe(true);\n521\t      expect(result.escalationMessage).toContain('/repo');\n522\t    });\n523\t  });\n524\t});\n525\t"}]},"parent_tool_use_id":"toolu_0175npHDGRfVyrbCzjafE5Mk","session_id":"22206bba-5847-41b1-b510-883e1dd8c0da","uuid":"a3dc64d6-4b5e-4d53-bf32-393519a32cd4","timestamp":"2026-04-03T22:13:06.599Z"}
