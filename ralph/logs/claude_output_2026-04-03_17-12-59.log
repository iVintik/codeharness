{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XCGb125ba8F1wDLLD2LnzQ","type":"tool_result","content":"17-export interface ResolvedTask {\n18-  agent: string;\n19-  scope: 'per-story' | 'per-run';\n20-  session: 'fresh' | 'continue';\n21-  source_access: boolean;\n22-  prompt_template?: string;\n23-  input_contract?: Record<string, unknown>;\n24-  output_contract?: Record<string, unknown>;\n25-  max_budget_usd?: number;\n26-  driver?: string;\n27-  model?: string;\n28-  plugins?: string[];\n29-}\n30-\n31-export interface LoopBlock {\n32-  loop: string[];\n33-}\n34-\n35-export type FlowStep = string | LoopBlock;\n36-\n37:export interface ResolvedWorkflow {\n38-  tasks: Record<string, ResolvedTask>;\n39-  flow: FlowStep[];\n40-}\n41-\n42-// --- Error Class ---\n43-\n44-export class WorkflowParseError extends Error {\n45-  public readonly errors: Array<{ path: string; message: string }>;\n46-\n47-  constructor(message: string, errors?: Array<{ path: string; message: string }>) {\n48-    super(message);\n49-    this.name = 'WorkflowParseError';\n50-    this.errors = errors ?? [];\n51-  }\n52-}\n53-\n54-// --- Referential Integrity Validation ---\n55-\n56-/**\n57- * Validate that driver and agent references in tasks point to real registered"}]},"parent_tool_use_id":"toolu_0188XVEoVFKE3hey9xp8FV9P","session_id":"cf16e575-8267-4c58-a992-20b07458710f","uuid":"a8d87872-6852-4e16-b488-51b59dacaaad","timestamp":"2026-04-03T13:20:48.511Z"}
