{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UEMQaUKeydq1gM2XZbrLGn","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, afterEach } from 'vitest';\n     2→import {\n     3→  existsSync,\n     4→  readFileSync,\n     5→  writeFileSync,\n     6→  unlinkSync,\n     7→  mkdirSync,\n     8→  rmSync,\n     9→} from 'node:fs';\n    10→import { join } from 'node:path';\n    11→import { parse } from 'yaml';\n    12→import type { SprintState } from '../../../types/state.js';\n    13→\n    14→// Import functions under test\n    15→const {\n    16→  generateSprintStatusYaml,\n    17→  getStoryStatusesFromState,\n    18→  writeStateAtomic,\n    19→  defaultState,\n    20→  sprintStatusYamlPath,\n    21→} = await import('../state.js');\n    22→\n    23→const STATE_FILE = join(process.cwd(), 'sprint-state.json');\n    24→const TMP_FILE = join(process.cwd(), '.sprint-state.json.tmp');\n    25→const YAML_DIR = join(process.cwd(), '_bmad-output', 'implementation-artifacts');\n    26→const YAML_FILE = join(YAML_DIR, 'sprint-status.yaml');\n    27→\n    28→function cleanup(): void {\n    29→  for (const f of [STATE_FILE, TMP_FILE]) {\n    30→    try { unlinkSync(f); } catch { /* ignore */ }\n    31→  }\n    32→  // Don't remove the actual YAML dir if it exists; just clean our test state file\n    33→}\n    34→\n    35→function mkStory(status: string): SprintState['stories'][string] {\n    36→  return {\n    37→    status: status as 'done',\n    38→    attempts: 0,\n    39→    lastAttempt: null,\n    40→    lastError: null,\n    41→    proofPath: null,\n    42→    acResults: null,\n    43→  };\n    44→}\n    45→\n    46→// ─── getStoryStatusesFromState ──────────────────────────────────────────────\n    47→\n    48→describe('getStoryStatusesFromState', () => {\n    49→  it('returns empty map for empty state', () => {\n    50→    const state = defaultState();\n    51→    const result = getStoryStatusesFromState(state);\n    52→    expect(result).toEqual({});\n    53→  });\n    54→\n    55→  it('returns flat key→status map from state stories', () => {\n    56→    const state: SprintState = {\n    57→      ...defaultState(),\n    58→      stories: {\n    59→        '1-1-first-story': mkStory('done'),\n    60→        '1-2-second-story': mkStory('in-progress'),\n    61→        '2-1-third-story': mkStory('backlog'),\n    62→      },\n    63→    };\n    64→    const result = getStoryStatusesFromState(state);\n    65→    expect(result).toEqual({\n    66→      '1-1-first-story': 'done',\n    67→      '1-2-second-story': 'in-progress',\n    68→      '2-1-third-story': 'backlog',\n    69→    });\n    70→  });\n    71→\n    72→  it('preserves all status types', () => {\n    73→    const state: SprintState = {\n    74→      ...defaultState(),\n    75→      stories: {\n    76→        '1-1-a': mkStory('done'),\n    77→        '1-2-b': mkStory('failed'),\n    78→        '1-3-c': mkStory('blocked'),\n    79→        '2-1-d': mkStory('verifying'),\n    80→        '2-2-e': mkStory('review'),\n    81→        '2-3-f': mkStory('ready'),\n    82→      },\n    83→    };\n    84→    const result = getStoryStatusesFromState(state);\n    85→    expect(result['1-1-a']).toBe('done');\n    86→    expect(result['1-2-b']).toBe('failed');\n    87→    expect(result['1-3-c']).toBe('blocked');\n    88→    expect(result['2-1-d']).toBe('verifying');\n    89→    expect(result['2-2-e']).toBe('review');\n    90→    expect(result['2-3-f']).toBe('ready');\n    91→  });\n    92→});\n    93→\n    94→// ─── generateSprintStatusYaml ───────────────────────────────────────────────\n    95→\n    96→describe('generateSprintStatusYaml', () => {\n    97→  it('produces valid YAML for empty state', () => {\n    98→    const state = defaultState();\n    99→    const yaml = generateSprintStatusYaml(state);\n   100→    expect(yaml).toContain('development_status:');\n   101→    // Should parse without error\n   102→    const parsed = parse(yaml)