),\n    90→      '[package]\\nname = \"myapp\"\\nversion = \"0.1.0\"\\n\\n[dependencies]\\nserde = \"1.0\"\\ntokio = \"1.0\"\\n',\n    91→    );\n    92→    const section = provider.getVerifyDockerfileSection(testDir);\n    93→    expect(section).toContain('rustup');\n    94→    expect(section).not.toContain('libudev-dev');\n    95→    expect(section).not.toContain('libasound2-dev');\n    96→  });\n    97→\n    98→  it('does NOT include Bevy libs when no Cargo.toml exists', () => {\n    99→    const section = provider.getVerifyDockerfileSection(testDir);\n   100→    expect(section).not.toContain('libudev-dev');\n   101→  });\n   102→\n   103→  it('does NOT include Bevy libs when bevy is only in dev-dependencies', () => {\n   104→    writeFileSync(\n   105→      join(testDir, 'Cargo.toml'),\n   106→      '[package]\\nname = \"myapp\"\\nversion = \"0.1.0\"\\n\\n[dependencies]\\nserde = \"1.0\"\\n\\n[dev-dependencies]\\nbevy = \"0.12\"\\n',\n   107→    );\n   108→    const section = provider.getVerifyDockerfileSection(testDir);\n   109→    expect(section).not.toContain('libudev-dev');\n   110→  });\n   111→});\n   112→"}]},"parent_tool_use_id":"toolu_01UEcnB3h2gZqmEJqfPaXmt4","session_id":"38809bab-d371-4c03-b647-b7b7381ee002","uuid":"16b70f8c-3dc9-4b5d-9589-e1e4860fc848","timestamp":"2026-03-24T23:42:40.848Z"}
