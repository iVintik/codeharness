{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J9EFZCqpHbMYSPQsAysgoT","type":"tool_result","content":"     1→/**\n     2→ * Helper functions for the run command.\n     3→ *\n     4→ * Extracted from run.ts to comply with NFR9 (max 300 lines per file).\n     5→ * Contains: elapsed time formatting, sprint status → story status mapping,\n     6→ * and ralph stderr → story message parsing.\n     7→ */\n     8→\n     9→import type { StoryStatusEntry, StoryStatusValue, StoryMessage } from './ink-components.js';\n    10→\n    11→// --- Elapsed Time Formatting (AC #6) ---\n    12→\n    13→/**\n    14→ * Format elapsed milliseconds as \"Xm\" or \"XhYm\".\n    15→ * Matches the UX spec format (not the DashboardFormatter \"Xm Ys\" format).\n    16→ */\n    17→export function formatElapsed(ms: number): string {\n    18→  const totalMinutes = Math.max(0, Math.floor(ms / 60_000));\n    19→  const hours = Math.floor(totalMinutes / 60);\n    20→  const minutes = totalMinutes % 60;\n    21→  if (hours > 0) {\n    22→    return `${hours}h${minutes}m`;\n    23→  }\n    24→  return `${totalMinutes}m`;\n    25→}\n    26→\n    27→// --- Sprint Status → Story Status Mapping (AC #7) ---\n    28→\n    29→/**\n    30→ * Maps a sprint-status.yaml status value to a StoryStatusValue for the Ink renderer.\n    31→ *\n    32→ * Mapping:\n    33→ *   done → done\n    34→ *   in-progress, review, verifying → in-progress\n    35→ *   backlog, ready-for-dev → pending\n    36→ *   failed → failed\n    37→ *   blocked, exhausted → blocked\n    38→ */\n    39→export function mapSprintStatus(status: string): StoryStatusValue {\n    40→  switch (status) {\n    41→    case 'done':\n    42→      return 'done';\n    43→    case 'in-progress':\n    44→    case 'review':\n    45→    case 'verifying':\n    46→      return 'in-progress';\n    47→    case 'backlog':\n    48→    case 'ready-for-dev':\n    49→      return 'pending';\n    50→    case 'failed':\n    51→      return 'failed';\n    52→    case 'blocked':\n    53→    case 'exhausted':\n    54→      return 'blocked';\n    55→    default:\n    56→      return 'pending';\n    57→  }\n    58→}\n    59→\n    60→/** Story key pattern: digit-digit-name */\n    61→const STORY_KEY_PATTERN = /^\\d+-\\d+-/;\n    62→\n    63→/**\n    64→ * Converts sprint-status.yaml entries to StoryStatusEntry[] for the Ink renderer.\n    65→ * Filters out epic keys, retrospective keys, and optional entries.\n    66→ */\n    67→export function mapSprintStatuses(statuses: Record<string, string>): StoryStatusEntry[] {\n    68→  const entries: StoryStatusEntry[] = [];\n    69→  for (const [key, status] of Object.entries(statuses)) {\n    70→    if (!STORY_KEY_PATTERN.test(key)) continue;\n    71→    if (status === 'optional') continue;\n    72→    entries.push({ key, status: mapSprintStatus(status) });\n    73→  }\n    74→  return entries;\n    75→}\n    76→\n    77→// --- Ralph Stderr → Story Messages (AC #8) ---\n    78→\n    79→/** Strip ANSI color codes */\n    80→const ANSI_ESCAPE = /\\x1b\\[[0-9;]*m/g;\n    81→\n    82→/** Strip timestamp prefix from ralph output lines */\n    83→const TIMESTAMP_PREFIX = /^\\[[\\d-]+\\s[\\d:]+\\]\\s*/;\n    84→\n    85→/** Matches: [SUCCESS] Story {key}: DONE ... */\n    86→const SUCCESS_STORY = /\\[SUCCESS\\]\\s+Story\\s+([\\w-]+):\\s+DONE(.*)/;\n    87→\n    88→/** Matches: [WARN] Story {key} exceeded retry limit ... flagging */\n    89→const WARN_STORY_RETRY = /\\[WARN\\]\\s+Story\\s+([\\w-]+)\\s+exceeded retry limit/;\n    90→\n    91→/** Matches: [WARN] Story {key} ... retry N/M */\n    92→const WARN_STORY_RETRYING = /\\[WARN\\]\\s+Story\\s+([\\w-]+)\\s+.*retry\\s+(\\d+)\\/(\\d+)/;\n    93→\n    94→/** Matches: [ERROR] ... */\n    95→const ERROR_LINE = /\\[ERROR\\]\\s+(.+)/;\n    96→\n    97→/**\n    98→ * Parse a ralph output line and return a StoryMessage if it matches\n    99→ * a story completion, failure, or warning pattern.\n   100→ * Returns null for non-matching lines.\n   101→ */\n   102→export function parseRalphMessage(rawLine: string): StoryMessage | null {\n   103→  const clean = rawLine.replace(ANSI_ESCAPE, '').replace(TIMESTAMP_PREFIX, '').trim();\n   104→  if (clean.length === 0) return null;\n   105→\n   106→  // [SUCCESS] Story {key}: DONE ...\n   107→  const success = SUCCESS_STORY.exec(clean);\n   108→  if (success) {\n   109→    const key = success[1];\n   110→    const rest = success[2].trim().replace(/^—\\s*/, '');\n   111→    return {\n   112→      type: 'ok',\n   113→      key,\n   114→      message: rest ? `DONE — ${rest}` : 'DONE',\n   115→    };\n   116→  }\n   117→\n   118→  // [WARN] Story {key} exceeded retry limit\n   119→  const retryExceeded = WARN_STORY_RETRY.exec(clean);\n   120→  if (retryExceeded) {\n   121→    return {\n   122→      type: 'fail',\n   123→      key: retryExceeded[1],\n   124→      message: 'exceeded retry limit',\n   125→    };\n   126→  }\n   127→\n   128→  // [WARN] Story {key} — retry N/M\n   129→  const retrying = WARN_STORY_RETRYING.exec(clean);\n   130→  if (retrying) {\n   131→    return {\n   132→      type: 'warn',\n   133→      key: retrying[1],\n   134→      message: `retry ${retrying[2]}/${retrying[3]}`,\n   135→    };\n   136→  }\n   137→\n   138→  // [ERROR] ... — surface as a generic error message\n   139→  const errorMatch = ERROR_LINE.exec(clean);\n   140→  if (errorMatch) {\n   141→    // Try to extract story key from error message\n   142→    const keyMatch = errorMatch[1].match(/Story\\s+([\\w-]+)/);\n   143→    if (keyMatch) {\n   144→      return {\n   145→        type: 'fail',\n   146→        key: keyMatch[1],\n   147→        message: errorMatch[1].trim(),\n   148→      };\n   149→    }\n   150→    // Generic error without a story key — skip (no key to associate)\n   151→    return null;\n   152→  }\n   153→\n   154→  return null;\n   155→}\n   156→"}]},"parent_tool_use_id":"toolu_01J5AdAMYAsRdio1YgdnbwDy","session_id":"64c1e9b9-a641-40be-ae67-07aee0c47965","uuid":"25ce11e1-5192-48d7-95ca-4243ca5fda68","timestamp":"2026-03-20T08:05:21.929Z"}
