7→      storyTitle: 'Screenshots Test',\n   228→      acceptanceCriteria: [\n   229→        { id: '1', description: 'Basic AC', verified: true, evidence: [] },\n   230→      ],\n   231→      screenshots: [\n   232→        { label: 'Home page', path: 'screenshots/home.png' },\n   233→        { label: 'Dashboard', path: 'screenshots/dashboard.png' },\n   234→      ],\n   235→    };\n   236→    const result = showboatProofTemplate(config);\n   237→    expect(result).toContain('## Screenshots');\n   238→    expect(result).toContain('- **Home page**: screenshots/home.png');\n   239→    expect(result).toContain('- **Dashboard**: screenshots/dashboard.png');\n   240→  });\n   241→\n   242→  it('omits screenshots section when screenshots array is empty', () => {\n   243→    const config: ShowboatProofConfig = {\n   244→      storyId: 'no-screenshots',\n   245→      storyTitle: 'No Screenshots',\n   246→      acceptanceCriteria: [\n   247→        { id: '1', description: 'Basic AC', verified: true, evidence: [] },\n   248→      ],\n   249→      screenshots: [],\n   250→    };\n   251→    const result = showboatProofTemplate(config);\n   252→    expect(result).not.toContain('## Screenshots');\n   253→  });\n   254→});\n   255→"}]},"parent_tool_use_id":"toolu_017LE4Rqhq3H1jAYQjBPXCJU","session_id":"36088b51-1d35-430b-9a0d-289c00965751","uuid":"19c72224-d481-4686-bdf9-a20320ba225d","timestamp":"2026-03-25T02:10:31.517Z"}
