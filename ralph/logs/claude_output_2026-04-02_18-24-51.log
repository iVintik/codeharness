{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012T5opqpJtJUysQKDLAYXoP","type":"tool_result","content":"1\t/**\n2\t * Types for the infra module.\n3\t */\n4\t\n5\timport type { AppType } from '../../lib/stacks/index.js';\n6\timport type { DependencyResult } from '../../lib/deps.js';\n7\timport type { OtlpResult } from '../../lib/observability/index.js';\n8\timport type { DockerStartResult } from '../../lib/docker/index.js';\n9\t\n10\t/** Options for project initialization */\n11\texport interface InitOptions {\n12\t  readonly projectDir: string;\n13\t  readonly frontend: boolean;\n14\t  readonly database: boolean;\n15\t  readonly api: boolean;\n16\t  readonly observability: boolean;\n17\t  readonly observabilityBackend?: 'victoria' | 'elk' | 'none';\n18\t  readonly otelEndpoint?: string;\n19\t  readonly opensearchUrl?: string;\n20\t  readonly logsUrl?: string;\n21\t  readonly metricsUrl?: string;\n22\t  readonly tracesUrl?: string;\n23\t  readonly force?: boolean;\n24\t  readonly json?: boolean;\n25\t}\n26\t\n27\t/** Docker result shape within InitResult */\n28\texport interface InitDockerResult {\n29\t  readonly compose_file: string;\n30\t  readonly stack_running: boolean;\n31\t  readonly services: DockerStartResult['services'];\n32\t  readonly ports: {\n33\t    readonly logs: number;\n34\t    readonly metrics: number;\n35\t    readonly traces: number;\n36\t    readonly otel_grpc: number;\n37\t    readonly otel_http: number;\n38\t  };\n39\t}\n40\t\n41\t/** Beads result shape within InitResult */\n42\texport interface InitBeadsResult {\n43\t  readonly status: 'initialized' | 'already-initialized' | 'failed' | 'skipped';\n44\t  readonly hooks_detected?: boolean;\n45\t  readonly error?: string;\n46\t  readonly message?: string;\n47\t}\n48\t\n49\t/** BMAD result shape within InitResult */\n50\texport interface InitBmadResult {\n51\t  readonly status: 'installed' | 'already-installed' | 'patched' | 'failed';\n52\t  readonly version: string | null;\n53\t  readonly patches_applied: string[];\n54\t  readonly bmalph_detected: boolean;\n55\t  readonly error?: string;\n56\t}\n57\t\n58\t/** Documentation scaffold result */\n59\texport interface InitDocumentationResult {\n60\t  readonly agents_md: 'created' | 'exists' | 'skipped';\n61\t  readonly docs_scaffold: 'created' | 'exists' | 'skipped';\n62\t  readonly readme: 'created' | 'exists' | 'skipped';\n63\t}\n64\t\n65\t/** Result of project initialization */\n66\texport interface InitResult {\n67\t  status: 'ok' | 'fail';\n68\t  stack: string | null;\n69\t  stacks: string[];\n70\t  app_type?: AppType;\n71\t  enforcement: {\n72\t    frontend: boolean;\n73\t    database: boolean;\n74\t    api: boolean;\n75\t  };\n76\t  documentation: InitDocumentationResult;\n77\t  dependencies?: DependencyResult[];\n78\t  beads?: InitBeadsResult;\n79\t  bmad?: InitBmadResult;\n80\t  otlp?: OtlpResult;\n81\t  workflow?: { status: 'created' | 'exists' | 'overwritten'; path: string };\n82\t  dockerfile?: { generated: boolean; stack: string; stacks: string[] };\n83\t  docker?: InitDockerResult | null;\n84\t  error?: string;\n85\t}\n86\t\n87\t/** Status of the infrastructure stack */\n88\texport interface StackStatus {\n89\t  readonly running: boolean;\n90\t  readonly composePath: string;\n91\t  readonly projectName: string;\n92\t  readonly services: ReadonlyArray<{\n93\t    readonly name: string;\n94\t    readonly healthy: boolean;\n95\t  }>;\n96\t}\n97\t\n98\t/** Result of detecting a running shared stack */\n99\texport interface StackDetectionResult {\n100\t  readonly running: boolean;\n101\t  readonly projectName: string;\n102\t  readonly composePath: string;\n103\t  readonly services: ReadonlyArray<{\n104\t    readonly name: string;\n105\t    readonly running: boolean;\n106\t  }>;\n107\t}\n108\t\n109\t/** Result of port conflict detection */\n110\texport interface PortConflictResult {\n111\t  readonly conflicts: ReadonlyArray<{\n112\t    readonly port: number;\n113\t    readonly pid: number;\n114\t    readonly processName: string;\n115\t  }>;\n116\t}\n117\t\n118\t/** Result of stale container cleanup */\n119\texport interface CleanupResult {\n120\t  readonly containersRemoved: number;\n121\t  readonly names: readonly string[];\n122\t}\n123\t\n124\t/** Default ports used by the observability stack */\n125\texport const DEFAULT_PORTS = {\n126\t  logs: 9428,\n127\t  metrics: 8428,\n128\t  traces: 16686,\n129\t  otel_grpc: 4317,\n130\t  otel_http: 4318,\n131\t} as const;\n132\t\n133\t/** All default ports as an array for conflict detection */\n134\texport const ALL_STACK_PORTS = [\n135\t  DEFAULT_PORTS.otel_grpc,\n136\t  DEFAULT_PORTS.otel_http,\n137\t  DEFAULT_PORTS.metrics,\n138\t  DEFAULT_PORTS.logs,\n139\t  DEFAULT_PORTS.traces,\n140\t] as const;\n141\t"}]},"parent_tool_use_id":"toolu_01CCM5MwgB4Cmai7i1sHHZbw","session_id":"5e9a7eca-0e0b-47b2-8610-117311a6629c","uuid":"95f8c6ed-d465-4ce0-a30e-4bb9af7e1594","timestamp":"2026-04-02T14:35:02.691Z"}
