{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RS8u5HEgeuYCVgBD2WcTcw","type":"tool_result","content":"diff --git a/src/modules/infra/docs-scaffold.ts b/src/modules/infra/docs-scaffold.ts\nindex c6061e7..ed3ac49 100644\n--- a/src/modules/infra/docs-scaffold.ts\n+++ b/src/modules/infra/docs-scaffold.ts\n@@ -23,9 +23,27 @@ export function getProjectName(projectDir: string): string {\n         return pkg.name;\n       }\n     }\n+  } catch {\n+    // Fall through to Cargo.toml check\n+  }\n+\n+  // Cargo.toml fallback for Rust projects\n+  try {\n+    const cargoPath = join(projectDir, 'Cargo.toml');\n+    if (existsSync(cargoPath)) {\n+      const content = readFileSync(cargoPath, 'utf-8');\n+      const packageMatch = content.match(/\\[package\\]([^[]*)/s);\n+      if (packageMatch) {\n+        const nameMatch = packageMatch[1].match(/^\\s*name\\s*=\\s*\"([^\"]+)\"/m);\n+        if (nameMatch) {\n+          return nameMatch[1];\n+        }\n+      }\n+    }\n   } catch {\n     // Fall through to basename\n   }\n+\n   return basename(projectDir);\n }","is_error":false}]},"parent_tool_use_id":"toolu_01Pjqm6RwzFUa1tNdjiqKz4j","session_id":"9c50fb69-0476-4a5d-8998-78fcdfa47c24","uuid":"772fda21-c35d-4645-94f0-89d4a4d5b80d","timestamp":"2026-03-23T08:18:29.994Z"}
