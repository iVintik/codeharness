ess: true, epicsProcessed: 0, epicResults: new Map(), durationMs: 0,\n225\t      }),\n226\t    });\n227\t    _wtFactory = () => ({\n228\t      createWorktree: vi.fn(() => '/tmp/codeharness-wt-epic-1'),\n229\t      cleanupWorktree: vi.fn(),\n230\t      listWorktrees: vi.fn(() => []),\n231\t      detectOrphans: vi.fn(() => []),\n232\t    });\n233\t    process.exitCode = undefined;\n234\t  });\n235\t\n236\t  afterEach(() => {\n237\t    vi.restoreAllMocks();\n238\t    process.exitCode = undefined;\n239\t  });\n240\t\n241\t  function mockPaths(overrides: Record<string, boolean>) {\n242\t    existsSyncMock.mockImplementation((p: unknown) => {\n243\t      const path = String(p);\n244\t      for (const [pattern, value] of Object.entries(overrides)) {\n245\t        if (path.includes(pattern)) return value;\n246\t      }\n247\t      return realExistsSync(path);\n248\t    });\n249\t  }\n250\t\n251\t  function mockParallelWorkflow(maxParallel = 2) {\n252\t    resolveWorkflowMock.mockReturnValue({\n253\t      tasks: { implement: { agent: 'dev', scope: 'per-story', session: 'fresh', source_access: true } },\n254\t      flow: ['implement'],\n255\t      execution: { epic_strategy: 'parallel', max_parallel: maxParallel, isolation: 'none', merge_strategy: 'merge-commit', story_strategy: 'sequential' },\n256\t      storyFlow: ['implement'],\n257\t      epicFlow: [],\n258\t    });\n259\t  }\n260\t\n261\t  function mockSequentialWorkflow() {\n262\t    resolveWorkflowMock.mockReturnValue({\n263\t      tasks: { implement: { agent: 'dev', scope: 'per-story', session: 'fresh', source_access: true } },\n264\t      flow: ['implement'],\n265\t      execution: { epic_strategy: 'sequential', max_parallel: 1, isolation: 'none', merge_strategy: 'merge-commit', story_strategy: 'sequential' },\n266\t      storyFlow: ['implement'],\n267\t      epicFlow: [],\n268\t    });\n269\t  }\n270\t\n271\t  function mockPoolAndWorktree(poolOverrides?: Record<string, unknown>, wtOverrides?: Record<string, unknown>) {\n272\t    const poolInstance: Record<string, unknown> = {\n273\t      onEvent: vi.fn(),\n274\t      startPool: vi.fn().mockResolvedValue({\n275\t        success: true, epicsProcessed: 1,\n276\t        epicResults: new Map([['1', { epicId: '1', status: 'completed', engineResult: { success: true, tasksCompleted: 1, storiesProcessed: 1, errors: [], durationMs: 1000 }, durationMs: 1000 }]]),\n277\t        durationMs: 1000,\n278\t      }),\n279\t      ...poolOverrides,\n280\t    };\n281\t    const wtInstance: Record<string, unknown> = {\n282\t      createWorktree: vi.fn(() => '/tmp/codeharness-wt-epic-1'),\n283\t      cleanupWorktree: vi.fn(),\n284\t      listWorktrees: vi.fn(() => []),\n285\t      detectOrphans: vi.fn(() => []),\n286\t      ...wtOverrides,\n287\t    };\n288\t    _poolFactory = () => poolInstance;\n289\t    _wtFactory = () => wtInstance;\n290\t    return { poolInstance, wtInstance };\n291\t  }\n292\t\n293\t  async function runCommand(args: string[] = []) {\n294\t    const { registerRunCommand } = await import('../run.js');\n295\t    const program = new Command();\n296\t    program.exitOverride();\n297\t    program.option('--json', 'JSON output');\n298\t    registerRunCommand(program);\n299\t    await program.parseAsync(['node', 'codeharness', 'run', ...args]);\n300\t  }\n301\t\n302\t\n303\t  // --- extractEpicId unit tests ---\n304\t\n305\t  describe('extractEpicId', () => {\n306\t    it('extracts numeric epic prefix from story key', () => {\n307\t      expect(extractEpicId('17-1-foo')).toBe('17');\n308\t      expect(extractEpicId('3-2-bar-baz')).toBe('3');\n309\t      expect(extractEpicId('100-5-long-slug')).toBe('100');\n310\t    });\n311\t\n312\t    it('returns full key if no numeric prefix', () => {\n313\t      expect(extractEpicId('nonnumeric')).toBe('nonnumeric');\n314\t    });\n315\t  });\n316\t\n317\t\n318\t  // --- buildEpicDescriptors unit tests ---\n319\t\n320\t  describe('buildEpicDescriptors', () => {\n321\t    it('groups stories by epic ID (AC #3)', () => {\n322\t      const state = makeSprintState({\n323\t        stories: {\n324\t          '17-1-worktree': { ...defaultStory },\n325\t          '17-2-lane-pool': { ...defaultStory },\n326\t          '18-1-merge': { ...defaultStory },\n327\t        },\n328\t        epics: {},\n329\t      });\n330\t      const descriptors = buildEpicDescriptors(state);\n331\t      expect(descriptors).toHaveLength(2);\n332\t      const epic17 = descriptors.find(d => d.id === '17');\n333\t      expect(epic17).toBeDefined();\n334\t      expect(epic17!.stories).toEqual(['17-1-worktree', '17-2-lane-pool']);\n335\t      expect(epic17!.slug).toBe('epic-17');\n336\t    });\n337\t\n338\t    it('filters out epics with done status (AC #3)', () => {\n339\t      const state = makeSprintState({\n340\t        stories: {\n341\t          '17-1-foo': { ...defaultStory },\n342\t          '18-1-bar': { ...defaultStory },\n343\t        },\n344\t        epics: {\n345\t          'epic-17': { status: 'done', storiesTotal: 1, storiesDone: 1 },\n346\t          'epic-18': { status: 'in-progress', storiesTotal: 1, storiesDone: 0 },\n347\t        },\n348\t      });\n349\t      const descriptors = buildEpicDescriptors(state);\n350\t      expect(descriptors).toHaveLength(1);\n351\t      expect(descriptors[0].id).toBe('18');\n352\t    });\n353\t\n354\t    it('returns empty array when all epics are done', () => {\n355\t      const state = makeSprintState({\n356\t        stories: { '17-1-foo': { ...defaultStory } },\n357\t        epics: { 'epic-17': { status: 'done', storiesTotal: 1, storiesDone: 1 } },\n358\t      });\n359\t      expect(buildEpicDescriptors(state)).toEqual([]);\n360\t    });\n361\t\n362\t    it('includes epics not present in epics map (assumes not done)', () => {\n363\t      const state = makeSprintState({\n364\t        stories: { '99-1-new': { ...defaultStory } },\n365\t        epics: {},\n366\t      });\n367\t      const descriptors = buildEpicDescriptors(state);\n368\t      expect(descriptors).toHaveLength(1);\n369\t      expect(descriptors[0].id).toBe('99');\n370\t    });\n371\t  });\n372\t\n373\t\n374\t  // --- Parallel execution path tests ---\n375\t\n376\t  describe('parallel mode detection (AC #1, #8)', () => {\n377\t    it('detects parallel mode when epic_strategy is parallel', async () => {\n378\t      mockPaths({ '.claude': true });\n379\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n380\t      mockParallelWorkflow(2);\n381\t      getSprintStateMock.mockReturnValue({\n382\t        success: true,\n383\t        data: makeSprintState({\n384\t          stories: { '1-1-story': { ...defaultStory } },\n385\t        }),\n386\t      });\n387\t\n388\t      const { poolInstance } = mockPoolAndWorktree();\n389\t      vi.spyOn(console, 'log').mockImplementation(() => {});\n390\t\n391\t      await runCommand();\n392\t\n393\t      expect(_lanePoolConstructed).toBe(true);\n394\t      expect(_worktreeManagerConstructed).toBe(true);\n395\t      expect(poolInstance.startPool).toHaveBeenCalled();\n396\t      // executeWorkflow should NOT be called directly in parallel mode\n397\t      expect(executeWorkflowMock).not.toHaveBeenCalled();\n398\t    });\n399\t\n400\t    it('uses sequential path when epic_strategy is sequential (AC #8)', async () => {\n401\t      mockPaths({ '.claude': true });\n402\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n403\t      mockSequentialWorkflow();\n404\t      vi.spyOn(console, 'log').mockImplementation(() => {});\n405\t\n406\t      await runCommand();\n407\t\n408\t      expect(_lanePoolConstructed).toBe(false);\n409\t      expect(_worktreeManagerConstructed).toBe(false);\n410\t      expect(executeWorkflowMock).toHaveBeenCalled();\n411\t    });\n412\t\n413\t    it('uses sequential path when no execution config present (AC #8)', async () => {\n414\t      mockPaths({ '.claude': true });\n415\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n416\t      resolveWorkflowMock.mockReturnValue({\n417\t        tasks: { implement: { agent: 'dev', scope: 'per-story', session: 'fresh', source_access: true } },\n418\t        flow: ['implement'],\n419\t        storyFlow: ['implement'],\n420\t        epicFlow: [],\n421\t        execution: undefined,\n422\t        // No execution config — should use sequential path\n423\t      });\n424\t      vi.spyOn(console, 'log').mockImplementation(() => {});\n425\t\n426\t      await runCommand();\n427\t\n428\t      expect(_lanePoolConstructed).toBe(false);\n429\t      expect(executeWorkflowMock).toHaveBeenCalled();\n430\t    });\n431\t  });\n432\t\n433\t  describe('LanePool created with correct config (AC #2)', () => {\n434\t    it('creates LanePool with maxParallel from execution config', async () => {\n435\t      mockPaths({ '.claude': true });\n436\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n437\t      mockParallelWorkflow(3);\n438\t      getSprintStateMock.mockReturnValue({\n439\t        success: true,\n440\t        data: makeSprintState({ stories: { '1-1-story': { ...defaultStory } } }),\n441\t      });\n442\t\n443\t      mockPoolAndWorktree();\n444\t      vi.spyOn(console, 'log').mockImplementation(() => {});\n445\t\n446\t      await runCommand();\n447\t\n448\t      expect(_lanePoolConstructorArgs[1]).toBe(3);\n449\t    });\n450\t  });\n451\t\n452\t  describe('executeFn sets projectDir to worktree path (AC #4, #5)', () => {\n453\t    it('passes worktree path as projectDir in EngineConfig', async () => {\n454\t      mockPaths({ '.claude': true });\n455\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n456\t      mockParallelWorkflow(2);\n457\t      getSprintStateMock.mockReturnValue({\n458\t        success: true,\n459\t        data: makeSprintState({ stories: { '1-1-story': { ...defaultStory } } }),\n460\t      });\n461\t\n462\t      let capturedExecuteFn: ((epicId: string, worktreePath: string) => Promise<unknown>) | undefined;\n463\t      mockPoolAndWorktree({\n464\t        startPool: vi.fn().mockImplementation((epics: unknown[], executeFn: (epicId: string, path: string) => Promise<unknown>) => {\n465\t          capturedExecuteFn = executeFn;\n466\t          return Promise.resolve({\n467\t            success: true, epicsProcessed: 1,\n468\t            epicResults: new Map([['1', { epicId: '1', status: 'completed', engineResult: { success: true, tasksCompleted: 1, storiesProcessed: 1, errors: [], durationMs: 1000 }, durationMs: 1000 }]]),\n469\t            durationMs: 1000,\n470\t          });\n471\t        }),\n472\t      });\n473\t      vi.spyOn(console, 'log').mockImplementation(() => {});\n474\t\n475\t      await runCommand();\n476\t\n477\t      expect(capturedExecuteFn).toBeDefined();\n478\t      // Call executeFn to verify it sets projectDir\n479\t      await capturedExecuteFn!('1', '/tmp/codeharness-wt-epic-1');\n480\t      expect(executeWorkflowMock).toHaveBeenCalledWith(\n481\t        expect.objectContaining({ projectDir: '/tmp/codeharness-wt-epic-1' }),\n482\t      );\n483\t    });\n484\t  });\n485\t\n486\t  describe('pool result maps to correct exit code (AC #7)', () => {\n487\t    it('exits 0 when pool succeeds', async () => {\n488\t      mockPaths({ '.claude': true });\n489\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n490\t      mockParallelWorkflow(2);\n491\t      getSprintStateMock.mockReturnValue({\n492\t        success: true,\n493\t        data: makeSprintState({ stories: { '1-1-story': { ...defaultStory } } }),\n494\t      });\n495\t\n496\t      mockPoolAndWorktree({\n497\t        startPool: vi.fn().mockResolvedValue({\n498\t          success: true, epicsProcessed: 2,\n499\t          epicResults: new Map([\n500\t            ['1', { epicId: '1', status: 'completed', engineResult: { success: true, tasksCompleted: 2, storiesProcessed: 1, errors: [], durationMs: 1000 }, durationMs: 1000 }],\n501\t            ['2', { epicId: '2', status: 'completed', engineResult: { success: true, tasksCompleted: 1, storiesProcessed: 1, errors: [], durationMs: 2000 }, durationMs: 2000 }],\n502\t          ]),\n503\t          durationMs: 3000,\n504\t        }),\n505\t      });\n506\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n507\t\n508\t      await runCommand();\n509\t\n510\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Parallel execution completed'));\n511\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('2 epics'));\n512\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('2 stories processed'));\n513\t      expect(process.exitCode).toBeUndefined();\n514\t    });\n515\t\n516\t    it('exits 1 when pool fails (AC #7)', async () => {\n517\t      mockPaths({ '.claude': true });\n518\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n519\t      mockParallelWorkflow(2);\n520\t      getSprintStateMock.mockReturnValue({\n521\t        success: true,\n522\t        data: makeSprintState({ stories: { '1-1-story': { ...defaultStory } } }),\n523\t      });\n524\t\n525\t      mockPoolAndWorktree({\n526\t        startPool: vi.fn().mockResolvedValue({\n527\t          success: false, epicsProcessed: 2,\n528\t          epicResults: new Map([\n529\t            ['1', { epicId: '1', status: 'completed', engineResult: { success: true, tasksCompleted: 2, storiesProcessed: 1, errors: [], durationMs: 1000 }, durationMs: 1000 }],\n530\t            ['2', { epicId: '2', status: 'failed', error: 'Engine crashed', durationMs: 500 }],\n531\t          ]),\n532\t          durationMs: 2000,\n533\t        }),\n534\t      });\n535\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n536\t\n537\t      await runCommand();\n538\t\n539\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Parallel execution failed'));\n540\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('1 failed'));\n541\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('Epic 2: Engine crashed'));\n542\t      expect(process.exitCode).toBe(1);\n543\t    });\n544\t  });\n545\t\n546\t  describe('lane events are logged (AC #10)', () => {\n547\t    it('registers onEvent callback for lane event logging', async () => {\n548\t      mockPaths({ '.claude': true });\n549\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n550\t      mockParallelWorkflow(2);\n551\t      getSprintStateMock.mockReturnValue({\n552\t        success: true,\n553\t        data: makeSprintState({ stories: { '1-1-story': { ...defaultStory } } }),\n554\t      });\n555\t\n556\t      const { poolInstance } = mockPoolAndWorktree();\n557\t      vi.spyOn(console, 'log').mockImplementation(() => {});\n558\t\n559\t      await runCommand();\n560\t\n561\t      expect(poolInstance.onEvent).toHaveBeenCalledWith(expect.any(Function));\n562\t\n563\t      // Simulate lane events and verify console output\n564\t      const consoleSpy = vi.spyOn(console, 'log');\n565\t      const onEventMock = poolInstance.onEvent as ReturnType<typeof vi.fn>;\n566\t      const eventCallback = onEventMock.mock.calls[0][0];\n567\t\n568\t      eventCallback({ type: 'lane-started', epicId: '17', laneIndex: 0, timestamp: new Date().toISOString() });\n569\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('[LANE] Started epic 17 in lane 0'));\n570\t\n571\t      eventCallback({ type: 'lane-completed', epicId: '17', laneIndex: 0, timestamp: new Date().toISOString() });\n572\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('[LANE] Epic 17 completed in lane 0'));\n573\t\n574\t      eventCallback({ type: 'lane-failed', epicId: '18', laneIndex: 1, timestamp: new Date().toISOString(), error: 'boom' });\n575\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('[LANE] Epic 18 failed in lane 1: boom'));\n576\t\n577\t      eventCallback({ type: 'epic-queued', epicId: '19', laneIndex: -1, timestamp: new Date().toISOString() });\n578\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('[LANE] Epic 19 queued for execution'));\n579\t    });\n580\t  });\n581\t\n582\t  describe('max_parallel=1 with parallel strategy (AC #9)', () => {\n583\t    it('creates lane pool with maxParallel=1 for sequential-through-pool execution', async () => {\n584\t      mockPaths({ '.claude': true });\n585\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n586\t      mockParallelWorkflow(1);\n587\t      getSprintStateMock.mockReturnValue({\n588\t        success: true,\n589\t        data: makeSprintState({ stories: { '1-1-story': { ...defaultStory } } }),\n590\t      });\n591\t\n592\t      const { poolInstance } = mockPoolAndWorktree();\n593\t      vi.spyOn(console, 'log').mockImplementation(() => {});\n594\t\n595\t      await runCommand();\n596\t\n597\t      expect(_lanePoolConstructorArgs[1]).toBe(1);\n598\t      expect(poolInstance.startPool).toHaveBeenCalled();\n599\t    });\n600\t  });\n601\t\n602\t  describe('parallel strategy forces worktree isolation (AC #12)', () => {\n603\t    it('creates WorktreeManager even when isolation is none', async () => {\n604\t      mockPaths({ '.claude': true });\n605\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n606\t      // isolation: 'none' but epic_strategy: 'parallel'\n607\t      resolveWorkflowMock.mockReturnValue({\n608\t        tasks: { implement: { agent: 'dev', scope: 'per-story', session: 'fresh', source_access: true } },\n609\t        flow: ['implement'],\n610\t        execution: { epic_strategy: 'parallel', max_parallel: 2, isolation: 'none', merge_strategy: 'merge-commit', story_strategy: 'sequential' },\n611\t        storyFlow: ['implement'],\n612\t        epicFlow: [],\n613\t      });\n614\t      getSprintStateMock.mockReturnValue({\n615\t        success: true,\n616\t        data: makeSprintState({ stories: { '1-1-story': { ...defaultStory } } }),\n617\t      });\n618\t\n619\t      mockPoolAndWorktree();\n620\t      vi.spyOn(console, 'log').mockImplementation(() => {});\n621\t\n622\t      await runCommand();\n623\t\n624\t      // WorktreeManager created regardless of isolation setting\n625\t      expect(_worktreeManagerConstructed).toBe(true);\n626\t      expect(_lanePoolConstructed).toBe(true);\n627\t    });\n628\t  });\n629\t\n630\t  describe('crash in one lane does not abort run (AC #6)', () => {\n631\t    it('handles pool that reports partial failure without crashing', async () => {\n632\t      mockPaths({ '.claude': true });\n633\t      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n634\t      mockParallelWorkflow(2);\n635\t      getSprintStateMock.mockReturnValue({\n636\t        success: true,\n637\t        data: makeSprintState({\n638\t          stories: {\n639\t            '1-1-story': { ...defaultStory },\n640\t            '2-1-other': { ...defaultStory },\n641\t          },\n642\t        }),\n643\t      });\n644\t\n645\t      mockPoolAndWorktree({\n646\t        startPool: vi.fn().mockResolvedValue({\n647\t          success: false, epicsProcessed: 2,\n648\t          epicResults: new Map([\n649\t            ['1', { epicId: '1', status: 'failed', error: 'Lane crashed', durationMs: 500 }],\n650\t            ['2', { epicId: '2', status: 'completed', engineResult: { success: true, tasksCompleted: 1, storiesProcessed: 1, errors: [], durationMs: 2000 }, durationMs: 2000 }],\n651\t          ]),\n652\t          durationMs: 2500,\n653\t        }),\n654\t      });\n655\t      const consoleSpy = vi.spyOn(console, 'log').mockImplementation(() => {});\n656\t\n657\t      await runCommand();\n658\t\n659\t      // Both epics were processed — crash in one did not prevent the other\n660\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('2 epics'));\n661\t      expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining('1 succeeded'));\n662\t 