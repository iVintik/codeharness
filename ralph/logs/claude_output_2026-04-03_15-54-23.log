yKey: 'test', phase: 'dev', done: 0, total: 1 }, _forceTTY: true });\n920\t    handle.update({ type: 'result', cost: 1.50, sessionId: 'sess1' });\n921\t    // No crash = backward compat\n922\t  });\n923\t\n924\t  it('handles error-like sequence without crash (driver failure resilience)', () => {\n925\t    handle = startRenderer({ sprintState: { storyKey: 'test', phase: 'dev', done: 0, total: 1 }, _forceTTY: true });\n926\t    // Start a tool with a driver\n927\t    handle.update({ type: 'tool-start', name: 'Bash', id: 't1' }, 'codex');\n928\t    handle.update({ type: 'tool-input', partial: '{\"command\":\"exit 1\"}' });\n929\t    // Tool completes (even on error, the tool-complete event fires)\n930\t    handle.update({ type: 'tool-complete' });\n931\t    // Text event after failure\n932\t    handle.update({ type: 'text', text: 'The command failed' });\n933\t    // Start another tool with a different driver — no crash\n934\t    handle.update({ type: 'tool-start', name: 'Read', id: 't2' }, 'claude-code');\n935\t    handle.update({ type: 'tool-complete' });\n936\t    // No crash = resilience verified\n937\t  });\n938\t});"}]},"parent_tool_use_id":"toolu_0117vDhwD8YtdmVSBCbGt4wb","session_id":"a29ee53b-c2b0-4802-9455-7215112648b1","uuid":"cc356e55-6245-4774-91d8-9c29cd8d626a","timestamp":"2026-04-03T12:11:26.832Z"}
