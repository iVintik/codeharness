         const engineError = handleDispatchError(err, taskName, item.key);\n854\t          errors.push(engineError);\n855\t\n856\t          // Record error checkpoint in state (AC #13)\n857\t          state = recordErrorInState(state, taskName, item.key, engineError);\n858\t          writeWorkflowState(state, projectDir);\n859\t\n860\t          // Halt on critical errors, continue on UNKNOWN\n861\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n862\t            halted = true;\n863\t            break;\n864\t          }\n865\t          // UNKNOWN errors: record and continue to next story\n866\t          continue;\n867\t        }\n868\t      }\n869\t    }\n870\t  }\n871\t\n872\t  // 4. Set final phase if no errors and phase not already set by loop termination\n873\t  if (errors.length === 0 && state.phase !== 'max-iterations' && state.phase !== 'circuit-breaker') {\n874\t    state = { ...state, phase: 'completed' };\n875\t    writeWorkflowState(state, projectDir);\n876\t  }\n877\t\n878\t  // 5. Return result\n879\t  const loopTerminated = state.phase === 'max-iterations' || state.phase === 'circuit-breaker';\n880\t  return {\n881\t    success: errors.length === 0 && !loopTerminated,\n882\t    tasksCompleted,\n883\t    storiesProcessed: processedStories.size,\n884\t    errors,\n885\t    durationMs: Date.now() - startMs,\n886\t  };\n887\t}\n888\t\n889\t// --- Error Handling ---\n890\t\n891\t/**\n892\t * Record a dispatch error in workflow state: set phase to \"error\" and append\n893\t * a TaskCheckpoint with the error details (AC #13).\n894\t */\n895\tfunction recordErrorInState(\n896\t  state: WorkflowState,\n897\t  taskName: string,\n898\t  storyKey: string,\n899\t  error: EngineError,\n900\t): WorkflowState {\n901\t  const errorCheckpoint: TaskCheckpoint = {\n902\t    task_name: taskName,\n903\t    story_key: storyKey,\n904\t    completed_at: new Date().toISOString(),\n905\t    error: true,\n906\t  };\n907\t  return {\n908\t    ...state,\n909\t    phase: 'error',\n910\t    tasks_completed: [...state.tasks_completed, errorCheckpoint],\n911\t  };\n912\t}\n913\t\n914\tfunction handleDispatchError(err: unknown, taskName: string, storyKey: string): EngineError {\n915\t  if (err instanceof DispatchError) {\n916\t    return {\n917\t      taskName,\n918\t      storyKey,\n919\t      code: err.code,\n920\t      message: err.message,\n921\t    };\n922\t  }\n923\t\n924\t  const message = err instanceof Error ? err.message : String(err);\n925\t  return {\n926\t    taskName,\n927\t    storyKey,\n928\t    code: 'UNKNOWN',\n929\t    message,\n930\t  };\n931\t}\n932\t"}]},"parent_tool_use_id":"toolu_019kDU2rXQxKhW35XzJYDDnv","session_id":"90f775a4-0bf0-4884-b410-4d7f1f50684d","uuid":"e547d013-36fe-4d25-a348-8c26899a580b","timestamp":"2026-04-03T08:11:34.589Z"}
