ork items. */\n38\t  issuesPath?: string;\n39\t  /** Unique identifier for this engine run. */\n40\t  runId: string;\n41\t  /** Project root directory. Defaults to process.cwd(). */\n42\t  projectDir?: string;\n43\t  /** Maximum loop iterations before termination. Defaults to 5. */\n44\t  maxIterations?: number;\n45\t}\n46\t\n47\t/**\n48\t * Result returned by executeWorkflow().\n49\t */\n50\texport interface EngineResult {\n51\t  /** Whether the workflow completed without errors. */\n52\t  success: boolean;\n53\t  /** Number of task dispatches completed. */\n54\t  tasksCompleted: number;\n55\t  /** Number of work items (stories/issues) processed. */\n56\t  storiesProcessed: number;\n57\t  /** Errors encountered during execution. */\n58\t  errors: EngineError[];\n59\t  /** Wall-clock duration of the entire workflow in milliseconds. */\n60\t  durationMs: number;\n61\t}\n62\t\n63\t/**\n64\t * Structured error recorded during workflow execution.\n65\t */\n66\texport interface EngineError {\n67\t  taskName: string;\n68\t  storyKey: string;\n69\t  code: string;\n70\t  message: string;\n71\t}\n72\t\n73\t/**\n74\t * A work item (story or issue) ready for execution.\n75\t */\n76\texport interface WorkItem {\n77\t  key: string;\n78\t  title?: string;\n79\t  source: 'sprint' | 'issues';\n80\t}"}]},"parent_tool_use_id":"toolu_01ChyoLDPrvpbR13hYNAz6e8","session_id":"c2800ecc-75a3-43b2-b3d8-396855aa3c3c","uuid":"c50dea03-8000-4f36-a0d6-1cf370d138a1","timestamp":"2026-04-03T03:04:14.897Z"}
