{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Gq2SGMwnEm6FuMYfuqKkKG","type":"tool_result","content":"1\timport { defineConfig } from 'vitest/config';\n2\timport { readFileSync } from 'node:fs';\n3\t\n4\tconst pkg = JSON.parse(readFileSync('package.json', 'utf-8'));\n5\t\n6\texport default defineConfig({\n7\t  define: {\n8\t    '__PKG_VERSION__': JSON.stringify(pkg.version),\n9\t  },\n10\t  test: {\n11\t    root: 'src',\n12\t    coverage: {\n13\t      provider: 'v8',\n14\t      include: ['**/*.ts', '**/*.tsx'],\n15\t      exclude: ['**/__tests__/**', '**/*.test.ts', '**/*.test.tsx'],\n16\t      reporter: ['text', 'json-summary'],\n17\t      reportsDirectory: '../coverage',\n18\t    },\n19\t  },\n20\t});\n21\t"}]},"parent_tool_use_id":"toolu_01HxnCrGRVZ6a9aAYNaAhVvW","session_id":"82c789c3-0c3c-4e9f-a910-db433860b9ed","uuid":"7d677cd5-6ccb-42b0-9a30-4523e8b2cefc","timestamp":"2026-04-02T15:58:27.739Z"}
