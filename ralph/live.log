46→  });\n    47→\n    48→  it('returns correct defaults with a stack', () => {\n    49→    const state = getDefaultState('nodejs');\n    50→    expect(state.stack).toBe('nodejs');\n    51→  });\n    52→\n    53→  it('treats explicit null as null', () => {\n    54→    const state = getDefaultState(null);\n    55→    expect(state.stack).toBeNull();\n    56→  });\n    57→});\n    58→\n    59→describe('writeState', () => {\n    60→  it('creates .claude directory if it does not exist', () => {\n    61→    const state = getDefaultState('nodejs');\n    62→    writeState(state, testDir);\n    63→    expect(existsSync(join(testDir, '.claude'))).toBe(true);\n    64→  });\n    65→\n    66→  it('creates file with valid YAML frontmatter', () => {\n    67→    const state = getDefaultState('nodejs');\n    68→    writeState(state, testDir);\n    69→    const content = readFileSync(getStatePath(testDir), 'utf-8');\n    70→    expect(content.startsWith('---\\n')).toBe(true);\n    71→    expect(content).toContain('---\\n');\n    72→    // Should have two --- delimiters\n    73→    const parts = content.split('---');\n    74→    expect(parts.length).toBeGreaterThanOrEqual(3);\n    75→  });\n    76→\n    77→  it('uses snake_case field names', () => {\n    78→    const state = getDefaultState('nodejs');\n    79→    writeState(state, testDir);\n    80→    const content = readFileSync(getStatePath(testDir), 'utf-8');\n    81→    expect(content).toContain('harness_version');\n    82→    expect(content).toContain('session_flags');\n    83→    expect(content).toContain('logs_queried');\n    84→    expect(content).toContain('tests_passed');\n    85→    expect(content).toContain('coverage_met');\n    86→    expect(content).toContain('verification_run');\n    87→    expect(content).toContain('verification_log');\n    88→    // No camelCase\n    89→    expect(content).not.toContain('harnessVersion');\n    90→    expect(content).not.toContain('sessionFlags');\n    91→  });\n    92→\n    93→  it('