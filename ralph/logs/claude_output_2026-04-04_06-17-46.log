{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HRWyg67b8LSYhNCSRixbHo","type":"tool_result","content":"1\t/**\n2\t * Ink UI components — types and layout components (Header, Separator, StoryBreakdown).\n3\t *\n4\t * Renders a UX-spec-compliant live display with plain text header,\n5\t * ━━━ separators, and labeled story breakdown sections.\n6\t * Activity components (tools, thoughts, retry) are in ink-activity-components.tsx.\n7\t * The App root component is in ink-app.tsx to avoid circular imports.\n8\t */\n9\t\n10\timport React from 'react';\n11\timport { Text, Box } from 'ink';\n12\timport type { FlowStep } from './workflow-parser.js';\n13\t\n14\t// --- Types ---\n15\t\n16\texport interface SprintInfo {\n17\t  storyKey: string;\n18\t  phase: string;\n19\t  done: number;\n20\t  total: number;\n21\t  elapsed?: string;\n22\t  iterationCount?: number;\n23\t  totalCost?: number;\n24\t  acProgress?: string;\n25\t  currentCommand?: string;\n26\t  /** Number of active lanes (multi-lane mode). */\n27\t  laneCount?: number;\n28\t  /** Total cost across all lanes (multi-lane mode). */\n29\t  laneTotalCost?: number;\n30\t}\n31\t\n32\texport interface CompletedToolEntry {\n33\t  name: string;\n34\t  args: string;\n35\t  driver?: string;\n36\t}\n37\t\n38\texport type StoryStatusValue = 'done' | 'in-progress' | 'pending' | 'failed' | 'blocked';\n39\t\n40\texport interface StoryStatusEntry {\n41\t  key: string;\n42\t  status: StoryStatusValue;\n43\t  retryCount?: number;\n44\t  maxRetries?: number;\n45\t  costByDriver?: Record<string, number>;\n46\t}\n47\t\n48\texport interface RetryInfo {\n49\t  attempt: number;\n50\t  delay: number;\n51\t}\n52\t\n53\texport interface StoryMessage {\n54\t  type: 'ok' | 'warn' | 'fail';\n55\t  key: string;\n56\t  message: string;\n57\t  details?: string[];\n58\t}\n59\t\n60\texport type TaskNodeState = 'pending' | 'active' | 'done' | 'failed';\n61\t\n62\texport interface TaskNodeMeta {\n63\t  driver?: string;\n64\t  costUsd?: number | null;\n65\t  elapsedMs?: number | null;\n66\t}\n67\t\n68\texport interface RendererState {\n69\t  sprintInfo: SprintInfo | null;\n70\t  stories: StoryStatusEntry[];\n71\t  messages: StoryMessage[];\n72\t  completedTools: CompletedToolEntry[];\n73\t  activeTool: { name: string } | null;\n74\t  activeToolArgs: string;\n75\t  lastThought: string | null;\n76\t  retryInfo: RetryInfo | null;\n77\t  workflowFlow: FlowStep[];\n78\t  currentTaskName: string | null;\n79\t  taskStates: Record<string, TaskNodeState>;\n80\t  taskMeta: Record<string, TaskNodeMeta>;\n81\t  activeDriverName: string | null;\n82\t  driverCosts: Record<string, number>;\n83\t  /** Multi-lane data for parallel execution TUI. */\n84\t  lanes?: import('./ink-lane-container.js').LaneData[];\n85\t}\n86\t\n87\t// --- Layout Components ---\n88\t\n89\t/** Full-width separator using ━ characters. */\n90\texport function Separator() {\n91\t  const width = process.stdout.columns || 60;\n92\t  return <Text>{'━'.repeat(width)}</Text>;\n93\t}\n94\t\n95\tfunction shortKey(key: string): string {\n96\t  const m = key.match(/^(\\d+-\\d+)/);\n97\t  return m ? m[1] : key;\n98\t}\n99\t\n100\tfunction formatCost(cost: number): string {\n101\t  return `$${cost.toFixed(2)}`;\n102\t}\n103\t\n104\texport function Header({ info, laneCount }: { info: SprintInfo | null; laneCount?: number }) {\n105\t  if (!info) return null;\n106\t\n107\t  const parts: string[] = ['codeharness run'];\n108\t  if (laneCount != null && laneCount > 1) {\n109\t    parts.push(`${laneCount} lanes`);\n110\t  }\n111\t  if (info.iterationCount != null) {\n112\t    parts.push(`iteration ${info.iterationCount}`);\n113\t  }\n114\t  if (info.elapsed) {\n115\t    parts.push(`${info.elapsed} elapsed`);\n116\t  }\n117\t  // In multi-lane mode, show total cost across all lanes if available\n118\t  const displayCost = (laneCount != null && laneCount > 1 && info.laneTotalCost != null)\n119\t    ? info.laneTotalCost\n120\t    : info.totalCost;\n121\t  if (displayCost != null) {\n122\t    parts.push(`${formatCost(displayCost)} spent`);\n123\t  }\n124\t  const headerLine = parts.join(' | ');\n125\t\n126\t  let phaseLine = '';\n127\t  if (info.phase) {\n128\t    phaseLine = `Phase: ${info.phase}`;\n129\t    if (info.acProgress) {\n130\t      phaseLine += ` → AC ${info.acProgress}`;\n131\t    }\n132\t    if (info.currentCommand) {\n133\t      phaseLine += ` (${info.currentCommand})`;\n134\t    }\n135\t  }\n136\t\n137\t  return (\n138\t    <Box flexDirection=\"column\">\n139\t      <Text>{headerLine}</Text>\n140\t      <Separator />\n141\t      <Text>{`Story: ${info.storyKey || '(waiting)'}`}</Text>\n142\t      {phaseLine && <Text>{phaseLine}</Text>}\n143\t    </Box>\n144\t  );\n145\t}\n146\t\n147\texport function StoryBreakdown({ stories, sprintInfo }: { stories: StoryStatusEntry[]; sprintInfo?: SprintInfo | null }) {\n148\t  if (stories.length === 0) return null;\n149\t\n150\t  const done: StoryStatusEntry[] = [];\n151\t  const inProgress: StoryStatusEntry[] = [];\n152\t  const pending: StoryStatusEntry[] = [];\n153\t  const failed: StoryStatusEntry[] = [];\n154\t  const blocked: StoryStatusEntry[] = [];\n155\t\n156\t  for (const s of stories) {\n157\t    switch (s.status) {\n158\t      case 'done': done.push(s); break;\n159\t      case 'in-progress': inProgress.push(s); break;\n160\t      case 'pending': pending.push(s); break;\n161\t      case 'failed': failed.push(s); break;\n162\t      case 'blocked': blocked.push(s); break;\n163\t    }\n164\t  }\n165\t\n166\t  const lines: React.ReactNode[] = [];\n167\t\n168\t  if (done.length > 0) {\n169\t    const doneItems = done.map(s => {\n170\t      let item = `${shortKey(s.key)} ✓`;\n171\t      if (s.costByDriver && Object.keys(s.costByDriver).length > 0) {\n172\t        const costParts = Object.keys(s.costByDriver).sort().map(\n173\t          driver => `${driver} ${formatCost(s.costByDriver![driver])}`\n174\t        );\n175\t        item += ` ${costParts.join(', ')}`;\n176\t      }\n177\t      return item;\n178\t    }).join('  ');\n179\t    lines.push(\n180\t      <Text key=\"done\"><Text color=\"green\">{'Done: '}</Text><Text color=\"green\">{doneItems}</Text></Text>\n181\t    );\n182\t  }\n183\t\n184\t  if (inProgress.length > 0) {\n185\t    for (const s of inProgress) {\n186\t      let thisText = `${shortKey(s.key)} ◆`;\n187\t      if (sprintInfo && sprintInfo.storyKey && shortKey(s.key) === shortKey(sprintInfo.storyKey)) {\n188\t        if (sprintInfo.phase) thisText += ` ${sprintInfo.phase}`;\n189\t        if (sprintInfo.acProgress) thisText += ` (${sprintInfo.acProgress} ACs)`;\n190\t      }\n191\t      lines.push(\n192\t        <Text key={`this-${s.key}`}><Text color=\"cyan\">{'This: '}</Text><Text color=\"cyan\">{thisText}</Text></Text>\n193\t      );\n194\t    }\n195\t  }\n196\t\n197\t  if (pending.length > 0) {\n198\t    lines.push(\n199\t      <Text key=\"next\">\n200\t        <Text>{'Next: '}</Text><Text>{shortKey(pending[0].key)}</Text>\n201\t        {pending.length > 1 && <Text dimColor>{` (+${pending.length - 1} more)`}</Text>}\n202\t      </Text>\n203\t    );\n204\t  }\n205\t\n206\t  if (blocked.length > 0) {\n207\t    const blockedItems = blocked.map(s => {\n208\t      let item = `${shortKey(s.key)} ✕`;\n209\t      if (s.retryCount != null && s.maxRetries != null) item += ` (${s.retryCount}/${s.maxRetries})`;\n210\t      return item;\n211\t    }).join('  ');\n212\t    lines.push(\n213\t      <Text key=\"blocked\"><Text color=\"yellow\">{'Blocked: '}</Text><Text color=\"yellow\">{blockedItems}</Text></Text>\n214\t    );\n215\t  }\n216\t\n217\t  if (failed.length > 0) {\n218\t    const failedItems = failed.map(s => {\n219\t      let item = `${shortKey(s.key)} ✗`;\n220\t      if (s.retryCount != null && s.maxRetries != null) item += ` (${s.retryCount}/${s.maxRetries})`;\n221\t      return item;\n222\t    }).join('  ');\n223\t    lines.push(\n224\t      <Text key=\"failed\"><Text color=\"red\">{'Failed: '}</Text><Text color=\"red\">{failedItems}</Text></Text>\n225\t    );\n226\t  }\n227\t\n228\t  return (\n229\t    <Box flexDirection=\"column\">\n230\t      {lines}\n231\t    </Box>\n232\t  );\n233\t}\n234\t\n235\t// Re-export activity components so existing consumers don't break\n236\texport { CompletedTool, CompletedTools, ActiveTool, LastThought, RetryNotice, StoryMessageLine, DriverCostSummary } from './ink-activity-components.js';\n237\t\n238\t// Re-export App from ink-app\n239\texport { App } from './ink-app.js';\n240\t"}]},"parent_tool_use_id":"toolu_01LF9uJNPtHNwmRNh99eK7QX","session_id":"0c112080-0896-4e32-96a0-f82adec16922","uuid":"0064e330-52ce-4246-bbb3-2fdbc7988f78","timestamp":"2026-04-04T02:26:14.673Z"}
