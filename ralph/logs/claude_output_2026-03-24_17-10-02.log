{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RuJYLE4ABPknGMDUo1VLZ7","type":"tool_result","content":"     1→/**\n     2→ * Documentation staleness and completeness checks.\n     3→ */\n     4→\n     5→import { execSync } from 'node:child_process';\n     6→import {\n     7→  existsSync,\n     8→  readFileSync,\n     9→  readdirSync,\n    10→  statSync,\n    11→} from 'node:fs';\n    12→import { join, relative } from 'node:path';\n    13→import { getExtension, isTestFile, getNewestSourceMtime } from './types.js';\n    14→import type { DocHealthResult, DocHealthReport } from './types.js';\n    15→import { findModules } from './scanner.js';\n    16→\n    17→const SOURCE_EXTENSIONS = new Set(['.ts', '.js', '.py']);\n    18→const DO_NOT_EDIT_HEADER = '<!-- DO NOT EDIT MANUALLY';\n    19→\n    20→// ─── Freshness Checking ─────────────────────────────────────────────────────\n    21→\n    22→export function isDocStale(docPath: string, codeDir: string): boolean {\n    23→  if (!existsSync(docPath)) return true;\n    24→  if (!existsSync(codeDir)) return false;\n    25→\n    26→  const docMtime = statSync(docPath).mtime;\n    27→  const newestCode = getNewestSourceMtime(codeDir);\n    28→\n    29→  if (newestCode === null) return false;\n    30→  return newestCode.getTime() > docMtime.getTime();\n    31→}\n    32→\n    33→// ─── AGENTS.md Content Completeness ──────────────────────────────────────────\n    34→\n    35→export function getSourceFilesInModule(modulePath: string): string[] {\n    36→  const files: string[] = [];\n    37→\n    38→  function walk(current: string): void {\n    39→    let entries: string[];\n    40→    try {\n    41→      entries = readdirSync(current);\n    42→    } catch {\n    43→      return;\n    44→    }\n    45→\n    46→    const dirName = current.split('/').pop() ?? '';\n    47→    if (\n    48→      dirName === 'node_modules' ||\n    49→      dirName === '.git' ||\n    50→      dirName === '__tests__' ||\n    51→      dirName === 'dist' ||\n    52→      dirName === 'coverage' ||\n    53→      (dirName.startsWith('.') && current !== modulePath)\n    54→    ) return;\n    55→\n    56→    for (const entry of entries) {\n    57→      const fullPath = join(current, entry);\n    58→      let stat;\n    59→      try {\n    60→        stat = statSync(fullPath);\n    61→      } catch {\n    62→        continue;\n    63→      }\n    64→\n    65→      if (stat.isDirectory()) {\n    66→        walk(fullPath);\n    67→      } else if (stat.isFile()) {\n    68→        const ext = getExtension(entry);\n    69→        if (SOURCE_EXTENSIONS.has(ext) && !isTestFile(entry)) {\n    70→          files.push(entry);\n    71→        }\n    72→      }\n    73→    }\n    74→  }\n    75→\n    76→  walk(modulePath);\n    77→  return files;\n    78→}\n    79→\n    80→export function getMentionedFilesInAgentsMd(agentsPath: string): string[] {\n    81→  if (!existsSync(agentsPath)) return [];\n    82→\n    83→  const content = readFileSync(agentsPath, 'utf-8');\n    84→  const mentioned = new Set<string>();\n    85→\n    86→  const filenamePattern = /[\\w./-]*[\\w-]+\\.(?:ts|js|py)\\b/g;\n    87→  let match;\n    88→  while ((match = filenamePattern.exec(content)) !== null) {\n    89→    const fullMatch = match[0];\n    90→    const basename = fullMatch.split('/').pop()!;\n    91→    if (!isTestFile(basename)) {\n    92→      mentioned.add(basename);\n    93→    }\n    94→  }\n    95→\n    96→  return Array.from(mentioned);\n    97→}\n    98→\n    99→export function checkAgentsMdCompleteness(\n   100→  agentsPath: string,\n   101→  modulePath: string,\n   102→): { complete: boolean; missing: string[] } {\n   103→  const sourceFiles = getSourceFilesInModule(modulePath);\n   104→  const mentionedFiles = new Set(getMentionedFilesInAgentsMd(agentsPath));\n   105→\n   106→  const missing = sourceFiles.filter(f => !mentionedFiles.has(f));\n   107→\n   108→  return {\n   109→    complete: missing.length === 0,\n   110→    missing,\n   111→  };\n   112→}\n   113→\n   114→// ─── AGENTS.md Checking ─────────────────────────────────────────────────────\n   115→\n   116→export function checkAgentsMdForModule(\n   117→  modulePath: string,\n   118→  dir?: string,\n   119→): DocHealthResult {\n   120→  const root = dir ?? process.cwd();\n   121→  const fullModulePath = join(root, modulePath);\n   122→\n   123→  let agentsPath = join(fullModulePath, 'AGENTS.md');\n   124→  if (!existsSync(agentsPath)) {\n   125→    agentsPath = join(root, 'AGENTS.md');\n   126→  }\n   127→\n   128→  if (!existsSync(agentsPath)) {\n   129→    return {\n   130→      path: relative(root, agentsPath),\n   131→      grade: 'missing',\n   132→      lastModified: null,\n   133→      codeLastModified: getNewestSourceMtime(fullModulePath),\n   134→      reason: `No AGENTS.md found for module: ${modulePath}`,\n   135→    };\n   136→  }\n   137→\n   138→  const docMtime = statSync(agentsPath).mtime;\n   139→  const codeMtime = getNewestSourceMtime(fullModulePath);\n   140→\n   141→  const { complete, missing } = checkAgentsMdCompleteness(agentsPath, fullModulePath);\n   142→\n   143→  if (!complete) {\n   144→    const missingList = missing.join(', ');\n   145→    return {\n   146→      path: relative(root, agentsPath),\n   147→      grade: 'stale',\n   148→      lastModified: docMtime,\n   149→      codeLastModified: codeMtime,\n   150→      reason: `AGENTS.md stale for module: ${modulePath} — missing: ${missingList}`,\n   151→    };\n   152→  }\n   153→\n   154→  return {\n   155→    path: relative(root, agentsPath),\n   156→    grade: 'fresh',\n   157→    lastModified: docMtime,\n   158→    codeLastModified: codeMtime,\n   159→    reason: 'Up to date',\n   160→  };\n   161→}\n   162→\n   163→// ─── DO NOT EDIT Header Check ────────────────────────────────────────────────\n   164→\n   165→export function checkDoNotEditHeaders(docPath: string): boolean {\n   166→  if (!existsSync(docPath)) return false;\n   167→\n   168→  try {\n   169→    const content = readFileSync(docPath, 'utf-8');\n   170→    if (content.length === 0) return false;\n   171→    return content.trimStart().startsWith(DO_NOT_EDIT_HEADER);\n   172→  } catch {\n   173→    return false;\n   174→  }\n   175→}\n   176→\n   177→// ─── Story-Specific Freshness ────────────────────────────────────────────────\n   178→\n   179→export function checkStoryDocFreshness(\n   180→  storyId: string,\n   181→  dir?: string,\n   182→): DocHealthReport {\n   183→  const start = Date.now();\n   184→  const root = dir ?? process.cwd();\n   185→  const documents: DocHealthResult[] = [];\n   186→\n   187→  const changedFiles = getRecentlyChangedFiles(root);\n   188→  const allModules = findModules(root);\n   189→\n   190→  let modulesToCheck: string[];\n   191→\n   192→  if (changedFiles.length > 0) {\n   193→    const changedModules = new Set<string>();\n   194→    for (const file of changedFiles) {\n   195→      for (const mod of allModules) {\n   196→        if (file.startsWith(mod + '/') || file.startsWith(mod + '\\\\')) {\n   197→          changedModules.add(mod);\n   198→        }\n   199→      }\n   200→    }\n   201→    modulesToCheck = Array.from(changedModules);\n   202→  } else {\n   203→    modulesToCheck = allModules;\n   204→  }\n   205→\n   206→  for (const mod of modulesToCheck) {\n   207→    const result = checkAgentsMdForModule(mod, root);\n   208→    documents.push(result);\n   209→\n   210→    const moduleAgentsPath = join(root, mod, 'AGENTS.md');\n   211→    const actualAgentsPath = existsSync(moduleAgentsPath)\n   212→      ? moduleAgentsPath\n   213→      : join(root, 'AGENTS.md');\n   214→    if (existsSync(actualAgentsPath)) {\n   215→      checkAgentsMdLineCountInternal(actualAgentsPath, result.path, documents);\n   216→    }\n   217→  }\n   218→\n   219→  if (modulesToCheck.length === 0) {\n   220→    const rootAgentsPath = join(root, 'AGENTS.md');\n   221→    if (existsSync(rootAgentsPath)) {\n   222→      documents.push({\n   223→        path: 'AGENTS.md',\n   224→        grade: 'fresh',\n   225→        lastModified: statSync(rootAgentsPath).mtime,\n   226→        codeLastModified: null,\n   227→        reason: 'No changed modules detected',\n   228→      });\n   229→    }\n   230→  }\n   231→\n   232→  const summary = {\n   233→    fresh: documents.filter(d => d.grade === 'fresh').length,\n   234→    stale: documents.filter(d => d.grade === 'stale').length,\n   235→    missing: documents.filter(d => d.grade === 'missing').length,\n   236→    total: documents.length,\n   237→  };\n   238→\n   239→  return {\n   240→    documents,\n   241→    summary,\n   242→    passed: summary.stale === 0 && summary.missing === 0,\n   243→    scanDurationMs: Date.now() - start,\n   244→  };\n   245→}\n   246→\n   247→function getRecentlyChangedFiles(dir: string): string[] {\n   248→  try {\n   249→    const output = execSync('git diff --name-only HEAD~5', {\n   250→      cwd: dir,\n   251→      encoding: 'utf-8',\n   252→      stdio: ['pipe', 'pipe', 'pipe'],\n   253→      timeout: 10_000,\n   254→    });\n   255→    return output\n   256→      .trim()\n   257→      .split('\\n')\n   258→      .filter(line => line.length > 0);\n   259→  } catch {\n   260→    return [];\n   261→  }\n   262→}\n   263→\n   264→function checkAgentsMdLineCountInternal(\n   265→  filePath: string,\n   266→  docPath: string,\n   267→  documents: DocHealthResult[],\n   268→): void {\n   269→  try {\n   270→    const content = readFileSync(filePath, 'utf-8');\n   271→    const lineCount = content.split('\\n').length;\n   272→    if (lineCount > 100) {\n   273→      documents.push({\n   274→        path: docPath,\n   275→        grade: 'fresh',\n   276→        lastModified: statSync(filePath).mtime,\n   277→        codeLastModified: null,\n   278→        reason: `AGENTS.md exceeds 100 lines (${lineCount} lines) — consider splitting`,\n   279→      });\n   280→    }\n   281→  } catch {\n   282→    // Ignore read errors\n   283→  }\n   284→}\n   285→"}]},"parent_tool_use_id":"toolu_01WxJciqSN2EMLLyK1wQ7yug","session_id":"6831c0a8-772d-4704-bc72-4469c7d7a986","uuid":"b1a86c0f-390b-49d7-8fad-cd8844ff17f4","timestamp":"2026-03-24T13:14:02.536Z"}
