{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01MkNQb3bnxFJFftZT8ANt8x","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Qw1B47LTDrr2NMKZR36HTU","name":"Write","input":{"file_path":"/Users/ivintik/dev/personal/codeharness/src/lib/trace-id.ts","content":"import type { WorkflowState } from './workflow-state.js';\n\n// --- Functions ---\n\n/**\n * Sanitize a string segment for use in a trace ID.\n *\n * Replaces non-alphanumeric characters (except hyphens) with hyphens,\n * collapses consecutive hyphens, and trims leading/trailing hyphens.\n */\nexport function sanitizeSegment(segment: string): string {\n  return segment\n    .replace(/[^a-zA-Z0-9-]/g, '-')\n    .replace(/-{2,}/g, '-')\n    .replace(/^-+|-+$/g, '');\n}\n\n/**\n * Generate a trace ID for a workflow iteration.\n *\n * Format: `ch-{runId}-{iteration}-{taskName}`\n *\n * The `runId` and `taskName` segments are sanitized to be safe for logs,\n * metrics labels, HTTP headers, and YAML serialization.\n */\nexport function generateTraceId(\n  runId: string,\n  iteration: number,\n  taskName: string,\n): string {\n  const safeRunId = sanitizeSegment(runId);\n  const safeTask = sanitizeSegment(taskName);\n  return `ch-${safeRunId}-${iteration}-${safeTask}`;\n}\n\n/**\n * Format a trace ID as a system prompt fragment for agent injection.\n *\n * Returns a structured block that an agent can include in log/metric/trace output.\n */\nexport function formatTracePrompt(traceId: string): string {\n  return `[TRACE] trace_id=${traceId}\\nInclude this trace ID in all log output, metric labels, and trace spans for correlation.`;\n}\n\n/**\n * Record a trace ID in workflow state.\n *\n * Returns a **new** WorkflowState with the trace ID appended to `trace_ids`.\n * Does not mutate the input state.\n *\n * Throws if `traceId` is empty.\n */\nexport function recordTraceId(\n  traceId: string,\n  state: WorkflowState,\n): WorkflowState {\n  if (!traceId) {\n    throw new Error('recordTraceId: traceId must be a non-empty string');\n  }\n\n  return {\n    ...state,\n    trace_ids: [...(state.trace_ids ?? []), traceId],\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":10187,"cache_read_input_tokens":25979,"cache_creation":{"ephemeral_5m_input_tokens":10187,"ephemeral_1h_input_tokens":0},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_0135B8ByKKd4w4TUHXADwck1","session_id":"a1f3179e-0b63-4a22-aa4b-b755c26a5a4c","uuid":"bef6ace1-64c6-4057-8143-fc50a206d2bb"}
