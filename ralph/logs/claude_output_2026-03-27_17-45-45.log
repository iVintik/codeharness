{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WGnuXqKk7B4fkq1hQktqF5","type":"tool_result","content":"    90→    otherCount,\n    91→    grepRatio,\n    92→    acsMissingDockerExec,\n    93→  };\n    94→}\n    95→\n    96→/** Checks if [FAIL] appears outside code blocks and inline code. */\n    97→function hasFailVerdict(section: string): boolean {\n    98→  return section.replace(/```[\\s\\S]*?```/g, '').replace(/`[^`]+`/g, '').includes('[FAIL]');\n    99→}\n   100→\n   101→/** Validates proof quality. `passed` is true when `pending === 0 && verified > 0`. */\n   102→export function validateProofQuality(proofPath: string): ProofQuality {\n   103→  const emptyResult: ProofQuality = {\n   104→    verified: 0, pending: 0, escalated: 0, total: 0, passed: false,\n   105→    grepSrcCount: 0, dockerExecCount: 0, observabilityCount: 0, otherCount: 0,\n   106→    blackBoxPass: false,\n   107→  };\n   108→\n   109→  if (!existsSync(proofPath)) {\n   110→    return emptyResult;\n   111→  }\n   112→\n   113→  const content = readFileSync(proofPath, 'utf-8');\n   114→\n   115→  // Compute black-box enforcement metrics once\n   116→  // Build tier regex dynamically from canonical TIER_HIERARCHY + legacy names\n   117→  const allTierNames = [...TIER_HIERARCHY, ...Object.keys(LEGACY_TIER_MAP)];\n   118→  const uniqueTierNames = [...new Set(allTierNames)];\n   119→  const tierPattern = new RegExp(`\\\\*\\\\*Tier:\\\\*\\\\*\\\\s*(${uniqueTierNames.join('|')})`, 'i');\n   120→  const bbTierMatch = tierPattern.exec(content);\n   121→  const rawTierValue = bbTierMatch ? bbTierMatch[1].toLowerCase() : null;\n   122→  // Normalize legacy tier names to canonical VerificationTier values\n   123→  const normalizedTier: VerificationTier | null = rawTierValue\n   124→    ? (LEGACY_TIER_MAP[rawTierValue] as VerificationTier | undefined) ?? (TIER_HIERARCHY.includes(rawTierValue as VerificationTier) ? rawTierValue as VerificationTier : null)\n   125→    : null;\n   126→  // Only environment-provable requires Docker evidence; all others skip\n   127→  const skipDockerEnforcement = normalizedTier !== null && normalizedTier !== 'environment-provable';\n   128→  // Always compute metrics for diagnostics; override blackBoxPass when skipping\n   129→  const bbRawEnforcement = checkBlackBoxEnforcement(content);\n   130→  const bbEnforcement = skipDockerEnforcement\n   131→    ? { ...bbRawEnforcement, blackBoxPass: true }\n   132→    : bbRawEnforcement;\n   133→\n   134→  /** Helper: merge base counts with black-box metrics */\n   135→  function buildResult(base: {\n   136→    verified: number; pending: number; escalated: number; total: number;\n   137→  }): ProofQuality {\n   138→    const basePassed = base.pending === 0 && base.verified > 0;\n   139→    return {\n   140→      ...base,\n   141→      passed: basePassed && bbEnforcement.blackBoxPass,\n   142→      grepSrcCount: bbEnforcement.grepSrcCount,\n   143→      dockerExecCount: bbEnforcement.dockerExecCount,\n   144→      observabilityCount: bbEnforcement.observabilityCount,\n   145→      otherCount: bbEnforcement.otherCount,\n   146→      blackBoxPass: bbEnforcement.blackBoxPass,\n   147→    };\n   148→  }\n   149→"}]},"parent_tool_use_id":"toolu_01WnS5VKtq5Dt9CxjE5HvPUj","session_id":"b3a82007-2654-437f-8d26-bde42ea858b0","uuid":"15ac3618-e809-481c-8761-78a23840c950","timestamp":"2026-03-27T14:07:28.128Z"}
