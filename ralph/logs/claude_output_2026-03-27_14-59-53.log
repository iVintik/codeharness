{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011pzF5pd89JHBnCb6m2cZ96","type":"tool_result","content":"     1→/**\n     2→ * Types for the verify module.\n     3→ * Merged from src/lib/verify.ts and src/lib/verify-parser.ts.\n     4→ */\n     5→\n     6→import type { AcResult } from '../../types/state.js';\n     7→\n     8→// ─── Parser Types ────────────────────────────────────────────────────────────\n     9→\n    10→/** @deprecated Use `VerificationTier` instead. Will be removed in a future release. */\n    11→export type Verifiability = 'cli-verifiable' | 'integration-required';\n    12→\n    13→/** The four verification tiers — what evidence is needed to prove ACs work. */\n    14→export type VerificationTier = 'test-provable' | 'runtime-provable' | 'environment-provable' | 'escalate';\n    15→\n    16→/** Tier ordering from lowest to highest. Index = priority. */\n    17→export const TIER_HIERARCHY: readonly VerificationTier[] = [\n    18→  'test-provable',\n    19→  'runtime-provable',\n    20→  'environment-provable',\n    21→  'escalate',\n    22→] as const;\n    23→\n    24→/** Returns the highest tier from an array of tiers. Empty array -> 'test-provable'. */\n    25→export function maxTier(tiers: VerificationTier[]): VerificationTier {\n    26→  if (tiers.length === 0) return 'test-provable';\n    27→  return tiers.reduce((max, t) =>\n    28→    TIER_HIERARCHY.indexOf(t) > TIER_HIERARCHY.indexOf(max) ? t : max\n    29→  );\n    30→}\n    31→\n    32→/** Maps old tag values to new VerificationTier values for backward compat. */\n    33→export const LEGACY_TIER_MAP: Record<string, VerificationTier> = {\n    34→  'cli-verifiable': 'test-provable',\n    35→  'integration-required': 'environment-provable',\n    36→  'unit-testable': 'test-provable',\n    37→};\n    38→\n    39→/**\n    40→ * Verification strategy — how the verifier should approach proving an AC.\n    41→ *\n    42→ * @deprecated Use `VerificationTier` instead. Will be removed in a future release.\n    43→ *\n    44→ * - docker:    Run in a Docker container (default, safest)\n    45→ * - cli-direct: Run CLI commands in the current subprocess (fallback)\n    46→ * - escalate:   Truly impossible — requires physical hardware, external paid\n    47→ *               service, or human judgement. Last resort only.\n    48→ */\n    49→export type VerificationStrategy = 'docker' | 'cli-direct' | 'escalate';\n    50→"}]},"parent_tool_use_id":"toolu_01KAstRRqc12jqV5LKYooyKt","session_id":"43e58b5f-4801-4d1c-b71e-1cb2980b19a0","uuid":"9c0d7cdf-9b29-4b4d-97bc-fdd0cbc6c32e","timestamp":"2026-03-27T11:06:13.643Z"}
