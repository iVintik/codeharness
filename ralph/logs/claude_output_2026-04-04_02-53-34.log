{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DYaRMcTHHuZyrVLEWQx9oU","type":"tool_result","content":"1\t/**\n2\t * Cross-Worktree Validator.\n3\t *\n4\t * Encapsulates the test-run-after-merge logic extracted from\n5\t * worktree-manager.ts and merge-agent.ts. Both modules delegate\n6\t * to validateMerge() instead of maintaining their own runTestSuite\n7\t * and parseTestOutput implementations.\n8\t *\n9\t * @see Story 18-3: Cross-Worktree Test Validation\n10\t */\n11\t\n12\timport { exec } from 'node:child_process';\n13\timport { appendFileSync, mkdirSync } from 'node:fs';\n14\timport { join } from 'node:path';\n15\timport { promisify } from 'node:util';\n16\t\n17\timport type { TelemetryEntry } from './telemetry-writer.js';\n18\t\n19\tconst execAsync = promisify(exec);\n20\t\n21\t/** 10 MB — generous buffer for verbose test + coverage output. */\n22\tconst MAX_BUFFER = 10 * 1024 * 1024;\n23\t\n24\t// --- Interfaces ---\n25\t\n26\t/**\n27\t * Options for running post-merge test validation.\n28\t */\n29\texport interface ValidateMergeOptions {\n30\t  /** Command to run for test validation. */\n31\t  readonly testCommand: string;\n32\t  /** Working directory to run the test command in. */\n33\t  readonly cwd: string;\n34\t  /** Epic identifier for telemetry. */\n35\t  readonly epicId: string;\n36\t  /** Optional story key override for telemetry (defaults to `merge-{epicId}`). */\n37\t  readonly storyKey?: string;\n38\t  /** Whether to write a telemetry entry after the test suite completes. */\n39\t  readonly writeTelemetry: boolean;\n40\t}\n41\t\n42\t/**\n43\t * Result of a post-merge test validation.\n44\t */\n45\texport interface ValidationResult {\n46\t  /** Whether all tests passed (passed > 0 and failed === 0). */\n47\t  readonly valid: boolean;\n48\t  /** Parsed test results: pass/fail counts and coverage (null if not reported). */\n49\t  readonly testResults: { passed: number; failed: number; coverage: number | null };\n50\t  /** Raw test command stdout+stderr for retry context. */\n51\t  readonly output: string;\n52\t  /** Wall-clock duration of the test run in milliseconds. */\n53\t  readonly durationMs: number;\n54\t}\n55\t\n56\t// --- Constants ---\n57\t\n58\tconst TELEMETRY_DIR = '.codeharness';\n59\tconst TELEMETRY_FILE = 'telemetry.jsonl';\n60\tconst TEST_TIMEOUT_MS = 300_000; // 5 minutes\n61\t\n62\t// --- Test Output Parsing ---\n63\t\n64\t/**\n65\t * Parse test output to extract pass/fail counts and optional coverage.\n66\t * Supports vitest/jest output patterns.\n67\t */\n68\texport function parseTestOutput(stdout: string): { passed: number; failed: number; coverage: number | null } {\n69\t  let passed = 0;\n70\t  let failed = 0;\n71\t  let coverage: number | null = null;\n72\t\n73\t  const passMatch = stdout.match(/(\\d+)\\s+passed/);\n74\t  const failMatch = stdout.match(/(\\d+)\\s+failed/);\n75\t  if (passMatch) passed = parseInt(passMatch[1], 10);\n76\t  if (failMatch) failed = parseInt(failMatch[1], 10);\n77\t\n78\t  const covMatch = stdout.match(/All files[^|]*\\|\\s*([\\d.]+)/);\n79\t  if (covMatch) coverage = parseFloat(covMatch[1]);\n80\t\n81\t  return { passed, failed, coverage };\n82\t}\n83\t\n84\t// --- Telemetry ---\n85\t\n86\t/**\n87\t * Write a merge validation telemetry entry to the NDJSON telemetry file.\n88\t * Failures are silently caught — telemetry must never break validation.\n89\t *\n90\t * Exported so callers (e.g., merge-agent) can defer telemetry writes\n91\t * until they know whether the validation is final (success or last attempt).\n92\t */\n93\texport function writeMergeTelemetry(opts: ValidateMergeOptions, result: ValidationResult): void {\n94\t  try {\n95\t    const entry: TelemetryEntry = {\n96\t      version: 1,\n97\t      timestamp: new Date().toISOString(),\n98\t      storyKey: opts.storyKey ?? `merge-${opts.epicId}`,\n99\t      epicId: opts.epicId,\n100\t      duration_ms: result.durationMs,\n101\t      cost_usd: null,\n102\t      attempts: null,\n103\t      acResults: null,\n104\t      filesChanged: [],\n105\t      testResults: result.testResults,\n106\t      errors: result.valid ? [] : ['Test suite failed after merge'],\n107\t    };\n108\t\n109\t    const dir = join(opts.cwd, TELEMETRY_DIR);\n110\t    mkdirSync(dir, { recursive: true });\n111\t    appendFileSync(join(dir, TELEMETRY_FILE), JSON.stringify(entry) + '\\n');\n112\t  } catch { // IGNORE: telemetry write failure must not break validation\n113\t  }\n114\t}\n115\t\n116\t// --- Main Entry Point ---\n117\t\n118\t/**\n119\t * Run test validation after a merge and optionally write telemetry.\n120\t *\n121\t * Executes the configured test command, parses the output for\n122\t * pass/fail/coverage, and returns a ValidationResult. When\n123\t * writeTelemetry is true, appends an NDJSON entry to the\n124\t * telemetry file.\n125\t *\n126\t * @param opts  Validation options including test command and cwd.\n127\t * @returns Validation result with test results and raw output.\n128\t */\n129\texport async function validateMerge(opts: ValidateMergeOptions): Promise<ValidationResult> {\n130\t  const start = Date.now();\n131\t\n132\t  try {\n133\t    const { stdout, stderr } = await execAsync(opts.testCommand, {\n134\t      cwd: opts.cwd,\n135\t      timeout: TEST_TIMEOUT_MS,\n136\t      maxBuffer: MAX_BUFFER,\n137\t    });\n138\t\n139\t    const combined = stdout + (stderr ? '\\n' + stderr : '');\n140\t    const testResults = parseTestOutput(combined);\n141\t    const result: ValidationResult = {\n142\t      valid: testResults.failed === 0 && testResults.passed > 0,\n143\t      testResults,\n144\t      output: combined,\n145\t      durationMs: Date.now() - start,\n146\t    };\n147\t\n148\t    if (opts.writeTelemetry) {\n149\t      writeMergeTelemetry(opts, result);\n150\t    }\n151\t\n152\t    return result;\n153\t  } catch (err: unknown) {\n154\t    const stdout = (err as { stdout?: string })?.stdout ?? '';\n155\t    const stderr = (err as { stderr?: string })?.stderr ?? '';\n156\t    const combined = stdout + (stderr ? '\\n' + stderr : '');\n157\t    const testResults = parseTestOutput(combined);\n158\t\n159\t    // If we couldn't parse anything, report 1 failure\n160\t    if (testResults.passed === 0 && testResults.failed === 0) {\n161\t      const result: ValidationResult = {\n162\t        valid: false,\n163\t        testResults: { passed: 0, failed: 1, coverage: null },\n164\t        output: combined || 'Test command failed with no output',\n165\t        durationMs: Date.now() - start,\n166\t      };\n167\t\n168\t      if (opts.writeTelemetry) {\n169\t        writeMergeTelemetry(opts, result);\n170\t      }\n171\t\n172\t      return result;\n173\t    }\n174\t\n175\t    const result: ValidationResult = {\n176\t      valid: false,\n177\t      testResults,\n178\t      output: combined,\n179\t      durationMs: Date.now() - start,\n180\t    };\n181\t\n182\t    if (opts.writeTelemetry) {\n183\t      writeMergeTelemetry(opts, result);\n184\t    }\n185\t\n186\t    return result;\n187\t  }\n188\t}\n189\t"}]},"parent_tool_use_id":"toolu_01TWqA5TngtorJpmpMX6MG5X","session_id":"cb820906-0735-4f53-a851-3960824caad6","uuid":"77f089e2-307e-4edd-8730-14dda754f378","timestamp":"2026-04-03T22:54:31.967Z"}
{"type":"system","subtype":"task_progress","task_id":"ae4431b46d1021457","tool_use_id":"toolu_01TWqA5TngtorJpmpMX6MG5X","description":"Writing src/lib/epic-completion.ts","usage":{"total_tokens":27840,"tool_uses":9,"duration_ms":39790},"last_tool_name":"Write","uuid":"fe51105b-dced-47ec-9513-5e575423cd11","session_id":"cb820906-0735-4f53-a851-3960824caad6"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_017jgFS97caXnuNgtB7KGF2U","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01VPogGPMdMg3WF9NgQ6TcgB","name":"Write","input":{"file_path":"/Users/ivintik/dev/personal/codeharness/src/lib/epic-completion.ts","content":"/**\n * Epic Completion Detection.\n *\n * Pure logic module that detects when all stories in an epic reach\n * \"done\" status and provides a state machine for epic lifecycle\n * transitions: in-progress → completing → merging → validating → done.\n *\n * @see Story 19-1: Epic Completion Detection\n */\n\nimport type { SprintState } from '../types/state.js';\n\n// --- Types ---\n\n/**\n * All possible epic lifecycle statuses.\n * Narrows the broad `string` type from EpicState.status.\n */\nexport type EpicLifecycleStatus =\n  | 'in-progress'\n  | 'completing'\n  | 'merging'\n  | 'validating'\n  | 'done'\n  | 'failed';\n\n// --- Error ---\n\n/**\n * Error thrown for invalid epic operations:\n * - Epic not found in state\n * - Invalid state transition\n */\nexport class EpicCompletionError extends Error {\n  constructor(message: string) {\n    super(message);\n    this.name = 'EpicCompletionError';\n  }\n}\n\n// --- State Machine ---\n\n/**\n * Valid epic state transitions.\n *\n * Happy path: in-progress → completing → merging → validating → done\n * Failure:    completing|merging|validating → failed\n */\nexport const VALID_TRANSITIONS: Record<string, EpicLifecycleStatus[]> = {\n  'in-progress': ['completing'],\n  'completing': ['merging', 'failed'],\n  'merging': ['validating', 'failed'],\n  'validating': ['done', 'failed'],\n};\n\n// --- Functions ---\n\n/**\n * Get all story keys belonging to a given epic.\n *\n * Stories are matched by the numeric prefix before the first dash.\n * E.g., epicId \"19\" matches \"19-1-foo\" and \"19-2-bar\" but not \"1-9-baz\".\n */\nexport function getEpicStories(state: SprintState, epicId: string): string[] {\n  return Object.keys(state.stories).filter((key) => {\n    const dash = key.indexOf('-');\n    if (dash === -1) return false;\n    return key.slice(0, dash) === epicId;\n  });\n}\n\n/**\n * Check whether all stories in an epic have status \"done\".\n *\n * Returns false for epics with zero stories (never considered complete).\n * Throws EpicCompletionError if the epic does not exist in state.\n */\nexport function checkEpicCompletion(state: SprintState, epicId: string): boolean {\n  if (!state.epics[`epic-${epicId}`]) {\n    throw new EpicCompletionError(`Epic epic-${epicId} not found in state`);\n  }\n  const stories = getEpicStories(state, epicId);\n  if (stories.length === 0) return false;\n  return stories.every((key) => state.stories[key]?.status === 'done');\n}\n\n/**\n * Transition an epic to a new lifecycle status (immutable).\n *\n * Validates that:\n * 1. The epic exists in state\n * 2. The transition is allowed by the state machine\n *\n * When transitioning to \"completing\", updates storiesDone to the\n * count of stories with status \"done\".\n *\n * Returns a new SprintState — does not mutate the input.\n */\nexport function transitionEpicState(\n  state: SprintState,\n  epicId: string,\n  targetStatus: EpicLifecycleStatus,\n): SprintState {\n  const epicKey = `epic-${epicId}`;\n  const epic = state.epics[epicKey];\n  if (!epic) throw new EpicCompletionError(`Epic ${epicKey} not found in state`);\n\n  const currentStatus = epic.status as EpicLifecycleStatus;\n  const allowed = VALID_TRANSITIONS[currentStatus];\n  if (!allowed?.includes(targetStatus)) {\n    throw new EpicCompletionError(\n      `Invalid transition: ${currentStatus} → ${targetStatus}`,\n    );\n  }\n\n  const storiesDone = targetStatus === 'completing'\n    ? getEpicStories(state, epicId).filter((k) => state.stories[k]?.status === 'done').length\n    : epic.storiesDone;\n\n  return {\n    ...state,\n    epics: {\n      ...state.epics,\n      [epicKey]: { ...epic, status: targetStatus, storiesDone },\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3908,"cache_read_input_tokens":23839,"cache_creation":{"ephemeral_5m_input_tokens":3908,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01TWqA5TngtorJpmpMX6MG5X","session_id":"cb820906-0735-4f53-a851-3960824caad6","uuid":"10e1be06-d93d-4d2d-b764-d8cda7126c40"}
