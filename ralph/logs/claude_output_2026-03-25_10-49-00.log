     Handle the error or add a # IGNORE: comment\"}\n```\n\n```bash\nnpx vitest run src/modules/review/__tests__/error-handling-enforcement.test.ts 2>&1 | tail -2\n```\n```output\n Test Files  1 passed (1)\n      Tests  14 passed (14)\n```\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":249,"cache_read_input_tokens":72436,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":249},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"3fcb2b1c-e710-401b-91ab-b64a3e9a3996","uuid":"52e0ad4c-a4f6-4459-ba02-d5d5b0f6b027"}
