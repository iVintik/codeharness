→  it('reports unhealthy stack with remedy', async () => {\n   149→    const state = getDefaultState('nodejs');\n   150→    state.initialized = true;\n   151→    writeState(state, testDir);\n   152→\n   153→    mockGetStackHealth.mockReturnValue({\n   154→      healthy: false,\n   155→      services: [\n   156→        { name: 'victoria-logs', running: true },\n   157→        { name: 'victoria-metrics', running: false },\n   158→        { name: 'victoria-traces', running: true },\n   159→        { name: 'otel-collector', running: false },\n   160→      ],\n   161→      remedy: 'Restart: docker compose -f docker-compose.harness.yml up -d',\n   162→    });\n   163→\n   164→    const { stdout } = await runCli(['status', '--check-docker']);\n   165→    expect(stdout).toContain('[FAIL] VictoriaMetrics stack: not running');\n   166→    expect(stdout).toContain('victoria-metrics: down');\n   167→    expect(stdout).toContain('otel-collector: down');\n   168→    expect(stdout).toContain('Restart: docker compose -f docker-compose.harness.yml up -d');\n   169→  });\n   170→\n   171→  it('uses compose file from state', async () => {\n   172→    const state = getDefaultState('nodejs');\n   173→    state.initialized = true;\n   174→    state.docker = {\n   175→      compose_file: 'custom-compose.yml',\n   176→      stack_running: true,\n   177→      ports: { logs: 9428, metrics: 8428, traces: 14268, otel_grpc: 4317, otel_http: 4318 },\n   178→    };\n   179→    writeState(state, testDir);\n   180→\n   181→    await runCli(['status', '--check-docker']);\n   182→    expect(mockGetStackHealth).toHaveBeenCalledWith('custom-compose.yml', undefined);\n   183→  });\n   184→\n   185→  it('falls back to default compose file when no state', async () => {\n   186→    await runCli(['status', '--check-docker']);\n   187→    expect(mockGetStackHealth).toHaveBeenCalledWith('docker-compose.harness.yml', undefined);\n   188→  });\n   189→\n   190→  it('JSON output for healthy stack', async () => {