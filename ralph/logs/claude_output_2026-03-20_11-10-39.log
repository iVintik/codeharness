{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GYSwNG5vQxyZrXKgios1Ga","type":"tool_result","content":"     1→/**\n     2→ * Ink UI components for the terminal activity display.\n     3→ *\n     4→ * Each component renders one visual element of the Claude activity dashboard.\n     5→ * These are consumed by the root <App> component in ink-renderer.tsx.\n     6→ */\n     7→\n     8→import React from 'react';\n     9→import { Text, Box } from 'ink';\n    10→import { Spinner } from '@inkjs/ui';\n    11→\n    12→// --- Types ---\n    13→\n    14→export interface SprintInfo {\n    15→  storyKey: string;\n    16→  phase: string;\n    17→  done: number;\n    18→  total: number;\n    19→  elapsed?: string; // formatted elapsed time, e.g. \"47m\" or \"2h14m\"\n    20→}\n    21→\n    22→export interface CompletedToolEntry {\n    23→  name: string;\n    24→  args: string;\n    25→}\n    26→\n    27→export type StoryStatusValue = 'done' | 'in-progress' | 'pending' | 'failed' | 'blocked';\n    28→\n    29→export interface StoryStatusEntry {\n    30→  key: string;\n    31→  status: StoryStatusValue;\n    32→}\n    33→\n    34→export interface RetryInfo {\n    35→  attempt: number;\n    36→  delay: number;\n    37→}\n    38→\n    39→export interface StoryMessage {\n    40→  type: 'ok' | 'warn' | 'fail';\n    41→  key: string;\n    42→  message: string;\n    43→  details?: string[];\n    44→}\n    45→\n    46→export interface RendererState {\n    47→  sprintInfo: SprintInfo | null;\n    48→  stories: StoryStatusEntry[];\n    49→  messages: StoryMessage[];\n    50→  completedTools: CompletedToolEntry[];\n    51→  activeTool: { name: string } | null;\n    52→  activeToolArgs: string;\n    53→  lastThought: string | null;\n    54→  retryInfo: RetryInfo | null;\n    55→}\n    56→\n    57→// --- Components ---\n    58→\n    59→export function Header({ info }: { info: SprintInfo | null }) {\n    60→  if (!info) return null;\n    61→  return (\n    62→    <Text>\n    63→      {'◆ '}\n    64→      {info.storyKey}\n    65→      {' — '}\n    66→      {info.phase}\n    67→      {info.elapsed ? ` | ${info.elapsed}` : ''}\n    68→      {' | Sprint: '}\n    69→      {info.done}\n    70→      {'/'}\n    71→      {info.total}\n    72→    </Text>\n    73→  );\n    74→}\n    75→\n    76→export function CompletedTool({ entry }: { entry: CompletedToolEntry }) {\n    77→  const argsSummary = entry.args.length > 60\n    78→    ? entry.args.slice(0, 60) + '...'\n    79→    : entry.args;\n    80→  return (\n    81→    <Text>\n    82→      {'✓ ['}\n    83→      {entry.name}\n    84→      {'] '}\n    85→      {argsSummary}\n    86→    </Text>\n    87→  );\n    88→}\n    89→\n    90→export function CompletedTools({ tools }: { tools: CompletedToolEntry[] }) {\n    91→  return (\n    92→    <Box flexDirection=\"column\">\n    93→      {tools.map((entry, i) => (\n    94→        <CompletedTool key={i} entry={entry} />\n    95→      ))}\n    96→    </Box>\n    97→  );\n    98→}\n    99→\n   100→export function ActiveTool({ name }: { name: string }) {\n   101→  return (\n   102→    <Box>\n   103→      <Text>{'⚡ ['}{name}{'] '}</Text>\n   104→      <Spinner label=\"\" />\n   105→    </Box>\n   106→  );\n   107→}\n   108→\n   109→export function LastThought({ text }: { text: string }) {\n   110→  const maxWidth = (process.stdout.columns || 80) - 4;\n   111→  const truncated = truncateToWidth(text, maxWidth);\n   112→  return (\n   113→    <Text>\n   114→      {'💭 '}\n   115→      {truncated}\n   116→    </Text>\n   117→  );\n   118→}\n   119→\n   120→/**\n   121→ * Truncate a string to fit within a given terminal column width.\n   122→ * Iterates by codepoint (not UTF-16 index) to avoid splitting surrogate pairs.\n   123→ * Treats characters outside the Basic Latin range as 2 columns wide (CJK, emoji).\n   124→ */\n   125→function truncateToWidth(text: string, maxWidth: number): string {\n   126→  let width = 0;\n   127→  let result = '';\n   128→  for (const char of text) {\n   129→    const cp = char.codePointAt(0)!;\n   130→    // Rough heuristic: ASCII printable = 1 col, everything else = 2 cols\n   131→    const charWidth = cp <= 0x7e ? 1 : 2;\n   132→    if (width + charWidth > maxWidth) {\n   133→      return result;\n   134→    }\n   135→    width += charWidth;\n   136→    result += char;\n   137→  }\n   138→  return result;\n   139→}\n   140→\n   141→const STATUS_SYMBOLS: Record<StoryStatusValue, string> = {\n   142→  'done': '✓',\n   143→  'in-progress': '◆',\n   144→  'pending': '○',\n   145→  'failed': '✗',\n   146→  'blocked': '✕',\n   147→};\n   148→\n   149→export function StoryBreakdown({ stories }: { stories: StoryStatusEntry[] }) {\n   150→  if (stories.length === 0) return null;\n   151→\n   152→  const groups: Partial<Record<StoryStatusValue, string[]>> = {};\n   153→  for (const s of stories) {\n   154→    if (!groups[s.status]) groups[s.status] = [];\n   155→    groups[s.status]!.push(s.key);\n   156→  }\n   157→\n   158→  const parts: string[] = [];\n   159→  if (groups['done']?.length) {\n   160→    parts.push(`Done: ${groups['done'].map(k => `${k} ✓`).join('  ')}`);\n   161→  }\n   162→  if (groups['in-progress']?.length) {\n   163→    parts.push(`This: ${groups['in-progress'].map(k => `${k} ◆`).join('  ')}`);\n   164→  }\n   165→  if (groups['pending']?.length) {\n   166→    parts.push(`Next: ${groups['pending'].map(k => `${k} ○`).join('  ')}`);\n   167→  }\n   168→  if (groups['failed']?.length) {\n   169→    parts.push(`Failed: ${groups['failed'].map(k => `${k} ✗`).join('  ')}`);\n   170→  }\n   171→  if (groups['blocked']?.length) {\n   172→    parts.push(`Blocked: ${groups['blocked'].map(k => `${k} ✕`).join('  ')}`);\n   173→  }\n   174→\n   175→  return <Text>{parts.join(' | ')}</Text>;\n   176→}\n   177→\n   178→const MESSAGE_PREFIX: Record<StoryMessage['type'], string> = {\n   179→  ok: '[OK]',\n   180→  warn: '[WARN]',\n   181→  fail: '[FAIL]',\n   182→};\n   183→\n   184→export function StoryMessages({ messages }: { messages: StoryMessage[] }) {\n   185→  if (messages.length === 0) return null;\n   186→  return (\n   187→    <Box flexDirection=\"column\">\n   188→      {messages.map((msg, i) => (\n   189→        <Box key={i} flexDirection=\"column\">\n   190→          <Text>{`${MESSAGE_PREFIX[msg.type]} Story ${msg.key}: ${msg.message}`}</Text>\n   191→          {msg.details?.map((d, j) => (\n   192→            <Text key={j}>{`  └ ${d}`}</Text>\n   193→          ))}\n   194→        </Box>\n   195→      ))}\n   196→    </Box>\n   197→  );\n   198→}\n   199→\n   200→export function RetryNotice({ info }: { info: RetryInfo }) {\n   201→  return (\n   202→    <Text>\n   203→      {'⏳ API retry '}\n   204→      {info.attempt}\n   205→      {' (waiting '}\n   206→      {info.delay}\n   207→      {'ms)'}\n   208→    </Text>\n   209→  );\n   210→}\n   211→\n   212→export function App({\n   213→  state,\n   214→}: {\n   215→  state: RendererState;\n   216→}) {\n   217→  return (\n   218→    <Box flexDirection=\"column\">\n   219→      <Header info={state.sprintInfo} />\n   220→      <StoryBreakdown stories={state.stories} />\n   221→      <StoryMessages messages={state.messages} />\n   222→      <CompletedTools tools={state.completedTools} />\n   223→      {state.activeTool && <ActiveTool name={state.activeTool.name} />}\n   224→      {state.lastThought && <LastThought text={state.lastThought} />}\n   225→      {state.retryInfo && <RetryNotice info={state.retryInfo} />}\n   226→    </Box>\n   227→  );\n   228→}\n   229→"}]},"parent_tool_use_id":"toolu_01MQvEK3vW8nbeASxm6nNmNn","session_id":"1eada203-6dd0-4cf1-909a-4daaca264b98","uuid":"24e87d49-d81a-44ca-8f1c-21f52d435372","timestamp":"2026-03-20T07:12:12.545Z"}
