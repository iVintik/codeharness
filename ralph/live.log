lt.data.metric).toBe('no Dockerfile');\n   566→      expect(result.data.gaps[0].description).toBe('No Dockerfile found');\n   567→    }\n   568→  });\n   569→\n   570→  it('returns pass when validateDockerfile reports no gaps', () => {\n   571→    mockExistsSync.mockReturnValue(true);\n   572→    mockReadFileSync.mockReturnValue('FROM node:22-slim\\nRUN npm install\\n');\n   573→    mockValidateDockerfile.mockReturnValue({\n   574→      success: true,\n   575→      data: { passed: true, gaps: [], warnings: [] },\n   576→    });\n   577→\n   578→    const result = checkInfrastructure('/project');\n   579→    expect(result.success).toBe(true);\n   580→    if (result.success) {\n   581→      expect(result.data.status).toBe('pass');\n   582→      expect(result.data.metric).toBe('Dockerfile valid');\n   583→      expect(result.data.gaps).toHaveLength(0);\n   584→    }\n   585→  });\n   586→\n   587→  it('returns warn when validateDockerfile reports gaps from all 6 categories', () => {\n   588→    mockExistsSync.mockReturnValue(true);\n   589→    mockReadFileSync.mockReturnValue('FROM node:latest\\nCOPY src/ /app/\\n');\n   590→    mockValidateDockerfile.mockReturnValue({\n   591→      success: true,\n   592→      data: {\n   593→        passed: false,\n   594→        gaps: [\n   595→          { rule: 'pinned-from', description: 'unpinned base image -- use specific version.', suggestedFix: 'Pin node:latest' },\n   596→          { rule: 'binary-on-path', description: 'project binary not installed.', suggestedFix: 'Add npm install -g' },\n   597→          { rule: 'verification-tools', description: 'verification tool missing: curl', suggestedFix: 'Install curl' },\n   598→          { rule: 'verification-tools', description: 'verification tool missing: jq', suggestedFix: 'Install jq' },\n   599→          { rule: 'no-source-copy', description: 'source code copied into container -- use build artifact instead.', suggestedFix: 'Use COPY dist/' },\n   600→          { rule: 'non-root-user', description: 'no non-root USER instruction found.', suggestedFix: 'Add USER node' },\n   601→          { rule: 'cache-cleanup', description: 'no cache cleanup detected.', suggestedFix: 'Add rm -rf /var/lib/apt/lists/*' },\n   602→        ],\n   603→        warnings: [],\n   604→      },\n   605→    });\n   606→\n   607→    const result = checkInfrastructure('/project');\n   608→    expect(result.success).toBe(true);\n   609→    if (result.success) {\n   610→      expect(result.data.status).toBe('warn');\n   611→      expect(result.data.gaps).toHaveLength(7);\n   612→      // All gaps should have dimension 'infrastructure'\n   613→      expect(result.data.gaps.every(g => g.dimension === 'infrastructure')).toBe(true);\n   614→    }\n   615→  });\n   616→\n   617→  it('returns fail when Dockerfile has no FROM', () => {\n   618→    mockExistsSync.mockReturnValue(true);\n   619→    mockReadFileSync.mockReturnValue('RUN npm install\\n');\n   620→\n   621→    const result = checkInfrastructure('/project');\n   622→    expect(result.success).toBe(true);\n   623→    if (result.success) {\n   624→      expect(result.data.status).toBe('fail');\n   625→      expect(result.data.metric).toBe('invalid Dockerfile');\n   626→    }\n   627→  });\n   628→\n   629→  it('returns warn when Dockerfile is unreadable', () => {\n   630→    mockExistsSync.mockReturnValue(true);\n   631→    mockReadFileSync.mockImplementation(() => {\n   632→      throw new Error('Permission denied');\n   633→    });\n   634→\n   635→    const result = checkInfrastructure('/project');\n   636→    expect(result.success).toBe(true);\n   637→    if (result.success) {\n   638→      expect(result.data.status).toBe('warn');\n   639→      expect(result.data.metric).toBe('Dockerfile unreadable');\n   640→      expect(result.data.gaps[0].description).toContain('could not be read');\n   641→    }\n   642→  });\n   643→\n   644→  it('returns warn when checkInfrastructure outer catch fires', () => {\n   645→    