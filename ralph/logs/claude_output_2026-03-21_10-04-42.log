{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HtbP5mPBVm4iL6r4suJJ3x","type":"tool_result","content":"     1→/**\n     2→ * Review module orchestrator — invokes BMAD code-review workflow via child_process.\n     3→ * Returns Result<ReviewResult>, never throws.\n     4→ */\n     5→\n     6→import { execFileSync } from 'node:child_process';\n     7→import { ok, fail } from '../../types/result.js';\n     8→import type { Result } from '../../types/result.js';\n     9→import type { ReviewResult } from './types.js';\n    10→\n    11→/** Default timeout: 25 minutes */\n    12→const DEFAULT_TIMEOUT_MS = 1_500_000;\n    13→\n    14→/** Max lines of output to keep */\n    15→const MAX_OUTPUT_LINES = 200;\n    16→\n    17→/**\n    18→ * Truncate output to the last N lines.\n    19→ */\n    20→function truncateOutput(output: string, maxLines: number): string {\n    21→  const lines = output.split('\\n');\n    22→  if (lines.length <= maxLines) {\n    23→    return output;\n    24→  }\n    25→  return lines.slice(-maxLines).join('\\n');\n    26→}\n    27→\n    28→/**\n    29→ * Determine if an error is a timeout error from child_process.\n    30→ * The `killed` flag is set by Node.js when it kills the process due to timeout.\n    31→ * We also accept SIGTERM as a timeout indicator since execFileSync uses it\n    32→ * as the default kill signal when the timeout expires.\n    33→ */\n    34→function isTimeoutError(err: unknown): boolean {\n    35→  if (typeof err !== 'object' || err === null) return false;\n    36→  const e = err as Record<string, unknown>;\n    37→  // `killed` is the most reliable indicator — Node.js sets it when it\n    38→  // terminates the child due to timeout. SIGTERM alone could come from\n    39→  // other sources but is still treated as timeout for child_process calls\n    40→  // since Node.js uses SIGTERM as the default timeout kill signal.\n    41→  return e['killed'] === true || e['signal'] === 'SIGTERM';\n    42→}\n    43→\n    44→/**\n    45→ * Parse review output to determine approval status and extract comments.\n    46→ * Looks for rejection/change-request signals in the output.\n    47→ */\n    48→function parseReviewOutput(output: string): { approved: boolean; comments: string[] } {\n    49→  const comments: string[] = [];\n    50→  const lower = output.toLowerCase();\n    51→\n    52→  // Look for explicit rejection signals\n    53→  const rejected =\n    54→    lower.includes('changes requested') ||\n    55→    lower.includes('changes required') ||\n    56→    lower.includes('not approved') ||\n    57→    lower.includes('review: reject') ||\n    58→    lower.includes('status: rejected') ||\n    59→    lower.includes('needs changes') ||\n    60→    lower.includes('request changes');\n    61→\n    62→  // Extract comment lines (lines starting with - or * that look like findings)\n    63→  const lines = output.split('\\n');\n    64→  for (const line of lines) {\n    65→    const trimmed = line.trim();\n    66→    if (\n    67→      (trimmed.startsWith('- ') || trimmed.startsWith('* ')) &&\n    68→      trimmed.length > 10\n    69→    ) {\n    70→      comments.push(trimmed);\n    71→    }\n    72→  }\n    73→\n    74→  // Rejection signals take priority over approval signals.\n    75→  // If no signals at all, default to approved (no findings = pass).\n    76→  const isApproved = !rejected;\n    77→\n    78→  return { approved: isApproved, comments };\n    79→}\n    80→\n    81→/**\n    82→ * Invoke the BMAD code-review workflow for a given story key.\n    83→ * Uses child_process.execFileSync with a configurable timeout.\n    84→ * Returns Result<ReviewResult> — never throws.\n    85→ */\n    86→export function invokeBmadCodeReview(\n    87→  key: string,\n    88→  opts?: { timeoutMs?: number },\n    89→): Result<ReviewResult> {\n    90→  const timeoutMs = opts?.timeoutMs ?? DEFAULT_TIMEOUT_MS;\n    91→  const startTime = Date.now();\n    92→\n    93→  try {\n    94→    const stdout = execFileSync(\n    95→      'claude',\n    96→      [\n    97→        '--print',\n    98→        `Run the BMAD code-review workflow for story at _bmad-output/implementation-artifacts/${key}.md — review all changes, check quality, and provide findings.`,\n    99→      ],\n   100→      {\n   101→        timeout: timeoutMs,\n   102→        encoding: 'utf-8',\n   103→        stdio: ['pipe', 'pipe', 'pipe'],\n   104→        maxBuffer: 50 * 1024 * 1024,\n   105→      },\n   106→    );\n   107→\n   108→    const duration = Date.now() - startTime;\n   109→    const output = truncateOutput(stdout, MAX_OUTPUT_LINES);\n   110→    const { approved, comments } = parseReviewOutput(output);\n   111→\n   112→    return ok({\n   113→      key,\n   114→      approved,\n   115→      comments,\n   116→      duration,\n   117→      output,\n   118→    });\n   119→  } catch (err: unknown) {\n   120→    const duration = Date.now() - startTime;\n   121→\n   122→    if (isTimeoutError(err)) {\n   123→      const errObj = err as Record<string, unknown>;\n   124→      const stderr = typeof errObj['stderr'] === 'string' ? errObj['stderr'] : '';\n   125→      const stdout = typeof errObj['stdout'] === 'string' ? errObj['stdout'] : '';\n   126→      const combinedOutput = truncateOutput(\n   127→        (stdout + '\\n' + stderr).trim(),\n   128→        MAX_OUTPUT_LINES,\n   129→      );\n   130→\n   131→      return fail(\n   132→        `timeout: review workflow exceeded ${Math.round(timeoutMs / 1000)}s for story ${key} (ran ${Math.round(duration / 1000)}s)`,\n   133→        {\n   134→          key,\n   135→          approved: false,\n   136→          comments: [],\n   137→          duration,\n   138→          output: combinedOutput,\n   139→        },\n   140→      );\n   141→    }\n   142→\n   143→    const errObj = err as Record<string, unknown>;\n   144→    const exitCode = typeof errObj['status'] === 'number' ? errObj['status'] : null;\n   145→    const stderr = typeof errObj['stderr'] === 'string' ? errObj['stderr'] : '';\n   146→    const stdout = typeof errObj['stdout'] === 'string' ? errObj['stdout'] : '';\n   147→    const msg = err instanceof Error ? err.message : String(err);\n   148→    const combinedOutput = truncateOutput(\n   149→      (stdout + '\\n' + stderr).trim(),\n   150→      MAX_OUTPUT_LINES,\n   151→    );\n   152→\n   153→    const errorMsg = exitCode !== null\n   154→      ? `review workflow failed with exit code ${exitCode} for story ${key}: ${msg}`\n   155→      : `review workflow failed for story ${key}: ${msg}`;\n   156→\n   157→    return fail(errorMsg, {\n   158→      key,\n   159→      approved: false,\n   160→      comments: [],\n   161→      duration,\n   162→      output: combinedOutput,\n   163→    });\n   164→  }\n   165→}\n   166→"}]},"parent_tool_use_id":"toolu_01SYFmth4jmfGkWhMfu7ffMP","session_id":"7be24b04-34e1-424a-85e4-e656cce56dfe","uuid":"4a86f183-3863-4eb5-afaf-ef35adcddacb","timestamp":"2026-03-21T06:13:02.843Z"}
