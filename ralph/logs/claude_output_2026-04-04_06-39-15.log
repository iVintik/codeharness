{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015kdpXuidS4e2r5XgwnSdDR","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { render } from 'ink-testing-library';\n3\timport React from 'react';\n4\timport { App } from '../ink-app.js';\n5\timport type { RendererState } from '../ink-components.js';\n6\timport type { LaneData } from '../ink-lane-container.js';\n7\timport type { SummaryBarProps } from '../ink-summary-bar.js';\n8\timport type { MergeState } from '../ink-merge-status.js';\n9\t\n10\tfunction makeState(overrides?: Partial<RendererState>): RendererState {\n11\t  return {\n12\t    sprintInfo: null,\n13\t    stories: [],\n14\t    messages: [],\n15\t    completedTools: [],\n16\t    activeTool: null,\n17\t    activeToolArgs: '',\n18\t    lastThought: null,\n19\t    retryInfo: null,\n20\t    workflowFlow: [],\n21\t    currentTaskName: null,\n22\t    taskStates: {},\n23\t    taskMeta: {},\n24\t    activeDriverName: null,\n25\t    driverCosts: {},\n26\t    ...overrides,\n27\t  };\n28\t}\n29\t\n30\tfunction makeLane(overrides?: Partial<LaneData>): LaneData {\n31\t  return {\n32\t    epicId: '10',\n33\t    epicTitle: 'Driver Interface',\n34\t    currentStory: '10-3',\n35\t    phase: 'dev',\n36\t    acProgress: '4/9',\n37\t    storyProgressEntries: [\n38\t      { key: '10-1', status: 'done' },\n39\t      { key: '10-2', status: 'done' },\n40\t      { key: '10-3', status: 'in-progress' },\n41\t    ],\n42\t    driver: 'claude-code',\n43\t    cost: 4.20,\n44\t    elapsedTime: 1080000,\n45\t    ...overrides,\n46\t  };\n47\t}\n48\t\n49\tdescribe('App component', () => {\n50\t  it('renders without crashing with minimal state', () => {\n51\t    const { lastFrame } = render(<App state={makeState()} />);\n52\t    const frame = lastFrame()!;\n53\t    // Should not crash — empty state renders something\n54\t    expect(frame).toBeDefined();\n55\t  });\n56\t\n57\t  it('renders single-lane layout when no lanes provided', () => {\n58\t    const state = makeState({\n59\t      sprintInfo: {\n60\t        storyKey: '10-3',\n61\t        phase: 'dev',\n62\t        done: 2,\n63\t        total: 5,\n64\t        elapsed: '18m',\n65\t        totalCost: 4.20,\n66\t      },\n67\t    });\n68\t    const { lastFrame } = render(<App state={state} />);\n69\t    const frame = lastFrame()!;\n70\t    // Should show header\n71\t    expect(frame).toContain('codeharness run');\n72\t    expect(frame).toContain('Story: 10-3');\n73\t    // Should NOT show lane count\n74\t    expect(frame).not.toContain('lanes');\n75\t  });\n76\t\n77\t  it('renders single-lane layout when lanes has 1 entry (AC #8 backward compat)', () => {\n78\t    const state = makeState({\n79\t      sprintInfo: {\n80\t        storyKey: '10-3',\n81\t        phase: 'dev',\n82\t        done: 2,\n83\t        total: 5,\n84\t        elapsed: '18m',\n85\t        totalCost: 4.20,\n86\t      },\n87\t      lanes: [makeLane()],\n88\t    });\n89\t    const { lastFrame } = render(<App state={state} />);\n90\t    const frame = lastFrame()!;\n91\t    // AC #8: single lane mode should be visually identical to current single-lane TUI\n92\t    expect(frame).toContain('codeharness run');\n93\t    expect(frame).toContain('Story: 10-3');\n94\t    // Should NOT render LaneContainer (no lane indices visible)\n95\t    expect(frame).not.toContain('Lane 1:');\n96\t    expect(frame).not.toContain('lanes');\n97\t  });\n98\t\n99\t  it('renders LaneContainer when lanes > 1 (AC #10)', () => {\n100\t    const state = makeState({\n101\t      sprintInfo: {\n102\t        storyKey: '10-3',\n103\t        phase: 'dev',\n104\t        done: 2,\n105\t        total: 5,\n106\t        elapsed: '18m',\n107\t        totalCost: 4.20,\n108\t      },\n109\t      lanes: [\n110\t        makeLane({ epicId: '10', epicTitle: 'Driver Interface' }),\n111\t        makeLane({ epicId: '14', epicTitle: 'Workflow Schema', currentStory: '14-1' }),\n112\t      ],\n113\t    });\n114\t    const { lastFrame } = render(<App state={state} />);\n115\t    const frame = lastFrame()!;\n116\t    // AC #10: should render LaneContainer with multiple lanes\n117\t    expect(frame).toContain('Epic 10');\n118\t    expect(frame).toContain('Epic 14');\n119\t    expect(frame).toContain('Lane 1:');\n120\t    expect(frame).toContain('Lane 2:');\n121\t  });\n122\t\n123\t  it('shows lane count in header when multi-lane (AC #11)', () => {\n124\t    const state = makeState({\n125\t      sprintInfo: {\n126\t        storyKey: '10-3',\n127\t        phase: 'dev',\n128\t        done: 2,\n129\t        total: 5,\n130\t        elapsed: '18m',\n131\t        totalCost: 4.20,\n132\t        laneTotalCost: 18.60,\n133\t      },\n134\t      lanes: [\n135\t        makeLane({ epicId: '10' }),\n136\t        makeLane({ epicId: '14' }),\n137\t      ],\n138\t    });\n139\t    const { lastFrame } = render(<App state={state} />);\n140\t    const frame = lastFrame()!;\n141\t    // AC #11: header shows lane count and total cost\n142\t    expect(frame).toContain('2 lanes');\n143\t    expect(frame).toContain('$18.60 spent');\n144\t  });\n145\t\n146\t  it('renders empty lanes array as single-lane layout', () => {\n147\t    const state = makeState({\n148\t      sprintInfo: {\n149\t        storyKey: '10-3',\n150\t        phase: 'dev',\n151\t        done: 2,\n152\t        total: 5,\n153\t      },\n154\t      lanes: [],\n155\t    });\n156\t    const { lastFrame } = render(<App state={state} />);\n157\t    const frame = lastFrame()!;\n158\t    // Empty lanes = single-lane layout\n159\t    expect(frame).toContain('Story: 10-3');\n160\t    expect(frame).not.toContain('Lane 1:');\n161\t  });\n162\t\n163\t  it('renders SummaryBar and MergeStatus when laneCount > 1 (AC #11)', () => {\n164\t    const summaryBar: SummaryBarProps = {\n165\t      doneStories: ['10-1', '10-2'],\n166\t      mergingEpic: { epicId: 'epic-14', status: 'in-progress' },\n167\t      pendingEpics: ['epic-11', 'epic-12'],\n168\t    };\n169\t    const mergeState: MergeState = {\n170\t      epicId: 'epic-14',\n171\t      outcome: 'clean',\n172\t      conflictCount: 0,\n173\t    };\n174\t    const state = makeState({\n175\t      sprintInfo: {\n176\t        storyKey: '10-3',\n177\t        phase: 'dev',\n178\t        done: 2,\n179\t        total: 5,\n180\t      },\n181\t      lanes: [\n182\t        makeLane({ epicId: '10' }),\n183\t        makeLane({ epicId: '14' }),\n184\t      ],\n185\t      summaryBar,\n186\t      mergeState,\n187\t    });\n188\t    const { lastFrame } = render(<App state={state} />);\n189\t    const frame = lastFrame()!;\n190\t    // SummaryBar should be visible\n191\t    expect(frame).toContain('Done:');\n192\t    expect(frame).toContain('10-1');\n193\t    expect(frame).toContain('Merging:');\n194\t    expect(frame).toContain('epic-14');\n195\t    expect(frame).toContain('Pending:');\n196\t    // MergeStatus should be visible\n197\t    expect(frame).toContain('[OK] Merge epic-14');\n198\t  });\n199\t\n200\t  it('does NOT render SummaryBar or MergeStatus when laneCount <= 1 (AC #12)', () => {\n201\t    const summaryBar: SummaryBarProps = {\n202\t      doneStories: ['10-1'],\n203\t      mergingEpic: null,\n204\t      pendingEpics: [],\n205\t    };\n206\t    const mergeState: MergeState = {\n207\t      epicId: 'epic-14',\n208\t      outcome: 'clean',\n209\t      conflictCount: 0,\n210\t    };\n211\t    const state = makeState({\n212\t      sprintInfo: {\n213\t        storyKey: '10-3',\n214\t        phase: 'dev',\n215\t        done: 2,\n216\t        total: 5,\n217\t      },\n218\t      lanes: [makeLane()],\n219\t      summaryBar,\n220\t      mergeState,\n221\t    });\n222\t    const { lastFrame } = render(<App state={state} />);\n223\t    const frame = lastFrame()!;\n224\t    // Single-lane mode: SummaryBar and MergeStatus should NOT render\n225\t    expect(frame).not.toContain('[OK] Merge');\n226\t    // The summary bar \"Done:\" with checkmarks should not appear\n227\t    // (StoryBreakdown may use \"Done:\" in single-lane mode, but not the SummaryBar format)\n228\t    expect(frame).not.toContain('Pending:');\n229\t  });\n230\t\n231\t  it('does NOT render SummaryBar or MergeStatus with no lanes (AC #12)', () => {\n232\t    const state = makeState({\n233\t      sprintInfo: {\n234\t        storyKey: '10-3',\n235\t        phase: 'dev',\n236\t        done: 2,\n237\t        total: 5,\n238\t      },\n239\t      summaryBar: {\n240\t        doneStories: ['10-1'],\n241\t        mergingEpic: null,\n242\t        pendingEpics: ['epic-12'],\n243\t      },\n244\t      mergeState: {\n245\t        epicId: 'epic-14',\n246\t        outcome: 'clean',\n247\t        conflictCount: 0,\n248\t      },\n249\t    });\n250\t    const { lastFrame } = render(<App state={state} />);\n251\t    const frame = lastFrame()!;\n252\t    expect(frame).not.toContain('[OK] Merge');\n253\t    expect(frame).not.toContain('Pending:');\n254\t  });\n255\t\n256\t  it('renders SummaryBar without MergeStatus when mergeState is absent', () => {\n257\t    const state = makeState({\n258\t      sprintInfo: {\n259\t        storyKey: '10-3',\n260\t        phase: 'dev',\n261\t        done: 2,\n262\t        total: 5,\n263\t      },\n264\t      lanes: [\n265\t        makeLane({ epicId: '10' }),\n266\t        makeLane({ epicId: '14' }),\n267\t      ],\n268\t      summaryBar: {\n269\t        doneStories: ['10-1'],\n270\t        mergingEpic: null,\n271\t        pendingEpics: ['epic-12'],\n272\t      },\n273\t    });\n274\t    const { lastFrame } = render(<App state={state} />);\n275\t    const frame = lastFrame()!;\n276\t    expect(frame).toContain('Done:');\n277\t    expect(frame).toContain('Pending:');\n278\t    expect(frame).not.toContain('[OK] Merge');\n279\t  });\n280\t});\n281\t"}]},"parent_tool_use_id":"toolu_01TzQwpEV7uekTzzh7pB5DWd","session_id":"7e3ded59-6184-4f8b-8f55-ba5e63dae51f","uuid":"9b1022c8-d6de-4ed5-b837-7ff4f6c556e7","timestamp":"2026-04-04T02:49:40.805Z"}
