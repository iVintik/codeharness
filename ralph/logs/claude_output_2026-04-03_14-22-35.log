{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019JZrpawXL7ZwSeuMMdpKR2","type":"tool_result","content":"1\t/**\n2\t * Output contract serialization and deserialization.\n3\t *\n4\t * Provides atomic write/read for OutputContract JSON files.\n5\t * Written atomically: first to a .tmp file, then renamed to final path.\n6\t * See architecture-multi-framework.md Decision 3.\n7\t */\n8\t\n9\timport { writeFileSync, readFileSync, renameSync, mkdirSync, existsSync } from 'node:fs';\n10\timport { join, resolve } from 'node:path';\n11\timport type { OutputContract } from './types.js';\n12\t\n13\t/**\n14\t * Validate that a string is a safe filename component (no path separators, not empty).\n15\t */\n16\tfunction assertSafeComponent(value: string, label: string): void {\n17\t  if (!value || value.trim().length === 0) {\n18\t    throw new Error(`${label} must be a non-empty string`);\n19\t  }\n20\t  if (value.includes('/') || value.includes('\\\\') || value.includes('..')) {\n21\t    throw new Error(`${label} contains invalid path characters: ${value}`);\n22\t  }\n23\t}\n24\t\n25\t/**\n26\t * Compute the file path for a contract.\n27\t * Validates that taskName and storyId are safe filename components.\n28\t */\n29\tfunction contractFilePath(taskName: string, storyId: string, contractDir: string): string {\n30\t  assertSafeComponent(taskName, 'taskName');\n31\t  assertSafeComponent(storyId, 'storyId');\n32\t  const filePath = join(contractDir, `${taskName}-${storyId}.json`);\n33\t  // Ensure the resolved path is inside the contract directory\n34\t  const resolvedDir = resolve(contractDir);\n35\t  const resolvedFile = resolve(filePath);\n36\t  if (!resolvedFile.startsWith(resolvedDir)) {\n37\t    throw new Error(`Path traversal detected: ${filePath} escapes ${contractDir}`);\n38\t  }\n39\t  return filePath;\n40\t}\n41\t\n42\t/**\n43\t * Write an OutputContract to disk atomically.\n44\t *\n45\t * Creates the target directory if it does not exist.\n46\t * Writes to a .tmp file first, then renames to the final path.\n47\t * On failure, throws an error with a descriptive message including the file path.\n48\t */\n49\texport function writeOutputContract(contract: OutputContract, contractDir: string): void {\n50\t  const finalPath = contractFilePath(contract.taskName, contract.storyId, contractDir);\n51\t  const tmpPath = finalPath + '.tmp';\n52\t\n53\t  try {\n54\t    mkdirSync(contractDir, { recursive: true });\n55\t    writeFileSync(tmpPath, JSON.stringify(contract, null, 2) + '\\n', 'utf-8');\n56\t    renameSync(tmpPath, finalPath);\n57\t  } catch (err) {\n58\t    const message = err instanceof Error ? err.message : String(err);\n59\t    throw new Error(`Failed to write output contract to ${finalPath}: ${message}`, { cause: err });\n60\t  }\n61\t}\n62\t\n63\t/**\n64\t * Read an OutputContract from disk.\n65\t *\n66\t * Returns null if the file does not exist.\n67\t */\n68\texport function readOutputContract(\n69\t  taskName: string,\n70\t  storyId: string,\n71\t  contractDir: string,\n72\t): OutputContract | null {\n73\t  const filePath = contractFilePath(taskName, storyId, contractDir);\n74\t\n75\t  if (!existsSync(filePath)) {\n76\t    return null;\n77\t  }\n78\t\n79\t  try {\n80\t    const raw = readFileSync(filePath, 'utf-8');\n81\t    return JSON.parse(raw) as OutputContract;\n82\t  } catch (err) {\n83\t    const message = err instanceof Error ? err.message : String(err);\n84\t    throw new Error(`Failed to read output contract from ${filePath}: ${message}`, { cause: err });\n85\t  }\n86\t}\n87\t\n88\t/** Maximum characters for the output summary before truncation. */\n89\tconst OUTPUT_TRUNCATE_LIMIT = 2000;\n90\t\n91\t/**\n92\t * Format an OutputContract as a structured text block suitable for injection\n93\t * into a subsequent task's prompt. Provides cross-framework context: changed\n94\t * files, test results, output summary, and acceptance criteria statuses.\n95\t *\n96\t * The `output` field is truncated to 2000 characters to avoid prompt bloat.\n97\t */\n98\texport function formatContractAsPromptContext(contract: OutputContract): string {\n99\t  const sections: string[] = [];\n100\t\n101\t  // Header: task metadata\n102\t  const costStr = contract.cost_usd != null ? `$${contract.cost_usd.toFixed(2)}` : 'N/A';\n103\t  const durationStr = `${(contract.duration_ms / 1000).toFixed(1)}s`;\n104\t  sections.push(\n105\t    `### Context from Previous Task\\n` +\n106\t    `- **Task:** ${contract.taskName}\\n` +\n107\t    `- **Driver:** ${contract.driver}\\n` +\n108\t    `- **Model:** ${contract.model}\\n` +\n109\t    `- **Cost:** ${costStr}\\n` +\n110\t    `- **Duration:** ${durationStr}\\n` +\n111\t    `- **Timestamp:** ${contract.timestamp}`,\n112\t  );\n113\t\n114\t  // Changed Files\n115\t  if (contract.changedFiles.length > 0) {\n116\t    const fileList = contract.changedFiles.map((f) => `- ${f}`).join('\\n');\n117\t    sections.push(`### Changed Files\\n${fileList}`);\n118\t  } else {\n119\t    sections.push(`### Changed Files\\nNone`);\n120\t  }\n121\t\n122\t  // Test Results\n123\t  if (contract.testResults) {\n124\t    const tr = contract.testResults;\n125\t    const coverageStr = tr.coverage != null ? `${tr.coverage}%` : 'N/A';\n126\t    sections.push(\n127\t      `### Test Results\\n` +\n128\t      `- **Passed:** ${tr.passed}\\n` +\n129\t      `- **Failed:** ${tr.failed}\\n` +\n130\t      `- **Coverage:** ${coverageStr}`,\n131\t    );\n132\t  } else {\n133\t    sections.push(`### Test Results\\nNo test results available`);\n134\t  }\n135\t\n136\t  // Output Summary (truncated)\n137\t  let outputText = contract.output;\n138\t  if (outputText.length > OUTPUT_TRUNCATE_LIMIT) {\n139\t    outputText = outputText.slice(0, OUTPUT_TRUNCATE_LIMIT) + ' [truncated]';\n140\t  }\n141\t  if (outputText.length > 0) {\n142\t    sections.push(`### Output Summary\\n${outputText}`);\n143\t  } else {\n144\t    sections.push(`### Output Summary\\nNone`);\n145\t  }\n146\t\n147\t  // Acceptance Criteria\n148\t  if (contract.acceptanceCriteria.length > 0) {\n149\t    const acList = contract.acceptanceCriteria\n150\t      .map((ac) => `- **${ac.id}** (${ac.status}): ${ac.description}`)\n151\t      .join('\\n');\n152\t    sections.push(`### Acceptance Criteria\\n${acList}`);\n153\t  } else {\n154\t    sections.push(`### Acceptance Criteria\\nNone`);\n155\t  }\n156\t\n157\t  return sections.join('\\n\\n');\n158\t}\n159\t\n160\t/**\n161\t * Build a prompt with optional contract context appended.\n162\t *\n163\t * If `previousContract` is null (first task in workflow), returns `basePrompt`\n164\t * unchanged. Otherwise, appends a formatted contract context block separated\n165\t * by a clear delimiter.\n166\t */\n167\texport function buildPromptWithContractContext(\n168\t  basePrompt: string,\n169\t  previousContract: OutputContract | null,\n170\t): string {\n171\t  if (!previousContract) {\n172\t    return basePrompt;\n173\t  }\n174\t\n175\t  const context = formatContractAsPromptContext(previousContract);\n176\t  return `${basePrompt}\\n\\n---\\n\\n## Previous Task Context\\n\\n${context}`;\n177\t}\n178\t"}]},"parent_tool_use_id":"toolu_01C5MehsTfY23j2CBRX28n4h","session_id":"8f19e005-5742-4a5a-a61f-d8a88dc16bec","uuid":"1dfd9db3-0419-44e7-985a-41fae5afdda1","timestamp":"2026-04-03T10:31:59.184Z"}
