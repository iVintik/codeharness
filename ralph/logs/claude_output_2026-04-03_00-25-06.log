{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NEmrwQHY4NghRk9XxWKFQf","type":"tool_result","content":"1\timport type { WorkflowState } from './workflow-state.js';\n2\t\n3\t// --- Functions ---\n4\t\n5\t/**\n6\t * Sanitize a string segment for use in a trace ID.\n7\t *\n8\t * Replaces non-alphanumeric characters (except hyphens) with hyphens,\n9\t * collapses consecutive hyphens, and trims leading/trailing hyphens.\n10\t */\n11\texport function sanitizeSegment(segment: string): string {\n12\t  return segment\n13\t    .replace(/[^a-zA-Z0-9-]/g, '-')\n14\t    .replace(/-{2,}/g, '-')\n15\t    .replace(/^-+|-+$/g, '');\n16\t}\n17\t\n18\t/**\n19\t * Generate a trace ID for a workflow iteration.\n20\t *\n21\t * Format: `ch-{runId}-{iteration}-{taskName}`\n22\t *\n23\t * The `runId` and `taskName` segments are sanitized to be safe for logs,\n24\t * metrics labels, HTTP headers, and YAML serialization.\n25\t */\n26\texport function generateTraceId(\n27\t  runId: string,\n28\t  iteration: number,\n29\t  taskName: string,\n30\t): string {\n31\t  const safeRunId = sanitizeSegment(runId);\n32\t  const safeTask = sanitizeSegment(taskName);\n33\t  return `ch-${safeRunId}-${iteration}-${safeTask}`;\n34\t}\n35\t\n36\t/**\n37\t * Format a trace ID as a system prompt fragment for agent injection.\n38\t *\n39\t * Returns a structured block that an agent can include in log/metric/trace output.\n40\t */\n41\texport function formatTracePrompt(traceId: string): string {\n42\t  return `[TRACE] trace_id=${traceId}\\nInclude this trace ID in all log output, metric labels, and trace spans for correlation.`;\n43\t}\n44\t\n45\t/**\n46\t * Record a trace ID in workflow state.\n47\t *\n48\t * Returns a **new** WorkflowState with the trace ID appended to `trace_ids`.\n49\t * Does not mutate the input state.\n50\t *\n51\t * Throws if `traceId` is empty.\n52\t */\n53\texport function recordTraceId(\n54\t  traceId: string,\n55\t  state: WorkflowState,\n56\t): WorkflowState {\n57\t  if (!traceId) {\n58\t    throw new Error('recordTraceId: traceId must be a non-empty string');\n59\t  }\n60\t\n61\t  return {\n62\t    ...state,\n63\t    trace_ids: [...(state.trace_ids ?? []), traceId],\n64\t  };\n65\t}\n66\t"}]},"parent_tool_use_id":"toolu_013s1entuytEnEY9hTFUsekN","session_id":"a1f3179e-0b63-4a22-aa4b-b755c26a5a4c","uuid":"d51aa8b2-6485-4295-bde3-95fe65aa3068","timestamp":"2026-04-02T20:46:32.836Z"}
