rkflow: {\n850\t        tasks: { implement: makeTask() },\n851\t        flow: ['implement'],\n852\t      },\n853\t    });\n854\t\n855\t    const result = await executeWorkflow(config);\n856\t\n857\t    expect(result.success).toBe(false);\n858\t    // Should halt after first error — only one dispatch attempted\n859\t    expect(mockDriverDispatch).toHaveBeenCalledTimes(1);\n860\t    expect(result.errors).toHaveLength(1);\n861\t  });\n862\t\n863\t  it('continues on UNKNOWN errors for per-story tasks (AC #13)', async () => {\n864\t    const { DispatchError } = await import('../agent-dispatch.js');\n865\t    let callCount = 0;\n866\t    mockDriverDispatch.mockImplementation(() => {\n867\t      callCount++;\n868\t      if (callCount === 1) {\n869\t        return makeDriverStreamError(new DispatchError('unknown error', 'UNKNOWN', 'dev', new Error('inner')));\n870\t      }\n871\t      return makeDriverStream('ok', 'sess-1');\n872\t    });\n873\t\n874\t    mockParse.mockReturnValue({\n875\t      development_status: {\n876\t        '3-1-foo': 'ready-for-dev',\n877\t        '3-2-bar': 'backlog',\n878\t      },\n879\t    });\n880\t\n881\t    const config = makeConfig({\n882\t      workflow: {\n883\t        tasks: { implement: makeTask() },\n884\t        flow: ['implement'],\n885\t      },\n886\t    });\n887\t\n888\t    const result = await executeWorkflow(config);\n889\t\n890\t    // Both stories attempted\n891\t    expect(mockDriverDispatch).toHaveBeenCalledTimes(2);\n892\t    expect(result.errors).toHaveLength(1);\n893\t    expect(result.tasksCompleted).toBe(1);\n894\t  });\n895\t\n896\t  it('sets phase to error on dispatch failure', async () => {\n897\t    const { DispatchError } = await import('../agent-dispatch.js');\n898\t    mockDriverDispatch.mockImplementation(() => makeDriverStreamError(\n899\t      new DispatchError('fail', 'UNKNOWN', 'dev', new Error('inner')),\n900\t    ));\n901\t\n902\t    mockParse.mockReturnValue({\n903\t      development_status: { '3-1-foo': 'ready-for-dev' },\n904\t    });\n905\t\n906\t    const config = makeConfig({\n907\t      workflow: {\n908\t        tasks: { implement: makeTask() },\n909\t        flow: ['implement'],\n910\t      },\n911\t    });\n912\t\n913\t    await executeWorkflow(config);\n914\t\n915\t    // Find the write call that sets phase to \"error\"\n916\t    const errorWrite = mockWriteWorkflowState.mock.calls.find(\n917\t      (call: unknown[]) => (call[0] as WorkflowState).phase === 'error',\n918\t    );\n919\t    expect(errorWrite).toBeDefined();\n920\t  });\n921\t\n922\t  it('sets phase to completed when no errors occur', async () => {\n923\t    mockParse.mockReturnValue({\n924\t      development_status: { '3-1-foo': 'ready-for-dev' },\n925\t    });\n926\t\n927\t    const config = makeConfig({\n928\t      workflow: {\n929\t        tasks: { implement: makeTask() },\n930\t        flow: ['implement'],\n931\t      },\n932\t    });\n933\t\n934\t    await executeWorkflow(config);\n935\t\n936\t    const lastWrite = mockWriteWorkflowState.mock.calls[\n937\t      mockWriteWorkflowState.mock.calls.length - 1\n938\t    ];\n939\t    expect((lastWrite[0] as WorkflowState).phase).toBe('completed');\n940\t  });\n941\t\n942\t  it('initializes workflow state with phase=executing at start', async () => {\n943\t    mockParse.mockReturnValue({\n944\t      development_status: { '3-1-foo': 'ready-for-dev' },\n945\t    });\n946\t\n947\t    const config = makeConfig({\n948\t      workflow: {\n949\t        tasks: { implement: makeTask() },\n950\t        flow: ['implement'],\n951\t      },\n952\t    });\n953\t\n954\t    await executeWorkflow(config);\n955\t\n956\t    const firstWrite = mockWriteWorkflowState.mock.calls[0];\n957\t    expect((firstWrite[0] as WorkflowState).phase).toBe('executing');\n958\t  });\n959\t\n960\t  it('invokes source isolation for per-run task with source_access false', async () => {\n961\t    const mockWorkspace = {\n962\t      dir: '/tmp/test',\n963\t      storyFilesDir: '/tmp/test