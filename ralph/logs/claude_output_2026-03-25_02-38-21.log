Instance._getChildOnHandlers()['close'](0);\n   857→      await p;\n   858→\n   859→      expect(rendererUpdateMock).toHaveBeenCalledWith(resultEvent);\n   860→    });\n   861→  });\n   862→\n   863→  describe('--quiet mode', () => {\n   864→    it('passes quiet: true to startRenderer and config', async () => {\n   865→      // For quiet mode, mock spawn to return null stdout/stderr\n   866→      const quietHandlers: Record<string, (...args: unknown[]) => void> = {};\n   867→      mockDriverInstance.spawn.mockImplementationOnce(() => ({\n   868→        on: vi.fn((event: string, handler: (...args: unknown[]) => void) => {\n   869→          quietHandlers[event] = handler;\n   870→        }),\n   871→        kill: vi.fn(),\n   872→        stdout: null,\n   873→        stderr: null,\n   874→      }));\n   875→\n   876→      vi.spyOn(process, 'cwd').mockReturnValue(tmpDir);\n   877→      mockPaths({ '.claude': true });\n   878→      readSprintStatusMock.mockReturnValue({ '1-1-story': 'backlog' });\n   879→      vi.spyOn(console, 'log').mockImplementation(() => {});\n   880→\n   881→      const p = runCommand(['--quiet']);\n   882→      await vi.waitFor(() => expect(mockDriverInstance.spawn).toHaveBeenCalled());\n   883→\n   884→      expect(startRendererMock).toHaveBeenCalledWith({ quiet: true });\n   885→      expect(getDriverMock).toHaveBeenCalledWith('ralph', expect.objectContaining({\n   886→        quiet: true,\n   887→      }));\n   888→\n   889→      quietHandlers['close'](0);\n   890→      await p;\n   891→\n   892→      expect(rendererUpdateMock).not.toHaveBeenCalled();\n   893→    });\n   894→  });\n   895→\n   896→  describe('source code verification', () => {\n   897→    it('run.ts does not import spawn from node:child_process', () => {\n   898→      const runSource = origReadFileSync(\n   899→        join(process.cwd(), 'src', 'commands', 'run.ts'),\n   900→        'utf-8',\n   901→      );\n   902→      expect(runSource).not.toContain(\"from 'node:child_pro