{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EYyFnqwDnB9JRAzrLH4BGR","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n2\timport { Command } from 'commander';\n3\timport { readFileSync } from 'node:fs';\n4\t\n5\t// ─── Mocks ───────────────────────────────────────────────────────────────────\n6\t\n7\tconst mockCreateValidationSprint = vi.fn();\n8\tconst mockRunValidationCycle = vi.fn();\n9\tconst mockGetValidationProgress = vi.fn();\n10\tconst mockGetACById = vi.fn();\n11\t\n12\tvi.mock('../../modules/verify/index.js', () => ({\n13\t  createValidationSprint: (...args: unknown[]) => mockCreateValidationSprint(...args),\n14\t  runValidationCycle: (...args: unknown[]) => mockRunValidationCycle(...args),\n15\t  getValidationProgress: (...args: unknown[]) => mockGetValidationProgress(...args),\n16\t  getACById: (...args: unknown[]) => mockGetACById(...args),\n17\t}));\n18\t\n19\timport { registerValidateCommand } from '../validate.js';\n20\t\n21\tbeforeEach(() => {\n22\t  vi.resetAllMocks();\n23\t  process.exitCode = undefined;\n24\t});\n25\t\n26\tafterEach(() => {\n27\t  vi.restoreAllMocks();\n28\t  process.exitCode = undefined;\n29\t});\n30\t\n31\tfunction createCli(): Command {\n32\t  const program = new Command();\n33\t  program.exitOverride();\n34\t  program.option('--json', 'JSON output');\n35\t  registerValidateCommand(program);\n36\t  return program;\n37\t}\n38\t\n39\tasync function runCli(args: string[]): Promise<{ stdout: string }> {\n40\t  const logs: string[] = [];\n41\t  const consoleSpy = vi.spyOn(console, 'log').mockImplementation((...a: unknown[]) => {\n42\t    logs.push(a.map(String).join(' '));\n43\t  });\n44\t  const program = createCli();\n45\t  await program.parseAsync(['node', 'codeharness', ...args]);\n46\t  consoleSpy.mockRestore();\n47\t  return { stdout: logs.join('\\n') };\n48\t}\n49\t\n50\t// Helper: set up mocks for a full successful run (all pass)\n51\tfunction setupAllPass(total = 5, blocked = 2) {\n52\t  mockCreateValidationSprint.mockReturnValue({ success: true, data: { acsAdded: total, existingPreserved: 0 } });\n53\t  // First call returns a cycle, second returns no-actionable\n54\t  mockRunValidationCycle\n55\t    .mockReturnValueOnce({ success: true, data: { acId: 1, action: 'passed' } })\n56\t    .mockReturnValue({ success: true, data: { acId: 0, action: 'no-actionable-ac' } });\n57\t  mockGetValidationProgress.mockReturnValue({\n58\t    success: true,\n59\t    data: {\n60\t      total, passed: total - blocked, failed: 0, blocked, remaining: 0,\n61\t      perAC: Array.from({ length: total }, (_, i) => ({\n62\t        acId: i + 1,\n63\t        status: i < total - blocked ? 'done' : 'blocked',\n64\t        attempts: 1,\n65\t        lastError: null,\n66\t      })),\n67\t    },\n68\t  });\n69\t}\n70\t\n71\t// Helper: set up mocks for a run with failures\n72\tfunction setupWithFailures() {\n73\t  mockCreateValidationSprint.mockReturnValue({ success: true, data: { acsAdded: 3, existingPreserved: 0 } });\n74\t  mockRunValidationCycle\n75\t    .mockReturnValueOnce({ success: true, data: { acId: 1, action: 'passed' } })\n76\t    .mockReturnValue({ success: true, data: { acId: 0, action: 'no-actionable-ac' } });\n77\t  mockGetValidationProgress.mockReturnValue({\n78\t    success: true,\n79\t    data: {\n80\t      total: 3, passed: 1, failed: 1, blocked: 1, remaining: 0,\n81\t      perAC: [\n82\t        { acId: 1, status: 'done', attempts: 1, lastError: null },\n83\t        { acId: 2, status: 'failed', attempts: 3, lastError: 'command exited with code 1' },\n84\t        { acId: 3, status: 'blocked', attempts: 1, lastError: 'blocked' },\n85\t      ],\n86\t    },\n87\t  });\n88\t  mockGetACById.mockImplementation((id: number) => {\n89\t    if (id === 2) return { id: 2, frRef: 'FR2', description: 'Test AC 2', verificationMethod: 'cli', command: 'echo test', category: 'FR' };\n90\t    if (id === 3) return { id: 3, frRef: 'FR3', description: 'Test AC 3', verificationMethod: 'integration', category: 'FR' };\n91\t    return null;\n92\t  });\n93\t}\n94\t\n95\tdescribe('validate command', () => {\n96\t  it('produces report with correct counts (AC 1)', async () => {\n97\t    setupAllPass(10, 3);\n98\t    const { stdout } = await runCli(['validate']);\n99\t    expect(stdout).toContain('Total: 10');\n100\t    expect(stdout).toContain('Passed: 7');\n101\t    expect(stdout).toContain('Failed: 0');\n102\t    expect(stdout).toContain('Blocked: 3');\n103\t    expect(stdout).toContain('Cycles: 1');\n104\t  });\n105\t\n106\t  it('outputs RELEASE GATE: PASS on all-pass scenario (AC 2)', async () => {\n107\t    setupAllPass(5, 2);\n108\t    const { stdout } = await runCli(['validate']);\n109\t    expect(stdout).toContain('RELEASE GATE: PASS -- v1.0 ready');\n110\t    expect(process.exitCode).toBe(0);\n111\t  });\n112\t\n113\t  it('includes per-failure detail on failure scenario (AC 3)', async () => {\n114\t    setupWithFailures();\n115\t    const { stdout } = await runCli(['validate']);\n116\t    expect(stdout).toContain('RELEASE GATE: FAIL');\n117\t    expect(stdout).toContain('AC 2');\n118\t    expect(stdout).toContain('Test AC 2');\n119\t    expect(stdout).toContain('Command: echo test');\n120\t    expect(stdout).toContain('Output: command exited with code 1');\n121\t    expect(stdout).toContain('Attempts: 3');\n122\t    expect(stdout).toContain('Blocker: failed');\n123\t    expect(process.exitCode).toBe(1);\n124\t  });\n125\t\n126\t  it('--ci sets exit code 0 on pass (AC 5)', async () => {\n127\t    setupAllPass();\n128\t    const { stdout } = await runCli(['validate', '--ci']);\n129\t    expect(stdout).toContain('RELEASE GATE: PASS -- v1.0 ready');\n130\t    expect(process.exitCode).toBe(0);\n131\t  });\n132\t\n133\t  it('--ci sets exit code 1 on fail (AC 5)', async () => {\n134\t    setupWithFailures();\n135\t    const { stdout } = await runCli(['validate', '--ci']);\n136\t    expect(stdout).toContain('RELEASE GATE: FAIL');\n137\t    expect(process.exitCode).toBe(1);\n138\t  });\n139\t\n140\t  it('--json outputs machine-readable JSON', async () => {\n141\t    setupAllPass(5, 2);\n142\t    const { stdout } = await runCli(['--json', 'validate']);\n143\t    const parsed = JSON.parse(stdout);\n144\t    expect(parsed.status).toBe('pass');\n145\t    expect(parsed.total).toBe(5);\n146\t    expect(parsed.passed).toBe(3);\n147\t    expect(parsed.blocked).toBe(2);\n148\t    expect(parsed.cycles).toBe(1);\n149\t    expect(parsed.gate).toBe('RELEASE GATE: PASS -- v1.0 ready');\n150\t    expect(parsed.failures).toBeDefined();\n151\t  });\n152\t\n153\t  it('--json includes failure details', async () => {\n154\t    setupWithFailures();\n155\t    const { stdout } = await runCli(['--json', 'validate']);\n156\t    const parsed = JSON.parse(stdout);\n157\t    expect(parsed.status).toBe('fail');\n158\t    expect(parsed.gate).toBe('RELEASE GATE: FAIL');\n159\t    expect(parsed.failures.length).toBeGreaterThan(0);\n160\t    const failedAc = parsed.failures.find((f: { acId: number }) => f.acId === 2);\n161\t    expect(failedAc).toBeDefined();\n162\t    expect(failedAc.description).toBe('Test AC 2');\n163\t    expect(failedAc.command).toBe('echo test');\n164\t    expect(failedAc.output).toBe('command exited with code 1');\n165\t  });\n166\t\n167\t  it('reports error when createValidationSprint fails', async () => {\n168\t    mockCreateValidationSprint.mockReturnValue({ success: false, error: 'state not found' });\n169\t    const { stdout } = await runCli(['validate']);\n170\t    expect(stdout).toContain('state not found');\n171\t    expect(process.exitCode).toBe(1);\n172\t  });\n173\t\n174\t  it('reports error when runValidationCycle fails', async () => {\n175\t    mockCreateValidationSprint.mockReturnValue({ success: true, data: { acsAdded: 1, existingPreserved: 0 } });\n176\t    mockRunValidationCycle.mockReturnValue({ success: false, error: 'cycle error' });\n177\t    const { stdout } = await runCli(['validate']);\n178\t    expect(stdout).toContain('cycle error');\n179\t    expect(process.exitCode).toBe(1);\n180\t  });\n181\t\n182\t  it('reports error when getValidationProgress fails', async () => {\n183\t    mockCreateValidationSprint.mockReturnValue({ success: true, data: { acsAdded: 1, existingPreserved: 0 } });\n184\t    mockRunValidationCycle.mockReturnValue({ success: true, data: { acId: 0, action: 'no-actionable-ac' } });\n185\t    mockGetValidationProgress.mockReturnValue({ success: false, error: 'progress error' });\n186\t    const { stdout } = await runCli(['validate']);\n187\t    expect(stdout).toContain('progress error');\n188\t    expect(process.exitCode).toBe(1);\n189\t  });\n190\t\n191\t  it('command file is under 100 lines (FR40)', () => {\n192\t    const source = readFileSync(\n193\t      new URL('../validate.ts', import.meta.url).pathname,\n194\t      'utf-8',\n195\t    );\n196\t    const lineCount = source.split('\\n').length;\n197\t    expect(lineCount).toBeLessThan(100);\n198\t  });\n199\t});\n200\t"}]},"parent_tool_use_id":"toolu_019SoUcSY6ykbxKMMLbKRkDH","session_id":"5fca15c0-771e-463c-9e4f-c528b230e359","uuid":"cb62314d-2641-4a38-b292-a81c45475d5a","timestamp":"2026-04-02T14:52:19.353Z"}
