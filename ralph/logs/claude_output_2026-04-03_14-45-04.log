{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FHz9JneroBeqxrYdkB8uLu","type":"tool_result","content":"399\t\n400\t  it('handles unreadable issues.yaml file gracefully', () => {\n401\t    // sprint-status.yaml is fine\n402\t    mockExistsSync.mockReturnValue(true);\n403\t    let readCount = 0;\n404\t    mockReadFileSync.mockImplementation(() => {\n405\t      readCount++;\n406\t      if (readCount === 1) return 'sprint yaml';\n407\t      throw new Error('EACCES: permission denied');\n408\t    });\n409\t    mockParse.mockReturnValue({\n410\t      development_status: { '3-1-foo': 'ready-for-dev' },\n411\t    });\n412\t\n413\t    const items = loadWorkItems('/path/sprint-status.yaml', '/path/issues.yaml');\n414\t    // Should still have the sprint story\n415\t    expect(items).toEqual([{ key: '3-1-foo', source: 'sprint' }]);\n416\t    expect(mockWarn).toHaveBeenCalledWith(\n417\t      expect.stringContaining('could not read issues.yaml'),\n418\t    );\n419\t  });\n420\t\n421\t  it('handles invalid YAML in issues.yaml gracefully', () => {\n422\t    mockExistsSync.mockReturnValue(true);\n423\t    mockReadFileSync.mockReturnValue('yaml');\n424\t    let parseCount = 0;\n425\t    mockParse.mockImplementation(() => {\n426\t      parseCount++;\n427\t      if (parseCount === 1) {\n428\t        return { development_status: { '3-1-foo': 'ready-for-dev' } };\n429\t      }\n430\t      throw new Error('bad issues yaml');\n431\t    });\n432\t\n433\t    const items = loadWorkItems('/path/sprint-status.yaml', '/path/issues.yaml');\n434\t    expect(items).toEqual([{ key: '3-1-foo', source: 'sprint' }]);\n435\t    expect(mockWarn).toHaveBeenCalledWith(\n436\t      expect.stringContaining('invalid YAML in issues.yaml'),\n437\t    );\n438\t  });\n439\t});\n440\t\n441\tdescribe('dispatchTask', () => {\n442\t  beforeEach(() => {\n443\t    vi.clearAllMocks();\n444\t    setupDefaultMocks();\n445\t  });\n446\t\n447\t  it('generates trace ID and injects trace prompt per dispatch (AC #11)', async () => {\n448\t    const task = makeTask();\n449\t    const definition = makeDefinition();\n450\t    const state = makeDefaultState();\n451\t    const config = makeConfig();\n452\t\n453\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n454\t\n455\t    expect(mockGenerateTraceId).toHaveBeenCalledWith('run-001', 0, 'implement');\n456\t    expect(mockFormatTracePrompt).toHaveBeenCalledWith('ch-run-001-0-implement');\n457\t    expect(mockDriverDispatch).toHaveBeenCalledWith(\n458\t      expect.objectContaining({\n459\t        prompt: 'Implement story 5-1-foo',\n460\t        appendSystemPrompt: '[TRACE] trace_id=ch-run-001-0-implement',\n461\t      }),\n462\t    );\n463\t  });\n464\t\n465\t  it('resolves session ID for continue boundary (AC #12)', async () => {\n466\t    const task = makeTask({ session: 'continue' });\n467\t    const definition = makeDefinition();\n468\t    const state = makeDefaultState();\n469\t    const config = makeConfig();\n470\t\n471\t    mockResolveSessionId.mockReturnValue('prev-sess-id');\n472\t\n473\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n474\t\n475\t    expect(mockResolveSessionId).toHaveBeenCalledWith(\n476\t      'continue',\n477\t      { taskName: 'implement', storyKey: '5-1-foo' },\n478\t      state,\n479\t    );\n480\t    // Session ID is passed through to the driver via DispatchOpts.sessionId\n481\t    expect(mockDriverDispatch).toHaveBeenCalledWith(\n482\t      expect.objectContaining({\n483\t        sessionId: 'prev-sess-id',\n484\t      }),\n485\t    );\n486\t  });\n487\t\n488\t  it('dispatches with cwd when source_access is true (default) (AC #10)', async () => {\n489\t    const task = makeTask({ source_access: true });\n490\t    const definition = makeDefinition();\n491\t    const state = makeDefaultState();\n492\t    const config = makeConfig({ projectDir: '/my-project' });\n493\t\n494\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n495\t\n496\t    expect(mockCreateIsolatedWorkspace).not.toHaveBeenCalled();\n497\t    expect(mockDriverDispatch).toHaveBeenCalledWith(\n498\t      expect.objectContaining({ cwd: '/my-project' }),\n499\t    );\n500\t  });\n501\t\n502\t  it('creates isolated workspace when source_access is false (AC #9)', async () => {\n503\t    const mockWorkspace = {\n504\t      dir: '/tmp/codeharness-verify-run-001',\n505\t      storyFilesDir: '/tmp/codeharness-verify-run-001/story-files',\n506\t      verdictDir: '/tmp/codeharness-verify-run-001/verdict',\n507\t      toDispatchOptions: () => ({ cwd: '/tmp/codeharness-verify-run-001' }),\n508\t      cleanup: vi.fn().mockResolvedValue(undefined),\n509\t    };\n510\t    mockCreateIsolatedWorkspace.mockResolvedValue(mockWorkspace);\n511\t\n512\t    const task = makeTask({ source_access: false });\n513\t    const definition = makeDefinition();\n514\t    const state = makeDefaultState();\n515\t    const config = makeConfig();\n516\t\n517\t    await dispatchTask(task, 'verify', '__run__', definition, state, config);\n518\t\n519\t    expect(mockCreateIsolatedWorkspace).toHaveBeenCalledWith({\n520\t      runId: 'run-001',\n521\t      storyFiles: [],\n522\t    });\n523\t    expect(mockDriverDispatch).toHaveBeenCalledWith(\n524\t      expect.objectContaining({ cwd: '/tmp/codeharness-verify-run-001' }),\n525\t    );\n526\t    expect(mockWorkspace.cleanup).toHaveBeenCalled();\n527\t  });\n528\t\n529\t  it('writes state to disk after each dispatch (AC #4)', async () => {\n530\t    const task = makeTask();\n531\t    const definition = makeDefinition();\n532\t    const state = makeDefaultState();\n533\t    const config = makeConfig();\n534\t\n535\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n536\t\n537\t    expect(mockWriteWorkflowState).toHaveBeenCalled();\n538\t    // State should have the new checkpoint\n539\t    const writtenState = mockWriteWorkflowState.mock.calls[0