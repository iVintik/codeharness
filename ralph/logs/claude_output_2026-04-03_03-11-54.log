{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DhQpqHbjnbwPNopH5MHY9b","type":"tool_result","content":"1\t/**\n2\t * Status formatters — human-readable and JSON formatting for status output.\n3\t * Handles the full status display, docker check, and health check formatting.\n4\t */\n5\t\n6\timport { ok, fail, info, jsonOutput } from '../../lib/output.js';\n7\timport { readState, StateFileNotFoundError } from '../../lib/state.js';\n8\timport { getStackHealth, getCollectorHealth, checkRemoteEndpoint } from '../../lib/docker/index.js';\n9\timport { getOnboardingProgress } from '../../lib/onboard-checks.js';\n10\timport { getStackDir, getComposeFilePath, getElkComposeFilePath } from '../../lib/stack-path.js';\n11\timport { generateReport } from '../sprint/index.js';\n12\timport { getValidationProgress } from '../verify/index.js';\n13\timport { readWorkflowState } from '../../lib/workflow-state.js';\n14\timport type { WorkflowState } from '../../lib/workflow-state.js';\n15\timport { DEFAULT_ENDPOINTS, buildScopedEndpoints, resolveEndpoints, getDefaultEndpointsForBackend } from './endpoints.js';\n16\timport type { HarnessState } from '../../lib/state.js';\n17\timport type { StatusReport } from '../sprint/index.js';\n18\t\n19\t/** Resolve the shared compose file path based on the backend type. */\n20\tfunction resolveSharedCompose(backend: string): string {\n21\t  return backend === 'elk' ? getElkComposeFilePath() : getComposeFilePath();\n22\t}\n23\t\n24\t// ─── Full Status Display ────────────────────────────────────────────────────\n25\t\n26\texport function handleFullStatus(isJson: boolean): void {\n27\t  let state: HarnessState;\n28\t  try {\n29\t    state = readState();\n30\t  } catch (err) {\n31\t    if (err instanceof StateFileNotFoundError) {\n32\t      if (isJson) {\n33\t        jsonOutput({ status: 'fail', message: \"Harness not initialized. Run 'codeharness init' first.\" });\n34\t      } else {\n35\t        fail(\"Harness not initialized. Run 'codeharness init' first.\");\n36\t      }\n37\t      process.exitCode = 1;\n38\t      return;\n39\t    }\n40\t    throw err;\n41\t  }\n42\t\n43\t  if (isJson) {\n44\t    handleFullStatusJson(state);\n45\t    return;\n46\t  }\n47\t\n48\t  // Workflow engine state\n49\t  printWorkflowState();\n50\t\n51\t  // Sprint state sections (Project State, Run, Action Items)\n52\t  printSprintState();\n53\t\n54\t  // Validation progress (if validation stories exist)\n55\t  printValidationProgress();\n56\t\n57\t  // Version & Stack\n58\t  console.log(`Harness: codeharness v${state.harness_version}`);\n59\t  console.log(`Stack: ${state.stack ?? 'unknown'}`);\n60\t  if (state.app_type) {\n61\t    console.log(`App type: ${state.app_type}`);\n62\t    if (state.app_type === 'agent' && state.otlp?.agent_sdk) {\n63\t      console.log(`Agent SDK: ${state.otlp.agent_sdk}`);\n64\t    }\n65\t  }\n66\t\n67\t  // Enforcement\n68\t  const e = state.enforcement;\n69\t  console.log(\n70\t    `Enforcement: front:${e.frontend ? 'ON' : 'OFF'} db:${e.database ? 'ON' : 'OFF'} api:${e.api ? 'ON' : 'OFF'} obs:ON`,\n71\t  );\n72\t\n73\t  // Docker (always shown — observability is mandatory unless backend is 'none')\n74\t  {\n75\t    const backend = state.otlp?.backend ?? 'victoria';\n76\t    const mode = state.otlp?.mode ?? 'local-shared';\n77\t\n78\t    if (backend === 'none') {\n79\t      console.log('Docker: disabled (observability off)');\n80\t    } else if (mode === 'remote-direct') {\n81\t      const endpoint = state.otlp?.endpoint ?? 'unknown';\n82\t      console.log(`Docker: none (remote OTLP at ${endpoint})`);\n83\t    } else if (mode === 'remote-routed') {\n84\t      const re = state.docker?.remote_endpoints;\n85\t      console.log(`Docker: OTel Collector only (backends at ${re?.logs_url ?? 'unknown'}, ${re?.metrics_url ?? 'unknown'}, ${re?.traces_url ?? 'unknown'})`);\n86\t      const sharedComposeFile = getComposeFilePath();\n87\t      const health = getCollectorHealth(sharedComposeFile);\n88\t      for (const svc of health.services) {\n89\t        console.log(`  ${svc.name}: ${svc.running ? 'running' : 'stopped'}`);\n90\t      }\n91\t    } else {\n92\t      const composeFile = state.docker?.compose_file ?? 'docker-compose.harness.yml';\n93\t      const stackDir = getStackDir();\n94\t      const isShared = composeFile.startsWith(stackDir);\n95\t\n96\t      const resolvedComposeFile = isShared ? resolveSharedCompose(backend) : composeFile;\n97\t      const projectName = isShared ? 'codeharness-shared' : undefined;\n98\t      const header = isShared ? 'Docker: shared stack at ~/.codeharness/stack/' : 'Docker:';\n99\t\n100\t      console.log(header);\n101\t      const health = getStackHealth(resolvedComposeFile, projectName);\n102\t      for (const svc of health.services) {\n103\t        console.log(`  ${svc.name}: ${svc.running ? 'running' : 'stopped'}`);\n104\t      }\n105\t      if (health.healthy) {\n106\t        const ep = getDefaultEndpointsForBackend(backend);\n107\t        console.log(\n108\t          `  Endpoints: logs=${ep.logs} metrics=${ep.metrics} traces=${ep.traces}`,\n109\t        );\n110\t      }\n111\t    }\n112\t  }\n113\t\n114\t  // Service-scoped endpoints\n115\t  const serviceName = state.otlp?.service_name;\n116\t  if (serviceName) {\n117\t    const endpoints = resolveEndpoints(state);\n118\t    const scoped = buildScopedEndpoints(endpoints, serviceName, state.otlp?.backend);\n119\t    console.log(`  Scoped: logs=${scoped.logs} metrics=${scoped.metrics} traces=${scoped.traces}`);\n120\t  }\n121\t\n122\t  // Beads — removed (Epic 8 replacement pending)\n123\t\n124\t  // Onboarding progress\n125\t  printOnboardingProgress();\n126\t\n127\t  // Session flags\n128\t  const sf = state.session_flags;\n129\t  console.log(\n130\t    `Session: tests_passed=${sf.tests_passed} coverage_met=${sf.coverage_met} verification_run=${sf.verification_run} logs_queried=${sf.logs_queried}`,\n131\t  );\n132\t\n133\t  // Coverage\n134\t  const currentCov = state.coverage.current !== null ? `${state.coverage.current}%` : '\\u2014';\n135\t  console.log(`Coverage: ${currentCov} / ${state.coverage.target}% target`);\n136\t\n137\t  // Verification log\n138\t  if (state.verification_log.length === 0) {\n139\t    console.log('Verification: no entries');\n140\t  } else {\n141\t    console.log('Verification log:');\n142\t    for (const entry of state.verification_log) {\n143\t      console.log(`  ${entry}`);\n144\t    }\n145\t  }\n146\t}\n147\t\n148\tfunction handleFullStatusJson(state: HarnessState): void {\n149\t  // Docker (always present — observability is mandatory unless backend is 'none')\n150\t  let docker: Record<string, unknown>;\n151\t  {\n152\t    const backend = state.otlp?.backend ?? 'victoria';\n153\t    const mode = state.otlp?.mode ?? 'local-shared';\n154\t\n155\t    if (backend === 'none') {\n156\t      docker = { mode: 'none', message: 'Observability disabled' };\n157\t    } else if (mode === 'remote-direct') {\n158\t      docker = {\n159\t        mode: 'remote-direct',\n160\t        endpoint: state.otlp?.endpoint,\n161\t      };\n162\t    } else if (mode === 'remote-routed') {\n163\t      const sharedComposeFile = getComposeFilePath();\n164\t      const health = getCollectorHealth(sharedComposeFile);\n165\t      docker = {\n166\t        mode: 'remote-routed',\n167\t        healthy: health.healthy,\n168\t        services: health.services,\n169\t        remote_endpoints: state.docker?.remote_endpoints,\n170\t      };\n171\t    } else {\n172\t      const composeFile = state.docker?.compose_file ?? 'docker-compose.harness.yml';\n173\t      const stackDir = getStackDir();\n174\t      const isShared = composeFile.startsWith(stackDir);\n175\t\n176\t      const ep = getDefaultEndpointsForBackend(backend);\n177\t      if (isShared) {\n178\t        const sharedComposeFile = resolveSharedCompose(backend);\n179\t        const health = getStackHealth(sharedComposeFile, 'codeharness-shared');\n180\t        docker = {\n181\t          shared: true,\n182\t          stack_dir: '~/.codeharness/stack/',\n183\t          healthy: health.healthy,\n184\t          services: health.services,\n185\t          ...(health.healthy ? { endpoints: ep } : {}),\n186\t        };\n187\t      } else {\n188\t        const health = getStackHealth(composeFile);\n189\t        docker = {\n190\t          healthy: health.healthy,\n191\t          services: health.services,\n192\t          ...(health.healthy ? { endpoints: ep } : {}),\n193\t        };\n194\t      }\n195\t    }\n196\t  }\n197\t\n198\t  // Resolved endpoints\n199\t  const endpoints = resolveEndpoints(state);\n200\t\n201\t  // Scoped endpoints\n202\t  const serviceName = state.otlp?.service_name;\n203\t  const scoped_endpoints = serviceName ? buildScopedEndpoints(endpoints, serviceName, state.otlp?.backend) : undefined;\n204\t\n205\t  // Onboarding progress\n206\t  const onboarding = getOnboardingProgressData();\n207\t\n208\t  // Sprint state\n209\t  const sprint = getSprintReportData();\n210\t\n211\t  // Validation progress\n212\t  const validationResult = getValidationProgress();\n213\t  const validation = validationResult.success && validationResult.data.total > 0\n214\t    ? validationResult.data : undefined;\n215\t\n216\t  // Workflow engine state\n217\t  const workflowState = getWorkflowStateData();\n218\t\n219\t  jsonOutput({\n220\t    version: state.harness_version,\n221\t    stack: state.stack,\n222\t    ...(state.app_type ? { app_type: state.app_type } : {}),\n223\t    ...(sprint ? { sprint } : {}),\n224\t    ...(validation ? { validation } : {}),\n225\t    ...(workflowState ? { workflow: workflowState } : {}),\n226\t    enforcement: state.enforcement,\n227\t    docker,\n228\t    endpoints,\n229\t    ...(scoped_endpoints ? { scoped_endpoints } : {}),\n230\t    ...(onboarding ? { onboarding } : {}),\n231\t    session_flags: state.session_flags,\n232\t    coverage: state.coverage,\n233\t    verification_log: state.verification_log,\n234\t  });\n235\t}\n236\t\n237\t// ─── Health Check Mode ──────────────────────────────────────────────────────\n238\t\n239\texport async function handleHealthCheck(isJson: boolean): Promise<void> {\n240\t  const checks: { name: string; status: 'ok' | 'fail'; detail: string }[] = [];\n241\t\n242\t  // 1. State file integrity\n243\t  let state: HarnessState | null = null;\n244\t  try {\n245\t    state = readState();\n246\t    checks.push({ name: 'state_file', status: 'ok', detail: 'valid' });\n247\t  } catch {\n248\t    // IGNORE: state file may not exist\n249\t    checks.push({ name: 'state_file', status: 'fail', detail: 'not found' });\n250\t  }\n251\t\n252\t  // 2. Docker health (always checked — observability is mandatory unless backend is 'none')\n253\t  if (state) {\n254\t    const backend = state.otlp?.backend ?? 'victoria';\n255\t    const mode = state.otlp?.mode ?? 'local-shared';\n256\t\n257\t    if (backend === 'none') {\n258\t      checks.push({ name: 'docker', status: 'ok', detail: 'observability disabled — skipped' });\n259\t    } else if (mode === 'remote-direct') {\n260\t      const endpoint = state.otlp?.endpoint ?? '';\n261\t      const result = await checkRemoteEndpoint(endpoint);\n262\t      checks.push({\n263\t        name: 'docker',\n264\t        status: result.reachable ? 'ok' : 'fail',\n265\t        detail: result.reachable ? `remote OTLP reachable (${endpoint})` : `remote OTLP unreachable (${result.error ?? 'unknown'})`,\n266\t      });\n267\t    } else if (mode === 'remote-routed') {\n268\t      const sharedComposeFile = getComposeFilePath();\n269\t      const health = getCollectorHealth(sharedComposeFile);\n270\t      checks.push({\n271\t        name: 'docker',\n272\t        status: health.healthy ? 'ok' : 'fail',\n273\t        detail: health.healthy ? 'OTel Collector running' : (health.remedy ?? 'collector down'),\n274\t      });\n275\t\n276\t      // Check remote endpoints\n277\t      const re = state.docker?.remote_endpoints;\n278\t      if (re) {\n279\t        for (const [label, url] of [['logs', re.logs_url], ['metrics', re.metrics_url], ['traces', re.traces_url]] as const) {\n280\t          if (url) {\n281\t            const result = await checkRemoteEndpoint(url);\n282\t            checks.push({\n283\t              name: `remote_${label}`,\n284\t              status: result.reachable ? 'ok' : 'fail',\n285\t              detail: result.reachable ? `reachable (${url})` : `unreachable (${result.error ?? 'unknown'})`,\n286\t            });\n287\t          }\n288\t        }\n289\t      }\n290\t    } else {\n291\t      const composeFile = state.docker?.compose_file ?? 'docker-compose.harness.yml';\n292\t      const sDir = getStackDir();\n293\t      const isShared = composeFile.startsWith(sDir);\n294\t      const healthComposeFile = isShared ? resolveSharedCompose(backend) : composeFile;\n295\t      const healthProjectName = isShared ? 'codeharness-shared' : undefined;\n296\t      const health = getStackHealth(healthComposeFile, healthProjectName);\n297\t      checks.push({\n298\t        name: 'docker',\n299\t        status: health.healthy ? 'ok' : 'fail',\n300\t        detail: health.healthy ? 'all services running' : (health.remedy ?? 'services down'),\n301\t      });\n302\t    }\n303\t  } else {\n304\t    checks.push({ name: 'docker', status: 'fail', detail: 'cannot check (no state)' });\n305\t  }\n306\t\n307\t  // 3. Issue tracker — placeholder for Epic 8\n308\t  // Beads health check removed; Epic 8 will add issue-tracker health check here.\n309\t\n310\t  const allPassed = checks.every(c => c.status === 'ok');\n311\t\n312\t  if (isJson) {\n313\t    const checksObj: Record<string, { status: string; detail: string }> = {};\n314\t    for (const c of checks) {\n315\t      checksObj[c.name] = { status: c.status, detail: c.detail };\n316\t    }\n317\t    jsonOutput({ status: allPassed ? 'ok' : 'fail', checks: checksObj });\n318\t  } else {\n319\t    for (const c of checks) {\n320\t      const prefix =