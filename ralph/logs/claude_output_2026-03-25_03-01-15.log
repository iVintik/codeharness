{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012ur6DEgFJ5c6xGMsAWG7ws","type":"tool_result","content":"     1→/**\n     2→ * Status formatters — human-readable and JSON formatting for status output.\n     3→ * Handles the full status display, docker check, and health check formatting.\n     4→ */\n     5→\n     6→import { ok, fail, info, jsonOutput } from '../../lib/output.js';\n     7→import { readState, StateFileNotFoundError } from '../../lib/state.js';\n     8→import { getStackHealth, getCollectorHealth, checkRemoteEndpoint } from '../../lib/docker/index.js';\n     9→import { listIssues, isBeadsInitialized } from '../../lib/beads.js';\n    10→import { getOnboardingProgress } from '../../lib/onboard-checks.js';\n    11→import { getStackDir, getComposeFilePath } from '../../lib/stack-path.js';\n    12→import { generateReport } from '../sprint/index.js';\n    13→import { getValidationProgress } from '../verify/index.js';\n    14→import { DEFAULT_ENDPOINTS, buildScopedEndpoints, resolveEndpoints } from './endpoints.js';\n    15→import type { HarnessState } from '../../lib/state.js';\n    16→import type { StatusReport } from '../sprint/index.js';\n    17→\n    18→// ─── Full Status Display ────────────────────────────────────────────────────\n    19→\n    20→export function handleFullStatus(isJson: boolean): void {\n    21→  let state: HarnessState;\n    22→  try {\n    23→    state = readState();\n    24→  } catch (err) {\n    25→    if (err instanceof StateFileNotFoundError) {\n    26→      if (isJson) {\n    27→        jsonOutput({ status: 'fail', message: \"Harness not initialized. Run 'codeharness init' first.\" });\n    28→      } else {\n    29→        fail(\"Harness not initialized. Run 'codeharness init' first.\");\n    30→      }\n    31→      process.exitCode = 1;\n    32→      return;\n    33→    }\n    34→    throw err;\n    35→  }\n    36→\n    37→  if (isJson) {\n    38→    handleFullStatusJson(state);\n    39→    return;\n    40→  }\n    41→\n    42→  // Sprint state sections (Project State, Run, Action Items)\n    43→  printSprintState();\n    44→\n    45→  // Validation progress (if validation stories exist)\n    46→  printValidationProgress();\n    47→\n    48→  // Version & Stack\n    49→  console.log(`Harness: codeharness v${state.harness_version}`);\n    50→  console.log(`Stack: ${state.stack ?? 'unknown'}`);\n    51→  if (state.app_type) {\n    52→    console.log(`App type: ${state.app_type}`);\n    53→    if (state.app_type === 'agent' && state.otlp?.agent_sdk) {\n    54→      console.log(`Agent SDK: ${state.otlp.agent_sdk}`);\n    55→    }\n    56→  }\n    57→\n    58→  // Enforcement\n    59→  const e = state.enforcement;\n    60→  console.log(\n    61→    `Enforcement: front:${e.frontend ? 'ON' : 'OFF'} db:${e.database ? 'ON' : 'OFF'} api:${e.api ? 'ON' : 'OFF'} obs:ON`,\n    62→  );\n    63→\n    64→  // Docker (always shown — observability is mandatory)\n    65→  {\n    66→    const mode = state.otlp?.mode ?? 'local-shared';\n    67→\n    68→    if (mode === 'remote-direct') {\n    69→      const endpoint = state.otlp?.endpoint ?? 'unknown';\n    70→      console.log(`Docker: none (remote OTLP at ${endpoint})`);\n    71→    } else if (mode === 'remote-routed') {\n    72→      const re = state.docker?.remote_endpoints;\n    73→      console.log(`Docker: OTel Collector only (backends at ${re?.logs_url ?? 'unknown'}, ${re?.metrics_url ?? 'unknown'}, ${re?.traces_url ?? 'unknown'})`);\n    74→      const sharedComposeFile = getComposeFilePath();\n    75→      const health = getCollectorHealth(sharedComposeFile);\n    76→      for (const svc of health.services) {\n    77→        console.log(`  ${svc.name}: ${svc.running ? 'running' : 'stopped'}`);\n    78→      }\n    79→    } else {\n    80→      const composeFile = state.docker?.compose_file ?? 'docker-compose.harness.yml';\n    81→      const stackDir = getStackDir();\n    82→      const isShared = composeFile.startsWith(stackDir);\n    83→\n    84→      const resolvedComposeFile = isShared ? getComposeFilePath() : composeFile;\n    85→      const projectName = isShared ? 'codeharness-shared' : undefined;\n    86→      const header = isShared ? 'Docker: shared stack at ~/.codeharness/stack/' : 'Docker:';\n    87→\n    88→      console.log(header);\n    89→      const health = getStackHealth(resolvedComposeFile, projectName);\n    90→      for (const svc of health.services) {\n    91→        console.log(`  ${svc.name}: ${svc.running ? 'running' : 'stopped'}`);\n    92→      }\n    93→      if (health.healthy) {\n    94→        console.log(\n    95→          `  Endpoints: logs=${DEFAULT_ENDPOINTS.logs} metrics=${DEFAULT_ENDPOINTS.metrics} traces=${DEFAULT_ENDPOINTS.traces}`,\n    96→        );\n    97→      }\n    98→    }\n    99→  }\n   100→\n   101→  // Service-scoped endpoints\n   102→  const serviceName = state.otlp?.service_name;\n   103→  if (serviceName) {\n   104→    const endpoints = resolveEndpoints(state);\n   105→    const scoped = buildScopedEndpoints(endpoints, serviceName);\n   106→    console.log(`  Scoped: logs=${scoped.logs} metrics=${scoped.metrics} traces=${scoped.traces}`);\n   107→  }\n   108→\n   109→  // Beads\n   110→  printBeadsSummary();\n   111→\n   112→  // Onboarding progress\n   113→  printOnboardingProgress();\n   114→\n   115→  // Session flags\n   116→  const sf = state.session_flags;\n   117→  console.log(\n   118→    `Session: tests_passed=${sf.tests_passed} coverage_met=${sf.coverage_met} verification_run=${sf.verification_run} logs_queried=${sf.logs_queried}`,\n   119→  );\n   120→\n   121→  // Coverage\n   122→  const currentCov = state.coverage.current !== null ? `${state.coverage.current}%` : '\\u2014';\n   123→  console.log(`Coverage: ${currentCov} / ${state.coverage.target}% target`);\n   124→\n   125→  // Verification log\n   126→  if (state.verification_log.length === 0) {\n   127→    console.log('Verification: no entries');\n   128→  } else {\n   129→    console.log('Verification log:');\n   130→    for (const entry of state.verification_log) {\n   131→      console.log(`  ${entry}`);\n   132→    }\n   133→  }\n   134→}\n   135→\n   136→function handleFullStatusJson(state: HarnessState): void {\n   137→  // Docker (always present — observability is mandatory)\n   138→  let docker: Record<string, unknown>;\n   139→  {\n   140→    const mode = state.otlp?.mode ?? 'local-shared';\n   141→\n   142→    if (mode === 'remote-direct') {\n   143→      docker = {\n   144→        mode: 'remote-direct',\n   145→        endpoint: state.otlp?.endpoint,\n   146→      };\n   147→    } else if (mode === 'remote-routed') {\n   148→      const sharedComposeFile = getComposeFilePath();\n   149→      const health = getCollectorHealth(sharedComposeFile);\n   150→      docker = {\n   151→        mode: 'remote-routed',\n   152→        healthy: health.healthy,\n   153→        services: health.services,\n   154→        remote_endpoints: state.docker?.remote_endpoints,\n   155→      };\n   156→    } else {\n   157→      const composeFile = state.docker?.compose_file ?? 'docker-compose.harness.yml';\n   158→      const stackDir = getStackDir();\n   159→      const isShared = composeFile.startsWith(stackDir);\n   160→\n   161→      if (isShared) {\n   162→        const sharedComposeFile = getComposeFilePath();\n   163→        const health = getStackHealth(sharedComposeFile, 'codeharness-shared');\n   164→        docker = {\n   165→          shared: true,\n   166→          stack_dir: '~/.codeharness/stack/',\n   167→          healthy: health.healthy,\n   168→          services: health.services,\n   169→          ...(health.healthy ? { endpoints: DEFAULT_ENDPOINTS } : {}),\n   170→        };\n   171→      } else {\n   172→        const health = getStackHealth(composeFile);\n   173→        docker = {\n   174→          healthy: health.healthy,\n   175→          services: health.services,\n   176→          ...(health.healthy ? { endpoints: DEFAULT_ENDPOINTS } : {}),\n   177→        };\n   178→      }\n   179→    }\n   180→  }\n   181→\n   182→  // Resolved endpoints\n   183→  const endpoints = resolveEndpoints(state);\n   184→\n   185→  // Scoped endpoints\n   186→  const serviceName = state.otlp?.service_name;\n   187→  const scoped_endpoints = serviceName ? buildScopedEndpoints(endpoints, serviceName) : undefined;\n   188→\n   189→  // Beads\n   190→  const beads = getBeadsData();\n   191→\n   192→  // Onboarding progress\n   193→  const onboarding = getOnboardingProgressData();\n   194→\n   195→  // Sprint state\n   196→  const sprint = getSprintReportData();\n   197→\n   198→  // Validation progress\n   199→  const validationResult = getValidationProgress();\n   200→  const validation = validationResult.success && validationResult.data.total > 0\n   201→    ? validationResult.data : undefined;\n   202→\n   203→  jsonOutput({\n   204→    version: state.harness_version,\n   205→    stack: state.stack,\n   206→    ...(state.app_type ? { app_type: state.app_type } : {}),\n   207→    ...(sprint ? { sprint } : {}),\n   208→    ...(validation ? { validation } : {}),\n   209→    enforcement: state.enforcement,\n   210→    docker,\n   211→    endpoints,\n   212→    ...(scoped_endpoints ? { scoped_endpoints } : {}),\n   213→    beads,\n   214→    ...(onboarding ? { onboarding } : {}),\n   215→    session_flags: state.session_flags,\n   216→    coverage: state.coverage,\n   217→    verification_log: state.verification_log,\n   218→  });\n   219→}\n   220→\n   221→// ─── Health Check Mode ──────────────────────────────────────────────────────\n   222→\n   223→export async function handleHealthCheck(isJson: boolean): Promise<void> {\n   224→  const checks: { name: string; status: 'ok' | 'fail'; detail: string }[] = [];\n   225→\n   226→  // 1. State file integrity\n   227→  let state: HarnessState | null = null;\n   228→  try {\n   229→    state = readState();\n   230→    checks.push({ name: 'state_file', status: 'ok', detail: 'valid' });\n   231→  } catch {\n   232→    checks.push({ name: 'state_file', status: 'fail', detail: 'not found' });\n   233→  }\n   234→\n   235→  // 2. Docker health (always checked — observability is mandatory)\n   236→  if (state) {\n   237→    const mode = state.otlp?.mode ?? 'local-shared';\n   238→\n   239→    if (mode === 'remote-direct') {\n   240→      const endpoint = state.otlp?.endpoint ?? '';\n   241→      const result = await checkRemoteEndpoint(endpoint);\n   242→      checks.push({\n   243→        name: 'docker',\n   244→        status: result.reachable ? 'ok' : 'fail',\n   245→        detail: result.reachable ? `remote OTLP reachable (${endpoint})` : `remote OTLP unreachable (${result.error ?? 'unknown'})`,\n   246→      });\n   247→    } else if (mode === 'remote-routed') {\n   248→      const sharedComposeFile = getComposeFilePath();\n   249→      const health = getCollectorHealth(sharedComposeFile);\n   250→      checks.push({\n   251→        name: 'docker',\n   252→        status: health.healthy ? 'ok' : 'fail',\n   253→        detail: health.healthy ? 'OTel Collector running' : (health.remedy ?? 'collector down'),\n   254→      });\n   255→\n   256→      // Check remote endpoints\n   257→      const re = state.docker?.remote_endpoints;\n   258→      if (re) {\n   259→        for (const [label, url] of [['logs', re.logs_url], ['metrics', re.metrics_url], ['traces', re.traces_url]] as const) {\n   260→          if (url) {\n   261→            const result = await checkRemoteEndpoint(url);\n   262→            checks.push({\n   263→              name: `remote_${label}`,\n   264→              status: result.reachable ? 'ok' : 'fail',\n   265→              detail: result.reachable ? `reachable (${url})` : `unreachable (${result.error ?? 'unknown'})`,\n   266→            });\n   267→          }\n   268→        }\n   269→      }\n   270→    } else {\n   271→      const composeFile = state.docker?.compose_file ?? 'docker-compose.harness.yml';\n   272→      const sDir = getStackDir();\n   273→      const isShared = composeFile.startsWith(sDir);\n   274→      const healthComposeFile = isShared ? getComposeFilePath() : composeFile;\n   275→      const healthProjectName = isShared ? 'codeharness-shared' : undefined;\n   276→      const health = getStackHealth(healthComposeFile, healthProjectName);\n   277→      checks.push({\n   278→        name: 'docker',\n   279→        status: health.healthy ? 'ok' : 'fail',\n   280→        detail: health.healthy ? 'all services running' : (health.remedy ?? 'services down'),\n   281→      });\n   282→    }\n   283→  } else {\n   284→    checks.push({ name: 'docker', status: 'fail', detail: 'cannot check (no state)' });\n   285→  }\n   286→\n   287→  // 3. Beads availability\n   288→  try {\n   289→    if (isBeadsInitialized()) {\n   290→      listIssues();\n   291→      checks.push({ name: 'beads', status: 'ok', detail: 'available' });\n   292→    } else {\n   293→      checks.push({ name: 'beads', status: 'fail', detail: 'not initialized' });\n   294→    }\n   295→  } catch {\n   296→    checks.push({ name: 'beads', status: 'fail', detail: 'bd command failed' });\n   297→  }\n   298→\n   299→  const allPassed = checks.every(c => c.status === 'ok');\n   300→\n   301→  if (isJson) {\n   302→    const checksObj: Record<string, { status: string; detail: string }> = {};\n   303→    for (const c of checks) {\n   304→      checksObj[c.name] = { status: c.status, detail: c.detail };\n   305→    }\n   306→    jsonOutput({ status: allPassed ? 'ok' : 'fail', checks: checksObj });\n   307→  } else {\n   308→    for (const c of checks) {\n   309→      const prefix = c.status === 'ok' ? '[OK]' : '[FAIL]';\n   310→      const label = c.name.replace(/_/g, ' ');\n   311→      console.log(`${prefix} ${label[0].toUpperCase() + label.slice(1)}: ${c.detail}`);\n   312→    }\n   313→  }\n   314→\n   315→  process.exitCode = allPassed ? 0 : 1;\n   316→}\n   317→\n   318→// ─── Docker Check ───────────────────────────────────────────────────────────\n   319→\n   320→export async function handleDockerCheck(isJson: boolean): Promise<void> {\n   321→  let state: HarnessState | null = null;\n   322→  try {\n   323→    state = readState();\n   324→  } catch {\n   325→    // No state file or corrupted\n   326→  }\n   327→\n   328→  const mode = state?.otlp?.mode ?? 'local-shared';\n   329→\n   330→  if (mode === 'remote-direct') {\n   331→    const endpoint = state?.otlp?.endpoint ?? '';\n   332→    const result = await checkRemoteEndpoint(endpoint);\n   333→    if (isJson) {\n   334→      jsonOutput({\n   335→        status: result.reachable ? 'ok' : 'fail',\n   336→        mode: 'remote-direct',\n   337→        endpoint,\n   338→        reachable: result.reachable,\n   339→        ...(result.error ? { error: result.error } : {}),\n   340→      });\n   341→    } else {\n   342→      if (result.reachable) {\n   343→        ok(`Remote OTLP endpoint: reachable (${endpoint})`);\n   344→      } else {\n   345→        fail(`Remote OTLP endpoint: unreachable (${endpoint})`);\n   346→        if (result.error) {\n   347→          info(`Error: ${result.error}`);\n   348→        }\n   349→      }\n   350→    }\n   351→    return;\n   352→  }\n   353→\n   354→  if (mode === 'remote-routed') {\n   355→    const sharedComposeFile = getComposeFilePath();\n   356→    const health = getCollectorHealth(sharedComposeFile);\n   357→\n   358→    if (isJson) {\n   359→      jsonOutput({\n   360→        status: health.healthy ? 'ok' : 'fail',\n   361→        mode: 'remote-routed',\n   362→        docker: {\n   363→          healthy: health.healthy,\n   364→          services: health.services,\n   365→          remedy: health.remedy,\n   366→        },\n   367→        remote_endpoints: state?.docker?.remote_endpoints,\n   368→      });\n   369→    } else {\n   370→      if (health.healthy) {\n   371→        ok('OTel Collector: running');\n   372→      } else {\n   373→        fail('OTel Collector: not running');\n   374→        if (health.remedy) {\n   375→          info(`-> ${health.remedy}`);\n   376→        }\n   377→      }\n   378→      const re = state?.docker?.remote_endpoints;\n   379→      if (re) {\n   380→        info(`Remote backends: logs=${re.logs_url} metrics=${re.metrics_url} traces=${re.traces_url}`);\n   381→      }\n   382→    }\n   383→    return;\n   384→  }\n   385→\n   386→  // local-shared mode (default)\n   387→  let composeFile = 'docker-compose.harness.yml';\n   388→  let projectName: string | undefined;\n   389→\n   390→  if (state?.docker?.compose_file) {\n   391→    composeFile = state.docker.compose_file;\n   392→  }\n   393→\n   394→  const stackDir = getStackDir();\n   395→  if (composeFile.startsWith(stackDir)) {\n   396→    composeFile = getComposeFilePath();\n   397→    projectName = 'codeharness-shared';\n   398→  }\n   399→\n   400→  const health = getStackHealth(composeFile, projectName);\n   401→\n   402→  if (isJson) {\n   403→    jsonOutput({\n   404→      status: health.healthy ? 'ok' : 'fail',\n   405→      ...(projectName ? { project_name: projectName } : {}),\n   406→      docker: {\n   407→        healthy: health.healthy,\n   408→        services: health.services,\n   409→        remedy: health.remedy,\n   410→      },\n   411→      ...(health.healthy ? { endpoints: DEFAULT_ENDPOINTS } : {}),\n   412→    });\n   413→    return;\n   414→  }\n   415→\n   416→  if (health.healthy) {\n   417→    ok(`VictoriaMetrics stack: running${projectName ? ` (project: ${projectName})` : ''}`);\n   418→    for (const svc of health.services) {\n   419→      info(`  ${svc.name}: ${svc.running ? 'running' : 'stopped'}`);\n   420→    }\n   421→    info(`Endpoints: logs=${DEFAULT_ENDPOINTS.logs} metrics=${DEFAULT_ENDPOINTS.metrics} traces=${DEFAULT_ENDPOINTS.traces}`);\n   422→  } else {\n   423→    fail(`VictoriaMetrics stack: not running${projectName ? ` (project: ${projectName})` : ''}`);\n   424→    for (const svc of health.services) {\n   425→      if (!svc.running) {\n   426→        info(`  ${svc.name}: down`);\n   427→      }\n   428→    }\n   429→    if (health.remedy) {\n   430→      info(`-> ${health.remedy}`);\n   431→    }\n   432→  }\n   433→}\n   434→\n   435→// ─── Sprint State Helpers ────────────────────────────────────────────────────\n   436→\n   437→function printSprintState(): void {\n   438→  const reportResult = generateReport();\n   439→  if (!reportResult.success) {\n   440→    console.log('Sprint state: unavailable');\n   441→    return;\n   442→  }\n   443→\n   444→  const r = reportResult.data;\n   445→  console.log(`\\u2500\\u2500 Project State \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500`);\n   446→  console.log(`Sprint: ${r.done}/${r.total} done (${r.sprintPercent}%) | ${r.epicsDone}/${r.epicsTotal} epics complete`);\n   447→\n   448→  if (r.activeRun) {\n   449→    console.log('');\n   450→    console.log(`\\u2500\\u2500 Active Run \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500`);\n   451→    const currentStory = r.inProgress ?? 'none';\n   452→    console.log(`Status: running (iteration ${r.activeRun.iterations}, ${r.activeRun.duration} elapsed)`);\n   453→    console.log(`Current: ${currentStory}`);\n   454→    console.log(`Budget: $${r.activeRun.cost.toFixed(2)} spent`);\n   455→  } else if (r.lastRun) {\n   456→    console.log('');\n   457→    console.log(`\\u2500\\u2500 Last Run Summary \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500`);\n   458→    console.log(`Duration: ${r.lastRun.duration} | Cost: $${r.lastRun.cost.toFixed(2)} | Iterations: ${r.lastRun.iterations}`);\n   459→    console.log(`Completed:  ${r.lastRun.completed.length} stories${r.lastRun.completed.length > 0 ? ` (${r.lastRun.completed.join(', ')})` : ''}`);\n   460→    if (r.failedDetails.length > 0) {\n   461→      console.log(`Failed:     ${r.failedDetails.length} stor${r.failedDetails.length === 1 ? 'y' : 'ies'}`);\n   462→      for (const fd of r.failedDetails) {\n   463→        const acPart = fd.acNumber !== null ? `AC ${fd.acNumber}` : 'unknown AC';\n   464→        console.log(`  \\u2514 ${fd.key}: ${acPart} \\u2014 ${fd.errorLine} (attempt ${fd.attempts}/${fd.maxAttempts})`);\n   465→      }\n   466→    }\n   467→    if (r.lastRun.blocked.length > 0) {\n   468→      console.log(`Blocked:    ${r.lastRun.blocked.length} stories (retry-exhausted)`);\n   469→    }\n   470→  }\n   471→\n   472→  if (r.actionItemsLabeled.length > 0) {\n   473→    console.log('');\n   474→    console.log(`\\u2500\\u2500 Action Items \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500`);\n   475→    for (const la of r.actionItemsLabeled) {\n   476→      console.log(`  [${la.label}] ${la.item.story}: ${la.item.description}`);\n   477→    }\n   478→  }\n   479→\n   480→  console.log('');\n   481→}\n   482→\n   483→function printValidationProgress(): void {\n   484→  const result = getValidationProgress();\n   485→  if (!result.success) return;\n   486→  const p = result.data;\n   487→  if (p.total === 0) return;\n   488→  console.log(`Validation: ${p.passed}/${p.total} passed, ${p.failed} failed, ${p.blocked} blocked, ${p.remaining} remaining`);\n   489→}\n   490→\n   491→function getSprintReportData(): StatusReport | null {\n   492→  const reportResult = generateReport();\n   493→  if (!reportResult.success) return null;\n   494→  return reportResult.data;\n   495→}\n   496→\n   497→// ─── Beads Helpers ──────────────────────────────────────────────────────────\n   498→\n   499→function printBeadsSummary(): void {\n   500→  if (!isBeadsInitialized()) {\n   501→    console.log('Beads: not initialized');\n   502→    return;\n   503→  }\n   504→\n   505→  try {\n   506→    const issues = listIssues();\n   507→    const byType = new Map<string, number>();\n   508→    const byStatus = new Map<string, number>();\n   509→\n   510→    for (const issue of issues) {\n   511→      byType.set(issue.type, (byType.get(issue.type) ?? 0) + 1);\n   512→      byStatus.set(issue.status, (byStatus.get(issue.status) ?? 0) + 1);\n   513→    }\n   514→\n   515→    const typeParts = Array.from(byType.entries())\n   516→      .map(([t, n]) => `${t}:${n}`)\n   517→      .join(' ');\n   518→    const ready = byStatus.get('ready') ?? 0;\n   519→    const inProgress = byStatus.get('in_progress') ?? 0;\n   520→    const done = byStatus.get('done') ?? 0;\n   521→\n   522→    const typeInfo = typeParts ? ` (${typeParts})` : '';\n   523→    console.log(\n   524→      `Beads: ${issues.length} issues${typeInfo} | ready:${ready} in-progress:${inProgress} done:${done}`,\n   525→    );\n   526→  } catch {\n   527→    console.log('Beads: unavailable (bd command failed)');\n   528→  }\n   529→}\n   530→\n   531→function printOnboardingProgress(): void {\n   532→  const progress = getOnboardingProgress({ listIssues });\n   533→  if (progress) {\n   534→    console.log(`Onboarding: ${progress.resolved}/${progress.total} gaps resolved (${progress.remaining} remaining)`);\n   535→  }\n   536→}\n   537→\n   538→function getOnboardingProgressData(): Record<string, unknown> | null {\n   539→  const progress = getOnboardingProgress({ listIssues });\n   540→  if (!progress) {\n   541→    return null;\n   542→  }\n   543→  return {\n   544→    total: progress.total,\n   545→    resolved: progress.resolved,\n   546→    remaining: progress.remaining,\n   547→  };\n   548→}\n   549→\n   550→function getBeadsData(): Record<string, unknown> {\n   551→  if (!isBeadsInitialized()) {\n   552→    return { initialized: false };\n   553→  }\n   554→\n   555→  try {\n   556→    const issues = listIssues();\n   557→    const issuesByType: Record<string, number> = {};\n   558→    const issuesByStatus: Record<string, number> = {};\n   559→\n   560→    for (const issue of issues) {\n   561→      issuesByType[issue.type] = (issuesByType[issue.type] ?? 0) + 1;\n   562→      issuesByStatus[issue.status] = (issuesByStatus[issue.status] ?? 0) + 1;\n   563→    }\n   564→\n   565→    return {\n   566→      initialized: true,\n   567→      total: issues.length,\n   568→      issues_by_type: issuesByType,\n   569→      issues_by_status: issuesByStatus,\n   570→    };\n   571→  } catch {\n   572→    return { initialized: true, error: 'bd command failed' };\n   573→  }\n   574→}\n   575→"}]},"parent_tool_use_id":"toolu_01GEPRaZucE7UgpGJiPm4ARu","session_id":"790cd04c-5c91-45bb-998d-78a56b65af9a","uuid":"aaf4b5f2-ac8f-499a-85f6-762b5d937118","timestamp":"2026-03-24T23:06:35.355Z"}
