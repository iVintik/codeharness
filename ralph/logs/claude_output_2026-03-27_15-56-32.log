{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016sfjDQkLVbMFzAnnmZ7sar","type":"tool_result","content":"     1→/**\n     2→ * Validation AC Registry — barrel export for all 79 validation acceptance criteria.\n     3→ * Data is split across validation-ac-types.ts and validation-ac-data.ts to comply with NFR18.\n     4→ *\n     5→ * Story 10-1: Validation AC Suite\n     6→ */\n     7→\n     8→export type { ValidationAC, VerificationMethod, AcCategory } from './validation-ac-types.js';\n     9→\n    10→import { FR_ACS, NFR_ACS, UX_ACS, REGRESSION_ACS, ACTION_ITEM_ACS } from './validation-ac-data.js';\n    11→import type { ValidationAC, AcCategory } from './validation-ac-types.js';\n    12→\n    13→// Re-export category arrays for direct access\n    14→export { FR_ACS, NFR_ACS, UX_ACS, REGRESSION_ACS, ACTION_ITEM_ACS } from './validation-ac-data.js';\n    15→\n    16→/**\n    17→ * Complete validation AC registry — 79 entries covering all FRs, NFRs, UX, regression, and action items.\n    18→ */\n    19→export const VALIDATION_ACS: readonly ValidationAC[] = [\n    20→  ...FR_ACS,\n    21→  ...NFR_ACS,\n    22→  ...UX_ACS,\n    23→  ...REGRESSION_ACS,\n    24→  ...ACTION_ITEM_ACS,\n    25→];\n    26→\n    27→// ─── Helper Functions ────────────────────────────────────────────────────────\n    28→\n    29→/** Get all ACs for a specific category */\n    30→export function getACsByCategory(category: AcCategory): readonly ValidationAC[] {\n    31→  return VALIDATION_ACS.filter(ac => ac.category === category);\n    32→}\n    33→\n    34→/**\n    35→ * Get all test-provable ACs (verificationMethod === 'cli').\n    36→ * These ACs correspond to the `test-provable` verification tier.\n    37→ */\n    38→export function getTestProvableACs(): readonly ValidationAC[] {\n    39→  return VALIDATION_ACS.filter(ac => ac.verificationMethod === 'cli');\n    40→}\n    41→\n    42→/**\n    43→ * Get all environment-provable ACs (verificationMethod === 'integration').\n    44→ * These ACs correspond to the `environment-provable` verification tier.\n    45→ */\n    46→export function getEnvironmentProvableACs(): readonly ValidationAC[] {\n    47→  return VALIDATION_ACS.filter(ac => ac.verificationMethod === 'integration');\n    48→}\n    49→\n    50→/** @deprecated Use `getTestProvableACs()` instead. */\n    51→export function getCliVerifiableACs(): readonly ValidationAC[] {\n    52→  return getTestProvableACs();\n    53→}\n    54→\n    55→/** @deprecated Use `getEnvironmentProvableACs()` instead. */\n    56→export function getIntegrationRequiredACs(): readonly ValidationAC[] {\n    57→  return getEnvironmentProvableACs();\n    58→}\n    59→\n    60→/** Get a single AC by ID */\n    61→export function getACById(id: number): ValidationAC | undefined {\n    62→  return VALIDATION_ACS.find(ac => ac.id === id);\n    63→}\n    64→"}]},"parent_tool_use_id":"toolu_01WTx8j9hk9cZfjCVrJFg5MD","session_id":"f9b706e3-1764-4868-a4a5-c90b37d26d0d","uuid":"f66c5b17-d08d-419b-bde8-9c8a7e4376ae","timestamp":"2026-03-27T12:04:11.546Z"}
