n158\t      type: 'result' as const,\n159\t      cost: 0.05,\n160\t      sessionId,\n161\t      ...(opts?.error ? { error: opts.error, errorCategory: opts.errorCategory ?? 'UNKNOWN' } : {}),\n162\t    };\n163\t  })();\n164\t}\n165\t\n166\t/**\n167\t * Helper: create an async iterable that throws an error (for testing dispatch failures).\n168\t */\n169\tfunction makeDriverStreamError(err: unknown) {\n170\t  return (async function* () {\n171\t    throw err;\n172\t  })();\n173\t}\n174\t\n175\tfunction makeDefaultState(overrides?: Partial<WorkflowState>): WorkflowState {\n176\t  return {\n177\t    workflow_name: '',\n178\t    started: '',\n179\t    iteration: 0,\n180\t    phase: 'idle',\n181\t    tasks_completed: [],\n182\t    evaluator_scores: [],\n183\t    circuit_breaker: { triggered: false, reason: null, score_history: [] },\n184\t    trace_ids: [],\n185\t    ...overrides,\n186\t  };\n187\t}\n188\t\n189\tfunction makeDefinition(overrides?: Partial<SubagentDefinition>): SubagentDefinition {\n190\t  return {\n191\t    name: 'test-agent',\n192\t    model: 'claude-sonnet-4-20250514',\n193\t    instructions: 'You are a test agent.',\n194\t    disallowedTools: [],\n195\t    bare: true,\n196\t    ...overrides,\n197\t  };\n198\t}\n199\t"}]},"parent_tool_use_id":"toolu_01E368mBox6AGS9E4aPFSS48","session_id":"8a461711-53e2-475a-88dd-c7013f6080c5","uuid":"ab5205a4-2c6e-419d-9312-ff4ded528ce8","timestamp":"2026-04-03T17:13:30.201Z"}
