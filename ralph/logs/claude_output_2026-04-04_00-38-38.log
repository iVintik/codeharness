run command registration', () => {\n700\t    it('registers the run command with correct options', async () => {\n701\t      const { registerRunCommand } = await import('../run.js');\n702\t      const program = new Command();\n703\t      program.option('--json', 'JSON output');\n704\t      registerRunCommand(program);\n705\t\n706\t      const runCmd = program.commands.find(c => c.name() === 'run');\n707\t      expect(runCmd).toBeDefined();\n708\t      expect(runCmd!.description()).toBe('Execute the autonomous coding loop');\n709\t\n710\t      const optionNames = runCmd!.options.map(o => o.long);\n711\t      expect(optionNames).toContain('--max-iterations');\n712\t      expect(optionNames).toContain('--timeout');\n713\t      expect(optionNames).toContain('--quiet');\n714\t      expect(optionNames).toContain('--max-story-retries');\n715\t      expect(optionNames).toContain('--resume');\n716\t      expect(optionNames).toContain('--workflow');\n717\t    });\n718\t\n719\t    it('--max-story-retries defaults to 10', async () => {\n720\t      const { registerRunCommand } = await import('../run.js');\n721\t      const program = new Command();\n722\t      program.option('--json', 'JSON output');\n723\t      registerRunCommand(program);\n724\t\n725\t      const runCmd = program.commands.find(c => c.name() === 'run');\n726\t      const retryOpt = runCmd!.options.find(o => o.long === '--max-story-retries');\n727\t      expect(retryOpt!.defaultValue).toBe('10');\n728\t    });\n729\t  });\n730\t\n731\t  describe('source code verification', () => {\n732\t    it('run.ts does not import spawn from node:child_process', () => {\n733\t      const runSource = origReadFileSync(\n734\t        join(process.cwd(), 'src', 'commands', 'run.ts'),\n735\t        'utf-8',\n736\t      );\n737\t      expect(runSource).not.toContain(\"from 'node:child_process'\");\n738\t    });\n739\t\n740\t    it('run.ts does not import buildSpawnArgs or resolveRalphPath', () => {\n741\t      const runSource = origR