{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_018zKmb8xjPnD21kPYmJfgwo","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01U9dmzGwHMcHdMUuHrgCyJP","name":"Write","input":{"file_path":"/Users/ivintik/dev/personal/codeharness/src/lib/hierarchical-flow.ts","content":"import type { ResolvedTask, FlowStep, LoopBlock } from './workflow-parser.js';\n\n// --- Interfaces ---\n\nexport interface ExecutionConfig {\n  max_parallel: number;\n  isolation: 'worktree' | 'none';\n  merge_strategy: 'rebase' | 'merge-commit';\n  epic_strategy: 'parallel' | 'sequential';\n  story_strategy: 'sequential' | 'parallel';\n}\n\nexport interface HierarchicalFlow {\n  execution: ExecutionConfig;\n  storyFlow: FlowStep[];\n  epicFlow: FlowStep[];\n  tasks: Record<string, ResolvedTask>;\n}\n\n// --- Constants ---\n\n/** Built-in epic flow task names that do not need entries in `tasks:`. */\nexport const BUILTIN_EPIC_FLOW_TASKS = new Set(['merge', 'validate']);\n\n/** Default execution configuration values. */\nexport const EXECUTION_DEFAULTS: ExecutionConfig = {\n  max_parallel: 1,\n  isolation: 'none',\n  merge_strategy: 'merge-commit',\n  epic_strategy: 'sequential',\n  story_strategy: 'sequential',\n};\n\n// --- Resolution ---\n\n/**\n * Resolve a parsed workflow YAML object into a HierarchicalFlow.\n *\n * Handles three cases:\n * 1. Legacy: only `flow` present → normalized to `storyFlow`\n * 2. Hierarchical: `story_flow` (and optionally `epic_flow`, `execution`) present\n * 3. Conflict: both `flow` and `story_flow` → rejected with error\n *\n * This is a pure parsing/normalization function with no side effects.\n */\nexport function resolveHierarchicalFlow(\n  parsed: Record<string, unknown>,\n  resolvedTasks: Record<string, ResolvedTask>,\n): HierarchicalFlow {\n  const hasFlow = 'flow' in parsed && parsed.flow !== undefined;\n  const hasStoryFlow = 'story_flow' in parsed && parsed.story_flow !== undefined;\n\n  // Reject coexistence of flow and story_flow\n  if (hasFlow && hasStoryFlow) {\n    throw new HierarchicalFlowError(\n      'Workflow cannot have both \"flow\" and \"story_flow\" — use \"story_flow\" for hierarchical workflows or \"flow\" for legacy mode',\n    );\n  }\n\n  // Resolve execution config with defaults\n  const rawExecution = (parsed.execution ?? {}) as Record<string, unknown>;\n  const execution: ExecutionConfig = {\n    max_parallel: (rawExecution.max_parallel as number) ?? EXECUTION_DEFAULTS.max_parallel,\n    isolation: (rawExecution.isolation as ExecutionConfig['isolation']) ?? EXECUTION_DEFAULTS.isolation,\n    merge_strategy: (rawExecution.merge_strategy as ExecutionConfig['merge_strategy']) ?? EXECUTION_DEFAULTS.merge_strategy,\n    epic_strategy: (rawExecution.epic_strategy as ExecutionConfig['epic_strategy']) ?? EXECUTION_DEFAULTS.epic_strategy,\n    story_strategy: (rawExecution.story_strategy as ExecutionConfig['story_strategy']) ?? EXECUTION_DEFAULTS.story_strategy,\n  };\n\n  // Resolve story flow\n  const rawStoryFlow = (hasStoryFlow ? parsed.story_flow : parsed.flow) as unknown[] | undefined;\n  const storyFlow: FlowStep[] = (rawStoryFlow ?? []).map((step) => {\n    if (typeof step === 'string') return step;\n    return step as LoopBlock;\n  });\n\n  // Resolve epic flow\n  const rawEpicFlow = (parsed.epic_flow ?? []) as unknown[];\n  const epicFlow: FlowStep[] = rawEpicFlow.map((step) => {\n    if (typeof step === 'string') return step;\n    return step as LoopBlock;\n  });\n\n  return {\n    execution,\n    storyFlow,\n    epicFlow,\n    tasks: resolvedTasks,\n  };\n}\n\n// --- Error Class ---\n\nexport class HierarchicalFlowError extends Error {\n  constructor(message: string) {\n    super(message);\n    this.name = 'HierarchicalFlowError';\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1606,"cache_read_input_tokens":38497,"cache_creation":{"ephemeral_5m_input_tokens":1606,"ephemeral_1h_input_tokens":0},"output_tokens":6,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01EPUyrKtMjV9xapMgmPR8xK","session_id":"9c9fe147-c536-4d36-9f64-8249f0c68839","uuid":"4418a0f0-79ba-48d8-997d-f13a4efcdc57"}
