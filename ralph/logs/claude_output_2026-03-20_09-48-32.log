{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012ER4LEzQjV9srMGyqvmkzB","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→\n     3→vi.mock('node:fs', () => ({\n     4→  readFileSync: vi.fn(),\n     5→  writeFileSync: vi.fn(),\n     6→  renameSync: vi.fn(),\n     7→  existsSync: vi.fn(),\n     8→}));\n     9→\n    10→import { checkObservabilityCoverageGate } from '../coverage-gate.js';\n    11→import {\n    12→  checkObservabilityCoverageGate as barrelGate,\n    13→  type ObservabilityCoverageGateResult,\n    14→} from '../index.js';\n    15→import { readFileSync, existsSync } from 'node:fs';\n    16→\n    17→const mockReadFileSync = vi.mocked(readFileSync);\n    18→const mockExistsSync = vi.mocked(existsSync);\n    19→\n    20→beforeEach(() => {\n    21→  vi.resetAllMocks();\n    22→});\n    23→\n    24→function makeState(obs: Record<string, unknown>): string {\n    25→  return JSON.stringify({\n    26→    version: 1,\n    27→    sprint: { total: 0, done: 0 },\n    28→    observability: obs,\n    29→  });\n    30→}\n    31→\n    32→// ============================================================\n    33→// Module barrel exports\n    34→// ============================================================\n    35→\n    36→describe('module barrel exports', () => {\n    37→  it('re-exports checkObservabilityCoverageGate from index.ts', () => {\n    38→    expect(barrelGate).toBe(checkObservabilityCoverageGate);\n    39→  });\n    40→});\n    41→\n    42→// ============================================================\n    43→// Gate passes\n    44→// ============================================================\n    45→\n    46→describe('checkObservabilityCoverageGate — pass scenarios', () => {\n    47→  it('passes when static >= 80% and runtime >= 60%', () => {\n    48→    mockExistsSync.mockReturnValue(true);\n    49→    mockReadFileSync.mockReturnValue(\n    50→      makeState({\n    51→        static: { coveragePercent: 85, lastScanTimestamp: '', history: [] },\n    52→        runtime: {\n    53→          coveragePercent: 65,\n    54→          lastValidationTimestamp: '',\n    55→          modulesWithTelemetry: 3,\n    56→          totalModules: 5,\n    57→          telemetryDetected: true,\n    58→        },\n    59→        targets: { staticTarget: 80, runtimeTarget: 60 },\n    60→      }),\n    61→    );\n    62→\n    63→    const result = checkObservabilityCoverageGate('/project');\n    64→    expect(result.success).toBe(true);\n    65→    if (result.success) {\n    66→      expect(result.data.passed).toBe(true);\n    67→      expect(result.data.staticResult.met).toBe(true);\n    68→      expect(result.data.staticResult.current).toBe(85);\n    69→      expect(result.data.staticResult.target).toBe(80);\n    70→      expect(result.data.staticResult.gap).toBe(0);\n    71→      expect(result.data.runtimeResult).not.toBeNull();\n    72→      expect(result.data.runtimeResult!.met).toBe(true);\n    73→      expect(result.data.runtimeResult!.current).toBe(65);\n    74→    }\n    75→  });\n    76→\n    77→  it('passes when runtime is absent (no verification yet)', () => {\n    78→    mockExistsSync.mockReturnValue(true);\n    79→    mockReadFileSync.mockReturnValue(\n    80→      makeState({\n    81→        static: { coveragePercent: 82, lastScanTimestamp: '', history: [] },\n    82→        targets: { staticTarget: 80 },\n    83→      }),\n    84→    );\n    85→\n    86→    const result = checkObservabilityCoverageGate('/project');\n    87→    expect(result.success).toBe(true);\n    88→    if (result.success) {\n    89→      expect(result.data.passed).toBe(true);\n    90→      expect(result.data.runtimeResult).toBeNull();\n    91→    }\n    92→  });\n    93→\n    94→  it('passes when coverage equals target exactly', () => {\n    95→    mockExistsSync.mockReturnValue(true);\n    96→    mockReadFileSync.mockReturnValue(\n    97→      makeState({\n    98→        static: { coveragePercent: 80, lastScanTimestamp: '', history: [] },\n    99→        targets: { staticTarget: 80 },\n   100→      }),\n   101→    );\n   102→\n   103→    const result = checkObservabilityCoverageGate('/project');\n   104→    expect(result.success).toBe(true);\n   105→    if (result.success) {\n   106→      expect(result.data.passed).toBe(true);\n   107→      expect(result.data.staticResult.met).toBe(true);\n   108→      expect(result.data.staticResult.gap).toBe(0);\n   109→    }\n   110→  });\n   111→});\n   112→\n   113→// ============================================================\n   114→// Gate fails\n   115→// ============================================================\n   116→\n   117→describe('checkObservabilityCoverageGate — fail scenarios', () => {\n   118→  it('fails when static is 72% (below 80% target)', () => {\n   119→    mockExistsSync.mockReturnValue(true);\n   120→    mockReadFileSync.mockReturnValue(\n   121→      makeState({\n   122→        static: { coveragePercent: 72, lastScanTimestamp: '', history: [] },\n   123→        targets: { staticTarget: 80 },\n   124→      }),\n   125→    );\n   126→\n   127→    const result = checkObservabilityCoverageGate('/project');\n   128→    expect(result.success).toBe(true);\n   129→    if (result.success) {\n   130→      expect(result.data.passed).toBe(false);\n   131→      expect(result.data.staticResult.met).toBe(false);\n   132→      expect(result.data.staticResult.current).toBe(72);\n   133→      expect(result.data.staticResult.target).toBe(80);\n   134→      expect(result.data.staticResult.gap).toBe(8);\n   135→    }\n   136→  });\n   137→\n   138→  it('fails when runtime is 50% (below 60% target)', () => {\n   139→    mockExistsSync.mockReturnValue(true);\n   140→    mockReadFileSync.mockReturnValue(\n   141→      makeState({\n   142→        static: { coveragePercent: 85, lastScanTimestamp: '', history: [] },\n   143→        runtime: {\n   144→          coveragePercent: 50,\n   145→          lastValidationTimestamp: '',\n   146→          modulesWithTelemetry: 1,\n   147→          totalModules: 2,\n   148→          telemetryDetected: true,\n   149→        },\n   150→        targets: { staticTarget: 80, runtimeTarget: 60 },\n   151→      }),\n   152→    );\n   153→\n   154→    const result = checkObservabilityCoverageGate('/project');\n   155→    expect(result.success).toBe(true);\n   156→    if (result.success) {\n   157→      expect(result.data.passed).toBe(false);\n   158→      expect(result.data.staticResult.met).toBe(true);\n   159→      expect(result.data.runtimeResult).not.toBeNull();\n   160→      expect(result.data.runtimeResult!.met).toBe(false);\n   161→      expect(result.data.runtimeResult!.current).toBe(50);\n   162→      expect(result.data.runtimeResult!.target).toBe(60);\n   163→      expect(result.data.runtimeResult!.gap).toBe(10);\n   164→    }\n   165→  });\n   166→\n   167→  it('fails when both static and runtime are below targets', () => {\n   168→    mockExistsSync.mockReturnValue(true);\n   169→    mockReadFileSync.mockReturnValue(\n   170→      makeState({\n   171→        static: { coveragePercent: 70, lastScanTimestamp: '', history: [] },\n   172→        runtime: {\n   173→          coveragePercent: 40,\n   174→          lastValidationTimestamp: '',\n   175→          modulesWithTelemetry: 0,\n   176→          totalModules: 2,\n   177→          telemetryDetected: false,\n   178→        },\n   179→        targets: { staticTarget: 80, runtimeTarget: 60 },\n   180→      }),\n   181→    );\n   182→\n   183→    const result = checkObservabilityCoverageGate('/project');\n   184→    expect(result.success).toBe(true);\n   185→    if (result.success) {\n   186→      expect(result.data.passed).toBe(false);\n   187→      expect(result.data.staticResult.met).toBe(false);\n   188→      expect(result.data.runtimeResult!.met).toBe(false);\n   189→    }\n   190→  });\n   191→});\n   192→\n   193→// ============================================================\n   194→// Custom target overrides\n   195→// ============================================================\n   196→\n   197→describe('checkObservabilityCoverageGate — custom overrides', () => {\n   198→  it('uses custom static target override', () => {\n   199→    mockExistsSync.mockReturnValue(true);\n   200→    mockReadFileSync.mockReturnValue(\n   201→      makeState({\n   202→        static: { coveragePercent: 72, lastScanTimestamp: '', history: [] },\n   203→        targets: { staticTarget: 80 },\n   204→      }),\n   205→    );\n   206→\n   207→    // 72% passes a 70% target\n   208→    const result = checkObservabilityCoverageGate('/project', { staticTarget: 70 });\n   209→    expect(result.success).toBe(true);\n   210→    if (result.success) {\n   211→      expect(result.data.passed).toBe(true);\n   212→      expect(result.data.staticResult.met).toBe(true);\n   213→      expect(result.data.staticResult.target).toBe(70);\n   214→    }\n   215→  });\n   216→\n   217→  it('uses custom runtime target override', () => {\n   218→    mockExistsSync.mockReturnValue(true);\n   219→    mockReadFileSync.mockReturnValue(\n   220→      makeState({\n   221→        static: { coveragePercent: 85, lastScanTimestamp: '', history: [] },\n   222→        runtime: {\n   223→          coveragePercent: 50,\n   224→          lastValidationTimestamp: '',\n   225→          modulesWithTelemetry: 1,\n   226→          totalModules: 2,\n   227→          telemetryDetected: true,\n   228→        },\n   229→        targets: { staticTarget: 80, runtimeTarget: 60 },\n   230→      }),\n   231→    );\n   232→\n   233→    // 50% passes a 50% target\n   234→    const result = checkObservabilityCoverageGate('/project', { runtimeTarget: 50 });\n   235→    expect(result.success).toBe(true);\n   236→    if (result.success) {\n   237→      expect(result.data.passed).toBe(true);\n   238→      expect(result.data.runtimeResult!.met).toBe(true);\n   239→      expect(result.data.runtimeResult!.target).toBe(50);\n   240→    }\n   241→  });\n   242→});\n   243→\n   244→// ============================================================\n   245→// Gap summary\n   246→// ============================================================\n   247→\n   248→describe('checkObservabilityCoverageGate — gap summary', () => {\n   249→  it('returns empty gap list (gaps come from analyzer, not gate)', () => {\n   250→    mockExistsSync.mockReturnValue(true);\n   251→    mockReadFileSync.mockReturnValue(\n   252→      makeState({\n   253→        static: { coveragePercent: 72, lastScanTimestamp: '', history: [] },\n   254→        targets: { staticTarget: 80 },\n   255→      }),\n   256→    );\n   257→\n   258→    const result = checkObservabilityCoverageGate('/project');\n   259→    expect(result.success).toBe(true);\n   260→    if (result.success) {\n   261→      expect(result.data.gapSummary).toEqual([]);\n   262→    }\n   263→  });\n   264→});\n   265→\n   266→// ============================================================\n   267→// Error handling\n   268→// ============================================================\n   269→\n   270→describe('checkObservabilityCoverageGate — errors', () => {\n   271→  it('rejects empty projectDir', () => {\n   272→    const result = checkObservabilityCoverageGate('');\n   273→    expect(result.success).toBe(false);\n   274→    if (!result.success) {\n   275→      expect(result.error).toContain('projectDir is required');\n   276→    }\n   277→  });\n   278→\n   279→  it('propagates state read errors', () => {\n   280→    mockExistsSync.mockReturnValue(true);\n   281→    mockReadFileSync.mockImplementation(() => {\n   282→      throw new Error('EACCES');\n   283→    });\n   284→\n   285→    const result = checkObservabilityCoverageGate('/project');\n   286→    expect(result.success).toBe(false);\n   287→    if (!result.success) {\n   288→      expect(result.error).toContain('Failed to read sprint-state.json');\n   289→    }\n   290→  });\n   291→\n   292→  it('uses default targets when no state file exists', () => {\n   293→    mockExistsSync.mockReturnValue(false);\n   294→\n   295→    const result = checkObservabilityCoverageGate('/project');\n   296→    expect(result.success).toBe(true);\n   297→    if (result.success) {\n   298→      // 0% coverage vs 80% default target = fail\n   299→      expect(result.data.passed).toBe(false);\n   300→      expect(result.data.staticResult.target).toBe(80);\n   301→      expect(result.data.staticResult.current).toBe(0);\n   302→    }\n   303→  });\n   304→\n   305→  it('uses default runtime target (60) when not specified in state', () => {\n   306→    mockExistsSync.mockReturnValue(true);\n   307→    mockReadFileSync.mockReturnValue(\n   308→      makeState({\n   309→        static: { coveragePercent: 85, lastScanTimestamp: '', history: [] },\n   310→        runtime: {\n   311→          coveragePercent: 55,\n   312→          lastValidationTimestamp: '',\n   313→          modulesWithTelemetry: 1,\n   314→          totalModules: 2,\n   315→          telemetryDetected: true,\n   316→        },\n   317→        targets: { staticTarget: 80 },\n   318→        // Note: no runtimeTarget in targets\n   319→      }),\n   320→    );\n   321→\n   322→    const result = checkObservabilityCoverageGate('/project');\n   323→    expect(result.success).toBe(true);\n   324→    if (result.success) {\n   325→      expect(result.data.runtimeResult!.target).toBe(60);\n   326→      expect(result.data.runtimeResult!.met).toBe(false);\n   327→    }\n   328→  });\n   329→});\n   330→"}]},"parent_tool_use_id":"toolu_01L7x1Zkv5Yv1DsfgSndzqDQ","session_id":"f7a66acd-0cc1-40de-a592-d59e75273c0b","uuid":"dc6bdddd-10d6-4851-b03e-a3d787fd7cb4","timestamp":"2026-03-20T06:00:23.612Z"}
