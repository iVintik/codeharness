{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HKaFy1CF8Q1EyUvyEyze4N","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { generateRalphPrompt } from '../ralph-prompt.js';\n     3→\n     4→describe('ralph-prompt', () => {\n     5→  const config = {\n     6→    projectDir: '/home/user/myproject',\n     7→    sprintStatusPath: '/home/user/myproject/_bmad-output/implementation-artifacts/sprint-status.yaml',\n     8→  };\n     9→\n    10→  describe('generateRalphPrompt', () => {\n    11→    it('returns a non-empty string', () => {\n    12→      const prompt = generateRalphPrompt(config);\n    13→      expect(prompt).toBeTruthy();\n    14→      expect(typeof prompt).toBe('string');\n    15→      expect(prompt.length).toBeGreaterThan(100);\n    16→    });\n    17→\n    18→    it('contains /harness-run instruction', () => {\n    19→      const prompt = generateRalphPrompt(config);\n    20→      expect(prompt).toContain('/harness-run');\n    21→    });\n    22→\n    23→    it('contains the sprint-status.yaml path', () => {\n    24→      const prompt = generateRalphPrompt(config);\n    25→      expect(prompt).toContain(config.sprintStatusPath);\n    26→    });\n    27→\n    28→    it('contains the project directory', () => {\n    29→      const prompt = generateRalphPrompt(config);\n    30→      expect(prompt).toContain(config.projectDir);\n    31→    });\n    32→\n    33→    it('contains BMAD workflow instructions', () => {\n    34→      const prompt = generateRalphPrompt(config);\n    35→      expect(prompt).toContain('BMAD');\n    36→    });\n    37→\n    38→    it('instructs to update sprint-status.yaml', () => {\n    39→      const prompt = generateRalphPrompt(config);\n    40→      expect(prompt).toContain('sprint-status.yaml');\n    41→      expect(prompt).toContain('update');\n    42→    });\n    43→\n    44→    it('mentions verification gates', () => {\n    45→      const prompt = generateRalphPrompt(config);\n    46→      expect(prompt).toContain('verification');\n    47→    });\n    48→\n    49→    it('contains codeharness verify instruction', () => {\n    50→      const prompt = generateRalphPrompt(config);\n    51→      expect(prompt).toContain('codeharness verify');\n    52→    });\n    53→\n    54→    it('interpolates different config values correctly', () => {\n    55→      const altConfig = {\n    56→        projectDir: '/tmp/other-project',\n    57→        sprintStatusPath: '/tmp/other-project/sprint-status.yaml',\n    58→      };\n    59→      const prompt = generateRalphPrompt(altConfig);\n    60→      expect(prompt).toContain('/tmp/other-project');\n    61→      expect(prompt).toContain('/tmp/other-project/sprint-status.yaml');\n    62→      expect(prompt).not.toContain('{{projectDir}}');\n    63→      expect(prompt).not.toContain('{{sprintStatusPath}}');\n    64→    });\n    65→\n    66→    it('does not contain unresolved template variables', () => {\n    67→      const prompt = generateRalphPrompt(config);\n    68→      expect(prompt).not.toMatch(/\\{\\{[^}]+\\}\\}/);\n    69→    });\n    70→  });\n    71→\n    72→  describe('retry context', () => {\n    73→    it('does not include retry section when retryCount is 0', () => {\n    74→      const prompt = generateRalphPrompt({ ...config, retryCount: 0, currentStoryKey: '5-1-test' });\n    75→      expect(prompt).not.toContain('Retry Context');\n    76→    });\n    77→\n    78→    it('does not include retry section when retryCount is undefined', () => {\n    79→      const prompt = generateRalphPrompt(config);\n    80→      expect(prompt).not.toContain('Retry Context');\n    81→    });\n    82→\n    83→    it('includes retry section when retryCount > 0 with currentStoryKey', () => {\n    84→      const prompt = generateRalphPrompt({\n    85→        ...config,\n    86→        retryCount: 2,\n    87→        currentStoryKey: '5-2-verification-gates',\n    88→      });\n    89→      expect(prompt).toContain('Retry Context');\n    90→      expect(prompt).toContain('retry attempt **2**');\n    91→      expect(prompt).toContain('5-2-verification-gates');\n    92→    });\n    93→\n    94→    it('does not include retry section when retryCount > 0 but no currentStoryKey', () => {\n    95→      const prompt = generateRalphPrompt({\n    96→        ...config,\n    97→        retryCount: 2,\n    98→      });\n    99→      expect(prompt).not.toContain('Retry Context');\n   100→    });\n   101→  });\n   102→\n   103→  describe('flagged stories', () => {\n   104→    it('does not include flagged section when flaggedStories is empty', () => {\n   105→      const prompt = generateRalphPrompt({ ...config, flaggedStories: [] });\n   106→      expect(prompt).not.toContain('Flagged Stories');\n   107→    });\n   108→\n   109→    it('does not include flagged section when flaggedStories is undefined', () => {\n   110→      const prompt = generateRalphPrompt(config);\n   111→      expect(prompt).not.toContain('Flagged Stories');\n   112→    });\n   113→\n   114→    it('includes flagged section when flaggedStories has entries', () => {\n   115→      const prompt = generateRalphPrompt({\n   116→        ...config,\n   117→        flaggedStories: ['5-1-broken-story', '5-3-another-broken'],\n   118→      });\n   119→      expect(prompt).toContain('Flagged Stories');\n   120→      expect(prompt).toContain('5-1-broken-story');\n   121→      expect(prompt).toContain('5-3-another-broken');\n   122→      expect(prompt).toContain('exceeded the retry limit');\n   123→    });\n   124→\n   125→    it('lists each flagged story on its own line', () => {\n   126→      const prompt = generateRalphPrompt({\n   127→        ...config,\n   128→        flaggedStories: ['5-1-a', '5-2-b'],\n   129→      });\n   130→      expect(prompt).toContain('- `5-1-a`');\n   131→      expect(prompt).toContain('- `5-2-b`');\n   132→    });\n   133→  });\n   134→});\n   135→"}]},"parent_tool_use_id":"toolu_01RmTR