{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01H8newnuWQC4sAJ4V1y2F7j","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { render } from 'ink-testing-library';\n3\timport React from 'react';\n4\timport { App } from '../ink-app.js';\n5\timport type { RendererState } from '../ink-components.js';\n6\timport type { LaneData } from '../ink-lane-container.js';\n7\t\n8\tfunction makeState(overrides?: Partial<RendererState>): RendererState {\n9\t  return {\n10\t    sprintInfo: null,\n11\t    stories: [],\n12\t    messages: [],\n13\t    completedTools: [],\n14\t    activeTool: null,\n15\t    activeToolArgs: '',\n16\t    lastThought: null,\n17\t    retryInfo: null,\n18\t    workflowFlow: [],\n19\t    currentTaskName: null,\n20\t    taskStates: {},\n21\t    taskMeta: {},\n22\t    activeDriverName: null,\n23\t    driverCosts: {},\n24\t    ...overrides,\n25\t  };\n26\t}\n27\t\n28\tfunction makeLane(overrides?: Partial<LaneData>): LaneData {\n29\t  return {\n30\t    epicId: '10',\n31\t    epicTitle: 'Driver Interface',\n32\t    currentStory: '10-3',\n33\t    phase: 'dev',\n34\t    acProgress: '4/9',\n35\t    storyProgressEntries: [\n36\t      { key: '10-1', status: 'done' },\n37\t      { key: '10-2', status: 'done' },\n38\t      { key: '10-3', status: 'in-progress' },\n39\t    ],\n40\t    driver: 'claude-code',\n41\t    cost: 4.20,\n42\t    elapsedTime: 1080000,\n43\t    ...overrides,\n44\t  };\n45\t}\n46\t\n47\tdescribe('App component', () => {\n48\t  it('renders without crashing with minimal state', () => {\n49\t    const { lastFrame } = render(<App state={makeState()} />);\n50\t    const frame = lastFrame()!;\n51\t    // Should not crash — empty state renders something\n52\t    expect(frame).toBeDefined();\n53\t  });\n54\t\n55\t  it('renders single-lane layout when no lanes provided', () => {\n56\t    const state = makeState({\n57\t      sprintInfo: {\n58\t        storyKey: '10-3',\n59\t        phase: 'dev',\n60\t        done: 2,\n61\t        total: 5,\n62\t        elapsed: '18m',\n63\t        totalCost: 4.20,\n64\t      },\n65\t    });\n66\t    const { lastFrame } = render(<App state={state} />);\n67\t    const frame = lastFrame()!;\n68\t    // Should show header\n69\t    expect(frame).toContain('codeharness run');\n70\t    expect(frame).toContain('Story: 10-3');\n71\t    // Should NOT show lane count\n72\t    expect(frame).not.toContain('lanes');\n73\t  });\n74\t\n75\t  it('renders single-lane layout when lanes has 1 entry (AC #8 backward compat)', () => {\n76\t    const state = makeState({\n77\t      sprintInfo: {\n78\t        storyKey: '10-3',\n79\t        phase: 'dev',\n80\t        done: 2,\n81\t        total: 5,\n82\t        elapsed: '18m',\n83\t        totalCost: 4.20,\n84\t      },\n85\t      lanes: [makeLane()],\n86\t    });\n87\t    const { lastFrame } = render(<App state={state} />);\n88\t    const frame = lastFrame()!;\n89\t    // AC #8: single lane mode should be visually identical to current single-lane TUI\n90\t    expect(frame).toContain('codeharness run');\n91\t    expect(frame).toContain('Story: 10-3');\n92\t    // Should NOT render LaneContainer (no lane indices visible)\n93\t    expect(frame).not.toContain('Lane 1:');\n94\t    expect(frame).not.toContain('lanes');\n95\t  });\n96\t\n97\t  it('renders LaneContainer when lanes > 1 (AC #10)', () => {\n98\t    const state = makeState({\n99\t      sprintInfo: {\n100\t        storyKey: '10-3',\n101\t        phase: 'dev',\n102\t        done: 2,\n103\t        total: 5,\n104\t        elapsed: '18m',\n105\t        totalCost: 4.20,\n106\t      },\n107\t      lanes: [\n108\t        makeLane({ epicId: '10', epicTitle: 'Driver Interface' }),\n109\t        makeLane({ epicId: '14', epicTitle: 'Workflow Schema', currentStory: '14-1' }),\n110\t      ],\n111\t    });\n112\t    const { lastFrame } = render(<App state={state} />);\n113\t    const frame = lastFrame()!;\n114\t    // AC #10: should render LaneContainer with multiple lanes\n115\t    expect(frame).toContain('Epic 10');\n116\t    expect(frame).toContain('Epic 14');\n117\t    expect(frame).toContain('Lane 1:');\n118\t    expect(frame).toContain('Lane 2:');\n119\t  });\n120\t\n121\t  it('shows lane count in header when multi-lane (AC #11)', () => {\n122\t    const state = makeState({\n123\t      sprintInfo: {\n124\t        storyKey: '10-3',\n125\t        phase: 'dev',\n126\t        done: 2,\n127\t        total: 5,\n128\t        elapsed: '18m',\n129\t        totalCost: 4.20,\n130\t        laneTotalCost: 18.60,\n131\t      },\n132\t      lanes: [\n133\t        makeLane({ epicId: '10' }),\n134\t        makeLane({ epicId: '14' }),\n135\t      ],\n136\t    });\n137\t    const { lastFrame } = render(<App state={state} />);\n138\t    const frame = lastFrame()!;\n139\t    // AC #11: header shows lane count and total cost\n140\t    expect(frame).toContain('2 lanes');\n141\t    expect(frame).toContain('$18.60 spent');\n142\t  });\n143\t\n144\t  it('renders empty lanes array as single-lane layout', () => {\n145\t    const state = makeState({\n146\t      sprintInfo: {\n147\t        storyKey: '10-3',\n148\t        phase: 'dev',\n149\t        done: 2,\n150\t        total: 5,\n151\t      },\n152\t      lanes: [],\n153\t    });\n154\t    const { lastFrame } = render(<App state={state} />);\n155\t    const frame = lastFrame()!;\n156\t    // Empty lanes = single-lane layout\n157\t    expect(frame).toContain('Story: 10-3');\n158\t    expect(frame).not.toContain('Lane 1:');\n159\t  });\n160\t});\n161\t"}]},"parent_tool_use_id":"toolu_01Lyf5tpvBU7eZNwMupgDFgG","session_id":"7e3ded59-6184-4f8b-8f55-ba5e63dae51f","uuid":"672620f0-620e-4c08-a046-36f4ad1eb7d6","timestamp":"2026-04-04T02:45:55.747Z"}
