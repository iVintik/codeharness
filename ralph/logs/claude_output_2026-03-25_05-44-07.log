{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01H4hbigGNpZ8xSFZ9FSB3uc","type":"tool_result","content":"     1→import { mkdirSync, readFileSync, writeFileSync } from 'node:fs';\n     2→import { dirname, resolve } from 'node:path';\n     3→import { fileURLToPath } from 'node:url';\n     4→\n     5→const __dirname = dirname(fileURLToPath(import.meta.url));\n     6→\n     7→/** Package root directory — works for both dev (src/) and installed (dist/) layouts. */\n     8→export function getPackageRoot(): string {\n     9→  // __dirname is src/lib/ in dev or dist/ in installed package\n    10→  // Walk up to find the directory containing package.json\n    11→  return resolve(__dirname, '..', '..');\n    12→}\n    13→\n    14→export function generateFile(targetPath: string, content: string): void {\n    15→  mkdirSync(dirname(targetPath), { recursive: true });\n    16→  writeFileSync(targetPath, content, 'utf-8');\n    17→}\n    18→\n    19→/**\n    20→ * Interpolates `{{VAR}}` placeholders in a template string.\n    21→ * Unmatched placeholders are left as-is.\n    22→ */\n    23→export function renderTemplate(template: string, vars: Record<string, string>): string {\n    24→  return template.replace(/\\{\\{(\\w+)\\}\\}/g, (match, key: string) => vars[key] ?? match);\n    25→}\n    26→\n    27→/**\n    28→ * Reads a template file relative to the package root and interpolates `{{VAR}}` placeholders.\n    29→ * @param templatePath - Path relative to package root, e.g. 'templates/dockerfiles/Dockerfile.nodejs'\n    30→ * @param vars - Key/value pairs for placeholder interpolation\n    31→ * @returns The rendered template content\n    32→ */\n    33→export function renderTemplateFile(templatePath: string, vars: Record<string, string> = {}): string {\n    34→  const fullPath = resolve(getPackageRoot(), templatePath);\n    35→  const content = readFileSync(fullPath, 'utf-8');\n    36→  if (Object.keys(vars).length === 0) return content;\n    37→  return renderTemplate(content, vars);\n    38→}\n    39→"}]},"parent_tool_use_id":"toolu_01L5LiJHunZnUnw7ysWAKpUU","session_id":"7c5953f4-1d55-4aa9-825f-60bc73601e00","uuid":"57907ffb-7a97-4b0c-8911-86ae9d920586","timestamp":"2026-03-25T02:03:40.844Z"}
