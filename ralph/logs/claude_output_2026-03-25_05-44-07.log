{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0154H1tJjUaUdeALWQoCBsV7","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach } from 'vitest';\n     2→import { resolve, dirname } from 'node:path';\n     3→import { fileURLToPath } from 'node:url';\n     4→\n     5→const __dirname = dirname(fileURLToPath(import.meta.url));\n     6→const packageRoot = resolve(__dirname, '..', '..', '..', '..');\n     7→\n     8→// Must mock before importing modules that use node:fs\n     9→vi.mock('node:fs', () => ({\n    10→  existsSync: vi.fn(),\n    11→  writeFileSync: vi.fn(),\n    12→  readFileSync: vi.fn(),\n    13→  mkdirSync: vi.fn(),\n    14→}));\n    15→\n    16→// Mock renderTemplateFile to use real file reads (the node:fs mock intercepts everything)\n    17→vi.mock('../../../lib/templates.js', async () => {\n    18→  const { readFileSync: realReadFileSync } = await vi.importActual<typeof import('node:fs')>('node:fs');\n    19→  return {\n    20→    generateFile: vi.fn(),\n    21→    renderTemplate(template: string, vars: Record<string, string>): string {\n    22→      return template.replace(/\\{\\{(\\w+)\\}\\}/g, (match: string, key: string) => vars[key] ?? match);\n    23→    },\n    24→    renderTemplateFile(templatePath: string, vars: Record<string, string> = {}): string {\n    25→      const fullPath = resolve(packageRoot, templatePath);\n    26→      const content = realReadFileSync(fullPath, 'utf-8');\n    27→      if (Object.keys(vars).length === 0) return content;\n    28→      return content.replace(/\\{\\{(\\w+)\\}\\}/g, (match: string, key: string) => vars[key] ?? match);\n    29→    },\n    30→    getPackageRoot() { return packageRoot; },\n    31→  };\n    32→});\n    33→\n    34→import { existsSync, writeFileSync, readFileSync } from 'node:fs';\n    35→import { join } from 'node:path';\n    36→import { generateDockerfileTemplate } from '../dockerfile-template.js';\n    37→import { validateDockerfile } from '../dockerfile-validator.js';\n    38→\n    39→const mockExistsSync = vi.mocked(existsSync);\n    40→const mockWriteFileSync = vi.mocked(writeFileSync);\n    41→\n    42→beforeEach(() => {\n    43→  vi.resetAllMocks();\n    44→});\n    45→\n    46→// ─── Node.js template ───────────────────────────────────────────────────────\n    47→\n    48→describe('generateDockerfileTemplate — nodejs', () => {\n    49→  it('generates Dockerfile with pinned FROM node:22-slim', () => {\n    50→    mockExistsSync.mockReturnValue(false);\n    51→\n    52→    const r = generateDockerfileTemplate('/project', 'nodejs');\n    53→    expect(r.success).toBe(true);\n    54→    if (r.success) {\n    55→      expect(r.data.path).toBe(join('/project', 'Dockerfile'));\n    56→      expect(r.data.stack).toBe('nodejs');\n    57→    }\n    58→\n    59→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    60→    expect(written).toContain('FROM node:22-slim');\n    61→  });\n    62→\n    63→  it('includes npm install -g for binary installation', () => {\n    64→    mockExistsSync.mockReturnValue(false);\n    65→    generateDockerfileTemplate('/project', 'nodejs');\n    66→\n    67→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    68→    expect(written).toContain('npm install -g');\n    69→  });\n    70→\n    71→  it('includes curl and jq verification tools', () => {\n    72→    mockExistsSync.mockReturnValue(false);\n    73→    generateDockerfileTemplate('/project', 'nodejs');\n    74→\n    75→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    76→    expect(written).toContain('curl');\n    77→    expect(written).toContain('jq');\n    78→  });\n    79→\n    80→  it('includes USER node for non-root execution', () => {\n    81→    mockExistsSync.mockReturnValue(false);\n    82→    generateDockerfileTemplate('/project', 'nodejs');\n    83→\n    84→    const written = mockWriteFileSync.mock.calls[0][1] as string;\n    85→    expect(written).t