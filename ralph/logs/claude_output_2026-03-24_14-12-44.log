{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014PH8TSPhrjUxEQv3YYHgjQ","type":"tool_result","content":"     1→/**\n     2→ * Migration from old scattered state files to unified sprint-state.json.\n     3→ * Runs once when sprint-state.json does not exist and old files are found.\n     4→ */\n     5→\n     6→import { readFileSync, existsSync } from 'node:fs';\n     7→import { join } from 'node:path';\n     8→import { ok, fail } from '../../types/result.js';\n     9→import type { Result } from '../../types/result.js';\n    10→import type { SprintState, StoryState, StoryStatus, ActionItem } from '../../types/state.js';\n    11→import { defaultState, writeStateAtomic, computeSprintCounts } from './state.js';\n    12→\n    13→const OLD_FILES = {\n    14→  storyRetries: 'ralph/.story_retries',\n    15→  flaggedStories: 'ralph/.flagged_stories',\n    16→  ralphStatus: 'ralph/status.json',\n    17→  sprintStatusYaml: '_bmad-output/implementation-artifacts/sprint-status.yaml',\n    18→  sessionIssues: '_bmad-output/implementation-artifacts/.session-issues.md',\n    19→} as const;\n    20→\n    21→function resolve(relative: string): string {\n    22→  return join(process.cwd(), relative);\n    23→}\n    24→\n    25→function readIfExists(relative: string): string | null {\n    26→  const p = resolve(relative);\n    27→  if (!existsSync(p)) return null;\n    28→  try { return readFileSync(p, 'utf-8'); } catch { return null; }\n    29→}\n    30→\n    31→/** Return a fresh empty StoryState */\n    32→function emptyStory(): StoryState {\n    33→  return {\n    34→    status: 'backlog', attempts: 0, lastAttempt: null,\n    35→    lastError: null, proofPath: null, acResults: null,\n    36→  };\n    37→}\n    38→\n    39→/** Ensure a story entry exists, then apply a partial update */\n    40→function upsertStory(\n    41→  stories: Record<string, StoryState>,\n    42→  key: string,\n    43→  patch: Partial<StoryState>,\n    44→): void {\n    45→  stories[key] = { ...(stories[key] ?? emptyStory()), ...patch };\n    46→}\n    47→\n    48→/** Parse ralph/.story_retries: \"<key> <count>\" per line */\n    49→function parseStoryRetries(content: string, stories: Record<string, StoryState>): void {\n    50→  for (const line of content.split('\\n')) {\n    51→    const trimmed = line.trim();\n    52→    if (!trimmed) continue;\n    53→    const parts = trimmed.split(/\\s+/);\n    54→    if (parts.length < 2) continue;\n    55→    const count = parseInt(parts[1], 10);\n    56→    if (!isNaN(count)) upsertStory(stories, parts[0], { attempts: count });\n    57→  }\n    58→}\n    59→\n    60→/** Parse ralph/.flagged_stories: one key per line */\n    61→function parseFlaggedStories(content: string, stories: Record<string, StoryState>): void {\n    62→  for (const line of content.split('\\n')) {\n    63→    const key = line.trim();\n    64→    if (key) upsertStory(stories, key, { status: 'blocked' });\n    65→  }\n    66→}\n    67→\n    68→/** Map YAML status strings to StoryStatus */\n    69→function mapYamlStatus(value: string): StoryStatus | null {\n    70→  const mapping: Record<string, StoryStatus> = {\n    71→    done: 'done', backlog: 'backlog', verifying: 'verifying',\n    72→    'in-progress': 'in-progress', 'ready-for-dev': 'ready',\n    73→    blocked: 'blocked', failed: 'failed', review: 'review', ready: 'ready',\n    74→  };\n    75→  return mapping[value.trim().toLowerCase()] ?? null;\n    76→}\n    77→\n    78→/**\n    79→ * Parse sprint-status.yaml (flat key: value).\n    80→ * Story lines like \"  1-1-result-type: done\" become entries.\n    81→ * Epic lines like \"  epic-1: done\" are skipped.\n    82→ */\n    83→function parseSprintStatusYaml(content: string, stories: Record<string, StoryState>): void {\n    84→  for (const line of content.split('\\n')) {\n    85→    const trimmed = line.trim();\n    86→    if (!trimmed || trimmed.startsWith('#')) continue;\n    87→    const match = trimmed.match(/^([a-zA-Z0-9_-]+):\\s*(.+)$/);\n    88→    if (!match) continue;\n    89→    const key = match[1];\n    90→    if (key === 'development_status' || key.startsWith('epic-')) continue;\n    91→    const status = mapYamlStatus(match[2]);\n    92→    if (status) upsertStory(stories, key, { status });\n    93→  }\n    94→}\n    95→\n    96→interface RalphStatusJson {\n    97→  loop_count?: number;\n    98→  stories_total?: number;\n    99→  stories_completed?: number;\n   100→  elapsed_seconds?: number;\n   101→  status?: string;\n   102→}\n   103→\n   104→/** Parse ralph/status.json into run section */\n   105→function parseRalphStatus(content: string): SprintState['run'] | null {\n   106→  try {\n   107→    const data = JSON.parse(content) as RalphStatusJson;\n   108→    return {\n   109→      active: data.status === 'running', startedAt: null,\n   110→      iteration: data.loop_count ?? 0, cost: 0, completed: [], failed: [],\n   111→      currentStory: null, currentPhase: null, lastAction: null, acProgress: null,\n   112→    };\n   113→  } catch { return null; }\n   114→}\n   115→\n   116→/** Parse .session-issues.md for action items (best effort) */\n   117→function parseSessionIssues(content: string): ActionItem[] {\n   118→  const items: ActionItem[] = [];\n   119→  let currentStory = '';\n   120→  let itemId = 0;\n   121→  for (const line of content.split('\\n')) {\n   122→    const headerMatch = line.match(/^###\\s+([a-zA-Z0-9_-]+)\\s*[—-]/);\n   123→    if (headerMatch) { currentStory = headerMatch[1]; continue; }\n   124→    const bulletMatch = line.match(/^-\\s+(.+)/);\n   125→    if (bulletMatch && currentStory) {\n   126→      itemId++;\n   127→      items.push({\n   128→        id: `migrated-${itemId}`, story: currentStory,\n   129→        description: bulletMatch[1], source: 'retro', resolved: false,\n   130→      });\n   131→    }\n   132→  }\n   133→  return items;\n   134→}\n   135→\n   136→/**\n   137→ * Migrate from old format files to SprintState.\n   138→ * Returns fail() if no old files exist (caller should use default).\n   139→ */\n   140→export function migrateFromOldFormat(): Result<SprintState> {\n   141→  const hasAnyOldFile = Object.values(OLD_FILES).some((rel) => existsSync(resolve(rel)));\n   142→  if (!hasAnyOldFile) return fail('No old format files found for migration');\n   143→\n   144→  try {\n   145→    const stories: Record<string, StoryState> = {};\n   146→    let run = defaultState().run;\n   147→    let actionItems: ActionItem[] = [];\n   148→\n   149→    const yamlContent = readIfExists(OLD_FILES.sprintStatusYaml);\n   150→    if (yamlContent) parseSprintStatusYaml(yamlContent, stories);\n   151→\n   152→    const retriesContent = readIfExists(OLD_FILES.storyRetries);\n   153→    if (retriesContent) parseStoryRetries(retriesContent, stories);\n   154→\n   155→    const flaggedContent = readIfExists(OLD_FILES.flaggedStories);\n   156→    if (flaggedContent) parseFlaggedStories(flaggedContent, stories);\n   157→\n   158→    const statusContent = readIfExists(OLD_FILES.ralphStatus);\n   159→    if (statusContent) {\n   160→      const parsed = parseRalphStatus(statusContent);\n   161→      if (parsed) run = parsed;\n   162→    }\n   163→\n   164→    const issuesContent = readIfExists(OLD_FILES.sessionIssues);\n   165→    if (issuesContent) actionItems = parseSessionIssues(issuesContent);\n   166→\n   167→    const sprint = computeSprintCounts(stories);\n   168→\n   169→    const migrated: SprintState = {\n   170→      version: 1,\n   171→      sprint,\n   172→      stories, run, actionItems,\n   173→    };\n   174→\n   175→    const writeResult = writeStateAtomic(migrated);\n   176→    if (!writeResult.success) return fail(writeResult.error);\n   177→    return ok(migrated);\n   178→  } catch (err: unknown) {\n   179→    const msg = err instanceof Error ? err.message : String(err);\n   180→    return fail(`Migration failed: ${msg}`);\n   181→  }\n   182→}\n   183→"}]},"parent_tool_use_id":"toolu_01EPL4eJAP5