{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013qDrqQJCWKv7s5NGqubWTC","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { parse } from 'yaml';\n3\timport { warn } from './output.js';\n4\timport { dispatchAgent, DispatchError } from './agent-dispatch.js';\n5\timport type { DispatchOptions, DispatchResult } from './agent-dispatch.js';\n6\timport type { SubagentDefinition } from './agent-resolver.js';\n7\timport type { ResolvedWorkflow, ResolvedTask, FlowStep, LoopBlock } from './workflow-parser.js';\n8\timport {\n9\t  readWorkflowState,\n10\t  writeWorkflowState,\n11\t} from './workflow-state.js';\n12\timport type { WorkflowState, TaskCheckpoint } from './workflow-state.js';\n13\timport { createIsolatedWorkspace } from './source-isolation.js';\n14\timport { generateTraceId, formatTracePrompt, recordTraceId } from './trace-id.js';\n15\timport { resolveSessionId, recordSessionId } from './session-manager.js';\n16\timport type { SessionLookupKey } from './session-manager.js';\n17\t\n18\t// --- Interfaces ---\n19\t\n20\t/**\n21\t * Configuration for the workflow engine.\n22\t */\n23\texport interface EngineConfig {\n24\t  /** The resolved workflow with tasks and flow steps. */\n25\t  workflow: ResolvedWorkflow;\n26\t  /** Pre-compiled agent definitions keyed by agent name. */\n27\t  agents: Record<string, SubagentDefinition>;\n28\t  /** Path to sprint-status.yaml for work item discovery. */\n29\t  sprintStatusPath: string;\n30\t  /** Optional path to issues.yaml for additional work items. */\n31\t  issuesPath?: string;\n32\t  /** Unique identifier for this engine run. */\n33\t  runId: string;\n34\t  /** Project root directory. Defaults to process.cwd(). */\n35\t  projectDir?: string;\n36\t}\n37\t\n38\t/**\n39\t * Result returned by executeWorkflow().\n40\t */\n41\texport interface EngineResult {\n42\t  /** Whether the workflow completed without errors. */\n43\t  success: boolean;\n44\t  /** Number of task dispatches completed. */\n45\t  tasksCompleted: number;\n46\t  /** Number of work items (stories/issues) processed. */\n47\t  storiesProcessed: number;\n48\t  /** Errors encountered during execution. */\n49\t  errors: EngineError[];\n50\t  /** Wall-clock duration of the entire workflow in milliseconds. */\n51\t  durationMs: number;\n52\t}\n53\t\n54\t/**\n55\t * Structured error recorded during workflow execution.\n56\t */\n57\texport interface EngineError {\n58\t  taskName: string;\n59\t  storyKey: string;\n60\t  code: string;\n61\t  message: string;\n62\t}\n63\t\n64\t/**\n65\t * A work item (story or issue) ready for execution.\n66\t */\n67\texport interface WorkItem {\n68\t  key: string;\n69\t  title?: string;\n70\t  source: 'sprint' | 'issues';\n71\t}\n72\t\n73\t// --- Constants ---\n74\t\n75\t/** Sentinel story key for per-run tasks. */\n76\tconst PER_RUN_SENTINEL = '__run__';\n77\t\n78\t/** DispatchError codes that should halt execution immediately. */\n79\tconst HALT_ERROR_CODES = new Set(['RATE_LIMIT', 'NETWORK', 'SDK_INIT']);\n80\t\n81\t// --- Work Item Loading ---\n82\t\n83\t/**\n84\t * Load work items from sprint-status.yaml and optionally issues.yaml.\n85\t *\n86\t * Stories are extracted from the `development_status` section of sprint-status.yaml.\n87\t * Issues are extracted from the `issues` array of issues.yaml.\n88\t *\n89\t * Only items with status `backlog` or `ready-for-dev` are included.\n90\t * Epic keys (`epic-*`) and retrospective keys (`*-retrospective`) are excluded.\n91\t *\n92\t * If issues.yaml does not exist, returns only stories (no error).\n93\t */\n94\texport function loadWorkItems(sprintStatusPath: string, issuesPath?: string): WorkItem[] {\n95\t  const items: WorkItem[] = [];\n96\t\n97\t  // --- Load stories from sprint-status.yaml ---\n98\t  if (existsSync(sprintStatusPath)) {\n99\t    let raw: string;\n100\t    try {\n101\t      raw = readFileSync(sprintStatusPath, 'utf-8');\n102\t    } catch { // IGNORE: unreadable file — warn and return empty\n103\t      warn(`workflow-engine: could not read sprint-status.yaml at ${sprintStatusPath}`);\n104\t      return items;\n105\t    }\n106\t\n107\t    let parsed: unknown;\n108\t    try {\n109\t      parsed = parse(raw);\n110\t    } catch { // IGNORE: malformed YAML — warn and return empty\n111\t      warn(`workflow-engine: invalid YAML in sprint-status.yaml at ${sprintStatusPath}`);\n112\t      return items;\n113\t    }\n114\t\n115\t    if (parsed && typeof parsed === 'object') {\n116\t      const data = parsed as Record<string, unknown>;\n117\t      const devStatus = data.development_status as Record<string, unknown> | undefined;\n118\t\n119\t      if (devStatus && typeof devStatus === 'object') {\n120\t        for (const [key, status] of Object.entries(devStatus)) {\n121\t          // Skip epic keys and retrospective keys\n122\t          if (key.startsWith('epic-')) continue;\n123\t          if (key.endsWith('-retrospective')) continue;\n124\t\n125\t          // Only include backlog or ready-for-dev\n126\t          if (status === 'backlog' || status === 'ready-for-dev') {\n127\t            items.push({ key, source: 'sprint' });\n128\t          }\n129\t        }\n130\t      }\n131\t    }\n132\t  }\n133\t\n134\t  // --- Load issues from issues.yaml ---\n135\t  if (issuesPath && existsSync(issuesPath)) {\n136\t    let raw: string;\n137\t    try {\n138\t      raw = readFileSync(issuesPath, 'utf-8');\n139\t    } catch { // IGNORE: unreadable issues file — warn and return what we have\n140\t      warn(`workflow-engine: could not read issues.yaml at ${issuesPath}`);\n141\t      return items;\n142\t    }\n143\t\n144\t    let parsed: unknown;\n145\t    try {\n146\t      parsed = parse(raw);\n147\t    } catch { // IGNORE: malformed issues YAML — warn and return what we have\n148\t      warn(`workflow-engine: invalid YAML in issues.yaml at ${issuesPath}`);\n149\t      return items;\n150\t    }\n151\t\n152\t    if (parsed && typeof parsed === 'object') {\n153\t      const data = parsed as Record<string, unknown>;\n154\t      const issuesList = data.issues as Array<Record<string, unknown>> | undefined;\n155\t\n156\t      if (Array.isArray(issuesList)) {\n157\t        for (const issue of issuesList) {\n158\t          if (issue && typeof issue === 'object') {\n159\t            const status = issue.status as string | undefined;\n160\t            if (status === 'backlog' || status === 'ready-for-dev') {\n161\t              items.push({\n162\t                key: issue.id as string,\n163\t                title: issue.title as string | undefined,\n164\t                source: 'issues',\n165\t              });\n166\t            }\n167\t          }\n168\t        }\n169\t      }\n170\t    }\n171\t  }\n172\t\n173\t  return items;\n174\t}\n175\t\n176\t// --- Single Task Dispatch ---\n177\t\n178\t/**\n179\t * Dispatch a single task for a specific work item (or per-run sentinel).\n180\t *\n181\t * Handles: trace ID generation, session resolution, source isolation,\n182\t * agent dispatch, state checkpointing, and cleanup.\n183\t *\n184\t * Returns the updated workflow state after recording the dispatch.\n185\t */\n186\texport async function dispatchTask(\n187\t  task: ResolvedTask,\n188\t  taskName: string,\n189\t  storyKey: string,\n190\t  definition: SubagentDefinition,\n191\t  state: WorkflowState,\n192\t  config: EngineConfig,\n193\t): Promise<WorkflowState> {\n194\t  const projectDir = config.projectDir ?? process.cwd();\n195\t\n196\t  // 1. Generate trace ID\n197\t  const traceId = generateTraceId(config.runId, state.iteration, taskName);\n198\t\n199\t  // 2. Format trace prompt\n200\t  const tracePrompt = formatTracePrompt(traceId);\n201\t\n202\t  // 3. Resolve session ID\n203\t  const sessionKey: SessionLookupKey = { taskName, storyKey };\n204\t  const sessionId = resolveSessionId(task.session, sessionKey, state);\n205\t\n206\t  // 4. Build dispatch options based on source_access\n207\t  let dispatchOptions: DispatchOptions;\n208\t  let workspace: Awaited<ReturnType<typeof createIsolatedWorkspace>> | null = null;\n209\t\n210\t  if (task.source_access === false) {\n211\t    workspace = await createIsolatedWorkspace({ runId: config.runId, storyFiles: [] });\n212\t    dispatchOptions = {\n213\t      ...workspace.toDispatchOptions(),\n214\t      sessionId,\n215\t      appendSystemPrompt: tracePrompt,\n216\t    };\n217\t  } else {\n218\t    dispatchOptions = {\n219\t      cwd: projectDir,\n220\t      sessionId,\n221\t      appendSystemPrompt: tracePrompt,\n222\t    };\n223\t  }\n224\t\n225\t  // 5. Construct prompt\n226\t  const prompt = storyKey === PER_RUN_SENTINEL\n227\t    ? `Execute task \"${taskName}\" for the current run.`\n228\t    : `Implement story ${storyKey}`;\n229\t\n230\t  // 6. Dispatch agent\n231\t  let result: DispatchResult;\n232\t  try {\n233\t    result = await dispatchAgent(definition, prompt, dispatchOptions);\n234\t  } finally {\n235\t    // Cleanup workspace regardless of dispatch success/failure\n236\t    if (workspace) {\n237\t      await workspace.cleanup();\n238\t    }\n239\t  }\n240\t\n241\t  // 7. Record session ID (if dispatch returned one)\n242\t  let updatedState = state;\n243\t  if (result.sessionId) {\n244\t    updatedState = recordSessionId(sessionKey, result.sessionId, updatedState);\n245\t  } else {\n246\t    // Append checkpoint manually when no session ID is returned\n247\t    const checkpoint: TaskCheckpoint = {\n248\t      task_name: taskName,\n249\t      story_key: storyKey,\n250\t      completed_at: new Date().toISOString(),\n251\t    };\n252\t    updatedState = {\n253\t      ...updatedState,\n254\t      tasks_completed: [...updatedState.tasks_completed, checkpoint],\n255\t    };\n256\t  }\n257\t\n258\t  // 8. Record trace ID\n259\t  updatedState = recordTraceId(traceId, updatedState);\n260\t\n261\t  // 9. Write state to disk\n262\t  writeWorkflowState(updatedState, projectDir);\n263\t\n264\t  return updatedState;\n265\t}\n266\t\n267\t// --- Flow Step Type Guard ---\n268\t\n269\tfunction isLoopBlock(step: FlowStep): step is LoopBlock {\n270\t  return typeof step === 'object' && step !== null && 'loop' in step;\n271\t}\n272\t\n273\t// --- Main Execution ---\n274\t\n275\t/**\n276\t * Execute a workflow sequentially: iterate through flow steps, dispatch tasks\n277\t * per-story or per-run, checkpoint state after each dispatch.\n278\t *\n279\t * Loop blocks are skipped with a warning (story 5-2).\n280\t *\n281\t * Returns an EngineResult summarizing the execution.\n282\t */\n283\texport async function executeWorkflow(config: EngineConfig): Promise<EngineResult> {\n284\t  const startMs = Date.now();\n285\t  const projectDir = config.projectDir ?? process.cwd();\n286\t  const errors: EngineError[] = [];\n287\t  let tasksCompleted = 0;\n288\t  const processedStories = new Set<string>();\n289\t\n290\t  // 1. Read or initialize workflow state\n291\t  let state = readWorkflowState(projectDir);\n292\t  state = {\n293\t    ...state,\n294\t    phase: 'executing',\n295\t    started: state.started || new Date().toISOString(),\n296\t    workflow_name: config.workflow.flow.filter((s) => typeof s === 'string').join(' -> '),\n297\t  };\n298\t  writeWorkflowState(state, projectDir);\n299\t\n300\t  // 2. Load work items\n301\t  const workItems = loadWorkItems(config.sprintStatusPath, config.issuesPath);\n302\t\n303\t  // 3. Iterate through flow steps\n304\t  for (const step of config.workflow.flow) {\n305\t    // Skip loop blocks (story 5-2)\n306\t    if (isLoopBlock(step)) {\n307\t      warn('workflow-engine: loop blocks are not yet implemented (story 5-2), skipping');\n308\t      continue;\n309\t    }\n310\t\n311\t    // step is a string task name\n312\t    const taskName = step;\n313\t    const task = config.workflow.tasks[taskName];\n314\t\n315\t    if (!task) {\n316\t      warn(`workflow-engine: task \"${taskName}\" not found in workflow tasks, skipping`);\n317\t      continue;\n318\t    }\n319\t\n320\t    // Look up the agent definition\n321\t    const definition = config.agents[task.agent];\n322\t    if (!definition) {\n323\t      warn(`workflow-engine: agent \"${task.agent}\" not found for task \"${taskName}\", skipping`);\n324\t      continue;\n325\t    }\n326\t\n327\t    if (task.scope === 'per-run') {\n328\t      // Per-run: dispatch once with sentinel key\n329\t      try {\n330\t        state = await dispatchTask(task, taskName, PER_RUN_SENTINEL, definition, state, config);\n331\t        tasksCompleted++;\n332\t      } catch (err: unknown) {\n333\t        const engineError = handleDispatchError(err, taskName, PER_RUN_SENTINEL);\n334\t        errors.push(engineError);\n335\t\n336\t        // Record error in state\n337\t        state = {\n338\t          ...state,\n339\t          phase: 'error',\n340\t        };\n341\t        writeWorkflowState(state, projectDir);\n342\t\n343\t        // Halt on critical errors\n344\t        if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n345\t          break;\n346\t        }\n347\t      }\n348\t    } else {\n349\t      // Per-story: dispatch once per work item\n350\t      for (const item of workItems) {\n351\t        processedStories.add(item.key);\n352\t        try {\n353\t          state = await dispatchTask(task, taskName, item.key, definition, state, config);\n354\t          tasksCompleted++;\n355\t        } catch (err: unknown) {\n356\t          const engineError = handleDispatchError(err, taskName, item.key);\n357\t          errors.push(engineError);\n358\t\n359\t          // Record error in state\n360\t          state = {\n361\t            ...state,\n362\t            phase: 'error',\n363\t          };\n364\t          writeWorkflowState(state, projectDir);\n365\t\n366\t          // Halt on critical errors, continue on UNKNOWN\n367\t          if (err instanceof DispatchError && HALT_ERROR_CODES.has(err.code)) {\n368\t            break;\n369\t          }\n370\t          // UNKNOWN errors: record and continue to next story\n371\t          continue;\n372\t        }\n373\t      }\n374\t    }\n375\t  }\n376\t\n377\t  // 4. Set final phase if no errors\n378\t  if (errors.length === 0) {\n379\t    state = { ...state, phase: 'completed' };\n380\t    writeWorkflowState(state, projectDir);\n381\t  }\n382\t\n383\t  // 5. Return result\n384\t  return {\n385\t    success: errors.length === 0,\n386\t    tasksCompleted,\n387\t    storiesProcessed: processedStories.size,\n388\t    errors,\n389\t    durationMs: Date.now() - startMs,\n390\t  };\n391\t}\n392\t\n393\t// --- Error Handling ---\n394\t\n395\tfunction handleDispatchError(err: unknown, taskName: string, storyKey: string): EngineError {\n396\t  if (err instanceof DispatchError) {\n397\t    return {\n398\t      taskName,\n399\t      storyKey,\n400\t      code: err.code,\n401\t      message: err.message,\n402\t    };\n403\t  }\n404\t\n405\t  const message = err instanceof Error ? err.message : String(err);\n406\t  return {\n407\t    taskName,\n408\t    storyKey,\n409\t    code: 'UNKNOWN',\n410\t    message,\n411\t  };\n412\t}\n413\t"}]},"parent_tool_use_id":"toolu_011dV6c9xFAQaHP6KDdoVM36","session_id":"7bb08296-a865-42eb-9710-ebdb6ccedbda","uuid":"7c481296-1b15-4495-ad84-f15e33fc0976","timestamp":"2026-04-02T21:54:35.205Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QjAMTPheY7Z7n8UBhoXi7v","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach } from 'vitest';\n2\t\n3\t// --- Hoisted Mocks ---\n4\t\n5\tconst {\n6\t  mockDispatchAgent,\n7\t  mockReadWorkflowState,\n8\t  mockWriteWorkflowState,\n9\t  mockCreateIsolatedWorkspace,\n10\t  mockGenerateTraceId,\n11\t  mockFormatTracePrompt,\n12\t  mockRecordTraceId,\n13\t  mockResolveSessionId,\n14\t  mockRecordSessionId,\n15\t  mockWarn,\n16\t  mockReadFileSync,\n17\t  mockExistsSync,\n18\t  mockParse,\n19\t} = vi.hoisted(() => ({\n20\t  mockDispatchAgent: vi.fn(),\n21\t  mockReadWorkflowState: vi.fn(),\n22\t  mockWriteWorkflowState: vi.fn(),\n23\t  mockCreateIsolatedWorkspace: vi.fn(),\n24\t  mockGenerateTraceId: vi.fn(),\n25\t  mockFormatTracePrompt: vi.fn(),\n26\t  mockRecordTraceId: vi.fn(),\n27\t  mockResolveSessionId: vi.fn(),\n28\t  mockRecordSessionId: vi.fn(),\n29\t  mockWarn: vi.fn(),\n30\t  mockReadFileSync: vi.fn(),\n31\t  mockExistsSync: vi.fn(),\n32\t  mockParse: vi.fn(),\n33\t}));\n34\t\n35\tvi.mock('../agent-dispatch.js', () => ({\n36\t  dispatchAgent: mockDispatchAgent,\n37\t  DispatchError: class DispatchError extends Error {\n38\t    public readonly code: string;\n39\t    public readonly agentName: string;\n40\t    public readonly cause: unknown;\n41\t    constructor(message: string, code: string, agentName: string, cause: unknown) {\n42\t      super(message);\n43\t      this.name = 'DispatchError';\n44\t      this.code = code;\n45\t      this.agentName = agentName;\n46\t      this.cause = cause;\n47\t    }\n48\t  },\n49\t}));\n50\t\n51\tvi.mock('../workflow-state.js', () => ({\n52\t  readWorkflowState: mockReadWorkflowState,\n53\t  writeWorkflowState: mockWriteWorkflowState,\n54\t  getDefaultWorkflowState: () => ({\n55\t    workflow_name: '',\n56\t    started: '',\n57\t    iteration: 0,\n58\t    phase: 'idle',\n59\t    tasks_completed: [],\n60\t    evaluator_scores: [],\n61\t    circuit_breaker: { triggered: false, reason: null, score_history: [] },\n62\t    trace_ids: [],\n63\t  }),\n64\t}));\n65\t\n66\tvi.mock('../source-isolation.js', () => ({\n67\t  createIsolatedWorkspace: mockCreateIsolatedWorkspace,\n68\t}));\n69\t\n70\tvi.mock('../trace-id.js', () => ({\n71\t  generateTraceId: mockGenerateTraceId,\n72\t  formatTracePrompt: mockFormatTracePrompt,\n73\t  recordTraceId: mockRecordTraceId,\n74\t}));\n75\t\n76\tvi.mock('../session-manager.js', () => ({\n77\t  resolveSessionId: mockResolveSessionId,\n78\t  recordSessionId: mockRecordSessionId,\n79\t}));\n80\t\n81\tvi.mock('../output.js', () => ({\n82\t  warn: mockWarn,\n83\t}));\n84\t\n85\tvi.mock('node:fs', () => ({\n86\t  readFileSync: mockReadFileSync,\n87\t  existsSync: mockExistsSync,\n88\t}));\n89\t\n90\tvi.mock('yaml', () => ({\n91\t  parse: mockParse,\n92\t}));\n93\t\n94\timport {\n95\t  executeWorkflow,\n96\t  loadWorkItems,\n97\t  dispatchTask,\n98\t} from '../workflow-engine.js';\n99\timport type {\n100\t  EngineConfig,\n101\t  WorkItem,\n102\t} from '../workflow-engine.js';\n103\timport type { WorkflowState } from '../workflow-state.js';\n104\timport type { ResolvedWorkflow, ResolvedTask } from '../workflow-parser.js';\n105\timport type { SubagentDefinition } from '../agent-resolver.js';\n106\t\n107\t// --- Helpers ---\n108\t\n109\tfunction makeDefaultState(overrides?: Partial<WorkflowState>): WorkflowState {\n110\t  return {\n111\t    workflow_name: '',\n112\t    started: '',\n113\t    iteration: 0,\n114\t    phase: 'idle',\n115\t    tasks_completed: [],\n116\t    evaluator_scores: [],\n117\t    circuit_breaker: { triggered: false, reason: null, score_history: [] },\n118\t    trace_ids: [],\n119\t    ...overrides,\n120\t  };\n121\t}\n122\t\n123\tfunction makeDefinition(overrides?: Partial<SubagentDefinition>): SubagentDefinition {\n124\t  return {\n125\t    name: 'test-agent',\n126\t    model: 'claude-sonnet-4-20250514',\n127\t    instructions: 'You are a test agent.',\n128\t    disallowedTools: [],\n129\t    bare: true,\n130\t    ...overrides,\n131\t  };\n132\t}\n133\t\n134\tfunction makeTask(overrides?: Partial<ResolvedTask>): ResolvedTask {\n135\t  return {\n136\t    agent: 'dev',\n137\t    scope: 'per-story',\n138\t    session: 'fresh',\n139\t    source_access: true,\n140\t    ...overrides,\n141\t  };\n142\t}\n143\t\n144\tfunction makeConfig(overrides?: Partial<EngineConfig>): EngineConfig {\n145\t  return {\n146\t    workflow: {\n147\t      tasks: {\n148\t        implement: makeTask(),\n149\t        verify: makeTask({ scope: 'per-run', source_access: false }),\n150\t      },\n151\t      flow: ['implement', 'verify'],\n152\t    },\n153\t    agents: {\n154\t      dev: makeDefinition(),\n155\t    },\n156\t    sprintStatusPath: '/project/sprint-status.yaml',\n157\t    runId: 'run-001',\n158\t    projectDir: '/project',\n159\t    ...overrides,\n160\t  };\n161\t}\n162\t\n163\tfunction setupDefaultMocks() {\n164\t  mockReadWorkflowState.mockReturnValue(makeDefaultState());\n165\t  mockWriteWorkflowState.mockImplementation(() => {});\n166\t\n167\t  mockGenerateTraceId.mockReturnValue('ch-run-001-0-implement');\n168\t  mockFormatTracePrompt.mockReturnValue('[TRACE] trace_id=ch-run-001-0-implement');\n169\t  mockRecordTraceId.mockImplementation((traceId: string, state: WorkflowState) => ({\n170\t    ...state,\n171\t    trace_ids: [...(state.trace_ids ?? []), traceId],\n172\t  }));\n173\t\n174\t  mockResolveSessionId.mockReturnValue(undefined);\n175\t  mockRecordSessionId.mockImplementation(\n176\t    (key: { taskName: string; storyKey: string }, sessionId: string, state: WorkflowState) => ({\n177\t      ...state,\n178\t      tasks_completed: [\n179\t        ...state.tasks_completed,\n180\t        {\n181\t          task_name: key.taskName,\n182\t          story_key: key.storyKey,\n183\t          completed_at: '2026-04-03T00:00:00.000Z',\n184\t          session_id: sessionId,\n185\t        },\n186\t      ],\n187\t    }),\n188\t  );\n189\t\n190\t  mockDispatchAgent.mockResolvedValue({\n191\t    sessionId: 'sess-abc-123',\n192\t    success: true,\n193\t    durationMs: 1000,\n194\t    output: 'Done',\n195\t  });\n196\t\n197\t  // Default: sprint-status.yaml exists with two stories\n198\t  mockExistsSync.mockImplementation((path: string) => {\n199\t    if (path === '/project/sprint-status.yaml') return true;\n200\t    return false;\n201\t  });\n202\t\n203\t  mockReadFileSync.mockReturnValue('dummy yaml');\n204\t  mockParse.mockReturnValue({\n205\t    development_status: {\n206\t      'epic-5': 'backlog',\n207\t      '5-1-foo': 'ready-for-dev',\n208\t      '5-2-bar': 'backlog',\n209\t    },\n210\t  });\n211\t}\n212\t\n213\t// --- Tests ---\n214\t\n215\tdescribe('loadWorkItems', () => {\n216\t  beforeEach(() => {\n217\t    vi.clearAllMocks();\n218\t  });\n219\t\n220\t  it('loads stories from sprint-status.yaml excluding epics and retrospectives', () => {\n221\t    mockExistsSync.mockReturnValue(true);\n222\t    mockReadFileSync.mockReturnValue('yaml content');\n223\t    mockParse.mockReturnValue({\n224\t      development_status: {\n225\t        'epic-5': 'backlog',\n226\t        '5-1-foo': 'ready-for-dev',\n227\t        '5-2-bar': 'backlog',\n228\t        '5-3-baz': 'done',\n229\t        'epic-5-retrospective': 'backlog',\n230\t      },\n231\t    });\n232\t\n233\t    const items = loadWorkItems('/path/sprint-status.yaml');\n234\t\n235\t    expect(items).toEqual([\n236\t      { key: '5-1-foo', source: 'sprint' },\n237\t      { key: '5-2-bar', source: 'sprint' },\n238\t    ]);\n239\t  });\n240\t\n241\t  it('returns empty array when sprint-status.yaml does not exist and no issues.yaml', () => {\n242\t    mockExistsSync.mockReturnValue(false);\n243\t\n244\t    const items = loadWorkItems('/nonexistent/sprint-status.yaml');\n245\t    expect(items).toEqual([]);\n246\t  });\n247\t\n248\t  it('returns stories only when issues.yaml does not exist (AC #6)', () => {\n249\t    mockExistsSync.mockImplementation((path: string) => {\n250\t      if (path === '/path/sprint-status.yaml') return true;\n251\t      return false;\n252\t    });\n253\t    mockReadFileSync.mockReturnValue('yaml');\n254\t    mockParse.mockReturnValue({\n255\t      development_status: {\n256\t        '3-1-foo': 'ready-for-dev',\n257\t      },\n258\t    });\n259\t\n260\t    const items = loadWorkItems('/path/sprint-status.yaml', '/path/issues.yaml');\n261\t\n262\t    expect(items).toEqual([{ key: '3-1-foo', source: 'sprint' }]);\n263\t  });\n264\t\n265\t  it('loads both stories and issues when issues.yaml exists (AC #5)', () => {\n266\t    let callCount = 0;\n267\t    mockExistsSync.mockReturnValue(true);\n268\t    mockReadFileSync.mockReturnValue('yaml');\n269\t    mockParse\n270\t      .mockReturnValueOnce({\n271\t        development_status: {\n272\t          '3-1-foo': 'ready-for-dev',\n273\t        },\n274\t      })\n275\t      .mockReturnValueOnce({\n276\t        issues: [\n277\t          { id: 'issue-001', title: 'Fix docker timeout', status: 'ready-for-dev' },\n278\t          { id: 'issue-002', title: 'Already done', status: 'done' },\n279\t        ],\n280\t      });\n281\t\n282\t    const items = loadWorkItems('/path/sprint-status.yaml', '/path/issues.yaml');\n283\t\n284\t    expect(items).toEqual([\n285\t      { key: '3-1-foo', source: 'sprint' },\n286\t      { key: 'issue-001', title: 'Fix docker timeout', source: 'issues' },\n287\t    ]);\n288\t  });\n289\t\n290\t  it('handles invalid YAML in sprint-status.yaml gracefully', () => {\n291\t    mockExistsSync.mockReturnValue(true);\n292\t    mockReadFileSync.mockReturnValue('yaml');\n293\t    mockParse.mockImplementation(() => {\n294\t      throw new Error('bad yaml');\n295\t    });\n296\t\n297\t    const items = loadWorkItems('/path/sprint-status.yaml');\n298\t    expect(items).toEqual([]);\n299\t    expect(mockWarn).toHaveBeenCalled();\n300\t  });\n301\t});\n302\t\n303\tdescribe('dispatchTask', () => {\n304\t  beforeEach(() => {\n305\t    vi.clearAllMocks();\n306\t    setupDefaultMocks();\n307\t  });\n308\t\n309\t  it('generates trace ID and injects trace prompt per dispatch (AC #11)', async () => {\n310\t    const task = makeTask();\n311\t    const definition = makeDefinition();\n312\t    const state = makeDefaultState();\n313\t    const config = makeConfig();\n314\t\n315\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n316\t\n317\t    expect(mockGenerateTraceId).toHaveBeenCalledWith('run-001', 0, 'implement');\n318\t    expect(mockFormatTracePrompt).toHaveBeenCalledWith('ch-run-001-0-implement');\n319\t    expect(mockDispatchAgent).toHaveBeenCalledWith(\n320\t      definition,\n321\t      'Implement story 5-1-foo',\n322\t      expect.objectContaining({\n323\t        appendSystemPrompt: '[TRACE] trace_id=ch-run-001-0-implement',\n324\t      }),\n325\t    );\n326\t  });\n327\t\n328\t  it('resolves session ID for continue boundary (AC #12)', async () => {\n329\t    const task = makeTask({ session: 'continue' });\n330\t    const definition = makeDefinition();\n331\t    const state = makeDefaultState();\n332\t    const config = makeConfig();\n333\t\n334\t    mockResolveSessionId.mockReturnValue('prev-sess-id');\n335\t\n336\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n337\t\n338\t    expect(mockResolveSessionId).toHaveBeenCalledWith(\n339\t      'continue',\n340\t      { taskName: 'implement', storyKey: '5-1-foo' },\n341\t      state,\n342\t    );\n343\t    expect(mockDispatchAgent).toHaveBeenCalledWith(\n344\t      definition,\n345\t      expect.any(String),\n346\t      expect.objectContaining({ sessionId: 'prev-sess-id' }),\n347\t    );\n348\t  });\n349\t\n350\t  it('dispatches with cwd when source_access is true (default) (AC #10)', async () => {\n351\t    const task = makeTask({ source_access: true });\n352\t    const definition = makeDefinition();\n353\t    const state = makeDefaultState();\n354\t    const config = makeConfig({ projectDir: '/my-project' });\n355\t\n356\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n357\t\n358\t    expect(mockCreateIsolatedWorkspace).not.toHaveBeenCalled();\n359\t    expect(mockDispatchAgent).toHaveBeenCalledWith(\n360\t      definition,\n361\t      expect.any(String),\n362\t      expect.objectContaining({ cwd: '/my-project' }),\n363\t    );\n364\t  });\n365\t\n366\t  it('creates isolated workspace when source_access is false (AC #9)', async () => {\n367\t    const mockWorkspace = {\n368\t      dir: '/tmp/codeharness-verify-run-001',\n369\t      storyFilesDir: '/tmp/codeharness-verify-run-001/story-files',\n370\t      verdictDir: '/tmp/codeharness-verify-run-001/verdict',\n371\t      toDispatchOptions: () => ({ cwd: '/tmp/codeharness-verify-run-001' }),\n372\t      cleanup: vi.fn().mockResolvedValue(undefined),\n373\t    };\n374\t    mockCreateIsolatedWorkspace.mockResolvedValue(mockWorkspace);\n375\t\n376\t    const task = makeTask({ source_access: false });\n377\t    const definition = makeDefinition();\n378\t    const state = makeDefaultState();\n379\t    const config = makeConfig();\n380\t\n381\t    await dispatchTask(task, 'verify', '__run__', definition, state, config);\n382\t\n383\t    expect(mockCreateIsolatedWorkspace).toHaveBeenCalledWith({\n384\t      runId: 'run-001',\n385\t      storyFiles: [],\n386\t    });\n387\t    expect(mockDispatchAgent).toHaveBeenCalledWith(\n388\t      definition,\n389\t      expect.any(String),\n390\t      expect.objectContaining({ cwd: '/tmp/codeharness-verify-run-001' }),\n391\t    );\n392\t    expect(mockWorkspace.cleanup).toHaveBeenCalled();\n393\t  });\n394\t\n395\t  it('writes state to disk after each dispatch (AC #4)', async () => {\n396\t    const task = makeTask();\n397\t    const definition = makeDefinition();\n398\t    const state = makeDefaultState();\n399\t    const config = makeConfig();\n400\t\n401\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n402\t\n403\t    expect(mockWriteWorkflowState).toHaveBeenCalled();\n404\t    // State should have the new checkpoint\n405\t    const writtenState = mockWriteWorkflowState.mock.calls[0][0] as WorkflowState;\n406\t    expect(writtenState.trace_ids).toContain('ch-run-001-0-implement');\n407\t  });\n408\t\n409\t  it('records trace ID in workflow state (AC #11)', async () => {\n410\t    const task = makeTask();\n411\t    const definition = makeDefinition();\n412\t    const state = makeDefaultState();\n413\t    const config = makeConfig();\n414\t\n415\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n416\t\n417\t    expect(mockRecordTraceId).toHaveBeenCalledWith('ch-run-001-0-implement', expect.any(Object));\n418\t  });\n419\t\n420\t  it('records session ID after successful dispatch', async () => {\n421\t    const task = makeTask();\n422\t    const definition = makeDefinition();\n423\t    const state = makeDefaultState();\n424\t    const config = makeConfig();\n425\t\n426\t    await dispatchTask(task, 'implement', '5-1-foo', definition, state, config);\n427\t\n428\t    expect(mockRecordSessionId).toHaveBeenCalledWith(\n429\t      { taskName: 'implement', storyKey: '5-1-foo' },\n430\t      'sess-abc-123',\n431\t      expect.any(Object),\n432\t    );\n433\t  });\n434\t\n435\t  it('cleans up workspace on dispatch error when source_access is false', async () => {\n436\t    const mockWorkspace = {\n437\t      dir: '/tmp/test',\n438\t      storyFilesDir: '/tmp/test/story-files',\n439\t      verdictDir: '/tmp/test/verdict',\n440\t      toDispatchOptions: () => ({ cwd: '/tmp/test' }),\n441\t      cleanup: vi.fn().mockResolvedValue(undefined),\n442\t    };\n443\t    mockCreateIsolatedWorkspace.mockResolvedValue(mockWorkspace);\n444\t    mockDispatchAgent.mockRejectedValue(new Error('dispatch failed'));\n445\t\n446\t    const task = makeTask({ source_access: false });\n447\t    const definition = makeDefinition();\n448\t    const state = makeDefaultState();\n449\t    const config = makeConfig();\n450\t\n451\t    await expect(\n452\t      dispatchTask(task, 'verify', '__run__', definition, state, config),\n453\t    ).rejects.toThrow('dispatch failed');\n454\t\n455\t    // Cleanup should still be called\n456\t    expect(mockWorkspace.cleanup).toHaveBeenCalled();\n457\t  });\n458\t\n459\t  it('constructs per-run prompt for sentinel key', async () => {\n460\t    const task = makeTask({ scope: 'per-run' });\n461\t    const definition = makeDefinition();\n462\t    const state = makeDefaultState();\n463\t    const config = makeConfig();\n464\t\n465\t    await dispatchTask(task, 'verify', '__run__', definition, state, config);\n466\t\n467\t    expect(mockDispatchAgent).toHaveBeenCalledWith(\n468\t      definition,\n469\t      'Execute task \"verify\" for the current run.',\n470\t      expect.any(Object),\n471\t    );\n472\t  });\n473\t});\n474\t\n475\tdescribe('executeWorkflow', () => {\n476\t  beforeEach(() => {\n477\t    vi.clearAllMocks();\n478\t    setupDefaultMocks();\n479\t  });\n480\t\n481\t  it('executes flow steps sequentially in order (AC #2)', async () => {\n482\t    const callOrder: string[] = [];\n483\t    mockDispatchAgent.mockImplementation(\n484\t      async (_def: SubagentDefinition, prompt: string) => {\n485\t        callOrder.push(prompt);\n486\t        return { sessionId: 'sess-1', success: true, durationMs: 100, output: 'ok' };\n487\t      },\n488\t    );\n489\t\n490\t    // Two stories, flow: [implement, verify]\n491\t    mockParse.mockReturnValue({\n492\t      development_status: {\n493\t        '3-1-foo': 'ready-for-dev',\n494\t        '3-2-bar': 'backlog',\n495\t      },\n496\t    });\n497\t\n498\t    const config = makeConfig();\n499\t    const result = await executeWorkflow(config);\n500\t\n501\t    expect(result.success).toBe(true);\n502\t    // implement dispatched for each story, then verify once\n503\t    expect(callOrder).toEqual([\n504\t      'Implement story 3-1-foo',\n505\t      'Implement story 3-2-bar',\n506\t      'Execute task \"verify\" for the current run.',\n507\t    ]);\n508\t  });\n509\t\n510\t  it('dispatches per-story task once per story (AC #3)', async () => {\n511\t    mockParse.mockReturnValue({\n512\t      development_status: {\n513\t        '3-1-foo': 'ready-for-dev',\n514\t        '3-2-bar': 'backlog',\n515\t      },\n516\t    });\n517\t\n518\t    const config = makeConfig({\n519\t      workflow: {\n520\t        tasks: { implement: makeTask() },\n521\t        flow: ['implement'],\n522\t      },\n523\t    });\n524\t\n525\t    const result = await executeWorkflow(config);\n526\t\n527\t    expect(mockDispatchAgent).toHaveBeenCalledTimes(2);\n528\t    expect(result.tasksCompleted).toBe(2);\n529\t    expect(result.storiesProcessed).toBe(2);\n530\t  });\n531\t\n532\t  it('dispatches per-run task exactly once with sentinel key (AC #7)', async () => {\n533\t    mockParse.mockReturnValue({\n534\t      development_status: {\n535\t        '3-1-foo': 'ready-for-dev',\n536\t        '3-2-bar': 'backlog',\n537\t      },\n538\t    });\n539\t\n540\t    const config = makeConfig({\n541\t      workflow: {\n542\t        tasks: { verify: makeTask({ scope: 'per-run' }) },\n543\t        flow: ['verify'],\n544\t      },\n545\t    });\n546\t\n547\t    const result = await executeWorkflow(config);\n548\t\n549\t    expect(mockDispatchAgent).toHaveBeenCalledTimes(1);\n550\t    expect(result.tasksCompleted).toBe(1);\n551\t  });\n552\t\n553\t  it('writes state after each task completion (AC #4)', async () => {\n554\t    mockParse.mockReturnValue({\n555\t      development_status: {\n556\t        '3-1-foo': 'ready-for-dev',\n557\t      },\n558\t    });\n559\t\n560\t    const config = makeConfig({\n561\t      workflow: {\n562\t        tasks: { implement: makeTask() },\n563\t        flow: ['implement'],\n564\t      },\n565\t    });\n566\t\n567\t    await executeWorkflow(config);\n568\t\n569\t    // writeWorkflowState called: initial state + after dispatch + final completed state\n570\t    expect(mockWriteWorkflowState).toHaveBeenCalledTimes(3);\n571\t  });\n572\t\n573\t  it('skips loop blocks with warning (AC #8)', async () => {\n574\t    const config = makeConfig({\n575\t      workflow: {\n576\t        tasks: { implement: makeTask() },\n577\t        flow: ['implement', { loop: ['implement'] }],\n578\t      },\n579\t    });\n580\t\n581\t    mockParse.mockReturnValue({\n582\t      development_status: { '3-1-foo': 'ready-for-dev' },\n583\t    });\n584\t\n585\t    const result = await executeWorkflow(config);\n586\t\n587\t    expect(mockWarn).toHaveBeenCalledWith(\n588\t      expect.stringContaining('loop blocks are not yet implemented'),\n589\t    );\n590\t    // Only the string task should have dispatched\n591\t    expect(mockDispatchAgent).toHaveBeenCalledTimes(1);\n592\t    expect(result.success).toBe(true);\n593\t  });\n594\t\n595\t  it('handles DispatchError and records in result (AC #13)', async () => {\n596\t    const { DispatchError } = await import('../agent-dispatch.js');\n597\t    mockDispatchAgent.mockRejectedValue(\n598\t      new DispatchError('rate limited', 'UNKNOWN', 'dev', new Error('inner')),\n599\t    );\n600\t\n601\t    mockParse.mockReturnValue({\n602\t      development_status: { '3-1-foo': 'ready-for-dev' },\n603\t    });\n604\t\n605\t    const config = makeConfig({\n606\t      workflow: {\n607\t        tasks: { implement: makeTask() },\n608\t        flow: ['implement'],\n609\t      },\n610\t    });\n611\t\n612\t    const result = await executeWorkflow(config);\n613\t\n614\t    expect(result.success).toBe(false);\n615\t    expect(result.errors).toHaveLength(1);\n616\t    expect(result.errors[0].code).toBe('UNKNOWN');\n617\t    expect(result.errors[0].taskName).toBe('implement');\n618\t    expect(result.errors[0].storyKey).toBe('3-1-foo');\n619\t  });\n620\t\n621\t  it('halts on RATE_LIMIT dispatch errors (AC #13)', async () => {\n622\t    const { DispatchError } = await import('../agent-dispatch.js');\n623\t    mockDispatchAgent.mockRejectedValue(\n624\t      new DispatchError('rate limited', 'RATE_LIMIT', 'dev', new Error('inner')),\n625\t    );\n626\t\n627\t    mockParse.mockReturnValue({\n628\t      development_status: {\n629\t        '3-1-foo': 'ready-for-dev',\n630\t        '3-2-bar': 'backlog',\n631\t      },\n632\t    });\n633\t\n634\t    const config = makeConfig({\n635\t      workflow: {\n636\t        tasks: { implement: makeTask() },\n637\t        flow: ['implement'],\n638\t      },\n639\t    });\n640\t\n641\t    const result = await executeWorkflow(config);\n642\t\n643\t    expect(result.success).toBe(false);\n644\t    // Should halt after first error — only one dispatch attempted\n645\t    expect(mockDispatchAgent).toHaveBeenCalledTimes(1);\n646\t    expect(result.errors).toHaveLength(1);\n647\t  });\n648\t\n649\t  it('continues on UNKNOWN errors for per-story tasks (AC #13)', async () => {\n650\t    const { DispatchError } = await import('../agent-dispatch.js');\n651\t    let callCount = 0;\n652\t    mockDispatchAgent.mockImplementation(async () => {\n653\t      callCount++;\n654\t      if (callCount === 1) {\n655\t        throw new DispatchError('unknown error', 'UNKNOWN', 'dev', new Error('inner'));\n656\t      }\n657\t      return { sessionId: 'sess-1', success: true, durationMs: 100, output: 'ok' };\n658\t    });\n659\t\n660\t    mockParse.mockReturnValue({\n661\t      development_status: {\n662\t        '3-1-foo': 'ready-for-dev',\n663\t        '3-2-bar': 'backlog',\n664\t      },\n665\t    });\n666\t\n667\t    const config = makeConfig({\n668\t      workflow: {\n669\t        tasks: { implement: makeTask() },\n670\t        flow: ['implement'],\n671\t      },\n672\t    });\n673\t\n674\t    const result = await executeWorkflow(config);\n675\t\n676\t    // Both stories attempted\n677\t    expect(mockDispatchAgent).toHaveBeenCalledTimes(2);\n678\t    expect(result.errors).toHaveLength(1);\n679\t    expect(result.tasksCompleted).toBe(1);\n680\t  });\n681\t\n682\t  it('sets phase to error on dispatch failure', async () => {\n683\t    const { DispatchError } = await import('../agent-dispatch.js');\n684\t    mockDispatchAgent.mockRejectedValue(\n685\t      new DispatchError('fail', 'UNKNOWN', 'dev', new Error('inner')),\n686\t    );\n687\t\n688\t    mockParse.mockReturnValue({\n689\t      development_status: { '3-1-foo': 'ready-for-dev' },\n690\t    });\n691\t\n692\t    const config = makeConfig({\n693\t      workflow: {\n694\t        tasks: { implement: makeTask() },\n695\t        flow: ['implement'],\n696\t      },\n697\t    });\n698\t\n699\t    await executeWorkflow(config);\n700\t\n701\t    // Find the write call that sets phase to \"error\"\n702\t    const errorWrite = mockWriteWorkflowState.mock.calls.find(\n703\t      (call: unknown[]) => (call[0] as WorkflowState).phase === 'error',\n704\t    );\n705\t    expect(errorWrite).toBeDefined();\n706\t  });\n707\t\n708\t  it('sets phase to completed when no errors occur', async () => {\n709\t    mockParse.mockReturnValue({\n710\t      development_status: { '3-1-foo': 'ready-for-dev' },\n711\t    });\n712\t\n713\t    const config = makeConfig({\n714\t      workflow: {\n715\t        tasks: { implement: makeTask() },\n716\t        flow: ['implement'],\n717\t      },\n718\t    });\n719\t\n720\t    await executeWorkflow(config);\n721\t\n722\t    const lastWrite = mockWriteWorkflowState.mock.calls[\n723\t      mockWriteWorkflowState.mock.calls.length - 1\n724\t    ];\n725\t    expect((lastWrite[0] as WorkflowState).phase).toBe('completed');\n726\t  });\n727\t\n728\t  it('initializes workflow state with phase=executing at start', async () => {\n729\t    mockParse.mockReturnValue({\n730\t      development_status: { '3-1-foo': 'ready-for-dev' },\n731\t    });\n732\t\n733\t    const config = makeConfig({\n734\t      workflow: {\n735\t        tasks: { implement: makeTask() },\n736\t        flow: ['implement'],\n737\t      },\n738\t    });\n739\t\n740\t    await executeWorkflow(config);\n741\t\n742\t    const firstWrite = mockWriteWorkflowState.mock.calls[0];\n743\t    expect((firstWrite[0] as WorkflowState).phase).toBe('executing');\n744\t  });\n745\t\n746\t  it('invokes source isolation for per-run task with source_access false', async () => {\n747\t    const mockWorkspace = {\n748\t      dir: '/tmp/test',\n749\t      storyFilesDir: '/tmp/test/story-files',\n750\t      verdictDir: '/tmp/test/verdict',\n751\t      toDispatchOptions: () => ({ cwd: '/tmp/test' }),\n752\t      cleanup: vi.fn().mockResolvedValue(undefined),\n753\t    };\n754\t    mockCreateIsolatedWorkspace.mockResolvedValue(mockWorkspace);\n755\t\n756\t    mockParse.mockReturnValue({\n757\t      development_status: { '3-1-foo': 'ready-for-dev' },\n758\t    });\n759\t\n760\t    const config = makeConfig({\n761\t      workflow: {\n762\t        tasks: {\n763\t          verify: makeTask({ scope: 'per-run', source_access: false }),\n764\t        },\n765\t        flow: ['verify'],\n766\t      },\n767\t    });\n768\t\n769\t    await executeWorkflow(config);\n770\t\n771\t    expect(mockCreateIsolatedWorkspace).toHaveBeenCalled();\n772\t    expect(mockWorkspace.cleanup).toHaveBeenCalled();\n773\t  });\n774\t\n775\t  it('does NOT invoke source isolation for source_access true tasks', async () => {\n776\t    mockParse.mockReturnValue({\n777\t      development_status: { '3-1-foo': 'ready-for-dev' },\n778\t    });\n779\t\n780\t    const config = makeConfig({\n781\t      workflow: {\n782\t        tasks: { implement: makeTask({ source_access: true }) },\n783\t        flow: ['implement'],\n784\t      },\n785\t    });\n786\t\n787\t    await executeWorkflow(config);\n788\t\n789\t    expect(mockCreateIsolatedWorkspace).not.toHaveBeenCalled();\n790\t  });\n791\t\n792\t  it('returns correct EngineResult shape', async () => {\n793\t    mockParse.mockReturnValue({\n794\t      development_status: {\n795\t        '3-1-foo': 'ready-for-dev',\n796\t        '3-2-bar': 'backlog',\n797\t      },\n798\t    });\n799\t\n800\t    const config = makeConfig({\n801\t      workflow: {\n802\t        tasks: {\n803\t          implement: makeTask(),\n804\t          verify: makeTask({ scope: 'per-run' }),\n805\t        },\n806\t        flow: ['implement', 'verify'],\n807\t      },\n808\t    });\n809\t\n810\t    const result = await executeWorkflow(config);\n811\t\n812\t    expect(result).toEqual(\n813\t      expect.objectContaining({\n814\t        success: true,\n815\t        tasksCompleted: 3, // 2 per-story + 1 per-run\n816\t        storiesProcessed: 2,\n817\t        errors: [],\n818\t      }),\n819\t    );\n820\t    expect(typeof result.durationMs).toBe('number');\n821\t    expect(result.durationMs).toBeGreaterThanOrEqual(0);\n822\t  });\n823\t\n824\t  it('handles empty work items list gracefully', async () => {\n825\t    mockExistsSync.mockReturnValue(false);\n826\t\n827\t    const config = makeConfig({\n828\t      workflow: {\n829\t        tasks: { implement: makeTask() },\n830\t        flow: ['implement'],\n831\t      },\n832\t    });\n833\t\n834\t    const result = await executeWorkflow(config);\n835\t\n836\t    expect(result.success).toBe(true);\n837\t    expect(result.tasksCompleted).toBe(0);\n838\t    expect(result.storiesProcessed).toBe(0);\n839\t  });\n840\t\n841\t  it('skips tasks with missing agent definition', async () => {\n842\t    mockParse.mockReturnValue({\n843\t      development_status: { '3-1-foo': 'ready-for-dev' },\n844\t    });\n845\t\n846\t    const config = makeConfig({\n847\t      workflow: {\n848\t        tasks: { implement: makeTask({ agent: 'nonexistent' }) },\n849\t        flow: ['implement'],\n850\t      },\n851\t      agents: {}, // no agents\n852\t    });\n853\t\n854\t    const result = await executeWorkflow(config);\n855\t\n856\t    expect(mockWarn).toHaveBeenCalledWith(expect.stringContaining('agent'));\n857\t    expect(result.success).toBe(true);\n858\t    expect(result.tasksCompleted).toBe(0);\n859\t  });\n860\t\n861\t  it('halts on NETWORK dispatch errors for per-run tasks', async () => {\n862\t    const { DispatchError } = await import('../agent-dispatch.js');\n863\t    mockDispatchAgent.mockRejectedValue(\n864\t      new DispatchError('network fail', 'NETWORK', 'dev', new Error('inner')),\n865\t    );\n866\t\n867\t    mockParse.mockReturnValue({\n868\t      development_status: { '3-1-foo': 'ready-for-dev' },\n869\t    });\n870\t\n871\t    const config = makeConfig({\n872\t      workflow: {\n873\t        tasks: {\n874\t          implement: makeTask(),\n875\t          verify: makeTask({ scope: 'per-run' }),\n876\t        },\n877\t        flow: ['verify', 'implement'],\n878\t      },\n879\t    });\n880\t\n881\t    const result = await executeWorkflow(config);\n882\t\n883\t    expect(result.success).toBe(false);\n884\t    // Should halt after verify fails — implement never runs\n885\t    expect(mockDispatchAgent).toHaveBeenCalledTimes(1);\n886\t  });\n887\t});\n888\t"}]},"parent_tool_use_id":"toolu_011dV6c9xFAQaHP6KDdoVM36","session_id":"7bb08296-a865-42eb-9710-ebdb6ccedbda","uuid":"c88403fa-6512-4ec6-9144-fa5dfd12869a","timestamp":"2026-04-02T21:54:35.522Z"}
