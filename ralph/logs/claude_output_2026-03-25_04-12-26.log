{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AfkeVdfAo9rWTuWW1B6eTL","type":"tool_result","content":"     1→import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n     2→import { mkdtempSync, rmSync, mkdirSync, writeFileSync } from 'node:fs';\n     3→import { tmpdir } from 'node:os';\n     4→import { join } from 'node:path';\n     5→\n     6→vi.mock('node:child_process', () => ({\n     7→  execFileSync: vi.fn(),\n     8→}));\n     9→\n    10→import { execFileSync } from 'node:child_process';\n    11→import {\n    12→  bdCommand,\n    13→  createIssue,\n    14→  getReady,\n    15→  closeIssue,\n    16→  updateIssue,\n    17→  listIssues,\n    18→  isBeadsInitialized,\n    19→  initBeads,\n    20→  detectBeadsHooks,\n    21→  configureHookCoexistence,\n    22→  buildGapId,\n    23→  findExistingByGapId,\n    24→  appendGapId,\n    25→  createOrFindIssue,\n    26→  BeadsError,\n    27→} from '../beads.js';\n    28→import type { BeadsIssue } from '../beads.js';\n    29→\n    30→const mockExecFileSync = vi.mocked(execFileSync);\n    31→\n    32→let testDir: string;\n    33→\n    34→beforeEach(() => {\n    35→  vi.restoreAllMocks();\n    36→  testDir = mkdtempSync(join(tmpdir(), 'ch-beads-test-'));\n    37→});\n    38→\n    39→afterEach(() => {\n    40→  rmSync(testDir, { recursive: true, force: true });\n    41→});\n    42→\n    43→describe('BeadsError', () => {\n    44→  it('includes command and original message in error message', () => {\n    45→    const err = new BeadsError('bd create \"test\" --json', 'command not found');\n    46→    expect(err.message).toBe('Beads failed: command not found. Command: bd create \"test\" --json');\n    47→    expect(err.name).toBe('BeadsError');\n    48→    expect(err.command).toBe('bd create \"test\" --json');\n    49→    expect(err.originalMessage).toBe('command not found');\n    50→  });\n    51→\n    52→  it('is an instance of Error', () => {\n    53→    const err = new BeadsError('bd init', 'failed');\n    54→    expect(err).toBeInstanceOf(Error);\n    55→  });\n    56→});\n    57→\n    58→describe('bdCommand', () => {\n    59→  it('runs bd with given args and parses JSON output', () => {\n    60→    mockExecFileSync.mockReturnValue(Buffer.from('{\"id\":\"1\",\"title\":\"test\"}'));"}]},"parent_tool_use_id":"toolu_01KNQnUKBFtzFzrosUg6K7qd","session_id":"7d2c764f-deb1-4354-ad31-e0a846d19ae3","uuid":"e2924122-f2ed-432f-ba9c-986870489657","timestamp":"2026-03-25T00:21:53.503Z"}
