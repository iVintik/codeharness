{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MTYbvAfrEAKUUQqJCYzPWV","type":"tool_result","content":"1\timport { readFileSync, existsSync } from 'node:fs';\n2\timport { join } from 'node:path';\n3\timport { parse } from 'yaml';\n4\timport { warn } from './output.js';\n5\timport { DispatchError } from './agent-dispatch.js';\n6\timport type { DispatchErrorCode } from './agent-dispatch.js';\n7\t// Note: dispatchAgent is no longer imported — dispatch goes through the driver factory\n8\timport { getDriver } from './agents/drivers/factory.js';\n9\timport { checkCapabilityConflicts } from './agents/capability-check.js';\n10\timport { resolveModel } from './agents/model-resolver.js';\n11\timport type { DispatchOpts, DriverHealth, OutputContract } from './agents/types.js';\n12\timport type { ResultEvent, ToolStartEvent } from './agents/stream-parser.js';\n13\timport type { SubagentDefinition } from './agent-resolver.js';\n14\timport type { ResolvedWorkflow, ResolvedTask, FlowStep, LoopBlock } from './workflow-parser.js';\n15\timport {\n16\t  readWorkflowState,\n17\t  writeWorkflowState,\n18\t} from './workflow-state.js';\n19\timport { buildPromptWithContractContext, writeOutputContract } from './agents/output-contract.js';\n20\timport type { WorkflowState, TaskCheckpoint } from './workflow-state.js';\n21\timport { createIsolatedWorkspace } from './source-isolation.js';\n22\timport { generateTraceId, formatTracePrompt, recordTraceId } from './trace-id.js';\n23\timport { resolveSessionId, recordSessionId } from './session-manager.js';\n24\timport type { SessionLookupKey } from './session-manager.js';\n25\timport { parseVerdict, VerdictParseError } from './verdict-parser.js';\n26\timport type { EvaluatorVerdict } from './verdict-parser.js';\n27\timport { evaluateProgress } from './circuit-breaker.js';\n28\timport { getNullTask, listNullTasks } from './null-task-registry.js';\n29\timport type { TaskContext, NullTaskResult } from './null-task-registry.js';\n30\timport { readStateWithBody, writeState } from './state.js';\n31\t\n32\t// Re-export EvaluatorVerdict for downstream consumers that import from workflow-engine\n33\texport type { EvaluatorVerdict } from './verdict-parser.js';\n34\texport { parseVerdict } from './verdict-parser.js';\n35\t\n36\t// --- Interfaces ---\n37\t\n38\t/**\n39\t * Configuration for the workflow engine.\n40\t */\n41\texport interface EngineConfig {\n42\t  /** The resolved workflow with tasks and flow steps. */\n43\t  workflow: ResolvedWorkflow;\n44\t  /** Pre-compiled agent definitions keyed by agent name. */\n45\t  agents: Record<string, SubagentDefinition>;\n46\t  /** Path to sprint-status.yaml for work item discovery. */\n47\t  sprintStatusPath: string;\n48\t  /** Optional path to issues.yaml for additional work items. */\n49\t  issuesPath?: string;\n50\t  /** Unique identifier for this engine run. */\n51\t  runId: string;\n52\t  /** Project root directory. Defaults to process.cwd(). */\n53\t  projectDir?: string;\n54\t  /** Maximum loop iterations before termination. Defaults to 5. */\n55\t  maxIterations?: number;\n56\t}\n57\t\n58\t/**\n59\t * Result returned by executeWorkflow().\n60\t */\n61\texport interface EngineResult {\n62\t  /** Whether the workflow completed without errors. */\n63\t  success: boolean;\n64\t  /** Number of task dispatches completed. */\n65\t  tasksCompleted: number;\n66\t  /** Number of work items (stories/issues) processed. */\n67\t  storiesProcessed: number;\n68\t  /** Errors encountered during execution. */\n69\t  errors: EngineError[];\n70\t  /** Wall-clock duration of the entire workflow in milliseconds. */\n71\t  durationMs: number;\n72\t}\n73\t\n74\t/**\n75\t * Structured error recorded during workflow execution.\n76\t */\n77\texport interface EngineError {\n78\t  taskName: string;\n79\t  storyKey: string;\n80\t  code: string;"}]},"parent_tool_use_id":"toolu_01Hody5ZigZ3cTLmGuBw8VE3","session_id":"b6bb3bfc-8778-4f16-a616-88028acc2431","uuid":"65ca57fe-8e96-49fe-8e22-a931bb78687f","timestamp":"2026-04-03T18:31:27.551Z"}
