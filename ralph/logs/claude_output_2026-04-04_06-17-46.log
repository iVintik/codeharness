{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016xX9xzQZhG1GtyUBfzFtx4","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { render } from 'ink-testing-library';\n3\timport React from 'react';\n4\timport { Header } from '../ink-components.js';\n5\timport type { SprintInfo } from '../ink-components.js';\n6\t\n7\tfunction makeSprintInfo(overrides?: Partial<SprintInfo>): SprintInfo {\n8\t  return {\n9\t    storyKey: '10-3',\n10\t    phase: 'dev',\n11\t    done: 2,\n12\t    total: 5,\n13\t    elapsed: '18m',\n14\t    iterationCount: 3,\n15\t    totalCost: 4.20,\n16\t    ...overrides,\n17\t  };\n18\t}\n19\t\n20\tdescribe('Header component', () => {\n21\t  it('returns null when info is null', () => {\n22\t    const { lastFrame } = render(<Header info={null} />);\n23\t    expect(lastFrame()).toBe('');\n24\t  });\n25\t\n26\t  it('renders basic header without lane count', () => {\n27\t    const { lastFrame } = render(<Header info={makeSprintInfo()} />);\n28\t    const frame = lastFrame()!;\n29\t    expect(frame).toContain('codeharness run');\n30\t    expect(frame).toContain('18m elapsed');\n31\t    expect(frame).toContain('$4.20 spent');\n32\t    expect(frame).not.toContain('lanes');\n33\t  });\n34\t\n35\t  it('shows lane count when laneCount > 1', () => {\n36\t    const { lastFrame } = render(\n37\t      <Header info={makeSprintInfo()} laneCount={2} />\n38\t    );\n39\t    const frame = lastFrame()!;\n40\t    expect(frame).toContain('2 lanes');\n41\t  });\n42\t\n43\t  it('shows lane count of 3 when laneCount is 3', () => {\n44\t    const { lastFrame } = render(\n45\t      <Header info={makeSprintInfo()} laneCount={3} />\n46\t    );\n47\t    const frame = lastFrame()!;\n48\t    expect(frame).toContain('3 lanes');\n49\t  });\n50\t\n51\t  it('omits lane count when laneCount is 1', () => {\n52\t    const { lastFrame } = render(\n53\t      <Header info={makeSprintInfo()} laneCount={1} />\n54\t    );\n55\t    const frame = lastFrame()!;\n56\t    expect(frame).not.toContain('lanes');\n57\t  });\n58\t\n59\t  it('omits lane count when laneCount is undefined', () => {\n60\t    const { lastFrame } = render(\n61\t      <Header info={makeSprintInfo()} />\n62\t    );\n63\t    const frame = lastFrame()!;\n64\t    expect(frame).not.toContain('lanes');\n65\t  });\n66\t\n67\t  it('shows total cost across lanes when in multi-lane mode', () => {\n68\t    const info = makeSprintInfo({ laneTotalCost: 18.60, totalCost: 4.20 });\n69\t    const { lastFrame } = render(\n70\t      <Header info={info} laneCount={2} />\n71\t    );\n72\t    const frame = lastFrame()!;\n73\t    // In multi-lane mode, laneTotalCost should be displayed instead of totalCost\n74\t    expect(frame).toContain('$18.60 spent');\n75\t    expect(frame).not.toContain('$4.20');\n76\t  });\n77\t\n78\t  it('falls back to totalCost when laneTotalCost is not set in multi-lane mode', () => {\n79\t    const info = makeSprintInfo({ totalCost: 4.20 });\n80\t    const { lastFrame } = render(\n81\t      <Header info={info} laneCount={2} />\n82\t    );\n83\t    const frame = lastFrame()!;\n84\t    expect(frame).toContain('$4.20 spent');\n85\t  });\n86\t\n87\t  it('shows single-lane totalCost when laneCount is 1', () => {\n88\t    const info = makeSprintInfo({ totalCost: 5.50, laneTotalCost: 10.00 });\n89\t    const { lastFrame } = render(\n90\t      <Header info={info} laneCount={1} />\n91\t    );\n92\t    const frame = lastFrame()!;\n93\t    // When laneCount is 1 (not multi-lane), should use totalCost\n94\t    expect(frame).toContain('$5.50 spent');\n95\t  });\n96\t\n97\t  it('renders header format with pipes between parts', () => {\n98\t    const info = makeSprintInfo({ iterationCount: 5 });\n99\t    const { lastFrame } = render(\n100\t      <Header info={info} laneCount={2} />\n101\t    );\n102\t    const frame = lastFrame()!;\n103\t    // Format: codeharness run | 2 lanes | iteration 5 | 18m elapsed | $X.XX spent\n104\t    expect(frame).toContain('codeharness run | 2 lanes');\n105\t    expect(frame).toContain('| iteration 5');\n106\t  });\n107\t\n108\t  it('renders story key line', () => {\n109\t    const { lastFrame } = render(\n110\t      <Header info={makeSprintInfo({ storyKey: '14-2' })} />\n111\t    );\n112\t    const frame = lastFrame()!;\n113\t    expect(frame).toContain('Story: 14-2');\n114\t  });\n115\t\n116\t  it('renders phase and AC progress', () => {\n117\t    const info = makeSprintInfo({ phase: 'verify', acProgress: '7/9' });\n118\t    const { lastFrame } = render(<Header info={info} />);\n119\t    const frame = lastFrame()!;\n120\t    expect(frame).toContain('Phase: verify');\n121\t    expect(frame).toContain('AC 7/9');\n122\t  });\n123\t});\n124\t"}]},"parent_tool_use_id":"toolu_01LF9uJNPtHNwmRNh99eK7QX","session_id":"0c112080-0896-4e32-96a0-f82adec16922","uuid":"7a9df8f6-1f96-422c-854a-ecb70e961a62","timestamp":"2026-04-04T02:26:31.942Z"}
