70→  });\n   571→\n   572→  it('sets baseline on first run when it was null', () => {\n   573→    const state = getDefaultState('nodejs');\n   574→    state.coverage.baseline = null;\n   575→    writeState(state, testDir);\n   576→\n   577→    const result: CoverageResult = {\n   578→      success: true,\n   579→      testsPassed: true,\n   580→      passCount: 10,\n   581→      failCount: 0,\n   582→      coveragePercent: 75,\n   583→      rawOutput: '',\n   584→    };\n   585→    const evaluation: CoverageEvaluation = {\n   586→      met: false,\n   587→      target: 100,\n   588→      actual: 75,\n   589→      delta: null,\n   590→      baseline: 75,\n   591→    };\n   592→\n   593→    updateCoverageState(result, evaluation, testDir);\n   594→\n   595→    const { state: updated } = readStateWithBody(testDir);\n   596→    expect(updated.coverage.baseline).toBe(75);\n   597→  });\n   598→\n   599→  it('does not overwrite existing baseline', () => {\n   600→    const state = getDefaultState('nodejs');\n   601→    state.coverage.baseline = 50;\n   602→    writeState(state, testDir);\n   603→\n   604→    const result: CoverageResult = {\n   605→      success: true,\n   606→      testsPassed: true,\n   607→      passCount: 10,\n   608→      failCount: 0,\n   609→      coveragePercent: 90,\n   610→      rawOutput: '',\n   611→    };\n   612→    const evaluation: CoverageEvaluation = {\n   613→      met: false,\n   614→      target: 100,\n   615→      actual: 90,\n   616→      delta: 40,\n   617→      baseline: 50,\n   618→    };\n   619→\n   620→    updateCoverageState(result, evaluation, testDir);\n   621→\n   622→    const { state: updated } = readStateWithBody(testDir);\n   623→    expect(updated.coverage.baseline).toBe(50);\n   624→  });\n   625→});\n   626→\n   627→// ─── formatCoverageOutput ────────────────────────────────────────────────────\n   628→\n   629→describe('formatCoverageOutput', () => {\n   630→  it('formats passing coverage', () => {\n   631→    const evaluation: CoverageEvaluation = {\n   632→      met: true,\n   633→      target: 100,\n   634→      actual: 100,\n   635→      delta: null,\n   636→      baseline: 100,\n   637→    };\n   638→\n   639→    const lines = formatCoverageOutput(evaluation);\n   640→    expect(lines).toEqual(['[OK] Coverage: 100%']);\n   641→  });\n   642→\n   643→  it('formats failing coverage', () => {\n   644→    const evaluation: CoverageEvaluation = {\n   645→      met: false,\n   646→      target: 100,\n   647→      actual: 87,\n   648→      delta: null,\n   649→      baseline: 87,\n   650→    };\n   651→\n   652→    const lines = formatCoverageOutput(evaluation);\n   653→    expect(lines).toEqual(['[FAIL] Coverage: 87% (target: 100%)']);\n   654→  });\n   655→\n   656→  it('includes delta when available', () => {\n   657→    const evaluation: CoverageEvaluation = {\n   658→      met: true,\n   659→      target: 100,\n   660→      actual: 100,\n   661→      delta: 4,\n   662→      baseline: 96,\n   663→    };\n   664→\n   665→    const lines = formatCoverageOutput(evaluation);\n   666→    expect(lines).toHaveLength(2);\n   667→    expect(lines[0]).toBe('[OK] Coverage: 100%');\n   668→    expect(lines[1]).toBe('[INFO] Coverage delta: +4% (96% -> 100%)');\n   669→  });\n   670→\n   671→  it('formats negative delta', () => {\n   672→    const evaluation: CoverageEvaluation = {\n   673→      met: false,\n   674→      target: 100,\n   675→      actual: 85,\n   676→      delta: -5,\n   677→      baseline: 90,\n   678→    };\n   679→\n   680→    const lines = formatCoverageOutput(evaluation);\n   681→    expect(lines[1]).toBe('[INFO] Coverage delta: -5% (90% -> 85%)');\n   682→  });\n   683→});\n   684→\n   685→// ─── printCoverageOutput ─────────────────────────────────────────────────────\n   686→\n   687→describe('printCoverageOutput', () => {\n   688→  it('calls console.log with formatted output for passing tests', () => {\n   689→    const consoleSpy = vi.spyOn(console, 'log').moc