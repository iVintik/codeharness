{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DRCyCQBZmr2jkU3WUSb36u","type":"tool_result","content":"1\t/**\n2\t * Worktree Manager.\n3\t *\n4\t * Handles git worktree lifecycle for parallel epic execution:\n5\t * create, cleanup, list, and orphan detection. Each epic gets\n6\t * its own git worktree on a dedicated branch under the\n7\t * `codeharness/` namespace.\n8\t *\n9\t * @see Story 17-1: Worktree Manager\n10\t */\n11\t\n12\timport { execSync } from 'node:child_process';\n13\timport { existsSync, readFileSync, statSync } from 'node:fs';\n14\timport { join } from 'node:path';\n15\t\n16\t// --- Constants ---\n17\t\n18\t/** Branch prefix for all codeharness worktree branches. */\n19\texport const BRANCH_PREFIX = 'codeharness/epic-';\n20\t\n21\t/** Base path for worktree directories in /tmp. */\n22\texport const WORKTREE_BASE = '/tmp/codeharness-wt-epic-';\n23\t\n24\t// --- Interfaces ---\n25\t\n26\t/**\n27\t * Information about a codeharness worktree.\n28\t */\n29\texport interface WorktreeInfo {\n30\t  /** Epic identifier extracted from the branch name. */\n31\t  readonly epicId: string;\n32\t  /** Absolute path to the worktree directory. */\n33\t  readonly path: string;\n34\t  /** Full branch name (e.g., `codeharness/epic-17-worktree-manager`). */\n35\t  readonly branch: string;\n36\t  /** Timestamp when the worktree was created. */\n37\t  readonly createdAt: Date;\n38\t}\n39\t\n40\t// --- Error Class ---\n41\t\n42\t/**\n43\t * Error thrown by worktree operations. Includes stderr from git commands.\n44\t */\n45\texport class WorktreeError extends Error {\n46\t  /** Raw stderr output from the failed git command. */\n47\t  readonly stderr: string;\n48\t\n49\t  constructor(message: string, stderr: string) {\n50\t    super(message);\n51\t    this.name = 'WorktreeError';\n52\t    this.stderr = stderr;\n53\t  }\n54\t}\n55\t\n56\t// --- WorktreeManager Class ---\n57\t\n58\t/**\n59\t * Manages git worktrees for parallel epic execution.\n60\t *\n61\t * Creates isolated working directories (worktrees) for each epic,\n62\t * each on its own branch under the `codeharness/` namespace.\n63\t */\n64\texport class WorktreeManager {\n65\t  private readonly mainBranch: string;\n66\t  private readonly cwd: string;\n67\t\n68\t  /**\n69\t   * @param mainBranch  The main branch to base new worktree branches on (default: `'main'`).\n70\t   * @param cwd  The git repository root directory (default: `process.cwd()`).\n71\t   */\n72\t  constructor(mainBranch: string = 'main', cwd?: string) {\n73\t    this.mainBranch = mainBranch;\n74\t    this.cwd = cwd ?? process.cwd();\n75\t  }\n76\t\n77\t  /**\n78\t   * Create a worktree for a parallel epic.\n79\t   *\n80\t   * Creates a branch `codeharness/epic-{epicId}-{slug}` from the main branch HEAD,\n81\t   * then creates a git worktree at `/tmp/codeharness-wt-epic-{epicId}`.\n82\t   *\n83\t   * If a stale branch or worktree exists from a previous crashed run,\n84\t   * it is cleaned up before re-creating (idempotent recovery).\n85\t   *\n86\t   * @param epicId  The epic identifier (numeric or string).\n87\t   * @param slug  A human-readable slug for the branch name (sanitized to `[a-z0-9-]`).\n88\t   * @returns The absolute path to the created worktree directory.\n89\t   * @throws {WorktreeError} If the git command fails.\n90\t   */\n91\t  createWorktree(epicId: string, slug: string): string {\n92\t    this.validateEpicId(epicId);\n93\t    const sanitizedSlug = this.sanitizeSlug(slug);\n94\t    const branchName = `${BRANCH_PREFIX}${epicId}-${sanitizedSlug}`;\n95\t    const worktreePath = `${WORKTREE_BASE}${epicId}`;\n96\t\n97\t    // Clean up stale state from previous crashed runs (AC #9)\n98\t    this.cleanupStale(epicId, branchName, worktreePath);\n99\t\n100\t    let branchCreated = false;\n101\t    try {\n102\t      // Create branch from main branch HEAD\n103\t      this.execGit(`git branch ${branchName} ${this.mainBranch}`);\n104\t      branchCreated = true;\n105\t\n106\t      // Create worktree\n107\t      this.execGit(`git worktree add ${worktreePath} ${branchName}`);\n108\t\n109\t      return worktreePath;\n110\t    } catch (err: unknown) {\n111\t      // Clean up partial state on failure (AC #10)\n112\t      this.cleanupPartial(branchCreated, branchName, worktreePath);\n113\t\n114\t      // execGit always wraps errors as WorktreeError; re-throw directly\n115\t      if (err instanceof WorktreeError) {\n116\t        throw err;\n117\t      }\n118\t\n119\t      // Defensive: handle unexpected non-WorktreeError (should not happen)\n120\t      const message = err instanceof Error ? err.message : String(err);\n121\t      throw new WorktreeError(\n122\t        `Failed to create worktree for epic ${epicId}: ${message}`,\n123\t        '',\n124\t      );\n125\t    }\n126\t  }\n127\t\n128\t  /**\n129\t   * Remove a worktree and its branch for an epic.\n130\t   *\n131\t   * Idempotent: completes without error if the worktree or branch\n132\t   * does not exist (AC #5).\n133\t   *\n134\t   * @param epicId  The epic identifier.\n135\t   */\n136\t  cleanupWorktree(epicId: string): void {\n137\t    this.validateEpicId(epicId);\n138\t    const worktreePath = `${WORKTREE_BASE}${epicId}`;\n139\t\n140\t    // Remove worktree (ignore errors if it doesn't exist)\n141\t    try {\n142\t      this.execGit(`git worktree remove ${worktreePath} --force`);\n143\t    } catch { // IGNORE: idempotent cleanup — worktree may not exist per AC #5\n144\t    }\n145\t\n146\t    // Find and delete the branch matching this epicId\n147\t    const branch = this.findBranchForEpic(epicId);\n148\t    if (branch) {\n149\t      try {\n150\t        this.execGit(`git branch -D ${branch}`);\n151\t      } catch { // IGNORE: idempotent cleanup — branch may not exist per AC #5\n152\t      }\n153\t    }\n154\t  }\n155\t\n156\t  /**\n157\t   * List all codeharness worktrees.\n158\t   *\n159\t   * @returns An array of `WorktreeInfo` objects sorted by epicId.\n160\t   *          Returns an empty array when no codeharness worktrees exist.\n161\t   */\n162\t  listWorktrees(): WorktreeInfo[] {\n163\t    let output: string;\n164\t    try {\n165\t      output = this.execGit('git worktree list --porcelain');\n166\t    } catch { // IGNORE: non-git-repo or corrupt state returns empty list safely\n167\t      return [];\n168\t    }\n169\t\n170\t    const entries = this.parsePorcelainOutput(output);\n171\t    return entries\n172\t      .filter((e) => e.branch.startsWith(`refs/heads/${BRANCH_PREFIX}`))\n173\t      .map((e) => {\n174\t        const branchName = e.branch.replace('refs/heads/', '');\n175\t        const epicId = this.extractEpicId(branchName);\n176\t        return {\n177\t          epicId,\n178\t          path: e.path,\n179\t          branch: branchName,\n180\t          createdAt: this.getWorktreeCreatedAt(e.path),\n181\t        };\n182\t      })\n183\t      .sort((a, b) => a.epicId.localeCompare(b.epicId, undefined, { numeric: true }));\n184\t  }\n185\t\n186\t  /**\n187\t   * Detect orphaned worktrees from previous crashed runs.\n188\t   *\n189\t   * A worktree is considered orphaned if its directory exists on disk\n190\t   * but has no `.codeharness/lane-state.json` file or the file has\n191\t   * no active PID.\n192\t   *\n193\t   * @returns An array of orphaned `WorktreeInfo` entries.\n194\t   */\n195\t  detectOrphans(): WorktreeInfo[] {\n196\t    const worktrees = this.listWorktrees();\n197\t    return worktrees.filter((wt) => this.isOrphaned(wt));\n198\t  }\n199\t\n200\t  // --- Private Helpers ---\n201\t\n202\t  /**\n203\t   * Get the creation time of a worktree directory.\n204\t   * Falls back to current time if the directory doesn't exist or stat fails.\n205\t   */\n206\t  private getWorktreeCreatedAt(worktreePath: string): Date {\n207\t    try {\n208\t      const stats = statSync(worktreePath);\n209\t      return stats.birthtime;\n210\t    } catch { // IGNORE: stat failure — worktree dir may not be accessible; fall back to now\n211\t      return new Date();\n212\t    }\n213\t  }\n214\t\n215\t  /**\n216\t   * Validate epicId contains only safe characters `[a-zA-Z0-9-]`.\n217\t   * Prevents command injection via crafted epicId values.\n218\t   */\n219\t  private validateEpicId(epicId: string): void {\n220\t    if (!epicId || !/^[a-zA-Z0-9-]+$/.test(epicId)) {\n221\t      throw new WorktreeError(\n222\t        `Invalid epicId: \"${epicId}\" — must be non-empty and contain only [a-zA-Z0-9-]`,\n223\t        '',\n224\t      );\n225\t    }\n226\t  }\n227\t\n228\t  /**\n229\t   * Sanitize a slug to contain only `[a-z0-9-]`.\n230\t   */\n231\t  private sanitizeSlug(slug: string): string {\n232\t    return slug\n233\t      .toLowerCase()\n234\t      .replace(/[^a-z0-9-]/g, '-')\n235\t      .replace(/-+/g, '-')\n236\t      .replace(/^-|-$/g, '');\n237\t  }\n238\t\n239\t  /**\n240\t   * Execute a git command and return its stdout.\n241\t   * Wraps errors in WorktreeError with captured stderr.\n242\t   */\n243\t  private execGit(cmd: string): string {\n244\t    try {\n245\t      const result = execSync(cmd, {\n246\t        cwd: this.cwd,\n247\t        stdio: ['pipe', 'pipe', 'pipe'],\n248\t        timeout: 30_000,\n249\t      });\n250\t      return result.toString().trim();\n251\t    } catch (err: unknown) {\n252\t      const stderr = (err as { stderr?: Buffer })?.stderr?.toString() ?? '';\n253\t      throw new WorktreeError(`Git command failed: ${cmd} — ${stderr}`, stderr);\n254\t    }\n255\t  }\n256\t\n257\t  /**\n258\t   * Clean up stale branch and worktree from a previous crash (AC #9).\n259\t   */\n260\t  private cleanupStale(epicId: string, branchName: string, worktreePath: string): void {\n261\t    // Check if worktree path exists on disk\n262\t    if (existsSync(worktreePath)) {\n263\t      try {\n264\t        this.execGit(`git worktree remove ${worktreePath} --force`);\n265\t      } catch { // IGNORE: stale worktree removal is best-effort before re-create per AC #9\n266\t        try {\n267\t          this.execGit('git worktree prune');\n268\t        } catch { // IGNORE: prune is best-effort fallback for stale worktree cleanup\n269\t        }\n270\t      }\n271\t    }\n272\t\n273\t    // Check if branch already exists\n274\t    const existingBranch = this.findBranchForEpic(epicId);\n275\t    if (existingBranch) {\n276\t      try {\n277\t        this.execGit(`git branch -D ${existingBranch}`);\n278\t      } catch { // IGNORE: stale branch deletion is best-effort before re-create per AC #9\n279\t      }\n280\t    }\n281\t  }\n282\t\n283\t  /**\n284\t   * Clean up partial state after a failed createWorktree (AC #10).\n285\t   */\n286\t  private cleanupPartial(branchCreated: boolean, branchName: string, worktreePath: string): void {\n287\t    // Try to remove worktree if it was partially created\n288\t    try {\n289\t      this.execGit(`git worktree remove ${worktreePath} --force`);\n290\t    } catch { // IGNORE: partial worktree may not exist during failure cleanup per AC #10\n291\t    }\n292\t\n293\t    // Delete branch if it was created\n294\t    if (branchCreated) {\n295\t      try {\n296\t        this.execGit(`git branch -D ${branchName}`);\n297\t      } catch { // IGNORE: partial branch may not exist during failure cleanup per AC #10\n298\t      }\n299\t    }\n300\t  }\n301\t\n302\t  /**\n303\t   * Find a branch matching `codeharness/epic-{epicId}-*`.\n304\t   */\n305\t  private findBranchForEpic(epicId: string): string | undefined {\n306\t    try {\n307\t      const output = this.execGit(`git branch --list ${BRANCH_PREFIX}${epicId}-*`);\n308\t      const branches = output\n309\t        .split('\\n')\n310\t        .map((b) => b.trim().replace(/^\\*\\s*/, ''))\n311\t        .filter((b) => b.length > 0);\n312\t      return branches[0];\n313\t    } catch { // IGNORE: branch listing failure means no branch exists — safe to return undefined\n314\t      return undefined;\n315\t    }\n316\t  }\n317\t\n318\t  /**\n319\t   * Parse `git worktree list --porcelain` output into structured entries.\n320\t   */\n321\t  private parsePorcelainOutput(output: string): Array<{ path: string; branch: string }> {\n322\t    if (!output.trim()) return [];\n323\t\n324\t    const blocks = output.split('\\n\\n').filter((b) => b.trim());\n325\t    const entries: Array<{ path: string; branch: string }> = [];\n326\t\n327\t    for (const block of blocks) {\n328\t      const lines = block.split('\\n');\n329\t      let path = '';\n330\t      let branch = '';\n331\t\n332\t      for (const line of lines) {\n333\t        if (line.startsWith('worktree ')) {\n334\t          path = line.slice('worktree '.length);\n335\t        } else if (line.startsWith('branch ')) {\n336\t          branch = line.slice('branch '.length);\n337\t        }\n338\t      }\n339\t\n340\t      if (path && branch) {\n341\t        entries.push({ path, branch });\n342\t      }\n343\t    }\n344\t\n345\t    return entries;\n346\t  }\n347\t\n348\t  /**\n349\t   * Extract epicId from a branch name like `codeharness/epic-17-slug`.\n350\t   */\n351\t  private extractEpicId(branchName: string): string {\n352\t    const withoutPrefix = branchName.slice(BRANCH_PREFIX.length);\n353\t    const dashIndex = withoutPrefix.indexOf('-');\n354\t    if (dashIndex === -1) return withoutPrefix;\n355\t    return withoutPrefix.slice(0, dashIndex);\n356\t  }\n357\t\n358\t  /**\n359\t   * Check if a worktree is orphaned (no active codeharness process).\n360\t   */\n361\t  private isOrphaned(wt: WorktreeInfo): boolean {\n362\t    const laneStatePath = join(wt.path, '.codeharness', 'lane-state.json');\n363\t\n364\t    if (!existsSync(laneStatePath)) {\n365\t      return true;\n366\t    }\n367\t\n368\t    try {\n369\t      const content = readFileSync(laneStatePath, 'utf-8');\n370\t      const state = JSON.parse(content) as { pid?: number };\n371\t\n372\t      if (!state.pid) {\n373\t        return true;\n374\t      }\n375\t\n376\t      // Check if the PID is still running\n377\t      try {\n378\t        process.kill(state.pid, 0);\n379\t        return false; // Process is alive — not orphaned\n380\t      } catch { // IGNORE: ESRCH means process is dead — worktree is orphaned per AC #8\n381\t        return true;\n382\t      }\n383\t    } catch { // IGNORE: unreadable/corrupt lane-state.json means orphaned per AC #8\n384\t      return true;\n385\t    }\n386\t  }\n387\t}\n388\t"}]},"parent_tool_use_id":"toolu_01WUKKW3Fq3oqhMn79vnXB8N","session_id":"80ecde4e-3ccc-44de-925d-a2036bf845d1","uuid":"991ece80-6030-4243-9c5b-fb0a459df6bf","timestamp":"2026-04-03T21:18:20.317Z"}
